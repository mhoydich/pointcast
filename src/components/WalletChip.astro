---
/**
 * WalletChip — v2-tokenized wallet chip with multi-wallet memory.
 *
 * Beacon SDK is the single source of truth for the current signing
 * session (one active wallet at a time — Beacon's design). We layer
 * remembered-wallet memory on top:
 *
 *   localStorage
 *     pc:wallets         -> Array<Wallet>   (every wallet this browser has
 *                                             paired with, newest last)
 *     pc:wallet          -> Wallet          (mirror of the ACTIVE wallet;
 *                                             MintButton + other legacy
 *                                             surfaces read this key)
 *     pc:wallet-active   -> string          (address currently active;
 *                                             default = most-recent pair)
 *
 * Flows:
 *   disconnected → Beacon picker opens (Kukai/Temple/Umami/Airgap);
 *                  returned address pushed to pc:wallets + marked active
 *   connected   → chip shows short active address + provider; dropdown
 *                  gives: "Connect another wallet" (re-opens picker),
 *                  "View profile" link, "Disconnect this wallet"
 *
 * /profile visualizes every remembered wallet with balance/NFT/ops counts
 * and lets the user switch which is active or remove any.
 *
 * Public events:
 *   window 'pc:wallet-change' { detail: activeWallet | null }
 *   window 'pc:open-wallet-menu' (anyone can trigger the dropdown)
 */
---

<div class="wallet-chip" id="wallet-chip">
  <button
    type="button"
    class="wallet-chip__btn"
    id="wallet-chip-btn"
    aria-haspopup="menu"
    aria-expanded="false"
    aria-label="Connect wallet"
  >
    <span class="wallet-chip__dot" aria-hidden="true"></span>
    <span class="wallet-chip__label" id="wallet-chip-label">connect wallet →</span>
  </button>

  <div class="wallet-chip__menu" id="wallet-chip-menu" role="menu" hidden>
    <!-- disconnected state -->
    <div class="wallet-chip__panel" id="wallet-chip-connect-panel">
      <button type="button" class="wallet-chip__connect" id="wallet-chip-connect">
        Open Beacon picker →
      </button>
      <p class="wallet-chip__footnote">Connect any Tezos wallet. Social sign-in (Google / Apple / etc.) is available inside Kukai.</p>
    </div>

    <!-- connected state -->
    <div class="wallet-chip__panel" id="wallet-chip-connected-panel" hidden>
      <p class="wallet-chip__section">active</p>
      <p class="wallet-chip__kv"><span>addr</span><b id="wallet-chip-addr">—</b></p>
      <p class="wallet-chip__kv"><span>provider</span><b id="wallet-chip-prov">—</b></p>
      <p class="wallet-chip__kv"><span>balance</span><b id="wallet-chip-balance">—</b></p>
      <p class="wallet-chip__kv"><span>nfts</span><b id="wallet-chip-nfts">—</b></p>

      <p class="wallet-chip__section" id="wallet-chip-others-label" hidden>remembered (<span id="wallet-chip-others-count">0</span>)</p>
      <ul class="wallet-chip__others" id="wallet-chip-others"></ul>

      <a class="wallet-chip__profile" href="/profile">View profile →</a>

      <button type="button" class="wallet-chip__add" id="wallet-chip-add">
        Connect another wallet →
      </button>
      <button type="button" class="wallet-chip__disconnect" id="wallet-chip-disconnect">
        Disconnect active
      </button>
    </div>
  </div>
</div>

<script>
  type Wallet = { chain: 'tezos'; address: string; provider: string; addedAt: number; label?: string };

  const KEY_WALLETS = 'pc:wallets';
  const KEY_ACTIVE_ADDR = 'pc:wallet-active';
  const KEY_LEGACY = 'pc:wallet'; // mirror of active — MintButton + legacy surfaces read this

  // ────────────────────────────────────────────────────────────────────────
  //  Storage helpers
  // ────────────────────────────────────────────────────────────────────────

  function loadWallets(): Wallet[] {
    try {
      const raw = localStorage.getItem(KEY_WALLETS);
      if (raw) {
        const list = JSON.parse(raw) as Wallet[];
        if (Array.isArray(list)) return list;
      }
      // Migration from single-wallet legacy key if present
      const legacy = localStorage.getItem(KEY_LEGACY);
      if (legacy) {
        const w = JSON.parse(legacy) as Wallet;
        if (w?.address) {
          const migrated = [{ ...w, addedAt: Date.now() }];
          localStorage.setItem(KEY_WALLETS, JSON.stringify(migrated));
          localStorage.setItem(KEY_ACTIVE_ADDR, w.address);
          return migrated;
        }
      }
    } catch { /* ignore */ }
    return [];
  }

  function activeAddress(): string | null {
    try { return localStorage.getItem(KEY_ACTIVE_ADDR); } catch { return null; }
  }

  function activeWallet(): Wallet | null {
    const list = loadWallets();
    const a = activeAddress();
    if (a) {
      const found = list.find((w) => w.address === a);
      if (found) return found;
    }
    // Fallback: most recently added wallet
    return list.length > 0 ? list[list.length - 1] : null;
  }

  function saveWallets(list: Wallet[], newActiveAddr: string | null) {
    localStorage.setItem(KEY_WALLETS, JSON.stringify(list));
    if (newActiveAddr) localStorage.setItem(KEY_ACTIVE_ADDR, newActiveAddr);
    else localStorage.removeItem(KEY_ACTIVE_ADDR);
    const active = list.find((w) => w.address === newActiveAddr) ?? null;
    if (active) localStorage.setItem(KEY_LEGACY, JSON.stringify(active));
    else localStorage.removeItem(KEY_LEGACY);
    window.dispatchEvent(new CustomEvent('pc:wallet-change', { detail: active }));
  }

  function addOrUpdate(wallet: Wallet) {
    const list = loadWallets().filter((w) => w.address !== wallet.address);
    list.push(wallet);
    saveWallets(list, wallet.address);
  }

  function removeWallet(addr: string) {
    const list = loadWallets().filter((w) => w.address !== addr);
    const currentActive = activeAddress();
    const newActive = currentActive === addr
      ? (list.length > 0 ? list[list.length - 1].address : null)
      : currentActive;
    saveWallets(list, newActive);
  }

  function short(addr: string) {
    return addr.length > 12 ? `${addr.slice(0, 6)}…${addr.slice(-4)}` : addr;
  }

  // ────────────────────────────────────────────────────────────────────────
  //  DOM references
  // ────────────────────────────────────────────────────────────────────────

  const chip = document.getElementById('wallet-chip')!;
  const btn = document.getElementById('wallet-chip-btn') as HTMLButtonElement;
  const label = document.getElementById('wallet-chip-label')!;
  const menu = document.getElementById('wallet-chip-menu')!;
  const connectPanel = document.getElementById('wallet-chip-connect-panel')!;
  const connectedPanel = document.getElementById('wallet-chip-connected-panel')!;
  const addrEl = document.getElementById('wallet-chip-addr')!;
  const provEl = document.getElementById('wallet-chip-prov')!;
  const balanceEl = document.getElementById('wallet-chip-balance')!;
  const nftsEl = document.getElementById('wallet-chip-nfts')!;
  const othersLabel = document.getElementById('wallet-chip-others-label')!;
  const othersCountEl = document.getElementById('wallet-chip-others-count')!;
  const othersList = document.getElementById('wallet-chip-others')!;
  const connectBtn = document.getElementById('wallet-chip-connect') as HTMLButtonElement;
  const addBtn = document.getElementById('wallet-chip-add') as HTMLButtonElement;
  const disconnectBtn = document.getElementById('wallet-chip-disconnect') as HTMLButtonElement;

  // ────────────────────────────────────────────────────────────────────────
  //  Render
  // ────────────────────────────────────────────────────────────────────────

  function render() {
    const active = activeWallet();
    const all = loadWallets();
    const others = all.filter((w) => w.address !== active?.address);

    if (active) {
      label.textContent = `${short(active.address)} · ${active.provider}`;
      chip.classList.add('is-connected');
      connectPanel.hidden = true;
      connectedPanel.hidden = false;
      addrEl.textContent = active.address;
      provEl.textContent = active.provider;

      // Others list
      if (others.length > 0) {
        othersLabel.hidden = false;
        othersCountEl.textContent = String(others.length);
        othersList.innerHTML = '';
        for (const w of others) {
          const li = document.createElement('li');
          li.className = 'wallet-chip__other';
          li.innerHTML = `
            <button type="button" class="wallet-chip__other-switch" data-addr="${w.address}">
              <span class="wallet-chip__other-addr">${short(w.address)}</span>
              <span class="wallet-chip__other-prov">${w.provider}</span>
            </button>
          `;
          othersList.appendChild(li);
        }
        othersList.querySelectorAll<HTMLElement>('[data-addr]').forEach((el) => {
          el.addEventListener('click', (e) => {
            const target = (e.currentTarget as HTMLElement).dataset.addr;
            if (!target) return;
            // "Soft-switch" — mark this wallet as active for DISPLAY purposes.
            // Beacon is still paired with its own active session; any signing
            // action (mint, collect) will use Beacon's view. The profile page
            // surfaces this distinction + offers a full re-pair flow.
            const list = loadWallets();
            if (list.some((w) => w.address === target)) saveWallets(list, target);
            render();
            closeMenu();
          });
        });
      } else {
        othersLabel.hidden = true;
        othersList.innerHTML = '';
      }

      // Fire-and-forget visualizer fetch
      void loadVisualizer(active.address);
    } else {
      label.textContent = 'connect wallet →';
      chip.classList.remove('is-connected');
      connectPanel.hidden = false;
      connectedPanel.hidden = true;
    }
  }

  async function loadVisualizer(addr: string) {
    balanceEl.textContent = '…'; nftsEl.textContent = '…';
    try {
      const [accountRes, tokensRes] = await Promise.all([
        fetch(`https://api.tzkt.io/v1/accounts/${addr}`),
        fetch(`https://api.tzkt.io/v1/tokens/balances/count?account=${addr}&balance.gt=0`),
      ]);
      if (accountRes.ok) {
        const a = await accountRes.json();
        const tz = ((a.balance ?? 0) / 1_000_000).toFixed(2);
        balanceEl.textContent = `${tz} ꜩ`;
      }
      if (tokensRes.ok) {
        nftsEl.textContent = (await tokensRes.text()).trim();
      }
    } catch {
      balanceEl.textContent = '—'; nftsEl.textContent = '—';
    }
  }

  function openMenu() { menu.hidden = false; btn.setAttribute('aria-expanded', 'true'); }
  function closeMenu() { menu.hidden = true; btn.setAttribute('aria-expanded', 'false'); }
  function toggleMenu() { menu.hidden ? openMenu() : closeMenu(); }

  btn.addEventListener('click', toggleMenu);
  document.addEventListener('click', (e) => {
    if (!chip.contains(e.target as Node)) closeMenu();
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });

  // External open trigger
  window.addEventListener('pc:open-wallet-menu', () => openMenu());

  // ────────────────────────────────────────────────────────────────────────
  //  Beacon flows
  // ────────────────────────────────────────────────────────────────────────

  async function connectFlow(button: HTMLButtonElement, originalText: string) {
    button.disabled = true;
    button.textContent = 'Loading Beacon…';
    try {
      // Beacon only maintains one active session; calling requestPermissions
      // again prompts for a fresh pair. We clear first so the picker actually
      // shows (vs. silently returning the existing session).
      const { connectKukai, disconnectKukai } = await import('../lib/tezos');
      const existing = activeWallet();
      if (existing) {
        try { await disconnectKukai(); } catch { /* best-effort */ }
      }
      const addr = await connectKukai();
      addOrUpdate({ chain: 'tezos', address: addr, provider: 'beacon', addedAt: Date.now() });
      render();
      closeMenu();
    } catch (err: any) {
      const msg = err?.message || String(err);
      if (/reject|cancel|abort/i.test(msg)) {
        button.textContent = 'Cancelled — retry';
      } else {
        button.textContent = 'Failed — retry';
        console.warn('wallet connect failed:', err);
      }
      setTimeout(() => { button.textContent = originalText; button.disabled = false; }, 2400);
      return;
    }
    button.textContent = originalText;
    button.disabled = false;
  }

  connectBtn.addEventListener('click', () => connectFlow(connectBtn, 'Open Beacon picker →'));
  addBtn.addEventListener('click', () => connectFlow(addBtn, 'Connect another wallet →'));

  disconnectBtn.addEventListener('click', async () => {
    const active = activeWallet();
    if (!active) return;
    try {
      const { disconnectKukai } = await import('../lib/tezos');
      await disconnectKukai();
    } catch { /* best-effort */ }
    removeWallet(active.address);
    render();
    closeMenu();
  });

  // Cross-tab + same-tab sync
  window.addEventListener('storage', (e) => {
    if (e.key === KEY_WALLETS || e.key === KEY_ACTIVE_ADDR || e.key === KEY_LEGACY) render();
  });
  window.addEventListener('pc:wallet-change', () => render());

  render();
</script>

<style>
  .wallet-chip { position: relative; display: inline-flex; }

  .wallet-chip__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 8px;
    border: 1px solid var(--pc-rule);
    background: #fff;
    color: var(--pc-ink-muted);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 2px;
    cursor: pointer;
    transition: background-color 0.12s, border-color 0.12s, color 0.12s;
  }
  .wallet-chip__btn:hover {
    border-color: var(--pc-accent);
    color: var(--pc-accent);
  }

  .wallet-chip__dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--pc-ink-muted);
    transition: background-color 0.12s;
  }
  .wallet-chip.is-connected .wallet-chip__btn {
    border-color: #2F8F5F;
    color: #206d46;
  }
  .wallet-chip.is-connected .wallet-chip__dot {
    background: #2F8F5F;
    box-shadow: 0 0 0 0 rgba(47,143,95,0.4);
    animation: wc-pulse 2s infinite;
  }
  @keyframes wc-pulse {
    0% { box-shadow: 0 0 0 0 rgba(47,143,95,0.5); }
    80%, 100% { box-shadow: 0 0 0 6px rgba(47,143,95,0); }
  }

  .wallet-chip__menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    width: 300px;
    background: #fff;
    border: 1px solid var(--pc-ink);
    border-radius: 2px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    z-index: 50;
    padding: 12px 14px;
  }
  @media (max-width: 639px) { .wallet-chip__menu { width: 260px; } }

  .wallet-chip__section {
    font-family: var(--pc-font-mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin: 0 0 6px;
  }
  .wallet-chip__section:not(:first-child) { margin-top: 12px; }

  .wallet-chip__connect,
  .wallet-chip__disconnect,
  .wallet-chip__add {
    width: 100%;
    padding: 8px 10px;
    border: 1.5px solid var(--pc-ink);
    background: var(--pc-ink);
    color: #fff;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    border-radius: 2px;
    cursor: pointer;
    transition: background-color 0.1s;
  }
  .wallet-chip__connect:hover,
  .wallet-chip__add:hover {
    background: var(--pc-accent);
    border-color: var(--pc-accent);
  }
  .wallet-chip__connect:disabled,
  .wallet-chip__disconnect:disabled,
  .wallet-chip__add:disabled { opacity: 0.55; cursor: not-allowed; }

  .wallet-chip__add { margin-top: 10px; }

  .wallet-chip__disconnect {
    background: #fff;
    color: var(--pc-ink);
    margin-top: 8px;
  }
  .wallet-chip__disconnect:hover {
    background: #f4f2ed;
    color: var(--pc-ink);
    border-color: var(--pc-ink);
  }

  .wallet-chip__footnote {
    font-family: var(--pc-font-sans);
    font-size: 10.5px;
    line-height: 1.4;
    color: var(--pc-ink-muted);
    margin: 8px 0 0;
    font-style: italic;
  }

  .wallet-chip__kv {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
    margin: 4px 0;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
  }
  .wallet-chip__kv b {
    font-weight: 500;
    color: var(--pc-ink);
    word-break: break-all;
    text-align: right;
    max-width: 200px;
  }

  .wallet-chip__others {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .wallet-chip__other-switch {
    display: flex;
    width: 100%;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
    padding: 6px 8px;
    border: 1px solid var(--pc-rule);
    background: #fff;
    border-radius: 2px;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pc-ink);
    cursor: pointer;
    transition: background-color 0.1s, border-color 0.1s;
  }
  .wallet-chip__other-switch:hover {
    border-color: var(--pc-ink);
    background: #f4f2ed;
  }
  .wallet-chip__other-prov { color: var(--pc-ink-muted); }

  .wallet-chip__profile {
    display: block;
    margin-top: 10px;
    padding: 7px 9px;
    border: 1px solid var(--pc-accent);
    color: var(--pc-accent);
    text-align: center;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 2px;
  }
  .wallet-chip__profile:hover {
    background: var(--pc-accent);
    color: #fff;
    text-decoration: none;
  }
</style>
