---
/**
 * NounsCursor v2 — a tiny Noun head follows your mouse on every drum page.
 *
 * Per Mike 2026-04-26: "the cursor should be a noun not the glasses and
 * its very laggy". Fixed both:
 *   1. Cursor is now a 32×32 Nouns avatar, derived from the visitor's
 *      session id so each person gets their own noun cursor.
 *   2. Lag came from `document.elementFromPoint` on every mousemove (60+/sec)
 *      plus a CSS `transition` smearing transform updates. Both removed.
 *      Position now updates inside requestAnimationFrame for one paint
 *      per frame regardless of mousemove burst rate. Hover state moved
 *      to mouseover/mouseout delegation — same warm-glow effect, zero
 *      per-frame cost.
 *
 * Hidden on touch devices. Inputs/textareas keep a native text caret.
 */
---

<div id="nouns-cursor" aria-hidden="true">
  <img id="nouns-cursor-img" src="" alt="" width="32" height="32" />
</div>

<style is:global>
  @media (hover: hover) and (pointer: fine) {
    body.drum-body, body.drum-body * { cursor: none !important; }
    body.drum-body input,
    body.drum-body textarea,
    body.drum-body [contenteditable="true"] { cursor: text !important; }
  }
  #nouns-cursor {
    position: fixed; top: 0; left: 0;
    width: 32px; height: 32px;
    pointer-events: none;
    z-index: 9999;
    transform: translate3d(-9999px, -9999px, 0);
    will-change: transform;
  }
  #nouns-cursor img {
    display: block;
    width: 32px; height: 32px;
    image-rendering: pixelated;
    filter: drop-shadow(0 1px 1px rgba(18,17,14,0.25));
    transition: transform 80ms ease-out, filter 100ms ease-out;
  }
  #nouns-cursor.tap img { transform: scale(1.3); }
  #nouns-cursor.over-link img {
    filter: drop-shadow(0 0 6px rgba(194,106,74,0.85)) drop-shadow(0 1px 1px rgba(18,17,14,0.25));
  }
  @media (hover: none), (pointer: coarse) {
    #nouns-cursor { display: none; }
  }
</style>

<script>
  const cursor = document.getElementById('nouns-cursor') as HTMLElement | null;
  const cursorImg = document.getElementById('nouns-cursor-img') as HTMLImageElement | null;

  if (cursor && cursorImg && !matchMedia('(pointer: coarse)').matches) {
    function pickNoun(): number {
      try {
        const sid = localStorage.getItem('pc:reactSessionId') || '';
        if (!sid) return 42;
        let h = 0;
        for (let i = 0; i < sid.length; i++) { h = ((h << 5) - h) + sid.charCodeAt(i); h = h | 0; }
        return Math.abs(h) % 1200;
      } catch { return 42; }
    }
    cursorImg.src = `https://noun.pics/${pickNoun()}.svg`;

    let pendingX = 0, pendingY = 0;
    let rafScheduled = false;
    function flushPosition() {
      cursor!.style.transform = `translate3d(${pendingX - 16}px, ${pendingY - 16}px, 0)`;
      rafScheduled = false;
    }
    document.addEventListener('mousemove', (e) => {
      pendingX = e.clientX;
      pendingY = e.clientY;
      if (!rafScheduled) {
        rafScheduled = true;
        requestAnimationFrame(flushPosition);
      }
    }, { passive: true });

    function isInteractive(node: EventTarget | null): boolean {
      let n = node as Element | null;
      let depth = 0;
      while (n && depth < 5) {
        if (!('tagName' in n)) return false;
        const t = (n as HTMLElement).tagName;
        if (t === 'A' || t === 'BUTTON' || t === 'INPUT' || t === 'SELECT' || t === 'TEXTAREA' || t === 'LABEL') return true;
        if ((n as HTMLElement).getAttribute?.('role') === 'button') return true;
        n = (n as HTMLElement).parentElement;
        depth++;
      }
      return false;
    }
    document.addEventListener('mouseover', (e) => {
      if (isInteractive(e.target)) cursor.classList.add('over-link');
    }, { passive: true });
    document.addEventListener('mouseout', (e) => {
      if (isInteractive(e.target) && !isInteractive(e.relatedTarget)) {
        cursor.classList.remove('over-link');
      }
    }, { passive: true });

    document.addEventListener('mousedown', () => cursor.classList.add('tap'), { passive: true });
    document.addEventListener('mouseup',   () => cursor.classList.remove('tap'), { passive: true });
    document.addEventListener('mouseleave', () => {
      cursor.style.transform = 'translate3d(-9999px, -9999px, 0)';
    });
  }
</script>
