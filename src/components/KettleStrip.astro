---
/**
 * KettleStrip — homepage invite to /kettle.
 *
 * Per Mike 2026-04-27: "fun publish and lets do another kettle or
 * coffee play, something fun to participate with." A small cozy pill
 * on the homepage so visitors discover the multiplayer kettle and
 * stoke it together. Single line, gingham-blue accent, links straight
 * to the kitchen.
 */
---

<a class="kettle-strip" href="/kettle" aria-label="The kettle is on at /kettle">
  <span class="kettle-strip__emoji" aria-hidden="true">🫖</span>
  <span class="kettle-strip__copy">
    <span class="kettle-strip__line1">The kettle is on at <strong>/kettle</strong>.</span>
    <span class="kettle-strip__line2">Stoke the flame together — the room boils when we all show up.</span>
  </span>
  <span class="kettle-strip__cta" aria-hidden="true">enter the kitchen →</span>
</a>

<style>
  .kettle-strip {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 14px;
    margin: 18px 0 24px;
    padding: 14px 18px;
    border: 2px solid var(--pc-ink, #12110e);
    box-shadow: 4px 4px 0 0 var(--pc-ink, #12110e);
    background:
      repeating-linear-gradient(0deg, rgba(95, 186, 253, 0.10) 0 14px, transparent 14px 28px),
      repeating-linear-gradient(90deg, rgba(95, 186, 253, 0.10) 0 14px, transparent 14px 28px),
      var(--pc-paper, #fffaf0);
    color: var(--pc-ink, #12110e);
    text-decoration: none;
    transition: transform 120ms, box-shadow 120ms;
  }

  .kettle-strip:hover {
    transform: translate(-1px, -1px);
    box-shadow: 5px 5px 0 0 var(--pc-ink, #12110e);
    text-decoration: none;
  }

  .kettle-strip__emoji {
    font-size: 36px;
    line-height: 1;
    filter: drop-shadow(2px 2px 0 rgba(18, 17, 14, 0.18));
  }

  .kettle-strip__copy {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .kettle-strip__line1 {
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: clamp(15px, 2vw, 19px);
    line-height: 1.25;
  }
  .kettle-strip__line1 strong {
    font-style: normal;
    font-family: 'JetBrains Mono Variable', ui-monospace, monospace;
    font-size: 0.92em;
    color: #b8431a;
    background: #ffd400;
    padding: 1px 6px;
    border: 1px solid var(--pc-ink, #12110e);
  }
  .kettle-strip__line2 {
    font-size: 12px;
    color: var(--pc-ink-soft, #5f5e5a);
  }

  .kettle-strip__cta {
    font-family: 'JetBrains Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #b8431a;
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .kettle-strip { grid-template-columns: auto 1fr; }
    .kettle-strip__cta { grid-column: 1 / -1; text-align: right; padding-top: 4px; }
  }
</style>
