---
const eras = ['80s', '70s', '60s', 'ancient', 'future'] as const;
const families = [
  {
    id: 'postal-skate',
    title: 'Postal Skate Zine',
    setting: 'near post offices, blue mailboxes, loading docks, pasted wheatpaper edges',
    style: 'skate-magazine paste-up, distressed halftone, no brand logos',
  },
  {
    id: 'ocean',
    title: 'Ocean Head',
    setting: 'shoreline fog, tide pools, pier shadows, open water horizon',
    style: 'monochrome devotional photo collage with cyan digital tinting',
  },
  {
    id: 'de-stijl',
    title: 'De Stijl Grid',
    setting: 'flat white gallery air, primary-color geometry, quiet negative space',
    style: 'neoplastic grid language, clean rectangles, black rulework',
  },
  {
    id: 'silkscreen-pop',
    title: 'Silkscreen Pop',
    setting: 'repeated studio panels, ink registration marks, commercial printing table',
    style: 'pop-art silkscreen repeats, bold contrast, offset color plates',
  },
  {
    id: 'stamp-sheet',
    title: 'Stamp Sheet',
    setting: 'perforated postal sheets, cancellation marks, microprint, denomination corners',
    style: 'collectible stamp engraving, monochrome base, archival paper grain',
  },
  {
    id: 'meditating',
    title: 'Meditating Head',
    setting: 'empty room, low cushion, single shaft of light, still air',
    style: 'quiet meditation poster, softened graphite, devotional symmetry',
  },
  {
    id: 'stock-exchange',
    title: 'Exchange Floor',
    setting: 'empty stock exchange floor, dead tickers, marble rails, stale fluorescent light',
    style: 'midcentury modern art-deco finance mural, severe monochrome',
  },
  {
    id: 'agency-loft',
    title: 'Agency Loft',
    setting: 'New York City advertising agency loft, drafting tables, type drawers, windows',
    style: 'midcentury studio photograph with art-deco poster geometry',
  },
  {
    id: 'subway',
    title: 'Subway Platform',
    setting: 'New York City subway platform, tiled columns, late-night train blur',
    style: 'street-documentary monochrome with toner streaks',
  },
  {
    id: 'tokyo',
    title: 'Tokyo Signal',
    setting: 'Tokyo side street, vending machines, station signs, rain reflections',
    style: 'high-contrast night print with restrained neon tinting',
  },
  {
    id: 'mountain-sculpture',
    title: 'Mountain Sculpture',
    setting: 'major mountain face, carved colossal head, snowline, pilgrimage path',
    style: 'monumental landscape study, silver gelatin, stone-grain detail',
  },
  {
    id: 'airport-chapel',
    title: 'Airport Chapel',
    setting: 'empty airport interfaith chapel, vinyl chairs, arrivals board glow',
    style: 'institutional calm, monochrome security-camera softness',
  },
  {
    id: 'bank-vault',
    title: 'Bank Vault',
    setting: 'open bank vault, safe deposit boxes, polished steel, fluorescent hush',
    style: 'art-deco banking poster, metallic duotone tint',
  },
  {
    id: 'broadcast-studio',
    title: 'Broadcast Studio',
    setting: 'silent public-access TV studio, cameras idle, waveform monitors',
    style: 'analog video still, scanlines, spiritual test pattern',
  },
  {
    id: 'desert-motel',
    title: 'Desert Motel',
    setting: 'empty desert motel office, ice machine, sunset through blinds',
    style: 'roadside postcard, dusty monochrome with amber digital tint',
  },
  {
    id: 'library-basement',
    title: 'Library Basement',
    setting: 'archive basement, microfilm readers, catalog drawers, buzzing lights',
    style: 'xerox devotional, fine dust, high-detail paper texture',
  },
  {
    id: 'computer-lab',
    title: 'Computer Lab',
    setting: '1980s computer lab, beige terminals, acoustic panels, empty swivel chairs',
    style: 'early digital imaging, ordered dithering, phosphor-green tint',
  },
  {
    id: 'roller-rink',
    title: 'Roller Rink',
    setting: 'closed roller rink, mirrored ball, rental counter, scuffed floor',
    style: 'flash-photo zine collage, devotional grin of reflected light',
  },
  {
    id: 'museum-loading',
    title: 'Museum Loading Dock',
    setting: 'museum loading dock, crates, foam blocks, freight elevator',
    style: 'catalogue proof sheet, conservation-label precision',
  },
  {
    id: 'moon-terminal',
    title: 'Moon Terminal',
    setting: 'empty lunar transit terminal, dust on glass, Earth reflected in signage',
    style: 'retro-future monochrome, soft blue timestamping, serene monumentalism',
  },
] as const;

const variants = families.flatMap((family, familyIndex) =>
  eras.map((era, eraIndex) => {
    const number = familyIndex * eras.length + eraIndex + 1;
    return {
      id: `${family.id}-${era}`,
      number,
      title: `${family.title} / ${era}`,
      family: family.title,
      era,
      setting: family.setting,
      tint: ['ice blue', 'warm gray', 'newsprint red', 'sea green', 'gold wash'][(number - 1) % 5],
      image: `/images/buddha-heads/${String(number).padStart(3, '0')}-${family.id}-${era}.png`,
      prompt: `Image-model prompt ${String(number).padStart(3, '0')}: Buddha head study, ${era} register, ${family.setting}; ${family.style}; mostly monochrome with ${['ice blue', 'warm gray', 'newsprint red', 'sea green', 'gold wash'][(number - 1) % 5]} digital tinting; signed Michael Hoydich; no trademarks, no logos, no legible third-party mastheads.`,
    };
  }),
);

interface Props {
  context?: 'home' | 'block';
}

const { context = 'home' } = Astro.props;
---

<section class:list={['buddha-rotator', `buddha-rotator--${context}`]} data-buddha-rotator aria-labelledby={`buddha-rotator-title-${context}`}>
  <div class="buddha-rotator__header">
    <div>
      <p class="buddha-rotator__kicker">IMAGE MODEL ROTATION · 100 HEADS</p>
      <h2 id={`buddha-rotator-title-${context}`}>Buddha heads, signed Michael Hoydich</h2>
    </div>
    <div class="buddha-rotator__counter" aria-live="polite">
      <span data-current-number>001</span>
      <span>/100</span>
    </div>
  </div>

  <div class="buddha-rotator__body">
    <div class="buddha-rotator__stage">
      <canvas data-buddha-canvas width="1200" height="900" aria-label="Rotating generative preview of the current Buddha head prompt"></canvas>
      <img data-buddha-image alt="" loading="lazy" decoding="async" />
      <div class="buddha-rotator__stamp" aria-hidden="true">MICHAEL HOYDICH</div>
    </div>

    <div class="buddha-rotator__panel">
      <div class="buddha-rotator__readout">
        <p data-variant-family>Postal Skate Zine</p>
        <h3 data-variant-title>Postal Skate Zine / 80s</h3>
        <span data-variant-era>80s</span>
      </div>

      <p class="buddha-rotator__prompt" data-variant-prompt>{variants[0].prompt}</p>

      <div class="buddha-rotator__controls" aria-label="Rotation controls">
        <button type="button" data-prev aria-label="Previous image direction">←</button>
        <button type="button" data-play aria-pressed="true">Pause</button>
        <button type="button" data-next aria-label="Next image direction">→</button>
        <button type="button" data-shuffle>Shuffle</button>
      </div>

      <fieldset class="buddha-rotator__audio">
        <legend>Audio</legend>
        <label><input type="radio" name={`buddha-audio-${context}`} value="silent" checked /> Silent</label>
        <label><input type="radio" name={`buddha-audio-${context}`} value="meditative" /> Meditative</label>
        <label><input type="radio" name={`buddha-audio-${context}`} value="ocean" /> Ocean</label>
        <label><input type="radio" name={`buddha-audio-${context}`} value="subway" /> Subway hum</label>
      </fieldset>

      <div class="buddha-rotator__meta">
        <span>monochrome filter</span>
        <span>digital tinting</span>
        <span>postal / ocean / city / mountain</span>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ variants }}>
  (function () {
    const roots = document.querySelectorAll('[data-buddha-rotator]');
    if (!roots.length) return;

    roots.forEach((root) => {
      const canvas = root.querySelector('[data-buddha-canvas]');
      const ctx = canvas?.getContext('2d');
      if (!canvas || !ctx) return;

      const imageEl = root.querySelector('[data-buddha-image]');
      const currentNumber = root.querySelector('[data-current-number]');
      const familyEl = root.querySelector('[data-variant-family]');
      const titleEl = root.querySelector('[data-variant-title]');
      const eraEl = root.querySelector('[data-variant-era]');
      const promptEl = root.querySelector('[data-variant-prompt]');
      const playBtn = root.querySelector('[data-play]');
      const prevBtn = root.querySelector('[data-prev]');
      const nextBtn = root.querySelector('[data-next]');
      const shuffleBtn = root.querySelector('[data-shuffle]');
      const audioInputs = root.querySelectorAll('input[type="radio"]');
      const palette = {
        'ice blue': ['#101418', '#dce7ed', '#7fb0cb'],
        'warm gray': ['#15130f', '#e0d7ca', '#9a8872'],
        'newsprint red': ['#130f0f', '#eee8dd', '#b23a32'],
        'sea green': ['#0e1513', '#dfeae4', '#3c8a72'],
        'gold wash': ['#16130c', '#efe4c5', '#c99d35'],
      };
      let index = 0;
      let playing = true;
      let audioContext = null;
      let audioNodes = [];

      function hash(str) {
        let h = 2166136261;
        for (let i = 0; i < str.length; i++) {
          h ^= str.charCodeAt(i);
          h = Math.imul(h, 16777619);
        }
        return h >>> 0;
      }

      function randomFrom(seed) {
        let t = seed + 0x6D2B79F5;
        return function () {
          t = Math.imul(t ^ (t >>> 15), t | 1);
          t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
          return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
        };
      }

      function drawHead(x, y, scale, ink, paper, tint, r) {
        ctx.save();
        ctx.translate(x, y);
        ctx.scale(scale, scale);
        ctx.lineWidth = 6;
        ctx.strokeStyle = ink;
        ctx.fillStyle = paper;
        ctx.beginPath();
        ctx.ellipse(0, -8, 96, 124, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.stroke();
        ctx.beginPath();
        ctx.ellipse(0, -134, 34, 42, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.stroke();
        ctx.fillStyle = tint;
        for (let i = 0; i < 24; i++) {
          const angle = (i / 24) * Math.PI * 2;
          const px = Math.cos(angle) * (62 + r() * 22);
          const py = -78 + Math.sin(angle) * (42 + r() * 14);
          ctx.beginPath();
          ctx.arc(px, py, 7 + r() * 4, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.strokeStyle = ink;
        ctx.beginPath();
        ctx.moveTo(-42, -24);
        ctx.quadraticCurveTo(-18, -34, -2, -24);
        ctx.moveTo(42, -24);
        ctx.quadraticCurveTo(18, -34, 2, -24);
        ctx.moveTo(0, -10);
        ctx.quadraticCurveTo(-10, 18, 0, 34);
        ctx.moveTo(-30, 58);
        ctx.quadraticCurveTo(0, 74, 30, 58);
        ctx.stroke();
        ctx.restore();
      }

      function drawVariant(variant) {
        const seed = hash(variant.id);
        const r = randomFrom(seed);
        const [ink, paper, tint] = palette[variant.tint] || palette['ice blue'];
        ctx.fillStyle = paper;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        ctx.globalAlpha = 0.36;
        ctx.fillStyle = tint;
        for (let i = 0; i < 28; i++) {
          ctx.fillRect(r() * canvas.width, r() * canvas.height, 18 + r() * 140, 2 + r() * 26);
        }
        ctx.globalAlpha = 1;

        if (variant.family.includes('De Stijl')) {
          ctx.strokeStyle = ink;
          ctx.lineWidth = 12;
          [180, 420, 760, 940].forEach((x) => { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, 900); ctx.stroke(); });
          [160, 380, 650].forEach((y) => { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(1200, y); ctx.stroke(); });
          ['#d3322d', '#e7c82f', '#245aa8'].forEach((color, i) => {
            ctx.fillStyle = color;
            ctx.fillRect(60 + i * 330, 55 + i * 180, 190, 130);
          });
        }

        if (variant.family.includes('Stamp')) {
          ctx.strokeStyle = ink;
          ctx.lineWidth = 5;
          ctx.setLineDash([4, 12]);
          ctx.strokeRect(82, 62, 1036, 760);
          ctx.setLineDash([]);
        }

        if (variant.family.includes('Subway') || variant.family.includes('Tokyo')) {
          ctx.strokeStyle = ink;
          ctx.lineWidth = 7;
          for (let i = 0; i < 9; i++) {
            ctx.beginPath();
            ctx.moveTo(0, 120 + i * 72);
            ctx.lineTo(1200, 96 + i * 80);
            ctx.stroke();
          }
        }

        if (variant.family.includes('Mountain')) {
          ctx.fillStyle = ink;
          ctx.globalAlpha = 0.9;
          ctx.beginPath();
          ctx.moveTo(0, 760);
          ctx.lineTo(180, 420);
          ctx.lineTo(380, 620);
          ctx.lineTo(590, 300);
          ctx.lineTo(820, 610);
          ctx.lineTo(1040, 390);
          ctx.lineTo(1200, 760);
          ctx.closePath();
          ctx.fill();
          ctx.globalAlpha = 1;
        }

        const repeats = variant.family.includes('Silkscreen') ? 4 : variant.family.includes('Stamp') ? 6 : 1;
        for (let i = 0; i < repeats; i++) {
          const cols = repeats === 4 ? 2 : repeats === 6 ? 3 : 1;
          const row = Math.floor(i / cols);
          const col = i % cols;
          const x = repeats === 1 ? 600 : 250 + col * 350;
          const y = repeats === 1 ? 420 : 300 + row * 300;
          drawHead(x, y, repeats === 1 ? 2.25 : 0.9, ink, paper, tint, r);
        }

        ctx.fillStyle = ink;
        ctx.font = '28px monospace';
        ctx.fillText(`NO. ${String(variant.number).padStart(3, '0')} / ${variant.era.toUpperCase()}`, 62, 74);
        ctx.font = '24px monospace';
        ctx.fillText('SIGNED MICHAEL HOYDICH', 62, 842);
        ctx.fillStyle = tint;
        ctx.fillText(variant.family.toUpperCase(), 62, 804);

        const image = ctx.getImageData(0, 0, canvas.width, canvas.height);
        for (let i = 0; i < image.data.length; i += 4) {
          const noise = (r() - 0.5) * 28;
          image.data[i] = Math.max(0, Math.min(255, image.data[i] + noise));
          image.data[i + 1] = Math.max(0, Math.min(255, image.data[i + 1] + noise));
          image.data[i + 2] = Math.max(0, Math.min(255, image.data[i + 2] + noise));
        }
        ctx.putImageData(image, 0, 0);
      }

      function show(nextIndex) {
        index = (nextIndex + variants.length) % variants.length;
        const variant = variants[index];
        currentNumber.textContent = String(variant.number).padStart(3, '0');
        familyEl.textContent = variant.family;
        titleEl.textContent = variant.title;
        eraEl.textContent = variant.era;
        promptEl.textContent = variant.prompt;
        drawVariant(variant);
        imageEl.hidden = true;
        imageEl.removeAttribute('src');
        imageEl.onload = () => {
          imageEl.hidden = false;
          canvas.style.visibility = 'hidden';
        };
        imageEl.onerror = () => {
          imageEl.hidden = true;
          canvas.style.visibility = 'visible';
        };
        canvas.style.visibility = 'visible';
        imageEl.src = variant.image;
      }

      function stopAudio() {
        audioNodes.forEach((node) => {
          try { node.stop ? node.stop() : node.disconnect(); } catch (e) {}
        });
        audioNodes = [];
      }

      function playAudio(mode) {
        stopAudio();
        if (mode === 'silent') return;
        audioContext = audioContext || new (window.AudioContext || window.webkitAudioContext)();
        const master = audioContext.createGain();
        master.gain.value = 0.035;
        master.connect(audioContext.destination);
        const freqs = mode === 'meditative' ? [136.1, 204.15, 272.2] : mode === 'ocean' ? [82, 123, 164] : [55, 110, 220];
        freqs.forEach((freq, i) => {
          const osc = audioContext.createOscillator();
          const gain = audioContext.createGain();
          osc.type = mode === 'subway' ? 'sawtooth' : 'sine';
          osc.frequency.value = freq;
          gain.gain.value = i === 0 ? 0.55 : 0.22;
          osc.connect(gain);
          gain.connect(master);
          osc.start();
          audioNodes.push(osc, gain);
        });
      }

      prevBtn.addEventListener('click', () => show(index - 1));
      nextBtn.addEventListener('click', () => show(index + 1));
      shuffleBtn.addEventListener('click', () => show(Math.floor(Math.random() * variants.length)));
      playBtn.addEventListener('click', () => {
        playing = !playing;
        playBtn.textContent = playing ? 'Pause' : 'Play';
        playBtn.setAttribute('aria-pressed', String(playing));
      });
      audioInputs.forEach((input) => {
        input.addEventListener('change', () => {
          if (input.checked) playAudio(input.value);
        });
      });
      setInterval(() => {
        if (playing) show(index + 1);
      }, 7000);
      show(0);
    });
  })();
</script>

<style>
  .buddha-rotator {
    margin: 16px 0 18px;
    padding: 14px;
    border: 1.5px solid #151515;
    background: #f8f6ee;
    color: #111;
    font-family: var(--pc-font-sans);
  }

  .buddha-rotator--block {
    margin-top: 18px;
  }

  .buddha-rotator__header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: end;
    padding-bottom: 12px;
    border-bottom: 1px solid #151515;
  }

  .buddha-rotator__kicker,
  .buddha-rotator__counter,
  .buddha-rotator__meta,
  .buddha-rotator__audio legend {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .buddha-rotator__kicker {
    margin: 0 0 6px;
    color: #8a2432;
  }

  .buddha-rotator h2 {
    margin: 0;
    font-size: clamp(24px, 4vw, 52px);
    line-height: 0.96;
    letter-spacing: 0;
    font-weight: 500;
  }

  .buddha-rotator__counter {
    display: flex;
    gap: 4px;
    border: 1px solid #151515;
    padding: 8px 10px;
    background: #fff;
    white-space: nowrap;
  }

  .buddha-rotator__body {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(300px, 0.6fr);
    gap: 14px;
    padding-top: 14px;
  }

  .buddha-rotator__stage {
    position: relative;
    min-width: 0;
    background: #111;
    border: 1px solid #151515;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .buddha-rotator__stage canvas {
    width: 100%;
    height: 100%;
    filter: grayscale(0.78) contrast(1.12);
  }

  .buddha-rotator__stage img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.18) contrast(1.04);
  }

  .buddha-rotator__stage img[hidden] {
    display: none;
  }

  .buddha-rotator__stamp {
    position: absolute;
    right: 12px;
    bottom: 10px;
    padding: 5px 8px;
    border: 1px solid rgba(255, 255, 255, 0.7);
    color: #fff;
    background: rgba(0, 0, 0, 0.46);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
  }

  .buddha-rotator__panel {
    display: grid;
    gap: 12px;
    align-content: start;
  }

  .buddha-rotator__readout {
    border-left: 4px solid #8a2432;
    background: #fff;
    padding: 12px;
  }

  .buddha-rotator__readout p,
  .buddha-rotator__readout h3 {
    margin: 0;
  }

  .buddha-rotator__readout p,
  .buddha-rotator__readout span {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #5f5e5a;
  }

  .buddha-rotator__readout h3 {
    margin: 4px 0 8px;
    font-size: 24px;
    line-height: 1.04;
    font-weight: 500;
  }

  .buddha-rotator__prompt {
    margin: 0;
    min-height: 124px;
    padding: 12px;
    background: #111;
    color: #f1efe6;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    line-height: 1.55;
  }

  .buddha-rotator__controls {
    display: grid;
    grid-template-columns: 44px 1fr 44px 1fr;
    gap: 8px;
  }

  .buddha-rotator button {
    min-height: 40px;
    border: 1px solid #151515;
    background: #fff;
    color: #111;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .buddha-rotator button:hover {
    background: #151515;
    color: #fff;
  }

  .buddha-rotator__audio {
    display: grid;
    gap: 8px;
    margin: 0;
    padding: 12px;
    border: 1px solid #d6d4cd;
    background: #fff;
  }

  .buddha-rotator__audio legend {
    padding: 0 4px;
    color: #8a2432;
  }

  .buddha-rotator__audio label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
  }

  .buddha-rotator__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .buddha-rotator__meta span {
    padding: 5px 7px;
    border: 1px solid #d6d4cd;
    background: #fff;
  }

  @media (max-width: 860px) {
    .buddha-rotator__body {
      grid-template-columns: 1fr;
    }

    .buddha-rotator__controls {
      grid-template-columns: 44px 1fr 44px;
    }

    .buddha-rotator__controls [data-shuffle] {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 560px) {
    .buddha-rotator {
      padding: 10px;
    }

    .buddha-rotator__header {
      align-items: start;
      flex-direction: column;
    }

    .buddha-rotator__counter {
      align-self: stretch;
      justify-content: space-between;
    }
  }
</style>
