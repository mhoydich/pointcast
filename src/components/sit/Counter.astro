---
/**
 * Counter — single quiet line.
 *
 *   {N} sitting now · {M} min sat together
 *
 * Server renders em-dashes; the page's WS handler swaps in real numbers
 * once /api/sit reports presence (or stubbed values when the WS isn't
 * up yet — see /sit.astro for the fallback).
 */
---

<p class="sit-counter mono" id="sit-counter" data-state="loading" aria-live="polite">
  <span class="sit-counter__num" data-role="sitting">—</span>
  <span class="sit-counter__label">sitting now</span>
  <span class="sit-counter__sep" aria-hidden="true">·</span>
  <span class="sit-counter__num" data-role="minutes">—</span>
  <span class="sit-counter__label">min sat together</span>
</p>

<style>
  .sit-counter {
    margin: 0;
    font-family: var(--pc-font-mono);
    font-size: clamp(13px, 1.6vw, 18px);
    letter-spacing: 0.14em;
    text-transform: lowercase;
    color: var(--sit-ink);
    font-variant-numeric: tabular-nums;
    display: inline-flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.45em;
    line-height: 1.4;
  }

  .sit-counter__num {
    font-weight: 500;
    font-size: 1.25em;
    color: var(--sit-ink-strong);
  }

  .sit-counter__sep {
    opacity: 0.45;
    margin: 0 0.1em;
  }

  .sit-counter__label {
    opacity: 0.78;
  }

  /* TV mode (set on the parent root via data-surface). The counter is the
     only typography on screen at TV size — oversized and quiet. */
  :global([data-surface='tv']) .sit-counter {
    font-size: clamp(28px, 2.6vw, 56px);
    letter-spacing: 0.20em;
    gap: 0.55em;
  }
</style>
