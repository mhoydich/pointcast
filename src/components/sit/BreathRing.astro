---
/**
 * BreathRing — slow breathing ring SVG.
 *
 * 14-second cycle: 4s inhale (scale up), 2s hold, 6s exhale (scale down),
 * 2s rest. CSS-driven, GPU-friendly, no JS required for the animation.
 * Mobile pages can opt into a Web Vibration API haptic at inhale start;
 * the page is responsible for that, not the ring.
 *
 * The ring color comes from --sit-ring on the parent. No fill, just a
 * thin line — generous negative space is half the room.
 */
---

<svg
  class="sit-breath"
  viewBox="0 0 240 240"
  role="img"
  aria-label="Breath ring: inhale four, hold two, exhale six, rest two."
>
  <circle class="sit-breath__ring" cx="120" cy="120" r="78" fill="none" stroke="var(--sit-ring)" stroke-width="1.25" />
  <circle class="sit-breath__inner" cx="120" cy="120" r="2" fill="var(--sit-ring)" opacity="0.6" />
</svg>

<style>
  .sit-breath {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  .sit-breath__ring {
    transform-box: fill-box;
    transform-origin: center;
    animation: sit-breathe 14s ease-in-out infinite;
  }

  @keyframes sit-breathe {
    /* 0–28%: inhale 4s, scale 0.78 → 1.10 */
    0%   { transform: scale(0.78); opacity: 0.45; }
    28%  { transform: scale(1.10); opacity: 1; }
    /* 28–43%: hold 2s */
    43%  { transform: scale(1.10); opacity: 1; }
    /* 43–86%: exhale 6s, scale back to 0.78 */
    86%  { transform: scale(0.78); opacity: 0.45; }
    /* 86–100%: rest 2s */
    100% { transform: scale(0.78); opacity: 0.45; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sit-breath__ring {
      animation: none;
      transform: scale(1);
      opacity: 0.85;
    }
  }
</style>
