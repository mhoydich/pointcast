---
/**
 * Horizon — Pacific horizon SVG facing west from El Segundo.
 *
 * Three bands: sky, horizon line, water. Time-of-day color wash is driven
 * by CSS variables on the container (--sit-sky-top, --sit-sky-bottom,
 * --sit-water-top, --sit-water-bottom, --sit-horizon-line, --sit-sun)
 * which the parent /sit page sets per the time-of-day idiom shared with
 * PresenceBar (small-hours, morning, midday, golden, blue-hour, evening).
 *
 * The sun sits low and to the right (west). It does not move. We are not
 * trying to simulate the sky — we are anchoring the room to a known
 * direction. The page is the breath, not the sun.
 */
---

<svg
  class="sit-horizon"
  viewBox="0 0 1600 900"
  preserveAspectRatio="xMidYMid slice"
  role="img"
  aria-label="Pacific horizon facing west from El Segundo."
>
  <defs>
    <linearGradient id="sit-sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--sit-sky-top)" />
      <stop offset="100%" stop-color="var(--sit-sky-bottom)" />
    </linearGradient>
    <linearGradient id="sit-water" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--sit-water-top)" />
      <stop offset="100%" stop-color="var(--sit-water-bottom)" />
    </linearGradient>
    <radialGradient id="sit-sun-glow" cx="0.5" cy="0.5" r="0.5">
      <stop offset="0%" stop-color="var(--sit-sun)" stop-opacity="0.55" />
      <stop offset="100%" stop-color="var(--sit-sun)" stop-opacity="0" />
    </radialGradient>
  </defs>

  <rect x="0" y="0" width="1600" height="540" fill="url(#sit-sky)" />
  <rect x="0" y="540" width="1600" height="360" fill="url(#sit-water)" />

  <circle cx="1180" cy="540" r="220" fill="url(#sit-sun-glow)" />
  <circle cx="1180" cy="540" r="56" fill="var(--sit-sun)" opacity="0.85" />

  <line x1="0" y1="540" x2="1600" y2="540" stroke="var(--sit-horizon-line)" stroke-width="1.25" opacity="0.85" />
</svg>

<style>
  .sit-horizon {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
