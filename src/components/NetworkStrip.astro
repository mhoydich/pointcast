---
/**
 * NetworkStrip — home-page promo slot for what's new + worth surfacing.
 *
 * Mike 2026-04-20 15:30 PT: *"network likely almost a spot to yahh
 * promote things."*
 *
 * v1 of this strip was a network-primitive index (here / for-nodes /
 * workbench). v2 is a curated promo rotation — the three most
 * interesting things PointCast has right now, pointed at directly.
 * Still tiny; still live-count tethered to the live congregation so the
 * strip feels alive even when the promo content is static.
 *
 * Promo roster rotates by hand — whoever ships is responsible for
 * swapping what this strip points at. Matches the same discipline as
 * the compute ledger (hand-curated is the feature, not a bug).
 *
 * Author: cc. Source: Mike 2026-04-20 11:15 PT + 15:30 PT chat.
 */

interface PromoItem {
  href: string;
  label: string;
  kicker?: string;
}

// Curated: pick the three most interesting current artifacts. Swap as
// new things ship. Order matters — left is headline.
const PROMO: PromoItem[] = [
  {
    href: '/contribute',
    kicker: 'new',
    label: 'contribute · 5 ways to add compute to PointCast',
  },
  {
    href: '/b/0331',
    kicker: 'today',
    label: 'x402 + Agentic.Market + the compute ledger → payment meets attribution',
  },
  {
    href: '/compute',
    kicker: 'live',
    label: 'compute ledger · who did what, how heavy, paid in what rail',
  },
];
---

<aside class="network-strip" aria-label="What's new on PointCast">
  <p class="network-strip__kicker mono">
    <span class="network-strip__label">PROMOTE</span>
    <span class="network-strip__sep" aria-hidden="true">·</span>
    <span class="network-strip__lede">
      <span id="network-live-count">—</span> here now ·
      <a href="/compute">/compute</a> ·
      <a href="/contribute">/contribute</a> ·
      <a href="/collabs">/collabs</a>
    </span>
  </p>
  <ul class="network-strip__links mono">
    {PROMO.map((p) => (
      <li>
        {p.kicker && <span class="network-strip__tag">{p.kicker}</span>}
        <a href={p.href}>{p.label}</a>
      </li>
    ))}
  </ul>
</aside>

<script is:inline>
  (function () {
    fetch('/api/presence/snapshot', { cache: 'no-store' })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (j) {
        if (!j) return;
        var total = (j.humans || 0) + (j.agents || 0);
        var el = document.getElementById('network-live-count');
        if (el) el.textContent = String(Math.max(total, 1));
      })
      .catch(function () { /* no-op — sensible fallback already in markup */ });
  })();
</script>

<style>
  .network-strip {
    margin: 14px 0 8px;
    padding: 10px 14px;
    background: rgba(24, 95, 165, 0.04);
    border: 1px solid rgba(24, 95, 165, 0.18);
    border-left: 3px solid #185FA5;
    border-radius: 2px;
  }
  .mono {
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', 'Monaco', 'Menlo', ui-monospace, monospace);
  }
  .network-strip__kicker {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 6px;
    color: #0B3E73;
  }
  .network-strip__label { font-weight: 600; }
  .network-strip__sep { margin: 0 6px; opacity: 0.5; }
  .network-strip__lede { color: #38373A; }
  .network-strip__lede a { color: #185FA5; text-decoration: none; border-bottom: 1px dotted rgba(24, 95, 165, 0.35); }
  .network-strip__lede a:hover { border-bottom-color: currentColor; }

  .network-strip__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 11.5px;
    letter-spacing: 0.04em;
  }
  .network-strip__links li {
    line-height: 1.6;
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .network-strip__tag {
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
    color: #fff;
    background: #185FA5;
    padding: 1px 6px;
    border-radius: 2px;
    flex-shrink: 0;
  }
  .network-strip__links a {
    color: #12110E;
    text-decoration: none;
    border-bottom: 1px dotted rgba(24, 95, 165, 0.3);
    font-family: var(--pc-font-sans, system-ui);
    font-size: 13px;
    letter-spacing: 0;
    text-transform: none;
  }
  .network-strip__links a:hover {
    color: #185FA5;
    border-bottom-color: #185FA5;
  }
  @media (max-width: 720px) {
    .network-strip__links { font-size: 12px; gap: 6px; }
    .network-strip__links a { font-size: 12.5px; }
  }
</style>
