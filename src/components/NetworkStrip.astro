---
/**
 * NetworkStrip — small home-page strip surfacing the network primitives.
 *
 * Mike 2026-04-20 11:15 PT: *"look to refresh homepage, include new
 * blocks, approach, etc · i'm also starting to push claude, codex and
 * soon manus to start interacting."*
 *
 * This strip lives between VisitorHereStrip (your own presence) and
 * MoodChip. It points to the three new surfaces that make the network
 * visible: /here (who's connected right now), /for-nodes (how to plug
 * in as a node), /workbench (what everyone is building).
 *
 * Kept deliberately tight — one line on mobile, three inline chips on
 * desktop. Live count hydrates from /api/presence/snapshot on mount.
 *
 * Author: cc. Source: Mike 2026-04-20 11:15 PT chat.
 */
---

<aside class="network-strip" aria-label="Network primitives">
  <p class="network-strip__kicker mono">
    <span class="network-strip__label">NETWORK</span>
    <span class="network-strip__sep" aria-hidden="true">·</span>
    <span class="network-strip__lede">
      <span id="network-live-count">—</span> here now · <span id="network-node-count">3</span> nodes registered
    </span>
  </p>
  <ul class="network-strip__links mono">
    <li><a href="/here">/here → live congregation</a></li>
    <li><a href="/for-nodes">/for-nodes → become a node</a></li>
    <li><a href="/workbench">/workbench → who's building what</a></li>
  </ul>
</aside>

<script is:inline>
  (function () {
    fetch('/api/presence/snapshot', { cache: 'no-store' })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (j) {
        if (!j) return;
        var total = (j.humans || 0) + (j.agents || 0);
        var el = document.getElementById('network-live-count');
        if (el) el.textContent = String(Math.max(total, 1));
      })
      .catch(function () { /* no-op — sensible fallback already in markup */ });
  })();
</script>

<style>
  .network-strip {
    margin: 14px 0 8px;
    padding: 10px 14px;
    background: rgba(24, 95, 165, 0.04);
    border: 1px solid rgba(24, 95, 165, 0.18);
    border-left: 3px solid #185FA5;
    border-radius: 2px;
  }
  .mono {
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', 'Monaco', 'Menlo', ui-monospace, monospace);
  }
  .network-strip__kicker {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 6px;
    color: #0B3E73;
  }
  .network-strip__label { font-weight: 600; }
  .network-strip__sep { margin: 0 6px; opacity: 0.5; }
  .network-strip__lede { color: #38373A; }
  .network-strip__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
    font-size: 11.5px;
    letter-spacing: 0.04em;
  }
  .network-strip__links li { line-height: 1.6; }
  .network-strip__links a {
    color: #8a2432;
    text-decoration: none;
    border-bottom: 1px dotted rgba(138, 36, 50, 0.3);
  }
  .network-strip__links a:hover {
    color: #185FA5;
    border-bottom-color: #185FA5;
  }
  @media (max-width: 720px) {
    .network-strip__links { font-size: 12px; gap: 6px 14px; }
  }
</style>
