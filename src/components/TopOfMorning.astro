---
/**
 * TopOfMorning — daily auto-curated triptych that sits atop the home feed.
 *
 * Sprint #91 Theme E-1 (2026-04-21 afternoon).
 *
 * Selection algorithm (v0):
 *   Pick the 3 "most interesting" blocks from the last 24 hours, where
 *   "interesting" = channel=FD or GDN OR type=READ|NOTE, with at least
 *   a dek, timestamped within 24h of now (server-render time). Sort by
 *   timestamp desc. Deduplicate against whatever HeroBlock landed on.
 *
 * Fallback: if fewer than 3 qualify in the last 24h, widen to 48h. If
 *   still under 3, render nothing (home hero + feed cover the case).
 *
 * Mike 2026-04-21 13:00 PT sprint #91 E-1: "auto-select the three most-
 * interesting blocks from the last 24h and renders them atop the home feed."
 */
const blockModules = import.meta.glob('../content/blocks/*.json', { eager: true });
const blocks = Object.values(blockModules)
  .map((m: any) => m?.default ?? m)
  .filter((b: any) => b && b.id && b.timestamp);

interface Block {
  id: string;
  channel?: string;
  type?: string;
  title?: string;
  dek?: string;
  timestamp?: string;
  readingTime?: string;
  noun?: number;
}

const now = Date.now();
const MS_24H = 24 * 60 * 60 * 1000;
const MS_48H = 48 * 60 * 60 * 1000;

function inWindow(b: Block, ms: number): boolean {
  if (!b.timestamp) return false;
  const t = new Date(b.timestamp).getTime();
  if (Number.isNaN(t)) return false;
  return now - t <= ms && now - t >= 0;
}

function interestingness(b: Block): number {
  let score = 0;
  if (b.channel === 'FD') score += 3;
  if (b.channel === 'GDN') score += 2;
  if (b.type === 'READ') score += 2;
  if (b.type === 'NOTE') score += 1;
  if (b.dek && b.dek.length > 40) score += 1;
  return score;
}

let picks = (blocks as Block[])
  .filter((b) => inWindow(b, MS_24H))
  .filter((b) => interestingness(b) > 0)
  .sort((a, b) => {
    const diff = interestingness(b) - interestingness(a);
    if (diff !== 0) return diff;
    return new Date(b.timestamp || 0).getTime() - new Date(a.timestamp || 0).getTime();
  });

// Widen window if thin
if (picks.length < 3) {
  const widened = (blocks as Block[])
    .filter((b) => inWindow(b, MS_48H))
    .filter((b) => interestingness(b) > 0)
    .sort((a, b) => {
      const diff = interestingness(b) - interestingness(a);
      if (diff !== 0) return diff;
      return new Date(b.timestamp || 0).getTime() - new Date(a.timestamp || 0).getTime();
    });
  picks = widened;
}

picks = picks.slice(0, 3);

const hasContent = picks.length >= 2;

function fmtAgo(ts?: string): string {
  if (!ts) return '';
  const ms = now - new Date(ts).getTime();
  const h = Math.floor(ms / (60 * 60 * 1000));
  if (h < 1) return 'just now';
  if (h < 24) return `${h}h ago`;
  const d = Math.floor(h / 24);
  return `${d}d ago`;
}
---

{hasContent && (
  <section class="tom" aria-label="Top of the morning">
    <header class="tom__head">
      <p class="tom__kicker mono">TOP OF THE MORNING · 3 FRESH · AUTO-CURATED</p>
      <p class="tom__sub">Most-interesting blocks from the last 24 hours. Refreshes on every visit.</p>
    </header>
    <ol class="tom__list">
      {picks.map((b, i) => (
        <li class="tom__card">
          <span class="tom__num mono">{String(i + 1).padStart(2, '0')}</span>
          <div class="tom__body">
            <p class="tom__meta mono">
              {b.channel && <span class="tom__channel">CH.{b.channel}</span>}
              {b.type && <span class="tom__dot" aria-hidden="true">·</span>}
              {b.type && <span>{b.type}</span>}
              <span class="tom__dot" aria-hidden="true">·</span>
              <span>{fmtAgo(b.timestamp)}</span>
              {b.readingTime && <><span class="tom__dot" aria-hidden="true">·</span><span>{b.readingTime}</span></>}
            </p>
            <h3 class="tom__title">
              <a href={`/b/${b.id}/`}>{b.title}</a>
            </h3>
            {b.dek && <p class="tom__dek">{b.dek}</p>}
          </div>
        </li>
      ))}
    </ol>
  </section>
)}

<style>
  .tom {
    margin: 0 0 22px;
    padding: 14px 16px;
    background: linear-gradient(180deg, #fff8e7 0%, #fffdf6 100%);
    border: 1px solid #e6d8be;
    border-left: 3px solid #F59F00;
    border-radius: 2px;
  }
  .tom__head { margin-bottom: 10px; }
  .tom__kicker { font-size: 10px; letter-spacing: 0.22em; font-weight: 700; color: #8a2432; text-transform: uppercase; margin: 0 0 4px; }
  .tom__sub { font-size: 11.5px; color: #5F5E5A; margin: 0; font-family: Georgia, serif; font-style: italic; }
  .tom__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 12px;
  }
  @media (max-width: 820px) { .tom__list { grid-template-columns: 1fr; } }
  .tom__card {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 6px;
    padding: 6px 8px 6px 4px;
    border-right: 1px dotted #d6d4cd;
  }
  .tom__card:last-child { border-right: none; }
  @media (max-width: 820px) {
    .tom__card { border-right: none; border-bottom: 1px dotted #d6d4cd; padding-bottom: 10px; }
    .tom__card:last-child { border-bottom: none; }
  }
  .tom__num { font-size: 18px; color: #F59F00; font-weight: 700; line-height: 1; padding-top: 2px; }
  .tom__body { min-width: 0; }
  .tom__meta { font-size: 9px; letter-spacing: 0.1em; color: #8a7e6c; text-transform: uppercase; margin: 0 0 4px; display: flex; gap: 4px; flex-wrap: wrap; }
  .tom__channel { font-weight: 700; color: #8a2432; }
  .tom__dot { color: #d6d4cd; }
  .tom__title { font-family: 'DM Serif Display', 'Lora', Georgia, serif; font-size: 17px; line-height: 1.2; margin: 0 0 5px; }
  .tom__title a { color: #12110e; text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 0.14s ease; }
  .tom__title a:hover { border-bottom-color: #8a2432; }
  .tom__dek { font-size: 12px; line-height: 1.4; color: #38373A; margin: 0; font-family: Georgia, serif; }
</style>
