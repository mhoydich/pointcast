---
/**
 * SpinningBox — embeds one of Mike's Spotify playlists with a block-y,
 * midcentury-modern frame that sits between the main feed and the footer.
 *
 * To feature a different playlist, change the `playlistId` below. Future:
 * turn this into a content collection (src/content/playlists/) so Mike can
 * rotate multiple playlists per deploy.
 *
 * Spotify's embed iframe requires no auth for public playlists. The
 * "theme=0" param gives the dark variant, "theme=1" the light — we pick
 * light so the widget blends into the paper palette.
 */

// Default: the "vibes" playlist Mike shared.
// Extract the 22-char ID from any open.spotify.com/playlist/<id> URL.
const playlistId = '5ETLYkWQGMdyqTjnvT0UEH';
const embedUrl = `https://open.spotify.com/embed/playlist/${playlistId}?utm_source=pointcast&theme=0`;
const userProfileUrl = 'https://open.spotify.com/user/f350x1uuj8fu431fnch8bclwv';
---

<section class="mt-12 mb-10" id="spinning">
  <div class="flex items-center gap-3 mb-4">
    <div class="h-px flex-1 bg-rule/40"></div>
    <h2 class="font-mono text-[0.6rem] tracking-[0.22em] uppercase text-ink-soft/60">
      <span class="text-warm/70">06</span> &middot; Currently Spinning
    </h2>
    <div class="h-px flex-1 bg-rule/40"></div>
  </div>

  <!-- Midcentury/block-y frame: thick-corner card, warm accents, pixel-crisp edges -->
  <div class="relative rounded-xl overflow-hidden border-2 border-rule/50 bg-card shadow-[0_2px_0_0_rgba(0,0,0,0.04)]">
    <!-- Color blocks in the four corners — little midcentury-textile nod -->
    <div class="absolute top-0 left-0 w-2 h-2 bg-warm/80" aria-hidden="true"></div>
    <div class="absolute top-0 right-0 w-2 h-2 bg-ink/60" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-0 w-2 h-2 bg-ink/60" aria-hidden="true"></div>
    <div class="absolute bottom-0 right-0 w-2 h-2 bg-warm/80" aria-hidden="true"></div>

    <iframe
      class="w-full block"
      style="height: 352px; border: 0;"
      src={embedUrl}
      title="Mike's Spotify playlist"
      loading="lazy"
      allow="clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      sandbox="allow-scripts allow-same-origin allow-popups allow-popups-to-escape-sandbox allow-forms"
    ></iframe>
  </div>

  <p class="font-mono text-[0.5rem] tracking-[0.18em] uppercase text-ink-soft/45 text-center mt-3">
    <a
      href={userProfileUrl}
      target="_blank"
      rel="noopener"
      class="hover:text-warm transition-colors"
    >
      more of mike's playlists on spotify &nearr;
    </a>
  </p>
</section>
