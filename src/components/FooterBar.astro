    text-align: center;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .fb__omni-mode[data-mode='ask'] { background: rgba(249, 197, 108, 0.35); color: #fff; border-color: #f9c56c; }
  .fb__omni-mode[data-mode='agt'] { background: rgba(138, 36, 50, 0.35); color: #ffd1d8; border-color: #c1576c; }
  .fb__omni-mode[data-mode='say'] { background: rgba(47, 143, 95, 0.3); color: #c8efd9; border-color: #2f8f5f; }
  .fb__omni-input {
    flex: 1;
    min-width: 0;
    background: none;
    border: 0;
    outline: 0;
    color: #fdf2d6;
    font-size: 12.5px;
    letter-spacing: 0.02em;
    padding: 2px 0;
  }
  .fb__omni-input::placeholder { color: rgba(253, 242, 214, 0.4); }
  .fb__omni-hint {
    font-size: 9.5px;
    letter-spacing: 0.1em;
    color: rgba(253, 242, 214, 0.55);
    padding: 2px 5px;
    border: 1px solid rgba(253, 242, 214, 0.16);
    border-radius: 2px;
    flex-shrink: 0;
  }
  @media (max-width: 640px) { .fb__omni-hint { display: none; } }

  .fb__right { pointer-events: auto; display: flex; align-items: center; gap: 8px; }

  .fb__kit {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 4px;
    background: rgba(0, 0, 0, 0.22);
    border: 1px solid rgba(255, 180, 80, 0.18);
