  @media (max-width: 640px) {
    .fb__kit { padding: 2px 2px; gap: 2px; }
    .fb__stamp { width: 28px; height: 28px; }
  }
  @media (max-width: 380px) {
    .fb__stamp[data-tray='agent'],
    .fb__stamp[data-tray='fed'] { display: none; }
  }

  .fb__on-air { display: flex; align-items: center; gap: 5px; color: #f9c56c; padding: 0 2px; }
  .fb__on-air-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #ff9040;
    box-shadow: 0 0 8px rgba(255, 150, 80, 0.8);
    animation: fb-pulse 2.2s ease-in-out infinite;
  }
  @keyframes fb-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.6; transform: scale(0.85); }
  }
  .fb__on-air-label { font-size: 9px; letter-spacing: 0.2em; font-weight: 700; }
  @media (max-width: 640px) { .fb__on-air-label { display: none; } }

  .fb__menu-btn {
    appearance: none;
    background: rgba(255, 200, 100, 0.1);
    border: 1px solid rgba(255, 180, 80, 0.3);
    color: #fdf2d6;
