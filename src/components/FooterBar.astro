  .fb__tray-meta { font-size: 10px; letter-spacing: 0.1em; color: #6b5a3a; margin: 8px 0 0; }
  .fb-tray__link { display: inline-block; margin-top: 10px; font-size: 10.5px; color: #8a2432; text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 1px; letter-spacing: 0.08em; }

  .fb-ask { display: flex; flex-direction: column; gap: 8px; }
