    border-radius: 2px;
    cursor: pointer;
    line-height: 0;
    box-shadow: inset 0 0 0 1px #d4a437, 0 1px 2px rgba(0, 0, 0, 0.4);
    transition: transform 0.12s ease, box-shadow 0.12s ease;
    flex-shrink: 0;
  }
  .fb__stamp:hover {
    transform: translateY(-1px);
    box-shadow: inset 0 0 0 1px #d4a437, 0 0 0 2px var(--stamp-accent, #f9c56c), 0 2px 6px rgba(0, 0, 0, 0.5);
  }
  .fb__stamp[aria-expanded='true'] {
    transform: translateY(-1px);
    box-shadow: inset 0 0 0 1px #d4a437, 0 0 0 2px var(--stamp-accent, #f9c56c), 0 0 12px var(--stamp-accent, #f9c56c);
  }
  .fb__stamp-noun { width: 100%; height: 100%; image-rendering: pixelated; border-radius: 1px; background: #1a1004; display: block; }
