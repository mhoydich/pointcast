  }
  .fb__stamp-dot[data-state='on']   { background: #2f8f5f; box-shadow: 0 0 4px #2f8f5f; }
  .fb__stamp-dot[data-state='busy'] { background: #ff9040; box-shadow: 0 0 6px #ff9040; animation: fb-pulse 1.6s ease-in-out infinite; }
