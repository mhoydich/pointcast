  .fb-ask__status { margin: 4px 0 0; font-size: 10.5px; min-height: 1em; letter-spacing: 0.08em; }
  .fb-ask__status[data-state='ok']      { color: #2f8f5f; }
  .fb-ask__status[data-state='warn']    { color: #c4952e; }
  .fb-ask__status[data-state='err']     { color: #8a2432; }
