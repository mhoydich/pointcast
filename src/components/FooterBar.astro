  .fb__mood-label { font-size: 9px; letter-spacing: 0.1em; color: #f9c56c; white-space: nowrap; opacity: 0.85; }
  @media (max-width: 640px) { .fb__you-text { display: none; } }

  .fb__omni {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px 4px 4px;
    background: rgba(255, 253, 246, 0.08);
