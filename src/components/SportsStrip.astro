---
/**
 * SportsStrip — recent global-major sports results on the home.
 *
 * Mike 2026-04-20 13:20 PT: *"try a couple of sports updates of the
 * latest results from last night or today, start with global major."*
 * Mike 2026-04-20 14:00 PT refresh: *"and ui on sports scores in lol
 * what font, redesign and likely, whats quick interesting, upsets,
 * previews, current state, trends, etc."*
 *
 * Four league tiles: NBA, MLB, NHL, Premier League. Each tile
 * client-fetches ESPN's public scoreboard API on mount, renders
 * the most recent games with clear typography:
 *
 *   - Team abbrs in a condensed sans
 *   - Scores big, bold, monospace-tabular so columns line up
 *   - Status badge (LIVE / FINAL / UPCOMING) color-coded
 *   - ⚡ marker when score diff ≤ 3 (close game) or status contains OT/ET
 *   - Upcoming games show start time
 *
 * Results cached 10min in sessionStorage. Graceful fallback — if ESPN
 * fetch fails, the tile shows a scoreboard-link only, no fake scores.
 *
 * Author: cc. Source: Mike 2026-04-20 14:00 PT chat.
 */
---

<aside class="sports-strip" aria-label="Recent sports results">
  <header class="sports-strip__head">
    <p class="sports-strip__kicker">
      <span class="sports-strip__kicker-live">SPORTS</span>
      <span class="sports-strip__kicker-rest">· last night · today · global major</span>
    </p>
  </header>

  <div class="sports-strip__grid" id="sports-strip-grid">
    <article class="sports-tile" data-league="nba" data-path="basketball/nba">
      <header class="sports-tile__head">
        <h3 class="sports-tile__league">NBA</h3>
        <span class="sports-tile__sub">playoffs</span>
      </header>
      <div class="sports-tile__body" data-state="loading">
        <p class="sports-tile__loading">loading…</p>
      </div>
      <a class="sports-tile__link" href="https://www.espn.com/nba/scoreboard" target="_blank" rel="noopener">full board →</a>
    </article>

    <article class="sports-tile" data-league="mlb" data-path="baseball/mlb">
      <header class="sports-tile__head">
        <h3 class="sports-tile__league">MLB</h3>
        <span class="sports-tile__sub">regular season</span>
      </header>
      <div class="sports-tile__body" data-state="loading">
        <p class="sports-tile__loading">loading…</p>
      </div>
      <a class="sports-tile__link" href="https://www.espn.com/mlb/scoreboard" target="_blank" rel="noopener">full board →</a>
    </article>

    <article class="sports-tile" data-league="nhl" data-path="hockey/nhl">
      <header class="sports-tile__head">
        <h3 class="sports-tile__league">NHL</h3>
        <span class="sports-tile__sub">playoffs</span>
      </header>
      <div class="sports-tile__body" data-state="loading">
        <p class="sports-tile__loading">loading…</p>
      </div>
      <a class="sports-tile__link" href="https://www.espn.com/nhl/scoreboard" target="_blank" rel="noopener">full board →</a>
    </article>

    <article class="sports-tile" data-league="epl" data-path="soccer/eng.1">
      <header class="sports-tile__head">
        <h3 class="sports-tile__league">Premier Lg</h3>
        <span class="sports-tile__sub">matchday</span>
      </header>
      <div class="sports-tile__body" data-state="loading">
        <p class="sports-tile__loading">loading…</p>
      </div>
      <a class="sports-tile__link" href="https://www.espn.com/soccer/scoreboard/_/league/eng.1" target="_blank" rel="noopener">full board →</a>
    </article>

    <!-- MLS added 2026-04-21 03:36 PT (overnight tick 10) — spring schedule
         is in full swing; West vs East separation gives a useful US-football
         tile alongside the European leagues. -->
    <article class="sports-tile" data-league="mls" data-path="soccer/usa.1">
      <header class="sports-tile__head">
        <h3 class="sports-tile__league">MLS</h3>
        <span class="sports-tile__sub">spring</span>
      </header>
      <div class="sports-tile__body" data-state="loading">
        <p class="sports-tile__loading">loading…</p>
      </div>
      <a class="sports-tile__link" href="https://www.espn.com/soccer/scoreboard/_/league/usa.1" target="_blank" rel="noopener">full board →</a>
    </article>
  </div>
</aside>

<script is:inline>
(function () {
  'use strict';
  var grid = document.getElementById('sports-strip-grid');
  if (!grid) return;

  var CACHE_PREFIX = 'pc:sports:v3:';
  var TTL_MS = 10 * 60 * 1000;

  function readCache(key) {
    try {
      var raw = sessionStorage.getItem(CACHE_PREFIX + key);
      if (!raw) return null;
      var p = JSON.parse(raw);
      if (!p || !p.at || Date.now() - p.at > TTL_MS) return null;
      return p.data;
    } catch (e) { return null; }
  }
  function writeCache(key, data) {
    try { sessionStorage.setItem(CACHE_PREFIX + key, JSON.stringify({ at: Date.now(), data: data })); } catch (e) {}
  }

  function safe(x, fb) { return (x == null || x === '') ? fb : x; }

  function isCloseGame(homeScore, awayScore, status, shortDetail) {
    var hs = parseInt(homeScore, 10), as = parseInt(awayScore, 10);
    if (!isFinite(hs) || !isFinite(as)) return false;
    var diff = Math.abs(hs - as);
    var detail = (shortDetail || '').toLowerCase();
    // OT / extra time / shootout / penalties / F/OT / 2OT etc.
    if (/ot|extra|shootout|penalt|so|et/.test(detail)) return true;
    // Close-final: ≤3 runs in MLB, ≤5 pts in NBA, ≤1 in NHL/EPL.
    if (status === 'post') return diff <= 3;
    // In-progress: amber when tied or ≤2.
    if (status === 'in') return diff <= 2;
    return false;
  }

  // v3: parse "45-23" or "45-23-3" records to a winning-percentage number.
  // Used for upset detection. Returns null if we can't parse.
  function recordToPct(summary) {
    if (!summary || typeof summary !== 'string') return null;
    var parts = summary.split('-').map(function (x) { return parseInt(x, 10); });
    if (!parts.every(function (n) { return isFinite(n); })) return null;
    var wins = parts[0], losses = parts[1], otl = parts[2] || 0;
    var total = wins + losses + otl;
    if (total === 0) return null;
    return wins / total;
  }

  function getTeamRecord(competitor) {
    var recs = competitor && competitor.records;
    if (!Array.isArray(recs) || !recs.length) return '';
    // Prefer 'overall' / 'total' record if present; fall back to first.
    var r = recs.find(function (x) { return x.type === 'total' || x.name === 'overall'; }) || recs[0];
    return (r && r.summary) || '';
  }

  // v3: upset detection — a FINAL game where the winner had a worse record
  // coming into the game than the loser.
  function isUpset(status, home, away) {
    if (status !== 'post') return false;
    var hPct = recordToPct(getTeamRecord(home));
    var aPct = recordToPct(getTeamRecord(away));
    if (hPct == null || aPct == null) return false;
    if (home.winner === true && hPct < aPct - 0.08) return true;
    if (away.winner === true && aPct < hPct - 0.08) return true;
    return false;
  }

  function fmtTipoff(iso) {
    if (!iso) return '';
    try {
      var d = new Date(iso);
      if (isNaN(d.getTime())) return '';
      return new Intl.DateTimeFormat('en-US', {
        weekday: 'short', hour: 'numeric', minute: '2-digit', hour12: true,
        timeZone: 'America/Los_Angeles',
      }).format(d) + ' PT';
    } catch (e) { return ''; }
  }

  function fmtGame(event) {
    try {
      var comp = event.competitions && event.competitions[0];
      if (!comp) return null;
      var competitors = comp.competitors || [];
      if (competitors.length !== 2) return null;
      var home = competitors.find(function (c) { return c.homeAway === 'home'; }) || competitors[0];
      var away = competitors.find(function (c) { return c.homeAway === 'away'; }) || competitors[1];
      var status = (comp.status && comp.status.type && comp.status.type.state) || 'pre';
      var shortDetail = (comp.status && comp.status.type && comp.status.type.shortDetail) || '';
      var hAbbr = safe(home.team && home.team.abbreviation, safe(home.team && home.team.shortDisplayName, '—'));
      var aAbbr = safe(away.team && away.team.abbreviation, safe(away.team && away.team.shortDisplayName, '—'));
      var hScore = safe(home.score, '');
      var aScore = safe(away.score, '');
      var hWinner = home.winner === true;
      var aWinner = away.winner === true;
      var hRec = getTeamRecord(home);
      var aRec = getTeamRecord(away);
      var hot = isCloseGame(hScore, aScore, status, shortDetail);
      var upset = isUpset(status, home, away);
      var tipoff = status === 'pre' ? fmtTipoff(comp.date || event.date) : '';
      return {
        status: status,
        shortDetail: shortDetail,
        hAbbr: hAbbr, aAbbr: aAbbr,
        hScore: hScore, aScore: aScore,
        hWinner: hWinner, aWinner: aWinner,
        hRec: hRec, aRec: aRec,
        hot: hot,
        upset: upset,
        tipoff: tipoff,
      };
    } catch (e) { return null; }
  }

  function rank(a, b) {
    var order = { in: 3, post: 2, pre: 1 };
    return (order[b.status] || 0) - (order[a.status] || 0);
  }

  function renderGames(tile, games) {
    var body = tile.querySelector('.sports-tile__body');
    if (!body) return;
    if (!games || !games.length) {
      body.dataset.state = 'empty';
      body.innerHTML = '<p class="sports-tile__loading">no games scheduled</p>';
      return;
    }
    body.dataset.state = 'loaded';
    // Per Mike 2026-04-20 ~19:42 PT: "sports update, 1-5". Bumped to 5 games
    // per league so the strip carries actual context (was 3). Sort: live > final > pre.
    var sorted = games.slice().sort(rank).slice(0, 5);
    body.innerHTML = sorted.map(function (g) {
      var statusLabel = '';
      var statusClass = '';
      if (g.status === 'post') { statusLabel = 'FINAL'; statusClass = 'final'; }
      else if (g.status === 'in') { statusLabel = g.shortDetail || 'LIVE'; statusClass = 'live'; }
      else { statusLabel = g.shortDetail || 'UPCOMING'; statusClass = 'pre'; }

      var badges = '';
      if (g.upset) badges += '<span class="sports-game__upset" aria-label="upset">⭐ UPSET</span>';
      else if (g.hot) badges += '<span class="sports-game__hot" aria-label="close game">⚡</span>';

      var aRecStr = g.aRec ? '<span class="sports-game__rec">' + escapeHtml(g.aRec) + '</span>' : '';
      var hRecStr = g.hRec ? '<span class="sports-game__rec">' + escapeHtml(g.hRec) + '</span>' : '';

      var awayRow = '<div class="sports-game__row' + (g.aWinner ? ' sports-game__row--winner' : '') + '">' +
        '<span class="sports-game__team">' + escapeHtml(g.aAbbr) + '</span>' +
        aRecStr +
        '<span class="sports-game__score">' + escapeHtml(g.aScore) + '</span>' +
      '</div>';
      var homeRow = '<div class="sports-game__row' + (g.hWinner ? ' sports-game__row--winner' : '') + '">' +
        '<span class="sports-game__team">' + escapeHtml(g.hAbbr) + '</span>' +
        hRecStr +
        '<span class="sports-game__score">' + escapeHtml(g.hScore) + '</span>' +
      '</div>';

      var tipoffLine = (g.status === 'pre' && g.tipoff)
        ? '<div class="sports-game__tipoff mono">' + escapeHtml(g.tipoff) + '</div>'
        : '';

      return '<article class="sports-game sports-game--' + statusClass + (g.hot ? ' sports-game--hot' : '') + (g.upset ? ' sports-game--upset' : '') + '">' +
        '<div class="sports-game__meta"><span class="sports-game__status">' + escapeHtml(statusLabel) + '</span>' + badges + '</div>' +
        awayRow + homeRow +
        tipoffLine +
      '</article>';
    }).join('');
  }

  function escapeHtml(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  function renderError(tile) {
    var body = tile.querySelector('.sports-tile__body');
    if (!body) return;
    body.dataset.state = 'error';
    body.innerHTML = '<p class="sports-tile__loading">tap board →</p>';
  }

  function fetchLeague(tile) {
    var path = tile.getAttribute('data-path');
    var league = tile.getAttribute('data-league');
    if (!path || !league) return;

    var cached = readCache(league);
    if (cached) { renderGames(tile, cached); return; }

    var url = 'https://site.api.espn.com/apis/site/v2/sports/' + path + '/scoreboard';
    fetch(url, { cache: 'no-store' })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (data) {
        if (!data || !data.events) { renderError(tile); return; }
        var games = data.events.map(fmtGame).filter(function (g) { return g; });
        writeCache(league, games);
        renderGames(tile, games);
      })
      .catch(function () { renderError(tile); });
  }

  Array.prototype.forEach.call(grid.querySelectorAll('.sports-tile'), fetchLeague);
})();
</script>

<style>
  .sports-strip {
    margin: 14px 0;
    padding: 14px 16px 16px;
    background: #fbfaf5;
    border: 1px solid #e6d8be;
    border-left: 3px solid #185FA5;
    border-radius: 3px;
    font-family: Georgia, 'Times New Roman', serif;
  }
  .sports-strip__head { margin: 0 0 12px; }
  .sports-strip__kicker {
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', 'Monaco', 'Menlo', ui-monospace, monospace);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: #0B3E73;
    margin: 0;
    text-transform: uppercase;
  }
  .sports-strip__kicker-live { color: #185FA5; font-weight: 700; }
  .sports-strip__kicker-rest { color: #5F5E5A; margin-left: 4px; }

  .sports-strip__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 10px;
  }

  .sports-tile {
    padding: 12px 12px 8px;
    background: #fff;
    border: 1px solid #e6d8be;
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .sports-tile__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 6px;
    border-bottom: 1px solid #ece4d0;
    margin: 0;
  }
  .sports-tile__league {
    font-family: var(--pc-font-sans, 'Inter Variable', system-ui, sans-serif);
    font-size: 15px;
    font-weight: 700;
    color: #0B3E73;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .sports-tile__sub {
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', 'Monaco', 'Menlo', ui-monospace, monospace);
    font-size: 9px;
    letter-spacing: 0.12em;
    color: #8a8878;
    text-transform: uppercase;
  }

  .sports-tile__body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 60px;
    flex: 1;
  }
  .sports-tile__loading {
    font-family: Georgia, serif;
    font-size: 13px;
    color: #8a8878;
    margin: 0;
    font-style: italic;
  }

  .sports-tile__link {
    margin: 0;
    padding-top: 4px;
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', 'Monaco', 'Menlo', ui-monospace, monospace);
    font-size: 9.5px;
    letter-spacing: 0.12em;
    color: #8a2432;
    text-decoration: none;
    text-transform: uppercase;
    align-self: flex-start;
  }
  .sports-tile__link:hover { color: #185FA5; text-decoration: underline; }

  /* ───── Individual game cards ──── */
  .sports-game {
    padding: 7px 8px 8px;
    border: 1px solid transparent;
    border-radius: 2px;
    background: #fafaf6;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .sports-game--live {
    background: #fff5f5;
    border-color: rgba(217, 70, 70, 0.28);
  }
  .sports-game--hot {
    background: linear-gradient(180deg, #fff8e1 0%, #fafaf6 100%);
    border-color: rgba(232, 154, 45, 0.35);
  }
  .sports-game__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
    margin-bottom: 2px;
  }
  .sports-game__status {
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', 'Monaco', 'Menlo', ui-monospace, monospace);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .sports-game--final .sports-game__status { color: #5f5e5a; }
  .sports-game--live  .sports-game__status { color: #c92a2a; }
  .sports-game--live  .sports-game__status::before { content: '● '; animation: livePulse 1.4s infinite; }
  .sports-game--pre   .sports-game__status { color: #0B3E73; }
  .sports-game__hot {
    font-size: 12px;
    line-height: 1;
    color: #d97106;
  }
  @keyframes livePulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .sports-game__row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 8px;
    padding: 1px 2px;
  }
  .sports-game__team {
    font-family: var(--pc-font-sans, 'Inter Variable', system-ui, sans-serif);
    font-size: 13px;
    font-weight: 500;
    color: #38373a;
    letter-spacing: 0.01em;
  }
  .sports-game__rec {
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', 'Monaco', 'Menlo', ui-monospace, monospace);
    font-size: 9.5px;
    letter-spacing: 0.04em;
    color: #8a8878;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .sports-game__score {
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', 'Monaco', 'Menlo', ui-monospace, monospace);
    font-variant-numeric: tabular-nums;
    font-size: 16px;
    font-weight: 700;
    color: #38373a;
    letter-spacing: -0.01em;
  }
  .sports-game__row--winner .sports-game__team { color: #0B3E73; font-weight: 700; }
  .sports-game__row--winner .sports-game__score { color: #0B3E73; }
  .sports-game__row--winner .sports-game__rec { color: #0B3E73; }
  .sports-game--pre .sports-game__score { color: #aaa9a4; }

  /* v3: UPSET badge + tipoff preview */
  .sports-game__upset {
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', monospace);
    font-size: 9px;
    letter-spacing: 0.14em;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(90deg, #5F3DC4 0%, #E8590C 100%);
    padding: 2px 6px;
    border-radius: 2px;
  }
  .sports-game--upset {
    background: linear-gradient(180deg, #f5f0ff 0%, #fafaf6 100%);
    border-color: rgba(95, 61, 196, 0.4);
  }
  .sports-game__tipoff {
    font-size: 9.5px;
    letter-spacing: 0.08em;
    color: #0B3E73;
    margin-top: 3px;
    padding-top: 4px;
    border-top: 1px dotted rgba(11, 62, 115, 0.18);
    text-transform: uppercase;
  }

  /* Tighter layout on narrow screens */
  @media (max-width: 520px) {
    .sports-game__row { grid-template-columns: auto 1fr auto; gap: 6px; }
    .sports-game__team { font-size: 12.5px; }
    .sports-game__score { font-size: 15px; }
    .sports-game__rec { font-size: 9px; }
  }
</style>
