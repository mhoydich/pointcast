---
const wallet = 'tz2FjJhB1gb9Xc2qNB7QgFkdBZkGCCRMxdFw';
const walletUrl = `/wallet/?address=${wallet}`;
const items = [
  {
    label: 'PCMUG',
    title: 'Espresso Cup',
    meta: 'Coffee Mugs #1',
    image: '/images/coffee-mugs/espresso.svg',
    href: '/token/coffee-mugs/1',
    status: 'token detail',
  },
  {
    label: 'PCVN',
    title: 'Noun #557',
    meta: 'Visit Nouns #557',
    image: 'https://noun.pics/557.svg',
    href: '/token/visit-nouns/557',
    status: 'market aware',
  },
  {
    label: 'PCVN',
    title: 'Noun #88',
    meta: 'Visit Nouns #88',
    image: 'https://noun.pics/88.svg',
    href: '/token/visit-nouns/88',
    status: 'holder aware',
  },
];
---

<section class="wallet-shelf" aria-labelledby="wallet-shelf-title">
  <div class="wallet-shelf__copy">
    <p class="wallet-shelf__kicker mono">TEZOS SHELF · TOKEN PAGES · LIVE MARKET</p>
    <h2 id="wallet-shelf-title">Collected pieces should look collected.</h2>
    <p>
      The PointCast wallet now opens into shareable token pages with framed art,
      live holders, listing status, objkt, TzKT, and the market lane one tap away.
    </p>
    <nav class="wallet-shelf__actions" aria-label="Wallet shelf actions">
      <a href={walletUrl}>Open wallet shelf</a>
      <a href="/token/visit-nouns/557">Token #557</a>
      <a href="/marketplace">Marketplace console</a>
      <a href="/market">Live asks</a>
    </nav>
  </div>
  <div class="wallet-shelf__cards" aria-label="Current collected cards">
    {items.map((item) => (
      <a class="wallet-shelf__card" href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener' : undefined}>
        <span class="wallet-shelf__label mono">{item.label}</span>
        <span class="wallet-shelf__art">
          <img src={item.image} alt={item.title} loading="lazy" />
        </span>
        <strong>{item.title}</strong>
        <span>{item.meta}</span>
        <em class="wallet-shelf__status mono">{item.status}</em>
      </a>
    ))}
  </div>
</section>

<style>
  .wallet-shelf {
    display: grid;
    grid-template-columns: minmax(240px, 0.34fr) minmax(0, 1fr);
    gap: 14px;
    margin: 14px 0;
    padding: 14px;
    border: 1.5px solid var(--pc-ink);
    background:
      linear-gradient(135deg, rgba(63, 120, 93, 0.12), transparent 52%),
      linear-gradient(90deg, rgba(23, 23, 23, 0.035) 1px, transparent 1px),
      #fffdf4;
    background-size: auto, 28px 28px, auto;
    box-shadow: 6px 6px 0 rgba(18, 17, 14, 0.08);
  }

  .mono {
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .wallet-shelf__copy {
    display: grid;
    align-content: center;
  }

  .wallet-shelf__kicker {
    margin: 0 0 8px;
    color: #2f6d50;
    font-size: 10px;
  }

  .wallet-shelf h2 {
    margin: 0;
    color: var(--pc-ink);
    font-size: clamp(24px, 4vw, 44px);
    line-height: 0.98;
    letter-spacing: 0;
    font-weight: 600;
  }

  .wallet-shelf p {
    margin: 10px 0 0;
    color: var(--pc-ink-soft);
    font-size: 14px;
    line-height: 1.4;
  }

  .wallet-shelf__actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 12px;
  }

  .wallet-shelf__actions a {
    border: 1px solid var(--pc-ink);
    background: #fff;
    color: var(--pc-ink);
    padding: 7px 9px;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .wallet-shelf__actions a:first-child {
    background: var(--pc-ink);
    color: #fff;
  }

  .wallet-shelf__cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .wallet-shelf__card {
    min-width: 0;
    display: grid;
    gap: 7px;
    padding: 9px;
    border: 1px solid rgba(18, 17, 14, 0.22);
    background: rgba(255, 255, 255, 0.78);
    color: var(--pc-ink);
    text-decoration: none;
  }

  .wallet-shelf__card:hover {
    border-color: var(--pc-ink);
    text-decoration: none;
  }

  .wallet-shelf__label {
    color: #185fa5;
    font-size: 9px;
  }

  .wallet-shelf__art {
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    padding: 9px;
    border: 1px solid rgba(18, 17, 14, 0.2);
    background: #e9dfcc;
  }

  .wallet-shelf__art img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    image-rendering: pixelated;
    background: #fffdf4;
    box-shadow: 4px 4px 0 rgba(18, 17, 14, 0.12);
  }

  .wallet-shelf__card strong {
    min-width: 0;
    overflow-wrap: anywhere;
    font-size: 14px;
    line-height: 1.05;
  }

  .wallet-shelf__card span:last-child {
    min-width: 0;
    overflow-wrap: anywhere;
    color: var(--pc-ink-muted);
    font-size: 11px;
    line-height: 1.25;
  }

  .wallet-shelf__status {
    justify-self: start;
    border: 1px solid rgba(18, 17, 14, 0.22);
    background: #fff;
    color: #2f6d50;
    padding: 4px 6px;
    font-style: normal;
    font-size: 8px;
  }

  @media (max-width: 900px) {
    .wallet-shelf {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .wallet-shelf__cards {
      grid-template-columns: 1fr;
    }
  }
</style>
