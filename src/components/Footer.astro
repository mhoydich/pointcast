---
const year = new Date().getFullYear();
---

<footer class="border-t border-rule/50 mt-16" role="contentinfo">
  <div class="max-w-[34rem] mx-auto px-4 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <span class="font-heading text-base text-ink font-bold tracking-tight">PointCast</span>
        </div>
        <p class="text-sm text-ink-soft leading-relaxed">
          Intelligence dispatches and creative work from Mike Hoydich &amp; Claude Cowork.
        </p>
      </div>

      <!-- Navigate -->
      <nav aria-label="Footer navigation">
        <h3 class="font-mono text-[0.6rem] uppercase tracking-[0.22em] text-ink-soft/60 mb-3">Navigate</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-ink-soft hover:text-warm transition-colors">Home</a></li>
          <li><a href="/feed" class="text-sm text-ink-soft hover:text-warm transition-colors">Feed</a></li>
          <li><a href="/links" class="text-sm text-ink-soft hover:text-warm transition-colors">Links</a></li>
          <li><a href="/nouns" class="text-sm text-ink-soft hover:text-warm transition-colors">Nouns</a></li>
          <li><a href="/about" class="text-sm text-ink-soft hover:text-warm transition-colors">About</a></li>
        </ul>
      </nav>

      <!-- Connect -->
      <div>
        <h3 class="font-mono text-[0.6rem] uppercase tracking-[0.22em] text-ink-soft/60 mb-3">Elsewhere</h3>
        <ul class="space-y-2">
          <li><a href="https://github.com/mhoydich/pointcast" target="_blank" rel="noopener" class="text-sm text-ink-soft hover:text-warm transition-colors">GitHub &nearr;</a></li>
          <li><a href="/links" class="text-sm text-ink-soft hover:text-warm transition-colors">Links</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-rule/30 flex flex-col sm:flex-row items-center justify-between gap-3 font-mono text-[0.6rem] tracking-[0.14em] uppercase text-ink-soft/50">
      <span>&copy; {year} Mike Hoydich &times; Claude Cowork</span>
      <span class="font-heading text-[0.6rem] text-warm/30 tracking-tight">PC</span>
    </div>
  </div>
</footer>
