---
import Noggles from './Noggles.astro';
const year = new Date().getFullYear();
---

<footer class="border-t border-nouns-border mt-20">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="flex flex-col items-center gap-6 text-center">
      <Noggles width={70} />
      <div>
        <p class="font-heading text-lg text-nouns-yellow">PointCast</p>
        <p class="text-sm text-nouns-muted mt-1">
          Mike Hoydich & Claude Cowork Publishings
        </p>
      </div>
      <div class="flex items-center gap-2 text-xs text-nouns-muted font-mono">
        <span>&copy; {year}</span>
        <span class="text-nouns-border">|</span>
        <span>Built with human-AI collaboration</span>
        <span class="text-nouns-border">|</span>
        <span class="text-nouns-yellow">&#x2310;&#x25E8;-&#x25E8;</span>
      </div>
    </div>
  </div>
</footer>
