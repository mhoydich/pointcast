---
import Noggles from './Noggles.astro';
const year = new Date().getFullYear();
---

<footer class="border-t border-nouns-border/50 mt-20 bg-nouns-bg-card/30" role="contentinfo">
  <div class="max-w-5xl mx-auto px-4 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 sm:gap-8 mb-10">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <Noggles width={50} />
          <span class="font-heading text-lg text-nouns-yellow">PointCast</span>
        </div>
        <p class="text-sm text-nouns-muted leading-relaxed">
          Intelligence dispatches and creative work from Mike Hoydich &amp; Claude Cowork Publishings.
        </p>
      </div>

      <!-- Navigate -->
      <nav aria-label="Footer navigation">
        <h3 class="font-mono text-xs uppercase tracking-widest text-nouns-muted/60 mb-4">Navigate</h3>
        <ul class="space-y-2.5">
          <li><a href="/" class="text-sm text-nouns-muted hover:text-nouns-yellow transition-colors">Home</a></li>
          <li><a href="/feed" class="text-sm text-nouns-muted hover:text-nouns-yellow transition-colors">Feed</a></li>
          <li><a href="/nouns" class="text-sm text-nouns-muted hover:text-nouns-yellow transition-colors">Nouns</a></li>
          <li><a href="/about" class="text-sm text-nouns-muted hover:text-nouns-yellow transition-colors">About</a></li>
        </ul>
      </nav>

      <!-- Connect -->
      <div>
        <h3 class="font-mono text-xs uppercase tracking-widest text-nouns-muted/60 mb-4">Ecosystem</h3>
        <ul class="space-y-2.5">
          <li><a href="https://nouns.wtf" target="_blank" rel="noopener" class="text-sm text-nouns-muted hover:text-nouns-yellow transition-colors">Nouns DAO &nearr;</a></li>
          <li><a href="https://github.com/mhoydich/pointcast" target="_blank" rel="noopener" class="text-sm text-nouns-muted hover:text-nouns-yellow transition-colors">GitHub &nearr;</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-nouns-border/30 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-nouns-muted/60 font-mono">
      <span>&copy; {year} Mike Hoydich &times; Claude Cowork</span>
      <span class="text-nouns-yellow/40">⌐◨-◨</span>
    </div>
  </div>
</footer>
