---
import TagPill from './TagPill.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: 'article' | 'project' | 'essay' | 'art' | 'newsletter';
  slug: string;
  image?: string;
  tags?: string[];
  collection: 'posts' | 'projects';
}

const { title, description, date, type, slug, image, tags = [], collection } = Astro.props;

const href = collection === 'posts' ? `/posts/${slug}` : `/projects/${slug}`;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={href} class="block group" aria-label={`Read: ${title}`}>
  <article class="bg-nouns-bg-card border border-nouns-border/50 rounded-2xl overflow-hidden card-hover h-full">
    {image && (
      <div class="aspect-video overflow-hidden">
        <img
          src={image}
          alt=""
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    )}

    <div class="p-5 md:p-6">
      <div class="flex items-center gap-2.5 mb-3">
        <TagPill tag={type} />
        <time class="text-xs text-nouns-muted font-mono" datetime={date.toISOString()}>
          {formattedDate}
        </time>
      </div>

      <h3 class="font-heading text-lg md:text-xl text-nouns-white group-hover:text-nouns-yellow transition-colors mb-2.5 leading-tight">
        {title}
      </h3>

      <p class="text-sm text-nouns-muted leading-relaxed line-clamp-3">
        {description}
      </p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-4">
          {tags.slice(0, 4).map(tag => (
            <span class="text-xs font-mono text-nouns-muted/50 bg-nouns-bg-elevated px-2 py-0.5 rounded-full">
              #{tag}
            </span>
          ))}
          {tags.length > 4 && (
            <span class="text-xs font-mono text-nouns-muted/40">+{tags.length - 4}</span>
          )}
        </div>
      )}
    </div>
  </article>
</a>
