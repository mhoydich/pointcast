---
import TagPill from './TagPill.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: 'article' | 'project' | 'essay' | 'art' | 'newsletter';
  slug: string;
  image?: string;
  tags?: string[];
  collection: 'posts' | 'projects';
}

const { title, description, date, type, slug, image, tags = [], collection } = Astro.props;

const href = collection === 'posts' ? `/posts/${slug}` : `/projects/${slug}`;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const typeIcons: Record<string, string> = {
  article: '\u{1F4DD}',
  project: '\u{1F6E0}',
  essay: '\u{270F}',
  art: '\u{1F3A8}',
  newsletter: '\u{1F4E1}',
};
---

<a href={href} class="block group">
  <article class="bg-nouns-bg-card border border-nouns-border rounded-xl overflow-hidden card-hover">
    {image && (
      <div class="aspect-video overflow-hidden">
        <img
          src={image}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    )}

    <div class="p-5">
      <div class="flex items-center gap-2 mb-3">
        <TagPill tag={type} />
        <span class="text-xs text-nouns-muted font-mono">{formattedDate}</span>
      </div>

      <h3 class="font-heading text-xl text-nouns-white group-hover:text-nouns-yellow transition-colors mb-2">
        {typeIcons[type] || ''} {title}
      </h3>

      <p class="text-sm text-nouns-muted leading-relaxed line-clamp-3">
        {description}
      </p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-4">
          {tags.map(tag => (
            <span class="text-xs font-mono text-nouns-muted/60 bg-nouns-bg-elevated px-2 py-0.5 rounded">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </article>
</a>
