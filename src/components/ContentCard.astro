---
interface Props {
  title: string;
  description: string;
  date: Date;
  type: 'article' | 'project' | 'essay' | 'art' | 'newsletter';
  slug: string;
  image?: string;
  tags?: string[];
  collection: 'posts' | 'projects';
}

const { title, description, date, type, slug, image, tags = [], collection } = Astro.props;

const href = collection === 'posts' ? `/posts/${slug}` : `/projects/${slug}`;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const typeLabel: Record<string, string> = {
  newsletter: 'Dispatch',
  article: 'Article',
  essay: 'Essay',
  project: 'Project',
  art: 'Art',
};

const typeClass: Record<string, string> = {
  newsletter: 'type-dispatch',
  article: 'type-article',
  essay: 'type-essay',
  project: 'type-project',
  art: 'type-art',
};
---

<a href={href} class="block group" aria-label={`Read: ${title}`}>
  <article class="editorial-card h-full">
    {image && (
      <div class="aspect-video overflow-hidden rounded-md mb-4 border border-rule">
        <img
          src={image}
          alt=""
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    )}

    <div class="flex items-center gap-2.5 mb-3">
      <span class:list={[
        'font-mono text-[0.58rem] tracking-[0.18em] uppercase px-2 py-0.5 rounded-full',
        typeClass[type] || 'type-article',
      ]}>
        {typeLabel[type] || type}
      </span>
      <time class="text-[0.62rem] text-ink-soft font-mono tracking-[0.1em] uppercase" datetime={date.toISOString()}>
        {formattedDate}
      </time>
    </div>

    <h3 class="font-serif text-base md:text-lg text-ink group-hover:text-warm transition-colors mb-2 leading-tight font-semibold">
      {title}
    </h3>

    <p class="text-sm text-ink-soft leading-relaxed line-clamp-3">
      {description}
    </p>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-3">
        {tags.slice(0, 4).map(tag => (
          <span class="text-[0.6rem] font-mono text-ink-soft/40 tracking-[0.1em] uppercase">
            #{tag}
          </span>
        ))}
        {tags.length > 4 && (
          <span class="text-[0.6rem] font-mono text-ink-soft/30">+{tags.length - 4}</span>
        )}
      </div>
    )}
  </article>
</a>
