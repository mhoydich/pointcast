---
/**
 * DailyDropStrip — compact daily-drop-collect surface for the home.
 *
 * Mike 2026-04-20 13:20 PT: *"have on homepage, ability to collect
 * daily drop."*
 *
 * Smaller sibling of /today. Shows today's pick inline — thumbnail +
 * title + channel + one-tap collect. Click-through to full drop on
 * tap of the block itself, collect button for the HELLO increment.
 * Once collected, the strip swaps to a quiet "✓ Collected · streak
 * N" state without disappearing.
 *
 * localStorage shared with /today — collect here and /today reflects
 * it, and vice versa. Same keys, same format.
 *
 * Author: cc. Source: Mike 2026-04-20 13:20 PT chat.
 */
import { getCollection } from 'astro:content';
import { pickDailyBlock, todayPT } from '../lib/daily';
import { CHANNELS } from '../lib/channels';

const blocks = (await getCollection('blocks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

const pick = pickDailyBlock(blocks);
const today = todayPT();
const prettyDay = new Intl.DateTimeFormat('en-US', {
  weekday: 'short',
  month: 'short',
  day: 'numeric',
  timeZone: 'America/Los_Angeles',
}).format(new Date()).toUpperCase();
---

{pick && (
  <aside class="daily-drop-strip" data-block-id={pick.data.id} data-today={today} aria-label="Today's daily drop">
    <div class="daily-drop-strip__left">
      <p class="daily-drop-strip__kicker mono">
        <span class="daily-drop-strip__day">{prettyDay}</span>
        <span class="daily-drop-strip__sep" aria-hidden="true">·</span>
        <span>TODAY'S DROP · ONE PER DAY · EVERYONE SEES THE SAME</span>
      </p>

      <div class="daily-drop-strip__row">
        <a class="daily-drop-strip__thumb" href={`/b/${pick.data.id}`} aria-label={`Open block ${pick.data.id}`}>
          <img
            src={`https://noun.pics/${pick.data.noun ?? parseInt(pick.data.id, 10) % 1200}.svg`}
            alt=""
            width="44"
            height="44"
            loading="lazy"
            style="image-rendering: pixelated;"
          />
        </a>
        <div class="daily-drop-strip__body">
          <p class="daily-drop-strip__code mono">
            CH.{CHANNELS[pick.data.channel]?.code ?? pick.data.channel} · {pick.data.id} · {pick.data.type}
          </p>
          <a class="daily-drop-strip__title" href={`/b/${pick.data.id}`}>{pick.data.title}</a>
        </div>
      </div>
    </div>

    <div class="daily-drop-strip__right">
      <button type="button" class="daily-drop-strip__collect" id="daily-drop-collect" data-block-id={pick.data.id} data-today={today}>
        <span class="daily-drop-strip__collect-icon" aria-hidden="true">✦</span>
        <span class="daily-drop-strip__collect-label mono">COLLECT</span>
      </button>
      <p class="daily-drop-strip__stats mono" id="daily-drop-stats" aria-live="polite">
        <span id="daily-drop-total">0</span>
        <span class="daily-drop-strip__stats-label">COLLECTED</span>
        <span class="daily-drop-strip__stats-sep" aria-hidden="true">·</span>
        <span id="daily-drop-streak">0</span>
        <span class="daily-drop-strip__stats-label">STREAK</span>
      </p>
    </div>
  </aside>
)}

<script is:inline>
(function () {
  'use strict';
  var strip = document.querySelector('.daily-drop-strip');
  if (!strip) return;

  var COLLECTION_KEY = 'pc:daily:collected';
  var LAST_DAY_KEY = 'pc:daily:lastDay';
  var HELLO_KEY = 'pc:hello:count';

  var btn = document.getElementById('daily-drop-collect');
  var totalEl = document.getElementById('daily-drop-total');
  var streakEl = document.getElementById('daily-drop-streak');

  var blockId = strip.getAttribute('data-block-id') || '';
  var today = strip.getAttribute('data-today') || '';

  function readCollection() {
    try {
      var raw = localStorage.getItem(COLLECTION_KEY);
      if (!raw) return [];
      var parsed = JSON.parse(raw);
      return Array.isArray(parsed) ? parsed : [];
    } catch (e) { return []; }
  }

  function writeCollection(arr) {
    try { localStorage.setItem(COLLECTION_KEY, JSON.stringify(arr)); } catch (e) {}
  }

  function computeStreak(collection) {
    if (!collection.length) return 0;
    var dates = collection.map(function (c) { return c.date; }).sort();
    var streak = 1;
    // Walk backward from today; count consecutive days present.
    var d = new Date(today + 'T12:00:00');
    for (var i = dates.length - 1; i >= 0; i--) {
      var ymd = d.toISOString().slice(0, 10);
      if (dates.indexOf(ymd) === -1) break;
      streak = 1 + (i === dates.length - 1 ? 0 : streak);
      d.setDate(d.getDate() - 1);
    }
    // Simpler: just count distinct recent consecutive days.
    var uniq = {};
    dates.forEach(function (x) { uniq[x] = true; });
    var days = Object.keys(uniq).sort().reverse();
    var count = 0;
    var cursor = new Date(today + 'T12:00:00');
    for (var j = 0; j < days.length; j++) {
      var want = cursor.toISOString().slice(0, 10);
      if (days[j] !== want) break;
      count++;
      cursor.setDate(cursor.getDate() - 1);
    }
    return count;
  }

  function paint(state) {
    var coll = state.collection;
    if (totalEl) totalEl.textContent = String(coll.length);
    if (streakEl) streakEl.textContent = String(computeStreak(coll));
    if (state.claimed && btn) {
      btn.classList.add('daily-drop-strip__collect--done');
      btn.disabled = true;
      var icon = btn.querySelector('.daily-drop-strip__collect-icon');
      var label = btn.querySelector('.daily-drop-strip__collect-label');
      if (icon) icon.textContent = '✓';
      if (label) label.textContent = 'COLLECTED';
    }
  }

  function currentState() {
    var collection = readCollection();
    var claimed = collection.some(function (c) { return c.date === today && c.blockId === blockId; });
    return { collection: collection, claimed: claimed };
  }

  paint(currentState());

  if (btn) {
    btn.addEventListener('click', function () {
      var st = currentState();
      if (st.claimed) return;
      var entry = { date: today, blockId: blockId, at: new Date().toISOString() };
      var next = st.collection.concat([entry]);
      writeCollection(next);
      try { localStorage.setItem(LAST_DAY_KEY, today); } catch (e) {}
      // HELLO +1 on first collect of the day (matches /today's behavior).
      try {
        var h = parseInt(localStorage.getItem(HELLO_KEY) || '0', 10) || 0;
        localStorage.setItem(HELLO_KEY, String(h + 1));
      } catch (e) {}
      paint({ collection: next, claimed: true });
    });
  }
})();
</script>

<style>
  .daily-drop-strip {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 14px;
    margin: 14px 0 10px;
    background: #f4f8f4;
    border: 1px solid #cfe0d0;
    border-left: 3px solid #2f8f5f;
    border-radius: 3px;
    flex-wrap: wrap;
  }
  .daily-drop-strip__left { flex: 1 1 320px; min-width: 0; }
  .daily-drop-strip__right { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; flex-shrink: 0; }

  .mono { font-family: var(--pc-font-mono, 'JetBrains Mono Variable', 'Monaco', 'Menlo', ui-monospace, monospace); }
  .daily-drop-strip__kicker {
    font-size: 10px;
    letter-spacing: 0.12em;
    color: #1f6d42;
    margin: 0 0 6px;
    text-transform: uppercase;
  }
  .daily-drop-strip__day { color: #2f8f5f; font-weight: 700; }
  .daily-drop-strip__sep { margin: 0 4px; opacity: 0.55; }

  .daily-drop-strip__row { display: flex; align-items: center; gap: 10px; }
  .daily-drop-strip__thumb {
    width: 44px; height: 44px;
    flex-shrink: 0;
    background: #eee8dc;
    border-radius: 2px;
    display: block;
  }
  .daily-drop-strip__thumb img { width: 100%; height: 100%; display: block; }
  .daily-drop-strip__body { flex: 1 1 auto; min-width: 0; }
  .daily-drop-strip__code {
    font-size: 9.5px;
    letter-spacing: 0.12em;
    color: #5f5e5a;
    margin: 0 0 2px;
    text-transform: uppercase;
  }
  .daily-drop-strip__title {
    display: block;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 15px;
    font-weight: 600;
    color: #12110e;
    text-decoration: none;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .daily-drop-strip__title:hover { color: #2f8f5f; text-decoration: underline; }

  .daily-drop-strip__collect {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: #2f8f5f;
    color: #fff;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    transition: background 0.15s;
  }
  .daily-drop-strip__collect:hover { background: #1f6d42; }
  .daily-drop-strip__collect--done { background: #1f6d42; cursor: default; }
  .daily-drop-strip__collect-icon { font-size: 13px; }

  .daily-drop-strip__stats {
    font-size: 9.5px;
    letter-spacing: 0.08em;
    color: #5f5e5a;
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 4px;
  }
  .daily-drop-strip__stats-label { opacity: 0.7; }
  .daily-drop-strip__stats-sep { margin: 0 2px; opacity: 0.5; }
  #daily-drop-total, #daily-drop-streak { color: #2f8f5f; font-weight: 700; }

  @media (max-width: 600px) {
    .daily-drop-strip__right { width: 100%; align-items: flex-start; flex-direction: row; justify-content: space-between; }
    .daily-drop-strip__title { white-space: normal; }
  }
</style>
