---
interface Props {
  blockCount: number;
}

const { blockCount } = Astro.props;
---

<section class="gamgee-front-door" aria-labelledby="gamgee-front-door-title">
  <div class="gamgee-front-door__copy">
    <p class="gamgee-front-door__kicker">Gamgee RC0</p>
    <h2 id="gamgee-front-door-title" class="gamgee-front-door__title">PointCast is an agent-native broadcast from El Segundo.</h2>
    <p class="gamgee-front-door__dek">
      Humans get the live home. Agents get stable manifests, feeds, and a visible
      release ledger. Gamgee keeps both sides pointed at the same truth while
      Claude, Codex, and Manus ship in small reviewable slices.
    </p>
    <ul class="gamgee-front-door__signals" aria-label="Gamgee release signals">
      <li>{blockCount} blocks</li>
      <li>Claude + Codex + Manus</li>
      <li>Stable agent surfaces</li>
    </ul>
  </div>

  <nav class="gamgee-front-door__paths" aria-label="Gamgee entry points">
    <a href="/gamgee" class="gamgee-front-door__path">
      <span class="gamgee-front-door__label">For the release</span>
      <span class="gamgee-front-door__target">/gamgee</span>
      <span class="gamgee-front-door__note">Open the public RC0 anchor.</span>
    </a>
    <a href="/now" class="gamgee-front-door__path">
      <span class="gamgee-front-door__label">For humans</span>
      <span class="gamgee-front-door__target">/now</span>
      <span class="gamgee-front-door__note">See what is live today.</span>
    </a>
    <a href="/for-agents" class="gamgee-front-door__path">
      <span class="gamgee-front-door__label">For agents</span>
      <span class="gamgee-front-door__target">/for-agents</span>
      <span class="gamgee-front-door__note">Read the operating surface.</span>
    </a>
    <a href="/agents.json" class="gamgee-front-door__path">
      <span class="gamgee-front-door__label">For tools</span>
      <span class="gamgee-front-door__target">/agents.json</span>
      <span class="gamgee-front-door__note">Parse the canonical manifest.</span>
    </a>
  </nav>
</section>

<style>
  .gamgee-front-door {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.65fr);
    gap: 24px;
    margin: 14px 0 18px;
    padding: 18px 0;
    border-bottom: 1.5px solid var(--pc-ink);
    font-family: var(--pc-font-sans);
  }

  .gamgee-front-door__copy,
  .gamgee-front-door__paths {
    min-width: 0;
  }

  .gamgee-front-door__kicker {
    margin: 0 0 8px;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-accent);
  }

  .gamgee-front-door__title {
    max-width: 820px;
    margin: 0;
    font-size: 40px;
    line-height: 0.98;
    letter-spacing: 0;
    font-weight: 500;
    color: var(--pc-ink);
  }

  .gamgee-front-door__dek {
    max-width: 760px;
    margin: 12px 0 0;
    font-size: 15px;
    line-height: 1.5;
    color: var(--pc-ink-soft);
  }

  .gamgee-front-door__signals {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    padding: 0;
    margin: 14px 0 0;
  }

  .gamgee-front-door__signals li {
    border: 1px solid var(--pc-rule);
    padding: 5px 8px;
    background: #fafaf7;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pc-ink-soft);
  }

  .gamgee-front-door__paths {
    display: grid;
    gap: 8px;
    align-content: start;
  }

  .gamgee-front-door__path {
    display: grid;
    grid-template-columns: minmax(82px, auto) minmax(0, 1fr);
    gap: 3px 12px;
    min-width: 0;
    padding: 10px 0 10px 12px;
    border-left: 3px solid var(--pc-accent);
    background: #f4f8fb;
    color: var(--pc-ink);
  }

  .gamgee-front-door__path:hover {
    background: #eef4fa;
    text-decoration: none;
  }

  .gamgee-front-door__label,
  .gamgee-front-door__target {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .gamgee-front-door__label {
    color: var(--pc-ink-muted);
  }

  .gamgee-front-door__target {
    min-width: 0;
    overflow-wrap: anywhere;
    color: var(--pc-accent);
    font-weight: 500;
  }

  .gamgee-front-door__note {
    grid-column: 1 / -1;
    min-width: 0;
    font-size: 13px;
    line-height: 1.35;
    color: var(--pc-ink-soft);
    overflow-wrap: anywhere;
  }

  @media (max-width: 820px) {
    .gamgee-front-door {
      grid-template-columns: 1fr;
      gap: 14px;
    }
  }

  @media (max-width: 639px) {
    .gamgee-front-door {
      width: calc(100vw - 40px);
      max-width: calc(100vw - 40px);
      margin-top: 12px;
      padding: 14px 0 16px;
      overflow: hidden;
    }

    .gamgee-front-door__copy,
    .gamgee-front-door__paths {
      width: min(100%, 350px);
      max-width: 100%;
    }

    .gamgee-front-door__title {
      max-width: 100%;
      font-size: 29px;
      line-height: 1.02;
      overflow-wrap: anywhere;
    }

    .gamgee-front-door__dek {
      max-width: 100%;
      font-size: 14px;
      overflow-wrap: anywhere;
    }

    .gamgee-front-door__signals {
      display: grid;
      grid-template-columns: 1fr;
    }

    .gamgee-front-door__signals li {
      max-width: 100%;
      overflow-wrap: anywhere;
    }

    .gamgee-front-door__path {
      grid-template-columns: 1fr;
      gap: 2px;
    }
  }
</style>
