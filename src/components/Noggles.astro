---
interface Props {
  width?: number;
  class?: string;
  variant?: 'red' | 'black' | 'blue' | 'yellow';
}

const { width = 120, class: className = '', variant = 'red' } = Astro.props;
const src = `/images/noggles-${variant}.svg`;
// Official noggles viewBox is 175x70, so aspect ratio is 2.5:1
const height = Math.round(width / 2.5);
---

<img
  src={src}
  alt="Noggles ⌐◨-◨"
  width={width}
  height={height}
  class:list={['inline-block', className]}
  style={`image-rendering: pixelated;`}
/>
