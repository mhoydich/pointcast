---
/**
 * PresenceBar — live "who's here" readout for the masthead.
 *
 * Opens a WebSocket to `/api/presence` (a Cloudflare Durable Object,
 * functions/api/presence.ts) that broadcasts an aggregate once per second.
 * The DO now carries richer session data for other clients, but this bar
 * still reads only the backwards-compatible aggregate counts.
 *
 * Render:
 *   · HUMANS 3 · AGENTS 1 · YOU ·
 *
 * Graceful degradation: if the WS doesn't connect in 4s (or errors), the
 * bar quietly hides — no flashy "DISCONNECTED" state. The rest of the
 * masthead keeps working.
 */
---

<span class="presence" id="pc-presence" aria-live="polite" data-initial="off">
  <span class="presence__sep" aria-hidden="true">·</span>
  <span class="presence__pill" id="pc-presence-pill">
    <span class="presence__dot" aria-hidden="true"></span>
    <span class="presence__you">YOU</span>
    <span class="presence__count" id="pc-presence-label">·</span>
  </span>
</span>

<script>
  (() => {
    const el = document.getElementById('pc-presence');
    const label = document.getElementById('pc-presence-label');
    if (!el || !label) return;

    // Skip presence on file://, http localhost without Functions, etc. A
    // cheap feature-flag so the local dev server doesn't get stuck in
    // CONNECTING… on every hot reload.
    if (!window.location.host.endsWith('pointcast.xyz') && !window.location.host.endsWith('.pages.dev')) {
      el.style.display = 'none';
      return;
    }

    // Naive agent-detection — if the UA string contains a well-known agent
    // vendor, tag the presence as AGENT. Server trusts the tag but clamps
    // to [human, agent] and dedupes on session id.
    const isAgent = /gptbot|claude|perplexity|atlas|bingbot|googlebot/i.test(navigator.userAgent);
    const cheapHash = (input: string) => {
      let hash = 5381;
      for (let i = 0; i < input.length; i++) {
        hash = ((hash << 5) + hash + input.charCodeAt(i)) | 0;
      }
      return hash >>> 0;
    };
    const sessionId = (() => {
      const KEY = 'pc:session';
      let v = localStorage.getItem(KEY);
      if (!v) {
        v = (crypto.randomUUID?.() ?? Math.random().toString(36).slice(2));
        try { localStorage.setItem(KEY, v); } catch {}
      }
      return v;
    })();
    const nounId = (() => {
      const KEY = 'pc:visitor:noun';
      const cached = parseInt(localStorage.getItem(KEY) || '', 10);
      if (cached >= 0 && cached < 1200) return cached;
      const next = cheapHash(sessionId) % 1200;
      try { localStorage.setItem(KEY, String(next)); } catch {}
      return next;
    })();

    const wsURL = (window.location.protocol === 'https:' ? 'wss://' : 'ws://') + window.location.host + '/api/presence';
    let ws: WebSocket | null = null;
    let connectTimer: number | null = null;
    let degrade: number | null = null;
    let heartbeat: number | null = null;

    function setLabel(text: string) { label.textContent = text; }
    function send(type: 'identify' | 'ping') {
      if (!ws || ws.readyState !== WebSocket.OPEN) return;
      try { ws.send(JSON.stringify({ type, nounId })); } catch {}
    }
    function stopHeartbeat() {
      if (heartbeat) {
        clearInterval(heartbeat);
        heartbeat = null;
      }
    }
    function hide() {
      el.style.display = 'none';
      stopHeartbeat();
      if (ws) try { ws.close(); } catch {}
    }

    degrade = window.setTimeout(() => hide(), 4000);

    try {
      ws = new WebSocket(wsURL + '?sid=' + encodeURIComponent(sessionId) + '&kind=' + (isAgent ? 'agent' : 'human'));
    } catch {
      hide();
      return;
    }

    // Sprint 22 — time-aware "ALONE" label. "YOU | ALONE" at 09:00
    // reads flat; flexing it by hour gives the same solo-visit a
    // different mood in morning / day / golden / evening / small-hours.
    function timeOfDayTag() {
      const h = new Date().getHours();
      if (h < 6)       return 'SMALL HRS';
      if (h < 10)      return 'MORNING';
      if (h < 15)      return 'MIDDAY';
      if (h < 18)      return 'GOLDEN';
      if (h < 21)      return 'BLUE HR';
      return 'EVENING';
    }
    function aloneLabel() {
      return `${timeOfDayTag()} · ONE UP`;
    }

    ws.addEventListener('open', () => {
      if (degrade) clearTimeout(degrade);
      setLabel(aloneLabel());
      send('identify');
      stopHeartbeat();
      heartbeat = window.setInterval(() => send('ping'), 30_000);
    });

    ws.addEventListener('message', (evt) => {
      try {
        const { humans, agents } = JSON.parse(evt.data);
        // "YOU · +2 HUMANS · 1 AGENT" style — the YOU pill already
        // indicates this visitor, so show others-only counts here.
        const otherHumans = Math.max(0, (humans ?? 0) - (isAgent ? 0 : 1));
        const otherAgents = Math.max(0, (agents ?? 0) - (isAgent ? 1 : 0));
        const parts = [];
        if (otherHumans > 0) parts.push(`+${otherHumans} ${otherHumans === 1 ? 'HUMAN' : 'HUMANS'}`);
        if (otherAgents > 0) parts.push(`+${otherAgents} ${otherAgents === 1 ? 'AGENT' : 'AGENTS'}`);
        // Solo state gets the time-of-day flex; crowded stays +N style.
        setLabel(parts.length ? parts.join(' · ') : aloneLabel());
      } catch {}
    });

    ws.addEventListener('error', () => hide());
    ws.addEventListener('close', () => {
      stopHeartbeat();
      // Silent backoff — try once after 10s, then give up.
      if (!connectTimer) {
        connectTimer = window.setTimeout(() => { /* one-shot retry no-op; keep it simple */ }, 10_000);
      }
    });
  })();
</script>

<style>
  .presence {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
  }

  .presence__sep {
    color: var(--pc-rule);
  }

  .presence__pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 8px;
    border: 1px solid #C95C2E;
    border-radius: 2px;
    background: color-mix(in srgb, #C95C2E 6%, #fff);
    color: #7a2e0d;
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.14em;
  }

  .presence__dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #C95C2E;
    animation: pc-pulse 1.6s ease-in-out infinite;
    flex-shrink: 0;
  }

  .presence__you {
    font-weight: 500;
  }

  .presence__count::before {
    content: '';
    display: inline-block;
    width: 1px;
    height: 9px;
    margin: 0 6px -1px 2px;
    background: currentColor;
    opacity: 0.35;
    vertical-align: middle;
  }

  @keyframes pc-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.15); }
  }

  @media (max-width: 620px) {
    .presence__pill {
      padding: 2px 6px;
      font-size: 9.5px;
    }
  }
</style>
