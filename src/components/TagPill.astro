---
interface Props {
  tag: string;
  active?: boolean;
}

const { tag, active = false } = Astro.props;

const colors: Record<string, string> = {
  article: 'bg-nouns-blue/20 text-nouns-blue border-nouns-blue/30',
  project: 'bg-nouns-green/20 text-nouns-green border-nouns-green/30',
  essay: 'bg-nouns-yellow/20 text-nouns-yellow border-nouns-yellow/30',
  art: 'bg-nouns-red/20 text-nouns-red border-nouns-red/30',
  newsletter: 'bg-nouns-green/20 text-nouns-green border-nouns-green/30',
};

const colorClass = colors[tag.toLowerCase()] || 'bg-nouns-bg-elevated text-nouns-muted border-nouns-border';
---

<span class:list={[
  'inline-block px-3 py-1 text-xs font-mono uppercase tracking-wider rounded-full border',
  colorClass,
  active && 'ring-1 ring-current',
]}>
  {tag}
</span>
