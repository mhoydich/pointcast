---
interface Props {
  tag: string;
  active?: boolean;
}

const { tag, active = false } = Astro.props;

const colors: Record<string, string> = {
  article: 'bg-nouns-blue/15 text-nouns-blue border-nouns-blue/20',
  project: 'bg-nouns-green/15 text-nouns-green border-nouns-green/20',
  essay: 'bg-nouns-yellow/15 text-nouns-yellow border-nouns-yellow/20',
  art: 'bg-nouns-red/15 text-nouns-red border-nouns-red/20',
  newsletter: 'bg-nouns-yellow/15 text-nouns-yellow border-nouns-yellow/20',
};

const colorClass = colors[tag.toLowerCase()] || 'bg-nouns-bg-elevated text-nouns-muted border-nouns-border';
---

<span class:list={[
  'inline-block px-2.5 py-0.5 text-xs font-mono uppercase tracking-wider rounded-full border',
  colorClass,
  active && 'ring-1 ring-current',
]}>
  {tag === 'newsletter' ? 'dispatch' : tag}
</span>
