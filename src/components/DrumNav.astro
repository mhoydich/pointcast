---
/**
 * DrumNav — shared navigation strip across all /drum* surfaces.
 *
 * Current surfaces:
 *   /drum         → v1 classic (cookie-clicker, original)
 *   /drum-v2      → v2 collab  (pentatonic voice + leaderboard + DRUM token)
 *   /drum-v3      → v3 spotify (drum along to a Spotify track, collaborative)
 *   /drum-apr26   → special   (8-pad beat machine + sequencer, dark theme)
 *
 * The active pill is highlighted. Use `current` prop with one of:
 * 'v1' | 'v2' | 'v3' | 'apr26'.
 *
 * Per Mike 2026-04-26: "/drum is where everything should land with toggles
 * and navigation". This strip is the toggles+navigation. It renders inside
 * each variant page (not the shared layout) so the standalone-dark
 * /drum-apr26 page can opt in too if its agent picks it up.
 */
interface Props {
  current: 'v1' | 'v2' | 'v3' | 'v4' | 'v5' | 'v6' | 'v7' | 'v8' | 'v9' | 'v10' | 'v11' | 'v12' | 'v13' | 'potato' | 'jam' | 'pulse' | 'agents' | 'daily' | 'viz' | 'marquee' | 'radio' | 'stickers' | 'trophies' | 'apr26' | 'tv' | 'tv2' | 'mcp';
}
const { current } = Astro.props;

const links = [
  { id: 'v1',    href: '/drum',       label: 'classic',   sub: 'v1' },
  { id: 'v2',    href: '/drum-v2',    label: 'collab',    sub: 'v2' },
  { id: 'v3',    href: '/drum-v3',    label: 'spotify',   sub: 'v3' },
  { id: 'v4',    href: '/drum-v4',    label: 'orchestra', sub: 'v4' },
  { id: 'v5',    href: '/drum-v5',    label: 'loops',     sub: 'v5' },
  { id: 'v6',    href: '/drum-v6',    label: 'choir',     sub: 'v6' },
  { id: 'v7',       href: '/drum-v7',    label: 'big',       sub: 'v7 · 30' },
  { id: 'v8',       href: '/drum-v8',    label: 'symphony',  sub: 'v8 · 42' },
  { id: 'v9',       href: '/drum-v9',    label: 'lounge',    sub: 'v9 · sax' },
  { id: 'v10',      href: '/drum-v10',   label: 'theremin',  sub: 'v10 · gesture' },
  { id: 'v11',      href: '/drum-v11',   label: 'bells',     sub: 'v11 · chimes' },
  { id: 'v12',      href: '/drum-v12',   label: 'organ',     sub: 'v12 · pipes' },
  { id: 'v13',      href: '/drum-v13',   label: 'strings',   sub: 'v13 · pizz/arco' },
  { id: 'potato',   href: '/drum-potato', label: 'potato',   sub: 'game' },
  { id: 'jam',      href: '/drum-jam',    label: 'jam',      sub: '3+ jams' },
  { id: 'pulse',    href: '/drum-pulse', label: 'pulse',    sub: 'heartbeat' },
  { id: 'agents',   href: '/drum-agents', label: 'agents',  sub: 'hall' },
  { id: 'daily',    href: '/drum-daily',  label: 'daily',   sub: 'beat of day' },
  { id: 'stickers', href: '/drum-stickers', label: 'stickers', sub: 'binder' },
  { id: 'trophies', href: '/drum-trophies', label: 'trophies', sub: 'on-chain' },
  { id: 'apr26', href: '/drum-apr26', label: 'sequencer', sub: 'apr 26' },
  { id: 'tv',       href: '/drum-tv',    label: 'tv',        sub: 'cast mode' },
  { id: 'tv2',      href: '/drum-tv-v2', label: 'venue',     sub: 'tv v2' },
  { id: 'viz',      href: '/drum-viz',   label: 'viz',       sub: 'tv v3' },
  { id: 'marquee',  href: '/drum-marquee', label: 'marquee', sub: 'tv min' },
  { id: 'radio',    href: '/drum-radio', label: 'radio',    sub: '96.1 fm' },
  { id: 'mcp',      href: '/api/mcp',    label: 'mcp',       sub: 'agents' },
] as const;
---

<nav class="drum-nav" aria-label="Drum room variants">
  <span class="drum-nav__label">drum room</span>
  <ul class="drum-nav__list" role="list">
    {links.map((l) => (
      <li class="drum-nav__item">
        <a
          href={l.href}
          class={`drum-nav__pill${l.id === current ? ' drum-nav__pill--active' : ''}`}
          aria-current={l.id === current ? 'page' : undefined}
        >
          <span class="drum-nav__pill-label">{l.label}</span>
          <span class="drum-nav__pill-sub">{l.sub}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<style is:global>
  .drum-nav {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    padding: 10px 0 14px;
    font-family: var(--pc-font-mono, 'JetBrains Mono', ui-monospace, monospace);
  }
  .drum-nav__label {
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--pc-ink-muted, #5F5E5A);
  }
  .drum-nav__list {
    display: flex;
    gap: 6px;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }
  .drum-nav__pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px 4px 12px;
    border: 1.5px solid var(--pc-ink, #12110E);
    border-radius: 999px;
    text-decoration: none;
    color: var(--pc-ink, #12110E);
    background: #fff;
    transition: background 120ms, color 120ms;
  }
  .drum-nav__pill:hover { background: var(--pc-rule-soft, #E5E3DE); text-decoration: none; }
  .drum-nav__pill--active {
    background: var(--pc-ink, #12110E);
    color: #fff;
    cursor: default;
  }
  .drum-nav__pill--active:hover { background: var(--pc-ink, #12110E); }
  .drum-nav__pill-label {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .drum-nav__pill-sub {
    font-size: 8px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.5;
  }
</style>
