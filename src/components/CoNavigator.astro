---
/**
 * CoNavigator — persistent sticky footer bar across the whole site.
 *
 * Mike 2026-04-20 14:05 PT: *"need a way to keep the music as you
 * navigate... lets start to look into a footer bar co navigator for
 * pointcast, has your mood, current pointcast state, data, interaction
 * tools, etc."*
 *
 * Design:
 *   - Fixed to viewport bottom, ~56px tall (48 on mobile).
 *   - Three zones, left-to-right:
 *       [LEFT]   mood chip + ▶ play soundtrack
 *       [MID]    state readouts (here now · hello · streak · shipped today)
 *       [RIGHT]  quick-nav chips (/here · /workbench · /drop)
 *   - Expandable drawer above the bar holds the soundtrack iframe.
 *     The iframe uses `transition:persist="pc-soundtrack"` so
 *     ClientRouter soft-navigations keep the audio alive across pages.
 *
 * Music persistence contract:
 *   - MoodChip dispatches `pc:mood-changed` with detail.moodId on click.
 *   - CoNav listens → updates display + surfaces a "▶ {label}" offer.
 *   - User taps ▶ → iframe src = MOOD_SOUNDTRACKS[id].url.
 *   - Navigating to any other page preserves the iframe (persist).
 *   - pc:music:mood + pc:music:playing remembered in localStorage so
 *     a full page reload can offer "▶ resume" with the prior mood.
 *
 * Author: cc. Source: Mike 2026-04-20 14:05 PT chat.
 */
import { MOOD_SOUNDTRACKS } from '../lib/moods-soundtracks';
const SOUNDTRACKS_JSON = JSON.stringify(MOOD_SOUNDTRACKS);
---

<aside class="conav" id="pc-conav" aria-label="PointCast co-navigator" data-open="true">
  <!-- When closed, only this tiny reopen chip shows. -->
  <button type="button" class="conav__reopen mono" id="pc-conav-reopen" aria-label="Open co-navigator bar">
    <span aria-hidden="true">📡</span>
  </button>

  <div class="conav__bar">
    <div class="conav__left">
      <button
        type="button"
        class="conav__noun"
        id="pc-conav-noun-btn"
        aria-label="Your noun — tap to shuffle or pick a new one"
      >
        <img class="conav__noun-img" id="pc-conav-noun-img" alt="" src="" loading="eager" />
      </button>
      <button
        type="button"
        class="conav__mood"
        id="pc-conav-mood-btn"
        aria-label="Current mood — tap to open soundtrack"
      >
        <span class="conav__mood-dot" id="pc-conav-mood-dot" aria-hidden="true"></span>
        <span class="conav__mood-label mono" id="pc-conav-mood-label">SET MOOD</span>
      </button>
      <button
        type="button"
        class="conav__play"
        id="pc-conav-play"
        aria-label="Play mood soundtrack"
        hidden
      >
        <span class="conav__play-icon" aria-hidden="true">▶</span>
      </button>
      <button
        type="button"
        class="conav__collect"
        id="pc-conav-collect"
        aria-label="Collect this moment — noun + mood + listening + where"
        title="Collect this moment (noun + mood + listening + where)"
      >
        <span class="conav__collect-icon" aria-hidden="true">✦</span>
        <span class="conav__collect-label mono">COLLECT</span>
      </button>
    </div>

    <div class="conav__mid">
      <span class="conav__stat">
        <span class="conav__stat-n mono" id="pc-conav-here">·</span>
        <span class="conav__stat-l mono">here</span>
      </span>
      <span class="conav__stat">
        <span class="conav__stat-n mono" id="pc-conav-hello">·</span>
        <span class="conav__stat-l mono">hello</span>
      </span>
      <span class="conav__stat">
        <span class="conav__stat-n mono" id="pc-conav-streak">·</span>
        <span class="conav__stat-l mono">streak</span>
      </span>
      <span class="conav__stat" id="pc-conav-moments-wrap" hidden>
        <span class="conav__stat-n mono" id="pc-conav-moments">·</span>
        <span class="conav__stat-l mono">moments</span>
      </span>
    </div>

    <nav class="conav__right" aria-label="Quick nav">
      <a class="conav__link mono" href="/here">here</a>
      <a class="conav__link mono" href="/drum/click" title="Drum — cookie clicker">drum</a>
      <a class="conav__link conav__link--noundrum mono" href="/noundrum" title="Noundrum — drum to claim land, make art">
        <span class="conav__link-icon" aria-hidden="true">🥁</span><span class="conav__link-text">nd</span>
      </a>
      <a class="conav__link conav__link--ping mono" href="/ping" title="Ping — message the team">
        <span class="conav__link-icon" aria-hidden="true">✎</span><span class="conav__link-text">ping</span>
      </a>
      <a class="conav__link conav__link--contribute mono" href="/contribute" title="Contribute compute">
        <span class="conav__link-icon" aria-hidden="true">✦</span><span class="conav__link-text">+compute</span>
      </a>
      <button type="button" class="conav__link conav__link--cast mono" id="pc-conav-cast" title="Cast this page to Farcaster / share">
        <span class="conav__link-icon" aria-hidden="true">↗</span><span class="conav__link-text">cast</span>
      </button>
      <a class="conav__link conav__link--cos mono" href="/cos" title="Chief of Staff — chat the team">cos</a>
      <a class="conav__link mono" href="/tv" title="TV — ambient broadcast + 12 shows">tv</a>
      <a class="conav__link mono" href="/profile">me</a>
    </nav>

    <button type="button" class="conav__close" id="pc-conav-close-bar" aria-label="Close co-navigator bar (can reopen)" title="Close bar">×</button>
  </div>

  <!-- Mood picker popover, opens above the bar when the mood chip is tapped
       and no mood is set yet. Per Mike 2026-04-20 ~15:00 PT: "have this
       [mood] in the bar, and then once you select it goes away". Selection
       closes the popover + drops the mood chip into its "chosen" state. -->
  <div class="conav__mood-picker" id="pc-conav-mood-picker" hidden>
    <p class="conav__mood-picker-title mono">
      <span>pick a mood · page + music follow</span>
      <button type="button" class="conav__mood-picker-close mono" id="pc-conav-mood-picker-close" aria-label="Close picker">×</button>
    </p>
    <div class="conav__mood-picker-row" id="pc-conav-mood-picker-row">
      <button type="button" class="conav__mood-opt" data-mood-id="chill"   style="--m: #2B8A3E">
        <span class="conav__mood-opt-dot" aria-hidden="true"></span>
        <span class="conav__mood-opt-l mono">CHILL</span>
        <span class="conav__mood-opt-h">slow + calm</span>
      </button>
      <button type="button" class="conav__mood-opt" data-mood-id="hype"    style="--m: #C92A2A">
        <span class="conav__mood-opt-dot" aria-hidden="true"></span>
        <span class="conav__mood-opt-l mono">HYPE</span>
        <span class="conav__mood-opt-h">on the rise</span>
      </button>
      <button type="button" class="conav__mood-opt" data-mood-id="focus"   style="--m: #1864AB">
        <span class="conav__mood-opt-dot" aria-hidden="true"></span>
        <span class="conav__mood-opt-l mono">FOCUS</span>
        <span class="conav__mood-opt-h">in the work</span>
      </button>
      <button type="button" class="conav__mood-opt" data-mood-id="flow"    style="--m: #5F3DC4">
        <span class="conav__mood-opt-dot" aria-hidden="true"></span>
        <span class="conav__mood-opt-l mono">FLOW</span>
        <span class="conav__mood-opt-h">on tempo</span>
      </button>
      <button type="button" class="conav__mood-opt" data-mood-id="curious" style="--m: #E8590C">
        <span class="conav__mood-opt-dot" aria-hidden="true"></span>
        <span class="conav__mood-opt-l mono">CURIOUS</span>
        <span class="conav__mood-opt-h">following a thread</span>
      </button>
      <button type="button" class="conav__mood-opt" data-mood-id="quiet"   style="--m: #5F5E5A">
        <span class="conav__mood-opt-dot" aria-hidden="true"></span>
        <span class="conav__mood-opt-l mono">QUIET</span>
        <span class="conav__mood-opt-h">under the noise</span>
      </button>
    </div>
    <p class="conav__mood-picker-foot mono">
      once picked, the page tints + the soundtrack follows you.
      change anytime via this chip.
    </p>
  </div>

  <!-- Noun picker popover, opens above the bar when the noun chip is tapped. -->
  <div class="conav__noun-picker" id="pc-conav-noun-picker" hidden>
    <p class="conav__noun-picker-title mono">
      <span id="pc-conav-noun-picker-current">noun —</span>
      <button type="button" class="conav__noun-picker-close mono" id="pc-conav-noun-picker-close" aria-label="Close picker">×</button>
    </p>
    <div class="conav__noun-picker-row" id="pc-conav-noun-picker-row"></div>
    <div class="conav__noun-picker-actions">
      <button type="button" class="conav__noun-picker-btn mono" id="pc-conav-noun-shuffle">↺ SHUFFLE</button>
      <button type="button" class="conav__noun-picker-btn mono" id="pc-conav-noun-reset">DEFAULT</button>
    </div>
  </div>

  <div class="conav__drawer" id="pc-conav-drawer" hidden data-soundtracks={SOUNDTRACKS_JSON}>
    <div class="conav__drawer-head">
      <p class="conav__drawer-title mono" id="pc-conav-drawer-title">soundtrack</p>
      <button type="button" class="conav__drawer-close mono" id="pc-conav-close" aria-label="Close soundtrack">× close</button>
    </div>
    <!-- transition:persist keeps this iframe alive across ClientRouter soft-navs -->
    <iframe
      transition:persist="pc-soundtrack"
      id="pc-conav-iframe"
      src="about:blank"
      title="Mood soundtrack"
      loading="lazy"
      allow="autoplay; encrypted-media"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>
</aside>

<script>
// Typed client script — runs once per full page load. Internal state is
// re-read from localStorage + DOM each time so ClientRouter soft-navs
// rehydrate cleanly.
(function () {
  'use strict';
  if (typeof window === 'undefined') return;

  const MOODS: Record<string, { color: string; label: string }> = {
    chill:   { color: '#2B8A3E', label: 'CHILL' },
    hype:    { color: '#C92A2A', label: 'HYPE' },
    focus:   { color: '#1864AB', label: 'FOCUS' },
    flow:    { color: '#5F3DC4', label: 'FLOW' },
    curious: { color: '#E8590C', label: 'CURIOUS' },
    quiet:   { color: '#5F5E5A', label: 'QUIET' },
  };

  const LS_MOOD = 'pc:mood';
  const LS_MUSIC_MOOD = 'pc:music:mood';
  const LS_MUSIC_PLAYING = 'pc:music:playing';

  function qs<T extends Element>(sel: string): T | null { return document.querySelector(sel) as T | null; }
  function qid<T extends HTMLElement>(id: string): T | null { return document.getElementById(id) as T | null; }

  function init() {
    const moodBtn = qid<HTMLButtonElement>('pc-conav-mood-btn');
    const moodDot = qid<HTMLElement>('pc-conav-mood-dot');
    const moodLabel = qid<HTMLElement>('pc-conav-mood-label');
    const moodArrow = qid<HTMLElement>('pc-conav-mood-arrow');
    const playBtn = qid<HTMLButtonElement>('pc-conav-play');
    const playLabel = qid<HTMLElement>('pc-conav-play-label');
    const drawer = qid<HTMLElement>('pc-conav-drawer');
    const drawerTitle = qid<HTMLElement>('pc-conav-drawer-title');
    const closeBtn = qid<HTMLButtonElement>('pc-conav-close');
    const iframe = qid<HTMLIFrameElement>('pc-conav-iframe');

    if (!drawer || !iframe) return;

    let soundtracks: Record<string, { label: string; url: string; source: string; description: string }> = {};
    try { soundtracks = JSON.parse(drawer.getAttribute('data-soundtracks') || '{}'); } catch { soundtracks = {}; }

    // ---------- mood display update --------------------------------------
    function paintMood(id: string | null) {
      const m = id && MOODS[id];
      if (m && moodDot && moodLabel) {
        moodDot.style.background = m.color;
        moodLabel.textContent = m.label;
      } else if (moodDot && moodLabel) {
        moodDot.style.background = '#c4c2bc';
        moodLabel.textContent = 'SET MOOD';
      }
      // Show play offer if we have a soundtrack.
      const t = id ? soundtracks[id] : null;
      if (playBtn && playLabel && t) {
        playBtn.hidden = false;
        playLabel.textContent = t.label;
      } else if (playBtn) {
        playBtn.hidden = true;
      }
    }

    function getMood(): string | null {
      try { return localStorage.getItem(LS_MOOD); } catch { return null; }
    }

    // ---------- drawer + iframe ----------------------------------------
    function openDrawer(moodId: string) {
      if (!drawer || !iframe) return;
      const t = soundtracks[moodId];
      if (!t) return;
      if (iframe.src !== t.url) iframe.src = t.url;
      drawer.hidden = false;
      if (drawerTitle) drawerTitle.textContent = t.label + ' · ' + (MOODS[moodId] ? MOODS[moodId].label : moodId.toUpperCase());
      try {
        localStorage.setItem(LS_MUSIC_MOOD, moodId);
        localStorage.setItem(LS_MUSIC_PLAYING, '1');
      } catch {}
    }
    function closeDrawer() {
      if (!drawer || !iframe) return;
      iframe.src = 'about:blank';
      drawer.hidden = true;
      try { localStorage.setItem(LS_MUSIC_PLAYING, '0'); } catch {}
    }

    // ---------- stats: live count + hello + streak ---------------------
    function paintStats() {
      const hereEl = qid('pc-conav-here');
      const helloEl = qid('pc-conav-hello');
      const streakEl = qid('pc-conav-streak');
      try {
        const h = parseInt(localStorage.getItem('pc:hello:count') || '0', 10) || 0;
        if (helloEl) helloEl.textContent = String(h);
      } catch {}
      try {
        const raw = localStorage.getItem('pc:daily:collected');
        const arr: { date: string }[] = raw ? JSON.parse(raw) || [] : [];
        // Simple streak: consecutive days ending today (PT).
        const today = new Date().toISOString().slice(0, 10);
        let streak = 0;
        const uniq: Record<string, boolean> = {};
        arr.forEach((c) => { if (c.date) uniq[c.date] = true; });
        const cursor = new Date(today + 'T12:00:00');
        while (true) {
          const ymd = cursor.toISOString().slice(0, 10);
          if (!uniq[ymd]) break;
          streak++;
          cursor.setDate(cursor.getDate() - 1);
        }
        if (streakEl) streakEl.textContent = String(streak);
      } catch {}
      fetch('/api/presence/snapshot', { cache: 'no-store' })
        .then((r) => (r.ok ? r.json() : null))
        .then((j) => {
          if (!j) return;
          const total = (j.humans || 0) + (j.agents || 0);
          if (hereEl) hereEl.textContent = String(Math.max(total, 1));
        })
        .catch(() => {});
    }

    // ---------- mood picker popover (inline mood selection) --------------
    const moodPicker = qid<HTMLElement>('pc-conav-mood-picker');
    const moodPickerClose = qid<HTMLButtonElement>('pc-conav-mood-picker-close');
    const moodPickerRow = qid<HTMLElement>('pc-conav-mood-picker-row');

    const MOOD_HUES: Record<string, number> = {
      chill: 155, hype: 8, focus: 215, flow: 275, curious: 28, quiet: 220,
    };

    function openMoodPicker() {
      if (moodPicker) moodPicker.hidden = false;
      // Close the other popover if open.
      if (picker && !picker.hidden) picker.hidden = true;
    }
    function closeMoodPicker() {
      if (moodPicker) moodPicker.hidden = true;
    }

    function meditativePulse(id: string) {
      try {
        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      } catch {}
      const hue = MOOD_HUES[id] ?? 28;
      const overlay = document.createElement('div');
      overlay.className = 'mood-pulse';
      overlay.setAttribute('aria-hidden', 'true');
      overlay.style.setProperty('--mood-hue', String(hue));
      document.body.appendChild(overlay);
      setTimeout(() => { if (overlay.parentNode) overlay.parentNode.removeChild(overlay); }, 1800);
    }

    function selectMood(id: string) {
      try { localStorage.setItem(LS_MOOD, id); } catch {}
      document.documentElement.setAttribute('data-pc-mood', id);
      paintMood(id);
      meditativePulse(id);
      try { window.dispatchEvent(new CustomEvent('pc:mood-changed', { detail: { moodId: id } })); } catch {}
      closeMoodPicker();
    }

    if (moodPickerRow) {
      Array.prototype.forEach.call(moodPickerRow.querySelectorAll('.conav__mood-opt'), (el: Element) => {
        el.addEventListener('click', () => {
          const id = el.getAttribute('data-mood-id');
          if (id) selectMood(id);
        });
      });
    }
    if (moodPickerClose) moodPickerClose.addEventListener('click', closeMoodPicker);

    // ---------- wiring --------------------------------------------------
    if (moodBtn) moodBtn.addEventListener('click', () => {
      const id = getMood();
      if (!id) {
        // No mood yet — open the picker inline. Per Mike 2026-04-20 15:00 PT:
        // "have this in the bar, and then once you select it goes away."
        if (moodPicker && moodPicker.hidden) openMoodPicker();
        else closeMoodPicker();
        return;
      }
      // Mood set: tap toggles the soundtrack drawer.
      if (drawer && drawer.hidden) openDrawer(id);
      else closeDrawer();
    });
    if (playBtn) playBtn.addEventListener('click', () => {
      const id = getMood();
      if (!id) return;
      if (drawer && drawer.hidden) openDrawer(id);
      else closeDrawer();
    });
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);

    window.addEventListener('pc:mood-changed', (e: Event) => {
      const detail = (e as CustomEvent).detail;
      const id = detail && detail.moodId;
      if (id) paintMood(id);
    });

    // ---------- initial paint on every page load + soft-nav --------------
    function hydrate() {
      paintMood(getMood());
      paintStats();
      // If music was playing on a prior page AND iframe is still live, keep drawer open.
      try {
        const wasPlaying = localStorage.getItem(LS_MUSIC_PLAYING) === '1';
        const moodId = localStorage.getItem(LS_MUSIC_MOOD) || getMood();
        if (wasPlaying && drawer && moodId && iframe && iframe.src && iframe.src !== 'about:blank') {
          drawer.hidden = false;
          if (drawerTitle && soundtracks[moodId] && MOODS[moodId]) {
            drawerTitle.textContent = soundtracks[moodId].label + ' · ' + MOODS[moodId].label;
          }
        }
      } catch {}
    }

    // ---------- noun chip + picker --------------------------------------
    const nounBtn = qid<HTMLButtonElement>('pc-conav-noun-btn');
    const nounImg = qid<HTMLImageElement>('pc-conav-noun-img');
    const picker = qid<HTMLElement>('pc-conav-noun-picker');
    const pickerClose = qid<HTMLButtonElement>('pc-conav-noun-picker-close');
    const pickerCurrent = qid<HTMLElement>('pc-conav-noun-picker-current');
    const pickerRow = qid<HTMLElement>('pc-conav-noun-picker-row');
    const shuffleBtn = qid<HTMLButtonElement>('pc-conav-noun-shuffle');
    const resetBtn = qid<HTMLButtonElement>('pc-conav-noun-reset');

    const LS_NOUN_OVERRIDE = 'pc:visitor:noun:override';
    const LS_NOUN = 'pc:visitor:noun';
    const LS_SESSION = 'pc:session';

    function cheapHash(s: string): number {
      let h = 5381;
      for (let i = 0; i < s.length; i++) h = (((h << 5) + h) + s.charCodeAt(i)) | 0;
      return h >>> 0;
    }
    function deriveNounId(): number {
      try {
        const sid = localStorage.getItem(LS_SESSION) || '';
        if (!sid) return 0;
        return cheapHash(sid) % 1200;
      } catch { return 0; }
    }
    function currentNounId(): number {
      try {
        const override = localStorage.getItem(LS_NOUN_OVERRIDE);
        if (override) {
          const n = parseInt(override, 10);
          if (n >= 0 && n < 1200) return n;
        }
        const stored = localStorage.getItem(LS_NOUN);
        if (stored) {
          const n = parseInt(stored, 10);
          if (n >= 0 && n < 1200) return n;
        }
      } catch {}
      return deriveNounId();
    }
    function paintNoun() {
      const id = currentNounId();
      if (nounImg) {
        nounImg.src = 'https://noun.pics/' + id + '.svg';
        nounImg.alt = 'your noun · ' + id;
      }
      if (pickerCurrent) pickerCurrent.textContent = 'YOUR NOUN · ' + id;
    }
    function paintPickerRow() {
      if (!pickerRow) return;
      const current = currentNounId();
      const pool = [];
      // 6 random options + current.
      const seen: Record<number, boolean> = { [current]: true };
      pool.push(current);
      while (pool.length < 7) {
        const n = Math.floor(Math.random() * 1200);
        if (!seen[n]) { seen[n] = true; pool.push(n); }
      }
      pickerRow.innerHTML = pool.map((n) => {
        const activeCls = (n === current) ? ' conav__noun-opt--current' : '';
        return '<button type="button" class="conav__noun-opt' + activeCls + '" data-noun-id="' + n + '" aria-label="Use noun ' + n + '"><img src="https://noun.pics/' + n + '.svg" alt="" loading="lazy" width="36" height="36" style="image-rendering: pixelated;"/></button>';
      }).join('');
      Array.prototype.forEach.call(pickerRow.querySelectorAll('.conav__noun-opt'), function (el: Element) {
        el.addEventListener('click', function () {
          const id = parseInt(el.getAttribute('data-noun-id') || '0', 10);
          if (id >= 0 && id < 1200) {
            try { localStorage.setItem(LS_NOUN_OVERRIDE, String(id)); } catch {}
            try { localStorage.setItem(LS_NOUN, String(id)); } catch {}
            paintNoun();
            paintPickerRow();
          }
        });
      });
    }
    function openPicker() {
      if (picker) picker.hidden = false;
      paintPickerRow();
    }
    function closePicker() { if (picker) picker.hidden = true; }
    if (nounBtn) nounBtn.addEventListener('click', () => {
      if (picker && picker.hidden) openPicker();
      else closePicker();
    });
    if (pickerClose) pickerClose.addEventListener('click', closePicker);
    if (shuffleBtn) shuffleBtn.addEventListener('click', () => {
      const n = Math.floor(Math.random() * 1200);
      try { localStorage.setItem(LS_NOUN_OVERRIDE, String(n)); } catch {}
      try { localStorage.setItem(LS_NOUN, String(n)); } catch {}
      paintNoun();
      paintPickerRow();
    });
    if (resetBtn) resetBtn.addEventListener('click', () => {
      try { localStorage.removeItem(LS_NOUN_OVERRIDE); } catch {}
      // Keep pc:visitor:noun as derived.
      try { localStorage.setItem(LS_NOUN, String(deriveNounId())); } catch {}
      paintNoun();
      paintPickerRow();
    });

    // ---------- collect moment ------------------------------------------
    const collectBtn = qid<HTMLButtonElement>('pc-conav-collect');
    const momentsWrap = qid<HTMLElement>('pc-conav-moments-wrap');
    const momentsEl = qid<HTMLElement>('pc-conav-moments');
    const LS_MOMENTS = 'pc:moments';

    function readMoments(): Array<Record<string, unknown>> {
      try {
        const raw = localStorage.getItem(LS_MOMENTS);
        if (!raw) return [];
        const parsed = JSON.parse(raw);
        return Array.isArray(parsed) ? parsed : [];
      } catch { return []; }
    }
    function writeMoments(arr: Array<Record<string, unknown>>): void {
      try { localStorage.setItem(LS_MOMENTS, JSON.stringify(arr.slice(-200))); } catch {}
    }
    function paintMoments() {
      const arr = readMoments();
      if (momentsWrap) momentsWrap.hidden = arr.length === 0;
      if (momentsEl) momentsEl.textContent = String(arr.length);
    }
    if (collectBtn) collectBtn.addEventListener('click', () => {
      let mood = null, listening = null, where = null;
      try { mood = localStorage.getItem('pc:mood') || localStorage.getItem('pc:visitor:mood'); } catch {}
      try { listening = localStorage.getItem('pc:visitor:listening'); } catch {}
      try { where = localStorage.getItem('pc:visitor:where'); } catch {}
      const moment = {
        at: new Date().toISOString(),
        path: window.location.pathname,
        nounId: currentNounId(),
        mood: mood,
        listening: listening,
        where: where,
      };
      const next = readMoments();
      next.push(moment);
      writeMoments(next);
      paintMoments();
      // Flash the collect button so the user sees the save.
      collectBtn.classList.add('conav__collect--saved');
      setTimeout(() => collectBtn.classList.remove('conav__collect--saved'), 1200);
    });

    // ---------- close / reopen bar --------------------------------------
    const conav = qid<HTMLElement>('pc-conav');
    const closeBarBtn = qid<HTMLButtonElement>('pc-conav-close-bar');
    const reopenBtn = qid<HTMLButtonElement>('pc-conav-reopen');
    const LS_CLOSED = 'pc:conav:closed';
    function paintOpenState() {
      if (!conav) return;
      let closed = false;
      try { closed = localStorage.getItem(LS_CLOSED) === '1'; } catch {}
      conav.setAttribute('data-open', closed ? 'false' : 'true');
    }
    if (closeBarBtn) closeBarBtn.addEventListener('click', () => {
      try { localStorage.setItem(LS_CLOSED, '1'); } catch {}
      // Close any open drawer / picker first.
      closeDrawer(); closePicker(); closeMoodPicker();
      paintOpenState();
    });
    if (reopenBtn) reopenBtn.addEventListener('click', () => {
      try { localStorage.setItem(LS_CLOSED, '0'); } catch {}
      paintOpenState();
    });

    // ---------- cast (share to Farcaster / copy-link fallback) ----------
    // Opens warpcast.com/~/compose with the current page URL + a short
    // lead so any Farcaster user can cast the page in one tap. Falls back
    // to clipboard copy on non-mobile when Warpcast isn't installed.
    const castBtn = qid<HTMLButtonElement>('pc-conav-cast');
    if (castBtn) castBtn.addEventListener('click', async () => {
      const url = window.location.href;
      const titleEl = document.querySelector('meta[property="og:title"]') as HTMLMetaElement | null;
      const pageTitle = (titleEl && titleEl.content) || document.title || 'PointCast';
      const text = `${pageTitle} — ${url}`;
      // Prefer native share (mobile + recent desktop Safari/Chrome).
      const nav = navigator as Navigator & { share?: (data: { title?: string; text?: string; url?: string }) => Promise<void> };
      if (nav.share) {
        try { await nav.share({ title: pageTitle, text: pageTitle, url }); return; } catch {}
      }
      // Fallback: open warpcast compose.
      const castUrl = `https://warpcast.com/~/compose?text=${encodeURIComponent(text)}&embeds[]=${encodeURIComponent(url)}`;
      window.open(castUrl, '_blank', 'noopener');
    });

    // ---------- full hydrate ----------
    paintNoun();
    paintMoments();
    paintOpenState();

    hydrate();
    document.addEventListener('astro:page-load', () => { hydrate(); paintNoun(); paintMoments(); paintOpenState(); });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // ---- WebMCP — expose PointCast tools to browser AI agents ----------
  // Per isitagentready.com 2026-04-20 audit: implement
  // navigator.modelContext.provideContext() so in-browser agents
  // (Chrome with the Gemini/Claude extension, etc.) can discover +
  // invoke PointCast's key actions without scraping the DOM.
  // Docs: webmachinelearning.github.io/webmcp + developer.chrome.com/blog/webmcp-epp
  function registerWebMCP() {
    const nav = navigator as Navigator & {
      modelContext?: {
        provideContext?: (ctx: { tools?: Array<Record<string, unknown>> }) => void;
      };
    };
    if (!nav.modelContext || typeof nav.modelContext.provideContext !== 'function') return;
    try {
      nav.modelContext.provideContext({
        tools: [
          {
            name: 'pointcast.ping',
            description: 'Send an async message to the PointCast team (Mike + Claude Code). Optional expand:true turns the message into a topic cc drafts a block from on the next session.',
            inputSchema: {
              type: 'object',
              properties: {
                body: { type: 'string', description: 'The message body, up to 4000 chars.', maxLength: 4000 },
                subject: { type: 'string', description: 'Optional one-line subject.', maxLength: 120 },
                from: { type: 'string', description: 'Optional sender name / handle.', maxLength: 80 },
                expand: { type: 'boolean', description: 'If true, cc drafts a block from this seed.', default: false },
              },
              required: ['body'],
            },
            execute: async (input: Record<string, unknown>) => {
              const res = await fetch('/api/ping', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  type: 'pc-ping-v1',
                  body: String(input.body || ''),
                  subject: input.subject ? String(input.subject) : undefined,
                  from: input.from ? String(input.from) : undefined,
                  expand: Boolean(input.expand),
                  timestamp: new Date().toISOString(),
                }),
              });
              return res.json();
            },
          },
          {
            name: 'pointcast.setMood',
            description: 'Set the visitor\'s current mood (tints the page + plays a soundtrack via the persistent CoNavigator bar). One of: chill, hype, focus, flow, curious, quiet.',
            inputSchema: {
              type: 'object',
              properties: { mood: { type: 'string', enum: ['chill', 'hype', 'focus', 'flow', 'curious', 'quiet'] } },
              required: ['mood'],
            },
            execute: async (input: Record<string, unknown>) => {
              const m = String(input.mood || '');
              const valid = ['chill', 'hype', 'focus', 'flow', 'curious', 'quiet'];
              if (!valid.includes(m)) return { ok: false, error: 'unknown mood' };
              try { localStorage.setItem('pc:mood', m); } catch {}
              document.documentElement.setAttribute('data-pc-mood', m);
              window.dispatchEvent(new CustomEvent('pc:mood-changed', { detail: { moodId: m } }));
              return { ok: true, mood: m };
            },
          },
          {
            name: 'pointcast.collectMoment',
            description: 'Collect the current moment — saves {nounId, mood, listening, where, path, at} to local moments list.',
            inputSchema: { type: 'object', properties: {} },
            execute: async () => {
              const btn = document.getElementById('pc-conav-collect') as HTMLButtonElement | null;
              if (btn) btn.click();
              return { ok: true, note: 'Moment collected to pc:moments localStorage.' };
            },
          },
          {
            name: 'pointcast.presenceSnapshot',
            description: 'Get live count of humans + agents connected to the PointCast presence Durable Object.',
            inputSchema: { type: 'object', properties: {} },
            execute: async () => {
              const res = await fetch('/api/presence/snapshot', { cache: 'no-store' });
              return res.ok ? res.json() : { ok: false };
            },
          },
          {
            name: 'pointcast.readLedger',
            description: 'Read the compute ledger — who did what, how heavy, optionally paid via what rail.',
            inputSchema: { type: 'object', properties: {} },
            execute: async () => {
              const res = await fetch('/compute.json');
              return res.ok ? res.json() : { ok: false };
            },
          },
          {
            name: 'pointcast.readCadence',
            description: 'Read the 15-minute ship cadence schedule (upcoming + recent).',
            inputSchema: { type: 'object', properties: {} },
            execute: async () => {
              const res = await fetch('/cadence.json');
              return res.ok ? res.json() : { ok: false };
            },
          },
        ],
      });
    } catch {}
  }
  registerWebMCP();
  // Re-register on Astro soft-nav so ClientRouter transitions don't drop context.
  document.addEventListener('astro:page-load', registerWebMCP);
})();
</script>

