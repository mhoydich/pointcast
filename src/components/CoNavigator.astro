---
/**
 * CoNavigator — persistent sticky footer bar across the whole site.
 *
 * Mike 2026-04-20 14:05 PT: *"need a way to keep the music as you
 * navigate... lets start to look into a footer bar co navigator for
 * pointcast, has your mood, current pointcast state, data, interaction
 * tools, etc."*
 *
 * Design:
 *   - Fixed to viewport bottom, ~56px tall (48 on mobile).
 *   - Three zones, left-to-right:
 *       [LEFT]   mood chip + ▶ play soundtrack
 *       [MID]    state readouts (here now · hello · streak · shipped today)
 *       [RIGHT]  quick-nav chips (/here · /workbench · /drop)
 *   - Expandable drawer above the bar holds the soundtrack iframe.
 *     The iframe uses `transition:persist="pc-soundtrack"` so
 *     ClientRouter soft-navigations keep the audio alive across pages.
 *
 * Music persistence contract:
 *   - MoodChip dispatches `pc:mood-changed` with detail.moodId on click.
 *   - CoNav listens → updates display + surfaces a "▶ {label}" offer.
 *   - User taps ▶ → iframe src = MOOD_SOUNDTRACKS[id].url.
 *   - Navigating to any other page preserves the iframe (persist).
 *   - pc:music:mood + pc:music:playing remembered in localStorage so
 *     a full page reload can offer "▶ resume" with the prior mood.
 *
 * Author: cc. Source: Mike 2026-04-20 14:05 PT chat.
 */
import { MOOD_SOUNDTRACKS } from '../lib/moods-soundtracks';
const SOUNDTRACKS_JSON = JSON.stringify(MOOD_SOUNDTRACKS);
---

<aside class="conav" id="pc-conav" aria-label="PointCast co-navigator">
  <div class="conav__bar">
    <div class="conav__identity">
      <a class="conav__brand mono" href="/" aria-label="PointCast home">
        <span class="conav__brand-mark" aria-hidden="true">PC</span>
        <span class="conav__brand-text">PointCast</span>
      </a>
      <button
        type="button"
        class="conav__mood"
        id="pc-conav-mood-btn"
        aria-label="Current mood - open soundtrack dock"
        aria-expanded="false"
        aria-controls="pc-conav-drawer"
      >
        <span class="conav__mood-dot" id="pc-conav-mood-dot" aria-hidden="true"></span>
        <span class="conav__mood-copy">
          <span class="conav__eyebrow mono">mood</span>
          <span class="conav__mood-label mono" id="pc-conav-mood-label">SET MOOD</span>
        </span>
      </button>
    </div>

    <div class="conav__sound">
      <button
        type="button"
        class="conav__play"
        id="pc-conav-play"
        aria-label="Play mood soundtrack"
        aria-expanded="false"
        aria-disabled="true"
        aria-controls="pc-conav-drawer"
      >
        <span class="conav__play-icon" aria-hidden="true"></span>
        <span class="conav__play-copy">
          <span class="conav__eyebrow mono">soundtrack</span>
          <span class="conav__play-label mono" id="pc-conav-play-label">CHOOSE MOOD</span>
        </span>
      </button>
    </div>

    <div class="conav__status" aria-label="Live PointCast state">
      <span class="conav__status-led" aria-hidden="true"></span>
      <span class="conav__status-label mono">live</span>
      <span class="conav__stat mono">
        <strong id="pc-conav-here">·</strong>
        <span>here</span>
      </span>
      <span class="conav__stat mono">
        <strong id="pc-conav-hello">·</strong>
        <span>hello</span>
      </span>
      <span class="conav__stat mono">
        <strong id="pc-conav-streak">·</strong>
        <span>streak</span>
      </span>
    </div>

    <nav class="conav__actions" aria-label="Quick nav">
      <a class="conav__link mono" href="/here" data-conav-route="/here">Here</a>
      <a class="conav__link mono" href="/apps" data-conav-route="/apps">Apps</a>
      <a class="conav__link mono" href="/workbench" data-conav-route="/workbench">Workbench</a>
      <a class="conav__link mono" href="/drop" data-conav-route="/drop">Drop</a>
    </nav>
  </div>

  <div class="conav__drawer" id="pc-conav-drawer" hidden data-soundtracks={SOUNDTRACKS_JSON}>
    <div class="conav__drawer-head">
      <div>
        <p class="conav__drawer-kicker mono">now playing</p>
        <p class="conav__drawer-title mono" id="pc-conav-drawer-title">soundtrack</p>
      </div>
      <button type="button" class="conav__drawer-close mono" id="pc-conav-close" aria-label="Close soundtrack">close</button>
    </div>
    <!-- transition:persist keeps this iframe alive across ClientRouter soft-navs -->
    <iframe
      transition:persist="pc-soundtrack"
      id="pc-conav-iframe"
      src="about:blank"
      title="Mood soundtrack"
      loading="lazy"
      allow="autoplay; encrypted-media"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>
</aside>

<script>
// Typed client script — runs once per full page load. Internal state is
// re-read from localStorage + DOM each time so ClientRouter soft-navs
// rehydrate cleanly.
(function () {
  'use strict';
  if (typeof window === 'undefined') return;

  const MOODS: Record<string, { color: string; label: string }> = {
    chill:   { color: '#2B8A3E', label: 'CHILL' },
    hype:    { color: '#C92A2A', label: 'HYPE' },
    focus:   { color: '#1864AB', label: 'FOCUS' },
    flow:    { color: '#5F3DC4', label: 'FLOW' },
    curious: { color: '#E8590C', label: 'CURIOUS' },
    quiet:   { color: '#5F5E5A', label: 'QUIET' },
  };

  const LS_MOOD = 'pc:mood';
  const LS_MUSIC_MOOD = 'pc:music:mood';
  const LS_MUSIC_PLAYING = 'pc:music:playing';

  function qid<T extends HTMLElement>(id: string): T | null { return document.getElementById(id) as T | null; }

  function init() {
    const root = qid<HTMLElement>('pc-conav');
    const moodBtn = qid<HTMLButtonElement>('pc-conav-mood-btn');
    const moodDot = qid<HTMLElement>('pc-conav-mood-dot');
    const moodLabel = qid<HTMLElement>('pc-conav-mood-label');
    const playBtn = qid<HTMLButtonElement>('pc-conav-play');
    const playLabel = qid<HTMLElement>('pc-conav-play-label');
    const drawer = qid<HTMLElement>('pc-conav-drawer');
    const drawerTitle = qid<HTMLElement>('pc-conav-drawer-title');
    const closeBtn = qid<HTMLButtonElement>('pc-conav-close');
    const iframe = qid<HTMLIFrameElement>('pc-conav-iframe');

    if (!drawer || !iframe) return;

    let soundtracks: Record<string, { label: string; url: string; source: string; description: string }> = {};
    try { soundtracks = JSON.parse(drawer.getAttribute('data-soundtracks') || '{}'); } catch { soundtracks = {}; }

    // ---------- mood display update --------------------------------------
    function paintMood(id: string | null) {
      const m = id && MOODS[id];
      if (m && moodDot && moodLabel) {
        moodDot.style.background = m.color;
        moodLabel.textContent = m.label;
        if (root) root.style.setProperty('--conav-mood', m.color);
      } else if (moodDot && moodLabel) {
        moodDot.style.background = '#c4c2bc';
        moodLabel.textContent = 'SET MOOD';
        if (root) root.style.setProperty('--conav-mood', '#e89a2d');
      }
      // Show play offer if we have a soundtrack.
      const t = id ? soundtracks[id] : null;
      if (playBtn && playLabel && t) {
        playBtn.setAttribute('aria-disabled', 'false');
        playLabel.textContent = t.label;
      } else if (playBtn && playLabel) {
        playBtn.setAttribute('aria-disabled', 'true');
        playLabel.textContent = 'CHOOSE MOOD';
      }
    }

    function getMood(): string | null {
      try { return localStorage.getItem(LS_MOOD); } catch { return null; }
    }

    // ---------- drawer + iframe ----------------------------------------
    function openDrawer(moodId: string) {
      if (!drawer || !iframe) return;
      const t = soundtracks[moodId];
      if (!t) return;
      if (iframe.src !== t.url) iframe.src = t.url;
      drawer.hidden = false;
      if (moodBtn) moodBtn.setAttribute('aria-expanded', 'true');
      if (playBtn) playBtn.setAttribute('aria-expanded', 'true');
      if (drawerTitle) drawerTitle.textContent = t.label + ' · ' + (MOODS[moodId] ? MOODS[moodId].label : moodId.toUpperCase());
      try {
        localStorage.setItem(LS_MUSIC_MOOD, moodId);
        localStorage.setItem(LS_MUSIC_PLAYING, '1');
      } catch {}
    }
    function closeDrawer() {
      if (!drawer || !iframe) return;
      iframe.src = 'about:blank';
      drawer.hidden = true;
      if (moodBtn) moodBtn.setAttribute('aria-expanded', 'false');
      if (playBtn) playBtn.setAttribute('aria-expanded', 'false');
      try { localStorage.setItem(LS_MUSIC_PLAYING, '0'); } catch {}
    }

    // ---------- stats: live count + hello + streak ---------------------
    function paintStats() {
      const hereEl = qid('pc-conav-here');
      const helloEl = qid('pc-conav-hello');
      const streakEl = qid('pc-conav-streak');
      try {
        const h = parseInt(localStorage.getItem('pc:hello:count') || '0', 10) || 0;
        if (helloEl) helloEl.textContent = String(h);
      } catch {}
      try {
        const raw = localStorage.getItem('pc:daily:collected');
        const arr: { date: string }[] = raw ? JSON.parse(raw) || [] : [];
        // Simple streak: consecutive days ending today (PT).
        const today = new Date().toISOString().slice(0, 10);
        let streak = 0;
        const uniq: Record<string, boolean> = {};
        arr.forEach((c) => { if (c.date) uniq[c.date] = true; });
        const cursor = new Date(today + 'T12:00:00');
        while (true) {
          const ymd = cursor.toISOString().slice(0, 10);
          if (!uniq[ymd]) break;
          streak++;
          cursor.setDate(cursor.getDate() - 1);
        }
        if (streakEl) streakEl.textContent = String(streak);
      } catch {}
      fetch('/api/presence/snapshot', { cache: 'no-store' })
        .then((r) => (r.ok ? r.json() : null))
        .then((j) => {
          if (!j) return;
          const total = (j.humans || 0) + (j.agents || 0);
          if (hereEl) hereEl.textContent = String(Math.max(total, 1));
        })
        .catch(() => {});
    }

    // ---------- wiring --------------------------------------------------
    if (moodBtn) moodBtn.addEventListener('click', () => {
      const id = getMood();
      if (!id) { window.location.href = '/#mood'; return; }
      if (drawer && drawer.hidden) openDrawer(id);
      else closeDrawer();
    });
    if (playBtn) playBtn.addEventListener('click', () => {
      const id = getMood();
      if (!id) { window.location.href = '/#mood'; return; }
      if (drawer && drawer.hidden) openDrawer(id);
      else closeDrawer();
    });
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer && !drawer.hidden) closeDrawer();
    });

    window.addEventListener('pc:mood-changed', (e: Event) => {
      const detail = (e as CustomEvent).detail;
      const id = detail && detail.moodId;
      if (id) paintMood(id);
    });

    // ---------- initial paint on every page load + soft-nav --------------
    function hydrate() {
      paintMood(getMood());
      paintStats();
      // If music was playing on a prior page AND iframe is still live, keep drawer open.
      try {
        const wasPlaying = localStorage.getItem(LS_MUSIC_PLAYING) === '1';
        const moodId = localStorage.getItem(LS_MUSIC_MOOD) || getMood();
        if (wasPlaying && drawer && moodId && iframe && iframe.src && iframe.src !== 'about:blank') {
          drawer.hidden = false;
          if (moodBtn) moodBtn.setAttribute('aria-expanded', 'true');
          if (playBtn) playBtn.setAttribute('aria-expanded', 'true');
          if (drawerTitle && soundtracks[moodId] && MOODS[moodId]) {
            drawerTitle.textContent = soundtracks[moodId].label + ' · ' + MOODS[moodId].label;
          }
        }
      } catch {}

      const path = window.location.pathname.replace(/\/$/, '') || '/';
      document.querySelectorAll<HTMLAnchorElement>('[data-conav-route]').forEach((a) => {
        const route = (a.getAttribute('data-conav-route') || '').replace(/\/$/, '') || '/';
        if (path === route || (route !== '/' && path.startsWith(route + '/'))) {
          a.setAttribute('aria-current', 'page');
        } else {
          a.removeAttribute('aria-current');
        }
      });
    }

    hydrate();
    document.addEventListener('astro:page-load', hydrate);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

<style>
  .conav {
    --conav-mood: #e89a2d;
    position: fixed;
    left: max(10px, env(safe-area-inset-left));
    right: max(10px, env(safe-area-inset-right));
    bottom: max(10px, env(safe-area-inset-bottom));
    z-index: 40;
    font-family: var(--pc-font-sans, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif);
    pointer-events: none;
  }
  .conav,
  .conav * {
    box-sizing: border-box;
  }
  .conav > * { pointer-events: auto; }

  .conav__bar {
    width: min(1180px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(240px, 0.95fr) minmax(210px, 0.9fr) minmax(250px, 1fr) auto;
    align-items: center;
    gap: 8px;
    padding: 8px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent 42%),
      rgba(14, 13, 11, 0.94);
    color: #f5eadc;
    border: 1px solid rgba(232, 154, 45, 0.24);
    border-radius: 8px;
    box-shadow: 0 18px 54px rgba(0, 0, 0, 0.34), 0 0 0 1px rgba(0, 0, 0, 0.28);
    min-height: 62px;
    backdrop-filter: blur(18px);
  }

  .conav__identity,
  .conav__sound,
  .conav__status,
  .conav__actions {
    display: flex;
    align-items: center;
    min-width: 0;
  }
  .conav__identity { gap: 8px; }
  .conav__sound { min-width: 0; }
  .conav__status {
    justify-content: center;
    gap: 10px;
    padding: 0 10px;
    min-height: 44px;
    border-inline: 1px solid rgba(245, 234, 220, 0.1);
  }
  .conav__actions {
    gap: 6px;
    flex-wrap: nowrap;
  }

  .mono { font-family: var(--pc-font-mono, 'Monaco', 'Menlo', monospace); }

  .conav__brand {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-width: 0;
    color: #f5eadc;
    text-decoration: none;
    padding: 7px 8px;
    border-radius: 6px;
  }
  .conav__brand:hover {
    background: rgba(245, 234, 220, 0.07);
    text-decoration: none;
  }
  .conav__brand-mark {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border: 1px solid rgba(232, 154, 45, 0.45);
    border-radius: 50%;
    color: #e89a2d;
    font-size: 10px;
    letter-spacing: 0.04em;
  }
  .conav__brand-text {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .conav__mood, .conav__play {
    display: inline-flex;
    align-items: center;
    min-width: 0;
    gap: 9px;
    background: transparent;
    border: 1px solid rgba(245, 234, 220, 0.1);
    color: inherit;
    cursor: pointer;
    padding: 8px 10px;
    border-radius: 6px;
    transition: background 0.12s, border-color 0.12s, transform 0.12s;
  }
  .conav__mood { background: color-mix(in srgb, var(--conav-mood) 17%, transparent); }
  .conav__play {
    width: 100%;
    justify-content: flex-start;
  }
  .conav__mood:hover, .conav__play:hover {
    background: rgba(245, 234, 220, 0.08);
    border-color: rgba(232, 154, 45, 0.42);
    transform: translateY(-1px);
  }
  .conav__play[aria-disabled="true"] {
    cursor: pointer;
    opacity: 0.72;
  }
  .conav__mood-dot {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #c4c2bc;
    box-shadow: 0 0 0 4px rgba(245, 234, 220, 0.06);
    flex-shrink: 0;
  }
  .conav__mood-copy,
  .conav__play-copy {
    display: grid;
    gap: 2px;
    min-width: 0;
  }
  .conav__eyebrow {
    font-size: 8px;
    letter-spacing: 0.14em;
    color: rgba(245, 234, 220, 0.52);
    text-transform: uppercase;
  }
  .conav__mood-label,
  .conav__play-label {
    min-width: 0;
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .conav__play-icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #e89a2d;
    color: #12110e;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
  }
  .conav__play-icon::before {
    content: '';
    display: block;
    width: 0;
    height: 0;
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-left: 9px solid currentColor;
    margin-left: 2px;
  }

  .conav__status-led {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4dab5b;
    box-shadow: 0 0 0 5px rgba(77, 171, 91, 0.1);
    flex: 0 0 auto;
  }
  .conav__status-label {
    font-size: 9px;
    letter-spacing: 0.16em;
    color: rgba(245, 234, 220, 0.58);
    text-transform: uppercase;
  }

  .conav__stat {
    display: inline-flex;
    align-items: baseline;
    gap: 5px;
    color: rgba(245, 234, 220, 0.68);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .conav__stat strong {
    color: #e89a2d;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0;
  }

  .conav__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    min-height: 34px;
    color: rgba(245, 234, 220, 0.82);
    text-decoration: none;
    padding: 7px 10px;
    border: 1px solid rgba(245, 234, 220, 0.1);
    border-radius: 6px;
    font-size: 10px;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }
  .conav__link:hover,
  .conav__link[aria-current="page"] {
    color: #12110e;
    background: #e89a2d;
    border-color: #e89a2d;
    text-decoration: none;
  }

  .conav__drawer {
    width: min(760px, 100%);
    margin: 0 auto 8px;
    background: rgba(14, 13, 11, 0.97);
    border: 1px solid rgba(232, 154, 45, 0.24);
    border-radius: 8px;
    padding: 10px;
    max-height: 238px;
    overflow: hidden;
    box-shadow: 0 18px 54px rgba(0, 0, 0, 0.36);
    backdrop-filter: blur(18px);
  }
  .conav__drawer[hidden] { display: none; }
  .conav__drawer-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    margin: 0 0 8px;
  }
  .conav__drawer-kicker {
    margin: 0 0 3px;
    font-size: 8px;
    letter-spacing: 0.16em;
    color: rgba(245, 234, 220, 0.52);
    text-transform: uppercase;
  }
  .conav__drawer-title {
    font-size: 11px;
    letter-spacing: 0.14em;
    color: #e89a2d;
    margin: 0;
    text-transform: uppercase;
  }
  .conav__drawer-close {
    background: transparent;
    border: 1px solid rgba(245, 234, 220, 0.18);
    color: rgba(245, 234, 220, 0.76);
    font-size: 10px;
    letter-spacing: 0.1em;
    padding: 6px 9px;
    border-radius: 6px;
    cursor: pointer;
    text-transform: uppercase;
  }
  .conav__drawer-close:hover { background: rgba(245, 234, 220, 0.08); }
  .conav__drawer iframe {
    width: 100%;
    height: 168px;
    border: none;
    border-radius: 6px;
    background: #000;
    display: block;
  }

  /* Don't let content hide under the fixed bar. Paired with a body bottom-padding rule. */
  @media (max-width: 980px) {
    .conav__bar {
      grid-template-columns: minmax(190px, 1fr) minmax(185px, 1fr) auto;
    }
    .conav__status {
      display: none;
    }
    .conav__brand-text {
      display: none;
    }
  }

  @media (max-width: 680px) {
    .conav {
      left: 0;
      right: 0;
      bottom: 0;
      width: 100dvw;
      max-width: 100dvw;
      overflow: hidden;
    }
    .conav__bar {
      width: 100dvw;
      max-width: 100dvw;
      margin: 0;
      grid-template-columns: 1fr 1fr;
      gap: 6px;
      min-height: 56px;
      padding: 6px max(8px, env(safe-area-inset-right)) max(6px, env(safe-area-inset-bottom)) max(8px, env(safe-area-inset-left));
      border-radius: 8px 8px 0 0;
      border-inline: 0;
      border-bottom: 0;
    }
    .conav__brand {
      display: none;
    }
    .conav__mood,
    .conav__play {
      width: 100%;
      padding: 7px 8px;
    }
    .conav__mood-label,
    .conav__play-label {
      max-width: 110px;
      font-size: 10px;
    }
    .conav__actions {
      grid-column: 1 / -1;
      display: flex;
      gap: 5px;
      width: 100%;
      max-width: min(calc(100dvw - 16px), 318px);
      margin: 0 auto;
    }
    .conav__link {
      flex: 1 1 0;
      min-height: 30px;
      padding: 5px 4px;
      font-size: 9px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .conav__drawer {
      width: auto;
      margin: 0 8px 8px;
      max-height: 218px;
    }
    .conav__drawer iframe {
      height: 132px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .conav__mood,
    .conav__play {
      transition: none;
    }
    .conav__mood:hover,
    .conav__play:hover {
      transform: none;
    }
  }
</style>
