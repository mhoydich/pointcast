---
import { POINTCAST_APPS } from '../lib/pointcast-apps';
---

<section class="app-strip" aria-labelledby="app-strip-title">
  <div class="app-strip__head">
    <p class="app-strip__kicker mono">APPS · NOW VIEWABLE ON POINTCAST</p>
    <h2 id="app-strip-title">Two satellite rooms are live.</h2>
  </div>
  <div class="app-strip__grid">
    {POINTCAST_APPS.map((app) => (
      <a class="app-strip__item" href={`/${app.slug}`}>
        <span class="app-strip__channel mono">{app.channel}</span>
        <strong>{app.name}</strong>
        <span>{app.kicker}</span>
      </a>
    ))}
    <a class="app-strip__item app-strip__item--all" href="/apps">
      <span class="app-strip__channel mono">INDEX</span>
      <strong>All apps</strong>
      <span>MoodyGold + Offbalance</span>
    </a>
  </div>
</section>

<style>
  .app-strip {
    margin: 14px 0 8px;
    padding: 12px 14px;
    border: 1px solid rgba(153, 53, 86, 0.2);
    border-left: 3px solid #993556;
    background: linear-gradient(90deg, rgba(153, 53, 86, 0.055), rgba(24, 95, 165, 0.035));
    border-radius: 2px;
  }
  .mono {
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .app-strip__head {
    display: flex;
    gap: 12px;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .app-strip__kicker {
    margin: 0;
    font-size: 10px;
    color: #6B2139;
  }
  .app-strip h2 {
    margin: 0;
    font-size: 16px;
    line-height: 1.2;
    font-weight: 500;
  }
  .app-strip__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }
  .app-strip__item {
    min-width: 0;
    padding: 10px;
    display: grid;
    gap: 4px;
    border: 1px solid rgba(18, 17, 14, 0.12);
    background: rgba(255, 255, 255, 0.68);
    color: var(--pc-ink);
    text-decoration: none;
  }
  .app-strip__item:hover {
    border-color: #185FA5;
    text-decoration: none;
  }
  .app-strip__channel {
    font-size: 9px;
    color: #8A2432;
  }
  .app-strip__item strong {
    font-size: 14px;
    font-weight: 500;
  }
  .app-strip__item span:last-child {
    min-width: 0;
    overflow-wrap: anywhere;
    font-size: 11px;
    line-height: 1.35;
    color: var(--pc-ink-muted);
  }
  .app-strip__item--all {
    background: rgba(24, 95, 165, 0.06);
  }
  @media (max-width: 720px) {
    .app-strip__grid {
      grid-template-columns: 1fr;
    }
    .app-strip h2 {
      font-size: 15px;
    }
  }
</style>
