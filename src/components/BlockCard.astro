---
/**
 * BlockCard — the single primitive that renders every piece of content on
 * pointcast.xyz v2. Grammar per BLOCKS.md:
 *
 *   ┌───────────────────────────────────────────────────┐
 *   │ CH.{CODE} · {ID}         {TYPE}  {TIMESTAMP}      │  ← header
 *   │                                                   │
 *   │ Title in sentence case, sans, weight 500          │
 *   │                                                   │
 *   │ Body or media treatment (varies by type)          │
 *   │                                                   │
 *   │                                                   │
 *   │ FOOTER META · per type (reading time / ED count)  │  ← footer
 *   └───────────────────────────────────────────────────┘
 *
 * Every block shares the same frame; the body swaps on type. Hard corners,
 * 1.5px channel-colored border, optional 6px left accent bar on READ type.
 */
import type { CollectionEntry } from 'astro:content';
import { CHANNELS } from '../lib/channels';
import { BLOCK_TYPES } from '../lib/block-types';

/**
 * Footer meta line — one string per type, picked by footerHint.
 * Extracted to keep the template readable and mirror the table in BLOCKS.md.
 */
function footerMeta(data: CollectionEntry<'blocks'>['data'], hint: string): string | null {
  const ed = data.edition;
  const supplyStr = (s: number | 'open' | undefined) => (s === 'open' ? '∞' : String(s ?? '—'));
  // For internal URLs (pointcast.xyz/*) show the pathname — "/drum ↗" reads
  // better than "pointcast.xyz ↗" when the user is already on pointcast.xyz.
  const host = (url?: string) => {
    if (!url) return '';
    try {
      const u = new URL(url, 'https://pointcast.xyz'); // base handles relative "/drum"
      const h = u.host.replace(/^www\./, '');
      return h === 'pointcast.xyz' && u.pathname !== '/' ? u.pathname : h;
    } catch { return ''; }
  };

  switch (hint) {
    case 'readingTime':
      if (!data.readingTime) return null;
      return ed ? `${data.readingTime} · ED ${ed.minted}/${supplyStr(ed.supply)}` : data.readingTime;
    case 'externalLink':
    case 'destination':
      return data.external ? `${host(data.external.url)} ↗` : null;
    case 'duration':
      return data.external ? `${host(data.external.url)} ↗` : null;
    case 'edition':
      if (!ed) return null;
      const price = ed.price === 'free' ? 'FREE' : `${ed.price?.tez ?? '—'} ꜩ`;
      return `${price} · ED ${ed.minted}/${supplyStr(ed.supply)}`;
    case 'claimStatus':
      if (!ed) return null;
      return `CLAIMED ${ed.minted}/${supplyStr(ed.supply)} TODAY`;
    case 'location':
      return data.meta?.location ?? null;
    case 'agent':
      if (!data.visitor) return null;
      return data.visitor.vendor ?? data.visitor.name ?? (data.visitor.kind === 'agent' ? 'AGENT' : 'HUMAN');
  }
  return null;
}

interface Props {
  block: CollectionEntry<'blocks'>;
  /** If true, renders a larger body preview (used on single-block pages). */
  detail?: boolean;
}

const { block, detail = false } = Astro.props;
const data = block.data;
const channel = CHANNELS[data.channel];
const typeSpec = BLOCK_TYPES[data.type];

// Compact timestamp: "04.17 · 07:22 PT"
const ts = data.timestamp;
const fmt = new Intl.DateTimeFormat('en-US', {
  month: '2-digit',
  day: '2-digit',
  hour: '2-digit',
  minute: '2-digit',
  hour12: false,
  timeZone: 'America/Los_Angeles',
}).formatToParts(ts);
const part = (t: string) => fmt.find((p) => p.type === t)?.value ?? '';
const tsShort = `${part('month')}.${part('day')} · ${part('hour')}:${part('minute')} PT`;

// Grid footprint per size. Default 1x1 → one column, one row; 2x1 spans 2
// columns etc. Tablet + mobile downgrades are handled in global.css with
// media queries on the grid container.
const sizeClassMap: Record<string, string> = {
  '1x1': 'span-1x1',
  '2x1': 'span-2x1',
  '1x2': 'span-1x2',
  '2x2': 'span-2x2',
  '3x2': 'span-3x2',
};
const sizeClass = sizeClassMap[data.size ?? '1x1'] ?? 'span-1x1';

---

<article
  class:list={[
    'block-card',
    `type-${data.type.toLowerCase()}`,
    `channel-${data.channel.toLowerCase()}`,
    sizeClass,
    { 'block-card--detail': detail, 'block-card--accent': data.type === 'READ' },
  ]}
  style={{
    '--ch-600': channel.color600,
    '--ch-800': channel.color800,
    '--ch-50': channel.color50,
  }}
>
  {/* On grid mode the whole card is a link into /b/{id}. On detail mode
      (the permalink page itself) href is omitted — the /b/[id] page
      supplies a dedicated CTA below this card for any external URL. */}
  <a
    href={detail ? undefined : `/b/${data.id}`}
    class:list={['block-card__link', { 'block-card__link--inert': detail }]}
    aria-label={detail ? undefined : `Block ${data.id}: ${data.title}`}
  >
    <header class="block-card__header">
      <span class="block-card__code">CH.{channel.code} · {data.id}</span>
      <span class="block-card__type-tag">{typeSpec.label}</span>
      <time class="block-card__time" datetime={ts.toISOString()}>{tsShort}</time>
    </header>

    {data.noun !== undefined && !detail && (
      <span class="block-card__noun-frame" aria-hidden="true">
        <img
          src={`https://noun.pics/${data.noun}.svg`}
          alt=""
          width="30"
          height="30"
          loading="lazy"
          class="block-card__noun"
          style="image-rendering: pixelated;"
          onerror="this.style.visibility='hidden'"
        />
      </span>
    )}

    {/* Per-type kicker above the title — the "flair" row that distinguishes
        a dispatch from a note from a visit from a listen. Channel already
        provides the color; kicker provides the register. */}
    {data.type === 'READ' && (
      <p class="block-card__kicker block-card__kicker--read">
        DISPATCH · Nº {data.id}
        {(data as any).meta?.series ? ` · ${(data as any).meta.series.toUpperCase()}` : ''}
      </p>
    )}
    {data.type === 'LISTEN' && (
      <p class="block-card__kicker block-card__kicker--listen">
        ♪ NOW PLAYING{(data as any).meta?.artist ? ` · ${(data as any).meta.artist.toUpperCase()}` : ''}
      </p>
    )}
    {data.type === 'WATCH' && (
      <p class="block-card__kicker block-card__kicker--watch">▸ WATCH</p>
    )}
    {data.type === 'NOTE' && (
      <p class="block-card__kicker block-card__kicker--note">
        ✳ NOTE{(data as any).meta?.location ? ` · ${(data as any).meta.location.toUpperCase()}` : ''}
      </p>
    )}
    {data.type === 'VISIT' && (
      <p class="block-card__kicker block-card__kicker--visit">
        ◊ VISIT STAMP · {tsShort.toUpperCase()}
      </p>
    )}
    {data.type === 'MINT' && (
      <p class="block-card__kicker block-card__kicker--mint">
        ◆ MINT · EDITION
      </p>
    )}
    {data.type === 'FAUCET' && (
      <p class="block-card__kicker block-card__kicker--faucet">
        ⚑ FAUCET · DAILY CLAIM
      </p>
    )}
    {data.type === 'LINK' && (data as any).meta?.price && (
      <p class="block-card__kicker block-card__kicker--link">
        → {(data as any).meta.price}{(data as any).external?.label ? ` · ${(data as any).external.label.toUpperCase()}` : ''}
      </p>
    )}

    <h3 class="block-card__title">{data.title}</h3>
    {data.dek && <p class="block-card__dek">{data.dek}</p>}

    {/* Media treatment — image or embed.
        onerror flips to the IPFS fallback if the primary (objkt CDN)
        fails. After that it hides the media frame entirely instead of
        showing a broken-image icon — Mike caught the broken-image
        pattern in the 03xx Tezos imports 2026-04-17 after the
        cloudflare-ipfs gateway was sunset. */}
    {data.media?.kind === 'image' && (
      <div class="block-card__media">
        <img
          src={data.media.src}
          alt={data.title}
          loading="lazy"
          data-fallback={(data.media as any).ipfsFallback ?? ''}
          onerror="if(this.dataset.fallback && this.src!==this.dataset.fallback){this.src=this.dataset.fallback;}else{this.parentElement.style.display='none';}"
        />
      </div>
    )}
    {/* LISTEN-embed treatment: mount the iframe only on the detail page.
        On the home grid a third-party iframe per card hits ~6s of cold
        load (Manus QA 2026-04-17, finding 3.1). Facade is a static chip
        that doubles as a "tap to open" affordance — the card's outer
        anchor already routes to /b/{id}, where the iframe loads cleanly.
     */}
    {data.media?.kind === 'embed' && data.type === 'LISTEN' && (
      detail ? (
        <div class="block-card__embed block-card__embed--audio">
          <iframe
            src={data.media.src}
            loading="lazy"
            frameborder="0"
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            title={data.title}
          ></iframe>
        </div>
      ) : (
        <div class="block-card__embed-facade" aria-hidden="true">
          <span class="block-card__embed-facade-play">▶</span>
          <span class="block-card__embed-facade-label">
            {(() => {
              try { return new URL(data.media.src).host.replace(/^www\./, ''); }
              catch { return 'Open to play'; }
            })()}
          </span>
        </div>
      )
    )}

    {/* Body.
        - NOTE / VISIT / LINK / detail-mode READ all render the body.
        - For READ on detail, split on blank lines into proper paragraphs
          (the JSON stores bodies with \n\n as paragraph breaks), and
          apply article typography for comfortable long-form reading on
          mobile + desktop. Plain <p> for everything else. */}
    {data.body && (data.type === 'NOTE' || data.type === 'VISIT' || data.type === 'LINK' || (detail && data.type === 'READ')) && (
      detail && data.type === 'READ' ? (
        <div class="block-card__article">
          {data.body.split(/\n\n+/).map((para) => <p class="block-card__article-p">{para}</p>)}
        </div>
      ) : (
        <p class="block-card__body">{data.body}</p>
      )
    )}

    {/* Footer meta — type-specific, computed in footerMeta() helper above */}
    {(() => {
      const meta = footerMeta(data, typeSpec.footerHint);
      return (
        <footer class="block-card__footer">
          {meta && <span class="block-card__meta">{meta}</span>}
        </footer>
      );
    })()}
  </a>
</article>

<style>
  .block-card {
    position: relative;
    display: block;
    background: #fff;
    border: 1.5px solid var(--ch-600);
    border-radius: 2px;
    overflow: hidden;
    container-type: inline-size;
  }

  .block-card--accent {
    border-left-width: 6px;
  }

  .block-card__link {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 14px 16px;
    color: inherit;
    text-decoration: none;
    height: 100%;
  }

  .block-card__link:hover .block-card__title {
    color: var(--ch-800);
  }

  /* Detail mode: anchor exists for class consistency but has no href;
     make it visually + interactively inert so hover + cursor match. */
  .block-card__link--inert,
  .block-card__link--inert:hover .block-card__title {
    cursor: default;
    color: inherit;
  }

  .block-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    font-family: 'JetBrains Mono', 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ch-800);
    font-weight: 500;
  }

  .block-card__code {
    white-space: nowrap;
  }

  .block-card__type-tag {
    font-size: 9px;
    padding: 2px 6px;
    border: 1px solid var(--ch-600);
    color: var(--ch-800);
    background: var(--ch-50);
    border-radius: 2px;
  }

  .block-card__time {
    color: #5F5E5A;
    font-size: 9px;
    font-weight: 400;
  }

  /* Noun thumbnail lives in a channel-tinted frame so pale Nouns (which
     default to cool-blue or warm-cream backgrounds) still read against a
     white card. Also acts as a graceful-degrade container when the remote
     noun.pics SVG errors. Per Manus QA 2026-04-17, finding 1.2. */
  .block-card__noun-frame {
    display: inline-flex;
    align-self: flex-start;
    padding: 2px;
    background: var(--ch-50);
    border: 1px solid var(--ch-600);
    border-radius: 2px;
  }
  .block-card__noun {
    display: block;
    width: 30px;
    height: 30px;
  }

  .block-card__title {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.25;
    color: #12110E;
    margin: 0;
  }

  .block-card__dek {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 12.5px;
    line-height: 1.45;
    color: #38373A;
    margin: 0;
  }

  /* ── Per-type kicker rows ─────────────────────────────────────────────
     A one-line, mono, tracked-up-0.14em signal above the title. Channel
     provides the color (inherits --ch-800 via .block-card--<channel>
     from the article wrapper); the kicker provides the register —
     DISPATCH for READ, NOW PLAYING for LISTEN, VISIT STAMP for VISIT,
     etc. Each uses a type-specific glyph as a visual hook. */
  .block-card__kicker {
    margin: 0 0 -2px;
    font-family: var(--pc-font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 9.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ch-800);
    font-weight: 500;
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .block-card__kicker--note,
  .block-card__kicker--visit {
    color: var(--pc-ink-muted, #5F5E5A);
  }
  .block-card__kicker--mint,
  .block-card__kicker--faucet {
    /* Drop-channel money kicker pops harder */
    background: var(--ch-50);
    border: 1px solid var(--ch-600);
    padding: 2px 6px;
    border-radius: 2px;
    align-self: flex-start;
    font-weight: 500;
  }
  .block-card__kicker--link {
    color: var(--pc-accent, #185FA5);
  }

  /* READ blocks: italic serif dek for a dispatch feel (only the dek —
     the body stays sans in the article-paragraph style on detail). */
  .block-card.type-read .block-card__dek {
    font-family: Georgia, 'Iowan Old Style', serif;
    font-style: italic;
    font-size: 13.5px;
    color: #2a2724;
  }

  /* ══ TYPE VARIATION ═════════════════════════════════════════════════════
     Each type gets a visually distinct treatment so the scroll feels varied
     rather than uniform. Mike 2026-04-17: "keep working on the visual part
     via scroll so they don't all look the same". */

  /* NOTE — sticky-note / postcard. Tinted background, no header border,
     italic dek, a "pinned" top-left corner dot. */
  .block-card.type-note:not(.block-card--detail) {
    background: color-mix(in oklab, var(--ch-50) 78%, #fff);
    box-shadow: 0 1px 0 color-mix(in oklab, var(--ch-600) 18%, transparent);
  }

  .block-card.type-note:not(.block-card--detail)::before {
    content: '';
    position: absolute;
    top: 8px;
    left: 8px;
    width: 4px;
    height: 4px;
    background: var(--ch-600);
    border-radius: 50%;
    opacity: 0.5;
  }

  .block-card.type-note .block-card__dek {
    font-style: italic;
    color: #4a4745;
  }

  /* VISIT — terminal log entry. Darker ink card with mono body and a
     "> " prefix on the title, reads like a stdout line. */
  .block-card.type-visit:not(.block-card--detail) {
    background: #12110E;
    border-color: #12110E;
  }

  .block-card.type-visit:not(.block-card--detail) .block-card__header,
  .block-card.type-visit:not(.block-card--detail) .block-card__code,
  .block-card.type-visit:not(.block-card--detail) .block-card__time,
  .block-card.type-visit:not(.block-card--detail) .block-card__kicker {
    color: color-mix(in oklab, var(--ch-600) 55%, #fff);
  }

  .block-card.type-visit:not(.block-card--detail) .block-card__type-tag {
    background: transparent;
    border-color: color-mix(in oklab, var(--ch-600) 55%, #fff);
    color: color-mix(in oklab, var(--ch-600) 55%, #fff);
  }

  .block-card.type-visit:not(.block-card--detail) .block-card__title {
    color: #f2efe9;
    font-family: var(--pc-font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 13.5px;
    letter-spacing: 0.01em;
  }

  .block-card.type-visit:not(.block-card--detail) .block-card__title::before {
    content: '> ';
    color: color-mix(in oklab, var(--ch-600) 70%, #fff);
    opacity: 0.8;
  }

  .block-card.type-visit:not(.block-card--detail) .block-card__body {
    color: #c4c2bc;
    font-family: var(--pc-font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 11.5px;
    line-height: 1.55;
  }

  .block-card.type-visit:not(.block-card--detail) .block-card__footer {
    border-top-color: color-mix(in oklab, var(--ch-600) 35%, #000);
  }

  .block-card.type-visit:not(.block-card--detail) .block-card__meta {
    color: color-mix(in oklab, var(--ch-600) 60%, #fff);
  }

  .block-card.type-visit:not(.block-card--detail):hover .block-card__title {
    color: #fff;
  }

  .block-card.type-visit:not(.block-card--detail) .block-card__noun-frame {
    background: color-mix(in oklab, var(--ch-600) 30%, #000);
    border-color: color-mix(in oklab, var(--ch-600) 55%, #fff);
  }

  /* LINK — compact, arrow-first. Big arrow glyph in the corner where
     the noun would go for non-LINK types. Subtle dashed-right accent to
     hint "points somewhere". */
  .block-card.type-link:not(.block-card--detail) {
    border-right-width: 3px;
    border-right-style: dashed;
    border-right-color: color-mix(in oklab, var(--ch-600) 70%, #fff);
  }

  .block-card.type-link:not(.block-card--detail) .block-card__link::after {
    content: '→';
    position: absolute;
    top: 10px;
    right: 10px;
    font-family: var(--pc-font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 22px;
    color: color-mix(in oklab, var(--ch-600) 65%, #fff);
    opacity: 0.55;
    pointer-events: none;
    line-height: 1;
  }

  .block-card.type-link:not(.block-card--detail):hover .block-card__link::after {
    color: var(--ch-800);
    opacity: 1;
    transform: translateX(2px);
    transition: transform 0.15s, opacity 0.15s, color 0.15s;
  }

  /* LISTEN — already has vinyl puck. Add a subtle grooves pattern on
     the facade background. */
  .block-card.type-listen .block-card__embed-facade {
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent 0,
        transparent 2px,
        color-mix(in oklab, var(--ch-600) 15%, transparent) 2px,
        color-mix(in oklab, var(--ch-600) 15%, transparent) 3px
      );
  }

  /* MINT / FAUCET — ticketed / currency feel. Double-dashed right edge
     like a perforated coupon tear-off. Already has the tinted kicker. */
  .block-card.type-mint:not(.block-card--detail),
  .block-card.type-faucet:not(.block-card--detail) {
    border-right-style: dashed;
    border-right-width: 2.5px;
  }

  .block-card.type-mint:not(.block-card--detail)::after,
  .block-card.type-faucet:not(.block-card--detail)::after {
    content: '';
    position: absolute;
    top: 0;
    right: 7px;
    bottom: 0;
    width: 0;
    border-right: 2px dashed color-mix(in oklab, var(--ch-600) 40%, #fff);
    pointer-events: none;
  }

  /* WATCH — cinema-frame letterbox: thin horizontal bars top + bottom. */
  .block-card.type-watch:not(.block-card--detail) .block-card__link {
    padding-top: 18px;
    padding-bottom: 18px;
  }

  .block-card.type-watch:not(.block-card--detail)::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 6px;
    background: #12110E;
  }

  .block-card.type-watch:not(.block-card--detail)::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 6px;
    background: #12110E;
  }

  /* CRT channel (courtside sports): subtle chalked baseline accent on
     the footer to read as scoreboard / court. */
  .block-card.channel-crt .block-card__footer {
    border-top-style: solid;
    border-top-color: color-mix(in oklab, var(--ch-600) 40%, #fff);
  }

  /* LISTEN facade gets a vinyl-disc hint via a radial-gradient puck
     on the play icon for better music-block recognition. */
  .block-card.type-listen .block-card__embed-facade-play {
    width: 14px;
    height: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%, #111 0 3px, var(--ch-800) 3.1px 5.5px, var(--ch-50) 5.6px 100%);
    border: 1px solid var(--ch-600);
    color: transparent;
    font-size: 0;
  }

  .block-card__body {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 13px;
    line-height: 1.5;
    color: #38373A;
    margin: 0;
  }

  /* READ on detail mode — article typography. Mobile-first: comfortable
     reading size (16px), generous line-height, paragraph spacing.
     Constrains line-length to ~72 characters at desktop to keep
     long-form readable. */
  .block-card__article {
    display: flex;
    flex-direction: column;
    gap: 0.9em;
    max-width: 64ch;
  }
  .block-card__article-p {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: #12110E;
    margin: 0;
  }
  .block-card__article-p code {
    font-family: var(--pc-font-mono);
    font-size: 0.92em;
    background: #F2EFE9;
    padding: 1px 4px;
    border-radius: 2px;
  }
  @media (min-width: 640px) {
    .block-card__article-p { font-size: 17px; }
  }

  .block-card__media {
    margin: 2px -16px;
  }

  .block-card__media img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* Detail mode: contain images so the whole frame is visible and the
     image never takes more than ~half the viewport. Letterbox with a
     warm cream so tall/wide images sit neatly. Fixes the case where
