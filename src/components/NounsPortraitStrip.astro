---
/**
 * NounsPortraitStrip — five mintable Visit Nouns portraits.
 *
 * Uses the existing Visit Nouns FA2 + MintButton flow. The selected seeds
 * avoid the ten starter mints already present on mainnet as of this build.
 */
import MintButton from './MintButton.astro';
import contracts from '../data/contracts.json';

interface Props {
  context?: 'home' | 'page' | 'compact';
}

const { context = 'home' } = Astro.props;
const KT1 = (contracts as any).visit_nouns?.mainnet ?? '';
const priceMutez = Number((contracts as any).visit_nouns?.mintPriceMutez ?? 0);

const portraits = [
  { id: 313, name: 'Marine Layer', note: 'soft blue signal, easy morning' },
  { id: 523, name: 'Block Runner', note: 'agent ledger energy' },
  { id: 742, name: 'Main Street', note: 'El Segundo DAO daydream' },
  { id: 1042, name: 'Release Train', note: 'Gamgee-era collector mark' },
  { id: 1189, name: 'Night Broadcast', note: 'late build, bright screen' },
];
---

<section class:list={['nouns-portraits', `nouns-portraits--${context}`]} id="nouns-portraits" aria-labelledby="nouns-portraits-title">
  <div class="nouns-portraits__head">
    <p class="nouns-portraits__kicker">Visit Nouns · Tezos mainnet</p>
    <div>
      <h2 id="nouns-portraits-title">Five mintable Nouns portraits</h2>
      <p>
        Pick a portrait, connect a Beacon wallet, and mint it through the PointCast Visit Nouns FA2.
      </p>
    </div>
    <a class="nouns-portraits__collection" href="/collection/visit-nouns">Collection</a>
  </div>

  <div class="nouns-portraits__grid">
    {portraits.map((portrait) => (
      <article class="noun-card">
        <a class="noun-card__art" href={`https://noun.pics/${portrait.id}.svg`} target="_blank" rel="noopener" aria-label={`Open Noun ${portrait.id} art`}>
          <img
            src={`https://noun.pics/${portrait.id}.svg`}
            alt={`Noun ${portrait.id} portrait`}
            width="220"
            height="220"
            loading={context === 'home' ? 'eager' : 'lazy'}
          />
        </a>
        <div class="noun-card__body">
          <p class="noun-card__id">Noun #{portrait.id}</p>
          <h3>{portrait.name}</h3>
          <p>{portrait.note}</p>
        </div>
        <div class="noun-card__actions">
          <MintButton
            contract={KT1}
            tokenId={portrait.id}
            priceMutez={priceMutez}
            kind="mint"
            label={priceMutez > 0 ? `Mint ${(priceMutez / 1_000_000).toFixed(2)} tez` : 'Mint on Tezos'}
          />
          <a href={`https://objkt.com/tokens/${KT1}/${portrait.id}`} target="_blank" rel="noopener">objkt</a>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .nouns-portraits {
    margin: 18px 0 24px;
    padding: 16px;
    border: 1.5px solid var(--pc-ink, #12110e);
    background:
      linear-gradient(90deg, rgba(24, 95, 165, 0.08), transparent 34%),
      var(--pc-card, #f8f3e8);
  }

  .nouns-portraits--page {
    margin-top: 18px;
  }

  .nouns-portraits--compact {
    padding: 12px;
  }

  .nouns-portraits__head {
    display: grid;
    grid-template-columns: minmax(120px, 0.24fr) minmax(0, 1fr) auto;
    gap: 12px;
    align-items: end;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--pc-rule, #d6d4cd);
  }

  .nouns-portraits__kicker,
  .nouns-portraits__collection,
  .noun-card__id,
  .noun-card__actions a {
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .nouns-portraits__kicker {
    margin: 0;
    color: var(--pc-accent, #185fa5);
  }

  .nouns-portraits h2 {
    margin: 0 0 4px;
    font-family: var(--pc-font-sans, system-ui, sans-serif);
    font-size: clamp(24px, 3vw, 42px);
    line-height: 1;
    font-weight: 520;
    color: var(--pc-ink, #12110e);
  }

  .nouns-portraits__head p:not(.nouns-portraits__kicker) {
    margin: 0;
    max-width: 66ch;
    color: var(--pc-ink-soft, #5f5e5a);
    font-size: 14px;
    line-height: 1.45;
  }

  .nouns-portraits__collection {
    color: var(--pc-accent, #185fa5);
    white-space: nowrap;
  }

  .nouns-portraits__grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 10px;
    padding-top: 12px;
  }

  .noun-card {
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-width: 0;
    border: 1px solid var(--pc-rule, #d6d4cd);
    background: var(--pc-paper, #fffaf0);
  }

  .noun-card__art {
    display: block;
    aspect-ratio: 1;
    background: #f2f2f2;
    border-bottom: 1px solid var(--pc-rule, #d6d4cd);
    overflow: hidden;
  }

  .noun-card__art img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: pixelated;
    transition: transform 140ms ease;
  }

  .noun-card:hover .noun-card__art img {
    transform: scale(1.04);
  }

  .noun-card__body {
    padding: 10px;
  }

  .noun-card__id {
    margin: 0 0 6px;
    color: var(--pc-accent, #185fa5);
  }

  .noun-card h3 {
    margin: 0 0 5px;
    font-family: var(--pc-font-sans, system-ui, sans-serif);
    font-size: 17px;
    line-height: 1.05;
    font-weight: 560;
    color: var(--pc-ink, #12110e);
  }

  .noun-card__body p:last-child {
    margin: 0;
    color: var(--pc-ink-soft, #5f5e5a);
    font-size: 12.5px;
    line-height: 1.35;
  }

  .noun-card__actions {
    display: grid;
    gap: 7px;
    padding: 10px;
    border-top: 1px solid var(--pc-rule, #d6d4cd);
  }

  .noun-card__actions a {
    color: var(--pc-ink-soft, #5f5e5a);
  }

  @media (max-width: 920px) {
    .nouns-portraits__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .nouns-portraits {
      padding: 12px;
    }

    .nouns-portraits__head {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .nouns-portraits__grid {
      grid-template-columns: 1fr;
    }

    .noun-card {
      grid-template-columns: 112px minmax(0, 1fr);
      grid-template-rows: auto auto;
    }

    .noun-card__art {
      grid-row: span 2;
      border-bottom: 0;
      border-right: 1px solid var(--pc-rule, #d6d4cd);
    }

    .noun-card__actions {
      border-top: 1px solid var(--pc-rule, #d6d4cd);
    }
  }
</style>
