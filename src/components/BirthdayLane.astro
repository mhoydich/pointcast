---
/**
 * <BirthdayLane /> — homepage strip for the Birthday Imprint.
 *
 * Per Mike 2026-04-29: "a bunch of birthday drum apps, different ways
 * to celebrate one's birthday with collaborative drumming, neat
 * unfurl, ability to potentially customize, ways to share and smile."
 *
 * 4 cards link to the 4 birthday surfaces (/drum-birthday hub,
 * /drum-cake, /drum-card, /drum-pinata). Tone: party invitation
 * pinned to a corkboard. Cream paper, magenta + yellow + cyan + teal
 * accents, hand-drawn-feeling chunky borders, slight rotation per
 * card so the row reads like 4 cards taped to a wall.
 *
 * Distinct from <DrumPressMarquee /> (editorial, oat-paper, ink) —
 * this one is louder and warmer because that's what birthdays are.
 *
 * Self-contained: scoped CSS, no presence/event polling. The pages
 * it links to handle live state. Strip is just the doorway.
 */
---

<aside class="bdl" aria-labelledby="bdl-title">
  <div class="bdl__head">
    <p class="bdl__kicker mono">★ DRUM HUB · BIRTHDAY IMPRINT · 4 WAYS TO CELEBRATE ★</p>
    <h2 class="bdl__title" id="bdl-title">
      it&apos;s <em>somebody&apos;s</em> birthday
    </h2>
    <p class="bdl__strap mono">tap a drum · light a candle · sign a card · swing a piñata</p>
  </div>

  <div class="bdl__row" role="list">
    <a class="bdl__card bdl__card--hub" role="listitem" href="/drum-birthday">
      <span class="bdl__cat mono">DR-BD1</span>
      <span class="bdl__glyph" aria-hidden="true">🎂</span>
      <span class="bdl__name">birthday</span>
      <span class="bdl__sub mono">the hub · big drum · live confetti</span>
      <span class="bdl__go mono">go to room →</span>
    </a>
    <a class="bdl__card bdl__card--cake" role="listitem" href="/drum-cake">
      <span class="bdl__cat mono">DR-BD2</span>
      <span class="bdl__glyph" aria-hidden="true">🕯️</span>
      <span class="bdl__name">cake</span>
      <span class="bdl__sub mono">light a candle · blow it out · wish</span>
      <span class="bdl__go mono">go to room →</span>
    </a>
    <a class="bdl__card bdl__card--card" role="listitem" href="/drum-card">
      <span class="bdl__cat mono">DR-BD3</span>
      <span class="bdl__glyph" aria-hidden="true">💌</span>
      <span class="bdl__name">card</span>
      <span class="bdl__sub mono">the room signs together · one tap each</span>
      <span class="bdl__go mono">go to room →</span>
    </a>
    <a class="bdl__card bdl__card--pinata" role="listitem" href="/drum-pinata">
      <span class="bdl__cat mono">DR-BD4</span>
      <span class="bdl__glyph" aria-hidden="true">🪅</span>
      <span class="bdl__name">piñata</span>
      <span class="bdl__sub mono">take a swing · the room bursts at 100</span>
      <span class="bdl__go mono">go to room →</span>
    </a>
  </div>

  <div class="bdl__foot">
    <p class="bdl__cta mono">
      personalize: append <code>?for=NAME&amp;from=YOU&amp;age=N</code> to any room — share the link, the page wears the name
    </p>
  </div>
</aside>

<style>
  .bdl {
    --bdl-paper: #fff5d8;
    --bdl-paper-deep: #f8e8c0;
    --bdl-ink: #11100c;
    --bdl-rule: #1a1610;
    --bdl-mute: #6a5d45;
    --bdl-magenta: #d6346a;
    --bdl-yellow: #f0c431;
    --bdl-cyan: #3aa9c4;
    --bdl-teal: #2f8c69;

    display: block;
    padding: 22px clamp(14px, 3vw, 28px);
    margin: 0 0 18px;
    background: var(--bdl-paper);
    border: 2px solid var(--bdl-ink);
    color: var(--bdl-ink);
    font-family: 'Iowan Old Style', 'Iowan Old Style W01', 'Palatino', 'Times New Roman', Times, serif;
    line-height: 1.45;
    /* Confetti dot scatter — radial CSS gradients so we don't ship an image */
    background-image:
      radial-gradient(circle at 8% 18%, var(--bdl-magenta) 4px, transparent 5px),
      radial-gradient(circle at 92% 22%, var(--bdl-yellow) 5px, transparent 6px),
      radial-gradient(circle at 16% 88%, var(--bdl-cyan) 4px, transparent 5px),
      radial-gradient(circle at 88% 86%, var(--bdl-teal) 5px, transparent 6px),
      radial-gradient(circle at 50% 8%, var(--bdl-magenta) 3px, transparent 4px),
      var(--bdl-paper);
    background-size: cover;
    /* Hard offset shadow in magenta for the festive layered-paper feel */
    box-shadow: 6px 6px 0 0 var(--bdl-magenta), 12px 12px 0 0 var(--bdl-yellow);
    position: relative;
  }
  .bdl .mono {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    letter-spacing: 0.04em;
  }

  /* Head */
  .bdl__head {
    text-align: center;
    margin: 0 0 18px;
    max-width: 960px;
    margin-left: auto;
    margin-right: auto;
  }
  .bdl__kicker {
    font-size: 10px;
    letter-spacing: 0.32em;
    color: var(--bdl-magenta);
    text-transform: uppercase;
    margin: 0 0 8px;
    font-weight: 700;
  }
  .bdl__title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 800;
    margin: 0 0 6px;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--bdl-ink);
  }
  .bdl__title em {
    font-style: italic;
    color: var(--bdl-magenta);
    font-weight: 500;
  }
  .bdl__strap {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--bdl-mute);
    margin: 0;
  }

  /* Row of 4 cards */
  .bdl__row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin: 0 0 18px;
  }
  .bdl__card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 14px 12px;
    background: var(--bdl-paper-deep);
    border: 2px solid var(--bdl-ink);
    text-decoration: none;
    color: var(--bdl-ink);
    transition: transform 100ms ease, background 120ms ease;
    min-width: 0;
    box-shadow: 4px 4px 0 0 var(--bdl-ink);
    position: relative;
  }
  /* Each card a slightly different rotation — taped-to-corkboard vibe */
  .bdl__card--hub    { transform: rotate(-1.2deg); border-left: 6px solid var(--bdl-magenta); }
  .bdl__card--cake   { transform: rotate(0.8deg);  border-left: 6px solid var(--bdl-yellow); }
  .bdl__card--card   { transform: rotate(-0.6deg); border-left: 6px solid var(--bdl-cyan); }
  .bdl__card--pinata { transform: rotate(1.1deg);  border-left: 6px solid var(--bdl-teal); }

  .bdl__card:hover {
    background: #fffaef;
    transform: translateY(-2px) rotate(0deg);
    text-decoration: none;
    box-shadow: 6px 6px 0 0 var(--bdl-magenta);
  }

  .bdl__cat {
    font-size: 9px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--bdl-magenta);
    font-weight: 700;
  }
  .bdl__glyph {
    font-size: 36px;
    line-height: 1;
    margin: 4px 0 2px;
    /* slight tilt on emoji so they feel hand-stamped */
    display: inline-block;
    transform: rotate(-4deg);
  }
  .bdl__card--cake   .bdl__glyph { transform: rotate(2deg); }
  .bdl__card--card   .bdl__glyph { transform: rotate(-3deg); }
  .bdl__card--pinata .bdl__glyph { transform: rotate(4deg); }
  .bdl__name {
    font-size: 22px;
    font-weight: 700;
    font-style: italic;
    line-height: 1;
    color: var(--bdl-ink);
  }
  .bdl__sub {
    font-size: 10px;
    color: var(--bdl-mute);
    line-height: 1.4;
    margin-top: 2px;
  }
  .bdl__go {
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--bdl-ink);
    margin-top: auto;
    padding-top: 8px;
    border-top: 1px dotted var(--bdl-rule);
  }

  /* Foot — personalize hint */
  .bdl__foot {
    border-top: 1px dashed var(--bdl-rule);
    padding-top: 10px;
    text-align: center;
  }
  .bdl__cta {
    font-size: 10px;
    color: var(--bdl-mute);
    margin: 0;
    letter-spacing: 0.06em;
  }
  .bdl__cta code {
    background: var(--bdl-ink);
    color: var(--bdl-paper);
    padding: 1px 6px;
    border-radius: 2px;
    font-size: 10px;
  }

  @media (max-width: 980px) {
    .bdl__row { grid-template-columns: repeat(2, 1fr); }
    .bdl__card { transform: rotate(0); }
  }
  @media (max-width: 480px) {
    .bdl__row { grid-template-columns: 1fr; }
    .bdl { box-shadow: 4px 4px 0 0 var(--bdl-magenta); }
  }
  @media (prefers-reduced-motion: reduce) {
    .bdl__card { transform: rotate(0) !important; }
    .bdl__card:hover { transform: none; }
  }
</style>
