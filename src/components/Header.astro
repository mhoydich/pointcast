---
import Noggles from './Noggles.astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/feed', label: 'Feed' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-nouns-bg/90 backdrop-blur-md border-b border-nouns-border">
  <nav class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <Noggles width={80} />
      <span class="font-heading text-xl text-nouns-yellow group-hover:nounish-glow transition-all">
        PointCast
      </span>
    </a>

    <div class="flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'px-3 py-1.5 text-sm font-mono rounded-lg transition-colors',
            currentPath === link.href
              ? 'bg-nouns-yellow/10 text-nouns-yellow'
              : 'text-nouns-muted hover:text-nouns-white hover:bg-nouns-bg-elevated',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>
