---
/*
Spec: block 0334.
Source: Mike ping 2026-04-20T21:30:05.706Z:90fbd5bb.
Author: codex (via mcp__codex__codex).
*/
interface Props {
  contract?: string;
  poolTez?: string;
  tickets?: string;
  countdown?: string;
}

const {
  contract = '',
  poolTez = '12.5',
  tickets = '8',
  countdown = '3d 14h',
} = Astro.props;

const isPending = contract.trim() === '';
---

<section class="prize-cast-chip">
  <p class="prize-cast-chip__kicker">PRIZECAST · WEEKLY TEZ LOTTERY</p>
  <p class="prize-cast-chip__readout">
    Pool · {poolTez} ꜩ · {tickets} tickets · draws in {countdown}
  </p>
  <button class="prize-cast-chip__btn" disabled={isPending}>
    {isPending ? 'Not yet originated — ghostnet pending' : 'Toss in 1 ꜩ →'}
  </button>
  <p class="prize-cast-chip__footnote">Withdraw or deposit more at /collect/prize →</p>
</section>

<script is:inline>
  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const button = target.closest('.prize-cast-chip__btn');
    if (!(button instanceof HTMLButtonElement) || button.disabled) return;
    if (!window.localStorage.getItem('pc:wallet')) {
      window.dispatchEvent(new CustomEvent('pc:open-wallet-menu'));
      return;
    }
    console.log('deposit flow TBD');
  });
</script>

<style>
  .prize-cast-chip {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1rem 1.1rem;
    border: 1px solid #e89a2d;
    border-radius: 16px;
    background: #12110e;
    color: #f3e6d8;
  }

  .prize-cast-chip__kicker,
  .prize-cast-chip__btn,
  .prize-cast-chip__footnote {
    font-family: var(--pc-font-mono);
  }

  .prize-cast-chip__kicker,
  .prize-cast-chip__readout,
  .prize-cast-chip__footnote {
    margin: 0;
  }

  .prize-cast-chip__kicker {
    color: #e89a2d;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .prize-cast-chip__readout {
    font-family: var(--pc-font-sans);
    font-size: 1rem;
    line-height: 1.45;
  }

  .prize-cast-chip__btn {
    width: 100%;
    padding: 0.95rem 1rem;
    border: 1px solid #e89a2d;
    border-radius: 999px;
    background: #e89a2d;
    color: #12110e;
    cursor: pointer;
    font-size: 0.92rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: transform 120ms ease, opacity 120ms ease;
  }

  .prize-cast-chip__btn:hover:not(:disabled),
  .prize-cast-chip__btn:focus-visible:not(:disabled) {
    transform: translateY(-1px);
  }

  .prize-cast-chip__btn:disabled {
    background: transparent;
    color: #f3e6d8;
    cursor: not-allowed;
    opacity: 0.7;
  }

  .prize-cast-chip__footnote {
    color: #e89a2d;
    font-size: 0.74rem;
    letter-spacing: 0.04em;
  }

  @media (max-width: 599px) {
    .prize-cast-chip {
      align-items: flex-start;
    }

    .prize-cast-chip__btn {
      width: 100%;
    }
  }
 </style>
