---
const stampTargets = [
  { label: 'First Bundle', bundles: 1 },
  { label: 'Carpenter', bundles: 3 },
  { label: 'Forester', bundles: 5 },
  { label: 'Keeper', bundles: 8 },
];
---

<aside class="wood-strip" aria-labelledby="wood-strip-title">
  <div class="wood-strip__scene" aria-hidden="true">
    <span class="wood-strip__sun"></span>
    <span class="wood-strip__tree wood-strip__tree--back"></span>
    <span class="wood-strip__tree wood-strip__tree--main"></span>
    <span class="wood-strip__noggles">
      <i></i>
      <i></i>
    </span>
    <span class="wood-strip__axe"></span>
    <span class="wood-strip__log wood-strip__log--one"></span>
    <span class="wood-strip__log wood-strip__log--two"></span>
  </div>
  <div class="wood-strip__copy">
    <p class="wood-strip__kicker">Nouns play loop / pixel collect</p>
    <h2 id="wood-strip-title">Wood Chop Commons is live.</h2>
    <p>
      Chop a pixel tree, collect wood, bank bundles, plant seeds, and unlock local Nouns stamps. It is small, quick, and very PointCast.
    </p>
    <nav class="wood-strip__actions" aria-label="Nouns Wood Chop links">
      <a href="/nouns-wood-chop">Play</a>
      <a href="/nouns-wood-chop.json">Manifest</a>
      <a href="/b/0383">Block 0383</a>
    </nav>
  </div>
  <div class="wood-strip__stamps" aria-label="Stamp milestones">
    {stampTargets.map((stamp) => (
      <div class="wood-strip__stamp">
        <span>{stamp.bundles} bundle{stamp.bundles === 1 ? '' : 's'}</span>
        <strong>{stamp.label}</strong>
      </div>
    ))}
  </div>
</aside>

<style>
  .wood-strip {
    display: grid;
    grid-template-columns: minmax(210px, 0.36fr) minmax(0, 0.7fr) minmax(220px, 0.44fr);
    gap: 14px;
    align-items: stretch;
    margin: 14px 0;
    padding: 14px;
    border: 1.5px solid #12110e;
    background:
      linear-gradient(120deg, rgba(228, 247, 255, 0.88), rgba(255, 249, 228, 0.72) 48%, rgba(231, 244, 239, 0.88)),
      #fbfff8;
  }

  .wood-strip__scene {
    position: relative;
    min-height: 170px;
    overflow: hidden;
    border: 1px solid rgba(18, 17, 14, 0.82);
    background:
      linear-gradient(#bfe8ff 0 58%, #75b967 58% 100%);
    image-rendering: pixelated;
  }

  .wood-strip__sun,
  .wood-strip__tree,
  .wood-strip__noggles,
  .wood-strip__noggles i,
  .wood-strip__axe,
  .wood-strip__log {
    position: absolute;
    display: block;
  }

  .wood-strip__sun {
    top: 18px;
    left: 22px;
    width: 34px;
    height: 34px;
    background: #ffd55c;
    box-shadow: 0 0 0 8px rgba(255, 213, 92, 0.28);
  }

  .wood-strip__tree--back {
    right: 26px;
    bottom: 40px;
    width: 44px;
    height: 88px;
    background:
      linear-gradient(#2f8055 0 36px, transparent 36px),
      linear-gradient(90deg, transparent 17px, #7b4a28 17px 27px, transparent 27px);
  }

  .wood-strip__tree--main {
    left: 82px;
    bottom: 28px;
    width: 86px;
    height: 126px;
    background:
      linear-gradient(#246d4c 0 44px, transparent 44px),
      linear-gradient(90deg, transparent 32px, #8d5a32 32px 55px, transparent 55px);
    box-shadow:
      18px -32px 0 -2px #3e966b,
      -18px -10px 0 -4px #2d7e58;
  }

  .wood-strip__noggles {
    left: 102px;
    bottom: 112px;
    width: 52px;
    height: 22px;
    background: #161616;
  }

  .wood-strip__noggles i {
    top: 5px;
    width: 18px;
    height: 12px;
    background: #fff3a3;
  }

  .wood-strip__noggles i:first-child { left: 5px; }
  .wood-strip__noggles i:last-child { right: 5px; }

  .wood-strip__axe {
    right: 76px;
    bottom: 46px;
    width: 18px;
    height: 76px;
    background: #7b4a28;
    transform: rotate(28deg);
    transform-origin: bottom center;
  }

  .wood-strip__axe::before {
    content: '';
    position: absolute;
    top: -12px;
    left: -14px;
    width: 38px;
    height: 28px;
    background: #e7eef4;
    border: 4px solid #242424;
  }

  .wood-strip__log {
    bottom: 22px;
    width: 54px;
    height: 18px;
    border: 3px solid #744323;
    background: #bd8450;
  }

  .wood-strip__log--one { left: 24px; }
  .wood-strip__log--two { right: 28px; }

  .wood-strip__copy {
    min-width: 0;
    align-self: center;
  }

  .wood-strip__kicker {
    margin: 0 0 7px;
    color: #0f6e56;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .wood-strip h2 {
    margin: 0;
    color: #12110e;
    font-size: 30px;
    line-height: 1.02;
    font-weight: 500;
    letter-spacing: 0;
  }

  .wood-strip p {
    margin: 9px 0 0;
    color: #38373a;
    font-size: 14px;
    line-height: 1.45;
  }

  .wood-strip__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .wood-strip__actions a {
    padding: 8px 10px;
    border: 1px solid #12110e;
    background: #fff;
    color: #12110e;
  }

  .wood-strip__actions a:first-child {
    background: #12110e;
    color: #fff;
  }

  .wood-strip__actions a:hover {
    background: #e7f4ef;
    text-decoration: none;
  }

  .wood-strip__stamps {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 6px;
  }

  .wood-strip__stamp {
    display: grid;
    align-content: space-between;
    min-width: 0;
    min-height: 78px;
    padding: 10px;
    border: 1px solid rgba(18, 17, 14, 0.74);
    background: rgba(255, 255, 255, 0.74);
  }

  .wood-strip__stamp span {
    color: #0f6e56;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .wood-strip__stamp strong {
    color: #12110e;
    font-size: 14px;
    line-height: 1.15;
  }

  @media (max-width: 1000px) {
    .wood-strip {
      grid-template-columns: 1fr;
    }

    .wood-strip__scene {
      min-height: 210px;
    }
  }

  @media (max-width: 560px) {
    .wood-strip__stamps {
      grid-template-columns: 1fr;
    }
  }
</style>
