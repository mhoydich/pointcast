---
/**
 * TodayOnPointCast — curated "today on PointCast" strip for the home.
 *
 * Mike 2026-04-20 12:20 PT: *"on homepage, it should likely be all the
 * interesting things we were talking about today from clock to bitcoin,
 * to 420, to feature updates, to things to try, to learnings, to how
 * to learn, to entertainment, kinda thing, and very monday stuffs as,
 * today is monday."*
 *
 * This is that strip. Hand-curated, small, dense — five to seven
 * chips of the day's actual themes. Unlike FreshDeck (random 3 from
 * the archive) or FreshStrip (time-since-last-visit signal), this is
 * Mike + cc's editorial pick of today's surfaces.
 *
 * Structure: a dated masthead + 6 chips + a "dig deeper" line. Each
 * chip is a deep link to a specific block or surface, with a tiny
 * kicker labeling the thread.
 *
 * Author: cc. Source: Mike 2026-04-20 12:20 PT chat + the actual
 * blocks filed today.
 */

const prettyToday = new Intl.DateTimeFormat('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  timeZone: 'America/Los_Angeles',
}).format(new Date());

interface Stop {
  kicker: string;
  title: string;
  dek: string;
  href: string;
}

const STOPS: Stop[] = [
  {
    kicker: 'TODAY · 4/20',
    title: 'Happy 4/20',
    dek: 'The cultural artifact, the Waldos origin story, the 2026 beverage shape — and Good Feels specials running today.',
    href: '/b/0328',
  },
  {
    kicker: 'MARKETS · BTC',
    title: 'Bitcoin at $75K · ETF gravity vs. Iran risk-off',
    dek: 'Red candle on geopolitics + $1B weekly ETF inflows underneath. Structural demand vs headline risk, in a single Monday tape.',
    href: '/b/0329',
  },
  {
    kicker: 'SHIPPED · LIVE',
    title: 'Presence is live · the DO is finally bound',
    dek: 'Months-deferred Durable Object deploy landed this morning. /here now renders real connected visitors, not a placeholder.',
    href: '/b/0327',
  },
  {
    kicker: 'FEATURE · CLOCK',
    title: 'Collab clock — the roster in timezones',
    dek: 'Ticking digital readout over /collabs. Mike in El Segundo; Kenzo in Mallorca; cc + Codex in cloud/UTC.',
    href: '/clock/0324',
  },
  {
    kicker: 'LEARN · AI LANDSCAPE',
    title: 'Kimi K2.6 + Qwen 3.6 Max — what shipped + what it means',
    dek: 'Open-weights SOTA on agentic benches + closed incremental from Alibaba. Where they fit (and don\'t) in PointCast\'s stack.',
    href: '/b/0325',
  },
  {
    kicker: 'TRY · FIRST-TIME',
    title: 'Start here · 5-stop tour',
    dek: 'See who\'s here → collect today\'s drop → vote a poll → play a round → back to feed. About 5 minutes, every step an action.',
    href: '/start',
  },
];
---

<aside class="today-strip" aria-label="Today on PointCast">
  <header class="today-strip__head">
    <p class="today-strip__date mono">
      <span class="today-strip__date-day">{prettyToday}</span>
      <span class="today-strip__sep" aria-hidden="true">·</span>
      <span class="today-strip__date-loc">El Segundo</span>
    </p>
    <p class="today-strip__kicker mono">TODAY ON POINTCAST · CURATED</p>
  </header>

  <ol class="today-strip__list">
    {STOPS.map((s, i) => (
      <li class="today-stop">
        <a class="today-stop__link" href={s.href}>
          <span class="today-stop__num mono">{String(i + 1).padStart(2, '0')}</span>
          <span class="today-stop__kicker mono">{s.kicker}</span>
          <span class="today-stop__title">{s.title}</span>
          <span class="today-stop__dek">{s.dek}</span>
          <span class="today-stop__arrow mono" aria-hidden="true">→</span>
        </a>
      </li>
    ))}
  </ol>

  <p class="today-strip__footer mono">
    also today · <a href="/workbench">who's building what</a> · <a href="/here">who's here</a> · <a href="/for-nodes">become a node</a>
  </p>
</aside>

<style>
  .today-strip {
    margin: 14px 0;
    padding: 14px 16px;
    background: #fffaf1;
    border: 1px solid #e6d8be;
    border-top: 3px solid #8a2432;
    border-radius: 2px;
  }
  .mono {
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', 'Monaco', 'Menlo', ui-monospace, monospace);
  }
  .today-strip__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    border-bottom: 1px solid #e6d8be;
    padding: 0 0 8px;
    margin: 0 0 10px;
    flex-wrap: wrap;
  }
  .today-strip__date {
    font-size: 12px;
    letter-spacing: 0.1em;
    color: #2a1b11;
    text-transform: uppercase;
    margin: 0;
    font-weight: 600;
  }
  .today-strip__date-day { color: #8a2432; }
  .today-strip__date-loc { opacity: 0.8; font-weight: 500; }
  .today-strip__sep { margin: 0 4px; opacity: 0.55; }
  .today-strip__kicker {
    font-size: 10px;
    letter-spacing: 0.16em;
    color: #5f2a1e;
    margin: 0;
    text-transform: uppercase;
  }
  .today-strip__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 8px;
  }
  .today-stop {
    border-bottom: 1px solid rgba(138, 36, 50, 0.08);
  }
  .today-stop__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto auto;
    grid-template-areas:
      "num kicker arrow"
      "num title arrow"
      "num dek arrow";
    column-gap: 10px;
    row-gap: 2px;
    padding: 8px 6px;
    color: inherit;
    text-decoration: none;
    transition: background 0.12s;
    border-radius: 2px;
  }
  .today-stop__link:hover {
    background: rgba(138, 36, 50, 0.05);
    text-decoration: none;
  }
  .today-stop__num {
    grid-area: num;
    font-size: 11px;
    font-weight: 700;
    color: #8a2432;
    letter-spacing: 0.04em;
    align-self: start;
    padding-top: 1px;
  }
  .today-stop__kicker {
    grid-area: kicker;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #5f2a1e;
    font-weight: 500;
  }
  .today-stop__title {
    grid-area: title;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 14px;
    font-weight: 600;
    color: #12110e;
    line-height: 1.25;
  }
  .today-stop__dek {
    grid-area: dek;
    font-size: 12px;
    line-height: 1.4;
    color: #5f5e5a;
    font-family: Georgia, 'Times New Roman', serif;
  }
  .today-stop__arrow {
    grid-area: arrow;
    align-self: center;
    font-size: 14px;
    color: #8a2432;
    opacity: 0.5;
    transition: opacity 0.12s, transform 0.12s;
  }
  .today-stop__link:hover .today-stop__arrow {
    opacity: 1;
    transform: translateX(2px);
  }
  .today-strip__footer {
    margin: 12px 0 0;
    padding: 8px 0 0;
    border-top: 1px solid #e6d8be;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #5f5e5a;
  }
  .today-strip__footer a {
    color: #8a2432;
    text-decoration: none;
    margin: 0 2px;
    border-bottom: 1px dotted rgba(138, 36, 50, 0.3);
  }
  .today-strip__footer a:hover { color: #185FA5; border-bottom-color: #185FA5; }

  @media (max-width: 720px) {
    .today-strip__list {
      grid-template-columns: 1fr;
    }
  }
</style>
