// Daily rotation: pick 6 from the pool using a day-of-year seed so the
// same slice renders all day (TZ: PT), a different slice renders
// tomorrow. 4/20 is always included if present in the pool on its day.
function pickTodays(pool: Stop[], when = new Date()): Stop[] {
  const day = Math.floor(when.getTime() / (24 * 3600 * 1000));
  const want = 3;
  const n = pool.length;
  if (n <= want) return pool;
  // Stable pseudo-random shuffle seeded by day number. Fisher-Yates with
  // a linear-congruential PRNG keyed by `day` — deterministic per day.
  const seeded = (() => {
    let s = (day * 2654435761) >>> 0;
    return () => {
      s = (s * 1664525 + 1013904223) >>> 0;
      return s / 0x100000000;
    };
  })();
  const idx = Array.from({ length: n }, (_, i) => i);
  for (let i = n - 1; i > 0; i--) {
    const j = Math.floor(seeded() * (i + 1));
    [idx[i], idx[j]] = [idx[j], idx[i]];
  }
  return idx.slice(0, want).map((i) => pool[i]);
}

const STOPS: Stop[] = pickTodays(POOL);
