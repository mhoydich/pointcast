          <span class="today-stop__dek">{s.dek}</span>
          <span class="today-stop__arrow mono" aria-hidden="true">→</span>
        </a>
      </li>
    ))}
  </ol>

  <p class="today-strip__footer mono">
    &nbsp;
  </p>
</aside>

