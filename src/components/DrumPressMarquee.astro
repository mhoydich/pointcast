---
/**
 * <DrumPressMarquee /> — homepage strip pointing at /drum-press.
 *
 * Per Mike 2026-04-29 (post-AgentLane): "rethink homepage for drum
 * and an almost publishing house that published tons of drum media."
 *
 * Visual: a small advertising slip — like a publishing house's quarter-
 * page in the back of a literary magazine. Warm oat paper, ink black,
 * marquee-red accent, a 4-up thumbnail row of "covers", and a "browse
 * the catalog" link.
 *
 * Self-contained: scoped CSS, no presence/event polling. The page it
 * points at handles the live state. This strip is just the doorway.
 *
 * Hover behaviour: each cover thumbnail dims its neighbors so the row
 * feels touchable, not just decorative.
 */
---

<aside class="dpm" aria-labelledby="dpm-title">
  <div class="dpm__head">
    <p class="dpm__kicker mono">★ DRUM PRESS · CATALOG OF DRUM MEDIA ★</p>
    <h2 class="dpm__title" id="dpm-title">
      forty-seven <em>editions</em> in print
    </h2>
    <p class="dpm__strap mono">eight imprints · pressed nightly · el segundo, ca</p>
  </div>

  <div class="dpm__row" role="list">
    <a class="dpm__cover" role="listitem" href="/drum-v15">
      <span class="dpm__cat mono">DR-V15</span>
      <span class="dpm__name">hang</span>
      <span class="dpm__sub mono">handpan · steel</span>
    </a>
    <a class="dpm__cover" role="listitem" href="/drum-letters">
      <span class="dpm__cat mono">DR-COM3</span>
      <span class="dpm__name">letters</span>
      <span class="dpm__sub mono">note for the next</span>
    </a>
    <a class="dpm__cover" role="listitem" href="/drum-radio">
      <span class="dpm__cat mono">DR-CST5</span>
      <span class="dpm__name">radio</span>
      <span class="dpm__sub mono">96.1 fm · all rooms</span>
    </a>
    <a class="dpm__cover" role="listitem" href="/drum-agent">
      <span class="dpm__cat mono">DR-MAC2</span>
      <span class="dpm__name">agent room</span>
      <span class="dpm__sub mono">play floor · machine</span>
    </a>
  </div>

  <a class="dpm__cta mono" href="/drum-press">
    browse the catalog → <span class="dpm__cta-imprints">8 imprints · 47 titles</span>
  </a>
</aside>

<style>
  .dpm {
    --dpm-paper: #f4ead4;
    --dpm-paper-deep: #ecdfbe;
    --dpm-ink: #0c0a07;
    --dpm-rule: #1a1610;
    --dpm-mute: #5b5347;
    --dpm-accent: #c4351c;
    --dpm-cream: #fbf6e7;

    display: grid;
    grid-template-columns: minmax(220px, 1fr) 2.6fr auto;
    gap: 22px;
    align-items: center;
    padding: 18px clamp(14px, 3vw, 28px);
    margin: 0 0 18px;
    background: var(--dpm-paper);
    border: 1.5px solid var(--dpm-rule);
    border-left: 6px solid var(--dpm-accent);
    color: var(--dpm-ink);
    font-family: 'Iowan Old Style', 'Iowan Old Style W01', 'Palatino', 'Times New Roman', Times, serif;
    line-height: 1.45;
    /* Slight ditto-machine shadow for the catalog-card vibe */
    box-shadow: 4px 4px 0 0 rgba(196, 53, 28, 0.12);
  }
  .dpm .mono {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    letter-spacing: 0.04em;
  }

  .dpm__head { min-width: 0; }
  .dpm__kicker {
    font-size: 9px;
    letter-spacing: 0.28em;
    color: var(--dpm-accent);
    text-transform: uppercase;
    margin: 0 0 6px;
    font-weight: 600;
  }
  .dpm__title {
    font-size: clamp(22px, 2.6vw, 30px);
    font-weight: 700;
    margin: 0 0 6px;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--dpm-ink);
  }
  .dpm__title em {
    font-style: italic;
    color: var(--dpm-accent);
    font-weight: 500;
  }
  .dpm__strap {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dpm-mute);
    margin: 0;
  }

  .dpm__row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 8px;
    min-width: 0;
  }
  .dpm__cover {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 10px 10px 9px;
    background: var(--dpm-cream);
    border: 1.25px solid var(--dpm-rule);
    text-decoration: none;
    color: var(--dpm-ink);
    transition: background 120ms ease, transform 100ms ease, opacity 120ms ease;
    min-width: 0;
  }
  .dpm__row:hover .dpm__cover { opacity: 0.55; }
  .dpm__row .dpm__cover:hover {
    opacity: 1;
    background: #fff;
    transform: translateY(-1px);
    text-decoration: none;
  }
  .dpm__cat {
    font-size: 8px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--dpm-accent);
    font-weight: 600;
  }
  .dpm__name {
    font-size: 18px;
    font-weight: 700;
    font-style: italic;
    line-height: 1;
    color: var(--dpm-ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .dpm__sub {
    font-size: 9px;
    color: var(--dpm-mute);
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .dpm__cta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 16px;
    background: var(--dpm-ink);
    color: var(--dpm-paper);
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border: 1.5px solid var(--dpm-ink);
    transition: background 120ms, color 120ms;
    text-align: center;
    white-space: nowrap;
  }
  .dpm__cta:hover {
    background: var(--dpm-accent);
    border-color: var(--dpm-accent);
    text-decoration: none;
  }
  .dpm__cta-imprints {
    font-size: 8px;
    letter-spacing: 0.22em;
    color: rgba(244, 234, 212, 0.7);
  }

  @media (max-width: 980px) {
    .dpm {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .dpm__cta {
      align-self: stretch;
      flex-direction: row;
      justify-content: space-between;
    }
  }
  @media (max-width: 480px) {
    .dpm__row { grid-template-columns: repeat(2, 1fr); }
  }
</style>
