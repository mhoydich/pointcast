---
/**
 * MoodChip — top-of-home mood selector.
 *
 * Mike 2026-04-18: "at the top nav some click across, interaction, game,
 * poll, whats beyond, mood, state register, go". The mood primitive
 * lands as a one-tap chip at the very top — pick your mood, the page
 * tints subtly, localStorage remembers for returns.
 *
 * v1 is localStorage-only — personal state register, not a shared
 * tally. v2 can add /api/mood for a global aggregate if the primitive
 * lands.
 */

const MOODS = [
  { id: 'chill',   label: 'CHILL',   color: '#2B8A3E', hint: 'slow + calm' },
  { id: 'hype',    label: 'HYPE',    color: '#C92A2A', hint: 'on the rise' },
  { id: 'focus',   label: 'FOCUS',   color: '#1864AB', hint: 'in the work' },
  { id: 'flow',    label: 'FLOW',    color: '#5F3DC4', hint: 'on tempo' },
  { id: 'curious', label: 'CURIOUS', color: '#E8590C', hint: 'following a thread' },
  { id: 'quiet',   label: 'QUIET',   color: '#5F5E5A', hint: 'under the noise' },
];
import { MOOD_SOUNDTRACKS } from '../lib/moods-soundtracks';
const SOUNDTRACKS_JSON = JSON.stringify(MOOD_SOUNDTRACKS);
---

<aside class="mood" aria-label="Current mood">
  <span class="mood__kicker mono">MOOD · ONE TAP · PAGE FOLLOWS</span>
  <div class="mood__row" role="group">
    {MOODS.map((m) => (
      <button
        type="button"
        class="mood__btn"
        data-mood-id={m.id}
        style={`--mood-color: ${m.color};`}
        aria-label={`Set mood: ${m.label}`}
      >
        <span class="mood__swatch" aria-hidden="true"></span>
        <span class="mood__label mono">{m.label}</span>
        <span class="mood__hint">{m.hint}</span>
      </button>
    ))}
  </div>

  <div class="mood__soundtrack" id="mood-soundtrack" hidden data-soundtracks={SOUNDTRACKS_JSON}>
    <button type="button" class="mood__soundtrack-toggle mono" id="mood-soundtrack-toggle" aria-expanded="false">
      <span class="mood__soundtrack-play" aria-hidden="true">▶</span>
      <span id="mood-soundtrack-label">soundtrack</span>
    </button>
    <div class="mood__soundtrack-player" id="mood-soundtrack-player" hidden>
      <iframe id="mood-soundtrack-frame" src="about:blank" title="Mood soundtrack" loading="lazy" allow="autoplay; encrypted-media" referrerpolicy="no-referrer-when-downgrade"></iframe>
      <button type="button" class="mood__soundtrack-close mono" id="mood-soundtrack-close" aria-label="Close soundtrack">× close</button>
    </div>
  </div>
</aside>

<script is:inline>
  (function () {
    var buttons = Array.from(document.querySelectorAll('.mood__btn[data-mood-id]'));
    if (!buttons.length) return;
    var lsKey = 'pc:mood';
    var root = document.documentElement;

    // Mood → hue map for the meditative color-field pulse.
    // Per Mike 2026-04-20 13:00 PT: "when you click mode, animation and
    // change of the ui to match, have lite visualizations that are
    // meditative."
    var MOOD_HUE = {
      chill:   155,  // green-tea
      hype:    8,    // warm red
      focus:   215,  // cobalt
      flow:    275,  // soft violet
      curious: 28,   // amber
      quiet:   220,  // deep slate-blue
    };

    function applyMood(id) {
      if (!id) return;
      root.setAttribute('data-pc-mood', id);
      buttons.forEach(function (b) {
        b.classList.toggle('mood__btn--active', b.getAttribute('data-mood-id') === id);
      });
    }

    function meditativePulse(id) {
      // Respect prefers-reduced-motion.
      try {
        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      } catch (e) {}
      var hue = MOOD_HUE[id] || 28;
      var overlay = document.createElement('div');
      overlay.className = 'mood-pulse';
      overlay.setAttribute('aria-hidden', 'true');
      overlay.style.setProperty('--mood-hue', String(hue));
      document.body.appendChild(overlay);
      // Cleanup after animation completes.
      setTimeout(function () {
        if (overlay.parentNode) overlay.parentNode.removeChild(overlay);
      }, 1800);
    }

    // Paint prior choice (no pulse on initial load).
    try {
      var prior = localStorage.getItem(lsKey);
      if (prior) applyMood(prior);
    } catch (e) {}

    // ---------- Soundtrack toggle (Mike 2026-04-20 13:20 PT: "soundtracks
    //            that match the mood, that can be turned on, broadcast") ----
    var soundtrackEl = document.getElementById('mood-soundtrack');
    var soundtrackToggle = document.getElementById('mood-soundtrack-toggle');
    var soundtrackLabel = document.getElementById('mood-soundtrack-label');
    var soundtrackPlayer = document.getElementById('mood-soundtrack-player');
    var soundtrackFrame = document.getElementById('mood-soundtrack-frame');
    var soundtrackClose = document.getElementById('mood-soundtrack-close');
    var soundtracks = {};
    try { soundtracks = JSON.parse(soundtrackEl && soundtrackEl.getAttribute('data-soundtracks') || '{}'); } catch (e) { soundtracks = {}; }

    function showSoundtrackOffer(id) {
      if (!soundtrackEl || !soundtrackLabel || !soundtrackToggle) return;
      var t = soundtracks[id];
      if (!t) { soundtrackEl.hidden = true; return; }
      soundtrackEl.hidden = false;
      soundtrackLabel.textContent = t.label + ' · ' + id.toUpperCase();
      soundtrackToggle.setAttribute('data-mood-id', id);
      soundtrackToggle.setAttribute('aria-expanded', 'false');
      // Reset player when switching moods.
      if (soundtrackPlayer) soundtrackPlayer.hidden = true;
      if (soundtrackFrame && soundtrackFrame.src && soundtrackFrame.src !== 'about:blank') {
        soundtrackFrame.src = 'about:blank';
      }
    }

    function openSoundtrack() {
      if (!soundtrackPlayer || !soundtrackFrame || !soundtrackToggle) return;
      var id = soundtrackToggle.getAttribute('data-mood-id');
      var t = id && soundtracks[id];
      if (!t) return;
      soundtrackFrame.src = t.url;
      soundtrackPlayer.hidden = false;
      soundtrackToggle.setAttribute('aria-expanded', 'true');
    }

    function closeSoundtrack() {
      if (!soundtrackPlayer || !soundtrackFrame || !soundtrackToggle) return;
      soundtrackFrame.src = 'about:blank';
      soundtrackPlayer.hidden = true;
      soundtrackToggle.setAttribute('aria-expanded', 'false');
    }

    if (soundtrackToggle) {
      soundtrackToggle.addEventListener('click', function () {
        if (soundtrackToggle.getAttribute('aria-expanded') === 'true') closeSoundtrack();
        else openSoundtrack();
      });
    }
    if (soundtrackClose) soundtrackClose.addEventListener('click', closeSoundtrack);

    buttons.forEach(function (b) {
      b.addEventListener('click', function () {
        var id = b.getAttribute('data-mood-id');
        try { localStorage.setItem(lsKey, id); } catch (e) {}
        applyMood(id);
        meditativePulse(id);
        showSoundtrackOffer(id);
      });
    });

    // On load, if prior mood was set, surface the soundtrack offer immediately.
    try {
      var priorId = localStorage.getItem(lsKey);
      if (priorId) showSoundtrackOffer(priorId);
    } catch (e) {}
  })();
</script>

<style>
  .mood {
    margin: 6px 0 10px;
    padding: 8px 12px;
    border: 1px solid var(--pc-rule, #d6d4cd);
    border-left: 4px solid #5F3DC4;
    border-radius: 3px;
    background: #fbfaf5;
  }
  .mood__kicker {
    display: block;
    margin: 0 0 6px;
    font-size: 9px;
    letter-spacing: 0.16em;
    color: #5F5E5A;
    font-weight: 700;
  }
  .mono { font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); text-transform: uppercase; }

  .mood__row {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }
  .mood__btn {
    flex: 1 1 110px;
    min-width: 0;
    padding: 6px 8px;
    border: 1px solid var(--pc-rule, #d6d4cd);
    background: #fff;
    color: #12110E;
    border-radius: 2px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    font: inherit;
    transition: border-color 0.12s, background 0.12s;
  }
  .mood__btn:hover { border-color: var(--mood-color); }
  .mood__btn--active {
    border-color: var(--mood-color);
    border-width: 2px;
    padding: 5px 7px;
    background: color-mix(in oklab, var(--mood-color) 8%, #fff);
  }
  .mood__swatch {
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--mood-color);
    flex: 0 0 auto;
  }
  .mood__label {
    font-size: 10px; letter-spacing: 0.14em;
    color: #12110E; font-weight: 700;
  }
  .mood__hint {
    font-size: 10px; color: #8a8878;
    flex: 1 1 auto; text-align: right;
  }

  @media (max-width: 640px) {
    .mood__btn { flex: 1 1 calc(50% - 4px); }
    .mood__hint { display: none; }
  }

  /* Soundtrack toggle appears once a mood is selected. */
  .mood__soundtrack { margin: 10px 0 0; }
  .mood__soundtrack[hidden] { display: none; }
  .mood__soundtrack-toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: transparent;
    border: 1px solid var(--pc-rule, #d6d4cd);
    border-left: 3px solid #5F3DC4;
    border-radius: 3px;
    color: #12110e;
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.12s, border-color 0.12s;
  }
  .mood__soundtrack-toggle:hover { background: #f5f2ea; border-left-color: #3b2a85; }
  .mood__soundtrack-play { color: #5F3DC4; }
  .mood__soundtrack-toggle[aria-expanded="true"] .mood__soundtrack-play::before { content: '❚❚'; letter-spacing: -1px; }
  .mood__soundtrack-toggle[aria-expanded="true"] .mood__soundtrack-play { content: ''; }

  .mood__soundtrack-player {
    margin: 10px 0 0;
    padding: 8px;
    background: #1f1208;
    border-radius: 3px;
    position: relative;
  }
  .mood__soundtrack-player[hidden] { display: none; }
  .mood__soundtrack-player iframe {
    width: 100%;
    height: 152px;
    border: none;
    border-radius: 2px;
    background: #0b0b0b;
    display: block;
  }
  .mood__soundtrack-close {
    margin: 6px 0 0;
    background: transparent;
    border: 1px solid rgba(243, 230, 216, 0.3);
    color: #f3e6d8;
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 2px;
    cursor: pointer;
  }
  .mood__soundtrack-close:hover { background: rgba(243, 230, 216, 0.08); }

  /* ═ Subtle page tint when mood is set ═
     Sits at the document root so it affects any page-level surface that
     picks it up. Deliberately tiny — not brand-overriding. */
  :global(html[data-pc-mood="chill"]   body)  { background: linear-gradient(180deg, #f2f8f4 0%, #fff 200px); }
  :global(html[data-pc-mood="hype"]    body)  { background: linear-gradient(180deg, #fff1f1 0%, #fff 200px); }
  :global(html[data-pc-mood="focus"]   body)  { background: linear-gradient(180deg, #eef4fa 0%, #fff 200px); }
  :global(html[data-pc-mood="flow"]    body)  { background: linear-gradient(180deg, #f5f0ff 0%, #fff 200px); }
  :global(html[data-pc-mood="curious"] body)  { background: linear-gradient(180deg, #fff4ed 0%, #fff 200px); }
  :global(html[data-pc-mood="quiet"]   body)  { background: linear-gradient(180deg, #f5f5f2 0%, #fff 200px); }
</style>

<style is:global>
  /* Meditative color-field pulse on mood click.
     Injected by MoodChip click handler; fades in from center, blooms,
     fades out. Hue comes from --mood-hue set inline by JS. */
  .mood-pulse {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9998;
    background:
      radial-gradient(circle at 50% 50%,
        hsla(var(--mood-hue, 28), 70%, 60%, 0.35) 0%,
        hsla(var(--mood-hue, 28), 70%, 60%, 0.12) 32%,
        hsla(var(--mood-hue, 28), 70%, 60%, 0.00) 62%);
    opacity: 0;
    animation: moodPulse 1.8s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
    will-change: opacity, transform;
    mix-blend-mode: multiply;
  }

  @keyframes moodPulse {
    0%   { opacity: 0;   transform: scale(0.85); }
    20%  { opacity: 0.9; transform: scale(1.00); }
    55%  { opacity: 0.5; transform: scale(1.10); }
    100% { opacity: 0;   transform: scale(1.25); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mood-pulse { display: none; }
  }
</style>
