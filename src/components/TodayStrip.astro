---
/**
 * TodayStrip — six daily-rotating chips on the home page.
 *
 * Mike 2026-04-19 ~16:45 PT: "daily content, polls, weather, local,
 * sports, etc moods, clickable things for information share, etc,
 * content could be so much, this is the my brain haven't been thinking
 * about, so, yah claude do your magic, that should help with the
 * freshness".
 *
 * Approach: instead of cc hand-authoring fresh content every day, pick
 * six DIFFERENT things to feature each day — each derived
 * deterministically from the PT `daySeed`. Every PT midnight, all six
 * chips rotate. Same pick for every visitor globally on the same day.
 *
 * Each chip: small eyebrow + bolder value + short context + arrow to
 * its destination. Tappable, information-sharing by design.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import { CHANNEL_LIST } from '../lib/channels';
import { NAME_DROPS, STATIONS } from '../lib/local';
import { daySeed, pickDailyBlock, todayPT } from '../lib/daily';
import { GLOSSARY } from '../lib/glossary';

const blocks = await getCollection('blocks', ({ data }) => !data.draft);

// Distinct mood slugs across blocks + gallery.
let gallery: CollectionEntry<'gallery'>[] = [];
try {
  gallery = await getCollection('gallery', ({ data }) => !data.draft);
} catch { /* collection may be empty */ }

const moodSet = new Set<string>();
for (const b of blocks) if (b.data.mood) moodSet.add(b.data.mood);
for (const g of gallery) if (g.data.mood) moodSet.add(g.data.mood);
const moodList = [...moodSet].sort();  // stable order for stable seed-mod

// Day seed drives the whole rotation. Offsets prime-shuffled so the
// six picks don't all land in sync each day.
const seed = daySeed();
const todayStr = todayPT();

// Today's featured mood — cycles through the discovered mood vocabulary.
const todayMood = moodList.length > 0 ? moodList[seed % moodList.length] : null;

// Today's daily drop — same pick as /today and /tv.
const todayBlock = pickDailyBlock(blocks);

// Today's station — cycles through STATIONS with offset +3.
const stationList = [...STATIONS].sort((a, b) => a.miles - b.miles);
const todayStation = stationList[(seed + 3) % stationList.length];

// Today's ES name-drop — cycles through NAME_DROPS with offset +5.
const todayNameDrop = NAME_DROPS[(seed + 5) % NAME_DROPS.length];

// Today's channel — cycles through CHANNEL_LIST with offset +7.
const todayChannel = CHANNEL_LIST[(seed + 7) % CHANNEL_LIST.length];

// Today's noun — deterministic id 0..1199. Prime-multiplier spreads
// adjacent-day picks across the range instead of walking sequentially.
const todayNoun = (seed * 7) % 1200;

// Today's glossary term — cycles through the 26 PointCast-specific
// terms with offset +11 (prime). Answers Mike's "clickable things for
// information share" directive: a vocab lesson a day, linked to its
// anchor on /glossary. 7th chip in the strip.
const todayTerm = GLOSSARY[(seed + 11) % GLOSSARY.length];

const blockChannelName = todayBlock ? (
  CHANNEL_LIST.find((c) => c.code === todayBlock.data.channel)?.name ?? ''
) : '';
---

<aside class="today-strip" aria-label={`Today's rotation for ${todayStr}`}>
  <p class="today-strip__kicker mono">
    <span class="today-strip__kicker-label">TODAY · {todayStr}</span>
    <span class="today-strip__kicker-sub">SIX THINGS · ROTATES AT MIDNIGHT PT</span>
  </p>

  <div class="today-strip__grid">
    {todayMood && (
      <a class="chip chip--mood" href={`/mood/${todayMood}`} aria-label={`Today's mood: ${todayMood}`}>
        <span class="chip__eye mono">MOOD</span>
        <span class="chip__main">{todayMood.replace(/-/g, ' ')}</span>
        <span class="chip__sub mono">/mood/{todayMood}</span>
        <span class="chip__arrow mono" aria-hidden="true">→</span>
      </a>
    )}

    {todayBlock && (
      <a class="chip chip--block" href="/today" aria-label={`Today's block: № ${todayBlock.data.id}`}>
        <span class="chip__eye mono">BLOCK</span>
        <span class="chip__main">№ {todayBlock.data.id}</span>
        <span class="chip__sub mono">{blockChannelName.toUpperCase()} · TAP TO COLLECT</span>
        <span class="chip__arrow mono" aria-hidden="true">→</span>
      </a>
    )}

    <a class="chip chip--station" href={`/search?q=${encodeURIComponent(todayStation.name)}`} aria-label={`Today's station: ${todayStation.name}`}>
      <span class="chip__eye mono">STATION</span>
      <span class="chip__main">{todayStation.name}</span>
      <span class="chip__sub mono">{todayStation.miles}MI {todayStation.direction} · /LOCAL</span>
      <span class="chip__arrow mono" aria-hidden="true">→</span>
    </a>

    <a class="chip chip--namedrop" href="/b/0276" aria-label={`Today's name-drop: ${todayNameDrop.name}`}>
      <span class="chip__eye mono">NAME</span>
      <span class="chip__main">{todayNameDrop.name}</span>
      <span class="chip__sub mono">{todayNameDrop.kind.toUpperCase()}</span>
      <span class="chip__arrow mono" aria-hidden="true">→</span>
    </a>

    <a class="chip chip--channel" href={`/c/${todayChannel.slug}`} aria-label={`Today's channel: ${todayChannel.name}`} style={`--ch-600: ${todayChannel.color600}; --ch-50: ${todayChannel.color50};`}>
      <span class="chip__eye mono">CHANNEL</span>
      <span class="chip__main">CH.{todayChannel.code} · {todayChannel.name}</span>
      <span class="chip__sub mono">{todayChannel.purpose}</span>
      <span class="chip__arrow mono" aria-hidden="true">→</span>
    </a>

    <a class="chip chip--noun" href={`https://noun.pics/${todayNoun}.svg`} target="_blank" rel="noopener" aria-label={`Today's noun: ${todayNoun}`}>
      <span class="chip__eye mono">NOUN</span>
      <span class="chip__main">№ {todayNoun}</span>
      <span class="chip__sub mono">NOUN.PICS/{todayNoun}.SVG</span>
      <span class="chip__arrow mono" aria-hidden="true">↗</span>
    </a>

    <a class="chip chip--term" href={`/glossary#${todayTerm.slug}`} aria-label={`Today's glossary term: ${todayTerm.term}`}>
      <span class="chip__eye mono">TERM</span>
      <span class="chip__main">{todayTerm.term}</span>
      <span class="chip__sub mono">{todayTerm.category.toUpperCase()} · /GLOSSARY</span>
      <span class="chip__arrow mono" aria-hidden="true">→</span>
    </a>
  </div>

  <p class="today-strip__share mono" id="today-strip-share">
    <button type="button" class="share-btn" id="today-share-btn">↗ SHARE TODAY'S SIX</button>
    <span class="share-status" id="today-share-status" aria-live="polite"></span>
  </p>
</aside>

<script is:inline>
  (function () {
    var btn = document.getElementById('today-share-btn');
    var status = document.getElementById('today-share-status');
    if (!btn) return;

    btn.addEventListener('click', function () {
      var shareUrl = 'https://pointcast.xyz/';
      var shareText = "PointCast · today's six things rotate at midnight PT. Come see yours.";
      try {
        if (navigator.share) {
          navigator.share({ url: shareUrl, text: shareText, title: 'PointCast · Today' })
            .then(function () { if (status) status.textContent = '✓ shared'; })
            .catch(function () { /* user cancelled; no status */ });
          return;
        }
      } catch (e) { /* fall through to clipboard */ }

      try {
        navigator.clipboard.writeText(shareUrl);
        if (status) status.textContent = '✓ link copied';
        setTimeout(function () { if (status) status.textContent = ''; }, 2400);
      } catch (e) {
        if (status) status.textContent = '(copy manually: pointcast.xyz)';
      }
    });
  })();
</script>

<style>
  .today-strip {
    margin: 14px 0;
    padding: 12px 14px 14px;
    border: 1px solid var(--pc-rule, #d6d4cd);
    border-left: 4px solid #C95C2E;
    border-radius: 3px;
    background: linear-gradient(to right, #fff6ef 0%, #fefaf3 50%, #faf9f5 100%);
  }

  .today-strip__kicker {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    margin: 0 0 10px;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .today-strip__kicker-label {
    color: #8a2432;
    font-weight: 700;
  }
  .today-strip__kicker-sub {
    color: var(--pc-ink-muted);
    font-weight: 500;
    font-size: 9.5px;
  }

  .today-strip__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 6px;
  }

  .chip {
    display: grid;
    grid-template-columns: 58px 1fr 18px;
    grid-template-rows: auto auto;
    gap: 2px 10px;
    align-items: baseline;
    padding: 9px 12px;
    border: 1px solid #d6d4cd;
    border-radius: 2px;
    background: #fff;
    text-decoration: none;
    color: #12110E;
    transition: border-color 0.12s, background 0.12s, transform 0.08s;
    cursor: pointer;
  }
  .chip:hover {
    border-color: #C95C2E;
    background: #fff6ef;
    text-decoration: none;
    transform: translateY(-1px);
  }

  .chip__eye {
    grid-column: 1;
    grid-row: 1 / span 2;
    align-self: center;
    padding: 3px 6px;
    background: #12110E;
    color: #fef5e7;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-align: center;
    border-radius: 2px;
  }
  .chip__main {
    grid-column: 2;
    grid-row: 1;
    font-family: var(--pc-font-sans, system-ui, sans-serif);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.2;
    color: #12110E;
  }
  .chip__sub {
    grid-column: 2;
    grid-row: 2;
    font-size: 9px;
    letter-spacing: 0.12em;
    color: var(--pc-ink-soft);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .chip__arrow {
    grid-column: 3;
    grid-row: 1 / span 2;
    align-self: center;
    color: #C95C2E;
    font-weight: 700;
    text-align: right;
  }

  /* Per-type eye-color variation so the grid reads as six distinct things. */
  .chip--mood .chip__eye     { background: #8a2432; }
  .chip--block .chip__eye    { background: #0B3E73; }
  .chip--station .chip__eye  { background: #332C7C; }
  .chip--namedrop .chip__eye { background: #6A2810; }
  .chip--channel .chip__eye  { background: var(--ch-600, #534AB7); }
  .chip--noun .chip__eye     { background: #534AB7; }
  .chip--term .chip__eye     { background: #0F6E56; }

  .chip--channel {
    border-color: var(--ch-600, #d6d4cd);
    background: var(--ch-50, #fff);
  }
  .chip--channel:hover {
    background: color-mix(in oklab, var(--ch-600, #C95C2E) 10%, #fff);
  }

  .today-strip__share {
    margin: 12px 0 0;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--pc-ink-muted);
    text-transform: uppercase;
  }
  .share-btn {
    padding: 5px 10px;
    border: 1px solid #12110E;
    background: #fff;
    color: #12110E;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
  }
  .share-btn:hover { background: #12110E; color: #fef5e7; }
  .share-status { color: #0F6E56; font-weight: 700; }

  .mono { font-family: var(--pc-font-mono); }

  @media (max-width: 620px) {
    .today-strip__grid { gap: 5px; }
    .chip { padding: 8px 10px; grid-template-columns: 48px 1fr 16px; }
    .chip__eye { font-size: 8px; padding: 2px 4px; }
    .chip__main { font-size: 13px; }
  }
</style>
