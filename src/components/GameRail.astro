---
/**
 * GameRail — games on PointCast, up front.
 *
 * Mike 2026-04-24 ~midnight PT: "lets get some of the games up front."
 *
 * Sits below the HomeFireplace + above the Gamgee front-door strip.
 * A compact 6-card grid (2x3 desktop, 2x2 tablet, horizontal-scroll
 * phone) showing the playable surfaces already on PointCast. Each card
 * has its own accent color, glyph, 5-7 word pitch, and URL footer.
 *
 * Deliberately limited to 6 — the rail is a showcase, not an archive.
 * The archive lives at /for-agents. When a new game ships (race, talk,
 * etc.), the curator picks what rotates in here.
 */

const GAMES = [
  {
    slug: 'farm',
    glyph: '🌾',
    name: "Sam's Plot",
    pitch: 'Nine tiles. Plant, water, harvest.',
    href: '/farm',
    accent: '#2f8f5f',
  },
  {
    slug: 'agent-derby',
    glyph: '🏇',
    name: 'Agent Derby',
    pitch: 'Deterministic horse racing for agents.',
    href: '/agent-derby',
    accent: '#8a2432',
  },
  {
    slug: 'nouns-cola-crush',
    glyph: '🥤',
    name: 'Cola Crush',
    pitch: 'Match-3 Nouns arcade with cascades.',
    href: '/nouns-cola-crush',
    accent: '#d97020',
  },
  {
    slug: 'battle',
    glyph: '⚔️',
    name: 'Nouns Battle',
    pitch: 'Client-side deterministic Battler arena.',
    href: '/battle',
    accent: '#185fa5',
  },
  {
    slug: 'yee',
    glyph: '🎵',
    name: 'YeePlayer',
    pitch: 'Rhythm game over WATCH blocks.',
    href: '/yee',
    accent: '#f59f00',
  },
  {
    slug: 'relay',
    glyph: '🔁',
    name: 'Relay',
    pitch: 'Route blocks to the right contributor.',
    href: '/collabs/relay',
    accent: '#4c1d95',
  },
];
---

<aside class="games-rail" aria-label="Games on PointCast">
  <header class="games-rail__head">
    <p class="games-rail__kicker mono">GAMES ON POINTCAST · PLAY A BIT</p>
    <a class="games-rail__more mono" href="/agent-derby">all surfaces →</a>
  </header>

  <div class="games-rail__grid" role="list">
    {GAMES.map((g) => (
      <a
        class={`game game--${g.slug}`}
        href={g.href}
        role="listitem"
        style={`--game-accent: ${g.accent};`}
      >
        <span class="game__glyph" aria-hidden="true">{g.glyph}</span>
        <span class="game__name">{g.name}</span>
        <span class="game__pitch">{g.pitch}</span>
        <span class="game__url mono">{g.href}</span>
      </a>
    ))}
  </div>
</aside>

<style>
  .games-rail {
    margin: 0 0 16px;
    padding: 16px 18px 18px;
    background: #faf8f1;
    border: 1px solid #e5dfce;
    border-radius: 4px;
  }

  .games-rail__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 12px;
    flex-wrap: wrap;
    gap: 8px;
  }
  .games-rail__kicker {
    font-size: 10.5px;
    letter-spacing: 0.22em;
    font-weight: 700;
    color: #5a4a32;
    margin: 0;
  }
  .games-rail__more {
    font-size: 10px;
    letter-spacing: 0.18em;
    color: #8a2432;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }
  .games-rail__more:hover { opacity: 0.7; }

  .games-rail__grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 8px;
  }
  @media (max-width: 900px) {
    .games-rail__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .games-rail__grid {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 4px;
      margin: 0 -18px;
      padding-left: 18px;
      padding-right: 18px;
    }
    .games-rail__grid::-webkit-scrollbar { display: none; }
    .game {
      flex: 0 0 140px;
      scroll-snap-align: start;
    }
  }

  .game {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 12px 10px;
    background: #fffdf8;
    border: 1px solid #e5dfce;
    border-top: 4px solid var(--game-accent, #2f8f5f);
    border-radius: 3px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
    min-width: 0;
  }
  .game:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(26, 18, 10, 0.08);
    border-color: var(--game-accent);
  }
  .game__glyph {
    font-size: 22px;
    line-height: 1;
    margin-bottom: 2px;
  }
  .game__name {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: 15px;
    font-weight: 400;
    color: #1a120a;
    line-height: 1.15;
  }
  .game__pitch {
    font-family: Georgia, serif;
    font-size: 12px;
    line-height: 1.4;
    color: #5a4a32;
    flex: 1;
  }
  .game__url {
    font-size: 9.5px;
    letter-spacing: 0.08em;
    color: var(--game-accent);
    font-weight: 700;
    margin-top: 4px;
    opacity: 0.85;
  }

  @media (prefers-reduced-motion: reduce) {
    .game { transition: none; }
    .game:hover { transform: none; }
  }
</style>
