---
---

<div class="relative inline-flex" data-auth-menu>
  <button
    type="button"
    class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-rule/50 bg-card/80 hover:border-warm hover:bg-card transition-colors font-mono text-[0.58rem] tracking-[0.16em] uppercase text-ink-soft hover:text-ink cursor-pointer"
    aria-haspopup="menu"
    aria-expanded="false"
    data-auth-trigger
  >
    <svg class="w-3 h-3 text-warm" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
      <circle cx="6" cy="6" r="3"></circle>
    </svg>
    <span data-auth-trigger-label>sign in</span>
  </button>

  <div
    class="hidden absolute top-full right-0 mt-2 w-72 bg-paper border border-rule rounded-lg shadow-xl z-50 overflow-hidden"
    role="menu"
    data-auth-panel
  >
    <div class="hidden p-3 border-b border-rule/30 bg-card/40" data-auth-account>
      <p class="font-mono text-[0.5rem] tracking-[0.18em] uppercase text-ink-soft/60">signed in as</p>
      <p class="text-[0.95rem] text-ink font-medium leading-tight mt-1" data-auth-user-name>—</p>
      <p class="font-mono text-[0.5rem] tracking-[0.16em] uppercase text-ink-soft/60 mt-1" data-auth-user-meta>—</p>
      <button
        type="button"
        class="mt-3 w-full px-3 py-2 rounded-md bg-paper border border-rule/40 hover:border-warm text-ink-soft hover:text-warm font-mono text-[0.58rem] tracking-[0.14em] uppercase cursor-pointer transition-colors"
        data-auth-logout
      >
        Logout
      </button>
    </div>

    <div class="divide-y divide-rule/30">
      <button
        data-provider="kukai"
        type="button"
        class="w-full flex items-start gap-3 p-3 hover:bg-card transition-colors text-left cursor-pointer"
        role="menuitem"
      >
        <span class="font-mono text-[0.58rem] tracking-[0.16em] uppercase text-warm mt-0.5 shrink-0">tz</span>
        <div class="flex-1 min-w-0">
          <p class="text-[0.9rem] text-ink font-medium leading-tight">Kukai</p>
          <p class="font-mono text-[0.5rem] tracking-[0.16em] uppercase text-ink-soft/60 mt-0.5">Tezos · live wallet sign-in</p>
        </div>
      </button>

      <button
        data-provider="google"
        type="button"
        class="w-full flex items-start gap-3 p-3 hover:bg-card transition-colors text-left cursor-pointer"
        role="menuitem"
      >
        <span class="font-mono text-[0.58rem] tracking-[0.16em] uppercase text-warm mt-0.5 shrink-0">id</span>
        <div class="flex-1 min-w-0">
          <p class="text-[0.9rem] text-ink font-medium leading-tight">Google</p>
          <p class="font-mono text-[0.5rem] tracking-[0.16em] uppercase text-ink-soft/60 mt-0.5">OAuth 2.0 redirect</p>
        </div>
        <span class="font-mono text-[0.48rem] tracking-[0.2em] uppercase text-warm/80 px-1.5 py-0.5 rounded-sm bg-warm/10 border border-warm/20">soon</span>
      </button>

      <button
        data-provider="apple"
        type="button"
        class="w-full flex items-start gap-3 p-3 hover:bg-card transition-colors text-left cursor-pointer"
        role="menuitem"
      >
        <span class="font-mono text-[0.58rem] tracking-[0.16em] uppercase text-warm mt-0.5 shrink-0">id</span>
        <div class="flex-1 min-w-0">
          <p class="text-[0.9rem] text-ink font-medium leading-tight">Apple</p>
          <p class="font-mono text-[0.5rem] tracking-[0.16em] uppercase text-ink-soft/60 mt-0.5">OAuth redirect</p>
        </div>
        <span class="font-mono text-[0.48rem] tracking-[0.2em] uppercase text-warm/80 px-1.5 py-0.5 rounded-sm bg-warm/10 border border-warm/20">soon</span>
      </button>

      <button
        data-provider="metamask"
        type="button"
        class="w-full flex items-start gap-3 p-3 hover:bg-card transition-colors text-left cursor-pointer"
        role="menuitem"
      >
        <span class="font-mono text-[0.58rem] tracking-[0.16em] uppercase text-warm mt-0.5 shrink-0">eth</span>
        <div class="flex-1 min-w-0">
          <p class="text-[0.9rem] text-ink font-medium leading-tight">MetaMask</p>
          <p class="font-mono text-[0.5rem] tracking-[0.16em] uppercase text-ink-soft/60 mt-0.5">SIWE · EVM</p>
        </div>
        <span class="font-mono text-[0.48rem] tracking-[0.2em] uppercase text-warm/80 px-1.5 py-0.5 rounded-sm bg-warm/10 border border-warm/20">soon</span>
      </button>

      <button
        data-provider="phantom"
        type="button"
        class="w-full flex items-start gap-3 p-3 hover:bg-card transition-colors text-left cursor-pointer"
        role="menuitem"
      >
        <span class="font-mono text-[0.58rem] tracking-[0.16em] uppercase text-warm mt-0.5 shrink-0">sol</span>
        <div class="flex-1 min-w-0">
          <p class="text-[0.9rem] text-ink font-medium leading-tight">Phantom</p>
          <p class="font-mono text-[0.5rem] tracking-[0.16em] uppercase text-ink-soft/60 mt-0.5">SIWS · Solana</p>
        </div>
        <span class="font-mono text-[0.48rem] tracking-[0.2em] uppercase text-warm/80 px-1.5 py-0.5 rounded-sm bg-warm/10 border border-warm/20">soon</span>
      </button>

      <button
        data-provider="temple"
        type="button"
        class="w-full flex items-start gap-3 p-3 text-left opacity-70 cursor-not-allowed"
        role="menuitem"
        disabled
      >
        <span class="font-mono text-[0.58rem] tracking-[0.16em] uppercase text-warm mt-0.5 shrink-0">tz</span>
        <div class="flex-1 min-w-0">
          <p class="text-[0.9rem] text-ink font-medium leading-tight">Temple</p>
          <p class="font-mono text-[0.5rem] tracking-[0.16em] uppercase text-ink-soft/60 mt-0.5">Tezos wallet</p>
        </div>
        <span class="font-mono text-[0.48rem] tracking-[0.2em] uppercase text-warm/80 px-1.5 py-0.5 rounded-sm bg-warm/10 border border-warm/20">soon</span>
      </button>

      <button
        data-provider="umami"
        type="button"
        class="w-full flex items-start gap-3 p-3 text-left opacity-70 cursor-not-allowed"
        role="menuitem"
        disabled
      >
        <span class="font-mono text-[0.58rem] tracking-[0.16em] uppercase text-warm mt-0.5 shrink-0">tz</span>
        <div class="flex-1 min-w-0">
          <p class="text-[0.9rem] text-ink font-medium leading-tight">Umami</p>
          <p class="font-mono text-[0.5rem] tracking-[0.16em] uppercase text-ink-soft/60 mt-0.5">Tezos wallet</p>
        </div>
        <span class="font-mono text-[0.48rem] tracking-[0.2em] uppercase text-warm/80 px-1.5 py-0.5 rounded-sm bg-warm/10 border border-warm/20">soon</span>
      </button>
    </div>

    <div class="border-t border-rule/30 px-3 py-2 bg-card/40">
      <p class="font-mono text-[0.5rem] tracking-[0.18em] uppercase text-ink-soft/60 min-h-[1.15rem]" data-auth-status>
        kukai is live. oauth + evm/solana are scaffolded next.
      </p>
    </div>
  </div>
</div>

<script>
  import type { AuthProvider, PointCastUser } from '../lib/auth/types';
  import {
    getSession,
    loginWithApple,
    loginWithGoogle,
    loginWithKukai,
    loginWithMetaMask,
    loginWithPhantom,
    logout,
  } from '../lib/auth/client';

  const actions: Record<AuthProvider, () => Promise<PointCastUser | null>> = {
    kukai: loginWithKukai,
    google: loginWithGoogle,
    apple: loginWithApple,
    metamask: loginWithMetaMask,
    phantom: loginWithPhantom,
    temple: async () => {
      throw new Error('Temple sign-in is not scaffolded yet.');
    },
    umami: async () => {
      throw new Error('Umami sign-in is not scaffolded yet.');
    },
  };

  const providerLabels: Record<AuthProvider, string> = {
    kukai: 'Kukai',
    google: 'Google',
    apple: 'Apple',
    metamask: 'MetaMask',
    phantom: 'Phantom',
    temple: 'Temple',
    umami: 'Umami',
  };

  function closeMenu(root: HTMLElement): void {
    const trigger = root.querySelector('[data-auth-trigger]') as HTMLButtonElement | null;
    const panel = root.querySelector('[data-auth-panel]') as HTMLElement | null;
    panel?.classList.add('hidden');
    trigger?.setAttribute('aria-expanded', 'false');
  }

  function openMenu(root: HTMLElement): void {
    const trigger = root.querySelector('[data-auth-trigger]') as HTMLButtonElement | null;
    const panel = root.querySelector('[data-auth-panel]') as HTMLElement | null;
    panel?.classList.remove('hidden');
    trigger?.setAttribute('aria-expanded', 'true');
  }

  function setStatus(root: HTMLElement, message: string): void {
    const status = root.querySelector('[data-auth-status]');
    if (status) status.textContent = message;
  }

  function renderSession(root: HTMLElement, user: PointCastUser | null): void {
    const triggerLabel = root.querySelector('[data-auth-trigger-label]');
    const account = root.querySelector('[data-auth-account]') as HTMLElement | null;
    const userName = root.querySelector('[data-auth-user-name]');
    const userMeta = root.querySelector('[data-auth-user-meta]');

    if (user) {
      if (triggerLabel) triggerLabel.textContent = user.preferredName || 'account';
      account?.classList.remove('hidden');
      if (userName) userName.textContent = user.preferredName;
      if (userMeta) userMeta.textContent = `${user.identities.length} linked provider${user.identities.length === 1 ? '' : 's'}`;
      return;
    }

    if (triggerLabel) triggerLabel.textContent = 'sign in';
    account?.classList.add('hidden');
    if (userName) userName.textContent = '—';
    if (userMeta) userMeta.textContent = '—';
  }

  async function refreshSession(root: HTMLElement): Promise<void> {
    try {
      renderSession(root, await getSession());
    } catch {
      renderSession(root, null);
      setStatus(root, 'session check failed');
    }
  }

  function initAuthMenu(root: HTMLElement): void {
    const trigger = root.querySelector('[data-auth-trigger]') as HTMLButtonElement | null;
    const logoutButton = root.querySelector('[data-auth-logout]') as HTMLButtonElement | null;
    const providerButtons = Array.from(root.querySelectorAll('[data-provider]')) as HTMLButtonElement[];

    trigger?.addEventListener('click', () => {
      const panel = root.querySelector('[data-auth-panel]');
      if (panel?.classList.contains('hidden')) openMenu(root);
      else closeMenu(root);
    });

    document.addEventListener('click', (event) => {
      const target = event.target as Node;
      if (!root.contains(target)) closeMenu(root);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenu(root);
    });

    logoutButton?.addEventListener('click', async () => {
      setStatus(root, 'logging out…');
      try {
        await logout();
        await refreshSession(root);
        setStatus(root, 'session cleared');
        closeMenu(root);
      } catch (error) {
        setStatus(root, error instanceof Error ? error.message : 'logout failed');
      }
    });

    providerButtons.forEach((button) => {
      button.addEventListener('click', async () => {
        if (button.disabled) return;

        const provider = button.dataset.provider as AuthProvider;
        const action = actions[provider];
        setStatus(root, `${providerLabels[provider]}…`);

        try {
          const user = await action();
          if (user) {
            renderSession(root, user);
            setStatus(root, `${providerLabels[provider]} ready`);
            closeMenu(root);
            return;
          }

          setStatus(root, `${providerLabels[provider]} redirecting…`);
        } catch (error) {
          setStatus(root, error instanceof Error ? error.message : `${providerLabels[provider]} failed`);
        }
      });
    });

    void refreshSession(root);
  }

  document.querySelectorAll('[data-auth-menu]').forEach((root) => {
    initAuthMenu(root as HTMLElement);
  });
</script>
