---
/**
 * PickleballBlock — the sport, self-contained.
 *
 * Three expandable cards: Tour (pro scene), Stat (growth/records), and
 * Local play tips. No external links — per "don't link off" direction.
 * Expand each to reveal more stats / context.
 */
---

<section class="mt-10 mb-8" id="pickleball">
  <div class="flex items-center gap-3 mb-3">
    <div class="h-px flex-1 bg-rule/40"></div>
    <h2 class="font-mono text-[0.58rem] tracking-[0.22em] uppercase text-ink-soft/60">
      Pickleball &middot; <span class="text-warm">tap to expand</span>
    </h2>
    <div class="h-px flex-1 bg-rule/40"></div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">

    <!-- PPA Tour / Pro scene -->
    <button
      type="button"
      class="pkl-card group relative rounded-xl border-2 border-ink/80 overflow-hidden p-4 text-left transition-all hover:-translate-y-0.5 bg-gradient-to-br from-[#b91c1c] to-[#7f1d1d] text-paper w-full"
      aria-expanded="false"
    >
      <p class="font-mono text-[0.5rem] tracking-[0.22em] uppercase opacity-60 mb-0.5">
        The tour
      </p>
      <h3 class="font-heading text-[1.6rem] leading-none mb-2">
        Pro scene
      </h3>
      <p class="font-serif italic text-[0.88rem] leading-snug opacity-90">
        Ben Johns is a six-time triple-crown winner. Anna Leigh Waters won
        her first pro title at twelve.
      </p>
      <div class="pkl-expanded hidden mt-3 pt-3 border-t border-current/20 space-y-2">
        <p class="font-mono text-[0.48rem] tracking-[0.18em] uppercase opacity-60 mb-0.5">Top men</p>
        <ul class="font-mono text-[0.58rem] tracking-[0.04em] space-y-0.5">
          <li class="flex justify-between gap-2"><span>1. Ben Johns</span><span class="opacity-60">#1 since 2019</span></li>
          <li class="flex justify-between gap-2"><span>2. Federico Staksrud</span><span class="opacity-60">ARG</span></li>
          <li class="flex justify-between gap-2"><span>3. Gabriel Tardio</span><span class="opacity-60">USA</span></li>
        </ul>
        <p class="font-mono text-[0.48rem] tracking-[0.18em] uppercase opacity-60 mb-0.5 mt-2">Top women</p>
        <ul class="font-mono text-[0.58rem] tracking-[0.04em] space-y-0.5">
          <li class="flex justify-between gap-2"><span>1. Anna Leigh Waters</span><span class="opacity-60">triple-crown</span></li>
          <li class="flex justify-between gap-2"><span>2. Anna Bright</span><span class="opacity-60">USA</span></li>
          <li class="flex justify-between gap-2"><span>3. Catherine Parenteau</span><span class="opacity-60">CAN</span></li>
        </ul>
      </div>
      <p class="font-mono text-[0.46rem] tracking-[0.18em] uppercase opacity-50 mt-3 pkl-hint">
        tap for rankings
      </p>
    </button>

    <!-- Growth stat card -->
    <button
      type="button"
      class="pkl-card group relative rounded-xl border-2 border-ink/80 bg-card p-4 text-left transition-all hover:-translate-y-0.5 overflow-hidden w-full"
      aria-expanded="false"
    >
      <p class="font-mono text-[0.5rem] tracking-[0.22em] uppercase text-warm mb-0.5">
        The stat
      </p>
      <h3 class="font-heading text-[2.4rem] leading-none text-ink mb-2">
        +223%
      </h3>
      <p class="font-serif italic text-[0.88rem] text-ink/80 leading-snug">
        growth in U.S. pickleball participation from 2020\u20132024. No other
        racket sport is close.
      </p>
      <div class="pkl-expanded hidden mt-3 pt-3 border-t border-rule/30 space-y-1.5">
        <div class="flex justify-between gap-2 font-mono text-[0.58rem] text-ink">
          <span class="opacity-70">Players (2024)</span><span class="tabular-nums">19.8M</span>
        </div>
        <div class="flex justify-between gap-2 font-mono text-[0.58rem] text-ink">
          <span class="opacity-70">Courts in U.S.</span><span class="tabular-nums">~49,000</span>
        </div>
        <div class="flex justify-between gap-2 font-mono text-[0.58rem] text-ink">
          <span class="opacity-70">New courts \u2014 2024</span><span class="tabular-nums">+6,300</span>
        </div>
        <div class="flex justify-between gap-2 font-mono text-[0.58rem] text-ink">
          <span class="opacity-70">Tennis courts \u2014 built 2024</span><span class="tabular-nums">~850</span>
        </div>
        <p class="font-mono text-[0.44rem] tracking-[0.16em] uppercase text-ink-soft/40 mt-2">
          source: SFIA \u00B7 APP Tour \u00B7 ITA
        </p>
      </div>
      <p class="font-mono text-[0.46rem] tracking-[0.18em] uppercase text-ink-soft/50 mt-3 pkl-hint">
        tap for the numbers
      </p>
    </button>

    <!-- Local play -->
    <button
      type="button"
      class="pkl-card group relative rounded-xl border-2 border-ink/80 overflow-hidden p-4 text-left transition-all hover:-translate-y-0.5 bg-gradient-to-br from-[#0a3d2b] to-[#0f5132] text-paper w-full"
      aria-expanded="false"
    >
      <p class="font-mono text-[0.5rem] tracking-[0.22em] uppercase opacity-60 mb-0.5">
        Get in a game
      </p>
      <h3 class="font-heading text-[1.6rem] leading-none mb-2">
        Play local
      </h3>
      <p class="font-serif italic text-[0.88rem] leading-snug opacity-90">
        Show up with a paddle, you\u2019re in a game inside ten minutes.
      </p>
      <div class="pkl-expanded hidden mt-3 pt-3 border-t border-current/20 space-y-2">
        <p class="font-mono text-[0.48rem] tracking-[0.18em] uppercase opacity-60 mb-0.5">
          South Bay (where Mike plays)
        </p>
        <ul class="font-mono text-[0.58rem] tracking-[0.04em] space-y-0.5 opacity-90">
          <li>El Segundo Rec \u00B7 4 courts \u00B7 open play weekday mornings</li>
          <li>Manhattan Beach Polliwog \u00B7 6 courts \u00B7 league + open</li>
          <li>Torrance Sports Complex \u00B7 8 courts \u00B7 lit at night</li>
        </ul>
        <p class="font-mono text-[0.48rem] tracking-[0.18em] uppercase opacity-60 mb-0.5 mt-2">
          How open-play works
        </p>
        <p class="font-serif italic text-[0.78rem] leading-snug opacity-80">
          Drop your paddle in the line-up rack. Four paddles = one game. Winners
          stay, losers split. You\u2019ll play the same people ten times in a month,
          which is how you get a real pickleball friend.
        </p>
      </div>
      <p class="font-mono text-[0.46rem] tracking-[0.18em] uppercase opacity-50 mt-3 pkl-hint">
        tap for spots + etiquette
      </p>
    </button>

  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('#pickleball .pkl-card').forEach((card) => {
    card.addEventListener('click', () => {
      const expanded = card.querySelector('.pkl-expanded') as HTMLElement | null;
      const hint = card.querySelector('.pkl-hint') as HTMLElement | null;
      if (!expanded) return;
      const nowOpen = expanded.classList.toggle('hidden') === false;
      card.setAttribute('aria-expanded', String(nowOpen));
      if (hint) hint.textContent = nowOpen ? 'tap to close' : 'tap to expand';
    });
  });
</script>
