---
/**
 * HomeFireplace v2 — with the Nouns back in.
 *
 * Mike 2026-04-23 23:50-ish PT: "more cozy, bring the nouns back in,
 * v2 of the fireplace."
 *
 * v1 shipped a warm block between masthead and Gamgee front-door.
 * v2 adds:
 *   - A Noun companion at the hearth (circular 72px portrait with
 *     warm ring glow, day-seeded so everyone sees the same Noun on
 *     the same day)
 *   - Rotating cozy copy (small set of lines, picked per hour)
 *   - Kettle-steam drift above the hearth
 *   - "KEEP GOING" label tied to the Gamgee release thesis
 *   - Subtle grain texture overlay for warmth
 *   - Better mobile layout (Noun on top, copy below)
 *
 * Still client-side time-aware. Still prefers-reduced-motion respected.
 */

// Day-seeded Noun ID so the hearth companion is consistent for everyone
// on the same calendar day but rotates. 0-1199 range matches what noun.pics
// reliably serves.
function dailyNounId(): number {
  const day = Math.floor(Date.now() / (24 * 3600 * 1000));
  const seed = (day * 2654435761) >>> 0;
  return seed % 1200;
}

const nounId = dailyNounId();
const nounUrl = `https://noun.pics/${nounId}.svg`;
---

<aside class="hearth" aria-label="Evening hearth — cozy companion to the Gamgee release">
  <div class="hearth__grain" aria-hidden="true"></div>
  <div class="hearth__glow" aria-hidden="true"></div>
  <div class="hearth__smoke" aria-hidden="true">
    <span></span><span></span><span></span>
  </div>
  <div class="hearth__embers" aria-hidden="true">
    <span></span><span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span>
  </div>

  <div class="hearth__body">

    <figure class="hearth__noun">
      <span class="hearth__noun-ring" aria-hidden="true"></span>
      <img
        class="hearth__noun-img"
        src={nounUrl}
        alt={`Noun ${nounId} sitting by the hearth`}
        width="72"
        height="72"
        loading="eager"
      />
      <figcaption class="hearth__noun-cap mono">NOUN {nounId}</figcaption>
    </figure>

    <div class="hearth__copy">
      <p class="hearth__kicker mono">
        <span class="hearth__dot"></span>
        <span id="hearth-mood">EVENING · EL SEGUNDO</span>
        <span class="hearth__sep" aria-hidden="true">·</span>
        <span class="hearth__keep">KEEP GOING</span>
      </p>
      <h2 class="hearth__line">
        <span class="hearth__sub" id="hearth-sub">Pull up a chair.</span>
        <span class="hearth__main" id="hearth-main">The kettle's on. The marine layer's in.</span>
      </h2>
      <p class="hearth__meta mono">
        <span>HOSTING TONIGHT · <span id="hearth-noun-ref">Noun {nounId}</span></span>
        <span class="hearth__sep" aria-hidden="true">·</span>
        <span>GAMGEE RC0</span>
      </p>
    </div>

    <div class="hearth__cta">
      <a href="/gandalf" class="hearth__link">
        <span class="hearth__link-glyph" aria-hidden="true">🔥</span>
        <span class="hearth__link-label mono">SIT A WHILE <span class="hearth__arrow">→</span></span>
        <span class="hearth__link-sub">/gandalf · /tonight · /meditate</span>
      </a>
    </div>
  </div>
</aside>

<script is:inline>
  (function () {
    'use strict';
    var $mood = document.getElementById('hearth-mood');
    var $sub  = document.getElementById('hearth-sub');
    var $main = document.getElementById('hearth-main');
    if (!$mood || !$sub || !$main) return;

    // Bucketed copy — each time-of-day band carries its own set of
    // coherent lines. Previous version keyed off `hour % COPY.length`
    // which would show evening-jasmine copy at 09:00 etc. (Mike caught
    // this on 2026-04-24 Fri morning: "El Segundo's cool tonight" was
    // displaying next to "MORNING LIGHT · 09:00 PT".) Now the same
    // intensity that drives the kicker also picks from its bucket.
    var COPY_BY_BUCKET = {
      smallhours: [
        { sub: 'Walk slow.',       main: 'The city is forty blocks wide and half asleep.' },
        { sub: 'Hold still.',      main: "The jasmine isn't lying — it's just been holding this note since eleven." },
        { sub: 'Keep going.',      main: 'A night build is a slow garden. Something blooms before dawn.' },
      ],
      morning: [
        { sub: 'Start gentle.',    main: 'The coffee finds its own cadence here.' },
        { sub: 'Low and forward.', main: 'Marine layer still holding past Dockweiler. The boulevards are soft.' },
        { sub: 'Open a window.',   main: 'The air is salt-fresh; you can taste it before you see the water.' },
        { sub: 'Begin small.',     main: 'A garden is slow on purpose. So is a morning.' },
      ],
      midday: [
        { sub: 'Keep the pace.',   main: 'Midday on the Strand is quieter than you remember.' },
        { sub: 'Stay loose.',      main: 'The sun is direct; the work is patient.' },
        { sub: 'Ship a thing.',    main: 'Small hands change the course because the great have other things to do.' },
        { sub: 'Walk the block.',  main: 'Main Street at one pm has a particular honesty to it.' },
      ],
      golden: [
        { sub: 'Look west.',       main: 'The light goes copper for about twelve minutes.' },
        { sub: 'Slow the turn.',   main: "Golden hour is shorter than you'd like, which is the point." },
        { sub: 'Walk toward it.',  main: 'Vista del Mar becomes a reason to be outside.' },
      ],
      blue: [
        { sub: 'Settle in.',       main: 'Blue hour lasts longer at the coast. Let it.' },
        { sub: 'Ease off.',        main: 'The boulevards are a different city after nine.' },
        { sub: 'Hold the light.',  main: "The sky hasn't decided to be dark yet. Neither have you." },
      ],
      evening: [
        { sub: 'Pull up a chair.', main: "The kettle's on. The marine layer's in." },
        { sub: 'Stoke the fire.',  main: "El Segundo's cool tonight. The jasmine is lying." },
        { sub: 'Breathe through.', main: 'The Strand is empty past the lifeguard tower. Come sit.' },
        { sub: 'Stay a while.',    main: 'The day ran long. The block still holds up.' },
      ],
    };

    // Day-index seed so everyone viewing in the same hour+day reads
    // the same line, but the variant rotates across days. Prevents the
    // home page from looking pinned.
    function daySeededIndex(length, bucketSalt) {
      var day = Math.floor(Date.now() / (24 * 3600 * 1000));
      var hour = new Date().getHours();
      var mix = ((day * 131) ^ (hour * 17) ^ bucketSalt) >>> 0;
      return mix % length;
    }

    function updateMood() {
      var now = new Date();
      var h = now.getHours() + now.getMinutes() / 60;

      var label, intensity, bucket, salt;
      if (h < 6)        { label = 'SMALL HOURS · EL SEGUNDO'; intensity = 'evening'; bucket = 'smallhours'; salt = 1; }
      else if (h < 10)  { label = 'MORNING LIGHT · EL SEGUNDO'; intensity = 'day';   bucket = 'morning';    salt = 2; }
      else if (h < 15)  { label = 'MIDDAY · EL SEGUNDO';        intensity = 'day';   bucket = 'midday';     salt = 3; }
      else if (h < 18)  { label = 'GOLDEN HOUR · EL SEGUNDO';   intensity = 'golden';bucket = 'golden';     salt = 4; }
      else if (h < 21)  { label = 'BLUE HOUR · EL SEGUNDO';     intensity = 'evening';bucket = 'blue';      salt = 5; }
      else              { label = 'EVENING · EL SEGUNDO';       intensity = 'evening';bucket = 'evening';   salt = 6; }

      $mood.textContent = label;

      var hearth = document.querySelector('.hearth');
      if (hearth) {
        hearth.setAttribute('data-mood', intensity);
        hearth.setAttribute('data-bucket', bucket);
      }

      var lines = COPY_BY_BUCKET[bucket];
      var idx = daySeededIndex(lines.length, salt);
      $sub.textContent = lines[idx].sub;
      $main.textContent = lines[idx].main;
    }

    updateMood();
    setInterval(updateMood, 60 * 1000);
  })();
</script>

<style>
  .hearth {
    position: relative;
    margin: 10px 0 14px;
    padding: 18px 22px 20px;
    background:
      radial-gradient(ellipse at 18% 100%, #3d2712 0%, transparent 70%),
      linear-gradient(180deg, #1a0e04 0%, #2a1d0b 58%, #3d2712 100%);
    border-radius: 4px;
    border: 1px solid #4e3a16;
    overflow: hidden;
    color: #f9eccf;
    min-height: 140px;
    display: flex;
    align-items: center;
    isolation: isolate;
  }
  .hearth[data-mood='day'] {
    background: linear-gradient(180deg, #2a2215 0%, #3d3220 58%, #4e3f27 100%);
    color: #e8dfc8;
  }
  .hearth[data-mood='golden'] {
    background: linear-gradient(180deg, #2d1e0c 0%, #3d2a12 58%, #4e3419 100%);
  }

  /* Grain overlay — subtle film-like noise for warmth */
  .hearth__grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(255,220,150,0.025) 0%, transparent 2%),
      radial-gradient(circle at 70% 60%, rgba(255,200,100,0.03) 0%, transparent 2%),
      radial-gradient(circle at 90% 20%, rgba(255,180,80,0.025) 0%, transparent 2%),
      radial-gradient(circle at 40% 80%, rgba(255,160,70,0.03) 0%, transparent 2%);
    background-size: 160px 160px, 200px 200px, 140px 140px, 180px 180px;
    mix-blend-mode: overlay;
    opacity: 0.7;
  }

  /* Fire glow — radial warmth from bottom */
  .hearth__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(ellipse 60% 80% at 18% 100%, rgba(255, 150, 60, 0.6) 0%, transparent 60%),
      radial-gradient(ellipse 40% 60% at 82% 100%, rgba(240, 100, 40, 0.4) 0%, transparent 55%),
      radial-gradient(ellipse 30% 40% at 50% 100%, rgba(255, 200, 100, 0.32) 0%, transparent 60%);
    animation: hearth-flicker 4.3s ease-in-out infinite;
  }
  .hearth[data-mood='day'] .hearth__glow { opacity: 0.3; }
  @keyframes hearth-flicker {
    0%, 100% { opacity: 0.9; transform: scale(1); }
    22%      { opacity: 1;   transform: scale(1.04) translateY(-1px); }
    48%      { opacity: 0.85; transform: scale(0.98); }
    70%      { opacity: 0.95; transform: scale(1.02) translateY(1px); }
  }

  /* Kettle steam — slow rising tendrils at top */
  .hearth__smoke {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 30px;
    pointer-events: none;
    z-index: 1;
    opacity: 0.7;
  }
  .hearth__smoke span {
    position: absolute;
    top: 50%;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(220, 200, 170, 0.4) 0%, transparent 70%);
    animation: smoke-drift 8s ease-in-out infinite;
    filter: blur(4px);
  }
  .hearth__smoke span:nth-child(1) { left: 10%; animation-delay: 0s; }
  .hearth__smoke span:nth-child(2) { left: 12%; animation-delay: 2.8s; }
  .hearth__smoke span:nth-child(3) { left: 8%;  animation-delay: 5.3s; }
  @keyframes smoke-drift {
    0%   { top: 10px;  opacity: 0;   transform: translateX(0) scale(0.5); }
    20%  { opacity: 0.8; }
    100% { top: -30px; opacity: 0;   transform: translateX(10px) scale(1.4); }
  }
  .hearth[data-mood='day'] .hearth__smoke { display: none; }

  /* Embers — rising from bottom */
  .hearth__embers {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }
  .hearth__embers span {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: radial-gradient(circle, #ffb060 0%, #d97020 60%, transparent 100%);
    opacity: 0;
    animation: ember-rise 4s linear infinite;
  }
  .hearth__embers span:nth-child(1) { left: 14%; animation-delay: 0s;   animation-duration: 5.2s; }
  .hearth__embers span:nth-child(2) { left: 24%; animation-delay: 1.3s; animation-duration: 4.1s; }
  .hearth__embers span:nth-child(3) { left: 36%; animation-delay: 2.2s; animation-duration: 5.8s; }
  .hearth__embers span:nth-child(4) { left: 48%; animation-delay: 0.6s; animation-duration: 4.6s; }
  .hearth__embers span:nth-child(5) { left: 62%; animation-delay: 3.1s; animation-duration: 5.3s; }
  .hearth__embers span:nth-child(6) { left: 74%; animation-delay: 1.9s; animation-duration: 4.8s; }
  .hearth__embers span:nth-child(7) { left: 84%; animation-delay: 2.7s; animation-duration: 5.0s; }
  .hearth__embers span:nth-child(8) { left: 92%; animation-delay: 0.9s; animation-duration: 4.4s; }
  @keyframes ember-rise {
    0%   { bottom: 0;   opacity: 0;   transform: translateX(0); }
    12%  { opacity: 1; }
    100% { bottom: 110%; opacity: 0; transform: translateX(-4px); }
  }
  .hearth[data-mood='day'] .hearth__embers { display: none; }

  /* Body layout — three columns desktop, stack mobile */
  .hearth__body {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 18px;
    align-items: center;
    width: 100%;
    min-width: 0;
  }
  @media (max-width: 700px) {
    .hearth__body {
      grid-template-columns: auto 1fr;
      gap: 14px;
    }
    .hearth__cta { grid-column: 1 / -1; justify-content: flex-start; }
  }
  @media (max-width: 460px) {
    .hearth__body {
      grid-template-columns: 1fr;
      gap: 12px;
      justify-items: start;
    }
    .hearth__noun { justify-self: start; }
    .hearth__cta { justify-self: start; }
  }

  /* Noun companion — circular avatar with warm ring glow */
  .hearth__noun {
    position: relative;
    width: 72px;
    height: 72px;
    margin: 0;
    flex-shrink: 0;
  }
  .hearth__noun-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: conic-gradient(from 200deg, #ff9040, #f9c56c, #ff9040, #d97020, #ff9040);
    opacity: 0.7;
    animation: noun-ring 6s linear infinite;
    filter: blur(1px);
  }
  @keyframes noun-ring {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  .hearth[data-mood='day'] .hearth__noun-ring { opacity: 0.4; animation: none; }
  .hearth__noun-img {
    position: relative;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: #1a1004;
    object-fit: cover;
    image-rendering: pixelated;
    box-shadow:
      inset 0 0 0 2px #2d1f08,
      0 0 12px rgba(255, 150, 60, 0.5);
    z-index: 1;
  }
  .hearth__noun-cap {
    position: absolute;
    left: -4px;
    right: -4px;
    bottom: -16px;
    font-size: 8.5px;
    letter-spacing: 0.14em;
    color: #f9c56c;
    text-align: center;
    font-weight: 700;
    z-index: 2;
  }
  .hearth[data-mood='day'] .hearth__noun-cap { color: #c9a872; }

  /* Copy column */
  .hearth__copy { min-width: 0; }

  .hearth__kicker {
    font-size: 10px;
    letter-spacing: 0.24em;
    font-weight: 700;
    color: #f9c56c;
    margin: 0 0 8px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .hearth[data-mood='day'] .hearth__kicker { color: #d9b570; }
  .hearth__keep {
    padding: 1px 6px;
    background: rgba(255, 200, 100, 0.15);
    border: 1px solid rgba(255, 180, 80, 0.3);
    border-radius: 2px;
    color: #ffc878;
    font-size: 9px;
    letter-spacing: 0.18em;
  }
  .hearth__sep { opacity: 0.5; }

  .hearth__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #ff9040;
    box-shadow: 0 0 8px rgba(255, 150, 80, 0.8);
    animation: dot-pulse 2.2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes dot-pulse {
    0%, 100% { opacity: 1;   transform: scale(1); }
    50%      { opacity: 0.6; transform: scale(0.85); }
  }

  .hearth__line {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-weight: 400;
    letter-spacing: 0;
    margin: 0 0 8px;
    line-height: 1.2;
    color: #fdf2d6;
  }
  .hearth[data-mood='day'] .hearth__line { color: #ece1c3; }

  .hearth__sub {
    display: block;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #f9c56c;
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, monospace;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .hearth[data-mood='day'] .hearth__sub { color: #c9a872; }

  .hearth__main {
    display: block;
    font-size: clamp(17px, 2.2vw, 22px);
    font-style: italic;
    color: #fdf2d6;
    line-height: 1.3;
  }

  .hearth__meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
    margin: 0;
    font-size: 9.5px;
    letter-spacing: 0.14em;
    color: rgba(253, 242, 214, 0.55);
    font-weight: 700;
  }

  /* CTA column */
  .hearth__cta {
    display: flex;
    justify-content: flex-end;
    min-width: 0;
  }

  .hearth__link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 16px;
    text-decoration: none;
    background: rgba(255, 200, 100, 0.1);
    border: 1px solid rgba(255, 180, 80, 0.3);
    border-radius: 3px;
    color: #fdf2d6;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
    white-space: nowrap;
  }
  .hearth__link:hover {
    background: rgba(255, 200, 100, 0.22);
    border-color: rgba(255, 200, 100, 0.55);
    transform: translateY(-1px);
  }
  .hearth__link-glyph {
    font-size: 20px;
    line-height: 1;
  }
  .hearth__link-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    letter-spacing: 0.18em;
    font-weight: 700;
    color: #ffc878;
  }
  .hearth__arrow { font-size: 14px; }
  .hearth__link-sub {
    font-family: 'JetBrains Mono Variable', ui-monospace, monospace;
    font-size: 9.5px;
    letter-spacing: 0.1em;
    color: rgba(253, 242, 214, 0.65);
  }

  @media (prefers-reduced-motion: reduce) {
    .hearth__glow { animation: none; }
    .hearth__smoke span { animation: none; display: none; }
    .hearth__embers span { animation: none; display: none; }
    .hearth__dot { animation: none; }
    .hearth__noun-ring { animation: none; }
  }
</style>
