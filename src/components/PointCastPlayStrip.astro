---
import { PLAY_SURFACES } from '../lib/play-layer';
import { DERBY_SEASON } from '../lib/agent-derby';

const primary = PLAY_SURFACES.filter((surface) =>
  ['passport', 'walk', 'quests', 'weather', 'radio', 'zen-cats', 'nouns-wood-chop', 'derby-season'].includes(surface.id),
);
---

<aside class="play-strip" aria-labelledby="play-strip-title">
  <div class="play-strip__head">
    <p class="play-strip__kicker">PLAY LAYER · TWELVE NEW LOOPS</p>
    <h2 id="play-strip-title">PointCast now has rituals, quests, cats, and route cards.</h2>
    <p>
      Passport stamps, the Daily Walk, room weather, radio bulletins, civic wishes,
      Zen Cats, Wood Chop, the pet, and {DERBY_SEASON.title} are wired through one local play layer.
    </p>
  </div>
  <nav class="play-strip__links" aria-label="PointCast play layer routes">
    {primary.map((surface) => (
      <a href={surface.route}>
        <span>{surface.code}</span>
        <strong>{surface.title}</strong>
      </a>
    ))}
    <a class="play-strip__all" href="/play">
      <span>ALL</span>
      <strong>/play</strong>
    </a>
  </nav>
</aside>

<style>
  .play-strip {
    display: grid;
    grid-template-columns: minmax(220px, 0.36fr) minmax(0, 1fr);
    gap: 16px;
    margin: 14px 0;
    padding: 14px;
    border: 1.5px solid var(--pc-ink);
    background:
      linear-gradient(135deg, rgba(24, 95, 165, 0.1), transparent 45%),
      #fffdf4;
  }

  .play-strip__kicker {
    margin: 0 0 7px;
    color: #185fa5;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .play-strip h2 {
    margin: 0;
    color: var(--pc-ink);
    font-size: 24px;
    line-height: 1.05;
    letter-spacing: 0;
    font-weight: 500;
  }

  .play-strip p {
    margin: 8px 0 0;
    color: var(--pc-ink-soft);
    font-size: 14px;
    line-height: 1.4;
  }

  .play-strip__links {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 6px;
  }

  .play-strip__links a {
    display: grid;
    gap: 6px;
    min-width: 0;
    min-height: 72px;
    padding: 9px;
    border: 1px solid var(--pc-rule);
    background: #fff;
    color: var(--pc-ink);
  }

  .play-strip__links a:hover {
    border-color: var(--pc-ink);
    background: #eef4fa;
    text-decoration: none;
  }

  .play-strip__links span {
    color: #185fa5;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    text-transform: uppercase;
  }

  .play-strip__links strong {
    min-width: 0;
    overflow-wrap: anywhere;
    font-size: 12px;
    line-height: 1.2;
    font-weight: 500;
  }

  .play-strip__all {
    background: #12110e !important;
    color: #fff !important;
  }

  .play-strip__all span {
    color: #f7d56b;
  }

  @media (max-width: 960px) {
    .play-strip {
      grid-template-columns: 1fr;
    }

    .play-strip__links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .play-strip__links {
      grid-template-columns: 1fr;
    }
  }
</style>
