---
---

<section class="relative" aria-label="Welcome">
  <div class="max-w-[34rem] mx-auto px-4 py-12 md:py-20">
    <!-- Masthead -->
    <div class="flex items-center justify-between pb-3 border-b border-rule mb-6 font-mono text-[0.66rem] tracking-[0.18em] uppercase text-ink-soft">
      <span>Mike Hoydich &times; Claude Cowork</span>
      <span class="pill"><span class="pill-dot"></span>Active</span>
    </div>

    <div class="grid md:grid-cols-3 gap-8 items-center mb-8">
      <div class="md:col-span-2">
        <div class="kicker">Publishings</div>
        <h1 class="font-heading text-5xl md:text-6xl text-ink mb-4 leading-[0.95]">
          PointCast
        </h1>
        <p class="text-[1.05rem] text-ink-soft leading-relaxed max-w-md">
          Intelligence dispatches, creative projects, and essays born from
          human-AI collaboration. Where taste meets machine.
        </p>
      </div>

      <div class="flex justify-center md:justify-end">
        <div class="border-3 border-warm p-1.5 rounded-lg shadow-[3px_3px_0_var(--color-warm)]">
          <img
            src="https://noun-api.com/beta/pfp?name=pointcast"
            alt="PointCast Noun — generative pixel art character"
            width="180"
            height="180"
            class="block rounded-md"
            style="image-rendering: pixelated;"
          />
        </div>
      </div>
    </div>

    <div class="flex flex-wrap gap-3">
      <a href="/feed"
        class="px-5 py-2.5 bg-warm text-white font-mono text-[0.7rem] tracking-[0.14em] uppercase rounded-md hover:bg-warm/90 transition-colors">
        Read the Feed
      </a>
      <a href="/nouns"
        class="px-5 py-2.5 border border-rule text-ink-soft font-mono text-[0.7rem] tracking-[0.14em] uppercase rounded-md hover:border-warm hover:text-warm transition-colors">
        &#x2310;&#x25A8;-&#x25A8; Nouns
      </a>
    </div>
  </div>
</section>

