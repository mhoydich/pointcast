---
import Noggles from './Noggles.astro';
---

<section class="relative overflow-hidden" aria-label="Welcome">
  <!-- Subtle pixel grid -->
  <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true"
    style="background-image: repeating-linear-gradient(0deg, transparent, transparent 31px, #F7C325 31px, #F7C325 32px), repeating-linear-gradient(90deg, transparent, transparent 31px, #F7C325 31px, #F7C325 32px);">
  </div>

  <div class="relative max-w-5xl mx-auto px-4 py-16 md:py-28">
    <div class="grid md:grid-cols-5 gap-10 md:gap-16 items-center">
      <!-- Left: text -->
      <div class="md:col-span-3 order-2 md:order-1">
        <p class="text-nouns-muted font-mono text-xs uppercase tracking-[0.2em] mb-4">
          Mike Hoydich &times; Claude Cowork Publishings
        </p>

        <h1 class="text-5xl md:text-7xl font-heading text-nouns-yellow nounish-glow mb-5 leading-[0.95]">
          PointCast
        </h1>

        <p class="text-lg md:text-xl text-nouns-white/80 leading-relaxed max-w-lg mb-8">
          Intelligence dispatches, creative projects, and essays born from human-AI collaboration. Where taste meets machine.
        </p>

        <div class="flex flex-wrap gap-3">
          <a href="/feed"
            class="px-6 py-3 bg-nouns-yellow text-nouns-bg font-heading text-lg rounded-xl hover:bg-nouns-yellow/90 transition-colors">
            Read the Feed
          </a>
          <a href="/nouns"
            class="px-6 py-3 border border-nouns-border text-nouns-muted font-mono text-sm rounded-xl hover:border-nouns-yellow hover:text-nouns-yellow transition-colors">
            ⌐◨-◨ Nouns
          </a>
        </div>
      </div>

      <!-- Right: featured noggles -->
      <div class="md:col-span-2 order-1 md:order-2 flex justify-center md:justify-end">
        <div class="pixel-border p-5 bg-nouns-bg-card rounded-2xl">
          <img
            src="https://noun-api.com/beta/pfp?name=pointcast"
            alt="PointCast Noun — generative pixel art character"
            width="280"
            height="280"
            class="block rounded-xl"
            style="image-rendering: pixelated;"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Ticker -->
<div class="overflow-hidden border-y border-nouns-border/50 bg-nouns-bg-card/30 py-2" aria-hidden="true">
  <div class="nouns-ticker flex gap-8 whitespace-nowrap font-mono text-xs text-nouns-muted/60">
    <span>⌐◨-◨ CC0 FOREVER</span>
    <span class="text-nouns-yellow/40">●</span>
    <span>BUILD IN PUBLIC</span>
    <span class="text-nouns-red/40">●</span>
    <span>HUMAN × AI</span>
    <span class="text-nouns-blue/40">●</span>
    <span>NOUNS.WTF</span>
    <span class="text-nouns-green/40">●</span>
    <span>ONE NOUN EVERY DAY</span>
