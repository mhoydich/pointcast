---
import Noggles from './Noggles.astro';
---

<section class="relative overflow-hidden">
  <!-- Pixel grid background -->
  <div class="absolute inset-0 opacity-5"
    style="background-image: repeating-linear-gradient(0deg, transparent, transparent 31px, #F7C325 31px, #F7C325 32px), repeating-linear-gradient(90deg, transparent, transparent 31px, #F7C325 31px, #F7C325 32px);">
  </div>

  <div class="relative max-w-4xl mx-auto px-4 py-20 md:py-32 text-center">
    <!-- Floating noggles decoration -->
    <div class="absolute top-8 left-8 opacity-10 animate-pulse hidden md:block">
      <Noggles width={60} variant="blue" />
    </div>
    <div class="absolute top-16 right-12 opacity-10 animate-pulse hidden md:block" style="animation-delay: 1s;">
      <Noggles width={45} variant="yellow" />
    </div>
    <div class="absolute bottom-12 left-16 opacity-10 animate-pulse hidden md:block" style="animation-delay: 2s;">
      <Noggles width={40} variant="black" />
    </div>

    <div class="flex justify-center mb-8">
      <div class="pixel-border p-4 bg-nouns-bg-card rounded-lg">
        <Noggles width={200} />
      </div>
    </div>

    <h1 class="text-5xl md:text-7xl font-heading text-nouns-yellow nounish-glow mb-4">
      PointCast
    </h1>

    <p class="text-lg md:text-xl text-nouns-muted font-mono max-w-xl mx-auto mb-6">
      Mike Hoydich & Claude Cowork Publishings
    </p>

    <p class="text-sm text-nouns-white/60 max-w-lg mx-auto leading-relaxed">
      Articles, projects, art, and essays born from human-AI collaboration.
      Where creative ambition meets machine intelligence. ⌐◨-◨
    </p>

    <div class="mt-10 flex justify-center gap-4">
      <a href="/feed"
        class="px-6 py-2.5 bg-nouns-yellow text-nouns-bg font-heading text-lg rounded-lg hover:bg-nouns-yellow/90 transition-colors">
        Browse Feed
      </a>
      <a href="/nouns"
        class="px-6 py-2.5 border border-nouns-red text-nouns-red font-mono text-sm rounded-lg hover:bg-nouns-red/10 transition-colors">
        ⌐◨-◨ Nouns
      </a>
      <a href="/about"
        class="px-6 py-2.5 border border-nouns-border text-nouns-muted font-mono text-sm rounded-lg hover:border-nouns-yellow hover:text-nouns-yellow transition-colors">
        About
      </a>
    </div>
  </div>
</section>

<!-- Nouns ticker -->
<div class="overflow-hidden border-y border-nouns-border bg-nouns-bg-card/50 py-2">
  <div class="nouns-ticker flex gap-8 whitespace-nowrap font-mono text-xs text-nouns-muted">
    <span>⌐◨-◨ ONE NOUN EVERY DAY</span>
    <span class="text-nouns-yellow">●</span>
    <span>CC0 · PUBLIC DOMAIN</span>
    <span class="text-nouns-red">●</span>
    <span>BUILD IN PUBLIC</span>
    <span class="text-nouns-blue">●</span>
    <span>HUMAN × AI COLLABORATION</span>
    <span class="text-nouns-green">●</span>
    <span>NOUNS.WTF</span>
    <span class="text-nouns-yellow">●</span>
    <span>⌐◨-◨ ONE NOUN EVERY DAY</span>
    <span class="text-nouns-yellow">●</span>
    <span>CC0 · PUBLIC DOMAIN</span>
    <span class="text-nouns-red">●</span>
