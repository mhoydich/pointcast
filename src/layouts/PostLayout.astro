---
import BaseLayout from './BaseLayout.astro';
import TagPill from '../components/TagPill.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  image?: string;
  tags?: string[];
}

const { title, description, date, type, image, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} image={image}>
  <article class="max-w-3xl mx-auto px-4 py-10 md:py-14" aria-label={title}>
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <TagPill tag={type} />
        <time class="text-sm text-nouns-muted font-mono" datetime={date.toISOString()}>
          {formattedDate}
        </time>
      </div>

      <h1 class="text-3xl md:text-5xl font-heading text-nouns-yellow leading-tight mb-5">
        {title}
      </h1>

      <p class="text-lg text-nouns-muted leading-relaxed">
        {description}
      </p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-5" role="list" aria-label="Tags">
          {tags.map(tag => (
            <span role="listitem" class="text-xs font-mono text-nouns-muted/60 bg-nouns-bg-elevated px-2.5 py-1 rounded-full">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {image && (
      <div class="mb-10 -mx-4 md:mx-0">
        <img
          src={image}
          alt={title}
          class="w-full rounded-none md:rounded-2xl"
        />
      </div>
    )}

    <div class="prose-nouns">
      <slot />
    </div>

    <footer class="mt-16 pt-8 border-t border-nouns-border/50">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3 text-sm text-nouns-muted">
          <span class="text-nouns-yellow font-mono">⌐◨-◨</span>
          <span>Made with Claude Cowork</span>
        </div>
        <a href="/feed" class="text-sm text-nouns-muted font-mono hover:text-nouns-yellow transition-colors">
          &larr; Feed
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>
