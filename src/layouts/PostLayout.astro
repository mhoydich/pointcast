---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  image?: string;
  tags?: string[];
}

const { title, description, date, type, image, tags = [] } = Astro.props;

const isDispatch = type === 'newsletter';
const proseClass = isDispatch ? 'prose-dispatch' : 'prose-editorial';

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const typeLabel: Record<string, string> = {
  newsletter: 'Dispatch',
  article: 'Article',
  essay: 'Essay',
  art: 'Art',
};
---

<BaseLayout title={title} description={description} image={image}>
  <article class="article-root" aria-label={title}>
    <div class="snap-container" id="snap-scroll">

      <!-- Title card -->
      <section class="snap-card" aria-label="Article header">
        <div class="max-w-[34rem] mx-auto w-full px-4">

          <!-- Masthead -->
          <div class="flex items-center justify-between pb-3 border-b border-rule mb-4 font-mono text-[0.66rem] tracking-[0.18em] uppercase text-ink-soft">
            <span>{title.length > 30 ? title.slice(0, 30) + '...' : title}</span>
            {isDispatch && (
              <span class="pill"><span class="pill-dot"></span>Active</span>
            )}
          </div>

          <div class="kicker">
            {typeLabel[type] || 'Post'}
          </div>

          <h1 class="font-serif text-[1.65rem] leading-[1.15] font-medium italic text-ink mb-3 tracking-tight">
            {title}
          </h1>

          <!-- Meta line -->
          <div class="meta-line mb-4">
            <time datetime={date.toISOString()}>
              {formattedDate}
            </time>
            <span>MH {isDispatch ? '\u00D7 Opus 4.6' : '\u00D7 Claude Cowork'}</span>
          </div>

          <p class="text-[0.95rem] text-ink-soft leading-relaxed mb-4">
            {description}
          </p>

          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-4" role="list" aria-label="Tags">
              {tags.map(tag => (
                <span role="listitem" class="font-mono text-[0.6rem] tracking-[0.14em] uppercase text-ink-soft/50">
                  #{tag}
                </span>
              ))}
            </div>
          )}

          <!-- Mobile scroll hint -->
          <div class="mt-6 text-center md:hidden scroll-hint">
            <span class="text-ink-soft/40 text-xs font-mono">swipe up</span>
            <div class="text-warm/30 text-lg mt-1">&darr;</div>
          </div>
        </div>
      </section>

      {image && (
        <section class="snap-card" aria-label="Featured image">
          <div class="max-w-[34rem] mx-auto w-full px-4">
            <img
              src={image}
              alt={title}
              class="w-full rounded-lg border border-rule"
            />
          </div>
        </section>
      )}

      <!-- Content: split into snap cards by JS on mobile -->
      <div id="article-content" class={`${proseClass} max-w-[34rem] mx-auto w-full px-4`}>
        <slot />
      </div>

      <!-- Coda card -->
      <section class="snap-card" aria-label="Article footer">
        <div class="max-w-[34rem] mx-auto w-full px-4 text-center">
          <p class="editorial-close">
            I offer no predictions. Only a careful description<br />
            of today, so tomorrow feels less like a surprise.
          </p>
          <div class="editorial-foot justify-center gap-6">
            <span class="text-warm/40">&#x2310;&#x25A8;-&#x25A8;</span>
            <span>{formattedDate} &middot; PointCast</span>
          </div>
          <a href="/" class="inline-block mt-6 px-5 py-2 border border-rule text-ink-soft font-mono text-[0.66rem] tracking-[0.18em] uppercase rounded-md hover:border-warm hover:text-warm transition-colors">
            &larr; Back to Feed
          </a>
        </div>
      </section>

    </div>

    <!-- Progress dots (mobile only) -->
    <nav class="snap-progress" id="snap-dots" aria-label="Reading progress"></nav>
  </article>
</BaseLayout>

<script>
  function initSnap() {
    const content = document.getElementById('article-content');
    const scrollContainer = document.getElementById('snap-scroll');
    const dotsContainer = document.getElementById('snap-dots');
    if (!content || !scrollContainer || !dotsContainer) return;

    const isMobile = window.matchMedia('(max-width: 767px)').matches;
    if (!isMobile) return;

    // Split content at <hr> elements (markdown ---) into sections
    const children = Array.from(content.children);
    const sections: HTMLElement[][] = [[]];

    children.forEach(child => {
      if (child.tagName === 'HR') {
        sections.push([]);
      } else {
        sections[sections.length - 1].push(child as HTMLElement);
      }
    });

    const validSections = sections.filter(s => s.length > 0);

    if (validSections.length <= 1) {
      const card = document.createElement('section');
      card.className = 'snap-card';
      const inner = document.createElement('div');
      inner.className = content.className;
      while (content.firstChild) inner.appendChild(content.firstChild);
      card.appendChild(inner);
      content.replaceWith(card);
    } else {
      const proseClass = content.classList.contains('prose-dispatch') ? 'prose-dispatch' : 'prose-editorial';
      const frag = document.createDocumentFragment();

      validSections.forEach((section, i) => {
        const card = document.createElement('section');
        card.className = 'snap-card animate-fade-up';
        card.setAttribute('aria-label', `Section ${i + 1} of ${validSections.length}`);

        const inner = document.createElement('div');
        inner.className = `max-w-[34rem] mx-auto w-full px-4 ${proseClass}`;
        section.forEach(el => inner.appendChild(el));
        card.appendChild(inner);
        frag.appendChild(card);
      });

      content.replaceWith(frag);
    }

    // Build progress dots
    const allCards = scrollContainer.querySelectorAll('.snap-card');
    dotsContainer.innerHTML = '';
    for (let i = 0; i < allCards.length; i++) {
      const dot = document.createElement('div');
      dot.className = 'snap-dot' + (i === 0 ? ' active' : '');
      dotsContainer.appendChild(dot);
    }

    // Track active card
    const dots = dotsContainer.querySelectorAll('.snap-dot');
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const idx = Array.from(allCards).indexOf(entry.target as Element);
            dots.forEach((d, i) => d.classList.toggle('active', i === idx));
          }
        });
      },
      { root: scrollContainer, threshold: 0.5 }
    );
    allCards.forEach(card => observer.observe(card));

    // Hide scroll hint after first swipe
    const hint = document.querySelector('.scroll-hint');
    if (hint) {
      scrollContainer.addEventListener('scroll', () => {
        (hint as HTMLElement).style.opacity = '0';
      }, { once: true });
    }
  }

  initSnap();
</script>
