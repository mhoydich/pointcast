---
import BaseLayout from './BaseLayout.astro';
import TagPill from '../components/TagPill.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  image?: string;
  tags?: string[];
}

const { title, description, date, image, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} image={image}>
  <!-- Mobile: hide normal header/footer, use snap scroll -->
  <!-- Desktop: normal layout -->

  <article class="dispatch-article" aria-label={title}>
    <!-- Mobile snap container wraps everything -->
    <div class="dispatch-snap-container" id="dispatch-scroll">

      <!-- Card 0: Title -->
      <section class="dispatch-snap-card" aria-label="Dispatch header">
        <div class="max-w-3xl mx-auto w-full">
          <div class="flex items-center gap-3 mb-4">
            <TagPill tag="newsletter" />
            <time class="text-sm text-nouns-muted font-mono" datetime={date.toISOString()}>
              {formattedDate}
            </time>
          </div>

          <h1 class="text-3xl md:text-5xl font-heading text-nouns-yellow leading-tight mb-5">
            {title}
          </h1>

          <p class="text-lg md:text-xl text-nouns-white/70 leading-relaxed mb-6">
            {description}
          </p>

          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-6" role="list" aria-label="Tags">
              {tags.map(tag => (
                <span role="listitem" class="text-xs font-mono text-nouns-muted/70 bg-nouns-bg-elevated px-2.5 py-1 rounded-full">
                  #{tag}
                </span>
              ))}
            </div>
          )}

          <div class="flex items-center gap-3 text-sm text-nouns-muted font-mono">
            <span class="text-nouns-yellow">MH</span>
            <span class="text-nouns-border">&times;</span>
            <span class="text-nouns-blue">Opus 4.6</span>
          </div>

          <!-- Mobile scroll hint -->
          <div class="mt-8 text-center md:hidden animate-bounce">
            <span class="text-nouns-muted/50 text-xs font-mono">swipe up</span>
            <div class="text-nouns-yellow/50 text-lg mt-1">&darr;</div>
          </div>
        </div>
      </section>

      <!-- Content cards: injected by JS from rendered markdown -->
      <div id="dispatch-content" class="prose-dispatch max-w-3xl mx-auto w-full">
        <slot />
      </div>

      <!-- Card N: Coda -->
      <section class="dispatch-snap-card" aria-label="Dispatch footer">
        <div class="max-w-3xl mx-auto w-full text-center">
          <div class="mb-8">
            <span class="text-nouns-yellow font-heading text-4xl">⌐◨-◨</span>
          </div>
          <p class="text-nouns-muted font-mono text-sm mb-2">
            Made with Claude Cowork
          </p>
          <p class="text-nouns-muted/60 font-mono text-xs">
            {formattedDate} &middot; PointCast
          </p>
          <a href="/feed" class="inline-block mt-6 px-6 py-2.5 border border-nouns-border text-nouns-muted font-mono text-sm rounded-lg hover:border-nouns-yellow hover:text-nouns-yellow transition-colors">
            &larr; Back to Feed
          </a>
        </div>
      </section>

    </div>

    <!-- Progress dots (mobile only) -->
    <nav class="dispatch-progress" id="dispatch-dots" aria-label="Dispatch sections">
    </nav>
  </article>
</BaseLayout>

<script>
  // Split rendered markdown into snap cards on mobile
  function initDispatch() {
    const content = document.getElementById('dispatch-content');
    const scrollContainer = document.getElementById('dispatch-scroll');
    const dotsContainer = document.getElementById('dispatch-dots');
    if (!content || !scrollContainer || !dotsContainer) return;

    const isMobile = window.matchMedia('(max-width: 767px)').matches;
    if (!isMobile) return;

    // Split content at <hr> elements (markdown ---) into sections
    const children = Array.from(content.children);
    const sections: HTMLElement[][] = [[]];

    children.forEach(child => {
      if (child.tagName === 'HR') {
        sections.push([]);
      } else {
        sections[sections.length - 1].push(child as HTMLElement);
      }
    });

    // Filter out empty sections
    const validSections = sections.filter(s => s.length > 0);

    if (validSections.length <= 1) return;

    // Wrap each section in a snap card
    content.innerHTML = '';
    validSections.forEach((section, i) => {
      const card = document.createElement('section');
      card.className = 'dispatch-snap-card animate-fade-up';
      card.setAttribute('aria-label', `Section ${i + 1} of ${validSections.length}`);

      const inner = document.createElement('div');
      inner.className = 'max-w-3xl mx-auto w-full prose-dispatch';
      section.forEach(el => inner.appendChild(el));
      card.appendChild(inner);
      content.appendChild(card);
    });

    // Remove the wrapper's own padding since cards handle it
    content.classList.remove('max-w-3xl', 'mx-auto', 'w-full');

    // Count all snap cards (title + content sections + coda)
    const allCards = scrollContainer.querySelectorAll('.dispatch-snap-card');
    const totalCards = allCards.length;

    // Build dots
    dotsContainer.innerHTML = '';
    for (let i = 0; i < totalCards; i++) {
      const dot = document.createElement('div');
      dot.className = 'dispatch-dot' + (i === 0 ? ' active' : '');
      dot.setAttribute('aria-label', `Section ${i + 1}`);
      dotsContainer.appendChild(dot);
    }

    // Intersection observer for active dot
    const dots = dotsContainer.querySelectorAll('.dispatch-dot');
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const idx = Array.from(allCards).indexOf(entry.target as Element);
            dots.forEach((d, i) => {
              d.classList.toggle('active', i === idx);
            });
          }
        });
      },
      {
        root: scrollContainer,
        threshold: 0.5,
      }
    );

    allCards.forEach(card => observer.observe(card));
  }

  // Run on load
  initDispatch();

  // Re-run on resize (orientation change)
  let resizeTimer: number;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => {
      location.reload(); // Simple approach for orientation changes
    }, 300);
  });
</script>
