---
import Footer from '../components/Footer.astro';
import CoNavigator from '../components/CoNavigator.astro';
import FreshnessChip from '../components/FreshnessChip.astro';
import FirstSee from '../components/FirstSee.astro';
import { ClientRouter } from 'astro:transitions';
import { DISCOVERY_LINKS, SITE_DESCRIPTION, SITE_KEYWORDS, buildIdentityJsonLd } from '../lib/seo';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  hideNav?: boolean;
  /**
   * Opt-in Farcaster Frame metadata. When provided, extra <meta> tags
   * render in the <head> so a cast containing this page's URL unfurls as
   * an interactive Frame in Warpcast (Frames v1 spec).
   * Only `/drum` uses this today.
   */
  frame?: {
    image: string;           // absolute URL to the Frame image
    postUrl: string;         // absolute URL to the Frame POST handler
    button1Label: string;    // CTA for the primary Frame button
    button2Label?: string;   // optional secondary button (link action by default)
    button2Target?: string;  // absolute URL for the link button
  };
}

const {
  title,
  description = SITE_DESCRIPTION,
  // Versioned filename busts iMessage's aggressive LinkPresentation cache —
  // any client that previously cached the old og-default.png treats this as
  // a different URL and refetches. Bump the suffix when we change the art.
  image = '/images/og-home-v3.png',
  hideNav = false,
  frame = undefined,
} = Astro.props;

const siteTitle = title === 'Home' ? 'PointCast' : `${title} | PointCast`;
const siteBase = Astro.site || 'https://pointcast.xyz';
const canonicalURL = new URL(Astro.url.pathname, siteBase);
const ogImage = image.startsWith('http') ? image : new URL(image, siteBase).href;
const identityJsonLd = buildIdentityJsonLd();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="Mike Hoydich" />
    <meta name="creator" content="Mike Hoydich" />
    <meta name="publisher" content="PointCast" />
    <meta name="keywords" content={SITE_KEYWORDS.join(', ')} />
    <meta name="application-name" content="PointCast" />
    <meta name="geo.region" content="US-CA" />
    <meta name="geo.placename" content="El Segundo, California" />
    <meta name="geo.position" content="33.9192;-118.4165" />
    <meta name="ICBM" content="33.9192, -118.4165" />
    <meta name="pc-agents-manifest" content="https://pointcast.xyz/agents.json" />
    <meta name="pc-llms" content="https://pointcast.xyz/llms.txt" />
    <meta name="llm:manifest" content="https://pointcast.xyz/agents.json" />
    <meta name="llm:summary" content="https://pointcast.xyz/llms.txt" />
    <meta name="llm:context" content="https://pointcast.xyz/llms-full.txt" />
    <!-- Mood persistence — read pc:mood from localStorage BEFORE paint
         so the page renders in the visitor's chosen mood from the first
         frame, no flicker. Per Mike 2026-04-20 13:55 PT: "rolling thru
         the site in that mood." -->
    <script is:inline>
      (function () {
        try {
          var m = localStorage.getItem('pc:mood');
          if (m) document.documentElement.setAttribute('data-pc-mood', m);
        } catch (e) {}
      })();
    </script>
    <meta name="theme-color" content="#f5efe4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#12110e" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en-US" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />
    {DISCOVERY_LINKS.map((link) => (
      <link rel={link.rel} type={link.type} href={link.href} title={link.title} />
    ))}

    <!-- Open Graph — explicit dimensions + type + secure_url dramatically
         improve unfurl reliability in iMessage (Apple's LinkPresentation
         sometimes silently drops previews when these are missing). -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={siteTitle} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PointCast" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="en_US" />

    {frame && (
      <>
        {/* Farcaster Frame v1 meta tags — renders an interactive drum-tap
            card when pointcast.xyz/drum is cast in Warpcast. */}
        <meta property="fc:frame" content="vNext" />
        <meta property="fc:frame:image" content={frame.image} />
        <meta property="fc:frame:image:aspect_ratio" content="1.91:1" />
        <meta property="fc:frame:post_url" content={frame.postUrl} />
        <meta property="fc:frame:button:1" content={frame.button1Label} />
        {frame.button2Label && frame.button2Target && (
          <>
            <meta property="fc:frame:button:2" content={frame.button2Label} />
            <meta property="fc:frame:button:2:action" content="link" />
            <meta property="fc:frame:button:2:target" content={frame.button2Target} />
          </>
        )}
      </>
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={siteTitle} />
    <meta name="twitter:site" content="@mhoydich" />

    <!-- Fonts — display swap, trimmed to 8 variants actually used -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,500&family=Outfit:wght@400&family=Syne:wght@700&family=JetBrains+Mono:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{siteTitle}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="PointCast" href="/rss.xml" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Structured data (JSON-LD) — helps search engines, LLM crawlers,
         and generative-engine citations (GEO) understand who made this
         and what it is. `@graph` pattern so all three entities (Website,
         Organization, Person) are declared in a single script without
         duplication across pages. -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(identityJsonLd)} />
    <!-- Mood tint — site-wide, paired with the mood-persistence script
         above. Moved out of MoodChip's scoped styles so the tint
         applies on every page, not just home. -->
    <style is:global>
      html[data-pc-mood="chill"]   body { background: linear-gradient(180deg, #f2f8f4 0%, transparent 260px); }
      html[data-pc-mood="hype"]    body { background: linear-gradient(180deg, #fff1f1 0%, transparent 260px); }
      html[data-pc-mood="focus"]   body { background: linear-gradient(180deg, #eef4fa 0%, transparent 260px); }
      html[data-pc-mood="flow"]    body { background: linear-gradient(180deg, #f5f0ff 0%, transparent 260px); }
      html[data-pc-mood="curious"] body { background: linear-gradient(180deg, #fff4ed 0%, transparent 260px); }
      html[data-pc-mood="quiet"]   body { background: linear-gradient(180deg, #f5f5f2 0%, transparent 260px); }
      /* Co-Navigator dock sits at the bottom of every viewport; pad body
         so footer + content don't hide under the two-row mobile control. */
      body { padding-bottom: 88px; }
      @media (max-width: 680px) {
        body { padding-bottom: 112px; }
      }
    </style>
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col bg-paper text-ink font-body">
    <!-- Skip to content (accessibility) -->
    <a href="#main-content" class="skip-link">Skip to content</a>

    <main id="main-content" class="flex-1" role="main">
      <slot />
    </main>

    <Footer />
    <CoNavigator />
    <FreshnessChip />
    <FirstSee />
  </body>
</html>
