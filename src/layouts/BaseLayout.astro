---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  hideNav?: boolean;
}

const {
  title,
  description = 'Mike Hoydich & Claude Cowork Publishings — articles, projects, art, and essays born from human-AI collaboration.',
  image = '/images/og-default.png',
  hideNav = false,
} = Astro.props;

const siteTitle = title === 'Home' ? 'PointCast' : `${title} | PointCast`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://pointcast.xyz');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#141414" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PointCast" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts — display swap for fast render -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Londrina+Solid:wght@300;400;900&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <title>{siteTitle}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Skip to content (accessibility) -->
    <a href="#main-content" class="skip-link">Skip to content</a>

    <Header />

    <main id="main-content" class="flex-1" role="main">
      <slot />
    </main>

    <Footer />
  </body>
</html>
