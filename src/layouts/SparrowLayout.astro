      .sp-dial__kicker { font-family: var(--sp-mono); font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--sp-ember); }
      .sp-dial__count { font-family: var(--sp-display); font-size: clamp(40px, 6vw, 68px); color: var(--sp-bone); line-height: 1; letter-spacing: -0.02em; }
      .sp-dial__unit { font-family: var(--sp-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sp-ash); }
      .sp-dial__needle {
        position: absolute; top: 50%; left: 50%;
        width: 2px; height: 42%;
        background: linear-gradient(to top, var(--sp-ember), transparent);
        transform-origin: 50% 100%;
        transform: translate(-50%, -100%) rotate(0deg);
        border-radius: 2px;
        animation: sp-needle-sweep 12s linear infinite;
      }
      @keyframes sp-needle-sweep {
        from { transform: translate(-50%, -100%) rotate(0deg); }
        to   { transform: translate(-50%, -100%) rotate(360deg); }
      }
      @media (prefers-reduced-motion: reduce) { .sp-dial__needle { animation: none; } }

      .sp-hero-kicker { font-family: var(--sp-mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sp-mute); margin: 0 0 14px; }
      .sp-hero-title { font-family: var(--sp-display); font-weight: 400; color: var(--sp-bone); font-size: clamp(40px, 6vw, 68px); line-height: 1.02; letter-spacing: -0.015em; margin: 0 0 18px; }
      .sp-hero-title em { color: var(--sp-ember); font-style: italic; }
      .sp-hero-dek { font-size: 16px; color: var(--sp-ash); max-width: 52ch; margin: 0 0 18px; }
      .sp-hero-meta { font-family: var(--sp-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sp-mute); margin: 0; }
      .sp-hero-meta .sp-meta-k { color: var(--sp-ash); }
      .sp-hero-meta code { text-transform: none; letter-spacing: 0; }

      .sp-pill {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 3px 10px; border-radius: 999px;
        border: 1px solid var(--sp-rule);
        font-family: var(--sp-mono); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
        color: var(--sp-ash);
      }
      .sp-pill--on { border-color: var(--sp-moss); color: var(--sp-moss); }
      .sp-pill-dot {
        width: 6px; height: 6px; border-radius: 50%;
        background: currentColor; box-shadow: 0 0 8px currentColor;
        animation: sp-pulse 2.4s ease-in-out infinite;
      }
      @keyframes sp-pulse { 50% { opacity: 0.4; } }
      @media (prefers-reduced-motion: reduce) { .sp-pill-dot { animation: none; } }

      .sp-rosette { padding: 36px 0 28px; border-bottom: 1px solid var(--sp-rule); }
      .sp-rosette-head { display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; margin-bottom: 18px; }
      .sp-rosette-hint { font-family: var(--sp-mono); font-size: 11px; color: var(--sp-mute); letter-spacing: 0.06em; }
      .sp-rosette-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; }
      .sp-petal {
        border: 1px solid var(--sp-rule); border-radius: var(--sp-rad);
        background: color-mix(in oklch, var(--sp-blue-hour) 82%, transparent);
        transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
        position: relative; overflow: hidden;
      }
      .sp-petal::before {
        content: ""; position: absolute; inset: 0;
        background: linear-gradient(135deg, color-mix(in oklch, var(--petal) 18%, transparent), transparent 60%);
        opacity: 0.6; pointer-events: none;
      }
      .sp-petal:hover { transform: translateY(-2px); border-color: var(--petal); }
      .sp-petal:hover::before { opacity: 1; }
      .sp-petal a {
        display: grid;
        grid-template-areas: "code name count" "purpose purpose purpose";
        grid-template-columns: auto 1fr auto;
        gap: 2px 10px; padding: 12px 14px;
        color: var(--sp-ash); text-decoration: none;
      }
      .sp-petal-code { grid-area: code; font-family: var(--sp-mono); font-size: 10px; letter-spacing: 0.2em; padding: 3px 6px; border: 1px solid var(--petal); color: var(--petal); border-radius: 2px; }
      .sp-petal-name { grid-area: name; font-family: var(--sp-display); color: var(--sp-bone); font-size: 17px; line-height: 1.1; align-self: end; }
      .sp-petal-count { grid-area: count; font-family: var(--sp-mono); font-size: 11px; color: var(--sp-ember); }
      .sp-petal-purpose { grid-area: purpose; font-size: 12px; color: var(--sp-mute); }

      .sp-reel { padding: 36px 0 28px; }
      .sp-reel-head { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-bottom: 18px; }
      .sp-reel-search {
        margin-left: auto; min-width: 240px; flex: 0 1 320px;
        background: color-mix(in oklch, var(--sp-blue-hour) 75%, transparent);
        border: 1px solid var(--sp-rule); border-radius: var(--sp-rad);
        padding: 8px 12px; font-family: var(--sp-mono); font-size: 12px; color: var(--sp-bone);
        transition: border-color 140ms ease;
      }
      .sp-reel-search:focus { outline: none; border-color: var(--sp-ember); }
      .sp-reel-search::placeholder { color: var(--sp-mute); }

      .sp-moods {
        display: flex; gap: 6px; flex-wrap: wrap;
        margin-bottom: 18px;
      }
      .sp-mood-chip {
        font-family: var(--sp-mono); font-size: 10px;
        letter-spacing: 0.18em; text-transform: uppercase;
        padding: 3px 9px; border-radius: 999px;
        border: 1px solid var(--sp-rule); color: var(--sp-ash);
        background: transparent; cursor: pointer;
        transition: border-color 140ms ease, color 140ms ease, background 140ms ease;
      }
      .sp-mood-chip:hover { border-color: var(--sp-ember); color: var(--sp-ember); }
      .sp-mood-chip.is-active {
        border-color: var(--sp-ember);
        background: color-mix(in oklch, var(--sp-ember) 18%, transparent);
        color: var(--sp-bone);
      }

      .sp-receipts { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; }
      .sp-receipt {
        position: relative;
        border: 1px solid var(--sp-rule); border-radius: var(--sp-rad);
        background: color-mix(in oklch, var(--sp-blue-hour) 80%, transparent);
        box-shadow: inset 3px 0 0 var(--ch, var(--sp-ember));
        overflow: hidden;
        transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
      }
      .sp-receipt:hover { transform: translateY(-2px); border-color: var(--ch, var(--sp-ember)); }
      .sp-receipt:has(a:focus-visible) { outline: 2px solid var(--ch, var(--sp-ember)); outline-offset: 2px; }
      .sp-receipt.is-now-tuned {
        border-color: var(--ch, var(--sp-ember));
        box-shadow: inset 3px 0 0 var(--ch, var(--sp-ember)), 0 0 0 1px color-mix(in oklch, var(--ch, var(--sp-ember)) 35%, transparent), 0 10px 30px color-mix(in oklch, var(--ch, var(--sp-ember)) 10%, transparent);
      }
      .sp-receipt.is-saved::after {
        content: "☆  saved";
        position: absolute; top: 8px; right: 10px;
        font-family: var(--sp-mono); font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase;
        color: var(--sp-ember);
        padding: 2px 7px; border: 1px solid var(--sp-ember);
        border-radius: 999px;
        background: color-mix(in oklch, var(--sp-ember) 12%, transparent);
      }
      .sp-receipt a { display: block; padding: 16px 18px 14px; color: var(--sp-ash); text-decoration: none; }
      .sp-r-head { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 10px; }
      .sp-r-stamp {
        display: inline-grid; grid-template-columns: auto auto;
        border: 1px dashed var(--ch);
        font-family: var(--sp-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
        border-radius: 2px; overflow: hidden;
      }
      .sp-r-stamp__ch { background: color-mix(in oklch, var(--ch) 22%, transparent); color: var(--ch); padding: 2px 6px; }
      .sp-r-stamp__type { padding: 2px 6px; color: var(--sp-ash); }
      .sp-r-meta { margin-left: auto; font-family: var(--sp-mono); font-size: 11px; color: var(--sp-mute); }
      .sp-r-id { color: var(--sp-ember); }
      .sp-r-sep { margin: 0 4px; }
      .sp-r-title { font-family: var(--sp-display); font-weight: 400; font-size: 22px; line-height: 1.15; color: var(--sp-bone); margin: 0 0 6px; letter-spacing: -0.01em; }
      .sp-r-dek { font-size: 13px; line-height: 1.5; color: var(--sp-ash); margin: 0 0 12px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
      .sp-r-foot { display: flex; align-items: center; gap: 10px; font-family: var(--sp-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--sp-mute); }
      .sp-r-bars { display: inline-flex; align-items: end; gap: 2px; height: 10px; }
      .sp-r-bars i { display: block; width: 3px; background: var(--ch); border-radius: 1px; opacity: 0.3; }
      .sp-r-bars i:nth-child(1) { height: 3px; }
      .sp-r-bars i:nth-child(2) { height: 5px; }
      .sp-r-bars i:nth-child(3) { height: 7px; }
      .sp-r-bars i:nth-child(4) { height: 9px; }
      .sp-r-bars i:nth-child(5) { height: 11px; }
      .sp-r-bars[data-bars="4"] i:nth-child(-n+4) { opacity: 1; }
      .sp-r-bars[data-bars="3"] i:nth-child(-n+3) { opacity: 1; }
      .sp-r-bars[data-bars="5"] i { opacity: 1; }
      .sp-r-channel-name { color: var(--ch); }
      .sp-r-mood code { text-transform: none; letter-spacing: 0; color: var(--sp-ash); }

      .sp-beacon {
        position: relative; display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
        padding: 14px 18px; margin: 20px 0 0;
        border: 1px solid var(--sp-rule); border-radius: var(--sp-rad);
        background: color-mix(in oklch, var(--sp-blue-hour) 80%, transparent);
        overflow: hidden;
      }
      .sp-beacon-sweep {
        position: absolute; inset: 0;
        background: linear-gradient(90deg, transparent, color-mix(in oklch, var(--sp-ember) 15%, transparent), transparent);
        transform: translateX(-100%);
        animation: sp-sweep 6s linear infinite; pointer-events: none;
      }
      @keyframes sp-sweep { to { transform: translateX(100%); } }
      @media (prefers-reduced-motion: reduce) { .sp-beacon-sweep { animation: none; opacity: 0.15; } }
      .sp-beacon-kicker { font-family: var(--sp-mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sp-ember); position: relative; }
      .sp-beacon-body { position: relative; font-size: 13px; color: var(--sp-ash); }
      .sp-beacon-cta { position: relative; margin-left: auto; font-family: var(--sp-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; }

      .sp-foot {
        margin-top: 60px; padding-top: 20px;
        border-top: 1px dotted var(--sp-rule);
        font-family: var(--sp-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--sp-mute);
      }

      .sp-palette { position: fixed; inset: 0; z-index: 50; display: grid; place-items: start center; padding-top: 18vh; }
      .sp-palette[hidden] { display: none; }
      .sp-palette-scrim { position: absolute; inset: 0; background: color-mix(in oklch, var(--sp-ink) 85%, transparent); backdrop-filter: blur(4px); }
      .sp-palette-card { position: relative; width: min(560px, 92vw); border: 1px solid var(--sp-ember); border-radius: 4px; background: var(--sp-blue-hour); box-shadow: 0 30px 80px color-mix(in oklch, var(--sp-ink) 80%, transparent); }
      .sp-palette-head { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; border-bottom: 1px dotted var(--sp-rule); }
      .sp-palette-input { width: 100%; border: none; outline: none; padding: 16px 18px; font-family: var(--sp-ui); font-size: 16px; background: transparent; color: var(--sp-bone); }
      .sp-palette-list { list-style: none; padding: 0; margin: 0; max-height: 360px; overflow-y: auto; border-top: 1px dotted var(--sp-rule); }
      .sp-palette-item { display: grid; grid-template-columns: 80px 1fr auto; gap: 12px; padding: 10px 16px; align-items: baseline; border-bottom: 1px dotted color-mix(in oklch, var(--sp-rule) 60%, transparent); cursor: pointer; }
      .sp-palette-item.is-active { background: color-mix(in oklch, var(--sp-ember) 10%, transparent); }
      .sp-palette-kind { font-family: var(--sp-mono); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--sp-ember); }
      .sp-palette-label { color: var(--sp-bone); font-size: 14px; }
      .sp-palette-hint { font-family: var(--sp-mono); font-size: 11px; color: var(--sp-mute); }
      .sp-palette-foot { padding: 10px 16px; border-top: 1px dotted var(--sp-rule); font-family: var(--sp-mono); font-size: 10px; color: var(--sp-mute); letter-spacing: 0.12em; text-transform: uppercase; }

      /* ─── v0.5 · CHEATSHEET OVERLAY ─────────────────────────────── */
      .sp-cheatsheet { position: fixed; inset: 0; z-index: 50; display: grid; place-items: start center; padding-top: 10vh; }
      .sp-cheatsheet[hidden] { display: none; }
      .sp-cheat-card {
        position: relative;
        width: min(720px, 94vw);
        border: 1px solid var(--sp-ember);
        border-radius: 4px;
        background: var(--sp-blue-hour);
        box-shadow: 0 30px 80px color-mix(in oklch, var(--sp-ink) 80%, transparent);
        max-height: 80vh;
        overflow: hidden;
        display: grid;
        grid-template-rows: auto 1fr auto;
      }
      .sp-cheat-head {
        display: flex; justify-content: space-between; align-items: center;
        padding: 12px 16px;
        border-bottom: 1px dotted var(--sp-rule);
      }
      .sp-cheat-close {
        font-family: var(--sp-mono);
        font-size: 10px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--sp-ash);
        background: transparent;
        border: 1px solid var(--sp-rule);
        border-radius: 3px;
        padding: 4px 8px;
        cursor: pointer;
        transition: border-color 140ms ease, color 140ms ease;
      }
      .sp-cheat-close:hover { border-color: var(--sp-ember); color: var(--sp-ember); }
      .sp-cheat-body {
        padding: 18px 22px;
        overflow-y: auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 24px 32px;
      }
      .sp-cheat-group h3 {
        font-family: var(--sp-mono);
        font-size: 10px;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--sp-ember);
        margin: 0 0 10px;
      }
      .sp-cheat-group dl {
        display: grid;
        grid-template-columns: minmax(110px, auto) 1fr;
        gap: 8px 14px;
        margin: 0;
      }
      .sp-cheat-group dt {
        display: flex; flex-wrap: wrap; gap: 4px;
        align-items: center;
        font-family: var(--sp-mono);
        font-size: 11px;
        color: var(--sp-bone);
      }
      .sp-cheat-group dd {
        margin: 0;
        font-size: 13px;
        color: var(--sp-ash);
        line-height: 1.4;
      }
      .sp-cheat-foot {
        padding: 10px 16px;
        border-top: 1px dotted var(--sp-rule);
        font-family: var(--sp-mono);
        font-size: 10px;
        color: var(--sp-mute);
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .sp-cheat-foot kbd { margin: 0 2px; }

      /* ─── v0.5 · COPY-AS-QUOTE CHIP ─────────────────────────────── */
      .sp-quote-chip {
        position: absolute;
        z-index: 40;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border: 1px solid var(--sp-ember);
        background: color-mix(in oklch, var(--sp-ember) 18%, var(--sp-blue-hour));
        color: var(--sp-bone);
        border-radius: 999px;
        font-family: var(--sp-mono);
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        box-shadow: 0 8px 24px color-mix(in oklch, var(--sp-ink) 70%, transparent);
        cursor: pointer;
        transition: transform 140ms ease, background 140ms ease;
      }
      .sp-quote-chip[hidden] { display: none; }
      .sp-quote-chip:hover { transform: translateY(-1px); background: color-mix(in oklch, var(--sp-ember) 28%, var(--sp-blue-hour)); }
      .sp-quote-chip.is-copied { border-color: var(--sp-moss); background: color-mix(in oklch, var(--sp-moss) 22%, var(--sp-blue-hour)); }
      .sp-quote-chip-icon { font-family: var(--sp-display); font-size: 13px; line-height: 1; color: var(--sp-ember); }
      .sp-quote-chip.is-copied .sp-quote-chip-icon { color: var(--sp-moss); }

      /* ─── v0.5 · READER TYPOGRAPHY POLISH ───────────────────────── */
      .sp-article-body { text-wrap: pretty; hanging-punctuation: first last; }
      .sp-article-body > p:first-of-type::first-letter {
        font-family: var(--sp-display);
        font-size: 4.2em;
        line-height: 0.82;
        float: left;
        margin: 0.12em 0.12em 0 -0.06em;
        padding-right: 6px;
        color: var(--sp-ember);
      }
      .sp-article-title { text-wrap: balance; }
      .sp-article-dek { text-wrap: pretty; }

      /* Reading progress bar on /sparrow/b/<id> pages. Uses the modern
         view-timeline CSS — in unsupported browsers the bar simply
         stays at its initial width (transform: scaleX(0)), which is
         graceful and invisible. */
      .sp-reading-progress {
        position: fixed;
        top: 2px; /* sits just below the global tune-progress bar */
        left: 0; right: 0;
        height: 3px;
        z-index: 19;
        background: color-mix(in oklch, var(--sp-ember) 14%, transparent);
        pointer-events: none;
      }
      .sp-reading-progress__bar {
        height: 100%;
        width: 100%;
        transform-origin: 0 50%;
        transform: scaleX(0);
        background: linear-gradient(90deg, var(--sp-ember), color-mix(in oklch, var(--sp-ember) 60%, var(--sp-bone)));
        animation: sp-read-fill linear;
        animation-timeline: --sp-read;
        animation-range: contain 0% contain 100%;
      }
      @keyframes sp-read-fill { to { transform: scaleX(1); } }
      .sp-article-body { view-timeline-name: --sp-read; view-timeline-axis: block; }
      @media (prefers-reduced-motion: reduce) {
        .sp-reading-progress__bar { animation: none; transform: scaleX(0); }
      }
      .sp-palette-foot kbd { margin: 0 2px; }

      /* ─── READER (block detail) ─────────────────────────────────── */
      .sp-reader {
        display: grid; grid-template-columns: minmax(0, 1fr) minmax(200px, 300px);
        gap: 48px; padding: 20px 0 40px;
      }
      @media (max-width: 860px) { .sp-reader { grid-template-columns: 1fr; } }
      .sp-article { min-width: 0; }
      .sp-article-head { border-bottom: 1px solid var(--sp-rule); padding-bottom: 22px; margin-bottom: 28px; }
      .sp-article-meta { display: flex; align-items: center; gap: 10px; font-family: var(--sp-mono); font-size: 11px; color: var(--sp-mute); margin-bottom: 14px; flex-wrap: wrap; }
      .sp-article-title { font-family: var(--sp-display); font-weight: 400; font-size: clamp(32px, 5vw, 56px); line-height: 1.05; color: var(--sp-bone); letter-spacing: -0.015em; margin: 0 0 16px; }
      .sp-article-dek { font-family: var(--sp-display); font-style: italic; font-size: 19px; line-height: 1.4; color: var(--sp-ash); margin: 0; max-width: 58ch; }
      .sp-article-body { font-size: 17px; line-height: 1.72; color: var(--sp-bone); max-width: 64ch; }
      .sp-article-body p { margin: 0 0 18px; }
      .sp-article-body code { color: var(--sp-ember); }
      .sp-article-body a { text-decoration: underline; text-underline-offset: 3px; }
      .sp-article-foot {
        margin-top: 42px; padding-top: 20px;
        border-top: 1px solid var(--sp-rule);
        display: flex; gap: 18px; flex-wrap: wrap; align-items: center;
        font-family: var(--sp-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
        color: var(--sp-mute);
      }
      .sp-article-foot kbd { margin: 0 2px; }
      .sp-nav-btn {
        padding: 6px 12px; border: 1px solid var(--sp-rule); border-radius: 3px;
        color: var(--sp-ash); transition: border-color 140ms ease, color 140ms ease;
      }
      .sp-nav-btn:hover { border-color: var(--sp-ember); color: var(--sp-ember); text-decoration: none; }
      .sp-save-btn {
        font-family: var(--sp-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
        padding: 6px 12px; border-radius: 3px; cursor: pointer; background: transparent;
        border: 1px solid var(--sp-ember); color: var(--sp-ember);
      }
      .sp-save-btn:hover { background: color-mix(in oklch, var(--sp-ember) 15%, transparent); }
      .is-saved .sp-save-btn { color: var(--sp-bone); background: color-mix(in oklch, var(--sp-ember) 20%, transparent); }

      .sp-aside { position: sticky; top: 84px; align-self: start; }
      .sp-aside-box { border: 1px solid var(--sp-rule); border-radius: var(--sp-rad); padding: 16px 18px; background: color-mix(in oklch, var(--sp-blue-hour) 70%, transparent); margin-bottom: 16px; }
      .sp-aside-box h3 { font-family: var(--sp-mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sp-ember); margin: 0 0 10px; }
      .sp-aside-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
      .sp-aside-list a { display: block; color: var(--sp-ash); font-size: 13px; line-height: 1.3; }
      .sp-aside-list a:hover { color: var(--sp-bone); text-decoration: none; }
      .sp-aside-mono { font-family: var(--sp-mono); font-size: 11px; color: var(--sp-mute); letter-spacing: 0.06em; }

      /* ─── v0.7 · REACTIONS ──────────────────────────────────────── */
      .sp-reactions {
        margin: 28px 0 8px;
        padding: 16px 18px;
        border: 1px solid var(--sp-rule);
        border-radius: var(--sp-rad);
        background: color-mix(in oklch, var(--sp-blue-hour) 78%, transparent);
      }
      .sp-reactions-kicker {
        font-family: var(--sp-mono);
        font-size: 10px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--sp-ember);
        display: block;
        margin-bottom: 10px;
      }
      .sp-reactions-row {
        display: flex; gap: 8px; flex-wrap: wrap;
        margin-bottom: 10px;
      }
      .sp-reactions-hint {
        font-family: var(--sp-mono);
        font-size: 10.5px;
        color: var(--sp-mute);
        letter-spacing: 0.04em;
        margin: 0;
        line-height: 1.5;
      }
      .sp-react {
        --r-accent: var(--sp-ember);
        display: inline-flex; align-items: center; gap: 8px;
        padding: 6px 14px;
        border: 1px solid var(--sp-rule);
        background: transparent;
        color: var(--sp-ash);
        border-radius: 999px;
        font-family: var(--sp-mono);
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        cursor: pointer;
        transition: border-color 140ms ease, background 140ms ease, transform 140ms ease, color 140ms ease;
      }
      .sp-react:hover {
        border-color: var(--r-accent);
        color: var(--r-accent);
        transform: translateY(-1px);
      }
      .sp-react.is-on {
        border-color: var(--r-accent);
        background: color-mix(in oklch, var(--r-accent) 22%, transparent);
        color: var(--sp-bone);
        box-shadow: 0 0 0 1px color-mix(in oklch, var(--r-accent) 40%, transparent);
      }
      .sp-react-glyph { font-size: 14px; line-height: 1; }
      .sp-react--ember { --r-accent: var(--sp-ember); }
      .sp-react--moss  { --r-accent: var(--sp-moss); }
      .sp-react--lilac { --r-accent: var(--sp-lilac); }

      /* v0.9: count badge — aggregated from relay kind-7 events, painted
         by the layout script on each chip that has seen ≥1 event. */
      .sp-react-count {
        font-family: var(--sp-mono);
        font-size: 10.5px;
        padding: 1px 6px;
        border-radius: 999px;
        background: color-mix(in oklch, var(--r-accent) 22%, var(--sp-blue-hour));
        color: var(--sp-bone);
        min-width: 18px;
        text-align: center;
        line-height: 1.2;
      }
      .sp-react.is-on .sp-react-count {
        background: color-mix(in oklch, var(--r-accent) 38%, var(--sp-blue-hour));
        color: var(--sp-bone);
      }

      /* v0.10: compact reaction-count row on receipts. Painted client-
         side by paintReelCounts as kind-7 events arrive from the pool. */
      .sp-r-react-counts {
        margin-left: auto;
        font-family: var(--sp-mono);
        font-size: 10.5px;
        letter-spacing: 0.04em;
        color: var(--sp-mute);
        padding: 2px 0;
        white-space: nowrap;
      }
      .sp-r-react-counts[hidden] { display: none; }

      /* ─── v0.11 · INLINE REPLY COMPOSER ─────────────────────────── */
      .sp-compose {
        margin: 20px 0 8px;
        padding: 0;
        border: 1px solid var(--sp-rule);
        border-radius: var(--sp-rad);
        background: color-mix(in oklch, var(--sp-blue-hour) 78%, transparent);
        overflow: hidden;
      }
      .sp-compose[open] {
        border-color: color-mix(in oklch, var(--sp-ember) 45%, var(--sp-rule));
      }
      .sp-compose-summary {
        list-style: none;
        cursor: pointer;
        padding: 14px 18px;
        display: flex; align-items: center; gap: 10px;
        font-family: var(--sp-mono);
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--sp-ash);
        transition: background 140ms ease;
      }
      .sp-compose-summary::-webkit-details-marker { display: none; }
      .sp-compose-summary::marker { display: none; }
      .sp-compose-summary:hover { background: color-mix(in oklch, var(--sp-ember) 8%, transparent); color: var(--sp-ember); }
      .sp-compose[open] .sp-compose-summary {
        border-bottom: 1px dotted var(--sp-rule);
        color: var(--sp-ember);
      }
      .sp-compose-glyph {
        font-family: var(--sp-display);
        font-size: 18px;
        line-height: 1;
        color: var(--sp-ember);
      }
      .sp-compose-label { font-weight: 600; letter-spacing: 0.18em; }
      .sp-compose-hint {
        margin-left: auto;
        font-family: var(--sp-mono);
        font-size: 10px;
        letter-spacing: 0.1em;
        color: var(--sp-mute);
        text-transform: none;
      }

      .sp-compose-body { padding: 16px 18px 18px; display: grid; gap: 12px; }
      .sp-compose-row { display: block; }
      .sp-compose-field { display: block; }
      .sp-compose-field > span {
        display: block;
        font-family: var(--sp-mono);
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--sp-mute);
        margin-bottom: 6px;
      }
      .sp-compose-field > span em {
        font-style: italic;
        color: var(--sp-ash);
        letter-spacing: 0.04em;
        text-transform: none;
      }
      .sp-compose-field input,
      .sp-compose-field textarea {
        width: 100%;
        background: color-mix(in oklch, var(--sp-blue-hour) 90%, var(--sp-ink));
        border: 1px solid var(--sp-rule);
        border-radius: var(--sp-rad);
        padding: 10px 12px;
        color: var(--sp-bone);
        font-family: var(--sp-ui);
        font-size: 14px;
        line-height: 1.5;
        resize: vertical;
        transition: border-color 140ms ease, background 140ms ease;
      }
      .sp-compose-field input:focus,
      .sp-compose-field textarea:focus {
        outline: none;
        border-color: var(--sp-ember);
        background: var(--sp-blue-hour);
      }
      .sp-compose-field textarea { min-height: 110px; }

      .sp-compose-meta {
        display: flex; flex-wrap: wrap; align-items: center; gap: 8px;
        font-family: var(--sp-mono);
        font-size: 10px;
        color: var(--sp-ash);
      }
      .sp-compose-chip {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 3px 8px;
        border: 1px dashed var(--sp-rule);
        border-radius: 999px;
      }
      .sp-compose-chip-k {
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--sp-mute);
      }
      .sp-compose-counter {
        margin-left: auto;
        font-family: var(--sp-mono);
        font-size: 10px;
        letter-spacing: 0.1em;
        color: var(--sp-mute);
      }
      .sp-compose-counter.is-over { color: var(--sp-oxblood); }

      .sp-compose-actions {
        display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
      }
      .sp-compose-submit {
        font-family: var(--sp-mono);
        font-size: 12px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 8px 16px;
        border: 1px solid var(--sp-ember);
        color: var(--sp-bone);
        background: color-mix(in oklch, var(--sp-ember) 22%, transparent);
        border-radius: 3px;
        cursor: pointer;
        transition: background 140ms ease, transform 140ms ease;
      }
      .sp-compose-submit:hover { background: color-mix(in oklch, var(--sp-ember) 36%, transparent); }
      .sp-compose-submit:disabled { opacity: 0.5; cursor: progress; transform: none; }
      .sp-compose-result {
        font-family: var(--sp-mono);
        font-size: 11px;
        color: var(--sp-mute);
      }
      .sp-compose-result[data-state="pending"] { color: var(--sp-ember); }
      .sp-compose-result[data-state="ok"]      { color: var(--sp-moss); }
      .sp-compose-result[data-state="error"]   { color: var(--sp-oxblood); }

      .sp-compose-foot {
        font-family: var(--sp-mono);
        font-size: 10.5px;
        color: var(--sp-mute);
        margin: 4px 0 0;
        line-height: 1.5;
        letter-spacing: 0.02em;
      }

      /* ─── v0.12 · MAGPIE BRIDGE AWARENESS ───────────────────────── */
      .sp-compose-bridge {
        border-top: 1px dotted var(--sp-rule);
        padding-top: 14px;
        margin-top: 4px;
        display: grid;
        gap: 10px;
      }
      .sp-compose-bridge[hidden] { display: none; }
      .sp-bridge-head {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
      }
      .sp-bridge-pill {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 3px 10px;
        border: 1px solid var(--sp-rule);
        border-radius: 999px;
        font-family: var(--sp-mono);
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--sp-mute);
      }
      .sp-bridge-dot {
        width: 6px; height: 6px; border-radius: 50%; background: currentColor;
      }
      .sp-bridge-pill[data-state="probing"]   { color: var(--sp-ember); }
      .sp-bridge-pill[data-state="probing"] .sp-bridge-dot { animation: sp-pulse 1s ease-in-out infinite; }
      .sp-bridge-pill[data-state="connected"] {
        color: var(--sp-moss); border-color: var(--sp-moss);
        background: color-mix(in oklch, var(--sp-moss) 14%, transparent);
      }
      .sp-bridge-pill[data-state="connected"] .sp-bridge-dot { box-shadow: 0 0 8px currentColor; }
      .sp-bridge-pill[data-state="offline"]   { color: var(--sp-mute); }

      .sp-bridge-cta {
        margin-left: auto;
        font-family: var(--sp-mono);
        font-size: 10px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 3px 10px;
        border: 1px solid var(--sp-rule);
        border-radius: 3px;
        color: var(--sp-ash);
        text-decoration: none;
        transition: border-color 140ms ease, color 140ms ease;
      }
      .sp-bridge-cta:hover { border-color: var(--sp-ember); color: var(--sp-ember); text-decoration: none; }

      .sp-bridge-dests {
        list-style: none; padding: 0; margin: 0; border: 0;
        display: flex; gap: 6px; flex-wrap: wrap;
      }
      .sp-bridge-dest {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 3px 10px;
        border: 1px solid var(--sp-rule);
        border-radius: 999px;
        font-family: var(--sp-mono);
        font-size: 10px;
        color: var(--sp-ash);
        cursor: pointer;
        user-select: none;
        transition: border-color 120ms ease, background 120ms ease, color 120ms ease;
      }
      .sp-bridge-dest input[type="checkbox"] {
        appearance: none;
        -webkit-appearance: none;
        width: 10px; height: 10px;
        border: 1px solid currentColor;
        border-radius: 2px;
        margin: 0;
        display: inline-grid; place-items: center;
        background: transparent;
      }
      .sp-bridge-dest input[type="checkbox"]:checked::after {
        content: "✓";
        font-size: 9px; line-height: 1;
        color: currentColor;
      }
      .sp-bridge-dest input[type="checkbox"]:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }
      .sp-bridge-dest.is-ready { border-color: var(--sp-moss); color: var(--sp-bone); }
      .sp-bridge-dest.is-ready:has(input:checked) {
        background: color-mix(in oklch, var(--sp-moss) 16%, transparent);
        border-color: var(--sp-moss);
      }
      .sp-bridge-dest.is-locked {
        background: color-mix(in oklch, var(--sp-ember) 14%, transparent);
        border-color: var(--sp-ember);
      }
      .sp-bridge-dest.is-locked .sp-bridge-dest-code { color: var(--sp-ember); }
      .sp-bridge-dest.is-dim { opacity: 0.55; border-style: dashed; cursor: not-allowed; }
      .sp-bridge-dest:hover:not(.is-dim):not(.is-locked) { border-color: var(--sp-ember); }
      .sp-bridge-dest-code {
        font-weight: 700;
        letter-spacing: 0.14em;
        color: var(--sp-ember);
      }
      .sp-bridge-dest.is-ready .sp-bridge-dest-code { color: var(--sp-moss); }
      .sp-bridge-dest-name { color: inherit; }
      .sp-bridge-dest-state {
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--sp-mute);
        font-size: 9px;
      }

      .sp-bridge-note {
        font-family: var(--sp-mono);
        font-size: 10.5px;
        color: var(--sp-mute);
        margin: 0;
        line-height: 1.5;
        letter-spacing: 0.02em;
      }

      /* ─── v0.8 · NOSTR STATUS + CONNECT ─────────────────────────── */
      .sp-reactions-head {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        margin-bottom: 10px;
      }
      .sp-reactions-head .sp-reactions-kicker { margin: 0; flex: 0 0 auto; }

      .sp-nostr-status {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 3px 10px;
        border: 1px solid var(--sp-rule);
        border-radius: 999px;
        font-family: var(--sp-mono);
        font-size: 10px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--sp-ash);
        transition: border-color 140ms ease, color 140ms ease, background 140ms ease;
      }
      .sp-nostr-dot {
        width: 6px; height: 6px; border-radius: 50%;
        background: currentColor;
      }
      .sp-nostr-status[data-state="local"]     { color: var(--sp-mute); }
      .sp-nostr-status[data-state="available"] { color: var(--sp-ember); border-color: var(--sp-ember); }
      .sp-nostr-status[data-state="connected"] {
        color: var(--sp-moss);
        border-color: var(--sp-moss);
        background: color-mix(in oklch, var(--sp-moss) 14%, transparent);
      }
      .sp-nostr-status[data-state="connected"] .sp-nostr-dot { box-shadow: 0 0 8px currentColor; }
      .sp-nostr-status[data-state="emitting"] {
        color: var(--sp-lilac);
        border-color: var(--sp-lilac);
      }
      .sp-nostr-status[data-state="emitting"] .sp-nostr-dot {
        animation: sp-pulse 1s ease-in-out infinite;
      }

      .sp-nostr-connect {
        font-family: var(--sp-mono);
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 4px 10px;
        border: 1px solid var(--sp-ember);
        color: var(--sp-ember);
        background: color-mix(in oklch, var(--sp-ember) 14%, transparent);
        border-radius: 3px;
        cursor: pointer;
        transition: background 140ms ease;
      }
      .sp-nostr-connect[hidden] { display: none; }
      .sp-nostr-connect:hover { background: color-mix(in oklch, var(--sp-ember) 24%, transparent); }

      /* ─── CHANNEL HERO (per-channel page) ────────────────────────── */
      .sp-channel-hero {
        position: relative; overflow: hidden;
        border: 1px solid var(--ch, var(--sp-ember));
        border-radius: var(--sp-rad);
        padding: 32px 32px 28px;
        background:
          linear-gradient(135deg, color-mix(in oklch, var(--ch) 16%, transparent), transparent 65%),
          color-mix(in oklch, var(--sp-blue-hour) 88%, transparent);
        margin-bottom: 28px;
      }
      .sp-channel-hero::before {
        content: ""; position: absolute; inset: -40% -10% auto auto;
        width: 420px; height: 420px; border-radius: 50%;
        background: radial-gradient(circle, color-mix(in oklch, var(--ch) 25%, transparent), transparent 65%);
        pointer-events: none;
      }
      .sp-channel-code {
        display: inline-block; font-family: var(--sp-mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
        padding: 4px 10px; border: 1px solid var(--ch); color: var(--ch); border-radius: 2px;
        margin-bottom: 14px;
      }
      .sp-channel-name { font-family: var(--sp-display); font-weight: 400; font-size: clamp(40px, 7vw, 80px); line-height: 1; color: var(--sp-bone); margin: 0 0 12px; letter-spacing: -0.02em; }
      .sp-channel-purpose { font-family: var(--sp-display); font-style: italic; font-size: 18px; color: var(--sp-ash); margin: 0 0 14px; max-width: 58ch; }
      .sp-channel-meta {
        font-family: var(--sp-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--sp-mute);
        display: flex; gap: 18px; flex-wrap: wrap; align-items: center;
      }
      .sp-channel-meta strong { color: var(--sp-ember); font-family: var(--sp-display); font-weight: 400; font-size: 20px; letter-spacing: 0; }

      /* ─── SAVED LIST ─────────────────────────────────────────────── */
      .sp-saved-empty {
        border: 1px dashed var(--sp-rule); border-radius: var(--sp-rad);
        padding: 60px 40px; text-align: center; color: var(--sp-mute);
      }
      .sp-saved-empty .sp-kicker { margin-bottom: 10px; }
      .sp-saved-empty h2 { font-family: var(--sp-display); font-weight: 400; color: var(--sp-bone); font-size: 32px; line-height: 1.1; margin: 0 0 10px; }
      .sp-saved-empty p { color: var(--sp-ash); max-width: 48ch; margin: 0 auto; }
    </style>
  </body>
</html>
