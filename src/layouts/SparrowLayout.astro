---
/**
 * SparrowLayout — shared chrome for every /sparrow/* route.
 *
 * Lives apart from BlockLayout on purpose: Sparrow runs its own design
 * system (OKLCH blue-hour palette, Gloock+Inter Tight+Departure Mono)
 * that the canonical BlockLayout can't be bent into without bleeding
 * Sparrow chrome into the /b/<id> surface.
 *
 * What it ships:
 *   · <head> with Google Fonts + view transitions router
 *   · scroll-driven tuning progress bar
 *   · HUD (crumb + wordmark + theme toggle + palette kbd + saved count)
 *   · command palette (populated from collected blocks + channels + routes)
 *   · footer
 *   · global script: theme toggle, palette, J/K glide, G+letter channel
 *     jump, 1-9 channel jump, / search focus, T theme, S save-to-list,
 *     now-tuned IntersectionObserver
 *   · global <style is:global> with all Sparrow design tokens
 *
 * Each page supplies just its <main> inner content via the default slot.
 */
import { getCollection } from 'astro:content';
import { CHANNEL_LIST } from '../lib/channels';
import { ClientRouter } from 'astro:transitions';

interface Props {
  /** Page title used for <title>. Prefix prepended automatically. */
  title: string;
  /** Page description for <meta> + palette ergonomics. */
  description?: string;
  /** Canonical URL path — passed so alternates render consistently. */
  canonicalPath?: string;
  /** Mark which route the HUD's crumb should anchor to. */
  homeHref?: string;
}

const {
  title,
  description = 'A hosted reader client for PointCast. Tune in at dawn.',
  canonicalPath = '/sparrow',
  homeHref = '/',
} = Astro.props;

const fullTitle = title === 'Sparrow' ? 'Sparrow · PointCast reader' : `${title} · Sparrow`;

// Palette data — shared across every Sparrow page so ⌘K works anywhere.
const allBlocks = (await getCollection('blocks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

const paletteData = {
  blocks: allBlocks.slice(0, 60).map((b) => ({
    id: b.data.id,
    title: b.data.title,
    ch: b.data.channel,
    type: b.data.type,
    url: `/sparrow/b/${b.data.id}`,
  })),
  channels: CHANNEL_LIST.map((c) => ({
    code: c.code,
    name: c.name,
    slug: c.slug,
    purpose: c.purpose,
  })),
  routes: [
    { label: 'sparrow — reader home', url: '/sparrow' },
    { label: 'about — features + roadmap', url: '/sparrow/about' },
    { label: 'connect — native macOS companion', url: '/sparrow/connect' },
    { label: 'memo — technical memorandum (deck)', url: '/sparrow/deck' },
    { label: 'saved — your reading list', url: '/sparrow/saved' },
    { label: 'magpie — publisher', url: '/magpie' },
    { label: '/tv — live broadcast', url: '/tv' },
    { label: '/beacon — location pulse', url: '/beacon' },
    { label: '/mesh — federation', url: '/mesh' },
    { label: '/for-agents — agent front door', url: '/for-agents' },
    { label: 'pointcast — canonical', url: '/' },
  ],
};
---

<!doctype html>
<html lang="en" data-theme="blue-hour">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`https://pointcast.xyz${canonicalPath}`} />
    {/* SEO hreflang — parity with the rest of the site. */}
    <link rel="alternate" hreflang="en-US" href={`https://pointcast.xyz${canonicalPath}`} />
    <link rel="alternate" hreflang="x-default" href={`https://pointcast.xyz${canonicalPath}`} />
    <link rel="alternate" type="application/json" href="/sparrow.json" title="Sparrow manifest" />
    <link rel="alternate" type="application/atom+xml" href="/sparrow/feed.xml" title="Sparrow Atom feed" />

    <!-- PWA: installable app with its own scoped service worker. -->
    <link rel="manifest" href="/sparrow/manifest.webmanifest" />
    <meta name="theme-color" content="#16182a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f4ead8" media="(prefers-color-scheme: light)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Sparrow" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Gloock&family=Inter+Tight:wght@400;500;600;700&family=Departure+Mono&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>
  <body>
    <div class="sp-tune-progress" aria-hidden="true"><div class="sp-tune-progress__bar"></div></div>

    <main class="sp-root">
      <header class="sp-hud">
        <nav class="sp-crumb"><a href={homeHref}>{homeHref === '/' ? '←  pointcast' : '←  sparrow'}</a></nav>
        <div class="sp-wordmark">
          <a href="/sparrow" class="sp-wordmark-link">
            <span class="sp-glyph" aria-hidden="true">✦</span>
            <span class="sp-name">Sparrow</span>
          </a>
          <span class="sp-sub">pointcast reader · v0.16</span>
        </div>
        <div class="sp-hud-actions">
          <span class="sp-offline-pill" data-sp-offline-pill hidden aria-live="polite">
            <span class="sp-offline-dot" aria-hidden="true"></span>offline
          </span>
          <button class="sp-install-btn" type="button" data-sp-install hidden aria-label="install Sparrow">
            install ↓
          </button>
          <a href="/sparrow/saved" class="sp-saved-count" data-sp-saved-count aria-label="reading list">
            <span class="sp-saved-icon" aria-hidden="true">☆</span>
            <span class="sp-saved-n" data-sp-saved-n>0</span>
          </a>
          <kbd class="sp-kbd" data-sp-palette-open>⌘K</kbd>
          <button class="sp-theme-toggle" type="button" data-sp-theme-toggle aria-label="toggle theme">
            <span class="sp-theme-dot"></span>
          </button>
        </div>
      </header>

      <slot />

      <footer class="sp-foot">
        <span>sparrow · a reader for <a href="/" class="sp-link">pointcast.xyz</a></span>
        <span class="sp-meta-sep">·</span>
        <span>sibling to <a href="/magpie" class="sp-link">magpie</a></span>
        <span class="sp-meta-sep">·</span>
        <a href="/sparrow.json" class="sp-link">manifest</a>
        <span class="sp-meta-sep">·</span>
        <a href="/sparrow/feed.xml" class="sp-link">atom</a>
      </footer>
    </main>

    <div class="sp-palette" data-sp-palette hidden>
      <div class="sp-palette-scrim" data-sp-palette-close></div>
      <div class="sp-palette-card" role="dialog" aria-label="command palette">
        <header class="sp-palette-head">
          <span class="sp-kicker">✦ command</span>
          <kbd>esc</kbd>
        </header>
        <input
          type="search"
          class="sp-palette-input"
          placeholder="jump to a block, channel, or route"
          data-sp-palette-input
          autocomplete="off"
          spellcheck="false"
        />
        <ul class="sp-palette-list" data-sp-palette-list></ul>
        <footer class="sp-palette-foot">
          <kbd>↑↓</kbd> navigate · <kbd>↵</kbd> go · <kbd>esc</kbd> close
        </footer>
      </div>
    </div>

    {/* v0.5: keyboard cheatsheet — opens on `?`. Read-only reference —
        the palette is for doing, this is for remembering. */}
    <div class="sp-cheatsheet" data-sp-cheatsheet hidden>
      <div class="sp-palette-scrim" data-sp-cheatsheet-close></div>
      <div class="sp-cheat-card" role="dialog" aria-label="keyboard shortcuts">
        <header class="sp-cheat-head">
          <span class="sp-kicker">✦ keyboard · sparrow shortcuts</span>
          <button class="sp-cheat-close" type="button" data-sp-cheatsheet-close aria-label="close">esc ✕</button>
        </header>
        <div class="sp-cheat-body">
          <section class="sp-cheat-group">
            <h3>Discovery</h3>
            <dl>
              <dt><kbd>⌘K</kbd> / <kbd>Ctrl+K</kbd></dt><dd>open the command palette</dd>
              <dt><kbd>/</kbd></dt><dd>focus the reel search</dd>
              <dt><kbd>1</kbd>…<kbd>9</kbd></dt><dd>jump to channel by index (1=FD … 9=BTL)</dd>
              <dt><kbd>G</kbd> <kbd>F</kbd>…<kbd>G</kbd> <kbd>B</kbd></dt><dd>jump to channel by first letter</dd>
            </dl>
          </section>
          <section class="sp-cheat-group">
            <h3>Reading</h3>
            <dl>
              <dt><kbd>J</kbd></dt><dd>next receipt (reel) / older block (reader)</dd>
              <dt><kbd>K</kbd></dt><dd>previous receipt / newer block</dd>
              <dt><kbd>S</kbd></dt><dd>save or unsave the focused / now-tuned block</dd>
              <dt><kbd>0</kbd></dt><dd>jump to top of page</dd>
              <dt><kbd>$</kbd></dt><dd>jump to bottom of page</dd>
            </dl>
          </section>
          <section class="sp-cheat-group">
            <h3>Display</h3>
            <dl>
              <dt><kbd>T</kbd></dt><dd>toggle theme (blue-hour ↔ dawn)</dd>
              <dt><kbd>?</kbd></dt><dd>show this cheatsheet</dd>
              <dt><kbd>Esc</kbd></dt><dd>close overlays</dd>
            </dl>
          </section>
          <section class="sp-cheat-group">
            <h3>Reader extras</h3>
            <dl>
              <dt>select text</dt><dd>a ✎ chip appears — click to copy a quote block with attribution</dd>
              <dt>hover receipt</dt><dd>prefetches the reader page so click/J/K feels instant</dd>
            </dl>
          </section>
        </div>
        <footer class="sp-cheat-foot">
          <span class="sp-aside-mono">press <kbd>?</kbd> anywhere in Sparrow to re-open</span>
        </footer>
      </div>
    </div>

    {/* v0.5: floating "copy as quote" chip shown near text selection
        inside a block reader. Populated + positioned by the script. */}
    <button
      type="button"
      class="sp-quote-chip"
      data-sp-quote-chip
      hidden
      aria-label="copy selection as attributed quote"
    >
      <span class="sp-quote-chip-icon" aria-hidden="true">✎</span>
      copy as quote
    </button>

    <script
      is:inline
      type="application/json"
      id="sp-palette-data"
      set:html={JSON.stringify(paletteData)}
    />

    <script is:inline>
      (() => {
        const KEY_THEME = 'sparrow:theme';
        const KEY_SAVED = 'sparrow:saved';
        const KEY_VISITED = 'sparrow:visited';
        const KEY_REACTIONS = 'sparrow:reactions';
        const VISITED_MAX = 120;
        const htmlEl = document.documentElement;

        // ─── THEME ──────────────────────────────────────────────────
        const savedTheme = localStorage.getItem(KEY_THEME);
        if (savedTheme === 'dawn' || savedTheme === 'blue-hour') {
          htmlEl.dataset.theme = savedTheme;
        }
        const toggleTheme = () => {
          const next = htmlEl.dataset.theme === 'dawn' ? 'blue-hour' : 'dawn';
          htmlEl.dataset.theme = next;
          localStorage.setItem(KEY_THEME, next);
        };
        document.querySelector('[data-sp-theme-toggle]')?.addEventListener('click', toggleTheme);

        // ─── READING LIST ───────────────────────────────────────────
        const readSaved = () => {
          try { return JSON.parse(localStorage.getItem(KEY_SAVED) || '[]'); } catch { return []; }
        };
        const writeSaved = (ids, opts = {}) => {
          localStorage.setItem(KEY_SAVED, JSON.stringify(ids));
          const el = document.querySelector('[data-sp-saved-n]');
          if (el) el.textContent = String(ids.length);
          // Reflect save state on any visible receipts (channel/reader too).
          document.querySelectorAll('[data-sp-block-id]').forEach((node) => {
            const id = node.getAttribute('data-sp-block-id');
            node.classList.toggle('is-saved', ids.includes(id));
          });
          // v0.15: mirror to Magpie peer-node when the bridge is up.
          // opts.skipMirror is set on pulls (so we don't loop), not on
          // user-driven toggles. Debounced to batch rapid toggles.
          if (!opts.skipMirror) scheduleReaderMirror();
        };
        const toggleSaved = (id) => {
          if (!id) return;
          const list = readSaved();
          const i = list.indexOf(id);
          if (i === -1) list.unshift(id); else list.splice(i, 1);
          writeSaved(list);
        };
        // Initial hydrate
        writeSaved(readSaved());
        // Delegate click on .sp-save-btn
        document.addEventListener('click', (e) => {
          const btn = e.target.closest('[data-sp-save]');
          if (btn) { e.preventDefault(); toggleSaved(btn.getAttribute('data-sp-save')); }
        });

        // ─── COMMAND PALETTE ────────────────────────────────────────
        const palette = document.querySelector('[data-sp-palette]');
        const paletteInput = document.querySelector('[data-sp-palette-input]');
        const paletteList = document.querySelector('[data-sp-palette-list]');
        const dataEl = document.getElementById('sp-palette-data');
        let DATA = { blocks: [], channels: [], routes: [] };
        try { DATA = JSON.parse(dataEl?.textContent || '{}'); } catch {}

        let activeIdx = 0;
        let items = [];
        const score = (hay, q) => {
          hay = (hay || '').toLowerCase(); q = q.toLowerCase().trim();
          if (!q) return 0.5;
          if (hay.startsWith(q)) return 3;
          if (hay.includes(q)) return 2;
          const tokens = q.split(/\s+/).filter(Boolean);
          return tokens.reduce((s, t) => s + (hay.includes(t) ? 1 : 0), 0);
        };
        const render = (q) => {
          const scored = [];
          for (const r of DATA.routes) {
            const s = score(r.label, q);
            if (s > 0) scored.push({ kind: 'route', label: r.label, hint: r.url, url: r.url, s });
          }
          for (const c of DATA.channels) {
            const s = Math.max(score(c.name, q), score(c.code, q), score(c.purpose, q));
            if (s > 0) scored.push({ kind: 'channel', label: `${c.code} · ${c.name}`, hint: c.purpose, url: `/sparrow/ch/${c.slug}`, s });
          }
          for (const b of DATA.blocks) {
            const s = Math.max(score(b.title, q), score(b.id, q), score(b.ch, q));
            if (s > 0) scored.push({ kind: 'block', label: `№ ${b.id} · ${b.title}`, hint: `${b.ch} · ${b.type}`, url: b.url, s });
          }
          scored.sort((a, b) => b.s - a.s);
          items = scored.slice(0, 12);
          activeIdx = 0;
          paletteList.innerHTML = items
            .map((it, i) => `
              <li class="sp-palette-item ${i === 0 ? 'is-active' : ''}" data-i="${i}" data-url="${it.url}">
                <span class="sp-palette-kind">${it.kind}</span>
                <span class="sp-palette-label">${it.label}</span>
                <span class="sp-palette-hint">${it.hint ?? ''}</span>
              </li>`)
            .join('');
        };
        const showPalette = () => {
          palette.hidden = false;
          requestAnimationFrame(() => paletteInput.focus());
          render('');
        };
        const hidePalette = () => { palette.hidden = true; paletteInput.value = ''; };
        const setActive = (i) => {
          const lis = paletteList.querySelectorAll('.sp-palette-item');
          lis.forEach((li, idx) => li.classList.toggle('is-active', idx === i));
          activeIdx = i;
          lis[i]?.scrollIntoView({ block: 'nearest' });
        };
        const go = () => { const pick = items[activeIdx]; if (pick?.url) window.location.href = pick.url; };

        document.querySelector('[data-sp-palette-open]')?.addEventListener('click', showPalette);
        document.querySelector('[data-sp-palette-close]')?.addEventListener('click', hidePalette);
        paletteInput?.addEventListener('input', (e) => render(e.target.value));
        paletteInput?.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowDown') { e.preventDefault(); setActive(Math.min(items.length - 1, activeIdx + 1)); }
          else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(Math.max(0, activeIdx - 1)); }
          else if (e.key === 'Enter') { e.preventDefault(); go(); }
          else if (e.key === 'Escape') { e.preventDefault(); hidePalette(); }
        });
        paletteList?.addEventListener('click', (e) => {
          const li = e.target.closest('.sp-palette-item');
          if (li) { activeIdx = Number(li.dataset.i || 0); go(); }
        });

        // ─── REEL SEARCH + KEYBOARD ─────────────────────────────────
        const searchEl = document.querySelector('[data-sp-search]');
        const receipts = () => Array.from(document.querySelectorAll('[data-sp-receipts] .sp-receipt'));
        searchEl?.addEventListener('input', (e) => {
          const q = e.target.value.toLowerCase().trim();
          receipts().forEach((r) => {
            const text = r.textContent?.toLowerCase() ?? '';
            r.hidden = q.length > 0 && !text.includes(q);
          });
        });

        const channelByDigit = {
          '1': 'front-door', '2': 'court', '3': 'spinning', '4': 'good-feels',
          '5': 'garden', '6': 'el-segundo', '7': 'faucet', '8': 'visit', '9': 'battler',
        };

        let gPending = false, gTimer = null, focused = 0;
        const focusReceipt = (delta) => {
          const rs = receipts().filter((r) => !r.hidden);
          if (!rs.length) return;
          focused = (focused + delta + rs.length) % rs.length;
          rs[focused].querySelector('a')?.focus();
        };

        document.addEventListener('keydown', (e) => {
          const inField =
            ['INPUT', 'TEXTAREA', 'SELECT'].includes(e.target?.tagName) ||
            e.target?.isContentEditable;

          if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
            e.preventDefault(); showPalette(); return;
          }
          if (inField) return;

          // 1-9 direct channel jumps
          if (channelByDigit[e.key]) {
            e.preventDefault();
            window.location.href = `/sparrow/ch/${channelByDigit[e.key]}`;
            return;
          }

          // v0.5: cheatsheet on `?` (shift-/)
          if (e.key === '?') {
            e.preventDefault();
            showCheatsheet();
            return;
          }

          // v0.5: scroll jumps — 0 to top, $ (shift-4) to bottom
          if (e.key === '0') {
            e.preventDefault();
            window.scrollTo({ top: 0, behavior: 'smooth' });
            return;
          }
          if (e.key === '$') {
            e.preventDefault();
            window.scrollTo({ top: document.documentElement.scrollHeight, behavior: 'smooth' });
            return;
          }

          const k = e.key.toLowerCase();
          if (k === 'j') { e.preventDefault(); focusReceipt(1); }
          else if (k === 'k') { e.preventDefault(); focusReceipt(-1); }
          else if (k === '/') { e.preventDefault(); (searchEl || paletteInput)?.focus(); }
          else if (k === 't') { toggleTheme(); }
          else if (k === 's') {
            // Save currently focused/tuned receipt.
            const here =
              document.activeElement?.closest('[data-sp-block-id]') ||
              document.querySelector('[data-sp-block-id].is-now-tuned');
            const id = here?.getAttribute('data-sp-block-id');
            if (id) { e.preventDefault(); toggleSaved(id); }
          }
          else if (k === 'g') {
            gPending = true;
            clearTimeout(gTimer);
            gTimer = setTimeout(() => { gPending = false; }, 900);
          } else if (gPending) {
            const letter = k;
            const found = DATA.channels.find(
              (c) => c.code.toLowerCase().startsWith(letter) || c.name.toLowerCase().startsWith(letter),
            );
            gPending = false; clearTimeout(gTimer);
            if (found) { e.preventDefault(); window.location.href = `/sparrow/ch/${found.slug}`; }
          }
        });

        // ─── CHEATSHEET OVERLAY (? key) ──────────────────────────────
        const cheatsheet = document.querySelector('[data-sp-cheatsheet]');
        const showCheatsheet = () => { if (cheatsheet) cheatsheet.hidden = false; };
        const hideCheatsheet = () => { if (cheatsheet) cheatsheet.hidden = true; };
        document.querySelectorAll('[data-sp-cheatsheet-close]').forEach((el) =>
          el.addEventListener('click', hideCheatsheet),
        );
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && cheatsheet && !cheatsheet.hidden) hideCheatsheet();
        });

        // ─── HOVER / IDLE PREFETCH ───────────────────────────────────
        // Hovering a receipt gets the browser to pre-fetch the block
        // reader. Combined with the SW cache-first runtime strategy,
        // J/K paging and click-through feel instant.
        const prefetched = new Set();
        const prefetchUrl = (url) => {
          if (!url || prefetched.has(url)) return;
          prefetched.add(url);
          const link = document.createElement('link');
          link.rel = 'prefetch';
          link.href = url;
          link.as = 'document';
          document.head.appendChild(link);
        };
        document.addEventListener('mouseover', (e) => {
          const a = e.target?.closest?.('[data-sp-block-id] a[href^="/sparrow/b/"]');
          if (a) prefetchUrl(a.getAttribute('href'));
        });
        document.addEventListener('focusin', (e) => {
          const a = e.target?.closest?.('[data-sp-block-id] a[href^="/sparrow/b/"]');
          if (a) prefetchUrl(a.getAttribute('href'));
        });

        // ─── COPY-AS-QUOTE (reader pages only) ───────────────────────
        // When the user highlights text inside .sp-article-body, float
        // an ember chip near the end of the selection. Click: copy a
        // quote block with attribution (title · № · canonical URL).
        const quoteChip = document.querySelector('[data-sp-quote-chip]');
        const articleEl = () => document.querySelector('.sp-article-body');
        let lastQuote = null;
        const positionChip = () => {
          const sel = window.getSelection();
          if (!quoteChip || !articleEl()) return;
          const text = (sel?.toString() || '').trim();
          if (!sel || !text || text.length < 6 || sel.rangeCount === 0) {
            quoteChip.hidden = true; lastQuote = null; return;
          }
          const range = sel.getRangeAt(0);
          if (!articleEl().contains(range.commonAncestorContainer)) {
            quoteChip.hidden = true; lastQuote = null; return;
          }
          const rect = range.getBoundingClientRect();
          quoteChip.hidden = false;
          quoteChip.style.top = `${window.scrollY + rect.bottom + 8}px`;
          quoteChip.style.left = `${Math.max(
            8,
            window.scrollX + Math.min(rect.right, window.innerWidth - 180) - 160,
          )}px`;
          lastQuote = text;
        };
        document.addEventListener('selectionchange', positionChip);
        window.addEventListener('scroll', () => {
          if (!quoteChip?.hidden) positionChip();
        }, { passive: true });
        quoteChip?.addEventListener('click', async () => {
          if (!lastQuote) return;
          const idMatch = location.pathname.match(/^\/sparrow\/b\/(\d{3,})/);
          const id = idMatch ? idMatch[1] : '';
          const title = document.querySelector('.sp-article-title')?.textContent?.trim() || 'PointCast block';
          const url = id ? `https://pointcast.xyz/b/${id}` : location.href;
          const quote = `"${lastQuote}"\n\n— ${title}${id ? ' · № ' + id : ''}\n${url}`;
          try {
            await navigator.clipboard.writeText(quote);
            const original = quoteChip.innerHTML;
            quoteChip.innerHTML = '<span class="sp-quote-chip-icon" aria-hidden="true">✓</span>copied';
            quoteChip.classList.add('is-copied');
            setTimeout(() => {
              quoteChip.innerHTML = original;
              quoteChip.classList.remove('is-copied');
            }, 1400);
          } catch {
            quoteChip.textContent = 'copy failed';
          }
        });

        // ─── LAST-VISITED TRACKING ──────────────────────────────────
        const readVisited = () => {
          try { return JSON.parse(localStorage.getItem(KEY_VISITED) || '[]'); } catch { return []; }
        };
        const writeVisited = (ids, opts = {}) => {
          localStorage.setItem(KEY_VISITED, JSON.stringify(ids));
          if (!opts.skipMirror) scheduleReaderMirror();
        };
        const markVisited = (id) => {
          const list = readVisited();
          const i = list.indexOf(id);
          if (i !== -1) list.splice(i, 1);
          list.unshift(id);
          while (list.length > VISITED_MAX) list.pop();
          writeVisited(list);
        };
        // If we're on a block reader, mark this block as visited now.
        const pathMatch = location.pathname.match(/^\/sparrow\/b\/(\d{3,})/);
        if (pathMatch) markVisited(pathMatch[1]);
        // Reflect visited state on any receipts already in the DOM.
        const applyVisited = () => {
          const visited = new Set(readVisited());
          document.querySelectorAll('[data-sp-block-id]').forEach((el) => {
            const id = el.getAttribute('data-sp-block-id');
            if (visited.has(id)) el.classList.add('is-visited');
          });
        };
        applyVisited();

        // ─── v0.15 / v0.16 · READER-STATE MIRROR (via Magpie peer-node)
        // When the Magpie bridge is up, mirror all three reader-state
        // keys — saved (v0.15) + visited + reactions (v0.16) — to the
        // local peer-node at /reader-state (POST) and pull any existing
        // state on load (GET /reader-state.json). Single-machine sync
        // only — cross-device is v0.17 over Nostr.
        //
        // Payload shape (sparrow-reader-state-v1):
        //   { saved:     { value: string[], updated_at: ISO8601 },
        //     visited:   { value: string[], updated_at: ISO8601 },
        //     reactions: { value: { [id]: string[] }, updated_at: ISO8601 } }
        // Merge policy on both sides is newest-wins by updated_at.
        const MIRROR_ORIGIN = 'http://127.0.0.1:38473';
        const MIRROR_KEYS = [
          {
            remote: 'saved',
            tsKey:  'sparrow:saved:updated_at',
            read:   () => readSaved(),
            apply:  (value) => writeSaved(Array.isArray(value) ? value : [], { skipMirror: true }),
            validate: (v) => Array.isArray(v),
          },
          {
            remote: 'visited',
            tsKey:  'sparrow:visited:updated_at',
            read:   () => readVisited(),
            apply:  (value) => {
              writeVisited(Array.isArray(value) ? value : [], { skipMirror: true });
              // Re-paint .is-visited on any receipts already in the DOM.
              applyVisited();
            },
            validate: (v) => Array.isArray(v),
          },
          {
            remote: 'reactions',
            tsKey:  'sparrow:reactions:updated_at',
            read:   () => readReactions(),
            apply:  (value) => {
              const obj = (value && typeof value === 'object') ? value : {};
              writeReactions(obj, { skipMirror: true });
              // Repaint chip state if the reader is showing.
              hydrateReactions();
            },
            validate: (v) => v && typeof v === 'object' && !Array.isArray(v),
          },
        ];

        let mirrorEverConnected = false;
        let mirrorTimer = null;

        async function mirrorProbe() {
          try {
            const r = await fetch(MIRROR_ORIGIN + '/health', { cache: 'no-store' });
            if (!r.ok) throw new Error('bad status');
            mirrorEverConnected = true;
            return true;
          } catch { return false; }
        }

        async function mirrorPull() {
          try {
            const r = await fetch(MIRROR_ORIGIN + '/reader-state.json', { cache: 'no-store' });
            if (!r.ok) return;
            const json = await r.json();
            const state = json?.state || {};
            for (const k of MIRROR_KEYS) {
              const remote = state[k.remote];
              if (!remote || typeof remote !== 'object') continue;
              const remoteAt = String(remote.updated_at || '');
              const localAt  = localStorage.getItem(k.tsKey) || '';
              if (remoteAt && remoteAt > localAt && k.validate(remote.value)) {
                localStorage.setItem(k.tsKey, remoteAt);
                k.apply(remote.value);
              }
            }
          } catch { /* offline or not a Magpie — leave local state alone */ }
        }

        async function mirrorPush() {
          const at = new Date().toISOString();
          const body = {};
          for (const k of MIRROR_KEYS) {
            const value = k.read();
            body[k.remote] = { value, updated_at: at };
            localStorage.setItem(k.tsKey, at);
          }
          try {
            await fetch(MIRROR_ORIGIN + '/reader-state', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body),
            });
          } catch { /* silently degrade; next toggle will retry */ }
        }

        function scheduleReaderMirror() {
          clearTimeout(mirrorTimer);
          mirrorTimer = setTimeout(async () => {
            // Only try to push if we've ever seen the peer-node alive
            // in this session — avoids firing off dead requests on
            // every save when Magpie isn't running.
            if (!mirrorEverConnected && !(await mirrorProbe())) return;
            mirrorPush();
          }, 600);
        }

        // One-shot initial sync — probe then pull.
        (async () => {
          if (await mirrorProbe()) await mirrorPull();
        })();

        // ─── v0.7 · REACTIONS ───────────────────────────────────────
        // localStorage shape: { [blockId]: ["ember", "moss", ...] }.
        // Local-only for v0.7 — v0.8 will fan these out as Nostr kind-7
        // events when a signer is configured. Hydrate on load so the
        // three react-chips on the reader show the prior pick state.
        const readReactions = () => {
          try { return JSON.parse(localStorage.getItem(KEY_REACTIONS) || '{}') || {}; } catch { return {}; }
        };
        const writeReactions = (obj, opts = {}) => {
          localStorage.setItem(KEY_REACTIONS, JSON.stringify(obj));
          if (!opts.skipMirror) scheduleReaderMirror();
        };
        const toggleReaction = (blockId, kind) => {
          if (!blockId || !kind) return;
          const map = readReactions();
          const picks = new Set(Array.isArray(map[blockId]) ? map[blockId] : []);
          const willAdd = !picks.has(kind);
          if (willAdd) picks.add(kind); else picks.delete(kind);
          map[blockId] = Array.from(picks);
          if (map[blockId].length === 0) delete map[blockId];
          writeReactions(map);
          hydrateReactions();
          // v0.8: on ADD, fan out as a kind-7 Nostr reaction event.
          // v0.9: on REMOVE, emit a kind-5 delete that references the
          // previously-published event id (if we emitted one). Both
          // non-blocking — local state wins either way.
          if (willAdd) {
            nostrEmitReaction(blockId, kind).catch(() => {});
          } else {
            nostrDeleteReaction(blockId, kind).catch(() => {});
          }
        };
        const hydrateReactions = () => {
          const map = readReactions();
          document.querySelectorAll('[data-sp-reactions]').forEach((panel) => {
            const id = panel.getAttribute('data-sp-block-id');
            const picks = new Set(Array.isArray(map[id]) ? map[id] : []);
            panel.querySelectorAll('[data-sp-react]').forEach((btn) => {
              const kind = btn.getAttribute('data-sp-react');
              const on = picks.has(kind);
              btn.classList.toggle('is-on', on);
              btn.setAttribute('aria-pressed', on ? 'true' : 'false');
            });
          });
        };
        hydrateReactions();
        document.addEventListener('click', (e) => {
          const btn = e.target.closest('[data-sp-react]');
          if (!btn) return;
          const panel = btn.closest('[data-sp-reactions]');
          const id = panel?.getAttribute('data-sp-block-id');
          toggleReaction(id, btn.getAttribute('data-sp-react'));
        });

        // ─── v0.8 · NOSTR REACTION FAN-OUT (NIP-07) ─────────────────
        // If the page has a NIP-07 browser extension installed
        // (Alby, nos2x, Flamingo), the user can connect it and each
        // reaction pick becomes a signed kind-7 event r-tagged to the
        // block's canonical URL. Relays live in localStorage:
        // sparrow:nostr-relays; defaults are the same pool Magpie uses.
        const KEY_NOSTR_RELAYS = 'sparrow:nostr-relays';
        const KEY_NOSTR_EMITTED = 'sparrow:nostr-emitted';
        const KEY_NOSTR_PUBKEY  = 'sparrow:nostr-pubkey';
        const DEFAULT_RELAYS = [
          'wss://relay.damus.io',
          'wss://relay.primal.net',
          'wss://nos.lol',
        ];
        const GLYPH_BY_KIND = { ember: '🔥', moss: '🌿', lilac: '💜' };

        const hasNip07 = () => typeof window !== 'undefined' && !!window.nostr && typeof window.nostr.signEvent === 'function';
        const getRelays = () => {
          try {
            const raw = localStorage.getItem(KEY_NOSTR_RELAYS);
            const list = raw ? JSON.parse(raw) : null;
            if (Array.isArray(list) && list.length) return list.filter((u) => typeof u === 'string' && u.startsWith('ws'));
          } catch {}
          return DEFAULT_RELAYS;
        };
        const cachedPubkey = { value: localStorage.getItem(KEY_NOSTR_PUBKEY) || null };

        const paintNostrState = (state) => {
          document.querySelectorAll('[data-sp-nostr-status]').forEach((el) => {
            el.setAttribute('data-state', state);
            const label = el.querySelector('[data-sp-nostr-label]');
            if (!label) return;
            if (state === 'connected') {
              const pk = cachedPubkey.value || '';
              label.textContent = pk ? `signer · ${pk.slice(0, 8)}…${pk.slice(-4)}` : 'signer connected';
            } else if (state === 'available') {
              label.textContent = 'NIP-07 detected';
            } else if (state === 'emitting') {
              label.textContent = 'publishing…';
            } else {
              label.textContent = 'local only';
            }
          });
          document.querySelectorAll('[data-sp-nostr-connect]').forEach((btn) => {
            btn.hidden = !(state === 'available');
          });
        };

        const initNostr = async () => {
          if (!hasNip07()) { paintNostrState('local'); return; }
          if (cachedPubkey.value) {
            paintNostrState('connected');
            return;
          }
          paintNostrState('available');
        };
        initNostr();
        // The extension may inject window.nostr after DOMContentLoaded.
        setTimeout(initNostr, 800);
        setTimeout(initNostr, 2400);

        document.addEventListener('click', async (e) => {
          const btn = e.target.closest('[data-sp-nostr-connect]');
          if (!btn) return;
          if (!hasNip07()) { paintNostrState('local'); return; }
          try {
            const pk = await window.nostr.getPublicKey();
            if (typeof pk === 'string' && /^[0-9a-f]{64}$/i.test(pk)) {
              cachedPubkey.value = pk;
              localStorage.setItem(KEY_NOSTR_PUBKEY, pk);
              paintNostrState('connected');
            }
          } catch {
            paintNostrState('available');
          }
        });

        async function nostrEmitReaction(blockId, kind) {
          if (!hasNip07() || !cachedPubkey.value) return;
          const relays = getRelays();
          if (!relays.length) return;

          const glyph = GLYPH_BY_KIND[kind] || '+';
          const url = `https://pointcast.xyz/b/${blockId}`;
          const unsigned = {
            kind: 7,
            pubkey: cachedPubkey.value,
            created_at: Math.floor(Date.now() / 1000),
            tags: [
              ['r', url],
              ['t', 'sparrow'],
              ['t', `sparrow-${kind}`],
              ['client', 'sparrow', 'https://pointcast.xyz/sparrow'],
            ],
            content: glyph,
          };

          let signed;
          paintNostrState('emitting');
          try {
            signed = await window.nostr.signEvent(unsigned);
          } catch {
            paintNostrState('connected');
            return;
          }
          if (!signed || typeof signed.id !== 'string' || typeof signed.sig !== 'string') {
            paintNostrState('connected');
            return;
          }

          // Remember emission so we don't re-broadcast on rehydrate/reload.
          try {
            const map = JSON.parse(localStorage.getItem(KEY_NOSTR_EMITTED) || '{}');
            map[`${blockId}:${kind}`] = { id: signed.id, at: signed.created_at };
            localStorage.setItem(KEY_NOSTR_EMITTED, JSON.stringify(map));
          } catch {}

          // Fire-and-forget relay fan-out.
          for (const url of relays) {
            try {
              const ws = new WebSocket(url);
              ws.addEventListener('open', () => {
                try { ws.send(JSON.stringify(['EVENT', signed])); } catch {}
              });
              ws.addEventListener('message', () => { try { ws.close(); } catch {} });
              setTimeout(() => { try { if (ws.readyState <= 1) ws.close(); } catch {} }, 4000);
            } catch {}
          }

          paintNostrState('connected');
        }

        // ─── v0.9 · REACTION AGGREGATION (read) + KIND-5 UNREACT ────
        // For each reactions panel on the page, open a REQ subscription
        // against every configured relay, filter for kind:7 events
        // r-tagged to the block's canonical URL, count by content glyph,
        // paint a small count badge on each chip. Subscription works
        // without a NIP-07 signer — reading is public — but emits still
        // require a signer (see v0.8).
        const KIND_BY_GLYPH = { '🔥': 'ember', '🌿': 'moss', '💜': 'lilac' };
        const reactionCounts = new Map();   // blockId -> Map<kind, Set<eventId>>
        const openSockets = [];

        function ingestReactionEvent(blockId, event) {
          if (!event || event.kind !== 7 || typeof event.id !== 'string') return;
          if (typeof event.content !== 'string') return;
          // Deduce kind from content glyph first; fall back to a
          // sparrow-<kind> tag if the content is non-glyph (some
          // clients emit "+" or "like" as NIP-25 default).
          let kind = null;
          for (const g of Object.keys(KIND_BY_GLYPH)) {
            if (event.content.includes(g)) { kind = KIND_BY_GLYPH[g]; break; }
          }
          if (!kind && Array.isArray(event.tags)) {
            for (const t of event.tags) {
              if (Array.isArray(t) && t[0] === 't' && typeof t[1] === 'string') {
                const m = /^sparrow-(ember|moss|lilac)$/.exec(t[1]);
                if (m) { kind = m[1]; break; }
              }
            }
          }
          if (!kind) return;
          if (!reactionCounts.has(blockId)) reactionCounts.set(blockId, new Map());
          const byKind = reactionCounts.get(blockId);
          if (!byKind.has(kind)) byKind.set(kind, new Set());
          byKind.get(kind).add(event.id);
          paintReactionCounts(blockId);
          paintReelCounts(blockId);
        }

        function paintReactionCounts(blockId) {
          const panel = document.querySelector(`[data-sp-reactions][data-sp-block-id="${blockId}"]`);
          if (!panel) return;
          const byKind = reactionCounts.get(blockId) || new Map();
          panel.querySelectorAll('[data-sp-react]').forEach((btn) => {
            const kind = btn.getAttribute('data-sp-react');
            const count = byKind.get(kind)?.size ?? 0;
            let badge = btn.querySelector('[data-sp-react-count]');
            if (count > 0) {
              if (!badge) {
                badge = document.createElement('span');
                badge.setAttribute('data-sp-react-count', '');
                badge.className = 'sp-react-count';
                btn.appendChild(badge);
              }
              badge.textContent = String(count);
            } else if (badge) {
              badge.remove();
            }
          });
        }

        function subscribeReactionsForBlock(blockId) {
          const relays = getRelays();
          if (!relays.length) return;
          const url = `https://pointcast.xyz/b/${blockId}`;
          const subId = `sparrow-r-${blockId}-${Date.now().toString(36)}`;
          const filter = { kinds: [7], '#r': [url], limit: 200 };
          const req = JSON.stringify(['REQ', subId, filter]);
          for (const relay of relays) {
            try {
              const ws = new WebSocket(relay);
              ws.addEventListener('open', () => { try { ws.send(req); } catch {} });
              ws.addEventListener('message', (e) => {
                try {
                  const frame = JSON.parse(e.data);
                  if (!Array.isArray(frame)) return;
                  if (frame[0] === 'EVENT' && frame[1] === subId) {
                    ingestReactionEvent(blockId, frame[2]);
                  } else if (frame[0] === 'CLOSED' && frame[1] === subId) {
                    try { ws.close(); } catch {}
                  }
                } catch {}
              });
              ws.addEventListener('error', () => { try { ws.close(); } catch {} });
              openSockets.push(ws);
            } catch {}
          }
        }

        document.querySelectorAll('[data-sp-reactions]').forEach((panel) => {
          const id = panel.getAttribute('data-sp-block-id');
          if (id) subscribeReactionsForBlock(id);
        });

        // ─── v0.10 · CROSS-REEL COUNT BADGES ────────────────────────
        // On index / channel / saved pages, receipts carry only a
        // [data-sp-block-id] — no reactions panel. Instead of opening
        // N subs, open ONE subscription per relay with every visible
        // block URL in the filter's #r tag. Paint a compact
        // "🔥 3 · 🌿 1" row in each receipt's footer as events arrive.
        const GLYPH_OUT = { ember: '🔥', moss: '🌿', lilac: '💜' };

        function paintReelCounts(blockId) {
          if (!blockId) return;
          const byKind = reactionCounts.get(blockId);
          if (!byKind) return;
          const els = document.querySelectorAll(`[data-sp-block-id="${blockId}"]`);
          els.forEach((el) => {
            // Skip the full reader panel — paintReactionCounts handles it.
            if (el.matches('[data-sp-reactions]')) return;
            if (el.classList.contains('sp-reader') || el.querySelector('[data-sp-reactions]')) return;
            const foot = el.querySelector('.sp-r-foot');
            if (!foot) return;
            let row = foot.querySelector('[data-sp-r-react-counts]');
            if (!row) {
              row = document.createElement('span');
              row.setAttribute('data-sp-r-react-counts', '');
              row.className = 'sp-r-react-counts';
              foot.appendChild(row);
            }
            const parts = [];
            for (const k of ['ember', 'moss', 'lilac']) {
              const n = byKind.get(k)?.size ?? 0;
              if (n > 0) parts.push(`${GLYPH_OUT[k]} ${n}`);
            }
            if (parts.length === 0) { row.hidden = true; row.textContent = ''; }
            else { row.hidden = false; row.textContent = parts.join(' · '); }
          });
        }

        function subscribeReelReactions() {
          // Collect block IDs from receipts that are NOT already being
          // subscribed-to via a per-reader subscription.
          const readerIds = new Set(
            Array.from(document.querySelectorAll('[data-sp-reactions]'))
              .map((el) => el.getAttribute('data-sp-block-id'))
              .filter(Boolean),
          );
          const reelIds = Array.from(
            new Set(
              Array.from(document.querySelectorAll('[data-sp-block-id]'))
                .map((el) => el.getAttribute('data-sp-block-id'))
                .filter((id) => id && !readerIds.has(id)),
            ),
          );
          if (!reelIds.length) return;

          const relays = getRelays();
          if (!relays.length) return;

          const urls = reelIds.map((id) => `https://pointcast.xyz/b/${id}`);
          const subId = `sparrow-reel-${Date.now().toString(36)}`;
          // Some relays cap filter size; keep limit generous but bounded.
          const filter = { kinds: [7], '#r': urls, limit: 500 };
          const req = JSON.stringify(['REQ', subId, filter]);

          for (const relay of relays) {
            try {
              const ws = new WebSocket(relay);
              ws.addEventListener('open', () => { try { ws.send(req); } catch {} });
              ws.addEventListener('message', (e) => {
                try {
                  const frame = JSON.parse(e.data);
                  if (!Array.isArray(frame)) return;
                  if (frame[0] !== 'EVENT' || frame[1] !== subId) {
                    if (frame[0] === 'CLOSED' && frame[1] === subId) { try { ws.close(); } catch {} }
                    return;
                  }
                  const event = frame[2];
                  if (!event || !Array.isArray(event.tags)) return;
                  // Recover block id from the r-tag
                  for (const tag of event.tags) {
                    if (!Array.isArray(tag) || tag[0] !== 'r' || typeof tag[1] !== 'string') continue;
                    const m = /\/b\/(\d{3,})/.exec(tag[1]);
                    if (!m) continue;
                    const id = m[1];
                    ingestReactionEvent(id, event);
                    break;
                  }
                } catch {}
              });
              ws.addEventListener('error', () => { try { ws.close(); } catch {} });
              openSockets.push(ws);
            } catch {}
          }
        }
        subscribeReelReactions();

        // ─── v0.11 · INLINE REPLY COMPOSER ──────────────────────────
        // Collapsible composer on the block reader. Submit POSTs a
        // pc-ping-v1 draft to /api/ping on pointcast.xyz (same endpoint
        // Magpie uses for push-to-PointCast). Gives readers a one-hop
        // reply path without installing anything; Magpie-routed multi-
        // destination reply lands in v0.12.
        document.querySelectorAll('[data-sp-compose]').forEach((panel) => {
          const body = panel.querySelector('[data-sp-compose-body]');
          const subject = panel.querySelector('[data-sp-compose-subject]');
          const counter = panel.querySelector('[data-sp-compose-counter]');
          const submit = panel.querySelector('[data-sp-compose-submit]');
          const result = panel.querySelector('[data-sp-compose-result]');
          const blockId = panel.getAttribute('data-sp-block-id');
          const channel = panel.getAttribute('data-sp-channel') || 'FD';
          if (!body || !submit) return;

          const repaintCounter = () => {
            const len = body.value.length;
            counter && (counter.textContent = `${len} / 3800`);
            const tooLong = len > 3800;
            counter?.classList.toggle('is-over', tooLong);
          };
          body.addEventListener('input', repaintCounter);
          repaintCounter();

          // v0.13: read the destinations picker. PointCast is always
          // included (locked); other checkboxes reflect Magpie
          // readiness pulled by probeMagpie().
          const selectedDestinations = () => {
            const boxes = panel.querySelectorAll('[data-sp-dest-input]');
            const ids = new Set(['pointcast']);
            boxes.forEach((cb) => {
              if (cb.checked && !cb.disabled) ids.add(cb.getAttribute('data-sp-dest-input'));
            });
            return Array.from(ids);
          };
          const magpieIsOnline = () => {
            const pill = panel.querySelector('[data-sp-magpie-pill]');
            return pill?.getAttribute('data-state') === 'connected';
          };

          async function postDirectPing(payload) {
            const resp = await fetch('https://pointcast.xyz/api/ping', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            if (!resp.ok) throw new Error(`ping HTTP ${resp.status}`);
          }
          async function postMagpieCompose(payload) {
            // Short timeout — if Magpie doesn't recognize /compose, we
            // want to fall back quickly to the direct path.
            const ctrl = new AbortController();
            const timer = setTimeout(() => ctrl.abort(), 6000);
            try {
              const resp = await fetch('http://127.0.0.1:38473/compose', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
                signal: ctrl.signal,
              });
              clearTimeout(timer);
              if (!resp.ok) throw new Error(`compose HTTP ${resp.status}`);
              const json = await resp.json().catch(() => ({}));
              return json;
            } finally {
              clearTimeout(timer);
            }
          }

          submit.addEventListener('click', async () => {
            const text = (body.value || '').trim();
            if (!text) {
              result.textContent = '⚠ body is empty';
              result.setAttribute('data-state', 'error');
              return;
            }
            if (text.length > 3800) {
              result.textContent = '⚠ body over 3800 chars';
              result.setAttribute('data-state', 'error');
              return;
            }
            const subjectVal = (subject?.value || '').trim().slice(0, 120);
            const dests = selectedDestinations();
            const hasExtras = dests.some((d) => d !== 'pointcast');
            const useMagpie = hasExtras && magpieIsOnline();

            submit.disabled = true;
            result.textContent = useMagpie ? 'routing via magpie…' : 'posting…';
            result.setAttribute('data-state', 'pending');

            const pingPayload = {
              type: 'pc-ping-v1',
              subject: subjectVal || undefined,
              body: text,
              expand: true,
              channel,
              blockType: 'NOTE',
              dek: subjectVal ? undefined : `Re: ${blockId}`,
              sourceUrl: `https://pointcast.xyz/b/${blockId}`,
              sourceApp: 'sparrow',
              from: 'sparrow-reader',
              timestamp: new Date().toISOString(),
            };

            const composePayload = {
              body: text,
              title: subjectVal || undefined,
              dek: subjectVal ? undefined : `Re: ${blockId}`,
              destinations: dests,
              channel,
              blockType: 'NOTE',
              sourceUrl: `https://pointcast.xyz/b/${blockId}`,
              sourceApp: 'sparrow',
              subject: subjectVal || undefined,
              timestamp: new Date().toISOString(),
            };

            try {
              if (useMagpie) {
                try {
                  const out = await postMagpieCompose(composePayload);
                  const successes = (out.results || []).filter((r) => r.success);
                  const summaries = successes.map((r) => r.publisher).join(' · ');
                  if (successes.length > 0) {
                    result.textContent = `magpie → ${summaries || `${successes.length} destination${successes.length === 1 ? '' : 's'}`}`;
                    result.setAttribute('data-state', 'ok');
                  } else {
                    // Magpie accepted the request but everything failed.
                    // Treat as fallback trigger.
                    throw new Error('magpie: all destinations failed');
                  }
                } catch (magErr) {
                  // Fallback — still land the reply in PointCast.
                  await postDirectPing(pingPayload);
                  result.textContent = `direct (magpie fallback: ${magErr?.message || 'unreachable'})`;
                  result.setAttribute('data-state', 'ok');
                }
              } else {
                await postDirectPing(pingPayload);
                result.textContent = 'posted · staging as a block';
                result.setAttribute('data-state', 'ok');
              }
              body.value = '';
              if (subject) subject.value = '';
              repaintCounter();
              // Reset non-PC checkboxes
              panel.querySelectorAll('[data-sp-dest-input]').forEach((cb) => {
                if (cb.getAttribute('data-sp-dest-input') !== 'pointcast') cb.checked = false;
              });
              setTimeout(() => {
                result.textContent = '';
                result.removeAttribute('data-state');
                submit.disabled = false;
                if (panel instanceof HTMLDetailsElement) panel.open = false;
              }, 2600);
            } catch (err) {
              result.textContent = `× ${err?.message || 'failed'}`;
              result.setAttribute('data-state', 'error');
              submit.disabled = false;
            }
          });
        });

        // ─── v0.12 · MAGPIE BRIDGE DETECTION ────────────────────────
        // Composer reports whether a local Magpie peer-node is alive
        // and which of its destinations are ready (pulled from the
        // Magpie /config.json schema). v0.13 will route the composer
        // through Magpie's /broadcast for real multi-destination posts;
        // v0.12 is awareness + a deep link into /magpie.
        const MAGPIE_ORIGIN = 'http://127.0.0.1:38473';
        const DEST_META = {
          pointcast: { code: 'PC', name: 'PointCast' },
          mastodon:  { code: 'MA', name: 'Mastodon' },
          farcaster: { code: 'FC', name: 'Farcaster' },
          bitchat:   { code: 'BC', name: 'bitchat' },
          bluesky:   { code: 'BS', name: 'Bluesky' },
          twitter:   { code: 'TW', name: 'Twitter / X' },
          linkedin:  { code: 'LI', name: 'LinkedIn' },
          instagram: { code: 'IG', name: 'Instagram' },
          zora:      { code: 'ZO', name: 'Zora' },
          objkt:     { code: 'OB', name: 'Objkt' },
          opensea:   { code: 'OS', name: 'OpenSea' },
        };

        async function probeMagpie() {
          const bridges = document.querySelectorAll('[data-sp-magpie-bridge]');
          if (!bridges.length) return;
          bridges.forEach((b) => { b.hidden = false; });
          const paintPill = (state, label) => {
            bridges.forEach((b) => {
              const pill = b.querySelector('[data-sp-magpie-pill]');
              if (!pill) return;
              pill.setAttribute('data-state', state);
              const lbl = pill.querySelector('[data-sp-magpie-label]');
              if (lbl) lbl.textContent = label;
            });
          };
          const paintDests = (rows) => {
            bridges.forEach((b) => {
              const list = b.querySelector('[data-sp-magpie-dests]');
              if (!list) return;
              // Preserve the server-rendered PointCast lock-on chip; we
              // only replace the OTHER rows (rows excluding pointcast).
              const pcChip = list.querySelector('[data-sp-dest="pointcast"]');
              const extras = rows.filter((r) => r.id !== 'pointcast').map((r) => `
                <label class="sp-bridge-dest ${r.ready ? 'is-ready' : 'is-dim'}"
                       data-sp-dest="${r.id}"
                       title="${r.ready ? 'ready — will broadcast' : 'not configured in Magpie yet'}">
                  <input type="checkbox" data-sp-dest-input="${r.id}" ${r.ready ? '' : 'disabled'} />
                  <span class="sp-bridge-dest-code">${r.code}</span>
                  <span class="sp-bridge-dest-name">${r.name}</span>
                  <span class="sp-bridge-dest-state">${r.ready ? 'ready' : 'set up'}</span>
                </label>
              `).join('');
              list.innerHTML = (pcChip ? pcChip.outerHTML : '') + extras;
            });
          };

          paintPill('probing', 'magpie · probing');
          // 1.2s abort — don't block the reader when no Magpie is running.
          const ctrl = new AbortController();
          const timer = setTimeout(() => ctrl.abort(), 1200);
          let health;
          try {
            const r = await fetch(MAGPIE_ORIGIN + '/health', { signal: ctrl.signal, cache: 'no-store' });
            if (!r.ok) throw new Error(`HTTP ${r.status}`);
            health = await r.json();
          } catch {
            clearTimeout(timer);
            paintPill('offline', 'magpie · offline');
            paintDests([]);
            return;
          }
          clearTimeout(timer);

          // Config → enabled + ready destinations. Magpie's /config.json
          // returns { pointcast: {...}, publishers: {<id>: { ready, enabled, ... }} }
          let config;
          try {
            const r = await fetch(MAGPIE_ORIGIN + '/config.json', { cache: 'no-store' });
            config = r.ok ? await r.json() : {};
          } catch { config = {}; }

          const pubs = (config && config.publishers) || {};
          const rows = [];
          // PointCast first — always canonical.
          rows.push({ id: 'pointcast', code: 'PC', name: 'PointCast', ready: true });
          for (const id of Object.keys(DEST_META)) {
            if (id === 'pointcast') continue;
            const meta = DEST_META[id];
            const entry = pubs[id];
            if (!entry) continue;
            rows.push({ id, code: meta.code, name: meta.name, ready: !!entry.ready });
          }

          const readyN = rows.filter((r) => r.ready).length;
          paintPill('connected', `magpie · connected · ${readyN} ready`);
          paintDests(rows);
        }
        probeMagpie();

        window.addEventListener('beforeunload', () => {
          for (const ws of openSockets) {
            try { ws.close(1000, 'sparrow nav'); } catch {}
          }
        });

        // ─── Kind-5 unreact — wired into the existing toggleReaction
        // branch (willAdd === false). We keep the local delete optimistic;
        // if the signer call throws, the emit log entry stays so we can
        // retry the retraction later. Non-blocking.
        async function nostrDeleteReaction(blockId, kind) {
          if (!hasNip07() || !cachedPubkey.value) return;
          let emittedMap;
          try { emittedMap = JSON.parse(localStorage.getItem(KEY_NOSTR_EMITTED) || '{}'); } catch { return; }
          const key = `${blockId}:${kind}`;
          const entry = emittedMap[key];
          if (!entry?.id) return;

          const unsigned = {
            kind: 5,
            pubkey: cachedPubkey.value,
            created_at: Math.floor(Date.now() / 1000),
            tags: [
              ['e', entry.id],
              ['k', '7'],
              ['t', 'sparrow'],
              ['client', 'sparrow', 'https://pointcast.xyz/sparrow'],
            ],
            content: 'sparrow: unreact',
          };

          paintNostrState('emitting');
          let signed;
          try { signed = await window.nostr.signEvent(unsigned); }
          catch { paintNostrState('connected'); return; }
          if (!signed?.id || !signed?.sig) { paintNostrState('connected'); return; }

          for (const url of getRelays()) {
            try {
              const ws = new WebSocket(url);
              ws.addEventListener('open', () => {
                try { ws.send(JSON.stringify(['EVENT', signed])); } catch {}
              });
              ws.addEventListener('message', () => { try { ws.close(); } catch {} });
              setTimeout(() => { try { if (ws.readyState <= 1) ws.close(); } catch {} }, 4000);
            } catch {}
          }

          // Local bookkeeping: drop the emitted log entry + the observed
          // event from the count map so the chip stops claiming it.
          delete emittedMap[key];
          try { localStorage.setItem(KEY_NOSTR_EMITTED, JSON.stringify(emittedMap)); } catch {}
          const byKind = reactionCounts.get(blockId);
          if (byKind) {
            byKind.get(kind)?.delete(entry.id);
            paintReactionCounts(blockId);
          }
          paintNostrState('connected');
        }

        // ─── SERVICE WORKER REGISTRATION ────────────────────────────
        if ('serviceWorker' in navigator) {
          window.addEventListener('load', () => {
            navigator.serviceWorker
              .register('/sparrow/sw.js', { scope: '/sparrow/' })
              .catch(() => { /* SW registration failed — offline features degrade gracefully */ });
          });
        }

        // ─── ONLINE / OFFLINE PILL ──────────────────────────────────
        const offlinePill = document.querySelector('[data-sp-offline-pill]');
        const syncOnline = () => {
          if (!offlinePill) return;
          offlinePill.hidden = navigator.onLine;
        };
        window.addEventListener('online', syncOnline);
        window.addEventListener('offline', syncOnline);
        syncOnline();

        // ─── PWA INSTALL PROMPT ─────────────────────────────────────
        let deferredPrompt = null;
        const installBtn = document.querySelector('[data-sp-install]');
        const installCTAs = document.querySelectorAll('[data-sp-install-cta]');
        const showInstall = () => {
          if (installBtn) installBtn.hidden = false;
          installCTAs.forEach((el) => (el.hidden = false));
        };
        const hideInstall = () => {
          if (installBtn) installBtn.hidden = true;
          installCTAs.forEach((el) => (el.hidden = true));
        };
        window.addEventListener('beforeinstallprompt', (e) => {
          e.preventDefault();
          deferredPrompt = e;
          showInstall();
        });
        const triggerInstall = async () => {
          if (!deferredPrompt) return;
          deferredPrompt.prompt();
          try { await deferredPrompt.userChoice; } catch {}
          deferredPrompt = null;
          hideInstall();
        };
        installBtn?.addEventListener('click', triggerInstall);
        installCTAs.forEach((el) => el.addEventListener('click', triggerInstall));
        window.addEventListener('appinstalled', hideInstall);

        // ─── NOW-TUNED INTERSECTION OBSERVER ────────────────────────
        const tunables = document.querySelectorAll('[data-sp-block-id]');
        if ('IntersectionObserver' in window && tunables.length) {
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((ent) => {
                if (ent.isIntersecting) {
                  // The most-visible block at any moment is "now tuned".
                  tunables.forEach((n) => n.classList.remove('is-now-tuned'));
                  ent.target.classList.add('is-now-tuned');
                }
              });
            },
            { rootMargin: '-40% 0px -40% 0px', threshold: 0.01 },
          );
          tunables.forEach((n) => io.observe(n));
        }

        // ─── MOOD FILTER CHIPS ─────────────────────────────────────
        const chips = document.querySelectorAll('[data-sp-mood]');
        chips.forEach((chip) => {
          chip.addEventListener('click', () => {
            const target = chip.getAttribute('data-sp-mood') || '';
            const active = chip.classList.toggle('is-active');
            // Mutually exclusive — turn the others off when toggling on.
            if (active) chips.forEach((c) => { if (c !== chip) c.classList.remove('is-active'); });
            const anyActive = Array.from(chips).some((c) => c.classList.contains('is-active'));
            receipts().forEach((r) => {
              if (!anyActive) { r.hidden = false; return; }
              r.hidden = !(active && r.getAttribute('data-sp-mood') === target);
            });
          });
        });
      })();
    </script>

