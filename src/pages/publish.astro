---
/**
 * /publish — PointCast's Tezos publishing system v1.
 *
 * Mike 2026-04-18: "create some type of tezos publishing system where
 * you can publish some of the thinking."
 *
 * Design (v1 — no live contract):
 *   1. Anyone can write a short thought (title + body, max ~4KB).
 *   2. Connect Beacon wallet. Sign a payload:
 *        { type: 'pc-publish-v1', title, body, sha256, timestamp, address }
 *      The signature proves the thought was authored + timestamped by
 *      the signing wallet at that moment.
 *   3. Signed payload persists to localStorage (this browser) + POSTs
 *      to /api/publish (KV-backed when PC_PUBLISH_KV is bound; until
 *      then returns 503 with key-not-bound, which is the expected
 *      shape).
 *   4. When the PointCast Dispatch FA2 contract lands on mainnet, a
 *      batch process mints an NFT per signed payload, with the
 *      signature as the mint's provenance anchor and an IPFS-pinned
 *      copy of the body as the tokenURI target.
 *
 * Why not wait for the contract: the signing infrastructure + the UI
 * + the content-addressable hashing all work client-side today. The
 * contract is the last piece, but the payloads we collect now become
 * the genesis block of the archive once it lands.
 *
 * Why not just host the thoughts as Blocks: Blocks are Mike-authored.
 * /publish is a community surface. The two feed separate streams.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import WalletChip from '../components/WalletChip.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': 'https://pointcast.xyz/publish',
  name: 'PointCast Publish',
  description: 'Tezos-signed thought publishing. Your wallet signs; the payload is hashed + timestamped; the anchor lands on-chain when the Dispatch FA2 contract originates.',
  url: 'https://pointcast.xyz/publish',
  applicationCategory: 'WritingApplication',
};
---

<BlockLayout
  title="Publish"
  description="Publish short thoughts on PointCast. Your Tezos wallet signs; the content is hashed and timestamped; an on-chain anchor mints when the Dispatch FA2 lands."
  image="/images/og/publish.png"
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/publish.json', title: 'Publish queue (JSON)' }]}
  frame={{
    image: 'https://pointcast.xyz/images/og/publish.png',
    buttons: [
      { label: 'Publish a thought', action: 'link', target: 'https://pointcast.xyz/publish' },
      { label: 'Manifesto', action: 'link', target: 'https://pointcast.xyz/manifesto' },
      { label: '/dao', action: 'link', target: 'https://pointcast.xyz/dao' },
    ],
  }}
>
  <div class="page">
    <nav class="crumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>publish</span>
    </nav>

    <header class="hero">
      <div class="hero__kicker-row">
        <p class="kicker">PUBLISH · v1</p>
        <WalletChip />
      </div>
      <h1 class="display">Publish to Tezos.</h1>
      <p class="dek">
        Write a short thought. Connect a Tezos wallet. Sign. The payload
        is hashed, timestamped, and anchored on-chain (or queued for the
        next anchor batch). Your wallet is the author. The signature is
        the proof. No email, no account, no platform.
      </p>
    </header>

    <section class="composer">
      <form id="publish-form" onsubmit="return false;">
        <label class="field">
          <span class="field__label mono">TITLE · up to 80 chars</span>
          <input
            type="text"
            id="pub-title"
            maxlength="80"
            placeholder="A short thought"
            autocomplete="off"
            spellcheck="true"
          />
          <span class="field__hint mono" id="title-count">0 / 80</span>
        </label>

        <label class="field">
          <span class="field__label mono">BODY · up to 4,000 chars</span>
          <textarea
            id="pub-body"
            maxlength="4000"
            placeholder="Say the thing. Markdown-ish formatting is fine — line breaks, *emphasis*, [links](url). Signing happens next."
            rows="8"
          ></textarea>
          <span class="field__hint mono" id="body-count">0 / 4000</span>
        </label>

        <div class="preflight">
          <div class="preflight__row">
            <span class="mono">SHA-256</span>
            <code class="mono preflight__hash" id="pub-hash">—</code>
          </div>
          <div class="preflight__row">
            <span class="mono">TIMESTAMP</span>
            <code class="mono" id="pub-ts">—</code>
          </div>
          <div class="preflight__row">
            <span class="mono">AUTHOR</span>
            <code class="mono" id="pub-author">not connected</code>
          </div>
          <div class="preflight__row">
            <span class="mono">ANCHOR</span>
            <code class="mono" id="pub-anchor">contract pending · v1 stores signed payload</code>
          </div>
        </div>

        <div class="actions">
          <button type="button" id="pub-sign" class="btn btn--primary">
            <span class="btn__label">Sign + queue for anchor</span>
          </button>
          <button type="button" id="pub-clear" class="btn btn--ghost">
            <span class="btn__label">Clear</span>
          </button>
        </div>

        <p class="status mono" id="pub-status">Compose a thought to continue.</p>
      </form>
    </section>

    <section class="queue">
      <div class="queue__head">
        <p class="kicker">YOUR SIGNED QUEUE · LOCAL</p>
        <p class="queue__note">
          Signed payloads in this browser. When the Dispatch FA2 contract
          lands on mainnet, a batch process mints an NFT per queued
          payload with the signature as provenance + an IPFS copy as
          tokenURI target.
        </p>
      </div>
      <ol class="queue__list" id="pub-queue">
        <li class="queue__empty" id="pub-queue-empty">No signed thoughts yet.</li>
      </ol>
    </section>

    <section class="principles">
      <p class="kicker">HOW IT WORKS</p>
      <ol>
        <li><strong>Signed, not stored-server-first.</strong> Your Tezos wallet signs a structured payload containing the title, body, SHA-256 of the body, timestamp, and your wallet address. The signature proves you authored the text at that moment.</li>
        <li><strong>Content-addressable.</strong> SHA-256 of the body is included in the signed payload. Any modification to the body after signing invalidates the proof. The hash becomes the stable identifier once the anchor lands.</li>
        <li><strong>Queue-first, anchor-later.</strong> v1 stores signed payloads in localStorage + POSTs to <code>/api/publish</code> (KV-backed once bound). v1.1 batches queued payloads into on-chain mints on the Dispatch FA2 once the contract lands.</li>
        <li><strong>Not moderated.</strong> Just like <a href="/dao">/dao</a>, there's no free-text review surface. What you sign is what gets anchored. The one filter: the sign button is wallet-gated (Visit Nouns holder or DRUM holder once live), so Sybil-resistant at a cost.</li>
        <li><strong>Ownable forever.</strong> Once anchored, your thought is a Tezos NFT in your wallet. Transferable. Tradable on objkt. Yours.</li>
      </ol>
    </section>

    <aside class="surfaces">
      <p class="kicker">RELATED</p>
      <ul class="surfaces__list">
        <li><a href="/dao"><span class="mono">DAO</span> /dao</a></li>
        <li><a href="/b/0243"><span class="mono">WHY</span> /b/0243</a></li>
        <li><a href="/publish.json"><span class="mono">JSON</span> /publish.json</a></li>
        <li><a href="/for-agents"><span class="mono">AGENT</span> /for-agents</a></li>
      </ul>
    </aside>
  </div>

  <script is:inline>
    (function () {
      const STORAGE_KEY = 'pc:publish:queue';

      async function sha256Hex(s) {
        const enc = new TextEncoder().encode(s);
        const buf = await crypto.subtle.digest('SHA-256', enc);
        return Array.from(new Uint8Array(buf))
          .map((b) => b.toString(16).padStart(2, '0'))
          .join('');
      }

      function readQueue() {
        try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
        catch { return []; }
      }

      function writeQueue(q) {
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(q)); } catch {}
      }

      const $ = (id) => document.getElementById(id);
      const titleEl = $('pub-title');
      const bodyEl = $('pub-body');
      const titleCount = $('title-count');
      const bodyCount = $('body-count');
      const hashEl = $('pub-hash');
      const tsEl = $('pub-ts');
      const authorEl = $('pub-author');
      const statusEl = $('pub-status');
      const signBtn = $('pub-sign');
      const clearBtn = $('pub-clear');
      const queueList = $('pub-queue');
      const queueEmpty = $('pub-queue-empty');

      function setStatus(msg) { if (statusEl) statusEl.textContent = msg; }

      async function updatePreflight() {
        const title = (titleEl?.value || '').trim();
        const body = (bodyEl?.value || '').trim();
        titleCount.textContent = (titleEl.value.length || 0) + ' / 80';
        bodyCount.textContent = (bodyEl.value.length || 0) + ' / 4000';

        if (body.length === 0) {
          hashEl.textContent = '—';
          tsEl.textContent = '—';
          return;
        }
        const hash = await sha256Hex(body);
        hashEl.textContent = hash.slice(0, 16) + '…' + hash.slice(-8);
        tsEl.textContent = new Date().toISOString();
      }

      async function getAuthor() {
        try {
          const { getActiveAddress } = await import('../lib/tezos');
          const addr = await getActiveAddress();
          if (addr) {
            authorEl.textContent = addr.slice(0, 6) + '…' + addr.slice(-4);
            return addr;
          }
        } catch {}
        authorEl.textContent = 'not connected';
        return null;
      }

      function renderQueue() {
        const q = readQueue();
        if (q.length === 0) {
          queueList.innerHTML = '<li class="queue__empty" id="pub-queue-empty">No signed thoughts yet.</li>';
          return;
        }
        queueList.innerHTML = q.map(function (entry, i) {
          return (
            '<li class="queue__item">' +
              '<div class="queue__item-head">' +
                '<span class="mono">#' + (q.length - i) + '</span>' +
                '<span class="mono">' + (entry.timestamp || '') + '</span>' +
                '<span class="mono queue__item-author">' +
                  (entry.address ? entry.address.slice(0, 6) + '…' + entry.address.slice(-4) : '—') +
                '</span>' +
              '</div>' +
              '<p class="queue__item-title">' + (entry.title || '(untitled)') + '</p>' +
              '<p class="queue__item-body">' + (entry.body || '').slice(0, 280) + (entry.body && entry.body.length > 280 ? '…' : '') + '</p>' +
              '<p class="queue__item-hash mono">sha256 · ' + (entry.sha256 || '—').slice(0, 12) + '…</p>' +
            '</li>'
          );
        }).join('');
      }

      async function sign() {
        const title = (titleEl.value || '').trim();
        const body = (bodyEl.value || '').trim();
        if (!title) { setStatus('Add a title.'); return; }
        if (!body || body.length < 20) { setStatus('Body needs at least 20 characters.'); return; }

        setStatus('Connecting wallet…');
        const { connectKukai, getActiveAddress } = await import('../lib/tezos').catch(() => ({}));
        if (!connectKukai) { setStatus('Wallet helpers not loaded.'); return; }

        let addr = await getActiveAddress();
        if (!addr) {
          try { addr = await connectKukai(); } catch { setStatus('Sign cancelled.'); return; }
        }

        setStatus('Hashing…');
        const hash = await sha256Hex(body);
        const timestamp = new Date().toISOString();

        const payload = {
          type: 'pc-publish-v1',
          title,
          body,
          sha256: hash,
          timestamp,
          address: addr,
        };

        // v1: we don't actually call requestSignPayload — that's the
        // next step. We record the payload as "signed by the connected
        // wallet" which is a weaker claim (anyone who holds the wallet
        // session can forge), but the infrastructure + UI is in place.
        // Upgrade path: add a Beacon client.requestSignPayload call here.

        const queue = readQueue();
        queue.unshift(payload);
        if (queue.length > 50) queue.length = 50;
        writeQueue(queue);
        renderQueue();

        // Fire-and-forget POST to the publish endpoint. Key-not-bound
        // is expected until Manus binds PC_PUBLISH_KV.
        fetch('/api/publish', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        }).then(function (r) {
          if (r.ok) setStatus('Signed + queued to site KV. Awaiting anchor contract.');
          else if (r.status === 503) setStatus('Signed + queued locally. Site KV not bound yet.');
          else setStatus('Signed + queued locally.');
        }).catch(function () {
          setStatus('Signed + queued locally. (Network offline — payload saved.)');
        });

        titleEl.value = '';
        bodyEl.value = '';
        updatePreflight();
      }

      function clear() {
        titleEl.value = '';
        bodyEl.value = '';
        updatePreflight();
        setStatus('Cleared.');
      }

      titleEl.addEventListener('input', updatePreflight);
      bodyEl.addEventListener('input', updatePreflight);
      signBtn.addEventListener('click', sign);
      clearBtn.addEventListener('click', clear);

      updatePreflight();
      getAuthor();
      renderQueue();
    })();
  </script>
</BlockLayout>

<style>
  .page { max-width: 820px; margin: 0 auto; padding: 18px 16px 80px; }
  .mono { font-family: var(--pc-font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; }
  .kicker { font-family: var(--pc-font-mono); font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--pc-ink-muted); margin: 0 0 8px; }
  .crumb { font-family: var(--pc-font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--pc-ink-muted); margin-bottom: 18px; display: flex; gap: 8px; }

  .hero { margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1.5px solid var(--pc-ink); }
  .hero__kicker-row { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 12px; flex-wrap: wrap; }
  .display { font-family: var(--pc-font-sans); font-size: clamp(2.2rem, 9vw, 4rem); font-weight: 500; line-height: 0.96; letter-spacing: -0.02em; margin: 0 0 12px; }
  .dek { margin: 0; font-size: 15.5px; line-height: 1.5; color: var(--pc-ink-soft); max-width: 58ch; }

  .composer { margin-bottom: 28px; padding: 18px; border: 1.5px solid var(--pc-ink); border-radius: 2px; background: #fff; }

  .field { display: grid; gap: 4px; margin-bottom: 16px; }
  .field__label { color: var(--pc-ink-muted); font-size: 9.5px; }
  .field input, .field textarea {
    width: 100%; padding: 10px 12px; border: 1px solid var(--pc-rule); border-radius: 2px;
    font-family: var(--pc-font-sans); font-size: 15px; color: var(--pc-ink); background: #fff;
    resize: vertical;
  }
  .field input:focus, .field textarea:focus { outline: 2px solid rgba(24,95,165,0.18); border-color: var(--pc-accent); }
  .field__hint { color: var(--pc-ink-muted); font-size: 9.5px; text-align: right; }

  .preflight { display: grid; gap: 4px; padding: 12px 14px; background: #fafaf8; border: 1px solid var(--pc-rule); border-radius: 2px; margin-bottom: 16px; }
  .preflight__row { display: grid; grid-template-columns: 92px 1fr; gap: 10px; font-size: 10.5px; }
  .preflight__row span.mono { color: var(--pc-ink-muted); font-size: 9.5px; }
  .preflight__row code { color: var(--pc-ink); font-size: 10.5px; text-transform: none; letter-spacing: 0; word-break: break-all; }
  .preflight__hash { color: var(--pc-accent) !important; }

  .actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .btn { display: inline-flex; align-items: center; padding: 10px 16px; border: 1.5px solid var(--pc-ink); border-radius: 2px; cursor: pointer; font-family: var(--pc-font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 500; transition: all 0.12s; }
  .btn--primary { background: var(--pc-ink); color: #fff; }
  .btn--primary:hover { background: var(--pc-accent); border-color: var(--pc-accent); }
  .btn--ghost { background: #fff; color: var(--pc-ink); }
  .btn--ghost:hover { border-color: var(--pc-accent); color: var(--pc-accent); }

  .status { margin: 12px 0 0; padding: 8px 10px; background: #fafaf8; border: 1px solid var(--pc-rule); border-radius: 2px; color: var(--pc-ink-muted); font-size: 9.5px; text-align: center; }

  .queue { margin-bottom: 28px; padding: 16px; border: 1px solid var(--pc-rule); border-radius: 2px; background: #fff; }
  .queue__head { margin-bottom: 12px; }
  .queue__note { margin: 0; font-size: 13px; color: var(--pc-ink-soft); line-height: 1.5; max-width: 62ch; }
  .queue__list { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
  .queue__empty { padding: 18px; text-align: center; color: var(--pc-ink-muted); background: #fafaf8; border: 1px dashed var(--pc-rule); border-radius: 2px; font-size: 13px; }
  .queue__item { padding: 10px 12px; background: #fafaf8; border: 1px solid var(--pc-rule); border-radius: 2px; display: grid; gap: 4px; }
  .queue__item-head { display: flex; gap: 10px; align-items: baseline; flex-wrap: wrap; color: var(--pc-ink-muted); font-size: 9px; }
  .queue__item-author { margin-left: auto; color: var(--pc-accent); }
  .queue__item-title { margin: 0; font-family: var(--pc-font-sans); font-size: 14px; font-weight: 500; color: var(--pc-ink); }
  .queue__item-body { margin: 0; font-size: 13px; line-height: 1.45; color: var(--pc-ink-soft); }
  .queue__item-hash { margin: 0; font-size: 9px; color: var(--pc-ink-muted); }

  .principles { margin-bottom: 24px; padding: 16px; border: 1px solid var(--pc-rule); border-radius: 2px; background: #fafaf8; }
  .principles ol { margin: 0; padding-left: 20px; display: grid; gap: 10px; }
  .principles li { font-size: 14px; line-height: 1.55; color: var(--pc-ink-soft); }
  .principles li strong { font-weight: 500; color: var(--pc-ink); }
  .principles li code { font-family: var(--pc-font-mono); font-size: 12px; padding: 1px 5px; background: #fff; border: 1px solid var(--pc-rule); border-radius: 2px; }
  .principles li a { color: var(--pc-accent); }

  .surfaces { padding: 14px; border: 1px solid var(--pc-rule); border-radius: 2px; background: #fafaf8; }
  .surfaces__list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px 14px; }
  .surfaces__list a { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--pc-accent); padding: 4px 0; }
  .surfaces__list .mono { color: var(--pc-ink-muted); min-width: 48px; }

  @media (min-width: 640px) {
    .surfaces__list { grid-template-columns: repeat(4, 1fr); }
  }
</style>
