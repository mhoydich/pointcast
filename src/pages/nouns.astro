---
import BaseLayout from '../layouts/BaseLayout.astro';
import Noggles from '../components/Noggles.astro';
---

<BaseLayout title="Nouns Generator" description="Generate random Nouns-style pixel art characters. ⌐◨-◨">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <header class="text-center mb-12">
      <div class="flex justify-center mb-6">
        <Noggles width={120} variant="yellow" />
      </div>
      <h1 class="text-4xl md:text-5xl font-heading text-nouns-yellow mb-3">
        Nouns Generator
      </h1>
      <p class="text-nouns-muted font-mono text-sm max-w-lg mx-auto">
        Generate random Nouns-style pixel art. Each one is unique. CC0 forever. ⌐◨-◨
      </p>
    </header>

    <!-- Generator -->
    <div class="flex flex-col items-center gap-8">
      <div class="pixel-border bg-nouns-bg-card rounded-xl p-6 md:p-10">
        <canvas id="noun-canvas" width="320" height="320" class="block" style="image-rendering: pixelated;"></canvas>
      </div>

      <div class="flex flex-wrap justify-center gap-3">
        <button id="btn-generate" class="px-6 py-2.5 bg-nouns-yellow text-nouns-bg font-heading text-lg rounded-lg hover:bg-nouns-yellow/90 transition-colors cursor-pointer">
          Generate ⌐◨-◨
        </button>
        <button id="btn-download" class="px-6 py-2.5 border border-nouns-border text-nouns-muted font-mono text-sm rounded-lg hover:border-nouns-yellow hover:text-nouns-yellow transition-colors cursor-pointer">
          Download PNG
        </button>
      </div>

      <!-- Trait display -->
      <div id="traits" class="w-full max-w-sm bg-nouns-bg-card border border-nouns-border rounded-xl p-5">
        <h3 class="font-heading text-lg text-nouns-yellow mb-3">Traits</h3>
        <div class="space-y-2 font-mono text-sm">
          <div class="flex justify-between">
            <span class="text-nouns-muted">Background</span>
            <span id="trait-bg" class="text-nouns-white">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-nouns-muted">Body</span>
            <span id="trait-body" class="text-nouns-white">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-nouns-muted">Head</span>
            <span id="trait-head" class="text-nouns-white">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-nouns-muted">Noggles</span>
            <span id="trait-noggles" class="text-nouns-white">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-nouns-muted">Accessory</span>
            <span id="trait-accessory" class="text-nouns-white">—</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Nouns DAO info section -->
    <section class="mt-20">
      <div class="flex items-center gap-3 mb-8">
        <div class="h-px flex-1 bg-nouns-border"></div>
        <h2 class="font-heading text-2xl text-nouns-yellow">What are Nouns?</h2>
        <div class="h-px flex-1 bg-nouns-border"></div>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <div class="bg-nouns-bg-card border border-nouns-border rounded-xl p-6 card-hover">
          <div class="text-3xl mb-3">⌐◨-◨</div>
          <h3 class="font-heading text-lg text-nouns-yellow mb-2">One Noun, Every Day</h3>
          <p class="text-sm text-nouns-muted leading-relaxed">
            One Noun is trustlessly auctioned every 24 hours, forever.
            100% of auction proceeds go to the Nouns DAO treasury.
          </p>
        </div>
        <div class="bg-nouns-bg-card border border-nouns-border rounded-xl p-6 card-hover">
          <div class="text-3xl mb-3">🏛️</div>
          <h3 class="font-heading text-lg text-nouns-blue mb-2">On-Chain Governance</h3>
          <p class="text-sm text-nouns-muted leading-relaxed">
            Noun holders govern the treasury through proposals and votes.
            Each Noun equals one vote. No delegation tricks, no token games.
          </p>
        </div>
        <div class="bg-nouns-bg-card border border-nouns-border rounded-xl p-6 card-hover">
          <div class="text-3xl mb-3">♻️</div>
          <h3 class="font-heading text-lg text-nouns-green mb-2">CC0 · Public Domain</h3>
          <p class="text-sm text-nouns-muted leading-relaxed">
            Nouns artwork is in the public domain. Anyone can use, remix,
            and build on Nouns IP. No permission needed. Ever.
          </p>
        </div>
      </div>

      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div class="bg-nouns-bg-card border border-nouns-border rounded-xl p-6">
          <h3 class="font-heading text-lg text-nouns-red mb-3">Proliferation</h3>
          <p class="text-sm text-nouns-muted leading-relaxed mb-4">
            The Nouns ecosystem extends far beyond the DAO. Builders worldwide
            create projects, apps, and art using the Nouns identity. From
            Nouns Builder (launch your own DAO) to Prop House (funding rounds),
            the infrastructure is open and growing.
          </p>
          <a href="https://nouns.wtf" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-nouns-yellow font-mono text-sm hover:underline">
            nouns.wtf →
          </a>
        </div>
        <div class="bg-nouns-bg-card border border-nouns-border rounded-xl p-6">
          <h3 class="font-heading text-lg text-nouns-yellow mb-3">The Noggles</h3>
          <p class="text-sm text-nouns-muted leading-relaxed mb-4">
            The iconic noggles (⌐◨-◨) are the universal symbol of Nouns culture.
            They represent a way of seeing — building in public, creating value
            for everyone, and having fun doing it. If you see noggles in the wild,
            you've found a builder.
          </p>
          <div class="flex gap-3">
            <Noggles width={50} variant="red" />
            <Noggles width={50} variant="blue" />
            <Noggles width={50} variant="yellow" />
            <Noggles width={50} variant="black" />
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const canvas = document.getElementById('noun-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const GRID = 32;
  const PX = canvas.width / GRID;

  // Palettes
  const backgrounds = [
    { name: 'Cool', color: '#d5d7e1' },
    { name: 'Warm', color: '#e1d7d5' },
    { name: 'Mint', color: '#c8e6d5' },
    { name: 'Lavender', color: '#d5d0e6' },
    { name: 'Peach', color: '#e6d5c8' },
    { name: 'Sky', color: '#c8dae6' },
    { name: 'Lemon', color: '#e6e3c8' },
    { name: 'Rose', color: '#e6c8d5' },
  ];

  const bodyColors = [
    { name: 'Red', color: '#f3322c' },
    { name: 'Blue', color: '#2b83f6' },
    { name: 'Green', color: '#1aae9f' },
    { name: 'Orange', color: '#f78c25' },
    { name: 'Purple', color: '#7c5cfc' },
    { name: 'Pink', color: '#e84d8a' },
    { name: 'Yellow', color: '#f7c325' },
    { name: 'Teal', color: '#26b5b0' },
    { name: 'Robot Gray', color: '#8c8c8c' },
    { name: 'Bored Ape', color: '#634d2f' },
  ];

  const headShapes = [
    'Square', 'Rounded', 'Tall', 'Wide', 'Diamond', 'Mohawk',
    'Spiky', 'Flat Top', 'Beanie', 'Crown',
  ];

  const noggleColors = [
    { name: 'Classic Red', frame: '#f3322c', lens1: '#ffffff', lens2: '#000000' },
    { name: 'Blue', frame: '#5648ed', lens1: '#ffffff', lens2: '#000000' },
    { name: 'Yellow', frame: '#ffef16', lens1: '#ffffff', lens2: '#000000' },
    { name: 'Green', frame: '#1aae9f', lens1: '#ffffff', lens2: '#000000' },
    { name: 'Pink', frame: '#e84d8a', lens1: '#ffffff', lens2: '#000000' },
    { name: 'Dark', frame: '#1c1c1c', lens1: '#ffffff', lens2: '#333333' },
    { name: 'Gold', frame: '#f7c325', lens1: '#ffffff', lens2: '#8b6914' },
    { name: 'Holographic', frame: '#c0c0ff', lens1: '#ffd0ff', lens2: '#d0ffff' },
  ];

  const accessories = [
    'None', 'Chain', 'Earring', 'Cigar', 'Pipe', 'Flower', 'Antenna', 'Halo',
  ];

  function pick<T>(arr: T[]): T {
    return arr[Math.floor(Math.random() * arr.length)];
  }

  function px(x: number, y: number, w = 1, h = 1) {
    ctx.fillRect(x * PX, y * PX, w * PX, h * PX);
  }

  function drawBackground(bg: typeof backgrounds[0]) {
    ctx.fillStyle = bg.color;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
  }

  function drawBody(body: typeof bodyColors[0]) {
    ctx.fillStyle = body.color;
    // Torso
    for (let y = 22; y < 32; y++) {
      for (let x = 10; x < 22; x++) {
        px(x, y);
      }
    }
    // Neck
    px(14, 20, 4, 2);
  }

  function drawHead(shape: string, body: typeof bodyColors[0]) {
    // Skin/head color — slightly lighter than body
    const headColor = lighten(body.color, 30);
    ctx.fillStyle = headColor;

    switch (shape) {
      case 'Square':
        for (let y = 8; y < 20; y++) for (let x = 9; x < 23; x++) px(x, y);
        break;
      case 'Rounded':
        for (let y = 9; y < 20; y++) for (let x = 9; x < 23; x++) px(x, y);
        for (let x = 10; x < 22; x++) px(x, 8);
        break;
      case 'Tall':
        for (let y = 5; y < 20; y++) for (let x = 10; x < 22; x++) px(x, y);
        break;
      case 'Wide':
        for (let y = 9; y < 20; y++) for (let x = 7; x < 25; x++) px(x, y);
        break;
      case 'Diamond':
        for (let y = 8; y < 20; y++) {
          const indent = Math.abs(y - 14);
          for (let x = 9 + indent; x < 23 - indent; x++) px(x, y);
        }
        break;
      case 'Mohawk':
        for (let y = 9; y < 20; y++) for (let x = 9; x < 23; x++) px(x, y);
        ctx.fillStyle = body.color;
        for (let y = 3; y < 9; y++) px(14, y, 4, 1);
        ctx.fillStyle = headColor;
        break;
      case 'Spiky':
        for (let y = 9; y < 20; y++) for (let x = 9; x < 23; x++) px(x, y);
        ctx.fillStyle = body.color;
        px(10, 7, 2, 2); px(14, 6, 2, 3); px(18, 7, 2, 2); px(22, 8, 1, 1);
        ctx.fillStyle = headColor;
        break;
      case 'Flat Top':
        for (let y = 8; y < 20; y++) for (let x = 8; x < 24; x++) px(x, y);
        break;
      case 'Beanie':
        for (let y = 10; y < 20; y++) for (let x = 9; x < 23; x++) px(x, y);
        ctx.fillStyle = body.color;
        for (let x = 8; x < 24; x++) px(x, 8, 1, 2);
        px(7, 9, 1, 1); px(24, 9, 1, 1);
        ctx.fillStyle = headColor;
        break;
      case 'Crown':
        for (let y = 10; y < 20; y++) for (let x = 9; x < 23; x++) px(x, y);
        ctx.fillStyle = '#f7c325';
        for (let x = 9; x < 23; x++) px(x, 8, 1, 2);
        px(9, 6, 2, 2); px(15, 5, 2, 3); px(21, 6, 2, 2);
        ctx.fillStyle = headColor;
        break;
      default:
        for (let y = 8; y < 20; y++) for (let x = 9; x < 23; x++) px(x, y);
    }
  }

  function drawNoggles(noggles: typeof noggleColors[0]) {
    const y = 13;
    // Left lens
    ctx.fillStyle = noggles.frame;
    px(10, y, 6, 5);
    ctx.fillStyle = noggles.lens1;
    px(11, y + 1, 2, 3);
    ctx.fillStyle = noggles.lens2;
    px(13, y + 1, 2, 3);

    // Bridge
    ctx.fillStyle = noggles.frame;
    px(16, y, 2, 1);
    px(16, y + 4, 2, 1);

    // Right lens
    ctx.fillStyle = noggles.frame;
    px(18, y, 6, 5);
    ctx.fillStyle = noggles.lens1;
    px(19, y + 1, 2, 3);
    ctx.fillStyle = noggles.lens2;
    px(21, y + 1, 2, 3);

    // Temple arm
    ctx.fillStyle = noggles.frame;
    px(7, y + 2, 3, 1);
  }

  function drawAccessory(acc: string) {
    switch (acc) {
      case 'Chain':
        ctx.fillStyle = '#f7c325';
        px(12, 21, 1, 1); px(13, 22, 1, 1); px(14, 21, 1, 1);
        px(15, 22, 1, 1); px(16, 21, 1, 1); px(17, 22, 1, 1); px(18, 21, 1, 1);
        break;
      case 'Earring':
        ctx.fillStyle = '#f7c325';
        px(8, 16, 1, 1); px(8, 17, 1, 2);
        break;
      case 'Cigar':
        ctx.fillStyle = '#8b6914';
        px(13, 19, 4, 1);
        ctx.fillStyle = '#ff6600';
        px(12, 19, 1, 1);
        break;
      case 'Pipe':
        ctx.fillStyle = '#634d2f';
        px(12, 19, 1, 3); px(11, 21, 3, 1); px(10, 19, 2, 1);
        ctx.fillStyle = '#8c8c8c';
        px(10, 18, 1, 1);
        break;
      case 'Flower':
        ctx.fillStyle = '#e84d8a';
        px(22, 10, 1, 1); px(23, 9, 1, 1); px(24, 10, 1, 1);
        px(23, 11, 1, 1);
        ctx.fillStyle = '#f7c325';
        px(23, 10, 1, 1);
        break;
      case 'Antenna':
        ctx.fillStyle = '#8c8c8c';
        px(16, 4, 1, 4);
        ctx.fillStyle = '#f3322c';
        px(15, 3, 1, 1); px(16, 2, 1, 1); px(17, 3, 1, 1);
        break;
      case 'Halo':
        ctx.fillStyle = '#f7c325';
        for (let x = 10; x < 22; x++) px(x, 5, 1, 1);
        px(9, 6, 1, 1); px(22, 6, 1, 1);
        for (let x = 10; x < 22; x++) px(x, 7, 1, 1);
        break;
    }
  }

  function lighten(hex: string, amount: number): string {
    const num = parseInt(hex.replace('#', ''), 16);
    const r = Math.min(255, (num >> 16) + amount);
    const g = Math.min(255, ((num >> 8) & 0xff) + amount);
    const b = Math.min(255, (num & 0xff) + amount);
    return `#${((r << 16) | (g << 8) | b).toString(16).padStart(6, '0')}`;
  }

  function generate() {
    const bg = pick(backgrounds);
    const body = pick(bodyColors);
    const head = pick(headShapes);
    const noggles = pick(noggleColors);
    const accessory = pick(accessories);

    ctx.clearRect(0, 0, canvas.width, canvas.height);
    drawBackground(bg);
    drawBody(body);
    drawHead(head, body);
    drawNoggles(noggles);
    drawAccessory(accessory);

    // Update traits
    document.getElementById('trait-bg')!.textContent = bg.name;
    document.getElementById('trait-body')!.textContent = body.name;
    document.getElementById('trait-head')!.textContent = head;
    document.getElementById('trait-noggles')!.textContent = noggles.name;
    document.getElementById('trait-accessory')!.textContent = accessory;
  }

  document.getElementById('btn-generate')!.addEventListener('click', generate);

  document.getElementById('btn-download')!.addEventListener('click', () => {
    const link = document.createElement('a');
    link.download = `noun-${Date.now()}.png`;
    link.href = canvas.toDataURL('image/png');
    link.click();
  });

  // Generate on load
  generate();
</script>
