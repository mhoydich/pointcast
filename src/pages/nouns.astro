---
import BaseLayout from '../layouts/BaseLayout.astro';
import Noggles from '../components/Noggles.astro';
---

<BaseLayout title="Nouns" description="Explore real Nouns — on-chain generative pixel art, CC0 forever. ⌐◨-◨">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <header class="text-center mb-12">
      <div class="flex justify-center mb-6">
        <Noggles width={120} variant="yellow" />
      </div>
      <h1 class="text-4xl md:text-5xl font-heading text-nouns-yellow mb-3">
        Nouns
      </h1>
      <p class="text-nouns-muted font-mono text-sm max-w-lg mx-auto">
        On-chain generative art. One auctioned every day, forever. CC0. ⌐◨-◨
      </p>
    </header>

    <!-- Random Generator -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <div class="h-px flex-1 bg-nouns-border"></div>
        <h2 class="font-heading text-2xl text-nouns-yellow">Random Noun</h2>
        <div class="h-px flex-1 bg-nouns-border"></div>
      </div>

      <div class="flex flex-col items-center gap-8">
        <div class="pixel-border bg-nouns-bg-card rounded-xl p-4 md:p-6">
          <img
            id="random-noun"
            src="https://noun-api.com/beta/pfp"
            alt="Random Noun"
            width="320"
            height="320"
            class="block rounded-lg"
            style="image-rendering: pixelated;"
          />
        </div>

        <div class="flex flex-wrap justify-center gap-3">
          <button id="btn-generate" class="px-6 py-2.5 bg-nouns-yellow text-nouns-bg font-heading text-lg rounded-lg hover:bg-nouns-yellow/90 transition-colors cursor-pointer">
            Generate ⌐◨-◨
          </button>
          <button id="btn-download" class="px-6 py-2.5 border border-nouns-border text-nouns-muted font-mono text-sm rounded-lg hover:border-nouns-yellow hover:text-nouns-yellow transition-colors cursor-pointer">
            Download PNG
          </button>
        </div>

        <p class="text-xs text-nouns-muted/60 font-mono text-center">
          Powered by <a href="https://noun-api.com" target="_blank" rel="noopener" class="text-nouns-blue hover:underline">noun-api.com</a> · Compositions from the official Nouns trait set
        </p>
      </div>
    </section>

    <!-- Browse Real Nouns -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <div class="h-px flex-1 bg-nouns-border"></div>
        <h2 class="font-heading text-2xl text-nouns-yellow">Browse Nouns</h2>
        <div class="h-px flex-1 bg-nouns-border"></div>
      </div>

      <p class="text-nouns-muted font-mono text-sm text-center mb-6">
        Real auctioned Nouns, living on-chain forever.
      </p>

      <div id="nouns-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        <!-- Filled by JS -->
      </div>

      <div class="flex justify-center gap-3 mt-8">
        <button id="btn-shuffle" class="px-6 py-2.5 bg-nouns-yellow text-nouns-bg font-heading text-lg rounded-lg hover:bg-nouns-yellow/90 transition-colors cursor-pointer">
          Shuffle
        </button>
        <button id="btn-load-more" class="px-6 py-2.5 border border-nouns-border text-nouns-muted font-mono text-sm rounded-lg hover:border-nouns-yellow hover:text-nouns-yellow transition-colors cursor-pointer">
          Load More
        </button>
      </div>

      <p class="text-xs text-nouns-muted/60 font-mono text-center mt-4">
        Images from <a href="https://noun.pics" target="_blank" rel="noopener" class="text-nouns-blue hover:underline">noun.pics</a> · On-chain artwork via Nouns DAO
      </p>
    </section>

    <!-- Nouns DAO info section -->
    <section>
      <div class="flex items-center gap-3 mb-8">
        <div class="h-px flex-1 bg-nouns-border"></div>
        <h2 class="font-heading text-2xl text-nouns-yellow">What are Nouns?</h2>
        <div class="h-px flex-1 bg-nouns-border"></div>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <div class="bg-nouns-bg-card border border-nouns-border rounded-xl p-6 card-hover">
          <div class="text-3xl mb-3">⌐◨-◨</div>
          <h3 class="font-heading text-lg text-nouns-yellow mb-2">One Noun, Every Day</h3>
          <p class="text-sm text-nouns-muted leading-relaxed">
            One Noun is trustlessly auctioned every 24 hours, forever.
            100% of auction proceeds go to the Nouns DAO treasury.
          </p>
        </div>
        <div class="bg-nouns-bg-card border border-nouns-border rounded-xl p-6 card-hover">
          <div class="text-3xl mb-3">🏛️</div>
          <h3 class="font-heading text-lg text-nouns-blue mb-2">On-Chain Governance</h3>
          <p class="text-sm text-nouns-muted leading-relaxed">
            Noun holders govern the treasury through proposals and votes.
            Each Noun equals one vote. No delegation tricks, no token games.
          </p>
        </div>
        <div class="bg-nouns-bg-card border border-nouns-border rounded-xl p-6 card-hover">
          <div class="text-3xl mb-3">♻️</div>
          <h3 class="font-heading text-lg text-nouns-green mb-2">CC0 · Public Domain</h3>
          <p class="text-sm text-nouns-muted leading-relaxed">
            Nouns artwork is in the public domain. Anyone can use, remix,
            and build on Nouns IP. No permission needed. Ever.
          </p>
        </div>
      </div>

      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div class="bg-nouns-bg-card border border-nouns-border rounded-xl p-6">
          <h3 class="font-heading text-lg text-nouns-red mb-3">Proliferation</h3>
          <p class="text-sm text-nouns-muted leading-relaxed mb-4">
            The Nouns ecosystem extends far beyond the DAO. Builders worldwide
            create projects, apps, and art using the Nouns identity. From
            Nouns Builder (launch your own DAO) to Prop House (funding rounds),
            the infrastructure is open and growing.
          </p>
          <a href="https://nouns.wtf" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-nouns-yellow font-mono text-sm hover:underline">
            nouns.wtf →
          </a>
        </div>
        <div class="bg-nouns-bg-card border border-nouns-border rounded-xl p-6">
          <h3 class="font-heading text-lg text-nouns-yellow mb-3">The Noggles</h3>
          <p class="text-sm text-nouns-muted leading-relaxed mb-4">
            The iconic noggles (⌐◨-◨) are the universal symbol of Nouns culture.
            They represent a way of seeing — building in public, creating value
            for everyone, and having fun doing it. If you see noggles in the wild,
            you've found a builder.
          </p>
          <div class="flex gap-3">
            <Noggles width={50} variant="red" />
            <Noggles width={50} variant="blue" />
            <Noggles width={50} variant="yellow" />
            <Noggles width={50} variant="black" />
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const MAX_NOUN_ID = 1875;
  const GRID_SIZE = 12;

  // --- Random Generator ---
  const randomImg = document.getElementById('random-noun') as HTMLImageElement;

  document.getElementById('btn-generate')!.addEventListener('click', () => {
    randomImg.style.opacity = '0.3';
    const newSrc = `https://noun-api.com/beta/pfp?t=${Date.now()}`;
    const loader = new Image();
    loader.onload = () => {
      randomImg.src = newSrc;
      randomImg.style.opacity = '1';
    };
    loader.onerror = () => {
      randomImg.style.opacity = '1';
    };
    loader.src = newSrc;
  });

  document.getElementById('btn-download')!.addEventListener('click', async () => {
    try {
      const resp = await fetch(randomImg.src);
      const svgText = await resp.text();
      const blob = new Blob([svgText], { type: 'image/svg+xml' });
      const url = URL.createObjectURL(blob);

      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        canvas.width = 320;
        canvas.height = 320;
        const ctx = canvas.getContext('2d')!;
        ctx.imageSmoothingEnabled = false;
        ctx.drawImage(img, 0, 0, 320, 320);
        URL.revokeObjectURL(url);

        const link = document.createElement('a');
        link.download = `noun-${Date.now()}.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
      };
      img.src = url;
    } catch {
      // Fallback: open SVG directly
      window.open(randomImg.src, '_blank');
    }
  });

  // --- Browse Grid ---
  const grid = document.getElementById('nouns-grid')!;

  function getRandomIds(count: number): number[] {
    const ids = new Set<number>();
    while (ids.size < count) {
      ids.add(Math.floor(Math.random() * (MAX_NOUN_ID + 1)));
    }
    return Array.from(ids).sort((a, b) => a - b);
  }

  function renderGrid(ids: number[], append = false) {
    if (!append) grid.innerHTML = '';

    ids.forEach(id => {
      const card = document.createElement('a');
      card.href = `https://nouns.wtf/noun/${id}`;
      card.target = '_blank';
      card.rel = 'noopener';
      card.className = 'group block';
      card.innerHTML = `
        <div class="bg-nouns-bg-card border border-nouns-border rounded-xl overflow-hidden card-hover">
          <img
            src="https://noun.pics/${id}.svg"
            alt="Noun #${id}"
            width="320"
            height="320"
            class="w-full aspect-square"
            style="image-rendering: pixelated;"
            loading="lazy"
          />
          <div class="p-3 flex items-center justify-between">
            <span class="font-heading text-sm text-nouns-white group-hover:text-nouns-yellow transition-colors">
              Noun #${id}
            </span>
            <span class="text-xs text-nouns-muted font-mono">⌐◨-◨</span>
          </div>
        </div>
      `;
      grid.appendChild(card);
    });
  }

  // Initial load
  renderGrid(getRandomIds(GRID_SIZE));

  document.getElementById('btn-shuffle')!.addEventListener('click', () => {
    renderGrid(getRandomIds(GRID_SIZE));
  });

  document.getElementById('btn-load-more')!.addEventListener('click', () => {
    renderGrid(getRandomIds(GRID_SIZE), true);
  });
</script>
