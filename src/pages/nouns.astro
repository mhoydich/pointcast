---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Nouns" description="Explore real Nouns — on-chain generative pixel art, CC0 forever.">
  <div class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-10">
      <div class="kicker">Explore</div>
      <h1 class="font-serif text-[1.65rem] text-ink font-medium italic mb-3 leading-[1.15]">
        Nouns
      </h1>
      <p class="text-[0.95rem] text-ink-soft leading-relaxed max-w-md">
        On-chain generative art. One auctioned every day, forever. CC0.
      </p>
    </header>

    <!-- Random Generator -->
    <section class="card-obs mb-10">
      <h2 class="font-serif text-lg text-ink font-semibold mb-4">
        <span class="card-obs-num">01</span>Random Noun
      </h2>

      <div class="flex flex-col items-center gap-6">
        <div class="border-3 border-warm p-2 rounded-lg shadow-[3px_3px_0_var(--color-warm)]">
          <img
            id="random-noun"
            src="https://noun-api.com/beta/pfp"
            alt="Random Noun"
            width="280"
            height="280"
            class="block rounded-md"
            style="image-rendering: pixelated; transition: opacity 0.2s;"
          />
        </div>

        <div class="flex flex-wrap justify-center gap-3">
          <button id="btn-generate" class="px-5 py-2 bg-warm text-white font-mono text-[0.7rem] tracking-[0.14em] uppercase rounded-md hover:bg-warm/90 transition-colors cursor-pointer">
            Generate
          </button>
          <button id="btn-download" class="px-5 py-2 border border-rule text-ink-soft font-mono text-[0.7rem] tracking-[0.14em] uppercase rounded-md hover:border-warm hover:text-warm transition-colors cursor-pointer">
            Download PNG
          </button>
        </div>

        <p class="font-mono text-[0.6rem] tracking-[0.14em] uppercase text-ink-soft/40 text-center">
          Powered by <a href="https://noun-api.com" target="_blank" rel="noopener" class="text-accent hover:underline">noun-api.com</a> &middot; Official trait set
        </p>
      </div>
    </section>

    <!-- Browse Real Nouns -->
    <section class="card-obs mb-10">
      <h2 class="font-serif text-lg text-ink font-semibold mb-4">
        <span class="card-obs-num">02</span>Browse Real Nouns
      </h2>

      <p class="text-[0.95rem] text-ink-soft mb-5">
        Real auctioned Nouns, living on-chain forever.
      </p>

      <div id="nouns-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        <!-- Filled by JS -->
      </div>

      <div class="flex justify-center gap-3 mt-6">
        <button id="btn-shuffle" class="px-5 py-2 bg-warm text-white font-mono text-[0.7rem] tracking-[0.14em] uppercase rounded-md hover:bg-warm/90 transition-colors cursor-pointer">
          Shuffle
        </button>
        <button id="btn-load-more" class="px-5 py-2 border border-rule text-ink-soft font-mono text-[0.7rem] tracking-[0.14em] uppercase rounded-md hover:border-warm hover:text-warm transition-colors cursor-pointer">
          Load More
        </button>
      </div>

      <p class="font-mono text-[0.6rem] tracking-[0.14em] uppercase text-ink-soft/40 text-center mt-4">
        Images from <a href="https://noun.pics" target="_blank" rel="noopener" class="text-accent hover:underline">noun.pics</a> &middot; On-chain artwork
      </p>
    </section>

    <!-- Nouns DAO info section -->
    <section class="card-obs">
      <h2 class="font-serif text-lg text-ink font-semibold mb-4">
        <span class="card-obs-num">03</span>What are Nouns?
      </h2>

      <div class="tldr-list mb-6">
        <div class="tldr-link" style="cursor: default;">
          <span class="tldr-num">&#x2310;&#x25A8;-&#x25A8;</span>
          <span><span class="tldr-title">One Noun, Every Day</span> <span class="tldr-sub">— Trustlessly auctioned every 24 hours, forever. 100% to treasury.</span></span>
        </div>
        <div class="tldr-link" style="cursor: default;">
          <span class="tldr-num">&#x1F3DB;</span>
          <span><span class="tldr-title">On-Chain Governance</span> <span class="tldr-sub">— Each Noun = one vote. No delegation tricks.</span></span>
        </div>
        <div class="tldr-link" style="cursor: default;">
          <span class="tldr-num">&#x267B;</span>
          <span><span class="tldr-title">CC0 Public Domain</span> <span class="tldr-sub">— Anyone can use, remix, and build on Nouns IP. Forever.</span></span>
        </div>
      </div>

      <details class="disclosure mb-4">
        <summary>Proliferation</summary>
        <div class="disclosure-body">
          <p>The Nouns ecosystem extends far beyond the DAO. Builders worldwide
          create projects, apps, and art using the Nouns identity. From
          Nouns Builder (launch your own DAO) to Prop House (funding rounds),
          the infrastructure is open and growing.</p>
        </div>
      </details>

      <details class="disclosure">
        <summary>The Noggles</summary>
        <div class="disclosure-body">
          <p>The iconic noggles (&#x2310;&#x25A8;-&#x25A8;) are the universal symbol of Nouns culture.
          They represent a way of seeing — building in public, creating value
          for everyone, and having fun doing it.</p>
          <div class="flex gap-6 mt-2 text-xl">
            <span class="text-nouns-red">&#x2310;&#x25A8;-&#x25A8;</span>
            <span class="text-nouns-blue">&#x2310;&#x25A8;-&#x25A8;</span>
            <span class="text-warm">&#x2310;&#x25A8;-&#x25A8;</span>
          </div>
        </div>
      </details>

      <div class="mt-6">
        <a href="https://nouns.wtf" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-warm font-mono text-[0.66rem] tracking-[0.14em] uppercase hover:underline">
          nouns.wtf &rarr;
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const MAX_NOUN_ID = 1875;
  const GRID_SIZE = 12;

  const randomImg = document.getElementById('random-noun') as HTMLImageElement;

  document.getElementById('btn-generate')!.addEventListener('click', () => {
    randomImg.style.opacity = '0.3';
    const newSrc = `https://noun-api.com/beta/pfp?t=${Date.now()}`;
    const loader = new Image();
    loader.onload = () => {
      randomImg.src = newSrc;
      randomImg.style.opacity = '1';
    };
    loader.onerror = () => {
      randomImg.style.opacity = '1';
    };
    loader.src = newSrc;
  });

  document.getElementById('btn-download')!.addEventListener('click', async () => {
    try {
      const resp = await fetch(randomImg.src);
      const svgText = await resp.text();
      const blob = new Blob([svgText], { type: 'image/svg+xml' });
      const url = URL.createObjectURL(blob);

      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        canvas.width = 320;
        canvas.height = 320;
        const ctx = canvas.getContext('2d')!;
        ctx.imageSmoothingEnabled = false;
        ctx.drawImage(img, 0, 0, 320, 320);
        URL.revokeObjectURL(url);

        const link = document.createElement('a');
        link.download = `noun-${Date.now()}.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
      };
      img.src = url;
    } catch {
      window.open(randomImg.src, '_blank');
    }
  });

  const grid = document.getElementById('nouns-grid')!;

  function getRandomIds(count: number): number[] {
    const ids = new Set<number>();
    while (ids.size < count) {
      ids.add(Math.floor(Math.random() * (MAX_NOUN_ID + 1)));
    }
    return Array.from(ids).sort((a, b) => a - b);
  }

  function renderGrid(ids: number[], append = false) {
    if (!append) grid.innerHTML = '';

    ids.forEach(id => {
      const card = document.createElement('a');
      card.href = `https://nouns.wtf/noun/${id}`;
      card.target = '_blank';
      card.rel = 'noopener';
      card.className = 'group block';
      card.innerHTML = `
        <div class="editorial-card p-2">
          <img
            src="https://noun.pics/${id}.svg"
            alt="Noun #${id}"
            width="320"
            height="320"
            class="w-full aspect-square rounded-md"
            style="image-rendering: pixelated;"
            loading="lazy"
          />
          <div class="pt-2 flex items-center justify-between">
            <span class="font-mono text-[0.66rem] tracking-[0.1em] text-ink group-hover:text-warm transition-colors">
              Noun #${id}
            </span>
            <span class="text-[0.6rem] text-ink-soft/40 font-mono">\u2310\u25A8-\u25A8</span>
          </div>
        </div>
      `;
      grid.appendChild(card);
    });
  }

  renderGrid(getRandomIds(GRID_SIZE));

  document.getElementById('btn-shuffle')!.addEventListener('click', () => {
    renderGrid(getRandomIds(GRID_SIZE));
  });

  document.getElementById('btn-load-more')!.addEventListener('click', () => {
    renderGrid(getRandomIds(GRID_SIZE), true);
  });
</script>
