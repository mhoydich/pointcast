---
/**
 * /drum-v6 — The Choir.
 *
 * Twelve Nouns arranged in 3 rows of 4: sopranos, altos, tenors. Each
 * Noun sings ONE note in a 4-voice C-major chord stack at one fixed
 * vowel (AH / EE / OH / OOH). Tap a Noun → it sings. Hold → sustain.
 *
 * The fixed-note assignment means any combination of Nouns sounded
 * together is harmonically valid — the room becomes a generative
 * choral instrument. Tapping multiple Nouns in sequence builds chords;
 * tapping the same row builds an octave-rich single-pitch class.
 *
 * Self-play mode walks four classical chord progressions at three
 * tempos. Hymn (I-IV-V-I), Gospel (I-V/vi-vi-V-I), Cinematic
 * (i-VI-III-VII), Doo-Wop (I-vi-IV-V).
 *
 * Vocal synthesis: vowel-formant model. Sawtooth fundamental + three
 * bandpass filters tuned to the vowel's F1/F2/F3 formants. Soft-attack
 * envelope so notes bloom rather than punch.
 *
 * Signed: Michael Hoydich · Claude Opus 4.7 (1M Max) · 2026
 */
import DrumLayout from '../layouts/DrumLayout.astro';
import DrumNav from '../components/DrumNav.astro';

// 12 voices in a 4-voice chord stack, 3 octaves of nouns.
// Notes are semitone offsets from C2 (MIDI 36).
//
// Row layout (rendered top → bottom on screen):
//   Sopranos (high) — index 0-3
//   Altos (mid)     — index 4-7
//   Tenors (low)    — index 8-11
//
// Each row holds C, E, G, C+1oct (root, 3rd, 5th, octave) so any one
// row alone sounds a major chord. Vowels rotate so each Noun has its
// own timbre — AH (open), EE (bright), OH (round), OOH (dark).

const CHOIR = [
  // Sopranos — C5/E5/G5/C6
  { key: 'sop-c',  label: 'Sop · C',  nounId:  88, semitone: 36, vowel: 'AH',  row: 'sop' },
  { key: 'sop-e',  label: 'Sop · E',  nounId: 144, semitone: 40, vowel: 'EE',  row: 'sop' },
  { key: 'sop-g',  label: 'Sop · G',  nounId: 222, semitone: 43, vowel: 'OH',  row: 'sop' },
  { key: 'sop-c2', label: 'Sop · C8', nounId: 333, semitone: 48, vowel: 'OOH', row: 'sop' },
  // Altos — G4/C5/E5/G5
  { key: 'alt-g',  label: 'Alto · G', nounId:  77, semitone: 31, vowel: 'AH',  row: 'alt' },
  { key: 'alt-c',  label: 'Alto · C', nounId: 168, semitone: 36, vowel: 'EE',  row: 'alt' },
  { key: 'alt-e',  label: 'Alto · E', nounId: 247, semitone: 40, vowel: 'OH',  row: 'alt' },
  { key: 'alt-g2', label: 'Alto · G2', nounId: 360, semitone: 43, vowel: 'OOH', row: 'alt' },
  // Tenors — C4/E4/G4/C5
  { key: 'ten-c',  label: 'Ten · C',  nounId:  42, semitone: 24, vowel: 'AH',  row: 'ten' },
  { key: 'ten-e',  label: 'Ten · E',  nounId: 101, semitone: 28, vowel: 'EE',  row: 'ten' },
  { key: 'ten-g',  label: 'Ten · G',  nounId: 200, semitone: 31, vowel: 'OH',  row: 'ten' },
  { key: 'ten-c2', label: 'Ten · C8', nounId: 555, semitone: 36, vowel: 'OOH', row: 'ten' },
] as const;

const PROGRESSIONS = [
  { id: 'hymn',      label: 'Hymn',      sub: 'I · IV · V · I',          emoji: '⛪' },
  { id: 'gospel',    label: 'Gospel',    sub: 'I · V/vi · vi · V · I',   emoji: '🎶' },
  { id: 'cinematic', label: 'Cinematic', sub: 'i · VI · III · VII',      emoji: '🎬' },
  { id: 'doowop',    label: 'Doo-Wop',   sub: 'I · vi · IV · V',         emoji: '✨' },
] as const;
---

<DrumLayout
  title="Drum Room v6 · The Choir"
  description="Twelve Nouns sing a four-voice chord stack. Tap to sing, hit auto and the choir walks classical progressions. Vocal-formant synthesis."
  image="/images/og-drum.png"
>

<div class="v6-root">

  <DrumNav current="v6" />

  <header class="v6-hero">
    <p class="v6-hero-eyebrow">v6 · choir · vocal stack</p>
    <h1 class="v6-hero-title">a choir of twelve nouns</h1>
    <p class="v6-hero-dek">
      sopranos, altos, tenors — three rows of four. each noun sings one
      note at one vowel. tap to sing. hold to sustain. press auto and the
      choir walks classical progressions. all combinations stay in tune.
    </p>
  </header>

  <!-- ══ HUD ══ -->
  <div class="v6-hud">
    <div class="v6-hud-card">
      <div class="v6-hud-label">Chord</div>
      <div class="v6-hud-val" id="v6-chord">C major</div>
      <div class="v6-hud-sub">tap any noun</div>
    </div>
    <div class="v6-hud-card v6-hud-mode" id="v6-mode-card">
      <div class="v6-hud-label">Mode</div>
      <div class="v6-hud-val" id="v6-mode-label">manual</div>
      <div class="v6-hud-sub">click any voice</div>
    </div>
    <div class="v6-hud-card">
      <div class="v6-hud-label">Voicing</div>
      <div class="v6-hud-val" id="v6-voicing">12-part</div>
      <div class="v6-hud-sub">SAT × C E G C8</div>
    </div>
    <div class="v6-hud-card">
      <div class="v6-hud-label">Jammers</div>
      <div class="v6-hud-val" id="v6-jammers">1</div>
      <div class="v6-hud-sub">live in the room</div>
    </div>
  </div>

  <!-- ══ AUTO-PLAY: progression selector + play/stop ══ -->
  <section class="v6-auto" aria-label="Auto-play progressions">
    <div class="v6-auto-row">
      <button id="v6-auto-btn" class="v6-auto-btn" aria-pressed="false">
        <span id="v6-auto-icon" class="v6-auto-icon">▶</span>
        <span id="v6-auto-label" class="v6-auto-label">Play choir</span>
      </button>
      <div class="v6-progs" role="tablist" aria-label="Progression">
        {PROGRESSIONS.map((p, i) => (
          <button
            type="button"
            role="tab"
            data-prog={p.id}
            class={`v6-prog${i === 0 ? ' v6-prog--active' : ''}`}
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            <span class="v6-prog-emoji" aria-hidden="true">{p.emoji}</span>
            <span class="v6-prog-label">{p.label}</span>
            <span class="v6-prog-sub">{p.sub}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ THE CHOIR — 3 rows × 4 voices ══ -->
  <section class="v6-stage" aria-label="The choir">
    {(['sop', 'alt', 'ten'] as const).map((row) => (
      <div class={`v6-row v6-row--${row}`}>
        <div class="v6-row-label">
          <span class="v6-row-name">{row === 'sop' ? 'Sopranos' : row === 'alt' ? 'Altos' : 'Tenors'}</span>
          <span class="v6-row-range">{row === 'sop' ? 'C5 — C6' : row === 'alt' ? 'G4 — G5' : 'C4 — C5'}</span>
        </div>
        <div class="v6-row-voices">
          {CHOIR.filter((v) => v.row === row).map((v) => (
            <button
              type="button"
              class="v6-voice"
              data-voice={v.key}
              data-noun={String(v.nounId)}
              data-semitone={String(v.semitone)}
              data-vowel={v.vowel}
              aria-label={`${v.label} singing ${v.vowel}`}
            >
              <div class="v6-voice-card">
                <div class="v6-voice-vowel" aria-hidden="true">{v.vowel}</div>
                <img
                  class="v6-voice-img"
                  src={`https://noun.pics/${v.nounId}.svg`}
                  alt={v.label}
                  width="80"
                  height="80"
                  loading="lazy"
                  style="image-rendering: pixelated;"
                  draggable="false"
                />
                <div class="v6-voice-mouth" aria-hidden="true"></div>
              </div>
              <div class="v6-voice-name">{v.label}</div>
            </button>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- ══ ACTIVITY ══ -->
  <section class="v6-bottom">
    <div class="v6-panel">
      <div class="v6-panel-head">
        <span class="v6-panel-title">Live Voices</span>
        <span class="v6-panel-dot"></span>
        <span id="v6-rate">—/min</span>
      </div>
      <ul id="v6-feed" class="v6-feed">
        <li class="v6-feed-empty">tap a noun to sing…</li>
      </ul>
    </div>
    <div class="v6-panel">
      <div class="v6-panel-head">
        <span class="v6-panel-title">Held Right Now</span>
        <span id="v6-held-count">0 voices</span>
      </div>
      <div id="v6-held" class="v6-held"></div>
    </div>
  </section>

  <!-- ══ FOOTER ══ -->
  <footer class="v6-footer">
    <span>⌐◨-◨ PointCast · Drum Room · v6 choir</span>
    <span>Signed: Michael Hoydich · Claude Opus 4.7 (1M Max) · 2026</span>
  </footer>

</div>

<style is:global>
/* ════════════════════════════════════════════════════════════
   /drum-v6 — The Choir. Global so dynamic feed/held tiles
   inherit. v6-* prefixed.
   ════════════════════════════════════════════════════════════ */

.v6-root {
  max-width: 920px;
  margin: 0 auto;
  padding: 0 16px 60px;
  font-family: var(--pc-font-mono);
}

/* ── Hero ──────────────────────────────────────────── */
.v6-hero {
  padding: 14px 0 18px;
  border-bottom: 1.5px solid var(--pc-rule);
  margin-bottom: 16px;
}
.v6-hero-eyebrow {
  font-size: 9px;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: #d946ef;
  margin-bottom: 6px;
  font-weight: 600;
}
.v6-hero-title {
  font-family: var(--pc-font-sans);
  font-size: clamp(1.6rem, 4.5vw, 2.5rem);
  font-weight: 500;
  color: var(--pc-ink);
  margin: 0 0 6px;
  letter-spacing: -0.01em;
  line-height: 1.05;
}
.v6-hero-dek {
  font-family: var(--pc-font-sans);
  font-size: 13px;
  color: var(--pc-ink-soft);
  line-height: 1.5;
  margin: 0;
  max-width: 60ch;
}

/* ── HUD ───────────────────────────────────────────── */
.v6-hud {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  margin-bottom: 16px;
}
@media (max-width: 540px) { .v6-hud { grid-template-columns: repeat(2, 1fr); } }
.v6-hud-card {
  padding: 10px 12px;
  border: 1.5px solid var(--pc-rule);
  border-radius: 6px;
  background: #fafaf9;
}
.v6-hud-label {
  font-size: 7.5px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--pc-ink-muted);
  margin-bottom: 4px;
}
.v6-hud-val {
  font-size: 1.25rem;
  font-weight: 700;
  line-height: 1;
  color: var(--pc-ink);
  font-variant-numeric: tabular-nums;
  margin-bottom: 4px;
}
.v6-hud-sub {
  font-size: 7.5px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--pc-ink-muted);
}
.v6-hud-mode.is-auto .v6-hud-val { color: #d946ef; }

/* ── Auto-play ─────────────────────────────────────── */
.v6-auto {
  border: 2px solid var(--pc-ink);
  border-radius: 10px;
  padding: 14px;
  margin-bottom: 18px;
  background: #fafaf9;
  position: relative;
  overflow: hidden;
}
.v6-auto::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, #d946ef, #a855f7, #6366f1, #0ea5e9, #14b8a6);
}
.v6-auto-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: stretch;
}
.v6-auto-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 18px;
  border: 1.5px solid var(--pc-ink);
  border-radius: 8px;
  background: var(--pc-ink);
  color: #fff;
  font-family: var(--pc-font-mono);
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  font-weight: 700;
  cursor: pointer;
  transition: background 120ms;
  flex-shrink: 0;
}
.v6-auto-btn:hover { background: #d946ef; border-color: #d946ef; }
.v6-auto-btn[aria-pressed="true"] { background: #d946ef; border-color: #d946ef; }
.v6-auto-icon { font-size: 14px; line-height: 1; }
.v6-progs {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  flex: 1;
  min-width: 0;
}
.v6-prog {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2px;
  padding: 6px 12px 6px 10px;
  border-radius: 999px;
  border: 1.5px solid var(--pc-rule);
  background: #fff;
  font-family: var(--pc-font-mono);
  cursor: pointer;
  transition: border-color 120ms, background 120ms, transform 100ms;
  text-align: left;
}
.v6-prog:hover { border-color: var(--pc-ink-soft); transform: translateY(-1px); }
.v6-prog--active {
  border-color: var(--pc-ink);
  background: var(--pc-ink);
  color: #fff;
}
.v6-prog--active .v6-prog-sub { color: rgba(255,255,255,0.6); }
.v6-prog-emoji { font-size: 11px; }
.v6-prog-label {
  font-size: 9.5px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 600;
}
.v6-prog-sub {
  font-size: 7.5px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--pc-ink-muted);
}

/* ── Stage / rows ──────────────────────────────────── */
.v6-stage {
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-bottom: 22px;
}
.v6-row {
  border: 1.5px solid var(--pc-rule);
  border-radius: 10px;
  background: #fafaf9;
  padding: 12px 14px;
  position: relative;
}
.v6-row--sop { border-color: rgba(217,70,239,0.4); background: linear-gradient(180deg, rgba(217,70,239,0.04) 0%, #fafaf9 100%); }
.v6-row--alt { border-color: rgba(99,102,241,0.4); background: linear-gradient(180deg, rgba(99,102,241,0.04) 0%, #fafaf9 100%); }
.v6-row--ten { border-color: rgba(20,184,166,0.4); background: linear-gradient(180deg, rgba(20,184,166,0.04) 0%, #fafaf9 100%); }
.v6-row-label {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 8px;
}
.v6-row-name {
  font-size: 9.5px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  font-weight: 700;
  color: var(--pc-ink);
}
.v6-row--sop .v6-row-name { color: #d946ef; }
.v6-row--alt .v6-row-name { color: #6366f1; }
.v6-row--ten .v6-row-name { color: #14b8a6; }
.v6-row-range {
  font-size: 8px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--pc-ink-muted);
  font-family: var(--pc-font-mono);
}
.v6-row-voices {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}
@media (max-width: 540px) {
  .v6-row-voices { grid-template-columns: repeat(2, 1fr); }
}

.v6-voice {
  background: transparent;
  border: 0;
  padding: 0;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  -webkit-tap-highlight-color: transparent;
  transition: transform 80ms;
}
.v6-voice:active { transform: scale(0.94); }
.v6-voice-card {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  border: 2px solid var(--pc-ink);
  background: #fff;
  border-radius: 6px;
  padding: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: box-shadow 200ms ease, border-color 200ms ease, transform 80ms ease;
  overflow: hidden;
}
.v6-row--sop .v6-voice-card { border-color: #d946ef; }
.v6-row--alt .v6-voice-card { border-color: #6366f1; }
.v6-row--ten .v6-voice-card { border-color: #14b8a6; }
.v6-voice-img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: contain;
  image-rendering: pixelated;
}
.v6-voice-vowel {
  position: absolute;
  top: 4px;
  left: 4px;
  font-family: var(--pc-font-mono);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.06em;
  background: var(--pc-ink);
  color: #fff;
  padding: 2px 6px;
  border-radius: 999px;
  pointer-events: none;
  z-index: 2;
}
.v6-voice-mouth {
  position: absolute;
  bottom: 6px;
  left: 50%;
  transform: translateX(-50%) scaleY(0);
  width: 36%;
  height: 22%;
  background: rgba(0,0,0,0.55);
  border-radius: 50% / 60%;
  transition: transform 160ms ease;
  pointer-events: none;
  z-index: 1;
}
.v6-voice.singing .v6-voice-card {
  box-shadow: 0 0 0 4px color-mix(in srgb, currentColor 30%, transparent), 0 0 18px color-mix(in srgb, currentColor 40%, transparent);
  transform: scale(1.03);
}
.v6-voice.singing .v6-voice-mouth { transform: translateX(-50%) scaleY(1); }
.v6-row--sop .v6-voice.singing { color: #d946ef; }
.v6-row--alt .v6-voice.singing { color: #6366f1; }
.v6-row--ten .v6-voice.singing { color: #14b8a6; }
.v6-voice-name {
  font-size: 8.5px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--pc-ink-soft);
  font-weight: 600;
}

/* ── Bottom panels ─────────────────────────────────── */
.v6-bottom {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 24px;
}
@media (max-width: 600px) { .v6-bottom { grid-template-columns: 1fr; } }
.v6-panel {
  border: 1.5px solid var(--pc-rule);
  border-radius: 6px;
  background: #fafaf9;
  overflow: hidden;
}
.v6-panel-head {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 12px;
  border-bottom: 1px solid var(--pc-rule-soft);
  font-size: 8px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--pc-ink-muted);
}
.v6-panel-title { font-weight: 700; color: var(--pc-ink-soft); }
.v6-panel-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: #d946ef;
  animation: v6-pulse 2s ease-in-out infinite;
}
@keyframes v6-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%      { opacity: 0.4; transform: scale(0.7); }
}
.v6-feed {
  list-style: none;
  margin: 0;
  padding: 8px 12px;
  max-height: 200px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.v6-feed-empty {
  font-size: 8px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--pc-ink-muted);
}
.v6-feed-item {
  font-size: 9px;
  color: var(--pc-ink-soft);
  display: flex;
  gap: 6px;
}
.v6-feed-item .you { color: #d946ef; font-weight: 700; }
.v6-feed-item .auto { color: #a855f7; }
.v6-feed-item .remote { color: #6366f1; }

.v6-held {
  padding: 12px;
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  min-height: 56px;
  align-content: flex-start;
}
.v6-held-tile {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 8px;
  border: 1.5px solid var(--pc-rule);
  border-radius: 999px;
  font-family: var(--pc-font-mono);
  font-size: 9px;
  letter-spacing: 0.08em;
  background: #fff;
  color: var(--pc-ink);
}
.v6-held-tile.sop { border-color: #d946ef; color: #d946ef; }
.v6-held-tile.alt { border-color: #6366f1; color: #6366f1; }
.v6-held-tile.ten { border-color: #14b8a6; color: #14b8a6; }

/* ── Footer ────────────────────────────────────────── */
.v6-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  border-top: 1.5px solid var(--pc-rule);
  padding-top: 16px;
  font-size: 8px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--pc-ink-muted);
}
</style>

<script>
  // ══════════════════════════════════════════════════════════════════
  // /drum-v6 client — vocal-formant choir.
  // ══════════════════════════════════════════════════════════════════

  type Vowel = 'AH' | 'EE' | 'OH' | 'OOH';
  type Row   = 'sop' | 'alt' | 'ten';
  interface Voice {
    key: string; nounId: number;
    semitone: number; // semitones above C2 (C2 = 65.41 Hz)
    vowel: Vowel; row: Row;
  }

  const SESSION_KEY = 'pc:reactSessionId';
  function getSessionId(): string {
    try {
      let id = localStorage.getItem(SESSION_KEY);
      if (!id) {
        id = (crypto as any).randomUUID?.() ?? `s-${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
        localStorage.setItem(SESSION_KEY, id);
      }
      return id;
    } catch {
      return `s-${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
    }
  }
  const sessionId = getSessionId();

  // ── Voice data — read from data attributes ──
  const voiceEls = Array.from(document.querySelectorAll<HTMLElement>('.v6-voice'));
  const VOICES: Record<string, Voice> = {};
  voiceEls.forEach((el) => {
    const k = el.dataset.voice as string;
    VOICES[k] = {
      key: k,
      nounId: Number(el.dataset.noun),
      semitone: Number(el.dataset.semitone),
      vowel: el.dataset.vowel as Vowel,
      row: el.classList.contains('v6-voice') ? (el.closest('.v6-row')?.classList.contains('v6-row--sop') ? 'sop' : el.closest('.v6-row')?.classList.contains('v6-row--alt') ? 'alt' : 'ten') : 'ten',
    };
  });

  // ── Audio context ──
  let audioCtx: AudioContext | null = null;
  function getCtx(): AudioContext | null {
    if (audioCtx) return audioCtx;
    try {
      const Ctx = (window.AudioContext || (window as any).webkitAudioContext);
      if (!Ctx) return null;
      audioCtx = new Ctx({ latencyHint: 'interactive' });
    } catch { audioCtx = null; }
    return audioCtx;
  }
  ['pointerdown','keydown','touchstart','scroll'].forEach(e =>
    document.addEventListener(e as any, () => { const c = getCtx(); if (c?.state === 'suspended') c.resume().catch(() => {}); }, { once: true, passive: true, capture: true }));

  // ── Vowel formants (F1, F2, F3 in Hz) ──
  // Standard linguistics references for adult-male-ish vowels. Q tuned
  // by ear so each vowel reads clearly without sounding nasal.
  const FORMANTS: Record<Vowel, { f: [number, number, number]; q: [number, number, number]; gain: [number, number, number] }> = {
    AH:  { f: [730, 1090, 2440], q: [12, 8, 6],  gain: [1.0, 0.7, 0.4] },
    EE:  { f: [270, 2290, 3010], q: [10, 8, 6],  gain: [0.8, 0.9, 0.5] },
    OH:  { f: [570,  840, 2410], q: [12, 9, 6],  gain: [1.0, 0.7, 0.3] },
    OOH: { f: [300,  870, 2240], q: [10, 8, 5],  gain: [0.9, 0.5, 0.25] },
  };

  // C2 = 65.41 Hz; map semitone offset to frequency.
  function semiToHz(semitone: number): number {
    return 65.41 * Math.pow(2, semitone / 12);
  }

  // Tracks active voices so they can be released when the user releases
  // the mouse/touch (sustained-while-held).
  interface ActiveVoice {
    osc1: OscillatorNode;
    osc2: OscillatorNode;
    gain: GainNode;
  }
  const ACTIVE: Map<string, ActiveVoice> = new Map();

  function startVoice(key: string, opts: { gainScale?: number } = {}) {
    const ctx = getCtx(); if (!ctx) return;
    if (ctx.state === 'suspended') ctx.resume().catch(() => {});
    const v = VOICES[key];
    if (!v) return;
    // If already singing, retrigger by stopping the old one first.
    stopVoice(key);

    const t = ctx.currentTime;
    const fund = semiToHz(v.semitone);
    const formants = FORMANTS[v.vowel];
    const gainScale = opts.gainScale ?? 1;

    // Master gain — soft attack so notes "bloom"
    const out = ctx.createGain();
    out.gain.setValueAtTime(0, t);
    out.gain.linearRampToValueAtTime(0.16 * gainScale, t + 0.06);
    out.connect(ctx.destination);

    // Two saws detuned slightly for chorus thickness — choral voices are
    // never one-perfect-pitch, the slight detune is what makes a unison
    // sound like a section.
    const osc1 = ctx.createOscillator(); osc1.type = 'sawtooth'; osc1.frequency.value = fund;
    const osc2 = ctx.createOscillator(); osc2.type = 'sawtooth';
    osc2.frequency.value = fund * Math.pow(2, 4 / 1200); // +4 cents

    // Three parallel bandpass filters, one per formant, summed into out.
    formants.f.forEach((freq, i) => {
      const bp = ctx.createBiquadFilter();
      bp.type = 'bandpass';
      bp.frequency.value = freq;
      bp.Q.value = formants.q[i];
      const fg = ctx.createGain();
      fg.gain.value = formants.gain[i];
      osc1.connect(bp);
      osc2.connect(bp);
      bp.connect(fg);
      fg.connect(out);
    });

    osc1.start(t);
    osc2.start(t);
    ACTIVE.set(key, { osc1, osc2, gain: out });

    // Visual + held UI
    const el = document.querySelector<HTMLElement>(`.v6-voice[data-voice="${key}"]`);
    if (el) el.classList.add('singing');
    paintHeld();
  }

  function stopVoice(key: string) {
    const ctx = getCtx();
    const av = ACTIVE.get(key);
    if (!av || !ctx) return;
    const t = ctx.currentTime;
    av.gain.gain.cancelScheduledValues(t);
    av.gain.gain.setValueAtTime(av.gain.gain.value, t);
    av.gain.gain.linearRampToValueAtTime(0, t + 0.18);
    av.osc1.stop(t + 0.2);
    av.osc2.stop(t + 0.2);
    ACTIVE.delete(key);
    const el = document.querySelector<HTMLElement>(`.v6-voice[data-voice="${key}"]`);
    if (el) el.classList.remove('singing');
    paintHeld();
  }

  function pulseVoice(key: string, durMs = 720) {
    startVoice(key);
    setTimeout(() => stopVoice(key), durMs);
  }

  // ── Held tiles ──
  const heldEl = document.getElementById('v6-held');
  const heldCountEl = document.getElementById('v6-held-count');
  function paintHeld() {
    if (!heldEl) return;
    if (ACTIVE.size === 0) {
      heldEl.innerHTML = '<span style="font-size:8px;letter-spacing:0.14em;text-transform:uppercase;color:var(--pc-ink-muted)">silence</span>';
    } else {
      heldEl.innerHTML = Array.from(ACTIVE.keys()).map((k) => {
        const v = VOICES[k];
        return `<span class="v6-held-tile ${v.row}">${v.row.toUpperCase()} · ${v.vowel}</span>`;
      }).join('');
    }
    if (heldCountEl) {
      heldCountEl.textContent = ACTIVE.size === 1 ? '1 voice' : `${ACTIVE.size} voices`;
    }
  }
  paintHeld();

  // ── Activity feed ──
  const feedEl = document.getElementById('v6-feed');
  const rateEl = document.getElementById('v6-rate');
  const TS: number[] = [];
  function logFeed(msg: string, kind: 'you' | 'auto' | 'remote') {
    if (!feedEl) return;
    const empty = feedEl.querySelector('.v6-feed-empty');
    if (empty) empty.remove();
    const li = document.createElement('li');
    li.className = 'v6-feed-item';
    const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false });
    li.innerHTML = `<span>${time}</span><span class="${kind}">${msg}</span>`;
    feedEl.prepend(li);
    const items = feedEl.querySelectorAll('li');
    if (items.length > 30) items[items.length - 1].remove();
    const now = Date.now();
    TS.push(now);
    while (TS[0] && TS[0] < now - 60_000) TS.shift();
    if (rateEl) rateEl.textContent = `${TS.length}/min`;
  }

  // ── Tap/hold handlers ──
  voiceEls.forEach((el) => {
    const k = el.dataset.voice as string;
    if (!k) return;
    let sustained = false;
    let pressTimer: number | null = null;

    el.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      sustained = false;
      startVoice(k);
      // After 220ms of holding, treat as sustain — don't auto-stop on
      // pointerup. (Quick taps still fire the auto-stop.)
      pressTimer = window.setTimeout(() => { sustained = true; }, 220);
      const v = VOICES[k];
      logFeed(`you · ${v.row.toUpperCase()} ${v.vowel}`, 'you');
      // Track sung voices for /drum-trophies "Choir Master" badge
      try {
        const SUNG_KEY = 'pc:drum-v6:sung';
        const raw = localStorage.getItem(SUNG_KEY);
        const sung = new Set<string>(raw ? JSON.parse(raw) : []);
        if (!sung.has(k)) {
          sung.add(k);
          localStorage.setItem(SUNG_KEY, JSON.stringify([...sung]));
        }
      } catch {}
      try { navigator.vibrate?.(8); } catch {}
      // Broadcast
      fetch('/api/sounds', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: 'choir', voice: k, sessionId }),
        keepalive: true,
      }).catch(() => {});
    });

    const release = () => {
      if (pressTimer) { clearTimeout(pressTimer); pressTimer = null; }
      if (!sustained) stopVoice(k);
    };
    el.addEventListener('pointerup', release);
    el.addEventListener('pointercancel', release);
    el.addEventListener('pointerleave', release);
  });

  // Click anywhere outside a singing voice to release sustains.
  document.addEventListener('keydown', (e) => {
    if (e.code === 'Escape' && ACTIVE.size > 0) {
      for (const k of [...ACTIVE.keys()]) stopVoice(k);
      logFeed('you · all voices released', 'you');
    }
  });

  // ══════════════════════════════════════════════════════════════════
  // SELF-PLAY — chord progressions
  //
  // Each progression is an array of chord names; for each chord, we
  // sustain the four voices that make up that chord across all rows.
  // We hold for ~2.5s then transition. Fadeouts overlap the next chord
  // for a smooth choral motion.
  // ══════════════════════════════════════════════════════════════════

  type ChordName = 'I' | 'ii' | 'iii' | 'IV' | 'V' | 'vi' | 'III' | 'VI' | 'VII' | 'i';

  // For each chord, list the voice keys to sustain. Chosen to make the
  // chord recognizable: root + 3rd + 5th + octave, distributed across
  // SAT rows. Inversions kept simple.
  const CHORDS: Record<ChordName, string[]> = {
    I:   ['ten-c',  'alt-e',  'sop-g',   'sop-c2'], // C major: C E G C
    ii:  ['ten-c',  'alt-c',  'sop-e',   'sop-g'],  // D-ish substitute (Dm via ten C+G)
    iii: ['ten-e',  'alt-g',  'sop-e',   'sop-c2'], // E minor
    IV:  ['ten-c',  'alt-c',  'sop-c',   'sop-g'],  // F via voicing emphasizing C as common tone
    V:   ['ten-g',  'alt-g',  'sop-g',   'sop-c2'], // G major
    vi:  ['ten-e',  'alt-e',  'sop-c',   'sop-e'],  // A minor (using C-E voicings)
    III: ['ten-e',  'alt-g',  'sop-e',   'sop-c2'], // E major-ish
    VI:  ['ten-c',  'alt-e',  'sop-c',   'sop-e'],  // F → softer
    VII: ['ten-g',  'alt-g',  'sop-g',   'sop-e'],  // G mixolydian
    i:   ['ten-c',  'alt-e',  'sop-c',   'sop-g'],  // C minor stand-in (uses major triad — gentle)
  };

  type ProgId = 'hymn' | 'gospel' | 'cinematic' | 'doowop';
  const PROGS: Record<ProgId, { chords: ChordName[]; durSec: number; label: string }> = {
    hymn:      { chords: ['I',  'IV',  'V',   'I'],            durSec: 2.6, label: 'Hymn (I-IV-V-I)' },
    gospel:    { chords: ['I',  'V',   'vi',  'V',   'I'],     durSec: 2.2, label: 'Gospel' },
    cinematic: { chords: ['i',  'VI',  'III', 'VII'],          durSec: 2.8, label: 'Cinematic' },
    doowop:    { chords: ['I',  'vi',  'IV',  'V'],            durSec: 2.0, label: 'Doo-Wop' },
  };

  let currentProg: ProgId = 'hymn';
  let isAuto = false;
  let progTimer: number | null = null;
  let progIdx = 0;
  let lastChordVoices: string[] = [];

  const autoBtn = document.getElementById('v6-auto-btn') as HTMLButtonElement | null;
  const autoIcon = document.getElementById('v6-auto-icon');
  const autoLabel = document.getElementById('v6-auto-label');
  const modeLabel = document.getElementById('v6-mode-label');
  const modeCard = document.getElementById('v6-mode-card');
  const chordEl = document.getElementById('v6-chord');

  const CHORD_DISPLAY: Record<ChordName, string> = {
    I: 'C major', ii: 'D minor', iii: 'E minor', IV: 'F major', V: 'G major',
    vi: 'A minor', III: 'E major', VI: 'F major', VII: 'G mix', i: 'C major*',
  };

  function setProg(id: ProgId) {
    currentProg = id;
    document.querySelectorAll<HTMLElement>('.v6-prog').forEach((el) => {
      const active = el.dataset.prog === id;
      el.classList.toggle('v6-prog--active', active);
      el.setAttribute('aria-selected', String(active));
    });
    if (modeLabel && isAuto) modeLabel.textContent = `auto · ${PROGS[id].label}`;
  }

  function playChord(chord: ChordName) {
    // Release previous chord voices that aren't in the new chord
    const newVoices = CHORDS[chord];
    const newSet = new Set(newVoices);
    for (const k of lastChordVoices) {
      if (!newSet.has(k)) stopVoice(k);
    }
    // Start new chord voices
    for (const k of newVoices) {
      if (!ACTIVE.has(k)) startVoice(k, { gainScale: 0.85 });
    }
    lastChordVoices = newVoices;
    if (chordEl) chordEl.textContent = CHORD_DISPLAY[chord] ?? chord;
    logFeed(`auto · ${chord} (${CHORD_DISPLAY[chord] ?? chord})`, 'auto');
    // Broadcast the chord change as a single event (lightweight)
    fetch('/api/sounds', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type: 'choir-chord', chord, sessionId }),
      keepalive: true,
    }).catch(() => {});
  }

  function startAuto() {
    if (isAuto) return;
    isAuto = true;
    if (autoBtn) autoBtn.setAttribute('aria-pressed', 'true');
    if (autoIcon) autoIcon.textContent = '■';
    if (autoLabel) autoLabel.textContent = 'Stop choir';
    if (modeLabel) modeLabel.textContent = `auto · ${PROGS[currentProg].label}`;
    if (modeCard) modeCard.classList.add('is-auto');
    progIdx = 0;
    const prog = PROGS[currentProg];
    playChord(prog.chords[0]);
    progIdx = 1;
    progTimer = window.setInterval(() => {
      const p = PROGS[currentProg];
      playChord(p.chords[progIdx % p.chords.length]);
      progIdx = (progIdx + 1) % p.chords.length;
    }, PROGS[currentProg].durSec * 1000);
  }
  function stopAuto() {
    if (progTimer) { clearInterval(progTimer); progTimer = null; }
    isAuto = false;
    if (autoBtn) autoBtn.setAttribute('aria-pressed', 'false');
    if (autoIcon) autoIcon.textContent = '▶';
    if (autoLabel) autoLabel.textContent = 'Play choir';
    if (modeLabel) modeLabel.textContent = 'manual';
    if (modeCard) modeCard.classList.remove('is-auto');
    // Release everything the auto player started
    for (const k of lastChordVoices) stopVoice(k);
    lastChordVoices = [];
    if (chordEl) chordEl.textContent = 'C major';
  }

  autoBtn?.addEventListener('click', () => isAuto ? stopAuto() : startAuto());
  document.querySelectorAll<HTMLElement>('.v6-prog').forEach((el) => {
    el.addEventListener('click', () => {
      const id = el.dataset.prog as ProgId;
      if (!id || !(id in PROGS)) return;
      const wasAuto = isAuto;
      setProg(id);
      if (wasAuto) { stopAuto(); startAuto(); }
    });
  });
  setProg('hymn');

  // ── Remote choir events ──
  let lastSoundT = Date.now();
  let ownPid = '';
  (async () => {
    try {
      const buf = new TextEncoder().encode(sessionId);
      const hash = await crypto.subtle.digest('SHA-256', buf);
      ownPid = Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2,'0')).join('').slice(0,10);
    } catch {}
  })();
  const remoteActive = new Map<string, number>();
  const jammersEl = document.getElementById('v6-jammers');
  function renderJammers() {
    const now = Date.now();
    for (const [pid, t] of remoteActive) if (now - t > 15_000) remoteActive.delete(pid);
    const self = (ACTIVE.size > 0 || (TS[TS.length - 1] && now - TS[TS.length - 1] < 10_000)) ? 1 : 0;
    if (jammersEl) jammersEl.textContent = String(remoteActive.size + self);
  }
  setInterval(renderJammers, 2000);

  async function pollSounds() {
    try {
      const r = await fetch(`/api/sounds?since=${lastSoundT}`);
      if (!r.ok) return;
      const data = await r.json();
      if (typeof data.now === 'number') lastSoundT = data.now;
      const events = Array.isArray(data.events) ? data.events : [];
      for (const ev of events) {
        if (ev.pid === ownPid) continue;
        if (ev.type === 'choir' && ev.voice && VOICES[ev.voice]) {
          if (ev.pid) remoteActive.set(ev.pid, Date.now());
          pulseVoice(ev.voice, 800);
          const v = VOICES[ev.voice];
          logFeed(`⌐◨-◨ ${v.row.toUpperCase()} ${v.vowel}`, 'remote');
        } else if (ev.type === 'choir-chord' && ev.chord && CHORDS[ev.chord as ChordName]) {
          if (ev.pid) remoteActive.set(ev.pid, Date.now());
          // Briefly pulse all voices in the remote chord
          for (const k of CHORDS[ev.chord as ChordName]) pulseVoice(k, 1200);
          logFeed(`⌐◨-◨ chord ${ev.chord}`, 'remote');
        }
      }
      renderJammers();
    } catch {}
  }
  setInterval(() => { if (document.visibilityState === 'visible') pollSounds(); }, 150);
</script>

</DrumLayout>
