---
/**
 * /nouns-open-circuit - rival agent-operated league desk for the Nouns battler universe.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import {
  NOC_AGENTS,
  NOC_AGENT_HANDOFFS,
  NOC_AGENT_SHIFT_PROTOCOL,
  NOC_CLUBS,
  NOC_ENDPOINTS,
  NOC_FIXTURES,
  NOC_FORMATIONS,
  NOC_PACKET_SHAPE,
  NOC_PRINCIPLES,
  NOC_RECEIPT_SHAPE,
  NOC_STORAGE_KEYS,
  NOC_TARGET_POLICIES,
  NOC_V2_RELEASE,
  NOC_VERSION,
} from '../lib/nouns-open-circuit';

const clientPayload = {
  version: NOC_VERSION,
  clubs: NOC_CLUBS,
  agents: NOC_AGENTS,
  fixtures: NOC_FIXTURES,
  release: NOC_V2_RELEASE,
  agentShiftProtocol: NOC_AGENT_SHIFT_PROTOCOL,
  agentHandoffs: NOC_AGENT_HANDOFFS,
  formations: NOC_FORMATIONS,
  targetPolicies: NOC_TARGET_POLICIES,
  storageKeys: NOC_STORAGE_KEYS,
  endpoints: NOC_ENDPOINTS,
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Nouns Open Circuit',
  description:
    'A rival agent-operated league product for the same Nouns player pool: clubs, live agent shifts, tactics packets, fixture receipts, agent benches, and public JSON surfaces.',
  url: 'https://pointcast.xyz/nouns-open-circuit',
  gamePlatform: 'Web browser',
  genre: 'Auto battler league desk',
  inLanguage: 'en-US',
};
---

<BlockLayout
  title="Nouns Open Circuit"
  description="A rival agent-operated league product for the same Nouns player pool: clubs, live agent shifts, tactics packets, fixture receipts, agent benches, and public JSON surfaces."
  image="/images/og/battle.png"
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/nouns-open-circuit.json', title: 'Nouns Open Circuit manifest (JSON)' }]}
  frame={{
    image: 'https://pointcast.xyz/images/og/battle.png',
    buttons: [
      { label: 'Open Circuit', action: 'link', target: 'https://pointcast.xyz/nouns-open-circuit' },
      { label: 'Circuit JSON', action: 'link', target: 'https://pointcast.xyz/nouns-open-circuit.json' },
      { label: 'Nation Battler', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler' },
      { label: 'Agents', action: 'link', target: 'https://pointcast.xyz/agents.json' },
    ],
  }}
>
  <main class="noc">
    <section class="desk" aria-label="Nouns Open Circuit league desk">
      <div class="desk__lead">
        <p class="kicker">CH.BTL / RIVAL LEAGUE / AGENT OPERATED / V2</p>
        <h1>Nouns Open Circuit</h1>
        <p>
          Same Nouns. New league. Clubs publish agent tactics before kickoff, agents run visible shifts during the match,
          and every fixture resolves into receipt-shaped records that humans can watch and machine readers can cite.
        </p>
        <div class="desk__links" aria-label="Machine-readable links">
          <a href="/nouns-open-circuit.json">/nouns-open-circuit.json</a>
          <a id="deskMatchLink" href={NOC_FIXTURES[0].route}>match receipt</a>
          <a href="/nouns-nation-battler">incumbent league</a>
          <a href="/games/nouns-nation-battler/assets/manifest.json">sprite manifest</a>
        </div>
      </div>

      <div class="fixture-card" aria-label="Featured fixture">
        <span id="fixtureTag">Rivalry seed</span>
        <strong id="fixtureTitle">Opening Desk Match</strong>
        <div class="fixture-card__match">
          <div>
            <img id="homeNoun" src={NOC_CLUBS[0].image} alt="" loading="eager" />
            <b id="homeCode">BPC</b>
          </div>
          <em>vs</em>
          <div>
            <img id="awayNoun" src={NOC_CLUBS[5].image} alt="" loading="eager" />
            <b id="awayCode">PHC</b>
          </div>
        </div>
        <p id="fixtureSeed">seed: noc-open-001</p>
      </div>
    </section>

    <section class="club-switcher" aria-label="Club selection">
      {NOC_CLUBS.map((club, index) => (
        <button class={index === 0 ? 'is-active' : ''} type="button" data-club={club.slug} style={`--club:${club.color};`}>
          <img src={club.image} alt="" loading="lazy" />
          <span>{club.code}</span>
          <strong>{club.name}</strong>
        </button>
      ))}
    </section>

    <section class="ops-grid" aria-label="League operations">
      <article class="club-panel">
        <div class="panel-head">
          <span>Selected Club</span>
          <strong id="clubName">{NOC_CLUBS[0].name}</strong>
        </div>
        <div class="club-panel__body">
          <img id="clubImage" src={NOC_CLUBS[0].image} alt="" loading="lazy" />
          <div>
            <p id="clubDoctrine">{NOC_CLUBS[0].doctrine}</p>
            <dl>
              <div><dt>Operator</dt><dd id="clubOperator">{NOC_CLUBS[0].operator}</dd></div>
              <div><dt>Home</dt><dd id="clubHome">{NOC_CLUBS[0].home}</dd></div>
              <div><dt>Record</dt><dd id="clubRecord">{NOC_CLUBS[0].record}</dd></div>
              <div><dt>Heat</dt><dd id="clubHeat">{NOC_CLUBS[0].heat}</dd></div>
            </dl>
          </div>
        </div>
        <div class="noun-strip" id="nounStrip" aria-label="Club Noun pool"></div>
      </article>

      <article class="agent-panel">
        <div class="panel-head">
          <span>Agent Bench</span>
          <strong>{NOC_AGENTS.length} roles</strong>
        </div>
        <div class="agent-list">
          {NOC_AGENTS.map((agent) => (
            <div class={`agent-row agent-row--${agent.status}`}>
              <b>{agent.callSign}</b>
              <strong>{agent.label}</strong>
              <span>{agent.output}</span>
            </div>
          ))}
        </div>
      </article>

      <article class="packet-panel">
        <div class="panel-head">
          <span>Tactics Packet</span>
          <strong id="packetStatus">ready</strong>
        </div>
        <div class="button-row">
          <button id="packetButton" type="button">Generate Packet</button>
          <button id="receiptButton" type="button">Issue Receipt</button>
        </div>
        <pre id="packetPreview" aria-label="Tactics packet preview"></pre>
      </article>

      <article class="receipt-panel">
        <div class="panel-head">
          <span>Fixture Receipt</span>
          <strong id="receiptStatus">local preview</strong>
        </div>
        <div class="result-banner" id="resultBanner">Awaiting receipt.</div>
        <pre id="receiptPreview" aria-label="Receipt preview"></pre>
      </article>

      <article class="live-panel">
        <div class="panel-head">
          <span>Live Agent Match</span>
          <strong id="liveStatus">shift 0</strong>
        </div>
        <div class="live-scoreboard" aria-label="Live match state">
          <div>
            <span id="liveHomeCode">BPC</span>
            <strong id="liveHomeScore">0</strong>
            <small id="liveHomeMomentum">50 momentum</small>
          </div>
          <b id="liveClock">00'</b>
          <div>
            <span id="liveAwayCode">PHC</span>
            <strong id="liveAwayScore">0</strong>
            <small id="liveAwayMomentum">50 momentum</small>
          </div>
        </div>
        <div class="button-row button-row--three">
          <button id="shiftButton" type="button">Run Agent Shift</button>
          <button id="resetMatchButton" type="button">Reset Match</button>
          <a id="matchPageButton" href={NOC_FIXTURES[0].route}>Open Match Page</a>
        </div>
        <div class="proposal-grid" id="proposalGrid" aria-label="Agent proposals"></div>
        <ol class="event-log" id="eventLog" aria-label="Agent event log"></ol>
      </article>
    </section>

    <section class="table-grid" aria-label="League table and protocol">
      <article class="standings-panel">
        <div class="panel-head">
          <span>Club Table</span>
          <strong>v0 desk</strong>
        </div>
        <div class="standings-list" id="standingsList"></div>
      </article>

      <article class="protocol-panel">
        <div class="panel-head">
          <span>Protocol</span>
          <strong>agent-readable</strong>
        </div>
        <div class="protocol-grid">
          <div>
            <b>Packet shape</b>
            <code>{NOC_PACKET_SHAPE.schema}</code>
          </div>
          <div>
            <b>Receipt shape</b>
            <code>{NOC_RECEIPT_SHAPE.schema}</code>
          </div>
          <div>
            <b>Storage</b>
            <code>{NOC_STORAGE_KEYS.packet}</code>
          </div>
          <div>
            <b>Discovery</b>
            <code>/agents.json</code>
          </div>
        </div>
      </article>

      <article class="principles-panel">
        <div class="panel-head">
          <span>Constitution</span>
          <strong>why rival</strong>
        </div>
        <ul>
          {NOC_PRINCIPLES.map((principle) => <li>{principle}</li>)}
        </ul>
      </article>
    </section>
  </main>

  <script type="application/json" id="noc-data" set:html={JSON.stringify(clientPayload)} />
  <script>
    const dataNode = document.querySelector('#noc-data');
    const data = JSON.parse(dataNode?.textContent || '{}');
    const clubs = data.clubs || [];
    const fixtures = data.fixtures || [];
    const agents = data.agents || [];
    const agentShiftProtocol = data.agentShiftProtocol || [];
    const agentHandoffs = data.agentHandoffs || [];
    const formations = data.formations || [];
    const policies = data.targetPolicies || [];
    const storageKeys = data.storageKeys || {};
    const state = {
      clubSlug: localStorage.getItem(storageKeys.club) || clubs[0]?.slug || '',
      packetNonce: 0,
      packet: null,
      receipt: null,
      liveState: null,
    };

    const $ = (selector) => document.querySelector(selector);
    const clubButtons = [...document.querySelectorAll('[data-club]')];

    function hashText(text) {
      let hash = 2166136261;
      for (let index = 0; index < text.length; index += 1) {
        hash ^= text.charCodeAt(index);
        hash = Math.imul(hash, 16777619);
      }
      return hash >>> 0;
    }

    function shortHash(value) {
      return hashText(JSON.stringify(value)).toString(36).padStart(7, '0').slice(0, 9);
    }

    function clubBySlug(slug) {
      return clubs.find((club) => club.slug === slug) || clubs[0];
    }

    function fixtureForClub(club) {
      return fixtures.find((fixture) => fixture.home === club.slug || fixture.away === club.slug) || fixtures[0];
    }

    function opponentFor(club, fixture) {
      const opponentSlug = fixture.home === club.slug ? fixture.away : fixture.home;
      return clubBySlug(opponentSlug);
    }

    function selectedClub() {
      return clubBySlug(state.clubSlug);
    }

    function clamp(value, min, max) {
      return Math.max(min, Math.min(max, value));
    }

    function initialLiveState(fixture = fixtureForClub(selectedClub())) {
      const home = clubBySlug(fixture.home);
      const away = clubBySlug(fixture.away);
      return {
        fixtureId: fixture.id,
        turn: 0,
        clock: 0,
        home: { slug: home.slug, score: 0, momentum: 50 },
        away: { slug: away.slug, score: 0, momentum: 50 },
        log: [],
      };
    }

    function liveStateForFixture(fixture) {
      if (!state.liveState || state.liveState.fixtureId !== fixture.id) {
        state.liveState = initialLiveState(fixture);
      }
      return state.liveState;
    }

    function buildAgentShift(liveState) {
      const fixture = fixtures.find((item) => item.id === liveState.fixtureId) || fixtureForClub(selectedClub());
      const protocol = agentShiftProtocol[liveState.turn % agentShiftProtocol.length];
      const home = clubBySlug(fixture.home);
      const away = clubBySlug(fixture.away);
      const packet = state.packet || buildPacket();
      const base = hashText(`${fixture.seed}:${packet.formation}:${protocol.agent}:${liveState.turn}`);
      const actor = base % 2 === 0 ? home : away;
      const target = actor.slug === home.slug ? away : home;
      const delta = base % 5 === 0 ? 2 : base % 3 === 0 ? 1 : 0;
      const minute = Math.min(90, 8 + liveState.turn * 11);
      return {
        minute,
        phase: protocol.phase,
        agent: protocol.agent,
        action: protocol.action,
        artifact: protocol.artifact,
        actor: actor.slug,
        target: target.slug,
        delta,
        note: `${protocol.agent} turns ${protocol.artifact} into ${protocol.scoreboardEffect} for ${actor.code}`,
      };
    }

    function applyAgentShift() {
      const fixture = fixtureForClub(selectedClub());
      const liveState = liveStateForFixture(fixture);
      const shift = buildAgentShift(liveState);
      const side = shift.actor === liveState.home.slug ? liveState.home : liveState.away;
      const other = shift.actor === liveState.home.slug ? liveState.away : liveState.home;
      side.score += shift.delta;
      side.momentum = clamp(side.momentum + 7 + shift.delta * 4, 0, 99);
      other.momentum = clamp(other.momentum - 3, 0, 99);
      liveState.turn += 1;
      liveState.clock = shift.minute;
      liveState.log.unshift(shift);
      state.liveState = liveState;
      localStorage.setItem(storageKeys.liveState, JSON.stringify(liveState));
      localStorage.setItem(storageKeys.dispatch, JSON.stringify(shift));
    }

    function buildPacket() {
      const club = selectedClub();
      const fixture = fixtureForClub(club);
      const base = hashText(`${fixture.seed}:${club.slug}:${state.packetNonce}`);
      const watchlist = club.nounIds.slice(0, 3).map((nounId, index) => ({
        nounId,
        note: `${agentShiftProtocol[index]?.phase || 'scout'} lane watch`,
      }));
      return {
        schema: 'pointcast-nouns-open-circuit-tactics-v2',
        fixtureId: fixture.id,
        club: club.slug,
        operatorAgent: club.operator,
        nounPool: club.nounIds,
        formation: formations[base % formations.length],
        aggression: 42 + (base % 49),
        riskBudget: 35 + ((base >> 4) % 46),
        targetPolicy: policies[(base >> 3) % policies.length],
        agentHandoffs,
        watchlist,
        proofRefs: [
          data.endpoints.spriteManifest,
          data.endpoints.json,
          data.endpoints.incumbent,
          `${data.endpoints.human}/match/${fixture.id}`,
        ],
      };
    }

    function buildReceipt(packet) {
      const club = selectedClub();
      const fixture = fixtureForClub(club);
      const home = clubBySlug(fixture.home);
      const away = clubBySlug(fixture.away);
      const liveState = state.liveState?.fixtureId === fixture.id ? state.liveState : null;
      const timeline = liveState?.log?.length ? [...liveState.log].reverse() : [];
      const fallbackHome = 18 + (hashText(`${fixture.seed}:score:${home.slug}`) % 12);
      const fallbackAway = Math.max(0, fallbackHome - (2 + (hashText(`${fixture.seed}:margin:${away.slug}`) % 9)));
      const homeScore = liveState ? 12 + liveState.home.score : fallbackHome;
      const awayScore = liveState ? 12 + liveState.away.score : fallbackAway;
      const winner = homeScore >= awayScore ? home : away;
      return {
        schema: 'pointcast-nouns-open-circuit-receipt-v2',
        fixtureId: fixture.id,
        seed: fixture.seed,
        winner: winner.slug,
        score: `${homeScore}-${awayScore}`,
        packetHash: shortHash(packet),
        eventHash: shortHash({ fixture, winner: winner.slug, score: `${homeScore}-${awayScore}`, timeline }),
        agentTrail: timeline.map((event) => ({
          minute: event.minute,
          agent: event.agent,
          artifact: event.artifact,
          hash: shortHash(event),
        })),
        timeline,
        agents: agents.map((agent) => agent.slug),
        citation: `${data.endpoints.human}/match/${fixture.id}`,
      };
    }

    function renderFixture() {
      const club = selectedClub();
      const fixture = fixtureForClub(club);
      const home = clubBySlug(fixture.home);
      const away = clubBySlug(fixture.away);
      $('#fixtureTag').textContent = fixture.tag;
      $('#fixtureTitle').textContent = fixture.label;
      $('#fixtureSeed').textContent = `seed: ${fixture.seed}`;
      $('#homeNoun').src = home.image;
      $('#homeCode').textContent = home.code;
      $('#awayNoun').src = away.image;
      $('#awayCode').textContent = away.code;
      $('#deskMatchLink').href = fixture.route;
      $('#matchPageButton').href = fixture.route;
    }

    function renderClub() {
      const club = selectedClub();
      $('#clubName').textContent = club.name;
      $('#clubImage').src = club.image;
      $('#clubDoctrine').textContent = club.doctrine;
      $('#clubOperator').textContent = club.operator;
      $('#clubHome').textContent = club.home;
      $('#clubRecord').textContent = club.record;
      $('#clubHeat').textContent = club.heat;
      $('#nounStrip').innerHTML = club.nounIds.map((id) => `
        <span>
          <img src="/games/nouns-nation-battler/assets/noun-${id}.svg" alt="" loading="lazy" />
          <b>#${String(id).padStart(2, '0')}</b>
        </span>
      `).join('');
      clubButtons.forEach((button) => {
        button.classList.toggle('is-active', button.dataset.club === club.slug);
      });
    }

    function renderTable() {
      const sorted = [...clubs].sort((a, b) => b.heat - a.heat || a.name.localeCompare(b.name));
      $('#standingsList').innerHTML = sorted.map((club, index) => `
        <div class="standing-row" style="--club:${club.color};">
          <b>${index + 1}</b>
          <strong>${club.code}</strong>
          <span>${club.record}</span>
          <span>${club.heat} heat</span>
          <em>${club.operator}</em>
        </div>
      `).join('');
    }

    function renderPacket(packet = state.packet || buildPacket()) {
      state.packet = packet;
      $('#packetPreview').textContent = JSON.stringify(packet, null, 2);
      localStorage.setItem(storageKeys.packet, JSON.stringify(packet));
    }

    function renderReceipt(receipt = state.receipt) {
      if (!receipt) {
        $('#receiptPreview').textContent = JSON.stringify({
          schema: 'pointcast-nouns-open-circuit-receipt-v2',
          status: 'pending',
        }, null, 2);
        return;
      }
      const winner = clubBySlug(receipt.winner);
      $('#receiptPreview').textContent = JSON.stringify(receipt, null, 2);
      $('#receiptStatus').textContent = receipt.packetHash;
      $('#resultBanner').textContent = `${winner.code} win ${receipt.score}`;
      localStorage.setItem(storageKeys.receipt, JSON.stringify(receipt));
    }

    function renderLive() {
      const fixture = fixtureForClub(selectedClub());
      const home = clubBySlug(fixture.home);
      const away = clubBySlug(fixture.away);
      const liveState = liveStateForFixture(fixture);
      $('#liveHomeCode').textContent = home.code;
      $('#liveAwayCode').textContent = away.code;
      $('#liveHomeScore').textContent = liveState.home.score;
      $('#liveAwayScore').textContent = liveState.away.score;
      $('#liveHomeMomentum').textContent = `${liveState.home.momentum} momentum`;
      $('#liveAwayMomentum').textContent = `${liveState.away.momentum} momentum`;
      $('#liveClock').textContent = `${String(liveState.clock).padStart(2, '0')}'`;
      $('#liveStatus').textContent = `shift ${liveState.turn}`;
      const nextProtocol = agentShiftProtocol[liveState.turn % agentShiftProtocol.length];
      $('#proposalGrid').innerHTML = `
        <div>
          <b>${nextProtocol.agent}</b>
          <strong>${nextProtocol.action}</strong>
          <span>${nextProtocol.artifact}</span>
        </div>
        <div>
          <b>${fixture.tempo || 'open tempo'}</b>
          <strong>${home.code} vs ${away.code}</strong>
          <span>${fixture.seed}</span>
        </div>
        <div>
          <b>${selectedClub().operator}</b>
          <strong>${state.packet?.formation || 'packet pending'}</strong>
          <span>${state.packet?.targetPolicy || 'target policy pending'}</span>
        </div>
      `;
      $('#eventLog').innerHTML = liveState.log.length
        ? liveState.log.map((event) => {
            const actor = clubBySlug(event.actor);
            return `<li><b>${event.minute}' ${event.agent}</b><span>${event.note}</span><em>${actor.code} +${event.delta}</em></li>`;
          }).join('')
        : '<li><b>00&#39; DESK</b><span>Agents waiting for first shift.</span><em>ready</em></li>';
      localStorage.setItem(storageKeys.liveState, JSON.stringify(liveState));
    }

    function renderAll() {
      localStorage.setItem(storageKeys.club, state.clubSlug);
      renderFixture();
      renderClub();
      renderTable();
      renderPacket();
      renderReceipt(state.receipt);
      renderLive();
    }

    clubButtons.forEach((button) => {
      button.addEventListener('click', () => {
        state.clubSlug = button.dataset.club;
        state.packetNonce += 1;
        state.receipt = null;
        state.liveState = null;
        $('#receiptStatus').textContent = 'local preview';
        $('#resultBanner').textContent = 'Awaiting receipt.';
        renderAll();
      });
    });

    $('#packetButton').addEventListener('click', () => {
      state.packetNonce += 1;
      const packet = buildPacket();
      $('#packetStatus').textContent = shortHash(packet);
      renderPacket(packet);
      renderLive();
    });

    $('#receiptButton').addEventListener('click', () => {
      const packet = state.packet || buildPacket();
      state.receipt = buildReceipt(packet);
      renderReceipt(state.receipt);
    });

    $('#shiftButton').addEventListener('click', () => {
      applyAgentShift();
      renderLive();
    });

    $('#resetMatchButton').addEventListener('click', () => {
      state.liveState = initialLiveState(fixtureForClub(selectedClub()));
      state.receipt = null;
      localStorage.setItem(storageKeys.liveState, JSON.stringify(state.liveState));
      $('#receiptStatus').textContent = 'local preview';
      $('#resultBanner').textContent = 'Awaiting receipt.';
      renderReceipt(null);
      renderLive();
    });

    try {
      state.packet = JSON.parse(localStorage.getItem(storageKeys.packet) || 'null');
      state.receipt = JSON.parse(localStorage.getItem(storageKeys.receipt) || 'null');
      state.liveState = JSON.parse(localStorage.getItem(storageKeys.liveState) || 'null');
    } catch {
      state.packet = null;
      state.receipt = null;
      state.liveState = null;
    }
    if (state.packet?.schema !== 'pointcast-nouns-open-circuit-tactics-v2') state.packet = null;
    if (state.receipt?.schema !== 'pointcast-nouns-open-circuit-receipt-v2') state.receipt = null;
    if (!state.liveState?.fixtureId) state.liveState = null;

    renderAll();
  </script>
</BlockLayout>

<style>
  .noc {
    display: grid;
    gap: 16px;
    color: #15161a;
  }

  .noc button,
  .noc a {
    font: inherit;
  }

  .kicker,
  .panel-head span,
  .desk__links,
  .fixture-card span,
  .fixture-card p,
  .standing-row,
  .protocol-grid code {
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace);
    letter-spacing: 0;
  }

  .desk {
    min-height: min(560px, calc(100vh - 160px));
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(260px, 0.65fr);
    gap: 18px;
    align-items: stretch;
    padding: 18px;
    border: 3px solid #15161a;
    background:
      linear-gradient(90deg, rgba(24, 95, 165, 0.1), transparent 38%, rgba(47, 143, 95, 0.12)),
      #fff9ea;
    box-shadow: 6px 6px 0 #15161a;
  }

  .desk__lead {
    display: grid;
    align-content: center;
    gap: 14px;
    max-width: 840px;
  }

  .kicker {
    margin: 0;
    color: #6b2139;
    font-size: 0.78rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 9vw, 7.8rem);
    line-height: 0.88;
  }

