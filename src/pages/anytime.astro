---
/**
 * /anytime — George Harrison, "I'd Have You Anytime"
 *
 * All Things Must Pass, side A, track one. 2:57. November 1970.
 * Co-written with Bob Dylan in Woodstock, autumn 1968. The welcome
 * before the album begins — and what an album follows.
 *
 * Track ID: 7c37wgrjBNMnxAvGTXBJTT
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const TRACK_ID = '7c37wgrjBNMnxAvGTXBJTT';
const title = "I'd Have You Anytime — George Harrison";
const description =
  "A PointCast listening room for \"I'd Have You Anytime\" by George Harrison. Side A, track one of All Things Must Pass. 2 minutes 57 seconds of welcome, co-written with Bob Dylan. 1970.";

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicRecording',
  '@id': 'https://pointcast.xyz/anytime',
  name: "I'd Have You Anytime",
  byArtist: { '@type': 'MusicGroup', name: 'George Harrison' },
  inAlbum: { '@type': 'MusicAlbum', name: 'All Things Must Pass' },
  duration: 'PT2M57S',
  datePublished: '1970-11-27',
  description,
};
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="anytime" id="anytime-main">

    <!-- floating dust motes -->
    <div class="anytime__dust" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span>
    </div>

    <div class="anytime__frame">

      <header class="anytime__head">
        <p class="anytime__kicker">ROOM · SPN · GEORGE HARRISON · 1970</p>

        <!-- CSS vinyl record with counter-rotating label -->
        <div class="anytime__vinyl-wrap" aria-hidden="true">
          <div class="anytime__vinyl">
            <div class="anytime__label-ring">
              <span class="anytime__label-text">ALL THINGS<br/>MUST PASS</span>
              <span class="anytime__spindle"></span>
            </div>
          </div>
          <div class="anytime__arm"></div>
        </div>

        <h1 class="anytime__title"><em>I'd Have You Anytime</em></h1>
        <p class="anytime__byline">GEORGE HARRISON — ALL THINGS MUST PASS</p>
        <p class="anytime__dek">
          Side A, track one. The first sound on the record.
          Before the wall of sound, before the flood —
          two minutes fifty-seven seconds of someone opening the door.
        </p>
      </header>

      <section class="anytime__player" aria-label="Listen">
        <iframe
          src={`https://open.spotify.com/embed/track/${TRACK_ID}?utm_source=pointcast`}
          width="100%"
          height="152"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
          title="I'd Have You Anytime — George Harrison"
        />
      </section>

      <section class="anytime__chips" aria-label="Song notes">
        <span class="anytime__chip">CO-WRITTEN WITH BOB DYLAN</span>
        <span class="anytime__chip">WOODSTOCK · AUTUMN 1968</span>
        <span class="anytime__chip">SIDE A · TRACK 1</span>
        <span class="anytime__chip">2 MIN · 57 SEC</span>
        <span class="anytime__chip">PHIL SPECTOR · PROD.</span>
        <span class="anytime__chip">APPLE RECORDS · NOV 1970</span>
      </section>

      <section class="anytime__texture">
        <p>
          Dylan and Harrison wrote it together in Woodstock in the autumn of 1968 —
          Dylan teaching Harrison a gentler way in. Harrison placed it first
          because it lands like a hand on a shoulder before three hours of
          everything else that follows on the album.
        </p>
        <p>
          <em>Let me roll it to you.</em> That's the second verse. Spector's
          production is almost restrained here — close guitar, close voice, a
          prologue that already knows the weight of what comes next. All Things
          Must Pass earned its long shadow. This earned the quiet before it.
        </p>
      </section>

      <nav class="anytime__links" aria-label="Other rooms">
        <a class="anytime__link" href="/room">
          <span class="anytime__link-label">/ROOM</span>
          <span class="anytime__link-desc">the mix room · 10 tracks · 1h 11m</span>
        </a>
        <a class="anytime__link" href="/meditate">
          <span class="anytime__link-label">/MEDITATE</span>
          <span class="anytime__link-desc">the ocean room · timed breathing</span>
        </a>
        <a class="anytime__link" href="/gandalf">
          <span class="anytime__link-label">/GANDALF</span>
          <span class="anytime__link-desc">the hearth room · companion</span>
        </a>
        <a class="anytime__link" href="/">
          <span class="anytime__link-label">/</span>
          <span class="anytime__link-desc">back to the broadcast</span>
        </a>
      </nav>

      <footer class="anytime__foot">
        <span>on air · el segundo · fm 96.1 · cc0</span>
        <span id="anytime-clock">—</span>
      </footer>

    </div>
  </main>
</BlockLayout>

<script is:inline>
  (function () {
    'use strict';
    // Clock-tinted background: Harrison palette.
    // Dawn gold → midday garden → amber afternoon → copper dusk → indigo night.
    function paint() {
      var now = new Date();
      var h = now.getHours() + now.getMinutes() / 60;
      var root = document.getElementById('anytime-main');
      if (!root) return;
      var hue, sat, light;
      if      (h < 5)  { hue = 238; sat = 30; light = 10; }   // pre-dawn: deep indigo
      else if (h < 8)  { hue = 38;  sat = 62; light = 74; }   // dawn: golden morning
      else if (h < 12) { hue = 44;  sat = 48; light = 80; }   // morning: garden green-gold
      else if (h < 15) { hue = 36;  sat = 58; light = 72; }   // afternoon: warm amber
      else if (h < 18) { hue = 28;  sat = 64; light = 60; }   // golden hour
      else if (h < 20) { hue = 18;  sat = 54; light = 42; }   // copper dusk
      else if (h < 22) { hue = 270; sat = 38; light = 24; }   // twilight: lavender-purple
      else             { hue = 238; sat = 30; light = 12; }   // night: indigo
      var bg1 = 'hsl(' + hue + ',' + sat + '%,' + light + '%)';
      var bg2 = 'hsl(' + (hue + 20) + ',' + (sat - 8) + '%,' + Math.max(5, light - 16) + '%)';
      root.style.background = 'linear-gradient(160deg,' + bg1 + ' 0%,' + bg2 + ' 100%)';
      root.classList.toggle('anytime--dark', light < 55);
      var clock = document.getElementById('anytime-clock');
      if (clock) {
        var hh = String(now.getHours()).padStart(2, '0');
        var mm = String(now.getMinutes()).padStart(2, '0');
        clock.textContent = hh + ':' + mm + ' PT';
      }
    }
    paint();
    setInterval(paint, 60 * 1000);
  })();
</script>

<style>
  /* ── base room ── */
  .anytime {
    min-height: calc(100vh - 60px);
    padding: 48px 20px 60px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    background: linear-gradient(160deg, #f0dda0 0%, #b86c18 100%);
    color: #1a1208;
    transition: background 2.5s ease, color 1s ease;
    position: relative;
    overflow: hidden;
    font-family: 'JetBrains Mono Variable', 'Courier New', monospace;
  }
  .anytime--dark { color: #f5e8c2; }

  /* ── dust motes ── */
  .anytime__dust {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .anytime__dust span {
    position: absolute;
    width: 3px;
    height: 3px;
    background: rgba(255, 210, 100, 0.75);
    border-radius: 50%;
    animation: mote linear infinite;
  }
  .anytime__dust span:nth-child(1)  { left:  9%; top: 22%; animation-duration: 9.2s;  animation-delay: 0s;   }
  .anytime__dust span:nth-child(2)  { left: 32%; top: 58%; animation-duration: 11.4s; animation-delay: 1.6s; }
  .anytime__dust span:nth-child(3)  { left: 61%; top: 14%; animation-duration: 8.6s;  animation-delay: 3.1s; }
  .anytime__dust span:nth-child(4)  { left: 77%; top: 42%; animation-duration: 12.8s; animation-delay: 0.9s; }
  .anytime__dust span:nth-child(5)  { left: 21%; top: 74%; animation-duration: 10.3s; animation-delay: 2.4s; }
  .anytime__dust span:nth-child(6)  { left: 89%; top: 64%; animation-duration: 9.7s;  animation-delay: 4.2s; }
  .anytime__dust span:nth-child(7)  { left: 47%; top: 86%; animation-duration: 13.1s; animation-delay: 1.1s; }
  .anytime__dust span:nth-child(8)  { left:  6%; top: 50%; animation-duration: 11.8s; animation-delay: 3.6s; }
  .anytime__dust span:nth-child(9)  { left: 55%; top: 36%; animation-duration: 8.2s;  animation-delay: 2.8s; }
  .anytime__dust span:nth-child(10) { left: 72%; top: 78%; animation-duration: 14.5s; animation-delay: 0.4s; }

  @keyframes mote {
    0%   { transform: translate(0, 0) scale(1);   opacity: 0;   }
    15%  {                                         opacity: 0.85;}
    55%  { transform: translate(14px, -28px) scale(1.5); opacity: 0.55; }
    85%  {                                         opacity: 0.25;}
    100% { transform: translate(-10px, -52px) scale(0.5); opacity: 0; }
  }

  /* ── frame ── */
  .anytime__frame {
    position: relative;
    z-index: 1;
    max-width: 640px;
    width: 100%;
    padding: 36px 32px 32px;
    background: rgba(255, 248, 228, 0.11);
    border: 1px solid rgba(18, 10, 2, 0.14);
    border-radius: 2px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .anytime--dark .anytime__frame {
    background: rgba(10, 6, 2, 0.34);
    border-color: rgba(245, 215, 140, 0.18);
  }

  /* ── header ── */
  .anytime__head {
    text-align: center;
    margin-bottom: 22px;
  }

  .anytime__kicker {
    font-size: 10px;
    letter-spacing: 0.28em;
    font-weight: 700;
    margin: 0 0 22px;
    opacity: 0.68;
  }

  /* ── vinyl record ── */
  .anytime__vinyl-wrap {
    position: relative;
    width: 168px;
    height: 168px;
    margin: 0 auto 22px;
  }

  .anytime__vinyl {
    width: 168px;
    height: 168px;
    border-radius: 50%;
    background:
      radial-gradient(circle, transparent 28.5%, rgba(80,60,40,.35) 29%, transparent 29.5%),
      radial-gradient(circle, transparent 33%,   rgba(80,60,40,.30) 33.5%, transparent 34%),
      radial-gradient(circle, transparent 37.5%, rgba(80,60,40,.28) 38%, transparent 38.5%),
      radial-gradient(circle, transparent 42%,   rgba(80,60,40,.25) 42.5%, transparent 43%),
      radial-gradient(circle, transparent 46.5%, rgba(80,60,40,.22) 47%, transparent 47.5%),
      radial-gradient(circle, transparent 51%,   rgba(80,60,40,.20) 51.5%, transparent 52%),
      radial-gradient(circle, transparent 55.5%, rgba(80,60,40,.18) 56%, transparent 56.5%),
      radial-gradient(circle, transparent 60%,   rgba(80,60,40,.16) 60.5%, transparent 61%),
      radial-gradient(circle, transparent 64.5%, rgba(80,60,40,.14) 65%, transparent 65.5%),
      #16110c;
    animation: spin-vinyl 3.4s linear infinite;
    position: relative;
    box-shadow:
      0 0 0 1px rgba(255,200,80,0.12),
      0 8px 32px rgba(0,0,0,0.55);
  }

  /* Counter-rotating center label — stays stationary in global frame */
  .anytime__label-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    margin: -34px 0 0 -34px;
    width: 68px;
    height: 68px;
    border-radius: 50%;
    background: radial-gradient(circle at 42% 36%,
      #F0A030 0%, #C86020 50%, #8C3C12 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    animation: spin-vinyl 3.4s linear infinite reverse;
    box-shadow: inset 0 1px 4px rgba(0,0,0,0.4);
  }

  .anytime__label-text {
    font-size: 5.5px;
    letter-spacing: 0.08em;
    line-height: 1.5;
    text-align: center;
    color: rgba(255, 238, 190, 0.92);
    font-weight: 800;
    font-family: 'JetBrains Mono Variable', monospace;
  }

  .anytime__spindle {
    display: block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255, 230, 160, 0.5);
    box-shadow: 0 0 3px rgba(0,0,0,0.5);
    margin-top: 2px;
  }

  @keyframes spin-vinyl {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Tonearm — static, hovering at track one */
  .anytime__arm {
    position: absolute;
    top: -4px;
    right: -6px;
    width: 7px;
    height: 80px;
    background: linear-gradient(180deg,
      rgba(210,188,140,0.92) 0%,
      rgba(165,142,96,0.78) 100%);
    border-radius: 4px;
    transform-origin: top center;
    transform: rotate(-30deg);
    box-shadow: 0 2px 6px rgba(0,0,0,0.45);
  }
  .anytime__arm::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 50%;
    transform: translateX(-50%);
    width: 11px;
    height: 11px;
    background: rgba(210,188,140,0.9);
    border-radius: 50%;
    box-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }

  /* ── title block ── */
  .anytime__title {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: clamp(28px, 4.5vw, 42px);
    font-weight: 400;
    line-height: 1.08;
    margin: 0 0 7px;
    letter-spacing: -0.01em;
  }
  .anytime__title em { font-style: italic; }

  .anytime__byline {
    font-size: 9.5px;
    letter-spacing: 0.24em;
    font-weight: 700;
    margin: 0 0 12px;
    opacity: 0.64;
  }

  .anytime__dek {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 15.5px;
    line-height: 1.56;
    margin: 0 auto;
    max-width: 440px;
    opacity: 0.9;
  }

  /* ── player ── */
  .anytime__player {
    margin: 24px 0 18px;
  }
  .anytime__player iframe {
    display: block;
    border-radius: 10px;
    box-shadow: 0 4px 28px rgba(0,0,0,0.32);
    width: 100%;
  }

  /* ── annotation chips ── */
  .anytime__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin: 0 0 24px;
    justify-content: center;
  }
  .anytime__chip {
    font-size: 8.5px;
    letter-spacing: 0.20em;
    font-weight: 700;
    padding: 4px 10px;
    border: 1px solid currentColor;
    border-radius: 1px;
    opacity: 0.6;
    cursor: default;
    transition: opacity 0.15s ease, transform 0.15s ease;
    user-select: none;
  }
  .anytime__chip:hover {
    opacity: 1;
    transform: translateY(-1px);
  }

  /* ── prose texture ── */
  .anytime__texture {
    margin: 0 0 26px;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 15.5px;
    line-height: 1.64;
  }
  .anytime__texture p {
    margin: 0 0 13px;
    opacity: 0.9;
  }
  .anytime__texture p:last-child { margin-bottom: 0; }
  .anytime__texture em { font-style: italic; }

  /* ── room links nav ── */
  .anytime__links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(185px, 1fr));
    gap: 8px;
    margin: 0 0 24px;
  }
  .anytime__link {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 9px 12px;
    background: rgba(255, 248, 218, 0.42);
    border: 1px solid rgba(18, 10, 2, 0.15);
    border-radius: 2px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }
  .anytime--dark .anytime__link {
    background: rgba(10, 6, 2, 0.4);
    border-color: rgba(245, 215, 140, 0.15);
  }
  .anytime__link:hover {
    transform: translateY(-1px);
    background: rgba(255, 210, 100, 0.32);
    border-color: rgba(200, 140, 20, 0.6);
  }
  .anytime__link-label {
    font-size: 10px;
    letter-spacing: 0.16em;
    font-weight: 700;
  }
  .anytime__link-desc {
    font-size: 11.5px;
    font-family: Georgia, serif;
    opacity: 0.80;
    line-height: 1.4;
  }

  /* ── footer ── */
  .anytime__foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 10px;
    letter-spacing: 0.18em;
    padding-top: 14px;
    border-top: 1px dashed rgba(18, 10, 2, 0.18);
    opacity: 0.70;
  }
  .anytime--dark .anytime__foot {
    border-top-color: rgba(245, 215, 140, 0.18);
  }

  /* ── responsive ── */
  @media (max-width: 520px) {
    .anytime { padding: 28px 12px 48px; }
    .anytime__frame { padding: 24px 16px 22px; }
    .anytime__title { font-size: 26px; }
    .anytime__vinyl-wrap,
    .anytime__vinyl { width: 128px; height: 128px; }
    .anytime__label-ring {
      width: 52px;
      height: 52px;
      margin: -26px 0 0 -26px;
    }
  }
</style>
