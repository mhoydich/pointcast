---
/**
 * /magpie/changelog — sprint-by-sprint shipping history.
 *
 * All 70 ships organized by sprint (v0.6 → v0.10 → v1.0 → GTM).
 * The dry facts. Meant as a searchable reference for "when did X land?"
 */

import BlockLayout from '../../layouts/BlockLayout.astro';

interface ShipEntry {
  num: number;
  title: string;
  summary: string;
  files?: string[];
}

interface Sprint {
  id: string;
  version: string;
  label: string;
  date: string;
  summary: string;
  ships: ShipEntry[];
}

const sprints: Sprint[] = [
  {
    id: 's1', version: 'v0.6', label: 'Sprint #1 — core broadcast', date: '2026-04',
    summary: 'Publisher protocol + PointCast/Mastodon/Farcaster adapters. ComposerSheet. Keychain auth.',
    ships: [
      { num: 1, title: 'Publisher protocol + core types', summary: 'PublishDraft, PublishPreview, PublishOutcome, PublishError, PublisherCapabilities, PublisherID enum.' },
      { num: 2, title: 'PublisherAuthStore', summary: 'Keychain-scoped credential storage per publisher.' },
      { num: 3, title: 'PublisherRegistry', summary: 'Fan-out coordinator with concurrent publish via TaskGroup.' },
      { num: 4, title: 'PointCastPublisher', summary: 'Reference implementation of the Publisher protocol.' },
      { num: 5, title: 'MastodonPublisher', summary: 'REST /api/v1/statuses + threading + visibility.' },
      { num: 6, title: 'FarcasterPublisher', summary: 'Neynar managed signer + embeds + channels.' },
      { num: 7, title: 'ComposerSheet', summary: 'Multi-destination composer with per-destination previews.' },
      { num: 8, title: 'AppState + ClipItemRow integration', summary: 'Wires registry into SwiftUI row + composer open path.' },
      { num: 9, title: 'Mastodon + Farcaster settings views', summary: 'Paste-token flows in Preferences.' },
      { num: 10, title: 'Build + verify', summary: 'First end-to-end parse-check.' },
    ],
  },
  {
    id: 's2', version: 'v0.7–v0.8', label: 'Sprint #2 — OAuth, images, scheduling', date: '2026-04',
    summary: 'Twitter + LinkedIn via OAuth PKCE, Bluesky AT Proto, image attachments, local scheduling, activity log.',
    ships: [
      { num: 11, title: 'Twitter OAuth skeleton', summary: 'v2 /2/tweets + paste-token fallback.' },
      { num: 12, title: 'LinkedIn OAuth skeleton', summary: 'UGC Posts API + author URN resolution.' },
      { num: 13, title: 'MediaAttachment infrastructure', summary: 'Shared type for images across all publishers.' },
      { num: 14, title: 'Mastodon image upload', summary: 'multipart/form-data → /api/v2/media.' },
      { num: 15, title: 'Bluesky blob upload', summary: 'com.atproto.repo.uploadBlob + embed.images.' },
      { num: 16, title: 'Farcaster image embeds', summary: 'URL-based via hostedURL field.' },
      { num: 17, title: 'Image picker in ComposerSheet', summary: 'NSOpenPanel + chip thumbnails.' },
      { num: 18, title: 'Scheduled broadcasts (local)', summary: 'BroadcastScheduler with 15s ticker.' },
      { num: 19, title: 'Activity log view', summary: 'Per-publisher success-rate bars + chronological feed.' },
      { num: 20, title: 'Regression guards (24)', summary: 'BlockTypeDetector + capabilities + categorize.' },
    ],
  },
  {
    id: 's3', version: 'v0.9', label: 'Sprint #3 — bitchat, wallets, mints, cloud', date: '2026-04',
    summary: 'BitchatPublisher via Nostr, native Tezos signer, EVM skeleton, Zora + Objkt mint shapes, Cloudflare scheduler, Pinata.',
    ships: [
      { num: 21, title: 'BitchatPublisher + settings', summary: 'Nostr transport — NIP-01 kind-1 notes, relay fan-out.' },
      { num: 22, title: 'WalletSigner protocol + registry', summary: 'EVM / Tezos / Nostr chain abstraction.' },
      { num: 23, title: 'TezosSigner (native ed25519)', summary: 'CryptoKit Curve25519 + inline Blake2b + Base58check.' },
      { num: 24, title: 'EVMSigner skeleton', summary: 'Deferred until secp256k1 dep.' },
      { num: 25, title: 'Wallet settings tab', summary: 'Generate/import for both chains.' },
      { num: 26, title: 'ZoraPublisher skeleton', summary: 'Coin metadata shape + wallet gate.' },
      { num: 27, title: 'ObjktPublisher skeleton', summary: 'Teia FA2 metadata shape.' },
      { num: 28, title: 'Cloudflare /api/schedule', summary: 'POST + KV storage + validation.' },
      { num: 29, title: 'CLI schedule subcommand', summary: 'magpie schedule <id> --at <iso>.' },
      { num: 30, title: 'Farcaster IPFS staging via Pinata', summary: 'Auto-upload local images before cast.' },
    ],
  },
  {
    id: 's4', version: 'v0.10', label: 'Sprint #4 — cloud, visibility, polish', date: '2026-04',
    summary: 'Cron dispatcher, peer-node read routes, composer clip context, activity drill-down, Instagram + OpenSea skeletons.',
    ships: [
      { num: 31, title: 'Cloudflare cron dispatcher', summary: '*/5 * * * * fires due /api/schedule entries (pointcast only).' },
      { num: 32, title: 'Peer-node read routes', summary: 'GET /activity, /scheduled, /drafts. POST /retry.' },
      { num: 33, title: 'CLI activity subcommand', summary: 'magpie activity [-n N].' },
      { num: 34, title: 'CLI scheduled/drafts/retry', summary: 'Prefix-match retry by first 8 chars.' },
      { num: 35, title: 'Composer clip context card', summary: 'Shows source clip at top of composer.' },
      { num: 36, title: 'Activity entry drill-down', summary: 'Sheet with permalink + error details.' },
      { num: 37, title: 'InstagramPublisher skeleton', summary: 'Graph API capability shape.' },
      { num: 38, title: 'OpenSeaPublisher skeleton', summary: 'Seaport listing shape.' },
      { num: 39, title: 'Sprint #3 regression guards (28)', summary: 'PublisherID + capabilities + overrides.' },
      { num: 40, title: 'Manifest v0.10', summary: '/magpie.json bumped with 11 publishers.' },
    ],
  },
  {
    id: 's5', version: 'v0.10', label: 'Sprint #5 — runway to v1.0', date: '2026-04',
    summary: 'Reach dashboard, notifications, presets, keyboard shortcuts, retry-all, retention, hosted activity page.',
    ships: [
      { num: 41, title: 'Reach dashboard', summary: 'Totals, daily histogram, per-publisher lanes, block-type split.' },
      { num: 42, title: 'macOS publish notifications', summary: 'UNUserNotificationCenter + click-through routing.' },
      { num: 43, title: 'Destination presets', summary: 'All / Social / Web3 / Long-form / Mesh / Visual chips.' },
      { num: 44, title: 'Composer keyboard shortcuts', summary: '⌘1–6 presets, ⌘K scheduler, ⌘⇧A attach.' },
      { num: 45, title: 'Peer-node /summary + CLI summary', summary: 'One-glance 30-day recap.' },
      { num: 46, title: 'Retry-all in draft queue', summary: 'Bulk retry with sequential execution.' },
      { num: 47, title: 'ActivityLog age-based retention', summary: '7d / 30d / 90d / 1y / unlimited.' },
      { num: 48, title: 'Hosted /magpie/activity page', summary: 'Remote-read dashboard with 30s auto-refresh.' },
      { num: 49, title: 'Sprint #4 regression guards (21)', summary: 'Retention, presets, IG/OS skeletons.' },
      { num: 50, title: 'Manifest + closing docs', summary: 'destination_presets + hosted_activity_page sections.' },
    ],
  },
  {
    id: 's6', version: 'v1.0', label: 'Sprint #6 — tutorial + v1.0 close', date: '2026-04-21',
    summary: 'Interactive tour + long-form guide + in-app onboarding, real EVM + Nostr signers, Twitter media, encrypted credential forwarding.',
    ships: [
      { num: 51, title: '/magpie/guide (long-form)', summary: '10-section scrollable walkthrough.' },
      { num: 52, title: '/magpie/tour (interactive)', summary: '12-slide keyboard-driven deck.' },
      { num: 53, title: 'MagpieTourSheet (in-app)', summary: 'First-launch onboarding + About-tab launcher.' },
      { num: 54, title: 'secp256k1.swift SPM dep', summary: 'Scaffolded — Xcode adds the final product name.' },
      { num: 55, title: 'Real EVMSigner', summary: 'ECDSA + Keccak256 + EIP-55 + EIP-191.' },
      { num: 56, title: 'Real Nostr BIP-340 signer', summary: 'Schnorr via secp256k1.Schnorr.PrivateKey.' },
      { num: 57, title: 'Twitter media upload', summary: 'v1.1 INIT/APPEND/FINALIZE.' },
      { num: 58, title: 'Encrypted credential forwarding', summary: 'AES-GCM-256 envelope for cloud scheduling.' },
      { num: 59, title: 'Sprint #5+6 regression guards (23)', summary: 'Keccak256 vectors + EIP-55 + AES roundtrip.' },
      { num: 60, title: 'Manifest v1.0', summary: 'Onboarding + credential-forwarding + wallets sections.' },
    ],
  },
  {
    id: 's7', version: 'v1.0 GTM', label: 'Sprint #7 — v1 launch kit', date: '2026-04-21',
    summary: 'Launch landing, 90-second pitch, FAQ, press kit, changelog, launch thread copy, dogfood plan.',
    ships: [
      { num: 61, title: '/magpie/launch landing', summary: 'Hero + eleven destinations + three ideas.' },
      { num: 62, title: '/magpie/pitch', summary: '90-second overview — the shortest read.' },
      { num: 63, title: '/magpie/faq', summary: 'Privacy, pricing, setup, agents, roadmap.' },
      { num: 64, title: '/magpie/press', summary: 'One-liners, boilerplate, palette, logos.' },
      { num: 65, title: '/magpie/changelog', summary: 'This page.' },
      { num: 66, title: 'Twitter/X launch thread', summary: 'docs/launch/twitter-thread.md.' },
      { num: 67, title: 'Farcaster launch cast', summary: 'docs/launch/farcaster-cast.md.' },
      { num: 68, title: 'Show HN post', summary: 'docs/launch/show-hn.md.' },
      { num: 69, title: 'PointCast dogfood block', summary: 'docs/launch/pointcast-block.md.' },
      { num: 70, title: 'Internal launch checklist', summary: 'docs/launch/README.md — day-of playbook.' },
    ],
  },
];

const totalShips = sprints.reduce((acc, s) => acc + s.ships.length, 0);
---

<BlockLayout
  channelCode="FD"
  blockType="READ"
  title="Magpie · Changelog"
  description="Every ship across every sprint. v0.6 → v1.0 in 70 increments."
  pageTitle="Magpie Changelog"
>
  <article class="mgc-root">
    <header class="mgc-head">
      <p class="mgc-kicker">v0.6 → v1.0 · {totalShips} ships</p>
      <h1 class="mgc-title">Every increment, indexed.</h1>
      <p class="mgc-dek">
        Seven sprints. {sprints.length} versions. Each ship is a
        self-contained deliverable — parse-checked + documented the
        same day.
      </p>
    </header>

    <nav class="mgc-toc" aria-label="Sprint index">
      {sprints.map((s) => (
        <a href={`#${s.id}`}>
          <span class="mgc-toc-ver">{s.version}</span>
          <span class="mgc-toc-label">{s.label}</span>
          <span class="mgc-toc-count">{s.ships.length} ships</span>
        </a>
      ))}
    </nav>

    {sprints.map((sprint) => (
      <section class="mgc-sprint" id={sprint.id}>
        <header class="mgc-sprint-head">
          <p class="mgc-sprint-ver">{sprint.version} · {sprint.date}</p>
          <h2>{sprint.label}</h2>
          <p class="mgc-sprint-summary">{sprint.summary}</p>
        </header>
        <ol class="mgc-ships">
          {sprint.ships.map((ship) => (
            <li>
              <span class="mgc-ship-num">#{ship.num}</span>
              <div>
                <strong>{ship.title}</strong>
                <p>{ship.summary}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>
    ))}

    <footer class="mgc-foot">
      <p>
        <strong>{totalShips} ships across {sprints.length} sprints</strong>, each
        parse-checked at ship time.
      </p>
      <nav>
        <a href="/magpie/launch">launch</a>
        <a href="/magpie/guide">guide</a>
        <a href="/magpie/faq">faq</a>
        <a href="/magpie">app</a>
      </nav>
    </footer>
  </article>
</BlockLayout>

<style>
  :root {
    --mg-paper: #EFE8D2;
    --mg-paper-tint: #E7DFC4;
    --mg-card: #FAF5E0;
    --mg-rule: #C8B98E;
    --mg-rule-soft: #E0D6B6;
    --mg-ink: #1E1C14;
    --mg-ink-soft: #5A544A;
    --mg-ink-mute: #8A8273;
    --mg-moss: #3E5940;
    --mg-clay: #AE6A38;
    --mg-bronze: #7E5A2A;
    --mg-display: Georgia, 'Iowan Old Style', serif;
    --mg-mono: ui-monospace, 'IBM Plex Mono', 'SF Mono', Menlo, monospace;
  }

  .mgc-root {
    max-width: 820px;
    margin: 0 auto;
    padding: 40px 24px 60px;
    background: var(--mg-paper);
    color: var(--mg-ink);
    font-family: -apple-system, system-ui, sans-serif;
    line-height: 1.55;
    scroll-behavior: smooth;
  }

  .mgc-head { margin-bottom: 32px; }
  .mgc-kicker {
    font-family: var(--mg-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mg-clay);
    margin: 0 0 8px;
  }
  .mgc-title {
    font-family: var(--mg-display);
    font-style: italic;
    font-weight: 500;
    font-size: 36px;
    margin: 0 0 12px;
    color: var(--mg-ink);
  }
  .mgc-dek { font-size: 15px; color: var(--mg-ink-soft); margin: 0; }

  /* TOC */
  .mgc-toc {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 6px;
    margin-bottom: 40px;
    padding: 14px;
    background: var(--mg-card);
    border: 1px solid var(--mg-rule);
    border-radius: 3px;
  }
  .mgc-toc a {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 8px 10px;
    text-decoration: none;
    border-radius: 2px;
    transition: background 120ms;
  }
  .mgc-toc a:hover { background: var(--mg-paper-tint); }
  .mgc-toc-ver {
    font-family: var(--mg-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--mg-clay);
  }
  .mgc-toc-label {
    font-size: 13px;
    color: var(--mg-ink);
  }
  .mgc-toc-count {
    font-family: var(--mg-mono);
    font-size: 10px;
    color: var(--mg-ink-mute);
  }

  /* SPRINT */
  .mgc-sprint {
    margin-bottom: 40px;
    scroll-margin-top: 16px;
  }
  .mgc-sprint-head { margin-bottom: 14px; }
  .mgc-sprint-ver {
    font-family: var(--mg-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--mg-moss);
    margin: 0 0 4px;
  }
  .mgc-sprint h2 {
    font-family: var(--mg-display);
    font-style: italic;
    font-weight: 500;
    font-size: 26px;
    margin: 0 0 6px;
    color: var(--mg-ink);
  }
  .mgc-sprint-summary {
    font-size: 14px;
    color: var(--mg-ink-soft);
    margin: 0;
    font-style: italic;
  }

  /* SHIPS */
  .mgc-ships {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .mgc-ships li {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 10px;
    padding: 8px 12px;
    background: var(--mg-card);
    border: 1px solid var(--mg-rule-soft);
    border-radius: 2px;
  }
  .mgc-ship-num {
    font-family: var(--mg-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--mg-clay);
    padding-top: 2px;
  }
  .mgc-ships strong {
    font-size: 14px;
    color: var(--mg-ink);
    display: block;
    margin-bottom: 2px;
  }
  .mgc-ships p {
    font-size: 13px;
    color: var(--mg-ink-soft);
    margin: 0;
    line-height: 1.5;
  }

  /* FOOT */
  .mgc-foot {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px dotted var(--mg-rule);
    text-align: center;
  }
  .mgc-foot p {
    font-size: 14px;
    color: var(--mg-ink-soft);
    margin: 0 0 12px;
  }
  .mgc-foot nav {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .mgc-foot a {
    font-family: var(--mg-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--mg-bronze);
    text-decoration: none;
  }
  .mgc-foot a:hover { color: var(--mg-clay); }

  @media (max-width: 640px) {
    .mgc-title { font-size: 28px; }
    .mgc-ships li { grid-template-columns: 40px 1fr; }
  }
</style>
