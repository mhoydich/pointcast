---
/**
 * /magpie/press — press kit.
 *
 * One-liners + boilerplate + asset download links. Designed for
 * writers / podcasters / aggregators who want to cover the launch
 * without playing telephone with the copy. Everything on this page
 * is licensed for editorial reuse.
 */

import BlockLayout from '../../layouts/BlockLayout.astro';
---

<BlockLayout
  channelCode="FD"
  blockType="READ"
  title="Magpie · Press Kit"
  description="Boilerplate, one-liners, screenshots, and brand for Magpie v1.0."
  pageTitle="Magpie Press Kit"
>
  <article class="mgk-root">
    <header class="mgk-head">
      <p class="mgk-kicker">press kit · v1.0 · 2026-04-21</p>
      <h1 class="mgk-title">Magpie press kit.</h1>
      <p class="mgk-dek">
        Everything a writer or podcaster needs to cover Magpie without
        playing telephone with the copy. Reuse freely — everything on
        this page is editorial-licensed.
      </p>
    </header>

    <section class="mgk-section">
      <h2>One-liner</h2>
      <div class="mgk-copy">
        A macOS clipboard that broadcasts to eleven destinations —
        PointCast, Mastodon, Farcaster, bitchat, Bluesky, Twitter/X,
        LinkedIn, Instagram, Zora, Objkt, OpenSea — with per-platform
        previews, IPFS image staging, and a scriptable local HTTP
        peer-node.
      </div>
    </section>

    <section class="mgk-section">
      <h2>Shorter one-liners</h2>
      <ul class="mgk-short">
        <li>A clipboard that broadcasts.</li>
        <li>Capture once, broadcast everywhere.</li>
        <li>The Hootsuite for the agentic web.</li>
        <li>Eleven destinations. One compose.</li>
        <li>A local-first menu-bar app for cross-platform publishers.</li>
      </ul>
    </section>

    <section class="mgk-section">
      <h2>Boilerplate (100 words)</h2>
      <div class="mgk-copy">
        <p>
          Magpie is an open-source macOS menu-bar app that turns your
          clipboard into a universal publisher for the agentic web.
          Copy anything — a link, a paragraph, an image — and Magpie
          holds it locally. Right-click any clipping to broadcast it
          to eleven destinations at once: PointCast (canonical home),
          Mastodon, Farcaster, bitchat (Nostr + BLE mesh), Bluesky,
          Twitter/X, LinkedIn, Instagram, Zora (mint on Base), Objkt
          (mint on Tezos), and OpenSea. Each destination speaks its
          native shape — char limits, threading, embeds, mints — and
          Magpie translates. Local-first, MIT-licensed, free.
        </p>
      </div>
    </section>

    <section class="mgk-section">
      <h2>Boilerplate (280 chars — X/Twitter)</h2>
      <div class="mgk-copy">
        Magpie is a macOS clipboard that broadcasts to 11 destinations
        — PointCast, Mastodon, Farcaster, bitchat, Bluesky, Twitter,
        LinkedIn, Instagram, Zora, Objkt, OpenSea — with per-platform
        previews, IPFS image staging, scheduling, and a scriptable
        peer-node API. Local-first. Free.
      </div>
      <p class="mgk-meta">280 chars exact.</p>
    </section>

    <section class="mgk-section">
      <h2>Key facts</h2>
      <dl class="mgk-facts">
        <dt>Version</dt><dd>1.0 (shipped 2026-04-21)</dd>
        <dt>Platform</dt><dd>macOS 13+ (Apple Silicon + Intel)</dd>
        <dt>License</dt><dd>MIT</dd>
        <dt>Source</dt><dd><a href="https://github.com/Good-Feels/magpie">github.com/Good-Feels/magpie</a></dd>
        <dt>Download</dt><dd><a href="https://github.com/Good-Feels/magpie/releases/latest">Latest release</a></dd>
        <dt>Manifest</dt><dd><a href="/magpie.json">/magpie.json</a> (agent-readable)</dd>
        <dt>Destinations</dt><dd>11 (7 live-text, 1 live-mesh, 3 mint-scaffolded)</dd>
        <dt>Wallet signers</dt><dd>Tezos ed25519 (native), EVM secp256k1, Nostr BIP-340 Schnorr</dd>
        <dt>Cloud dependencies</dt><dd>Optional. Cloudflare Pages + KV for scheduling; Pinata for IPFS.</dd>
        <dt>Data residency</dt><dd>Your Mac. Keychain. No backend required.</dd>
        <dt>Maker</dt><dd>Mike Hoydich / Good Feels · based in El Segundo, CA</dd>
      </dl>
    </section>

    <section class="mgk-section">
      <h2>The three things to mention</h2>
      <ol class="mgk-takeaways">
        <li>
          <strong>Capture inverts the publish workflow.</strong> You
          don't switch to a composer to write — you copy where you
          already are.
        </li>
        <li>
          <strong>One compose, eleven homes.</strong> Social +
          mesh + on-chain, with per-destination previews and overrides.
        </li>
        <li>
          <strong>Local-first + writeable by agents.</strong> Runs
          entirely on your Mac; exposes an HTTP peer-node API so any
          script or model can publish through it.
        </li>
      </ol>
    </section>

    <section class="mgk-section">
      <h2>Product screenshots</h2>
      <p class="mgk-note">
        Coming after Mike assembles v1.0 Xcode build. Ping
        <a href="https://github.com/Good-Feels/magpie/issues/new">GitHub</a>
        for sooner.
      </p>
      <ul class="mgk-shots">
        <li>Menu-bar popover with clipboard history</li>
        <li>Composer with destination stack + per-destination previews</li>
        <li>Reach dashboard with per-publisher success-rate lanes</li>
        <li>Activity feed with drill-down</li>
        <li>Interactive tour — slide 6 (composer)</li>
      </ul>
    </section>

    <section class="mgk-section">
      <h2>Logo + wordmark</h2>
      <div class="mgk-logos">
        <div class="mgk-logo">
          <div class="mgk-logo-visual"><span>🐦‍⬛</span></div>
          <p><strong>Emoji glyph</strong></p>
          <p class="mgk-meta">U+1F426 U+200D U+2B1B (bird + ZWJ + black square)</p>
        </div>
        <div class="mgk-logo mgk-logo-wordmark">
          <div class="mgk-logo-visual mgk-logo-word">
            <span class="mgk-wordmark">Magpie</span>
          </div>
          <p><strong>Wordmark</strong></p>
          <p class="mgk-meta">Georgia italic · 40px · ink color #1E1C14</p>
        </div>
      </div>
    </section>

    <section class="mgk-section">
      <h2>Palette</h2>
      <div class="mgk-palette">
        <div class="mgk-swatch" style="--c: #EFE8D2"><span>paper</span><code>#EFE8D2</code></div>
        <div class="mgk-swatch" style="--c: #FAF5E0"><span>card</span><code>#FAF5E0</code></div>
        <div class="mgk-swatch" style="--c: #1E1C14; color: #EFE8D2"><span>ink</span><code>#1E1C14</code></div>
        <div class="mgk-swatch" style="--c: #3E5940; color: #EFE8D2"><span>moss</span><code>#3E5940</code></div>
        <div class="mgk-swatch" style="--c: #AE6A38; color: #EFE8D2"><span>clay</span><code>#AE6A38</code></div>
        <div class="mgk-swatch" style="--c: #7E5A2A; color: #EFE8D2"><span>bronze</span><code>#7E5A2A</code></div>
      </div>
      <p class="mgk-note">
        Nature-plan palette — warm cream paper, moss-green accents,
        clay-brown emphasis. Avoid black + pure-white on-brand.
      </p>
    </section>

    <section class="mgk-section">
      <h2>Typography</h2>
      <dl class="mgk-facts">
        <dt>Display</dt><dd>Georgia / Iowan Old Style — italic for headlines</dd>
        <dt>Body</dt><dd>-apple-system / system-ui / Helvetica</dd>
        <dt>Mono</dt><dd>IBM Plex Mono / SF Mono / Menlo</dd>
      </dl>
    </section>

    <section class="mgk-section">
      <h2>Reach the maker</h2>
      <dl class="mgk-facts">
        <dt>Founder</dt><dd>Mike Hoydich</dd>
        <dt>Project</dt><dd>Good Feels · <a href="https://pointcast.xyz">pointcast.xyz</a></dd>
        <dt>GitHub</dt><dd><a href="https://github.com/Good-Feels">@Good-Feels</a></dd>
        <dt>Location</dt><dd>El Segundo, CA</dd>
      </dl>
    </section>

    <footer class="mgk-foot">
      <p>All copy + visuals on this page: reuse freely. Attribution welcomed, not required.</p>
      <nav>
        <a href="/magpie/launch">launch page</a>
        <a href="/magpie/faq">faq</a>
        <a href="/magpie/guide">guide</a>
        <a href="/magpie">app</a>
      </nav>
    </footer>
  </article>
</BlockLayout>

<style>
  :root {
    --mg-paper: #EFE8D2;
    --mg-paper-tint: #E7DFC4;
    --mg-card: #FAF5E0;
    --mg-rule: #C8B98E;
    --mg-rule-soft: #E0D6B6;
    --mg-ink: #1E1C14;
    --mg-ink-soft: #5A544A;
    --mg-ink-mute: #8A8273;
    --mg-moss: #3E5940;
    --mg-clay: #AE6A38;
    --mg-bronze: #7E5A2A;
    --mg-display: Georgia, 'Iowan Old Style', serif;
    --mg-mono: ui-monospace, 'IBM Plex Mono', 'SF Mono', Menlo, monospace;
  }

  .mgk-root {
    max-width: 760px;
    margin: 0 auto;
    padding: 40px 24px 60px;
    background: var(--mg-paper);
    color: var(--mg-ink);
    font-family: -apple-system, system-ui, sans-serif;
    line-height: 1.6;
  }

  .mgk-head { margin-bottom: 40px; }
  .mgk-kicker {
    font-family: var(--mg-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mg-clay);
    margin: 0 0 8px;
  }
  .mgk-title {
    font-family: var(--mg-display);
    font-style: italic;
    font-weight: 500;
    font-size: 36px;
    margin: 0 0 12px;
    color: var(--mg-ink);
  }
  .mgk-dek { font-size: 15px; color: var(--mg-ink-soft); margin: 0; }

  .mgk-section { margin-bottom: 30px; }
  .mgk-section h2 {
    font-family: var(--mg-display);
    font-style: italic;
    font-weight: 500;
    font-size: 22px;
    margin: 0 0 10px;
    color: var(--mg-moss);
    border-bottom: 1px dotted var(--mg-rule);
    padding-bottom: 4px;
  }

  .mgk-copy {
    background: var(--mg-card);
    border: 1px solid var(--mg-rule);
    border-radius: 3px;
    padding: 14px 18px;
    font-size: 15px;
    color: var(--mg-ink);
    user-select: all;    /* easy copy */
  }
  .mgk-copy p { margin: 0; }
  .mgk-meta {
    font-family: var(--mg-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--mg-ink-mute);
    margin: 6px 0 0;
  }

  .mgk-short {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .mgk-short li {
    padding: 6px 12px;
    background: var(--mg-card);
    border: 1px solid var(--mg-rule-soft);
    border-radius: 2px;
    margin-bottom: 4px;
    font-family: var(--mg-display);
    font-style: italic;
    font-size: 15px;
    user-select: all;
  }

  .mgk-facts {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 4px 18px;
    margin: 0;
    font-size: 14px;
  }
  .mgk-facts dt {
    font-family: var(--mg-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--mg-clay);
    padding: 4px 0;
  }
  .mgk-facts dd {
    padding: 4px 0;
    margin: 0;
    color: var(--mg-ink);
    border-bottom: 1px dotted var(--mg-rule-soft);
  }
  .mgk-facts dt + dd { border-top: 1px dotted var(--mg-rule-soft); }
  .mgk-facts a { color: var(--mg-bronze); }

  .mgk-takeaways {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: tk;
  }
  .mgk-takeaways li {
    counter-increment: tk;
    padding: 12px 14px 12px 48px;
    background: var(--mg-card);
    border: 1px solid var(--mg-rule-soft);
    border-radius: 3px;
    margin-bottom: 6px;
    position: relative;
    font-size: 14px;
    color: var(--mg-ink-soft);
  }
  .mgk-takeaways li::before {
    content: counter(tk);
    position: absolute;
    left: 14px;
    top: 14px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--mg-moss);
    color: var(--mg-paper);
    font-family: var(--mg-mono);
    font-weight: 700;
    font-size: 12px;
    display: grid;
    place-items: center;
  }
  .mgk-takeaways strong { color: var(--mg-ink); font-weight: 600; }

  .mgk-shots {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--mg-mono);
    font-size: 12px;
    color: var(--mg-ink-soft);
  }
  .mgk-shots li {
    padding: 6px 0;
    border-bottom: 1px dotted var(--mg-rule-soft);
  }
  .mgk-shots li::before { content: '·  '; color: var(--mg-clay); }
  .mgk-note {
    font-family: var(--mg-mono);
    font-size: 11px;
    color: var(--mg-ink-mute);
    margin: 4px 0 0;
  }

  .mgk-logos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .mgk-logo {
    background: var(--mg-card);
    border: 1px solid var(--mg-rule);
    border-radius: 3px;
    padding: 16px;
    text-align: center;
  }
  .mgk-logo-visual {
    background: var(--mg-paper-tint);
    border: 1px solid var(--mg-rule-soft);
    border-radius: 2px;
    display: grid;
    place-items: center;
    height: 100px;
    margin-bottom: 10px;
  }
  .mgk-logo-visual span { font-size: 48px; }
  .mgk-logo p { margin: 2px 0; font-size: 13px; }
  .mgk-logo strong { color: var(--mg-ink); }
  .mgk-wordmark {
    font-family: var(--mg-display);
    font-style: italic;
    font-weight: 500;
    font-size: 40px;
    color: var(--mg-ink);
  }

  .mgk-palette {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 6px;
  }
  .mgk-swatch {
    background: var(--c);
    color: var(--mg-ink);
    padding: 14px 12px;
    border-radius: 2px;
    font-family: var(--mg-mono);
    font-size: 11px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border: 1px solid var(--mg-rule);
  }
  .mgk-swatch span { font-weight: 700; letter-spacing: 0.14em; }
  .mgk-swatch code { font-size: 10px; }

  .mgk-foot {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px dotted var(--mg-rule);
    font-family: var(--mg-mono);
    font-size: 11px;
    color: var(--mg-ink-mute);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .mgk-foot nav { display: flex; gap: 14px; }
  .mgk-foot a {
    color: var(--mg-bronze);
    text-decoration: none;
    letter-spacing: 0.1em;
  }
  .mgk-foot a:hover { color: var(--mg-clay); }

  @media (max-width: 640px) {
    .mgk-title { font-size: 28px; }
    .mgk-facts { grid-template-columns: 100px 1fr; }
    .mgk-logos { grid-template-columns: 1fr; }
  }
</style>
