---
/**
 * /magpie/launch — the v1 launch page.
 *
 * The hero. Big headline, one-line pitch, install CTA. Scrolls to a
 * section that name-drops the eleven destinations and links to the
 * tour, guide, and FAQ. Meant to be shareable — the URL you send
 * to a friend.
 */

import BlockLayout from '../../layouts/BlockLayout.astro';
---

<BlockLayout
  channelCode="FD"
  blockType="NOTE"
  title="Magpie v1.0 — a clipboard that broadcasts"
  description="One capture. Eleven destinations. Local-first. Shipping now."
  pageTitle="Magpie v1.0"
>
  <main class="mgl-root">

    <!-- HERO -->
    <section class="mgl-hero">
      <p class="mgl-kicker">🐦‍⬛ · field clippings · from your machine</p>
      <h1 class="mgl-h1">
        A clipboard that <em>broadcasts.</em>
      </h1>
      <p class="mgl-dek">
        Copy anything. Magpie holds it. Then sends it to
        <strong>eleven destinations</strong> at once — PointCast,
        Mastodon, Farcaster, bitchat, Bluesky, Twitter/X, LinkedIn,
        Instagram, Zora, Objkt, OpenSea. One compose, many homes.
      </p>

      <div class="mgl-cta-row">
        <a class="mgl-btn primary" href="https://github.com/Good-Feels/magpie/releases/latest" target="_blank" rel="noopener">
          Download v1.0 · macOS 13+
        </a>
        <a class="mgl-btn ghost" href="/magpie/tour">Take the tour →</a>
      </div>

      <p class="mgl-subdek">
        Local-first. Open source. Free. Runs entirely on your Mac.
      </p>
    </section>

    <!-- DESTINATIONS -->
    <section class="mgl-section mgl-destinations">
      <h2>Eleven destinations, one protocol</h2>
      <p class="mgl-section-dek">
        Each destination speaks its own shape — char limits, threading,
        embeds, mints. Magpie translates.
      </p>
      <div class="mgl-dest-grid">
        <div class="mgl-dest"><span class="mgl-dest-code">PC</span><div><strong>PointCast</strong><span>your canonical home · 4000 chars</span></div></div>
        <div class="mgl-dest"><span class="mgl-dest-code">MA</span><div><strong>Mastodon</strong><span>any instance · threads · 4 images</span></div></div>
        <div class="mgl-dest"><span class="mgl-dest-code">FC</span><div><strong>Farcaster</strong><span>Neynar signer · IPFS embeds · 320</span></div></div>
        <div class="mgl-dest"><span class="mgl-dest-code">BC</span><div><strong>bitchat</strong><span>Nostr + BLE mesh · 280</span></div></div>
        <div class="mgl-dest"><span class="mgl-dest-code">BS</span><div><strong>Bluesky</strong><span>AT Proto · rich cards · 300</span></div></div>
        <div class="mgl-dest"><span class="mgl-dest-code">TW</span><div><strong>Twitter / X</strong><span>OAuth 2.0 · threads + media · 280</span></div></div>
        <div class="mgl-dest"><span class="mgl-dest-code">LI</span><div><strong>LinkedIn</strong><span>UGC posts · 3000</span></div></div>
        <div class="mgl-dest"><span class="mgl-dest-code">IG</span><div><strong>Instagram</strong><span>Graph API · business accounts</span></div></div>
        <div class="mgl-dest"><span class="mgl-dest-code">ZO</span><div><strong>Zora</strong><span>MINT on Base · EVM wallet</span></div></div>
        <div class="mgl-dest"><span class="mgl-dest-code">OB</span><div><strong>Objkt</strong><span>MINT on Tezos · Teia FA2</span></div></div>
        <div class="mgl-dest"><span class="mgl-dest-code">OS</span><div><strong>OpenSea</strong><span>Seaport listings · post-mint reach</span></div></div>
      </div>
    </section>

    <!-- THREE IDEAS -->
    <section class="mgl-section mgl-ideas">
      <div class="mgl-idea">
        <h3>Capture where you are.</h3>
        <p>
          You're already in Safari, Spotify, Warpcast, Zora. Don't switch
          apps to publish. Copy, hit the magpie, broadcast.
        </p>
      </div>
      <div class="mgl-idea">
        <h3>Local-first, by default.</h3>
        <p>
          Your clipboard stays on your machine. Credentials live in
          Keychain. Nothing leaves unless you press <em>push</em>.
        </p>
      </div>
      <div class="mgl-idea">
        <h3>Writeable by agents.</h3>
        <p>
          Magpie runs an HTTP peer-node on loopback. Claude, ChatGPT,
          cron, a bash script — anything that speaks JSON can broadcast
          through it.
        </p>
      </div>
    </section>

    <!-- SOCIAL PROOF / DOGFOOD -->
    <section class="mgl-section mgl-quote">
      <blockquote>
        "The front door is agentic."
      </blockquote>
      <p class="mgl-quote-meta">— PointCast · CH.FD · № 0205</p>
    </section>

    <!-- QUICK PITCH -->
    <section class="mgl-section mgl-whyyou">
      <h2>Is this for you?</h2>
      <div class="mgl-whyyou-grid">
        <div>
          <p class="mgl-whyyou-tag">IF YOU</p>
          <ul>
            <li>Copy links + thoughts all day but never post them</li>
            <li>Run PointCast, Farcaster, Mastodon and never write the same thing twice</li>
            <li>Want your clipboard to be an API your agents can write through</li>
            <li>Mint on Tezos, Zora, or want to start</li>
            <li>Schedule posts but distrust cloud queues with your tokens</li>
          </ul>
        </div>
        <div>
          <p class="mgl-whyyou-tag">YOU GET</p>
          <ul>
            <li>Cross-destination composer with live per-platform previews</li>
            <li>Six one-click presets (Social, Web3, Long-form, Mesh, Visual, All)</li>
            <li>Image attachments with IPFS auto-staging</li>
            <li>Local + cloud scheduler with encrypted credential forwarding</li>
            <li>Reach dashboard — see what traveled, where</li>
            <li>CLI for scripting: <code>magpie broadcast 42 --to pointcast,mastodon</code></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- LINKS -->
    <section class="mgl-section mgl-links">
      <h2>Start here</h2>
      <div class="mgl-links-grid">
        <a href="/magpie/tour" class="mgl-link-card">
          <span class="mgl-link-kicker">tour</span>
          <strong>12-slide walkthrough</strong>
          <span>Keyboard-driven. 2 minutes.</span>
        </a>
        <a href="/magpie/guide" class="mgl-link-card">
          <span class="mgl-link-kicker">guide</span>
          <strong>Long-form tutorial</strong>
          <span>Every feature. Scrollable. Print-friendly.</span>
        </a>
        <a href="/magpie/pitch" class="mgl-link-card">
          <span class="mgl-link-kicker">pitch</span>
          <strong>90-second overview</strong>
          <span>The shortest read.</span>
        </a>
        <a href="/magpie/faq" class="mgl-link-card">
          <span class="mgl-link-kicker">faq</span>
          <strong>Common questions</strong>
          <span>Privacy, pricing, data, why.</span>
        </a>
        <a href="/magpie/activity" class="mgl-link-card">
          <span class="mgl-link-kicker">live</span>
          <strong>Your activity</strong>
          <span>Requires Magpie.app running.</span>
        </a>
        <a href="/magpie" class="mgl-link-card">
          <span class="mgl-link-kicker">browse</span>
          <strong>Clipboard UI</strong>
          <span>Demo mode if you don't have the app.</span>
        </a>
        <a href="/magpie/changelog" class="mgl-link-card">
          <span class="mgl-link-kicker">ships</span>
          <strong>Changelog · 60 ships</strong>
          <span>Six sprints. v0.6 → v1.0.</span>
        </a>
        <a href="/magpie/press" class="mgl-link-card">
          <span class="mgl-link-kicker">press</span>
          <strong>Press kit</strong>
          <span>Logo, one-liner, screenshots.</span>
        </a>
      </div>
    </section>

    <!-- INSTALL REMINDER -->
    <section class="mgl-section mgl-install">
      <h2>Install in under a minute.</h2>
      <ol class="mgl-install-steps">
        <li>Download the <code>.dmg</code> from GitHub.</li>
        <li>Drag <code>Magpie.app</code> to Applications.</li>
        <li>Launch it. Grant clipboard access.</li>
        <li>Copy something. Right-click → <em>Broadcast…</em></li>
      </ol>
      <a class="mgl-btn primary" href="https://github.com/Good-Feels/magpie/releases/latest" target="_blank" rel="noopener">
        Download v1.0
      </a>
    </section>

    <!-- FOOT -->
    <footer class="mgl-foot">
      <p>
        <span>Magpie is an open-source macOS menu-bar app by</span>
        <a href="https://pointcast.xyz">Mike Hoydich / Good Feels</a>.
      </p>
      <p>
        <a href="https://github.com/Good-Feels/magpie">Source</a> ·
        <a href="/magpie.json">Agent manifest</a> ·
        <a href="/magpie/guide">Guide</a> ·
        <a href="/magpie/faq">FAQ</a>
      </p>
    </footer>
  </main>
</BlockLayout>

<style>
  :root {
    --mg-paper: #EFE8D2;
    --mg-paper-tint: #E7DFC4;
    --mg-card: #FAF5E0;
    --mg-rule: #C8B98E;
    --mg-rule-soft: #E0D6B6;
    --mg-ink: #1E1C14;
    --mg-ink-soft: #5A544A;
    --mg-ink-mute: #8A8273;
    --mg-moss: #3E5940;
    --mg-moss-dark: #273A28;
    --mg-clay: #AE6A38;
    --mg-bronze: #7E5A2A;
    --mg-display: Georgia, 'Iowan Old Style', serif;
    --mg-mono: ui-monospace, 'IBM Plex Mono', 'SF Mono', Menlo, monospace;
  }

  .mgl-root {
    max-width: 900px;
    margin: 0 auto;
    padding: 40px 24px 60px;
    background: var(--mg-paper);
    color: var(--mg-ink);
    font-family: -apple-system, system-ui, sans-serif;
    line-height: 1.55;
  }

  /* HERO */
  .mgl-hero {
    text-align: center;
    padding: 40px 0 60px;
    border-bottom: 1px dotted var(--mg-rule);
  }
  .mgl-kicker {
    font-family: var(--mg-mono);
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--mg-clay);
    margin: 0 0 24px;
  }
  .mgl-h1 {
    font-family: var(--mg-display);
    font-weight: 500;
    font-size: 60px;
    line-height: 1.05;
    margin: 0 0 20px;
    color: var(--mg-ink);
  }
  .mgl-h1 em {
    font-style: italic;
    color: var(--mg-moss);
  }
  .mgl-dek {
    font-family: var(--mg-display);
    font-style: italic;
    font-size: 20px;
    color: var(--mg-ink-soft);
    max-width: 620px;
    margin: 0 auto 32px;
  }
  .mgl-dek strong {
    font-style: normal;
    font-weight: 600;
    color: var(--mg-clay);
  }
  .mgl-cta-row {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }
  .mgl-btn {
    font-family: var(--mg-mono);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
    padding: 12px 22px;
    border-radius: 3px;
    text-decoration: none;
    display: inline-block;
    transition: all 180ms;
  }
  .mgl-btn.primary {
    background: var(--mg-moss);
    color: var(--mg-paper);
    border: 1px solid var(--mg-moss);
  }
  .mgl-btn.primary:hover {
    background: var(--mg-moss-dark);
  }
  .mgl-btn.ghost {
    background: transparent;
    color: var(--mg-ink);
    border: 1px solid var(--mg-rule);
  }
  .mgl-btn.ghost:hover {
    border-color: var(--mg-clay);
    color: var(--mg-clay);
  }
  .mgl-subdek {
    font-family: var(--mg-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--mg-ink-mute);
    margin: 0;
  }

  /* SECTIONS */
  .mgl-section {
    padding: 44px 0;
    border-bottom: 1px dotted var(--mg-rule-soft);
  }
  .mgl-section:last-of-type { border-bottom: none; }
  .mgl-section h2 {
    font-family: var(--mg-display);
    font-style: italic;
    font-weight: 500;
    font-size: 32px;
    margin: 0 0 10px;
    color: var(--mg-moss);
  }
  .mgl-section h3 {
    font-family: var(--mg-display);
    font-style: italic;
    font-weight: 500;
    font-size: 22px;
    margin: 0 0 8px;
    color: var(--mg-ink);
  }
  .mgl-section-dek {
    font-family: var(--mg-display);
    font-style: italic;
    font-size: 16px;
    color: var(--mg-ink-soft);
    margin: 0 0 24px;
  }

  /* DESTINATIONS GRID */
  .mgl-dest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 10px;
  }
  .mgl-dest {
    display: flex;
    gap: 12px;
    padding: 12px 14px;
    background: var(--mg-card);
    border: 1px solid var(--mg-rule);
    border-radius: 3px;
    align-items: center;
  }
  .mgl-dest-code {
    font-family: var(--mg-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--mg-clay);
    padding: 3px 6px;
    border: 0.5px solid var(--mg-clay);
    border-radius: 2px;
    min-width: 30px;
    text-align: center;
    flex: 0 0 auto;
  }
  .mgl-dest > div { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .mgl-dest strong { font-size: 14px; color: var(--mg-ink); }
  .mgl-dest span { font-family: var(--mg-mono); font-size: 10px; color: var(--mg-ink-mute); }

  /* THREE IDEAS */
  .mgl-ideas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 28px;
    border-bottom: 1px dotted var(--mg-rule-soft);
  }
  .mgl-idea p {
    font-size: 15px;
    color: var(--mg-ink-soft);
    margin: 0;
  }
  .mgl-idea em {
    font-family: var(--mg-display);
    font-style: italic;
    color: var(--mg-moss);
  }

  /* QUOTE */
  .mgl-quote {
    text-align: center;
    padding: 60px 0;
  }
  .mgl-quote blockquote {
    font-family: var(--mg-display);
    font-style: italic;
    font-size: 36px;
    color: var(--mg-ink);
    margin: 0 0 12px;
    line-height: 1.2;
  }
  .mgl-quote-meta {
    font-family: var(--mg-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--mg-ink-mute);
    margin: 0;
  }

  /* WHY YOU */
  .mgl-whyyou-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 36px;
    margin-top: 20px;
  }
  .mgl-whyyou-tag {
    font-family: var(--mg-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: var(--mg-clay);
    margin: 0 0 8px;
  }
  .mgl-whyyou-grid ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .mgl-whyyou-grid li {
    padding: 6px 0;
    font-size: 14px;
    color: var(--mg-ink-soft);
    border-bottom: 1px dotted var(--mg-rule-soft);
  }
  .mgl-whyyou-grid li:last-child { border-bottom: none; }
  .mgl-whyyou-grid code {
    font-family: var(--mg-mono);
    font-size: 11px;
    padding: 1px 5px;
    background: var(--mg-paper-tint);
    border-radius: 2px;
  }

  /* LINKS */
  .mgl-links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 10px;
    margin-top: 16px;
  }
  .mgl-link-card {
    display: flex;
    flex-direction: column;
    padding: 14px 16px;
    background: var(--mg-card);
    border: 1px solid var(--mg-rule);
    border-radius: 3px;
    text-decoration: none;
    transition: all 180ms;
  }
  .mgl-link-card:hover {
    border-color: var(--mg-clay);
    background: #FFFDF0;
  }
  .mgl-link-kicker {
    font-family: var(--mg-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mg-clay);
    margin-bottom: 4px;
  }
  .mgl-link-card strong {
    font-size: 14px;
    color: var(--mg-ink);
    margin-bottom: 2px;
  }
  .mgl-link-card span:not(.mgl-link-kicker) {
    font-family: var(--mg-mono);
    font-size: 10px;
    color: var(--mg-ink-mute);
  }

  /* INSTALL */
  .mgl-install {
    text-align: center;
  }
  .mgl-install-steps {
    list-style: none;
    counter-reset: step;
    max-width: 480px;
    margin: 20px auto 24px;
    padding: 0;
    text-align: left;
  }
  .mgl-install-steps li {
    counter-increment: step;
    padding: 8px 0 8px 36px;
    position: relative;
    font-size: 15px;
    color: var(--mg-ink-soft);
  }
  .mgl-install-steps li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 6px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--mg-clay);
    color: var(--mg-paper);
    font-family: var(--mg-mono);
    font-weight: 700;
    font-size: 12px;
    display: grid;
    place-items: center;
  }
  .mgl-install-steps code {
    font-family: var(--mg-mono);
    font-size: 13px;
    padding: 1px 5px;
    background: var(--mg-paper-tint);
    border-radius: 2px;
  }

  /* FOOT */
  .mgl-foot {
    text-align: center;
    padding: 40px 0 20px;
    font-family: var(--mg-mono);
    font-size: 11px;
    color: var(--mg-ink-mute);
  }
  .mgl-foot a {
    color: var(--mg-bronze);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .mgl-foot p { margin: 4px 0; }

  /* RESPONSIVE */
  @media (max-width: 640px) {
    .mgl-h1 { font-size: 40px; }
    .mgl-dek { font-size: 17px; }
    .mgl-whyyou-grid { grid-template-columns: 1fr; }
    .mgl-quote blockquote { font-size: 26px; }
  }
</style>
