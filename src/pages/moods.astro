---
/**
 * /moods — tonal atlas. Lists every mood slug that has at least one
 * block or gallery entry, sorted by population. Each row links to the
 * corresponding /mood/{slug} filter page.
 *
 * Companion to the mood primitive landed in sprint `mood-primitive`
 * (2026-04-19 03:11 tick). Without this index, moods were only
 * discoverable by clicking a chip on /b/{id} — which meant a visitor
 * had to already know a mood existed to find others. This is the
 * discovery surface.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import BlockLayout from '../layouts/BlockLayout.astro';

const blocks = await getCollection('blocks', ({ data }) => !data.draft);

let gallery: CollectionEntry<'gallery'>[] = [];
try {
  gallery = await getCollection('gallery', ({ data }) => !data.draft);
} catch {
  gallery = [];
}

type MoodRow = {
  slug: string;
  blocks: number;
  gallery: number;
  total: number;
  /** Newest timestamp across both collections — lets us surface "fresh" moods. */
  freshest: number;
  /** First 3 blocks by recency for a tiny preview. */
  sampleBlocks: CollectionEntry<'blocks'>[];
};

const rowsByMood = new Map<string, MoodRow>();
function ensure(slug: string): MoodRow {
  let r = rowsByMood.get(slug);
  if (!r) {
    r = { slug, blocks: 0, gallery: 0, total: 0, freshest: 0, sampleBlocks: [] };
    rowsByMood.set(slug, r);
  }
  return r;
}

for (const b of blocks) {
  if (!b.data.mood) continue;
  const r = ensure(b.data.mood);
  r.blocks += 1;
  r.total += 1;
  r.freshest = Math.max(r.freshest, b.data.timestamp.getTime());
}
for (const g of gallery) {
  if (!g.data.mood) continue;
  const r = ensure(g.data.mood);
  r.gallery += 1;
  r.total += 1;
  r.freshest = Math.max(r.freshest, g.data.createdAt.getTime());
}

// Populate sample blocks (newest 3 per mood) after counts are tallied.
for (const row of rowsByMood.values()) {
  row.sampleBlocks = blocks
    .filter((b) => b.data.mood === row.slug)
    .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime())
    .slice(0, 3);
}

const rows = Array.from(rowsByMood.values())
  .sort((a, b) => b.total - a.total || b.freshest - a.freshest);

const totalEntries = rows.reduce((sum, r) => sum + r.total, 0);

const title = 'Moods · tonal atlas';
const description = `A tonal atlas of PointCast. ${rows.length} mood${rows.length === 1 ? '' : 's'} across ${totalEntries} entries — editorial classifiers that cut across channels and types.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://pointcast.xyz/moods',
  name: title,
  description,
  url: 'https://pointcast.xyz/moods',
  inLanguage: 'en-US',
  hasPart: rows.map((r) => ({
    '@type': 'CollectionPage',
    '@id': `https://pointcast.xyz/mood/${r.slug}`,
    name: r.slug.replace(/-/g, ' '),
    url: `https://pointcast.xyz/mood/${r.slug}`,
  })),
};
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">← All blocks</a>
      <span aria-hidden="true">/</span>
      <span>moods</span>
    </nav>

    <header class="masthead">
      <h1 class="title">Moods · <em>tonal atlas</em></h1>
      <p class="count mono">{rows.length} MOOD{rows.length === 1 ? '' : 'S'} · {totalEntries} ENTRIES</p>
      <p class="lede">
        Not a channel, not a type — a <em>register</em>. Moods cut across
        the feed by emotional or atmospheric fingerprint. A block tagged
        "rainy-week" and a gallery image tagged "quiet" can sit under
        different moods despite sharing a channel. This page lists every
        mood with at least one entry, sorted by population.
      </p>
      <p class="lede lede--secondary">
        Moods are additive. A future tick can coin a new slug the moment
        a block earns one — the route materializes on next build. See
        <a href="/b/0275">0275</a> (rainy-week) or <a href="/mood/rainy-week">/mood/rainy-week</a> for the first set.
      </p>
    </header>

    {rows.length === 0 && (
      <p class="empty">No mood-tagged entries yet. (If you see this in production, something regressed — the sprint <code>mood-primitive</code> seeded four blocks.)</p>
    )}

    {rows.length > 0 && (
      <ul class="rows">
        {rows.map((row) => (
          <li class="row">
            <a class="row__link" href={`/mood/${row.slug}`} aria-label={`${row.slug} — ${row.total} entries`}>
              <div class="row__head">
                <span class="row__slug">{row.slug.replace(/-/g, ' ')}</span>
                <span class="row__count mono" aria-label={`${row.total} entries`}>
                  {row.total}
                  <span class="row__count-sub">
                    {row.blocks > 0 ? `${row.blocks}B` : ''}{row.blocks > 0 && row.gallery > 0 ? '·' : ''}{row.gallery > 0 ? `${row.gallery}G` : ''}
                  </span>
                </span>
              </div>
              {row.sampleBlocks.length > 0 && (
                <ul class="row__samples">
                  {row.sampleBlocks.map((b) => (
                    <li class="row__sample mono">№{b.data.id} · {b.data.title.slice(0, 48)}{b.data.title.length > 48 ? '…' : ''}</li>
                  ))}
                </ul>
              )}
              <span class="row__arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    )}

    <aside class="agent-strip">
      <p class="agent-strip__label">MACHINE-READABLE</p>
      <ul>
        <li><a href="/moods.json">/moods.json</a></li>
        <li><a href="/blocks.json">/blocks.json</a></li>
        <li><a href="/for-agents">/for-agents</a></li>
      </ul>
    </aside>

  </div>
</BlockLayout>

<style>
  .page {
    max-width: 820px;
    margin: 0 auto;
    padding: 20px 20px 80px;
  }

  .breadcrumb {
    display: flex;
    gap: 8px;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin-bottom: 20px;
  }
  .breadcrumb a { color: var(--pc-accent); }

  .masthead {
    padding-bottom: 18px;
    border-bottom: 1.5px solid var(--pc-ink);
    margin-bottom: 24px;
  }
  .title {
    margin: 0 0 6px;
    font-family: var(--pc-font-heading, var(--pc-font-serif));
    font-size: 32px;
    font-weight: 500;
    color: #12110E;
    letter-spacing: -0.01em;
  }
  .title em { font-style: italic; color: #8a2432; }
  .count {
    margin: 0 0 14px;
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--pc-ink-soft);
  }
  .lede {
    margin: 0 0 10px;
    max-width: 58ch;
    font-size: 15px;
    line-height: 1.55;
    color: #2a2925;
  }
  .lede em { font-style: italic; color: #8a2432; }
  .lede a { color: var(--pc-accent); }
  .lede--secondary { font-size: 13px; color: var(--pc-ink-soft); margin-bottom: 0; }

  .rows {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    gap: 10px;
  }

  .row__link {
    display: block;
    padding: 14px 16px;
    border: 1px solid #d6d4cd;
    border-radius: 3px;
    background: #fafaf7;
    position: relative;
    transition: background-color 0.12s, border-color 0.12s;
  }
  .row__link:hover {
    background: #fef5e7;
    border-color: #8a2432;
    text-decoration: none;
  }

  .row__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }
  .row__slug {
    font-family: var(--pc-font-heading, var(--pc-font-serif));
    font-size: 20px;
    font-weight: 500;
    color: #12110E;
    letter-spacing: -0.005em;
    text-transform: none;
  }
  .row__count {
    font-size: 14px;
    font-weight: 700;
    color: #8a2432;
    letter-spacing: 0.08em;
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .row__count-sub {
    font-size: 9px;
    letter-spacing: 0.14em;
    color: var(--pc-ink-soft);
    font-weight: 500;
  }

  .row__samples {
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
    display: grid;
    gap: 2px;
  }
  .row__sample {
    font-size: 11px;
    color: var(--pc-ink-soft);
    letter-spacing: 0.02em;
  }

  .row__arrow {
    position: absolute;
    right: 14px;
    bottom: 12px;
    color: #8a2432;
    font-weight: 700;
    font-family: var(--pc-font-mono);
    opacity: 0;
    transition: opacity 0.12s;
  }
  .row__link:hover .row__arrow { opacity: 1; }

  .empty {
    margin: 40px 0;
    padding: 20px;
    border: 1px dashed #d6d4cd;
    border-radius: 3px;
    text-align: center;
    color: var(--pc-ink-soft);
    font-style: italic;
  }
  .empty code {
    font-family: var(--pc-font-mono);
    font-size: 12px;
    background: #f5f0ff;
    padding: 1px 4px;
    border-radius: 2px;
  }

  .agent-strip {
    margin-top: 48px;
    padding-top: 16px;
    border-top: 1px solid var(--pc-rule, #d6d4cd);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pc-ink-soft);
  }
  .agent-strip__label { margin: 0 0 6px; font-weight: 600; }
  .agent-strip ul {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .agent-strip a { color: var(--pc-accent); }

  .mono { font-family: var(--pc-font-mono); }
</style>
