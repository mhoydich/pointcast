---
/**
 * /play — the games + interactions hub.
 *
 * Mike 2026-04-20 17:32 PT chat: "humans land things like collect,
 * drum, interacting with existing peoples at the time, learnings,
 * information updates."
 *
 * One discovery surface for everything fun on PointCast. Currently:
 *   - Drum cookie clicker (/drum/click)
 *   - Cards (/cards) — collectible per visit
 *   - Quiz (/quiz) — daily trivia
 *   - Here (/here) — live-presence room with HereBeat + HerePoll
 *   - Polls (/polls) — community coordination
 *   - Prize Cast (/yield, /collect/prize) — weekly tez lottery (pending originate)
 *   - Today's Drop (/today) — the daily collectible block
 *   - Battle (/battle) — the existing card-of-the-day vs visitor game
 *
 * Each entry is a card with an emoji + 1-line + "play →". No fancy.
 * The whole point is one URL a reader can give a friend that says
 * "here's the thing to do."
 *
 * Author: cc. Source: Mike 2026-04-20 17:32 PT chat.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const title = 'Play — the games + interactions on PointCast';
const description =
  "All the playful stuff in one place: tap a drum to mint rhythms, collect a card per visit, answer the daily quiz, hang out in /here with whoever else is connected, vote on coordination polls, deposit tez to the weekly Prize Cast. No signup required for any of it.";

const games = [
  {
    href: '/play/tank',
    icon: '🐟',
    title: 'Tank',
    dek: 'Shared live aquarium. Every visitor becomes a Noun-head fish; agents manifest as metallic fish. Drop flake, place plants, vacuum gravel. Agents can observe, feed, place, dart, and write CC0 lore via WebMCP. Three empty gaps in the research-as-of-April-2026 (tank-as-UI, Nouns fish, Tezos aquarium) filled in one ship. No signup, no crypto.',
    cta: 'dive in →',
    color: '#0fb2c8',
    tags: ['live', 'multiplayer', 'agents', 'ecosystem'],
  },
  {
    href: '/drum/click',
    icon: '🥁',
    title: 'Drum Cookie Clicker',
    dek: 'Tap the drum. Beats accumulate. Unlock snare → hi-hat → auto-drummer → polyrhythm. At 25,000 beats you can cast a rhythm — burn the pile, lock in a +10% multiplier forever, accumulate receipts. Web Audio synth, mobile-first, Space = tap.',
    cta: 'tap →',
    color: '#E89A2D',
    tags: ['solo', 'audio', 'mobile-first'],
  },
  {
    href: '/cards',
    icon: '🃏',
    title: 'Daily Cards',
    dek: 'One collectible per visit — your mood + noun + date + a rarity tier (common / uncommon / rare / legendary). Legendary cards shimmer. Edge qualities tag special days (palindrome-noun, mood-of-the-day, four-twenty). Deck lives in your browser, grows quietly as you come back.',
    cta: 'collect →',
    color: '#5F3DC4',
    tags: ['daily', 'collectible'],
  },
  {
    href: '/quiz',
    icon: '🧠',
    title: 'PointCast Quiz',
    dek: 'One trivia question a day on PointCast lore — Tezos, nouns, the Waldos, Codex Chronicle, the cookie-clicker upgrade ladder, federated compute signature bands. Tap an answer, learn the explanation, your streak compounds locally. Never repeats within the same day.',
    cta: 'answer →',
    color: '#185FA5',
    tags: ['daily', 'learning'],
  },
  {
    href: '/here',
    icon: '🛋️',
    title: 'Here',
    dek: "The live room. See who else is connected right now (their nouns + cities). Tap the 6-pad meditative beat and others can hear it. Vote on the room's poll. Closest thing PointCast has to a hangout.",
    cta: 'enter →',
    color: '#2f8f5f',
    tags: ['multiplayer', 'live'],
  },
  {
    href: '/polls',
    icon: '🗳️',
    title: 'Polls',
    dek: 'Community coordination. Shelling-point, sky-clock, april-register, BTC trend, Sunday soundtrack. Vote once, watch the distribution update live. Post-vote a follow-up surfaces based on your choice. No accounts; one vote per session, tracked client-side.',
    cta: 'vote →',
    color: '#C92A2A',
    tags: ['community'],
  },
  {
    href: '/today',
    icon: '✦',
    title: "Today's Drop",
    dek: 'One block of editorial content per day, collectible with one tap. Streak counter compounds if you don\'t miss a day. No wallet required — it\'s pure localStorage. The pick rotates at midnight PT; everyone sees the same drop on the same day.',
    cta: 'collect →',
    color: '#E8590C',
    tags: ['daily', 'collectible'],
  },
  {
    href: '/battle',
    icon: '⚔️',
    title: 'Battle · Card of the Day',
    dek: 'A daily card-vs-card duel. The site picks a Card of the Day from the noun pool; you bring your noun. Stats clash, winner gets bragging rights. Tiny game, single click.',
    cta: 'duel →',
    color: '#8a2432',
    tags: ['daily', 'duel'],
  },
  {
    href: '/yield',
    icon: '🎰',
    title: 'Prize Cast',
    dek: 'Weekly no-loss tez lottery. Toss in 1 tez to the shared pool, principal stays liquid (withdraw anytime), one address wins the yield each Sunday at 18:00 UTC. Currently pending mainnet origination — ghostnet sketches running.',
    cta: 'see pool →',
    color: '#0B3E73',
    tags: ['tezos', 'weekly', 'pending'],
  },
  {
    href: '/noundrum',
    icon: '🥁',
    title: 'Noundrum',
    dek: 'Multiplayer cookie-clicker drum where every visitor is a Noun cursor. Drum to earn rhythm, spend rhythm to claim tiles on a shared 24×16 grid, decorate your tiles with trees, lamps, fountains, stars, towers. v0 simulates other visitors via NPC Nouns; v1 ships real DO-backed multiplayer.',
    cta: 'enter →',
    color: '#F59F00',
    tags: ['multiplayer', 'drum', 'land', 'art', 'new'],
  },
  {
    href: '/commercials',
    icon: '📺',
    title: 'Commercials',
    dek: 'Three commercial videos posted as editorial artifacts: a 1967 anachronistic Japanese PointCast spot, a Magpie commercial, and a Magpie × Lego crossover. Each comes with a one-question guess-the-decade game.',
    cta: 'watch →',
    color: '#8A2432',
    tags: ['video', 'editorial', 'game', 'new'],
  },
  {
    href: '/leaderboards',
    icon: '🏆',
    title: 'Leaderboards',
    dek: 'Local-first scores across drum, noundrum, cards, quiz, and the commercials game, sat against a session-derived simulated population of other players. Real federated boards ship with /noundrum v1.',
    cta: 'see board →',
    color: '#185FA5',
    tags: ['scores', 'aggregate', 'new'],
  },
];
---

<BlockLayout title={title} description={description}>
  <main class="play-page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>play</span>
    </nav>

    <header class="head">
      <p class="kicker mono">PLAY · GAMES + INTERACTIONS · NO SIGNUP REQUIRED</p>
      <h1 class="title">Eight tiny games, one URL.</h1>
      <p class="dek">
        Everything playful on PointCast in one place. Each one runs in your browser,
        keeps state locally, and asks nothing of you beyond a tap. Send <code>pointcast.xyz/play</code>
        to a friend if you want them to see what kind of site this is in 30 seconds.
      </p>
    </header>

    <section class="grid" aria-label="Games">
      {games.map((g) => (
        <a class="game-card" href={g.href} style={`--accent: ${g.color}`}>
          <div class="game-card__head">
            <span class="game-card__icon" aria-hidden="true">{g.icon}</span>
            <h2 class="game-card__title">{g.title}</h2>
          </div>
          <p class="game-card__dek">{g.dek}</p>
          <div class="game-card__foot">
            <span class="game-card__tags mono">
              {g.tags.map((t, i) => (
                <>
                  <span class="game-card__tag">{t}</span>
                  {i < g.tags.length - 1 && <span aria-hidden="true">·</span>}
                </>
              ))}
            </span>
            <span class="game-card__cta mono">{g.cta}</span>
          </div>
        </a>
      ))}
    </section>

    <p class="foot mono">
      more games coming · drop a request at <a href="/ping">/ping</a> ·
      everything here is open-source at <a href="https://github.com/MikeHoydich/pointcast" rel="noopener">github.com/MikeHoydich/pointcast</a>
    </p>
  </main>
</BlockLayout>

<style>
  .play-page { max-width: 1080px; margin: 0 auto; padding: 24px 20px 80px; color: var(--pc-ink, #12110E); }
  .mono { font-family: var(--pc-font-mono, 'JetBrains Mono Variable', monospace); }

  .crumb { font-family: var(--pc-font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; color: var(--pc-ink-muted, #5F5E5A); }
  .crumb a { color: inherit; text-decoration: none; border-bottom: 1px solid currentColor; }
  .crumb a:hover { color: #E89A2D; }
  .crumb span[aria-hidden] { margin: 0 6px; opacity: 0.5; }

  .head { margin: 10px 0 26px; padding-bottom: 18px; border-bottom: 1px solid var(--pc-rule-soft, #E5E3DE); }
  .kicker { font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: #E89A2D; margin: 0 0 10px; font-weight: 600; }
  .title { font-family: var(--pc-font-sans, 'Inter Variable', system-ui); font-size: clamp(28px, 4vw, 42px); font-weight: 500; margin: 0 0 14px; letter-spacing: -0.01em; line-height: 1.12; }
  .dek { font-size: 15px; line-height: 1.55; color: var(--pc-ink-soft, #38373A); margin: 0; max-width: 64ch; }
  .dek code { font-family: var(--pc-font-mono); font-size: 13px; padding: 1px 5px; background: rgba(232, 154, 45, 0.08); border-radius: 2px; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 14px;
    margin: 0 0 30px;
  }

  .game-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 16px 18px 14px;
    background: #fff;
    border: 1px solid var(--pc-rule-soft, #E5E3DE);
    border-left: 3px solid var(--accent, #E89A2D);
    border-radius: 3px;
    text-decoration: none;
    color: var(--pc-ink);
    transition: transform 0.12s, box-shadow 0.12s, border-color 0.12s;
  }
  .game-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px -8px rgba(0, 0, 0, 0.18);
    border-left-width: 5px;
    padding-left: 16px;
  }

  .game-card__head {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .game-card__icon { font-size: 22px; line-height: 1; flex-shrink: 0; }
  .game-card__title {
    font-family: var(--pc-font-sans, 'Inter Variable', system-ui);
    font-size: 18px;
    font-weight: 500;
    margin: 0;
    letter-spacing: -0.01em;
    color: var(--pc-ink);
  }

  .game-card__dek {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--pc-ink-soft, #38373A);
    margin: 0;
    flex: 1;
  }

  .game-card__foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
    padding-top: 8px;
    border-top: 1px dotted var(--pc-rule-soft, #E5E3DE);
  }
  .game-card__tags {
    font-size: 9.5px;
    letter-spacing: 0.1em;
    color: var(--pc-ink-muted);
    text-transform: uppercase;
    display: inline-flex;
    gap: 4px;
    align-items: baseline;
  }
  .game-card__tag { color: var(--pc-ink-muted); }
  .game-card__cta {
    font-size: 10.5px;
    letter-spacing: 0.14em;
    color: var(--accent);
    font-weight: 600;
    text-transform: uppercase;
  }

  .foot { margin: 30px 0 0; font-size: 11px; color: var(--pc-ink-muted); line-height: 1.55; letter-spacing: 0; text-transform: none; }
  .foot a { color: #E89A2D; text-decoration: underline; }

  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; }
    .game-card { padding: 14px 16px 12px; }
  }
</style>
