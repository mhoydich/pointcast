---
/**
 * /pairings — index of every mood with block + product counts.
 *
 * The landing page for the commerce-editorial cross-index. Each mood row
 * shows how many blocks and how many Good Feels products share that mood.
 * Click → /pairings/{mood}.
 */
import { getCollection } from 'astro:content';
import BlockLayout from '../../layouts/BlockLayout.astro';
import { resolveMoodTemplate } from '../../lib/moods-soundtracks';

const [blocks, products] = await Promise.all([
  getCollection('blocks', ({ data }) => !data.draft),
  getCollection('products', ({ data }) => !data.draft),
]);

type Row = { mood: string; template: ReturnType<typeof resolveMoodTemplate>; blocks: number; products: number };
const rowMap = new Map<string, Row>();

blocks.forEach((b) => {
  if (!b.data.mood) return;
  const row = rowMap.get(b.data.mood) ?? { mood: b.data.mood, template: resolveMoodTemplate(b.data.mood), blocks: 0, products: 0 };
  row.blocks += 1;
  rowMap.set(b.data.mood, row);
});
products.forEach((p) => {
  (p.data.pairsWithMood ?? []).forEach((m) => {
    const row = rowMap.get(m) ?? { mood: m, template: resolveMoodTemplate(m), blocks: 0, products: 0 };
    row.products += 1;
    rowMap.set(m, row);
  });
});

const rows: Row[] = Array.from(rowMap.values())
  .sort((a, b) => (b.blocks + b.products) - (a.blocks + a.products));

const withProducts = rows.filter((r) => r.products > 0).length;

const title = 'Pairings · blocks × products × vibe';
const description = `${rows.length} moods indexed. ${withProducts} have at least one Good Feels product pairing. Each pairing cross-links the editorial feed, the commerce catalog, and a procedural soundtrack.`;
---

<BlockLayout title={title} description={description} image="/images/og/polls.png">
  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>pairings</span>
    </nav>

    <header class="head">
      <p class="kicker mono">PAIRINGS · {rows.length} MOODS · {withProducts} WITH GOOD FEELS</p>
      <h1 class="title">Every mood, paired.</h1>
      <p class="dek">
        A mood is a coordinate that blocks and products can both occupy. This
        is the cross-index. Every mood row below clicks through to the full
        pairing page — editorial on the left, commerce on the right, a
        procedural Sonic Postcard on top when a vibe is declared.
      </p>
    </header>

    <ul class="list">
      {rows.map((r) => (
        <li>
          <a class="row" href={`/pairings/${r.mood}`} style={`--mood-accent:${r.template.accent};--mood-wash:${r.template.wash}`}>
            <span class="row__mood">{r.template.label}</span>
            <span class="row__slug mono">/{r.mood}</span>
            <span class="row__dek mono">{r.template.register}</span>
            <span class="row__counts mono">
              <span class="count count--blocks">{r.blocks} BLOCK{r.blocks === 1 ? '' : 'S'}</span>
              <span class="count count--products" data-has={r.products > 0 ? 'true' : 'false'}>{r.products} PROD{r.products === 1 ? '' : 'S'}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>

    <section class="agent-strip">
      <p class="agent-strip__label mono">MACHINE-READABLE</p>
      <ul>
        <li><a href="/api/products.jsonl">/api/products.jsonl</a></li>
        <li><a href="/api/blocks.jsonl">/api/blocks.jsonl</a></li>
        <li><a href="/moods">/moods (full list)</a></li>
        <li><a href="/for-agents">/for-agents</a></li>
      </ul>
    </section>
  </main>

  <style>
    .page { max-width: 880px; margin: 0 auto; padding: 24px 18px 80px; }
    .mono { font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); text-transform: uppercase; letter-spacing: 0.12em; }
    .crumb { display: flex; gap: 8px; margin-bottom: 14px; font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: #7a7a72; }
    .crumb a { color: #a02c2c; text-decoration: none; }

    .head { margin-bottom: 22px; max-width: 640px; }
    .kicker { font-size: 10px; margin: 0 0 8px; letter-spacing: 0.18em; color: #5F3DC4; }
    .title { font-family: var(--pc-font-sans, 'Inter Variable', system-ui, sans-serif); font-size: clamp(30px, 5vw, 44px); font-weight: 700; line-height: 1.05; margin: 0 0 12px; }
    .dek { margin: 0; color: #38373A; line-height: 1.55; font-size: 15px; }

    .list { list-style: none; padding: 0; margin: 0 0 28px; display: grid; gap: 4px; }
    .row {
      display: grid;
      grid-template-columns: 1fr auto minmax(120px, 0.5fr) auto;
      gap: 12px;
      align-items: baseline;
      padding: 10px 14px;
      background:
        linear-gradient(90deg, color-mix(in srgb, var(--mood-wash, #fbf9ff) 62%, transparent), transparent 46%),
        #fff;
      border: 1px solid #d6d4cd;
      border-left: 5px solid var(--mood-accent, #5F3DC4);
      border-radius: 2px;
      color: #12110E;
      text-decoration: none;
      transition: background 0.12s, border-color 0.12s;
    }
    .row:hover { background: var(--mood-wash, #fbf9ff); border-color: var(--mood-accent, #5F3DC4); }
    .row__mood { font-family: var(--pc-font-sans, 'Inter Variable', system-ui, sans-serif); font-size: 16px; font-weight: 600; text-transform: lowercase; }
    .row__slug { font-size: 10px; color: #8a8878; }
    .row__dek { font-size: 9px; color: var(--mood-accent, #5F3DC4); letter-spacing: 0.1em; }
    .row__counts { display: flex; gap: 10px; font-size: 9.5px; }
    .count { padding: 2px 6px; border-radius: 2px; font-weight: 700; }
    .count--blocks { background: #f5f0ff; color: #5F3DC4; }
    .count--products { background: #e6f5ee; color: #0F6E56; }
    .count--products[data-has="false"] { background: #f5f3ed; color: #8a8878; }

    @media (max-width: 540px) {
      .row { grid-template-columns: 1fr auto; grid-template-rows: auto auto; row-gap: 2px; }
      .row__slug { grid-column: 1 / 2; grid-row: 2; }
      .row__dek { display: none; }
      .row__counts { grid-column: 2; grid-row: 1 / 3; flex-direction: column; align-items: flex-end; }
    }

    .agent-strip { margin-top: 22px; padding-top: 12px; border-top: 1px dashed #d6d4cd; font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; }
    .agent-strip__label { margin: 0 0 6px; color: #5F5E5A; font-weight: 500; }
    .agent-strip ul { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 12px; }
    .agent-strip a { color: #a02c2c; text-decoration: none; text-transform: lowercase; letter-spacing: 0; }
    .agent-strip a:hover { text-decoration: underline; }
  </style>
</BlockLayout>
