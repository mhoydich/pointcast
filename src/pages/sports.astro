---
/**
 * /sports — dedicated sports page.
 *
 * Moved off home 2026-04-20 21:30 PT (Phase 3 collapse) per plan in
 * docs/plans/2026-04-20-home-phase3-plus-sprint-plan.md. The SportsStrip
 * component stays as-is (v3, with team records + upset detection + tipoff
 * previews) and renders as this page's main content.
 *
 * Rationale: the home page needs to read as a newspaper front page —
 * masthead, editorial hero, signal strip, grid. Sports is a destination,
 * not chrome. A chip in TodayOnPointCast's rotation pool points to
 * /sports so the surface stays discoverable.
 *
 * Author: cc. Source: home Phase 3 plan + Mike's pings about sports being
 * "still weak" + too much home chrome.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import SportsStrip from '../components/SportsStrip.astro';

const title = 'Sports — results, matchups, upsets';
const description = 'Last night\'s major-league results and tonight\'s matchups — NBA, NHL, MLB, Premier League, La Liga, Ligue 1. Team records in the row; upset badge when records flip the score. Client-side fetch of ESPN\'s scoreboards, 10-min cache.';
---

<BlockLayout title={title} description={description}>
  <main class="sports-page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>sports</span>
    </nav>

    <header class="head">
      <p class="kicker mono">SPORTS · RESULTS, MATCHUPS, UPSETS</p>
      <h1 class="title">What just happened.</h1>
      <p class="dek">
        Last night and tonight across six majors — NBA, NHL, MLB, Premier League, La Liga, Ligue 1.
        Records in the row so you know if the favorite held or got chewed.
        An upset badge fires when the winner's record is well below the loser's.
        Client-side fetch, short-TTL cache, respects your tab sleep.
      </p>
    </header>

    <SportsStrip />

    <section class="foot">
      <p class="foot__kicker mono">ALSO</p>
      <ul class="foot__list">
        <li><a href="/play">Play hub — eight tiny games in one place</a></li>
        <li><a href="/drum/click">Drum cookie clicker — build a rhythm, cast it on Tezos</a></li>
        <li><a href="/today">Today's drop — claim this morning's noun</a></li>
        <li><a href="/">Back to the front page</a></li>
      </ul>
    </section>
  </main>
</BlockLayout>

<style>
  .sports-page { max-width: 960px; margin: 0 auto; padding: 24px 18px 80px; color: var(--pc-ink, #12110E); }
  .mono { font-family: var(--pc-font-mono, 'JetBrains Mono Variable', monospace); }

  .crumb { font-family: var(--pc-font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; color: var(--pc-ink-muted, #5F5E5A); }
  .crumb a { color: inherit; text-decoration: none; border-bottom: 1px solid currentColor; }
  .crumb a:hover { color: #E89A2D; }
  .crumb span[aria-hidden] { margin: 0 6px; opacity: 0.5; }

  .head { margin: 10px 0 24px; padding-bottom: 18px; border-bottom: 1px solid var(--pc-rule-soft, #E5E3DE); }
  .kicker { font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: #185FA5; margin: 0 0 10px; font-weight: 600; }
  .title { font-family: var(--pc-font-sans, 'Inter Variable', system-ui); font-size: clamp(28px, 4.5vw, 44px); font-weight: 500; margin: 0 0 12px; letter-spacing: -0.01em; line-height: 1.1; }
  .dek { font-size: 14.5px; line-height: 1.55; color: var(--pc-ink-soft, #38373A); margin: 0; max-width: 68ch; }

  .foot { margin-top: 36px; padding-top: 18px; border-top: 1px solid var(--pc-rule-soft, #E5E3DE); }
  .foot__kicker { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--pc-ink-muted); margin: 0 0 8px; }
  .foot__list { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .foot__list a { color: var(--pc-ink); text-decoration: underline; text-decoration-color: rgba(0,0,0,0.18); font-size: 14.5px; }
  .foot__list a:hover { color: #185FA5; text-decoration-color: currentColor; }
</style>
