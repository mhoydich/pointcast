---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const projects = await getCollection('projects', ({ data }) => !data.draft);

const allContent = [
  ...posts.map(p => ({ ...p, collection: 'posts' as const, type: p.data.type })),
  ...projects.map(p => ({ ...p, collection: 'projects' as const, type: 'project' as const })),
].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const types = ['all', 'newsletter', 'article', 'essay', 'project', 'art'] as const;

const typeLabels: Record<string, string> = {
  all: 'All',
  newsletter: 'Dispatches',
  article: 'Articles',
  essay: 'Essays',
  project: 'Projects',
  art: 'Art',
};
---

<BaseLayout title="Feed" description="All published content from Mike Hoydich & Claude Cowork.">
  <div class="max-w-3xl mx-auto px-4 py-10 md:py-14">
    <header class="mb-6">
      <div class="kicker">Archive</div>
      <h1 class="font-serif text-2xl md:text-3xl text-ink font-medium italic mb-2">Feed</h1>
      <p class="font-mono text-[0.62rem] tracking-[0.14em] uppercase text-ink-soft">
        {allContent.length} pieces published
      </p>
    </header>

    <!-- Type filters -->
    <div class="flex flex-wrap gap-2 mb-8 pb-5 border-b border-rule/50" role="tablist" aria-label="Content type filter">
      {types.map(type => (
        <button
          data-filter={type}
          role="tab"
          aria-selected={type === 'all' ? 'true' : 'false'}
          class:list={[
            'filter-btn px-3 py-1.5 font-mono text-[0.6rem] tracking-[0.18em] uppercase rounded-md border transition-colors cursor-pointer',
            type === 'all'
              ? 'bg-warm/10 text-warm border-warm/20'
              : 'bg-card text-ink-soft border-rule hover:border-warm/30',
          ]}
        >
          {typeLabels[type]}
        </button>
      ))}
    </div>

    <div class="grid gap-5 sm:grid-cols-2" id="feed-grid" role="tabpanel">
      {allContent.map(item => (
        <div data-type={item.type}>
          <ContentCard
            title={item.data.title}
            description={item.data.description}
            date={item.data.date}
            type={item.type}
            slug={item.id}
            image={item.data.image}
            tags={item.data.tags}
            collection={item.collection}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('#feed-grid > div');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;

      buttons.forEach(b => {
        b.classList.remove('bg-warm/10', 'text-warm', 'border-warm/20');
        b.classList.add('bg-card', 'text-ink-soft', 'border-rule');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.remove('bg-card', 'text-ink-soft', 'border-rule');
      btn.classList.add('bg-warm/10', 'text-warm', 'border-warm/20');
      btn.setAttribute('aria-selected', 'true');

      items.forEach(item => {
        const type = (item as HTMLElement).dataset.type;
        if (filter === 'all' || type === filter) {
          (item as HTMLElement).style.display = '';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
