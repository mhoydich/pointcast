---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const projects = await getCollection('projects', ({ data }) => !data.draft);

const allContent = [
  ...posts.map(p => ({ ...p, collection: 'posts' as const, type: p.data.type })),
  ...projects.map(p => ({ ...p, collection: 'projects' as const, type: 'project' as const })),
].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const types = ['all', 'newsletter', 'article', 'essay', 'project', 'art'] as const;

const typeLabels: Record<string, string> = {
  all: 'All',
  newsletter: 'Dispatches',
  article: 'Articles',
  essay: 'Essays',
  project: 'Projects',
  art: 'Art',
};
---

<BaseLayout title="Feed" description="All published content from Mike Hoydich & Claude Cowork Publishings.">
  <div class="max-w-5xl mx-auto px-4 py-10 md:py-14">
    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-heading text-nouns-yellow mb-2">Feed</h1>
      <p class="text-nouns-muted font-mono text-sm">
        {allContent.length} pieces published
      </p>
    </header>

    <!-- Type filters -->
    <div class="flex flex-wrap gap-2 mb-8 pb-6 border-b border-nouns-border/50" role="tablist" aria-label="Content type filter">
      {types.map(type => (
        <button
          data-filter={type}
          role="tab"
          aria-selected={type === 'all' ? 'true' : 'false'}
          class:list={[
            'filter-btn px-4 py-2 text-xs font-mono uppercase tracking-wider rounded-full border transition-colors cursor-pointer',
            type === 'all'
              ? 'bg-nouns-yellow/15 text-nouns-yellow border-nouns-yellow/20'
              : 'bg-nouns-bg-elevated/50 text-nouns-muted border-nouns-border/50 hover:border-nouns-yellow/30',
          ]}
        >
          {typeLabels[type]}
        </button>
      ))}
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3" id="feed-grid" role="tabpanel">
      {allContent.map(item => (
        <div data-type={item.type}>
          <ContentCard
            title={item.data.title}
            description={item.data.description}
            date={item.data.date}
            type={item.type}
            slug={item.id}
            image={item.data.image}
            tags={item.data.tags}
            collection={item.collection}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('#feed-grid > div');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;

      buttons.forEach(b => {
        b.classList.remove('bg-nouns-yellow/15', 'text-nouns-yellow', 'border-nouns-yellow/20');
        b.classList.add('bg-nouns-bg-elevated/50', 'text-nouns-muted', 'border-nouns-border/50');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.remove('bg-nouns-bg-elevated/50', 'text-nouns-muted', 'border-nouns-border/50');
      btn.classList.add('bg-nouns-yellow/15', 'text-nouns-yellow', 'border-nouns-yellow/20');
      btn.setAttribute('aria-selected', 'true');

      items.forEach(item => {
        const type = (item as HTMLElement).dataset.type;
        if (filter === 'all' || type === filter) {
          (item as HTMLElement).style.display = '';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
