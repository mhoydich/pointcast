---
/**
 * /agent-derby - deterministic horse racing game for PointCast agents.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import WalletChip from '../components/WalletChip.astro';
import contracts from '../data/contracts.json';
import {
  DERBY_BADGES,
  DERBY_DAILY_RACES,
  DERBY_FAN_TIERS,
  DERBY_POSTERS,
  DERBY_ROSTER,
  DERBY_RULEBOOK,
  DERBY_STABLES,
  DERBY_STATS,
  DERBY_TRACKS,
  DERBY_VERSION,
} from '../lib/agent-derby';

const derbyReceiptContract = (contracts as any).agent_derby_receipts ?? {};
const derbyChain = {
  network: 'mainnet',
  address: String(derbyReceiptContract.mainnet ?? ''),
  entrypoint: String(derbyReceiptContract.entrypoint ?? 'record_race'),
  explorerBase: 'https://tzkt.io',
};

const derbyData = {
  version: DERBY_VERSION,
  stats: DERBY_STATS,
  tracks: DERBY_TRACKS,
  roster: DERBY_ROSTER,
  stables: DERBY_STABLES,
  dailyRaces: DERBY_DAILY_RACES,
  badges: DERBY_BADGES,
  fanTiers: DERBY_FAN_TIERS,
  posters: DERBY_POSTERS,
  rulebook: DERBY_RULEBOOK,
  chain: derbyChain,
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  '@id': 'https://pointcast.xyz/agent-derby#game',
  name: 'PointCast Agent Derby',
  description: 'A deterministic browser horse-racing game for PointCast agents and humans.',
  url: 'https://pointcast.xyz/agent-derby',
  gamePlatform: 'Web browser',
  genre: 'Horse racing simulation',
  inLanguage: 'en-US',
};
---

<BlockLayout
  title="Agent Derby"
  description="A deterministic browser horse-racing game for PointCast agents and humans."
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/agent-derby.json', title: 'PointCast Agent Derby manifest' }]}
  frame={{
    image: 'https://pointcast.xyz/images/og/og-home-v2.png',
    buttons: [
      { label: 'Run race', action: 'link', target: 'https://pointcast.xyz/agent-derby' },
      { label: 'Game JSON', action: 'link', target: 'https://pointcast.xyz/agent-derby.json' },
      { label: '/for-agents', action: 'link', target: 'https://pointcast.xyz/for-agents' },
      { label: 'Home', action: 'link', target: 'https://pointcast.xyz/' },
    ],
  }}
>
  <div class="derby-page" data-agent-derby>
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>agent-derby</span>
    </nav>

    <section class="derby-shell" aria-labelledby="derby-title">
      <header class="mast">
        <div class="mast__copy">
          <p class="kicker">CH.BTL / AGENT DERBY / v{DERBY_VERSION}</p>
          <h1 id="derby-title">PointCast Agent Derby v3</h1>
          <p class="mast__dek">Daily cards, fan-backed stables, badge receipts, and a livelier wire.</p>
        </div>
        <div class="mast__rail">
          <div class="race-key" aria-label="Race status">
            <span data-race-id>AD-READY</span>
            <strong data-race-state>GATES</strong>
          </div>
          <div class="beacon-gate" aria-label="Tezos Beacon gate">
            <span>Beacon gate</span>
            <WalletChip />
          </div>
        </div>
      </header>

      <section class="play-deck" aria-label="Fast play">
        <div class="play-step play-step--pick">
          <span>1 / Pick</span>
          <div class="quick-picks" data-quick-picks>
            {DERBY_ROSTER.map((horse) => (
              <button type="button" data-quick-agent={horse.slug} style={`--coat:${horse.coat};--accent:${horse.accent}`}>
                <strong>{horse.name}</strong>
                <small>{horse.agent}</small>
              </button>
            ))}
          </div>
        </div>
        <div class="play-step play-step--run">
          <span>2 / Race</span>
          <div class="play-actions">
            <button type="button" class="btn btn--primary btn--big" data-action="quick-run">Run v3 race</button>
            <button type="button" class="btn" data-action="new-field">Shuffle field</button>
          </div>
        </div>
        <div class="play-step play-step--chain">
          <span>3 / Tezos</span>
          <strong data-chain-status>Receipt pending</strong>
          <div class="play-actions">
            <button type="button" class="btn btn--chain" data-action="record-chain" data-chain-record disabled>Sign with Tezos</button>
            <button type="button" class="btn" data-action="copy-chain-packet" data-chain-copy disabled>Copy packet</button>
          </div>
        </div>
      </section>

      <section class="control-deck" aria-label="Race controls">
        <label class="seed-box">
          <span>Seed</span>
          <input type="text" value="gamgee-rc0" data-seed-input spellcheck="false" autocomplete="off" />
        </label>
        <div class="track-tabs" data-track-tabs role="tablist" aria-label="Track select"></div>
        <div class="button-row">
          <button type="button" class="btn btn--primary" data-action="run">Run race</button>
          <button type="button" class="btn" data-action="new-field">New field</button>
          <button type="button" class="btn" data-action="reset">Reset</button>
        </div>
      </section>

      <section class="v3-board" aria-labelledby="derby-v3-title">
        <div class="v3-board__head">
          <div>
            <p class="v3-board__kicker">CH.DERBY / DAILY CARD / STABLES</p>
            <h2 id="derby-v3-title">Today at the agent track</h2>
          </div>
          <a href="/agent-derby.json">v3 manifest</a>
        </div>
        <div class="daily-card-grid" data-daily-board></div>
        <div class="fan-grid">
          <section class="fan-panel" aria-labelledby="stable-fan-title">
            <div class="panel-head">
              <span id="stable-fan-title">Stable fandom</span>
              <strong data-fan-summary>Local rail loading</strong>
            </div>
            <div class="stable-fan-grid" data-stable-fan-grid></div>
          </section>
          <section class="badge-panel" aria-labelledby="derby-badge-title">
            <div class="panel-head">
              <span id="derby-badge-title">Badges</span>
              <button type="button" class="mini-btn" data-fan-reset>Reset local fandom</button>
            </div>
            <div class="badge-grid" data-badge-grid></div>
          </section>
        </div>
      </section>

      <section class="poster-wall" aria-labelledby="poster-wall-title">
        <div class="poster-wall__head">
          <div>
            <p class="poster-wall__kicker">CH.POSTER / STYLE BOOK / 10 HEATS</p>
            <h2 id="poster-wall-title">Ten poster heats</h2>
          </div>
          <a href="/agent-derby.json">Poster manifest</a>
        </div>
        <div class="poster-grid">
          {DERBY_POSTERS.map((poster) => (
            <a
              class="poster-card"
              href={`/agent-derby?seed=${poster.seed}&track=${poster.track}&agents=${poster.horseSlug}`}
              style={`--poster-position:${poster.imagePosition}`}
              aria-label={`Run ${poster.title} in ${poster.styleName}`}
            >
              <img src={poster.image} alt="" loading="lazy" decoding="async" />
              <span class="poster-card__gate">{poster.gate}</span>
              <span class="poster-card__agent">{poster.agent}</span>
              <strong>{poster.title}</strong>
              <em>{poster.styleName}</em>
              <small>{poster.palette.join(' / ')}</small>
            </a>
          ))}
        </div>
      </section>

      <div class="race-grid">
        <main class="track-card" aria-label="Race track">
          <div class="track-card__top">
            <span data-track-label>El Segundo Sprint</span>
            <strong data-track-meta>ES-1200 / 1200m / fast dirt</strong>
          </div>
          <div class="track-stage" data-track-stage></div>
        </main>

        <aside class="stable-card" aria-label="Field">
          <div class="stable-card__head">
            <span>Field</span>
            <strong data-field-summary>6 gates loaded</strong>
          </div>
          <div class="field-list" data-field-list></div>
        </aside>
      </div>

      <div class="race-bottom">
        <section class="result-card" aria-label="Race result">
          <div class="panel-head">
            <span>Result</span>
            <button type="button" class="mini-btn" data-action="copy">Copy receipt</button>
          </div>
          <div class="podium" data-podium>
            <p>Gates are loaded.</p>
          </div>
          <pre class="receipt" data-receipt aria-label="Race receipt">{}</pre>
        </section>

        <section class="chain-card" aria-label="Tezos receipt">
          <div class="panel-head">
            <span>Tezos receipt</span>
            <a href="/agent-derby.json">manifest</a>
          </div>
          <dl class="chain-readout">
            <div>
              <dt>Network</dt>
              <dd data-chain-network>mainnet</dd>
            </div>
            <div>
              <dt>Contract</dt>
              <dd data-chain-contract>pending KT1</dd>
            </div>
            <div>
              <dt>Receipt hash</dt>
              <dd data-chain-hash>run race first</dd>
            </div>
            <div>
              <dt>Operation</dt>
              <dd><a data-chain-op href="/agent-derby" aria-disabled="true">not recorded</a></dd>
            </div>
          </dl>
        </section>

        <section class="log-card" aria-label="Race call">
          <div class="panel-head">
            <span>Call</span>
            <a href="/agent-derby.json">/agent-derby.json</a>
          </div>
          <div class="race-log" data-race-log>
            <p>Race desk standing by.</p>
          </div>
        </section>

        <section class="agent-card" aria-label="Agent protocol">
          <div class="panel-head">
            <span>Agent line</span>
            <a href="/for-agents">/for-agents</a>
          </div>
          <code>/agent-derby?seed=gamgee-rc0&amp;track=wire-mile&amp;agents=claude,codex,manus</code>
          <div class="history-list" data-history-list></div>
        </section>
      </div>
    </section>
  </div>

  <script type="application/json" id="derby-data" set:html={JSON.stringify(derbyData)}></script>

  <script is:inline>
    (function () {
      var root = document.querySelector('[data-agent-derby]');
      var dataEl = document.getElementById('derby-data');
      if (!root || !dataEl) return;

      var DATA = JSON.parse(dataEl.textContent || '{}');
      var TRACKS = DATA.tracks || [];
      var ROSTER = DATA.roster || [];
      var STATS = DATA.stats || ['speed', 'stamina', 'burst', 'nerve', 'gate', 'grit'];
      var STABLES = DATA.stables || [];
      var DAILY_RACES = DATA.dailyRaces || [];
      var BADGES = DATA.badges || [];
      var FAN_TIERS = DATA.fanTiers || [];
      var STORAGE_KEY = 'pc:agent-derby:races';
      var FAN_STORAGE_KEY = 'pc:agent-derby:fans';
      var BADGE_STORAGE_KEY = 'pc:agent-derby:badges';
      var FRAME_COUNT = 120;

      var params = new URLSearchParams(window.location.search);
      var seedInput = root.querySelector('[data-seed-input]');
      var quickPicks = root.querySelector('[data-quick-picks]');
      var trackTabs = root.querySelector('[data-track-tabs]');
      var trackStage = root.querySelector('[data-track-stage]');
      var fieldList = root.querySelector('[data-field-list]');
      var historyList = root.querySelector('[data-history-list]');
      var raceLog = root.querySelector('[data-race-log]');
      var receiptEl = root.querySelector('[data-receipt]');
      var podium = root.querySelector('[data-podium]');
      var raceIdEl = root.querySelector('[data-race-id]');
      var raceStateEl = root.querySelector('[data-race-state]');
      var trackLabel = root.querySelector('[data-track-label]');
      var trackMeta = root.querySelector('[data-track-meta]');
      var fieldSummary = root.querySelector('[data-field-summary]');
      var dailyBoard = root.querySelector('[data-daily-board]');
      var fanSummary = root.querySelector('[data-fan-summary]');
      var stableFanGrid = root.querySelector('[data-stable-fan-grid]');
      var badgeGrid = root.querySelector('[data-badge-grid]');
      var fanReset = root.querySelector('[data-fan-reset]');

      var state = {
        seed: params.get('seed') || 'gamgee-rc0',
        trackId: params.get('track') || (TRACKS[0] && TRACKS[0].id),
        focusAgent: (params.get('agents') || '').split(',')[0].trim().toLowerCase(),
        dailyRaceId: params.get('daily') || '',
        field: [],
        sim: null,
        timer: 0,
        frame: 0,
        racing: false,
        receipt: null,
      };

      seedInput.value = state.seed;

      function escapeHtml(value) {
        return String(value).replace(/[&<>"']/g, function (char) {
          return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[char];
        });
      }

      function hashString(value) {
        var hash = 2166136261;
        var text = String(value);
        for (var i = 0; i < text.length; i += 1) {
          hash ^= text.charCodeAt(i);
          hash = Math.imul(hash, 16777619);
        }
        return hash >>> 0;
      }

      function rngFrom(value) {
        var a = hashString(value);
        return function () {
          a |= 0;
          a = (a + 0x6D2B79F5) | 0;
          var t = Math.imul(a ^ (a >>> 15), 1 | a);
          t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
          return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
        };
      }

      function ptDateKey(date) {
        var formatter = new Intl.DateTimeFormat('en-CA', {
          timeZone: 'America/Los_Angeles',
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
        });
        var parts = formatter.formatToParts(date || new Date()).reduce(function (acc, part) {
          acc[part.type] = part.value;
          return acc;
        }, {});
        return [parts.year, parts.month, parts.day].join('-');
      }

      function readJson(key, fallback) {
        try {
          var raw = localStorage.getItem(key);
          return raw ? JSON.parse(raw) : fallback;
        } catch (error) {
          return fallback;
        }
      }

      function writeJson(key, value) {
        try {
          localStorage.setItem(key, JSON.stringify(value));
        } catch (error) {}
      }

      function defaultFanState() {
        return { selectedStableId: '', stables: {}, visits: 0, updatedAt: null };
      }

      function normalizeFanState(value) {
        var next = defaultFanState();
        if (value && typeof value === 'object') {
          next.selectedStableId = String(value.selectedStableId || '');
          next.stables = value.stables && typeof value.stables === 'object' ? value.stables : {};
          next.visits = Number(value.visits || 0);
          next.updatedAt = value.updatedAt || null;
        }
        return next;
      }

      var fanState = normalizeFanState(readJson(FAN_STORAGE_KEY, defaultFanState()));

      function stableSlug(name) {
        return String(name || '')
          .toLowerCase()
          .replace(/&/g, 'and')
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-|-$/g, '');
      }

      function stableById(id) {
        return STABLES.find(function (stable) { return stable.id === id; }) || null;
      }

      function stableForHorse(horse) {
        if (!horse) return null;
        return stableById(stableSlug(horse.stable)) ||
          STABLES.find(function (stable) { return stable.name === horse.stable; }) ||
          null;
      }

      function stableSupport(id) {
        var record = fanState.stables && fanState.stables[id] ? fanState.stables[id] : {};
        return Number(record.support || 0);
      }

      function fanTier(support) {
        return FAN_TIERS.slice().sort(function (a, b) { return b.minSupport - a.minSupport; })
          .find(function (tier) { return support >= tier.minSupport; }) ||
          FAN_TIERS[0] ||
          { id: 'railbird', label: 'Railbird', minSupport: 0, boost: 0, note: 'Rail ready.' };
      }

      function stableBoostFor(horse) {
        var stable = stableForHorse(horse);
        if (!stable) return 0;
        return Number(fanTier(stableSupport(stable.id)).boost || 0);
      }

      function touchFanVisit() {
        fanState.visits = Number(fanState.visits || 0) + 1;
        fanState.updatedAt = new Date().toISOString();
        writeJson(FAN_STORAGE_KEY, fanState);
      }

      function saveFanState() {
        fanState.updatedAt = new Date().toISOString();
        writeJson(FAN_STORAGE_KEY, fanState);
        renderStableFans();
        renderBadges();
      }

      function readBadges() {
        var value = readJson(BADGE_STORAGE_KEY, {});
        return value && typeof value === 'object' ? value : {};
      }

      function writeBadges(value) {
        writeJson(BADGE_STORAGE_KEY, value || {});
      }

      function awardBadge(id) {
        if (!BADGES.some(function (badge) { return badge.id === id; })) return false;
        var badges = readBadges();
        if (badges[id]) return false;
        badges[id] = new Date().toISOString();
        writeBadges(badges);
        renderBadges();
        return true;
      }

      function activeDailyCards() {
        if (!DAILY_RACES.length) return [];
        var day = ptDateKey();
        var start = hashString(day + ':agent-derby-daily') % DAILY_RACES.length;
        return [0, 1, 2].map(function (offset) {
          return DAILY_RACES[(start + offset) % DAILY_RACES.length];
        });
      }

      function dailyRaceFor(id) {
        return DAILY_RACES.find(function (race) { return race.id === id; }) || null;
      }

      function dailySeed(race) {
        return race.seed + '-' + ptDateKey();
      }

      function renderDailyBoard() {
        if (!dailyBoard) return;
        var today = ptDateKey();
        var cards = activeDailyCards();
        dailyBoard.innerHTML = cards.map(function (race) {
          var track = TRACKS.find(function (item) { return item.id === race.track; }) || TRACKS[0];
          var stable = stableById(race.featuredStable);
          var selected = race.id === state.dailyRaceId;
          return '<article class="daily-race-card" data-selected="' + (selected ? 'true' : 'false') + '" style="--stable:' + escapeHtml(stable?.color || '#185fa5') + ';--stable-accent:' + escapeHtml(stable?.accent || '#f4b23f') + '">' +
            '<div><span>' + escapeHtml(today) + '</span><strong>' + escapeHtml(race.label) + '</strong></div>' +
            '<p>' + escapeHtml(track.label) + ' / ' + escapeHtml(race.window) + '</p>' +
            '<small>' + escapeHtml(stable ? stable.name : 'Open stable') + ' / ' + escapeHtml(race.prize) + '</small>' +
            '<button type="button" class="mini-btn" data-daily-race="' + escapeHtml(race.id) + '">' + (selected ? 'Loaded' : 'Load race') + '</button>' +
          '</article>';
        }).join('');
      }

      function renderBadges() {
        if (!badgeGrid) return;
        var earned = readBadges();
        badgeGrid.innerHTML = BADGES.map(function (badge) {
          var isEarned = Boolean(earned[badge.id]);
          return '<article class="badge-token" data-earned="' + (isEarned ? 'true' : 'false') + '">' +
            '<span>' + escapeHtml(badge.code) + '</span>' +
            '<strong>' + escapeHtml(badge.label) + '</strong>' +
            '<small>' + escapeHtml(isEarned ? 'earned' : badge.requirement) + '</small>' +
          '</article>';
        }).join('');
      }

      function renderStableFans() {
        if (!stableFanGrid) return;
        var selected = stableById(fanState.selectedStableId);
        var selectedSupport = selected ? stableSupport(selected.id) : 0;
        var selectedTier = fanTier(selectedSupport);
        if (fanSummary) {
          fanSummary.textContent = selected
            ? selected.name + ' / ' + selectedTier.label + ' / ' + selectedSupport + ' support'
            : 'Pick a stable from the rail';
        }
        stableFanGrid.innerHTML = STABLES.map(function (stable) {
          var support = stableSupport(stable.id);
          var tier = fanTier(support);
          var picked = fanState.selectedStableId === stable.id;
          return '<article class="stable-fan-card" data-selected="' + (picked ? 'true' : 'false') + '" style="--stable:' + escapeHtml(stable.color) + ';--stable-accent:' + escapeHtml(stable.accent) + '">' +
            '<div><span>' + escapeHtml(stable.agent) + '</span><strong>' + escapeHtml(stable.name) + '</strong></div>' +
            '<p>' + escapeHtml(stable.motto) + '</p>' +
            '<small>' + escapeHtml(tier.label) + ' / ' + support + ' support / +' + Number(tier.boost || 0).toFixed(Number(tier.boost || 0) % 1 ? 1 : 0) + ' form</small>' +
            '<div class="stable-fan-card__actions">' +
              '<button type="button" class="mini-btn" data-fan-stable="' + escapeHtml(stable.id) + '">' + (picked ? 'Fan' : 'Become fan') + '</button>' +
              '<button type="button" class="mini-btn" data-fan-back="' + escapeHtml(stable.id) + '" data-amount="50">Back +50</button>' +
              '<button type="button" class="mini-btn" data-fan-back="' + escapeHtml(stable.id) + '" data-amount="150">Build +150</button>' +
            '</div>' +
          '</article>';
        }).join('');
      }

      touchFanVisit();

      function activeTrack() {
        return TRACKS.find(function (track) { return track.id === state.trackId; }) || TRACKS[0];
      }

      function agentTokens() {
        if (state.focusAgent) return [state.focusAgent];
        return (new URLSearchParams(window.location.search).get('agents') || '')
          .split(',')
          .map(function (token) { return token.trim().toLowerCase(); })
          .filter(Boolean);
      }

      function matchesToken(horse, token) {
        return horse.slug.toLowerCase().indexOf(token) >= 0 ||
          horse.agent.toLowerCase().indexOf(token) >= 0 ||
          horse.name.toLowerCase().indexOf(token) >= 0;
      }

      function selectField(seed) {
        var requested = [];
        agentTokens().forEach(function (token) {
          var match = ROSTER.find(function (horse) { return matchesToken(horse, token); });
          if (match && requested.indexOf(match) === -1) requested.push(match);
        });

        var rng = rngFrom(seed + ':field');
        var shuffled = ROSTER
          .filter(function (horse) { return requested.indexOf(horse) === -1; })
          .map(function (horse) { return { horse: horse, sort: rng() }; })
          .sort(function (a, b) { return a.sort - b.sort; })
          .map(function (item) { return item.horse; });

        return requested.concat(shuffled).slice(0, 6).map(function (horse, index) {
          return Object.assign({}, horse, { gate: index + 1 });
        });
      }

      function ratingFor(horse, track) {
        var total = 0;
        STATS.forEach(function (stat) {
          total += horse.stats[stat] * (track.bias[stat] || 1);
        });
        return total / STATS.length + stableBoostFor(horse);
      }

      function raceId(seed, track, field) {
        var base = seed + ':' + track.id + ':' + field.map(function (horse) { return horse.slug; }).join(',');
        return 'AD-' + hashString(base).toString(36).toUpperCase().slice(0, 6).padStart(6, '0');
      }

      function simulateRace(seed, trackId, field) {
        var track = TRACKS.find(function (item) { return item.id === trackId; }) || TRACKS[0];
        var ratings = field.map(function (horse) { return ratingFor(horse, track); });
        var totalRating = ratings.reduce(function (sum, rating) { return sum + rating; }, 0);

        var runners = field.map(function (horse, runnerIndex) {
          var rng = rngFrom(seed + ':' + track.id + ':' + horse.slug);
          var rating = ratings[runnerIndex];
          var fanBoost = stableBoostFor(horse);
          var distance = 0;
          var raw = [0];
          var trouble = null;

          for (var tick = 1; tick <= FRAME_COUNT; tick += 1) {
            var p = tick / FRAME_COUNT;
            var gatePush = Math.max(0, 1 - p * 5) * (horse.stats.gate - 50) * 0.2;
            var cruise = Math.sin(Math.PI * Math.min(1, p * 1.12)) * (horse.stats.speed - 50) * 0.045;
            var stretch = Math.max(0, (p - 0.62) / 0.38) * (((horse.stats.stamina + horse.stats.burst) / 2) - 50) * 0.11;
            var surface = 0;
            if (track.id === 'dune-night') surface = (horse.stats.grit - 50) * 0.08;
            if (track.id === 'fog-route') surface = (((horse.stats.nerve + horse.stats.grit) / 2) - 50) * 0.07;

            var trafficWindow = p > 0.24 && p < 0.76;
            if (!trouble && trafficWindow && rng() < (100 - horse.stats.nerve) / 18000) {
              trouble = { tick: tick, note: horse.name + ' checked in traffic' };
            }

            var penalty = trouble && tick - trouble.tick < 11 ? 10.5 : 0;
            var pace = 47 + rating / 3.35 + gatePush + cruise + stretch + surface + (rng() - 0.5) * 6 - penalty;
            distance += Math.max(16, pace);
            raw.push(distance);
          }

          var chance = Math.max(0.05, rating / totalRating);
          return Object.assign({}, horse, {
            rating: rating,
            fanBoost: fanBoost,
            odds: (1 / chance).toFixed(1) + 'x',
            raw: raw,
            finish: raw[raw.length - 1],
            trouble: trouble,
          });
        });

        var maxDistance = runners.reduce(function (max, runner) { return Math.max(max, runner.finish); }, 0);
        runners.forEach(function (runner) {
          runner.positions = runner.raw.map(function (value) { return Math.min(100, (value / maxDistance) * 100); });
          runner.margin = Number((((maxDistance - runner.finish) / maxDistance) * 12).toFixed(2));
          runner.time = Number((track.par + runner.margin * 0.43).toFixed(2));
        });

        var order = runners.slice().sort(function (a, b) {
          return b.finish - a.finish || a.gate - b.gate;
        });

        return {
          raceId: raceId(seed, track, field),
          seed: seed,
          track: track,
          runners: runners,
          order: order,
          winner: order[0],
        };
      }

      function horseSvg() {
        return '<svg viewBox="0 0 96 52" aria-hidden="true" focusable="false">' +
          '<path fill="var(--coat)" d="M12 35h14l6-12h20l8 7 10-14 12 1 6 7-6 4 5 5-8 2-5-5-7 12H49l-5 9h-8l3-9H25l-7 9h-8l8-10-6-7Z"/>' +
          '<path fill="var(--accent)" d="M54 22l7 5 5-8-7-3-5 6Zm-24 1h12l-3 6H27l3-6Z"/>' +
          '<circle cx="80" cy="22" r="2" fill="#12110e"/>' +
          '<path stroke="#12110e" stroke-width="3" stroke-linecap="round" d="M25 37l-7 10M46 37l-4 10M62 37l5 10"/>' +
          '</svg>';
      }

      function laneTelemetry(runner) {
        var topStat = STATS.slice().sort(function (a, b) {
          return runner.stats[b] - runner.stats[a];
        })[0];
        return topStat.toUpperCase() + ' ' + runner.stats[topStat];
      }

      function statBars(horse) {
        return STATS.map(function (stat) {
          var value = horse.stats[stat];
          return '<div class="stat-line"><span>' + stat.toUpperCase() + '</span><strong>' + value + '</strong><i style="--v:' + value + '%"></i></div>';
        }).join('');
      }

      function renderTrackTabs() {
        trackTabs.innerHTML = TRACKS.map(function (track) {
          var selected = track.id === state.trackId ? ' aria-selected="true"' : ' aria-selected="false"';
          return '<button type="button" role="tab" data-track="' + escapeHtml(track.id) + '"' + selected + '>' +
            '<span>' + escapeHtml(track.code) + '</span>' +
            '<strong>' + escapeHtml(track.label) + '</strong>' +
            '</button>';
        }).join('');
      }

      function renderQuickPicks() {
        if (!quickPicks) return;
        quickPicks.querySelectorAll('[data-quick-agent]').forEach(function (button) {
          var selected = button.getAttribute('data-quick-agent') === state.focusAgent;
          button.setAttribute('aria-pressed', selected ? 'true' : 'false');
        });
      }

      function renderTrack() {
        var sim = state.sim;
        var track = sim.track;
        trackLabel.textContent = track.label;
        trackMeta.textContent = track.code + ' / ' + track.distance + 'm / ' + track.going;
        raceIdEl.textContent = sim.raceId;
        fieldSummary.textContent = sim.runners.length + ' gates loaded';

        trackStage.innerHTML =
          '<div class="race-cinema">' +
            '<div class="race-cinema__hud">' +
              '<span data-race-heat>GATES READY</span>' +
              '<strong data-live-leader>Awaiting break</strong>' +
              '<em data-live-gap>0.00L</em>' +
            '</div>' +
            '<div class="race-cinema__signal" data-live-board>' +
              '<span>TOP THREE</span><b>--</b><b>--</b><b>--</b><strong>0.00L</strong><i>GATES</i>' +
            '</div>' +
          '</div>' +
          '<div class="track-ruler"><span>GATE</span><span>BACKSTRETCH</span><span>TURN</span><span>WIRE</span></div>' +
          sim.runners.map(function (runner) {
            return '<div class="lane" data-lane="' + escapeHtml(runner.slug) + '" style="--coat:' + escapeHtml(runner.coat) + ';--accent:' + escapeHtml(runner.accent) + '">' +
              '<div class="lane__meta">' +
                '<span>G' + runner.gate + '</span>' +
                '<strong>' + escapeHtml(runner.name) + '</strong>' +
                '<small>' + escapeHtml(runner.agent) + ' / ' + runner.odds + '</small>' +
                '<div class="lane__telemetry"><b data-rank="' + escapeHtml(runner.slug) + '">--</b><i>' + escapeHtml(laneTelemetry(runner)) + '</i></div>' +
              '</div>' +
              '<div class="lane__rail">' +
                '<span class="lane__fill" data-fill="' + escapeHtml(runner.slug) + '"></span>' +
                '<span class="lane__wake" data-wake="' + escapeHtml(runner.slug) + '"></span>' +
                '<span class="runner" data-runner="' + escapeHtml(runner.slug) + '" style="left:3%;">' +
                  horseSvg() +
                  '<span class="runner__tag">' + escapeHtml(runner.agent) + '</span>' +
                '</span>' +
              '</div>' +
            '</div>';
          }).join('');
      }

      function renderField() {
        fieldList.innerHTML = state.sim.runners.map(function (runner) {
          var fanBoost = Number(runner.fanBoost || 0);
          var fanLine = fanBoost > 0 ? '+' + fanBoost.toFixed(fanBoost % 1 ? 1 : 0) + ' fan form' : 'base form';
          return '<article class="horse-card" style="--coat:' + escapeHtml(runner.coat) + ';--accent:' + escapeHtml(runner.accent) + '">' +
            '<div class="horse-card__top"><span>G' + runner.gate + '</span><strong>' + escapeHtml(runner.name) + '</strong><small>' + escapeHtml(runner.odds) + '</small></div>' +
            '<p>' + escapeHtml(runner.stable) + ' / ' + escapeHtml(fanLine) + '</p>' +
            '<em>' + escapeHtml(runner.bloodline) + '</em>' +
            '<div class="stats">' + statBars(runner) + '</div>' +
          '</article>';
        }).join('');
      }

      function receiptFor(sim) {
        var selectedStable = stableById(fanState.selectedStableId);
        var selectedSupport = selectedStable ? stableSupport(selectedStable.id) : 0;
        var selectedTier = fanTier(selectedSupport);
        var dailyRace = dailyRaceFor(state.dailyRaceId);
        return {
          version: DATA.version,
          raceId: sim.raceId,
          seed: sim.seed,
          track: sim.track.id,
          dailyRace: dailyRace ? {
            id: dailyRace.id,
            label: dailyRace.label,
            dateKey: ptDateKey(),
          } : null,
          generatedAt: new Date().toISOString(),
          winner: sim.winner.slug,
          fanBacking: {
            mode: 'local-practice',
            stableId: selectedStable ? selectedStable.id : null,
            stable: selectedStable ? selectedStable.name : null,
            support: selectedSupport,
            tier: selectedTier.label,
            boost: selectedTier.boost,
          },
          field: sim.runners.map(function (runner) {
            return {
              slug: runner.slug,
              gate: runner.gate,
              agent: runner.agent,
              stable: runner.stable,
              fanBoost: runner.fanBoost,
              rating: Number(runner.rating.toFixed(2)),
            };
          }),
          order: sim.order.map(function (runner) { return runner.slug; }),
          margins: sim.order.map(function (runner) {
            return { slug: runner.slug, margin: runner.margin, time: runner.time };
          }),
          badges: Object.keys(readBadges()).sort(),
        };
      }

      function renderReceipt(receipt) {
        receiptEl.textContent = JSON.stringify(receipt || {}, null, 2);
      }

      function renderPodium() {
        if (!state.receipt) {
          podium.innerHTML = '<p>Gates are loaded. The finish board will light after PHOTO.</p>';
          return;
        }
        var order = state.sim.order;
        var winner = order[0];
        var winnerBoost = Number(winner.fanBoost || 0);
        podium.innerHTML =
          '<article class="finish-hero" style="--coat:' + escapeHtml(winner.coat) + ';--accent:' + escapeHtml(winner.accent) + '">' +
            '<div class="finish-hero__copy">' +
              '<span>PHOTO / WINNER</span>' +
              '<strong>' + escapeHtml(winner.name) + '</strong>' +
              '<small>' + escapeHtml(winner.agent) + ' / ' + escapeHtml(winner.stable) + ' / ' + winner.time.toFixed(2) + 's / +' + winnerBoost.toFixed(winnerBoost % 1 ? 1 : 0) + ' fan form</small>' +
            '</div>' +
            '<div class="finish-hero__mark">' + horseSvg() + '</div>' +
          '</article>' +
          '<div class="finish-board">' +
            order.map(function (runner, index) {
              var place = index + 1;
              var beaten = runner.margin === 0 ? 'winner' : runner.margin.toFixed(2) + 'L';
              return '<article class="finish-row" style="--coat:' + escapeHtml(runner.coat) + ';--accent:' + escapeHtml(runner.accent) + ';--p:' + Math.max(8, 100 - runner.margin * 7) + '%">' +
                '<span>' + String(place).padStart(2, '0') + '</span>' +
                '<strong>' + escapeHtml(runner.name) + '</strong>' +
                '<small>' + beaten + ' / ' + runner.time.toFixed(2) + 's / ' + escapeHtml(runner.stable) + '</small>' +
                '<i></i>' +
              '</article>';
            }).join('') +
          '</div>';
      }

      function readHistory() {
        try {
          return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
        } catch (error) {
          return [];
        }
      }

      function writeHistory(receipt) {
        var next = [receipt].concat(readHistory().filter(function (item) { return item.raceId !== receipt.raceId; })).slice(0, 12);
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify(next));
        } catch (error) {}
      }

      function renderHistory() {
        var items = readHistory().slice(0, 4);
        historyList.innerHTML = items.length
          ? items.map(function (item) {
              return '<a href="/agent-derby?seed=' + encodeURIComponent(item.seed) + '&track=' + encodeURIComponent(item.track) + '">' +
                '<span>' + escapeHtml(item.raceId) + '</span><strong>' + escapeHtml(item.winner) + '</strong>' +
              '</a>';
            }).join('')
          : '<p>No race receipts yet.</p>';
      }

      function logLine(text) {
        var p = document.createElement('p');
        p.textContent = text;
        raceLog.prepend(p);
        while (raceLog.children.length > 8) raceLog.removeChild(raceLog.lastChild);
      }

      function setStateLabel(value) {
        raceStateEl.textContent = value;
        root.dataset.racePhase = value.toLowerCase();
      }

      function dispatchReceipt(receipt) {
        window.dispatchEvent(new CustomEvent('pc:agent-derby-receipt', { detail: receipt }));
      }

      function updateUrl() {
        var url = new URL(window.location.href);
        url.searchParams.set('seed', state.seed);
        url.searchParams.set('track', state.trackId);
        if (state.focusAgent) url.searchParams.set('agents', state.focusAgent);
        else url.searchParams.delete('agents');
        if (state.dailyRaceId) url.searchParams.set('daily', state.dailyRaceId);
        else url.searchParams.delete('daily');
        window.history.replaceState({}, '', url);
      }

      function updatePositions(frame) {
        var indexed = state.sim.runners.map(function (runner) {
          var progress = runner.positions[Math.min(frame, runner.positions.length - 1)] || 0;
          return { runner: runner, progress: progress };
        }).sort(function (a, b) {
          return b.progress - a.progress || a.runner.gate - b.runner.gate;
        });
        var leader = indexed[0] && indexed[0].runner;
        var secondProgress = indexed[1] ? indexed[1].progress : indexed[0]?.progress || 0;
        var leaderProgress = indexed[0]?.progress || 0;
        var gap = Math.max(0, (leaderProgress - secondProgress) * 0.12);
        var heat = frame >= FRAME_COUNT ? 'PHOTO FINISH' : frame > 92 ? 'WIRE RUN' : frame > 58 ? 'FAR TURN' : frame > 25 ? 'BACKSTRETCH' : 'BREAK';
        var leaderEl = trackStage.querySelector('[data-live-leader]');
        var gapEl = trackStage.querySelector('[data-live-gap]');
        var heatEl = trackStage.querySelector('[data-race-heat]');
        var liveBoard = trackStage.querySelector('[data-live-board]');
        if (leaderEl) leaderEl.textContent = leader ? leader.name + ' shows the way' : 'Awaiting break';
        if (gapEl) gapEl.textContent = gap.toFixed(2) + 'L';
        if (heatEl) heatEl.textContent = heat;
        if (liveBoard) {
          liveBoard.innerHTML =
            '<span>TOP THREE</span>' +
            indexed.slice(0, 3).map(function (item, index) {
              return '<b><em>' + (index + 1) + '</em>' + escapeHtml(item.runner.name) + '</b>';
            }).join('') +
            '<strong>' + gap.toFixed(2) + 'L</strong>' +
            '<i>' + escapeHtml(heat) + '</i>';
        }

        indexed.forEach(function (item, index) {
          var runner = item.runner;
          var progress = runner.positions[Math.min(frame, runner.positions.length - 1)] || 0;
          var x = 3 + progress * 0.935;
          var lane = trackStage.querySelector('[data-lane="' + runner.slug + '"]');
          var marker = trackStage.querySelector('[data-runner="' + runner.slug + '"]');
          var fill = trackStage.querySelector('[data-fill="' + runner.slug + '"]');
          var wake = trackStage.querySelector('[data-wake="' + runner.slug + '"]');
          var rank = trackStage.querySelector('[data-rank="' + runner.slug + '"]');
          if (lane) {
            lane.style.setProperty('--progress', progress.toFixed(2) + '%');
            lane.style.setProperty('--rank', index + 1);
            lane.classList.toggle('lane--leader', index === 0);
          }
          if (marker) marker.style.left = x + '%';
          if (fill) fill.style.width = Math.max(0, x - 3) + '%';
          if (wake) wake.style.width = Math.max(0, x - 8) + '%';
          if (rank) rank.textContent = '#' + (index + 1);
        });
      }

      function prepareRace(options) {
        window.clearInterval(state.timer);
        state.racing = false;
        state.frame = 0;
        state.receipt = null;
        if (!options || !options.keepField) state.field = selectField(state.seed);
        state.sim = simulateRace(state.seed, state.trackId, state.field);
        raceLog.innerHTML = '<p>Race desk standing by.</p>';
        setStateLabel('GATES');
        updateUrl();
        renderTrackTabs();
        renderQuickPicks();
        renderDailyBoard();
        renderStableFans();
        renderBadges();
        renderTrack();
        renderField();
        renderReceipt(null);
        renderPodium();
        renderHistory();
        dispatchReceipt(null);
        updatePositions(0);
      }

      function leaderAt(frame) {
        return state.sim.runners
          .slice()
          .sort(function (a, b) {
            return (b.positions[frame] || 0) - (a.positions[frame] || 0);
          })[0];
      }

      function playRace() {
        if (state.racing) return;
        prepareRace({ keepField: true });
        state.racing = true;
        state.frame = 0;
        setStateLabel('LIVE');
        logLine('And they are off at ' + state.sim.track.label + '.');
        state.timer = window.setInterval(function () {
          state.frame += 1;
          updatePositions(state.frame);

          if (state.frame === 25 || state.frame === 58 || state.frame === 92) {
            var leader = leaderAt(state.frame);
            logLine(leader.name + ' leads through frame ' + state.frame + '.');
          }

          if (state.frame >= FRAME_COUNT) {
            window.clearInterval(state.timer);
            state.racing = false;
            awardBadge('first-race');
            awardBadge('receipt-desk');
            if (state.dailyRaceId) awardBadge('daily-runner');
            if (state.sim.order[1] && state.sim.order[1].margin < 0.5) awardBadge('photo-hunter');
            state.receipt = receiptFor(state.sim);
            writeHistory(state.receipt);
            setStateLabel('PHOTO');
            logLine(state.sim.winner.name + ' hits the wire first.');
            state.sim.order.forEach(function (runner) {
              if (runner.trouble) logLine(runner.trouble.note + '.');
            });
            renderReceipt(state.receipt);
            renderPodium();
            renderHistory();
            dispatchReceipt(state.receipt);
          }
        }, 38);
      }

      trackTabs.addEventListener('click', function (event) {
        var button = event.target.closest('[data-track]');
        if (!button || state.racing) return;
        state.trackId = button.getAttribute('data-track');
        state.dailyRaceId = '';
        prepareRace({ keepField: true });
      });

      root.addEventListener('click', function (event) {
        var dailyPick = event.target.closest('[data-daily-race]');
        if (dailyPick && !state.racing) {
          var dailyRace = dailyRaceFor(dailyPick.getAttribute('data-daily-race') || '');
          if (dailyRace) {
            var stable = stableById(dailyRace.featuredStable);
            var featuredHorse = stable ? ROSTER.find(function (horse) {
              var horseStable = stableForHorse(horse);
              return horseStable && horseStable.id === stable.id;
            }) : null;
            state.dailyRaceId = dailyRace.id;
            state.trackId = dailyRace.track;
            state.seed = dailySeed(dailyRace);
            state.focusAgent = featuredHorse ? featuredHorse.slug : '';
            seedInput.value = state.seed;
            prepareRace();
          }
          return;
        }

        var stablePick = event.target.closest('[data-fan-stable]');
        if (stablePick && !state.racing) {
          var stableId = stablePick.getAttribute('data-fan-stable') || '';
          if (stableById(stableId)) {
            fanState.selectedStableId = stableId;
            fanState.stables[stableId] = fanState.stables[stableId] || { support: 0, fanSince: new Date().toISOString() };
            awardBadge('first-fan');
            saveFanState();
            prepareRace({ keepField: true });
          }
          return;
        }

        var stableBack = event.target.closest('[data-fan-back]');
        if (stableBack && !state.racing) {
          var backStableId = stableBack.getAttribute('data-fan-back') || '';
          var amount = Number(stableBack.getAttribute('data-amount') || 50);
          if (stableById(backStableId)) {
            fanState.selectedStableId = backStableId;
            fanState.stables[backStableId] = fanState.stables[backStableId] || { support: 0, fanSince: new Date().toISOString() };
            fanState.stables[backStableId].support = Math.max(0, Number(fanState.stables[backStableId].support || 0) + amount);
            if (fanState.stables[backStableId].support >= 50) awardBadge('stable-backer');
            if (fanState.stables[backStableId].support >= 150) awardBadge('stable-builder');
            awardBadge('first-fan');
            saveFanState();
            prepareRace({ keepField: true });
          }
          return;
        }

        var pick = event.target.closest('[data-quick-agent]');
        if (pick && !state.racing) {
          state.focusAgent = pick.getAttribute('data-quick-agent') || '';
          state.dailyRaceId = '';
          prepareRace();
          return;
        }

        if (fanReset && event.target === fanReset && !state.racing) {
          fanState = defaultFanState();
          writeJson(FAN_STORAGE_KEY, fanState);
          prepareRace({ keepField: true });
          return;
        }

        var action = event.target.closest('[data-action]');
        if (!action) return;
        var name = action.getAttribute('data-action');

        if (name === 'run') playRace();
        if (name === 'quick-run' && !state.racing) {
          state.dailyRaceId = '';
          state.seed = 'race-' + Date.now().toString(36).slice(-7);
          seedInput.value = state.seed;
          prepareRace();
          playRace();
        }
        if (name === 'reset' && !state.racing) prepareRace({ keepField: true });
        if (name === 'new-field' && !state.racing) {
          state.focusAgent = '';
          state.dailyRaceId = '';
          state.seed = 'race-' + Date.now().toString(36).slice(-7);
          seedInput.value = state.seed;
          prepareRace();
        }
        if (name === 'copy') {
          var receipt = state.receipt || receiptFor(state.sim);
          navigator.clipboard?.writeText(JSON.stringify(receipt, null, 2));
          logLine('Receipt copied for ' + receipt.raceId + '.');
        }
      });

      seedInput.addEventListener('change', function () {
        if (state.racing) return;
        state.seed = seedInput.value.trim() || 'gamgee-rc0';
        state.dailyRaceId = '';
        seedInput.value = state.seed;
        prepareRace();
      });

      prepareRace();
    })();
  </script>

  <script>
    import {
      derbyChainConfig,
      prepareDerbyChainPacket,
      recordDerbyReceiptOnChain,
      signDerbyReceipt,
    } from '../lib/agent-derby-chain';

    const root = document.querySelector('[data-agent-derby]');
    const statusEl = root?.querySelector('[data-chain-status]');
    const networkEl = root?.querySelector('[data-chain-network]');
    const contractEl = root?.querySelector('[data-chain-contract]');
    const hashEl = root?.querySelector('[data-chain-hash]');
    const opLink = root?.querySelector('[data-chain-op]') as HTMLAnchorElement | null;
    const recordButton = root?.querySelector('[data-chain-record]') as HTMLButtonElement | null;
    const copyButton = root?.querySelector('[data-chain-copy]') as HTMLButtonElement | null;
    const dataEl = document.getElementById('derby-data');
    const chainConfig = dataEl ? (JSON.parse(dataEl.textContent || '{}').chain ?? {}) : {};

    let currentReceipt: any = null;
    let currentPacket: Awaited<ReturnType<typeof prepareDerbyChainPacket>> | null = null;
    let currentSignature: Awaited<ReturnType<typeof signDerbyReceipt>> | null = null;

    function short(value: string, head = 8, tail = 6) {
      return value.length > head + tail + 1 ? `${value.slice(0, head)}…${value.slice(-tail)}` : value;
    }

    function setText(el: Element | null | undefined, value: string) {
      if (el) el.textContent = value;
    }

    function setOpLink(label: string, href?: string) {
      if (!opLink) return;
      opLink.textContent = label;
      opLink.href = href || '/agent-derby';
      opLink.setAttribute('aria-disabled', href ? 'false' : 'true');
    }

    function renderIdle() {
      const config = derbyChainConfig(chainConfig);
      setText(statusEl, 'Run a race to build a Tezos receipt');
      setText(networkEl, config.network);
      setText(contractEl, config.isLive ? short(config.address) : 'pending KT1');
      setText(hashEl, 'run race first');
      setOpLink('not recorded');
      if (recordButton) {
        recordButton.disabled = true;
        recordButton.textContent = config.isLive ? 'Record on Tezos' : 'Sign with Tezos';
      }
      if (copyButton) copyButton.disabled = true;
    }

    async function renderReceipt(receipt: any) {
      currentReceipt = receipt;
      currentPacket = null;
      currentSignature = null;
      if (!receipt) {
        renderIdle();
        return;
      }

      currentPacket = await prepareDerbyChainPacket(receipt, chainConfig);
      const { config, receiptHash } = currentPacket;
      setText(statusEl, config.isLive ? 'Ready for on-chain record' : 'Ready for Tezos signature');
      setText(networkEl, config.network);
      setText(contractEl, config.isLive ? short(config.address) : 'pending KT1');
      setText(hashEl, short(receiptHash, 10, 8));
      setOpLink(config.isLive ? 'not recorded' : 'not signed');
      if (recordButton) {
        recordButton.disabled = false;
        recordButton.textContent = config.isLive ? 'Record on Tezos' : 'Sign with Tezos';
      }
      if (copyButton) copyButton.disabled = false;
    }

    window.addEventListener('pc:agent-derby-receipt', (event) => {
      void renderReceipt((event as CustomEvent).detail);
    });

    root?.addEventListener('click', async (event) => {
      const action = (event.target as Element | null)?.closest?.('[data-action]');
      if (!action) return;
      const name = action.getAttribute('data-action');

      if (name === 'copy-chain-packet') {
        if (!currentReceipt || !currentPacket) return;
        await navigator.clipboard?.writeText(JSON.stringify({
          receipt: currentReceipt,
          chain: {
            network: currentPacket.config.network,
            contract: currentPacket.config.address || null,
            entrypoint: currentPacket.config.entrypoint,
            receiptHash: currentPacket.receiptHash,
            payload: currentPacket.payload,
            signature: currentSignature ? {
              walletAddress: currentSignature.walletAddress,
              signedAt: currentSignature.signedAt,
              signature: currentSignature.signature,
              signaturePayload: currentSignature.signaturePayload,
            } : null,
          },
        }, null, 2));
        setText(statusEl, 'Chain packet copied');
      }

      if (name === 'record-chain') {
        if (!recordButton || !currentReceipt) return;
        recordButton.disabled = true;
        const config = derbyChainConfig(chainConfig);
        recordButton.textContent = config.isLive ? 'Open wallet...' : 'Open wallet...';
        setText(statusEl, config.isLive ? 'Awaiting Beacon operation' : 'Awaiting Tezos signature');
        try {
          if (config.isLive) {
            const result = await recordDerbyReceiptOnChain(currentReceipt, chainConfig);
            currentPacket = result;
            setText(statusEl, 'Recorded on Tezos');
            setText(hashEl, short(result.receiptHash, 10, 8));
            setText(contractEl, short(result.config.address));
            setOpLink(short(result.opHash, 10, 8), result.explorerUrl);
            recordButton.textContent = 'Recorded';
          } else {
            const result = await signDerbyReceipt(currentReceipt, chainConfig);
            currentPacket = result;
            currentSignature = result;
            setText(statusEl, 'Signed by Tezos wallet');
            setText(hashEl, short(result.receiptHash, 10, 8));
            setText(contractEl, 'pending KT1');
            setOpLink(short(result.signature, 10, 8));
            recordButton.textContent = 'Signed';
          }
        } catch (error: any) {
          const message = String(error?.message || error);
          setText(statusEl, /reject|cancel|abort/i.test(message) ? 'Wallet cancelled' : config.isLive ? 'Record failed' : 'Sign failed');
          recordButton.textContent = config.isLive ? 'Record on Tezos' : 'Sign with Tezos';
          recordButton.disabled = false;
          console.warn('Agent Derby Tezos record failed:', error);
        }
      }
    });

    renderIdle();
  </script>
</BlockLayout>

