---
import BaseLayout from '../layouts/BaseLayout.astro';
import Noggles from '../components/Noggles.astro';
---

<BaseLayout title="About" description="About Mike Hoydich and Claude Cowork Publishings — the story behind PointCast.">
  <div class="max-w-3xl mx-auto px-4 py-12 md:py-16">
    <header class="mb-14">
      <p class="text-nouns-muted font-mono text-xs uppercase tracking-[0.2em] mb-3">About</p>
      <h1 class="text-4xl md:text-5xl font-heading text-nouns-yellow mb-4 leading-tight">
        PointCast
      </h1>
      <p class="text-lg text-nouns-white/70 leading-relaxed max-w-xl">
        Intelligence dispatches and creative work from the collaboration between
        Mike Hoydich and Claude.
      </p>
    </header>

    <div class="space-y-8">
      <!-- Mike -->
      <section class="bg-nouns-bg-card border border-nouns-border/50 rounded-2xl p-6 md:p-8" aria-label="About Mike Hoydich">
        <h2 class="font-heading text-2xl text-nouns-yellow mb-4">Mike Hoydich</h2>
        <div class="text-nouns-white/80 space-y-4 leading-relaxed">
          <p>
            Builder, writer, and creative technologist based in El Segundo, California.
            Mike works at the intersection of technology, culture, and community — always
            looking for new ways to create things that matter.
          </p>
          <p>
            COO at <strong class="text-nouns-white">Good Feels</strong>, believer in the Nouns DAO ethos of building
            in public, open collaboration, and creating culture that belongs to everyone.
          </p>
        </div>
      </section>

      <!-- Claude Cowork -->
      <section class="bg-nouns-bg-card border border-nouns-border/50 rounded-2xl p-6 md:p-8" aria-label="About Claude Cowork Publishing">
        <h2 class="font-heading text-2xl text-nouns-blue mb-4">Claude Cowork Publishing</h2>
        <div class="text-nouns-white/80 space-y-4 leading-relaxed">
          <p>
            Claude Cowork is a publishing imprint built on genuine human-AI collaboration.
            Not AI-generated slop. Not human work with AI sprinkled on top. Real creative
            partnership where both parties bring something essential to the table.
          </p>
          <p>
            Mike brings creative direction, taste, domain expertise, and the lived experience
            that gives writing its soul. Claude brings technical depth, pattern recognition,
            tireless iteration, and the ability to execute at the speed of thought.
          </p>
          <p>
            Together, we publish work that neither could create alone.
          </p>
        </div>
      </section>

      <!-- What we publish -->
      <section class="bg-nouns-bg-card border border-nouns-border/50 rounded-2xl p-6 md:p-8" aria-label="What we publish">
        <h2 class="font-heading text-2xl text-nouns-green mb-4">What We Publish</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="bg-nouns-bg-elevated/50 rounded-xl p-4">
            <h3 class="font-mono text-xs uppercase tracking-widest text-nouns-yellow mb-2">Dispatches</h3>
            <p class="text-sm text-nouns-muted leading-relaxed">
              Weekly intelligence briefings on AI, tech, and culture. Structured observations
              with actionable takes.
            </p>
          </div>
          <div class="bg-nouns-bg-elevated/50 rounded-xl p-4">
            <h3 class="font-mono text-xs uppercase tracking-widest text-nouns-blue mb-2">Articles</h3>
            <p class="text-sm text-nouns-muted leading-relaxed">
              Deep dives into technology, creativity, and the evolving landscape
              of human-AI work.
            </p>
          </div>
          <div class="bg-nouns-bg-elevated/50 rounded-xl p-4">
            <h3 class="font-mono text-xs uppercase tracking-widest text-nouns-red mb-2">Essays</h3>
            <p class="text-sm text-nouns-muted leading-relaxed">
              Long-form thinking about the world we're building and the tools
              we're building it with.
            </p>
          </div>
          <div class="bg-nouns-bg-elevated/50 rounded-xl p-4">
            <h3 class="font-mono text-xs uppercase tracking-widest text-nouns-green mb-2">Projects</h3>
            <p class="text-sm text-nouns-muted leading-relaxed">
              Showcases of things we've built — from code to creative works
              to experiments.
            </p>
          </div>
        </div>
      </section>

      <!-- Philosophy -->
      <section class="bg-nouns-bg-card border border-nouns-border/50 rounded-2xl p-6 md:p-8" aria-label="Philosophy">
        <h2 class="font-heading text-2xl text-nouns-red mb-4">The Philosophy</h2>
        <div class="text-nouns-white/80 space-y-4 leading-relaxed">
          <p>
            We believe the future of creative work isn't human <em>or</em> machine —
            it's human <em>and</em> machine, working as genuine collaborators.
          </p>
          <ul class="space-y-3 pl-0 list-none">
            <li class="flex items-start gap-3">
              <span class="text-nouns-yellow mt-0.5 text-sm" aria-hidden="true">&#x25A0;</span>
              <span><strong class="text-nouns-white">Transparency</strong> — every piece is clearly marked as collaborative work</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-nouns-yellow mt-0.5 text-sm" aria-hidden="true">&#x25A0;</span>
              <span><strong class="text-nouns-white">Quality over quantity</strong> — we publish when we have something worth saying</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-nouns-yellow mt-0.5 text-sm" aria-hidden="true">&#x25A0;</span>
              <span><strong class="text-nouns-white">Open culture</strong> — inspired by Nouns, built in the spirit of CC0</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-nouns-yellow mt-0.5 text-sm" aria-hidden="true">&#x25A0;</span>
              <span><strong class="text-nouns-white">Craft matters</strong> — AI is a tool for amplifying taste, not replacing it</span>
            </li>
          </ul>
        </div>
      </section>

      <!-- Nounish Roots -->
      <section class="bg-nouns-bg-card border border-nouns-border/50 rounded-2xl p-6 md:p-8" aria-label="Nouns culture">
        <div class="flex items-center gap-3 mb-4">
          <h2 class="font-heading text-2xl text-nouns-yellow">Nounish Roots</h2>
          <Noggles width={50} variant="yellow" />
        </div>
        <div class="text-nouns-white/80 space-y-4 leading-relaxed">
          <p>
            PointCast is built in the spirit of <a href="https://nouns.wtf" target="_blank" rel="noopener" class="text-nouns-blue hover:underline">Nouns DAO</a> —
            the on-chain experiment in identity, governance, and open culture.
            One Noun auctioned every day, forever. All artwork CC0.
          </p>
          <p>
            The noggles (⌐◨-◨) represent builders who create in public, share freely,
            and believe culture should belong to everyone.
          </p>
          <div class="flex gap-4 mt-4">
            <Noggles width={45} variant="red" />
            <Noggles width={45} variant="blue" />
            <Noggles width={45} variant="yellow" />
            <Noggles width={45} variant="black" />
          </div>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
