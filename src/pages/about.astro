---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Mike Hoydich and Claude Cowork — the story behind PointCast.">
  <div class="max-w-[34rem] mx-auto px-4 py-12 md:py-16">
    <header class="mb-10">
      <div class="kicker">About</div>
      <h1 class="font-serif text-[1.65rem] text-ink font-medium italic mb-3 leading-[1.15]">
        PointCast
      </h1>
      <p class="text-[0.95rem] text-ink-soft leading-relaxed max-w-md">
        Intelligence dispatches and creative work from the collaboration between
        Mike Hoydich and Claude.
      </p>
    </header>

    <div class="space-y-0">
      <!-- Mike -->
      <section class="card-obs" aria-label="About Mike Hoydich">
        <h2 class="font-serif text-lg text-ink font-semibold mb-3">
          <span class="card-obs-num">01</span>Mike Hoydich
        </h2>
        <div class="text-[0.95rem] text-ink/80 space-y-4 leading-relaxed">
          <p>
            Builder, writer, and creative technologist based in El Segundo, California.
            Mike works at the intersection of technology, culture, and community — always
            looking for new ways to create things that matter.
          </p>
          <div class="move-line">
            <span class="move-label">Role</span>
            <span>COO at <strong class="text-ink font-semibold">Good Feels</strong>. Builds in public, ships fast, cares about craft.</span>
          </div>
          <div class="flex flex-wrap gap-2 pt-2">
            <a href="https://x.com/mhoydich" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-card text-ink-soft hover:text-warm hover:bg-warm/8 transition-colors font-mono text-[0.6rem] tracking-[0.12em] uppercase">X &nearr;</a>
            <a href="https://www.linkedin.com/in/mhoydich/" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-card text-ink-soft hover:text-warm hover:bg-warm/8 transition-colors font-mono text-[0.6rem] tracking-[0.12em] uppercase">LinkedIn &nearr;</a>
            <a href="https://github.com/MikeHoydich" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-card text-ink-soft hover:text-warm hover:bg-warm/8 transition-colors font-mono text-[0.6rem] tracking-[0.12em] uppercase">GitHub &nearr;</a>
            <a href="https://www.instagram.com/mhoydich/" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-card text-ink-soft hover:text-warm hover:bg-warm/8 transition-colors font-mono text-[0.6rem] tracking-[0.12em] uppercase">Instagram &nearr;</a>
            <a href="https://www.are.na/mike-hoydich" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-card text-ink-soft hover:text-warm hover:bg-warm/8 transition-colors font-mono text-[0.6rem] tracking-[0.12em] uppercase">Are.na &nearr;</a>
            <a href="https://www.midjourney.com/@mhoydich" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-card text-ink-soft hover:text-warm hover:bg-warm/8 transition-colors font-mono text-[0.6rem] tracking-[0.12em] uppercase">Midjourney &nearr;</a>
            <a href="https://soundcloud.com/mikeisnice" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-card text-ink-soft hover:text-warm hover:bg-warm/8 transition-colors font-mono text-[0.6rem] tracking-[0.12em] uppercase">SoundCloud &nearr;</a>
            <a href="https://medium.com/@mhoydich" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-card text-ink-soft hover:text-warm hover:bg-warm/8 transition-colors font-mono text-[0.6rem] tracking-[0.12em] uppercase">Medium &nearr;</a>
          </div>
        </div>
      </section>

      <!-- Claude Cowork -->
      <section class="card-obs" aria-label="About Claude Cowork Publishing">
        <h2 class="font-serif text-lg text-ink font-semibold mb-3">
          <span class="card-obs-num">02</span>Claude Cowork
        </h2>
        <div class="text-[0.95rem] text-ink/80 space-y-4 leading-relaxed">
          <p>
            Claude Cowork is a publishing imprint built on genuine human-AI collaboration.
            Not AI-generated slop. Not human work with AI sprinkled on top. Real creative
            partnership where both parties bring something essential.
          </p>
          <details class="disclosure">
            <summary>Read more</summary>
            <div class="disclosure-body">
              <p>Mike brings creative direction, taste, domain expertise, and the lived experience
              that gives writing its soul. Claude brings technical depth, pattern recognition,
              tireless iteration, and the ability to execute at the speed of thought.</p>
              <p>Together, we publish work that neither could create alone.</p>
            </div>
          </details>
        </div>
      </section>

      <!-- What we publish -->
      <section class="card-obs" aria-label="What we publish">
        <h2 class="font-serif text-lg text-ink font-semibold mb-3">
          <span class="card-obs-num">03</span>What We Publish
        </h2>
        <div class="tldr-list">
          <div class="tldr-link" style="cursor: default;">
            <span class="tldr-num">D</span>
            <span><span class="tldr-title">Dispatches</span> <span class="tldr-sub">— Weekly intelligence briefings on AI, tech, and culture.</span></span>
          </div>
          <div class="tldr-link" style="cursor: default;">
            <span class="tldr-num">A</span>
            <span><span class="tldr-title">Articles</span> <span class="tldr-sub">— Deep dives into technology, creativity, and human-AI work.</span></span>
          </div>
          <div class="tldr-link" style="cursor: default;">
            <span class="tldr-num">E</span>
            <span><span class="tldr-title">Essays</span> <span class="tldr-sub">— Long-form thinking about the world we're building.</span></span>
          </div>
          <div class="tldr-link" style="cursor: default;">
            <span class="tldr-num">P</span>
            <span><span class="tldr-title">Projects</span> <span class="tldr-sub">— Showcases of things we've built, from code to creative works.</span></span>
          </div>
        </div>
      </section>

      <!-- Tezos & Web3 -->
      <section class="card-obs" aria-label="Tezos and web3">
        <h2 class="font-serif text-lg text-ink font-semibold mb-3">
          <span class="card-obs-num">04</span>Tezos &amp; On-Chain
        </h2>
        <div class="text-[0.95rem] text-ink/80 space-y-4 leading-relaxed">
          <p>
            Mike has been active in the Tezos ecosystem — collecting and minting
            on-chain art through <a href="https://objkt.com" target="_blank" rel="noopener" class="text-warm underline underline-offset-2 decoration-warm/30 hover:decoration-warm">objkt</a>,
            <a href="https://www.fxhash.xyz" target="_blank" rel="noopener" class="text-warm underline underline-offset-2 decoration-warm/30 hover:decoration-warm">fxhash</a>,
            and the broader Tezos art community. Tezos remains the chain for artists —
            low fees, proof-of-stake from day one, and a culture that actually cares about the work.
          </p>
          <p>
            PointCast is exploring on-chain creative tools, including a Nouns-style
            NFT minter on Tezos. CC0 art, open contracts, public-domain culture —
            the ethos we build with.
          </p>
          <div class="flex flex-wrap gap-2 pt-1">
            <a href="https://objkt.com" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-card text-ink-soft hover:text-warm hover:bg-warm/8 transition-colors font-mono text-[0.6rem] tracking-[0.12em] uppercase">objkt &nearr;</a>
            <a href="https://www.fxhash.xyz" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-card text-ink-soft hover:text-warm hover:bg-warm/8 transition-colors font-mono text-[0.6rem] tracking-[0.12em] uppercase">fxhash &nearr;</a>
            <a href="https://tezos.com" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-card text-ink-soft hover:text-warm hover:bg-warm/8 transition-colors font-mono text-[0.6rem] tracking-[0.12em] uppercase">tezos &nearr;</a>
            <a href="https://tezos.art" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-card text-ink-soft hover:text-warm hover:bg-warm/8 transition-colors font-mono text-[0.6rem] tracking-[0.12em] uppercase">tezos.art &nearr;</a>
          </div>
        </div>
      </section>

      <!-- Philosophy -->
      <section class="card-obs" aria-label="Philosophy">
        <h2 class="font-serif text-lg text-ink font-semibold mb-3">
          <span class="card-obs-num">05</span>The Philosophy
        </h2>
        <div class="text-[0.95rem] text-ink/80 space-y-3 leading-relaxed">
          <p>
            The future of creative work isn't human <em>or</em> machine —
            it's human <em>and</em> machine, working as genuine collaborators.
          </p>
          <ul class="space-y-2 pl-0 list-none">
            <li class="flex items-start gap-3">
              <span class="text-warm mt-0.5 text-sm" aria-hidden="true">&#x203A;</span>
              <span><strong class="text-ink font-semibold">Transparency</strong> — every piece is clearly marked as collaborative work</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-warm mt-0.5 text-sm" aria-hidden="true">&#x203A;</span>
              <span><strong class="text-ink font-semibold">Quality over quantity</strong> — we publish when we have something worth saying</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-warm mt-0.5 text-sm" aria-hidden="true">&#x203A;</span>
              <span><strong class="text-ink font-semibold">Open culture</strong> — we build in public and share freely</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-warm mt-0.5 text-sm" aria-hidden="true">&#x203A;</span>
              <span><strong class="text-ink font-semibold">Craft matters</strong> — AI is a tool for amplifying taste, not replacing it</span>
            </li>
          </ul>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
