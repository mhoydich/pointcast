---
/**
 * /local — the 100-mile lens. Anchored on El Segundo. Per Mike
 * 2026-04-19 morning directive (see block 0282): "think local, 100
 * mile radius". This is the human-facing surface; it also feeds the
 * eventual /tv STATIONS mode (flip between geo-stations on the big
 * screen).
 *
 * v0 structure:
 *   - At-a-glance: date, El Segundo anchor, quick orient.
 *   - Name-drops: the ES institutions from block 0276 (Mike's verbatim list).
 *   - Stations: cities within 100 miles, placeholder links for now —
 *     the station pages get authored when blocks accumulate there.
 *   - In-range blocks: filter by meta.location, sorted by recency.
 *   - Adjacent surfaces: /beacon (25-mile neighborhood), /poll/es-name-drops.
 *
 * v0 is static. v1 may add: geolocation API → "you are N miles from ES",
 * IP-based fallback, per-station dynamic feeds.
 */
import { getCollection } from 'astro:content';
import BlockLayout from '../layouts/BlockLayout.astro';
import { CHANNELS } from '../lib/channels';
import {
  NAME_DROPS,
  NATURE_NOTES,
  STATIONS,
  RADIUS_METERS,
  ANCHOR,
  filterInRangeBlocks,
  filterBlocksForStation,
  getStationPath,
} from '../lib/local';

const blocks = (await getCollection('blocks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

// NAME_DROPS, STATIONS, and the SoCal-token in-range filter live in
// src/lib/local.ts so /local.json can share the same source of truth.
const inRangeBlocks = filterInRangeBlocks(blocks);
const stations = [...STATIONS]
  .sort((a, b) => a.miles - b.miles)
  .map((station) => ({
    station,
    blockCount: filterBlocksForStation(blocks, station).length,
  }));

const today = new Intl.DateTimeFormat('en-US', {
  weekday: 'long', month: 'long', day: 'numeric', year: 'numeric',
  timeZone: 'America/Los_Angeles',
}).format(new Date());

const title = 'Local · 100 miles from El Segundo';
const description = 'PointCast\'s 100-mile lens. Anchored on El Segundo. Name-drops, stations, in-range blocks, adjacent surfaces. The local register of the site — and the data layer for /tv STATIONS mode.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  '@id': 'https://pointcast.xyz/local',
  name: 'PointCast · Local (100mi)',
  description,
  url: 'https://pointcast.xyz/local',
  containedInPlace: {
    '@type': 'City',
    name: 'El Segundo',
    containedInPlace: { '@type': 'AdministrativeArea', name: 'Los Angeles County, California' },
  },
  geo: {
    '@type': 'GeoCircle',
    geoMidpoint: { '@type': 'GeoCoordinates', latitude: ANCHOR.coords.latitude, longitude: ANCHOR.coords.longitude },
    geoRadius: RADIUS_METERS,
  },
};
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">← All blocks</a>
      <span aria-hidden="true">/</span>
      <span>local</span>
    </nav>

    <header class="masthead">
      <p class="masthead__kicker mono">LOCAL · 100 MILES FROM EL SEGUNDO</p>
      <h1 class="masthead__title">Local · <em>the 100-mile lens</em></h1>
      <p class="masthead__date mono">{today}</p>
      <p class="masthead__lede">
        PointCast anchors on El Segundo. This page is the tonal register for
        everything within a hundred miles — from the next town over to Santa
        Barbara north, Palm Springs east, North San Diego County south.
        Place is not a filter; it's a <em>register</em>, same as mood.
      </p>
    </header>

    <section class="section" aria-label="Name drops — El Segundo institutions">
      <div class="section__head">
        <h2 class="section__kicker mono">NAME DROPS · EL SEGUNDO</h2>
        <a class="section__all" href="/poll/es-name-drops">vote on the first one →</a>
      </div>
      <p class="section__lede">
        The shortlist of places that do most of the work of signaling you
        know the town. From Mike's <a href="/b/0276">verbatim list</a>.
      </p>
      <ul class="drops">
        {NAME_DROPS.map((d) => (
          <li class="drops__item">
            <span class="drops__name">{d.name}</span>
            <span class="drops__kind mono">{d.kind}</span>
            <span class="drops__one">{d.one}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="section nature-module" id="nature" aria-label="Nature — El Segundo flora and dune signals">
      <div class="section__head">
        <h2 class="section__kicker mono">NATURE · DUNE SIGNALS</h2>
        <a class="section__all" href="/nature">open field guide →</a>
      </div>
      <p class="section__lede">
        El Segundo's nature register is coastal-dune, airport-edge, marine-layer
        smallness: buckwheat, sand, scrub, and the butterfly that makes the
        town name literal.
      </p>
      <div class="nature-grid">
        {NATURE_NOTES.map((note) => (
          <article class={`nature-card nature-card--${note.kind}`}>
            <div class="nature-card__top">
              <span class="nature-card__kind mono">{note.kind}</span>
              <span class="nature-card__season mono">{note.season}</span>
            </div>
            <h3 class="nature-card__name">{note.name}</h3>
            {note.scientific && <p class="nature-card__latin">{note.scientific}</p>}
            <p class="nature-card__signal">{note.signal}</p>
            <p class="nature-card__read">{note.localRead}</p>
            <a class="nature-card__source mono" href={note.sourceUrl} target="_blank" rel="noopener">
              {note.sourceLabel} ↗
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="section" aria-label="Stations — nearby cities">
      <div class="section__head">
        <h2 class="section__kicker mono">STATIONS · {STATIONS.length} IN RANGE</h2>
        <span class="section__sub mono">sorted by distance</span>
      </div>
      <p class="section__lede">
        The <a href="/tv">/tv</a> mode flips between stations like
        broadcast channels — pick a city, you get its block feed, weather,
        events, and in-range drops.
      </p>
      <ul class="stations">
        {stations.map(({ station, blockCount }) => (
          <li class="stations__item">
            <div class="stations__lead">
              <span class="stations__dir mono">{station.direction}</span>
              <span class="stations__name">{station.name}</span>
              <span class="stations__miles mono">{station.miles}<span class="stations__unit">mi</span></span>
            </div>
            <p class="stations__blurb">{station.blurb}</p>
            <div class="stations__foot">
              <span class="stations__count mono">
                {blockCount > 0 ? `${blockCount} block${blockCount === 1 ? '' : 's'} in range` : 'no blocks yet'}
              </span>
              <a class="stations__cast mono" href={getStationPath(station)}>cast this station →</a>
            </div>
          </li>
        ))}
      </ul>
    </section>

    {inRangeBlocks.length > 0 && (
      <section class="section" aria-label={`Blocks in range — ${inRangeBlocks.length} items`}>
        <div class="section__head">
          <h2 class="section__kicker mono">IN-RANGE BLOCKS · {inRangeBlocks.length}</h2>
          <a class="section__all" href="/archive">all blocks →</a>
        </div>
        <p class="section__lede">
          Every block with a location tag that resolves inside the radius.
          This list grows whenever a new block carries a <code>meta.location</code>
          in SoCal.
        </p>
        <ul class="blocks">
          {inRangeBlocks.map((b) => {
            const ch = CHANNELS[b.data.channel];
            return (
              <li class="blocks__item">
                <a class="blocks__link" href={`/b/${b.data.id}`}>
                  <span class="blocks__meta mono">
                    <span class="blocks__id">№{b.data.id}</span>
                    <span class="blocks__sep" aria-hidden="true">·</span>
                    <span class="blocks__ch" style={`color: ${ch.color800}`}>CH.{ch.code}</span>
                    <span class="blocks__sep" aria-hidden="true">·</span>
                    <span class="blocks__loc">{b.data.meta?.location}</span>
                  </span>
                  <span class="blocks__title">{b.data.title}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    <section class="section section--adjacent" aria-label="Adjacent surfaces">
      <h2 class="section__kicker mono">ADJACENT · GO DEEPER</h2>
      <ul class="adjacent">
        <li><a href="/beacon"><strong>/beacon</strong> — 25-mile neighborhood map</a></li>
        <li><a href="/nature"><strong>/nature</strong> — El Segundo local flora field guide</a></li>
        <li><a href="/b/0254"><strong>/b/0254</strong> — why the 25-mile radius is the right shape</a></li>
        <li><a href="/b/0330"><strong>/b/0330</strong> — El Segundo local flora and dune signals</a></li>
        <li><a href="/b/0276"><strong>/b/0276</strong> — the El Segundo name-drops editorial</a></li>
        <li><a href="/poll/es-name-drops"><strong>/poll/es-name-drops</strong> — which to name-drop first</a></li>
        <li><a href="/tv"><strong>/tv</strong> — broadcast mode (STATIONS mode arriving soon)</a></li>
        <li><a href="https://shop.getgoodfeels.com" target="_blank" rel="noopener"><strong>Good Feels shop ↗</strong> — in-range distribution</a></li>
      </ul>
    </section>

    <aside class="agent-strip">
      <p class="agent-strip__label">MACHINE-READABLE</p>
      <ul>
        <li><a href="/local.json">/local.json</a></li>
        <li><a href="/blocks.json">/blocks.json</a></li>
        <li><a href="/for-agents">/for-agents</a></li>
      </ul>
    </aside>

  </div>
</BlockLayout>

<style>
  .page {
    max-width: 980px;
    margin: 0 auto;
    padding: 20px 20px 80px;
  }

  .breadcrumb {
    display: flex;
    gap: 8px;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin-bottom: 20px;
  }
  .breadcrumb a { color: var(--pc-accent); }

  .masthead {
    padding-bottom: 18px;
    border-bottom: 1.5px solid var(--pc-ink);
    margin-bottom: 28px;
  }
  .masthead__kicker {
    margin: 0 0 6px;
    font-size: 10px;
    letter-spacing: 0.16em;
    color: #8a2432;
    font-weight: 600;
  }
  .masthead__title {
    margin: 0 0 6px;
    font-family: var(--pc-font-heading, var(--pc-font-serif));
    font-size: 36px;
    font-weight: 500;
    color: #12110E;
    letter-spacing: -0.01em;
  }
  .masthead__title em { font-style: italic; color: #8a2432; }
  .masthead__date {
    margin: 0 0 14px;
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--pc-ink-soft);
  }
  .masthead__lede {
    margin: 0;
    max-width: 62ch;
    font-size: 15px;
    line-height: 1.55;
    color: #2a2925;
  }
  .masthead__lede em { font-style: italic; color: #8a2432; }

  .section { margin: 32px 0; }
  .section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .section__kicker {
    margin: 0 0 8px;
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--pc-ink-soft);
    font-weight: 700;
  }
  .section__sub {
    font-size: 10px;
    color: var(--pc-ink-muted);
    letter-spacing: 0.12em;
  }
  .section__all {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--pc-accent);
  }
  .section__lede {
    margin: 0 0 14px;
    max-width: 62ch;
    font-size: 14px;
    line-height: 1.5;
    color: #2a2925;
  }
  .section__lede a {
    color: var(--pc-accent);
    text-decoration: underline;
    text-decoration-color: rgba(138, 36, 50, 0.3);
  }
  .section__lede code {
    font-family: var(--pc-font-mono);
    background: #f4f2ec;
    padding: 1px 5px;
    border-radius: 2px;
    font-size: 12px;
  }

  /* ── NAME DROPS ──────────────────────────────────────────────── */
  .drops {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 10px;
  }
  .drops__item {
    padding: 12px 14px;
    border: 1px solid #d6d4cd;
    border-left: 3px solid #8a2432;
    border-radius: 2px;
    background: #fafaf7;
    display: grid;
    gap: 4px;
  }
  .drops__name {
    font-size: 16px;
    font-weight: 600;
    color: #12110E;
  }
  .drops__kind {
    font-size: 9px;
    letter-spacing: 0.18em;
    color: #8a2432;
    text-transform: uppercase;
    font-weight: 700;
  }
  .drops__one {
    font-size: 13px;
    line-height: 1.45;
    color: var(--pc-ink-soft);
  }

  /* ── NATURE MODULE ───────────────────────────────────────────── */
  .nature-module {
    padding: 18px 0 22px;
    border-top: 1.5px solid #0F6E56;
    border-bottom: 1px dashed #9ab8a8;
  }
  .nature-module .section__kicker {
    color: #074638;
  }
  .nature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 10px;
  }
  .nature-card {
    display: grid;
    gap: 7px;
    padding: 13px 14px;
    background: #f9fbf7;
    border: 1px solid #cfd8c9;
    border-left: 4px solid #0F6E56;
    border-radius: 2px;
  }
  .nature-card--pollinator { border-left-color: #534AB7; background: #f8f7fc; }
  .nature-card--habitat { border-left-color: #BA7517; background: #fffaf1; }
  .nature-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .nature-card__kind,
  .nature-card__season,
  .nature-card__source {
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .nature-card__kind {
    color: #074638;
    font-weight: 700;
  }
  .nature-card--pollinator .nature-card__kind { color: #332C7C; }
  .nature-card--habitat .nature-card__kind { color: #834F0A; }
  .nature-card__season {
    color: var(--pc-ink-muted);
    text-align: right;
  }
  .nature-card__name {
    margin: 0;
    font-size: 17px;
    line-height: 1.15;
    color: #12110E;
  }
  .nature-card__latin {
    margin: -3px 0 0;
    font-family: Georgia, 'Iowan Old Style', serif;
    font-style: italic;
    font-size: 13px;
    color: #4e4b45;
  }
  .nature-card__signal,
  .nature-card__read {
    margin: 0;
    font-size: 13px;
    line-height: 1.45;
    color: #2a2925;
  }
  .nature-card__read {
    color: var(--pc-ink-soft);
  }
  .nature-card__source {
    align-self: end;
    color: var(--pc-accent);
    font-weight: 700;
    margin-top: 2px;
  }

  /* ── STATIONS ────────────────────────────────────────────────── */
  .stations {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 8px;
  }
  .stations__item {
    padding: 10px 12px;
    border: 1px solid #d6d4cd;
    border-radius: 2px;
    background: #fff;
    display: grid;
    gap: 4px;
    transition: border-color 0.12s, background 0.12s;
  }
  .stations__item:hover {
    border-color: #534AB7;
    background: #f6f5fc;
  }
  .stations__lead {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .stations__dir {
    flex-shrink: 0;
    width: 24px;
    padding: 2px 4px;
    text-align: center;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    background: #edecf6;
    color: #534AB7;
    border-radius: 2px;
  }
  .stations__name {
    font-size: 15px;
    font-weight: 600;
    color: #12110E;
    flex: 1;
  }
  .stations__miles {
    font-size: 12px;
    font-weight: 700;
    color: #534AB7;
    font-variant-numeric: tabular-nums;
  }
  .stations__unit {
    font-size: 9px;
    font-weight: 500;
    color: var(--pc-ink-soft);
    margin-left: 1px;
    letter-spacing: 0.06em;
  }
  .stations__blurb {
    margin: 0;
    font-size: 12px;
    line-height: 1.4;
    color: var(--pc-ink-soft);
  }
  .stations__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .stations__count {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
  }
  .stations__cast {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #8a2432;
    font-weight: 700;
  }

  /* ── IN-RANGE BLOCKS ─────────────────────────────────────────── */
  .blocks {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    gap: 4px;
  }
  .blocks__link {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    padding: 8px 10px;
    border-radius: 2px;
    color: #12110E;
    text-decoration: none;
    transition: background 0.1s;
  }
  .blocks__link:hover {
    background: #fef5e7;
    text-decoration: none;
  }
  .blocks__meta {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--pc-ink-muted);
    white-space: nowrap;
    text-transform: uppercase;
  }
  .blocks__id { font-weight: 700; color: var(--pc-ink-soft); }
  .blocks__sep { opacity: 0.4; }
  .blocks__ch { font-weight: 600; }
  .blocks__loc { color: var(--pc-ink-muted); font-weight: 500; }
  .blocks__title {
    font-size: 14px;
    color: #12110E;
    line-height: 1.3;
  }

  /* ── ADJACENT ────────────────────────────────────────────────── */
  .adjacent {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    gap: 6px;
  }
  .adjacent li { padding: 0; }
  .adjacent a {
    display: inline-block;
    padding: 4px 0;
    color: var(--pc-ink-soft);
    font-size: 14px;
    line-height: 1.4;
  }
  .adjacent a strong {
    color: var(--pc-accent);
    font-family: var(--pc-font-mono);
    font-size: 12px;
    font-weight: 700;
    margin-right: 3px;
  }

  /* ── AGENT STRIP ─────────────────────────────────────────────── */
  .agent-strip {
    margin-top: 48px;
    padding-top: 16px;
    border-top: 1px solid var(--pc-rule, #d6d4cd);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pc-ink-soft);
  }
  .agent-strip__label { margin: 0 0 6px; font-weight: 600; }
  .agent-strip ul {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .agent-strip a { color: var(--pc-accent); }

  .mono { font-family: var(--pc-font-mono); }

  @media (max-width: 560px) {
    .masthead__title { font-size: 28px; }
    .section__head { flex-direction: column; gap: 4px; align-items: flex-start; }
    .stations__lead { flex-wrap: wrap; }
  }
</style>
