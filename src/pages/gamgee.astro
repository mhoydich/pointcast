---
/**
 * /gamgee — the Gamgee release front door.
 *
 * Opened 2026-04-23 as part of Gamgee RC0. Three-audience explainer
 * (humans, agents, builders) that names the release, states the thesis,
 * and points each visitor to the surface that fits them.
 *
 * This page is intentionally short. The canonical release doc lives at
 * docs/releases/gamgee.md in the repo; the inventory at
 * docs/releases/gamgee-inventory.md; the sprint checklist at
 * docs/sprints/2026-04-23-gamgee-rc0.md. This page summarizes the release
 * and sends each audience to their door.
 *
 * Gamgee codename: from Samwise Gamgee — loyal, rooted, carries the story
 * through the hard parts. Pairs with /sitting-with-gandalf.
 *
 * Future releases use the same page pattern under /{codename}.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import { getCollection } from 'astro:content';
import { CHANNEL_LIST } from '../lib/channels';

const blocks = await getCollection('blocks', ({ data }) => !data.draft);
const totalBlocks = blocks.length;
const channels = CHANNEL_LIST.length;

const title = 'Gamgee — the consolidation release';
const description =
  'Gamgee is the release where PointCast stops reading as a brilliant lab pile and starts reading as a named, navigable system. Agent-native broadcast: human pages, machine surfaces, and a visible multi-agent build ledger.';
const canonical = 'https://pointcast.xyz/gamgee';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': canonical,
  name: title,
  description,
  url: canonical,
  inLanguage: 'en-US',
  isPartOf: {
    '@type': 'WebSite',
    '@id': 'https://pointcast.xyz/#website',
    name: 'PointCast',
    url: 'https://pointcast.xyz/',
  },
  mainEntity: {
    '@type': 'CreativeWork',
    name: 'Gamgee',
    alternateName: 'PointCast Gamgee',
    creator: [
      { '@type': 'Person', name: 'Mike Hoydich', url: 'https://pointcast.xyz/' },
      { '@type': 'SoftwareApplication', name: 'Claude Code', url: 'https://claude.com/claude-code' },
      { '@type': 'SoftwareApplication', name: 'Codex' },
      { '@type': 'SoftwareApplication', name: 'Manus' },
    ],
    datePublished: '2026-04-23',
    about: 'Agent-native broadcast release for pointcast.xyz',
  },
};
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="gg">
    <nav class="gg__crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>gamgee</span>
    </nav>

    <header class="gg__hero">
      <p class="gg__kicker mono">RELEASE · GAMGEE · RC0 · 2026-04-23</p>
      <h1 class="gg__title">The release that makes the agents real.</h1>
      <p class="gg__thesis">
        PointCast is an <strong>agent-native broadcast system</strong>: human
        pages, machine-readable surfaces, and a visible multi-agent build
        ledger sharing the same source of truth.
      </p>
      <p class="gg__dek">
        Gamgee is not a new-feature sprint. It is a consolidation release —
        the one where PointCast stops reading as a brilliant lab pile and
        starts reading as a named, navigable system. Codename after Samwise
        Gamgee: loyal, rooted, carries the story through the hard parts.
      </p>
      <ul class="gg__stats mono">
        <li><span class="num">{totalBlocks}</span><span class="lbl">BLOCKS</span></li>
        <li><span class="num">{channels}</span><span class="lbl">CHANNELS</span></li>
        <li><span class="num">4</span><span class="lbl">AGENTS</span></li>
        <li><span class="num">RC0</span><span class="lbl">STATUS</span></li>
      </ul>
    </header>

    <section class="gg__audiences" aria-label="Three audiences">
      <article class="door door--humans">
        <header class="door__head">
          <p class="door__kicker mono">FOR HUMANS</p>
          <h2 class="door__title">What can I click?</h2>
        </header>
        <p class="door__dek">
          A living broadcast from El Segundo. Read blocks, tune a channel, drop
          into a moment. Nothing here asks you to sign up.
        </p>
        <ul class="door__links">
          <li><a href="/"><code>/</code></a> — the feed</li>
          <li><a href="/manifesto"><code>/manifesto</code></a> — what PointCast is</li>
          <li><a href="/today"><code>/today</code></a> — one block for today</li>
          <li><a href="/sparrow"><code>/sparrow</code></a> — the hosted reader</li>
          <li><a href="/tonight"><code>/tonight</code></a> — el segundo, after dark</li>
          <li><a href="/tv"><code>/tv</code></a> — broadcast mode</li>
          <li><a href="/here"><code>/here</code></a> — who's online right now</li>
        </ul>
      </article>

      <article class="door door--agents">
        <header class="door__head">
          <p class="door__kicker mono">FOR AGENTS</p>
          <h2 class="door__title">What should I fetch?</h2>
        </header>
        <p class="door__dek">
          Every surface has a JSON twin. Start with the discovery manifest,
          then crawl by channel or block. Cite the permalink.
        </p>
        <ul class="door__links">
          <li><a href="/agents.json"><code>/agents.json</code></a> — discovery manifest</li>
          <li><a href="/for-agents"><code>/for-agents</code></a> — human-readable manifest</li>
          <li><a href="/llms.txt"><code>/llms.txt</code></a> · <a href="/llms-full.txt"><code>/llms-full.txt</code></a> — LLM guide</li>
          <li><a href="/feed.json"><code>/feed.json</code></a> · <a href="/feed.xml"><code>/feed.xml</code></a> — unified feed</li>
          <li><code>/b/{'{id}'}.json</code> — one block, canonical</li>
          <li><code>/c/{'{channel}'}.json</code> — channel as JSON Feed v1.1</li>
          <li><a href="/now.json"><code>/now.json</code></a> — live snapshot</li>
        </ul>
      </article>

      <article class="door door--builders">
        <header class="door__head">
          <p class="door__kicker mono">FOR BUILDERS</p>
          <h2 class="door__title">What can I steal?</h2>
        </header>
        <p class="door__dek">
          Patterns tested in production on a small site running a
          multi-agent build loop. Everything here is inspectable, forkable,
          repeatable.
        </p>
        <ul class="door__links">
          <li><a href="/magpie"><code>/magpie</code></a> — native capture + fan-out peer-node</li>
          <li><a href="/sparrow"><code>/sparrow</code></a> — hosted reader, Nostr federation</li>
          <li><a href="/mesh"><code>/mesh</code></a> — the three-mesh map</li>
          <li><a href="/collabs"><code>/collabs</code></a> — who builds here, how to plug in</li>
          <li><a href="/stack"><code>/stack</code></a> — the tech stack, structured</li>
          <li><a href="/status"><code>/status</code></a> — live agent activity</li>
          <li><a href="https://github.com/mhoydich/pointcast" target="_blank" rel="noopener">github.com/mhoydich/pointcast</a> — the repo</li>
        </ul>
      </article>
    </section>

    <section class="gg__scope">
      <h2 class="gg__h2">What's in Gamgee RC0</h2>
      <div class="scope__grid">
        <div class="scope__col scope__col--in">
          <h3 class="scope__lbl mono">IN RC0</h3>
          <ul>
            <li>Agent loop real: issue → <code>@claude</code> → PR → Codex review → Manus log → merge</li>
            <li>Release train inventoried and split (<a href="https://github.com/mhoydich/pointcast/blob/main/docs/releases/gamgee-inventory.md" target="_blank" rel="noopener">see inventory</a>)</li>
            <li>Canonical story: this page + <code>docs/releases/gamgee.md</code></li>
            <li>Public front door: <code>/gamgee</code></li>
            <li>Agent surfaces: <code>/agents.json</code>, <code>/for-agents</code>, <code>/llms.txt</code> aligned</li>
            <li>Health pass: <code>npm run build:bare</code>, <code>audit:agents</code>, <code>audit:publishing</code></li>
          </ul>
        </div>
        <div class="scope__col scope__col--later">
          <h3 class="scope__lbl mono">LATER (RC1 / Gamgee 1.1+)</h3>
          <ul>
            <li>Public launch: Show HN draft, X/Farcaster threads, screenshots</li>
            <li>Homepage path tightening</li>
            <li>Sparrow federation (v0.2–0.35, Nostr, Magpie bridge, digest worker)</li>
            <li>New public page families (<code>/bath</code>, <code>/compute</code>, <code>/lab</code>, <code>/analytics</code>, <code>/lotto</code>, <code>/passport</code>, et al.)</li>
            <li>Voice Dispatch (<code>/talk</code>, <code>/listen</code>) — audio-first layer</li>
            <li>Race system — the competitive event layer</li>
            <li>Tezos contracts depth (Prize Cast, compute lotto, passport stamps)</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="gg__loop">
      <h2 class="gg__h2">The agent loop</h2>
      <p class="gg__p">
        Four agents, one source of truth. The repo is the work ledger. Every
        handoff is a file, an issue, or a PR — no ephemeral chat, no parallel
        trackers. When it works, it looks like this:
      </p>
      <ol class="gg__loopsteps">
        <li><strong>Mike</strong> files an issue using <a href="https://github.com/mhoydich/pointcast/blob/main/.github/ISSUE_TEMPLATE/agent-handoff.yml" target="_blank" rel="noopener">the handoff template</a></li>
        <li><strong>Claude Code</strong> responds via GitHub Actions (<code>@claude</code> trigger), reads <code>CLAUDE.md</code> + <code>AGENTS.md</code>, opens a small PR</li>
        <li><strong>Codex</strong> reviews, keeps release hygiene, shapes the train</li>
        <li><strong>Manus</strong> handles browser / ops / QA, logs to <code>docs/manus-logs/</code></li>
        <li><strong>Mike</strong> approves + merges. Release tagged when the loop closes cleanly</li>
      </ol>
      <p class="gg__p gg__p--small">
        Architecture at <a href="https://github.com/mhoydich/pointcast/blob/main/docs/setup/agent-bridge.md" target="_blank" rel="noopener"><code>docs/setup/agent-bridge.md</code></a>.
        Operating manual at <a href="https://github.com/mhoydich/pointcast/blob/main/CLAUDE.md" target="_blank" rel="noopener"><code>CLAUDE.md</code></a>.
      </p>
    </section>

    <section class="gg__credits">
      <h2 class="gg__h2">Credits</h2>
      <p class="gg__p">
        <strong>Mike Hoydich</strong> — product, voice, final call ·
        <strong>Claude Code</strong> (Opus 4.7, 1M context) — core platform,
        editorial, docs ·
        <strong>Codex</strong> (GPT-5.5 Spud / Extra High) — prototypes,
        review, release hygiene ·
        <strong>Manus</strong> — browser / ops / real-user QA
      </p>
      <p class="gg__p gg__p--small">
        El Segundo, California · Thursday 2026-04-23 · CC0 on everything
        editorial unless marked otherwise · Code AGPL unless marked MIT in
        <code>package.json</code>.
      </p>
    </section>

    <footer class="gg__foot mono">
      <div class="foot__row">
        <a href="https://github.com/mhoydich/pointcast/blob/main/docs/releases/gamgee.md" target="_blank" rel="noopener">release doc →</a>
        <a href="https://github.com/mhoydich/pointcast/blob/main/docs/releases/gamgee-inventory.md" target="_blank" rel="noopener">inventory →</a>
        <a href="https://github.com/mhoydich/pointcast/blob/main/docs/sprints/2026-04-23-gamgee-rc0.md" target="_blank" rel="noopener">sprint →</a>
        <a href="https://github.com/mhoydich/pointcast" target="_blank" rel="noopener">github →</a>
      </div>
    </footer>
  </main>
</BlockLayout>

<style>
  .gg {
    max-width: 880px;
    margin: 0 auto;
    padding: 24px 20px 80px;
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    color: #121116;
  }
  .mono { font-family: 'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, monospace; }
  .gg__crumb {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #5f5e5a;
    margin-bottom: 22px;
  }
  .gg__crumb a { color: inherit; text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 1px; }
  .gg__crumb span { margin: 0 6px; }

  .gg__hero { padding-bottom: 28px; border-bottom: 2px solid #1a1a22; margin-bottom: 32px; }
  .gg__kicker {
    font-size: 10.5px;
    letter-spacing: 0.24em;
    font-weight: 700;
    margin: 0 0 10px;
    color: #8a2432;
  }
  .gg__title {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: clamp(28px, 4.5vw, 44px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 18px;
    color: #121116;
  }
  .gg__thesis {
    font-family: Georgia, serif;
    font-size: 18px;
    line-height: 1.5;
    margin: 0 0 14px;
    color: #1a1a22;
  }
  .gg__thesis strong { font-weight: 700; }
  .gg__dek {
    font-family: Georgia, serif;
    font-size: 15px;
    line-height: 1.55;
    color: #38373a;
    margin: 0 0 20px;
    max-width: 68ch;
  }
  .gg__stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }
  .gg__stats li { display: flex; flex-direction: column; }
  .gg__stats .num {
    font-size: 22px;
    font-weight: 700;
    color: #8a2432;
    line-height: 1;
  }
  .gg__stats .lbl {
    font-size: 9.5px;
    letter-spacing: 0.16em;
    color: #5f5e5a;
    margin-top: 3px;
  }

  .gg__audiences {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin: 0 0 40px;
  }
  @media (max-width: 760px) {
    .gg__audiences { grid-template-columns: 1fr; }
  }

  .door {
    border: 1px solid #e5e3de;
    border-top: 4px solid #121116;
    border-radius: 2px;
    padding: 18px 18px 18px;
    background: #fffdfa;
    display: flex;
    flex-direction: column;
  }
  .door--humans   { border-top-color: #2f8f5f; }
  .door--agents   { border-top-color: #185fa5; }
  .door--builders { border-top-color: #e89a2d; }
  .door__head { margin-bottom: 10px; padding-bottom: 8px; border-bottom: 1px dashed #e5e3de; }
  .door__kicker {
    font-size: 10.5px;
    letter-spacing: 0.22em;
    color: #121116;
    font-weight: 700;
    margin: 0 0 6px;
  }
  .door__title {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: 20px;
    line-height: 1.2;
    margin: 0;
    font-weight: 400;
  }
  .door__dek {
    font-family: Georgia, serif;
    font-size: 13.5px;
    line-height: 1.5;
    color: #38373a;
    margin: 0 0 12px;
  }
  .door__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex: 1;
    font-family: Georgia, serif;
    font-size: 13px;
    color: #121116;
  }
  .door__links code {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11.5px;
    background: rgba(18, 17, 22, 0.06);
    padding: 1px 5px;
    border-radius: 2px;
  }
  .door__links a { color: #8a2432; text-decoration: none; border-bottom: 1px solid transparent; }
  .door__links a:hover { border-bottom-color: #8a2432; }

  .gg__h2 {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: 26px;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 0 0 16px;
    color: #121116;
  }
  .gg__p {
    font-family: Georgia, serif;
    font-size: 15px;
    line-height: 1.6;
    color: #38373a;
    margin: 0 0 12px;
    max-width: 68ch;
  }
  .gg__p--small { font-size: 13px; color: #5f5e5a; }
  .gg__p code { font-family: 'JetBrains Mono Variable', ui-monospace, monospace; font-size: 13px; background: rgba(18,17,22,0.06); padding: 1px 5px; border-radius: 2px; }
  .gg__p a { color: #8a2432; }

  .gg__scope { margin: 0 0 40px; padding-bottom: 28px; border-bottom: 1px solid #e5e3de; }
  .scope__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
  }
  @media (max-width: 760px) { .scope__grid { grid-template-columns: 1fr; } }
  .scope__col { }
  .scope__lbl {
    font-size: 10.5px;
    letter-spacing: 0.2em;
    font-weight: 700;
    margin: 0 0 10px;
    color: #121116;
  }
  .scope__col--in .scope__lbl { color: #2f8f5f; }
  .scope__col--later .scope__lbl { color: #5f5e5a; }
  .scope__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .scope__col li {
    font-family: Georgia, serif;
    font-size: 13.5px;
    line-height: 1.5;
    padding-left: 14px;
    position: relative;
    color: #1a1a22;
  }
  .scope__col li::before {
    content: "·";
    position: absolute;
    left: 4px;
    color: #8a2432;
    font-weight: 700;
  }
  .scope__col code { font-family: 'JetBrains Mono Variable', ui-monospace, monospace; font-size: 12.5px; background: rgba(18,17,22,0.06); padding: 1px 5px; border-radius: 2px; }
  .scope__col a { color: #8a2432; }

  .gg__loop { margin: 0 0 40px; padding-bottom: 28px; border-bottom: 1px solid #e5e3de; }
  .gg__loopsteps {
    list-style: decimal;
    padding-left: 20px;
    margin: 10px 0 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: 72ch;
  }
  .gg__loopsteps li {
    font-family: Georgia, serif;
    font-size: 14.5px;
    line-height: 1.55;
    color: #1a1a22;
  }
  .gg__loopsteps li code { font-family: 'JetBrains Mono Variable', ui-monospace, monospace; font-size: 12.5px; background: rgba(18,17,22,0.06); padding: 1px 5px; border-radius: 2px; }

  .gg__credits { margin: 0 0 32px; padding-bottom: 28px; border-bottom: 1px solid #e5e3de; }

  .gg__foot {
    font-size: 11px;
    letter-spacing: 0.14em;
    color: #5f5e5a;
  }
  .foot__row { display: flex; flex-wrap: wrap; gap: 18px; }
  .foot__row a { color: #8a2432; text-decoration: underline; text-underline-offset: 3px; }
</style>
