---
/**
 * /gamgee - public release anchor for the Gamgee RC0 train.
 *
 * This page is intentionally release-scoped. It makes the current PointCast
 * direction legible without claiming the evergreen /agent-native slug.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const title = 'Gamgee';
const description = 'Gamgee is the PointCast RC0 release train: a human front door, stable agent surfaces, and a visible builder loop for Claude, Codex, and Manus.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://pointcast.xyz/gamgee',
  name: 'PointCast Gamgee',
  description,
  url: 'https://pointcast.xyz/gamgee',
  datePublished: '2026-04-23',
  inLanguage: 'en-US',
  about: [
    'PointCast',
    'agent-native publishing',
    'human and machine-readable feeds',
    'multi-agent release coordination',
  ],
};

const lanes = [
  {
    label: 'Humans',
    title: 'Know what PointCast is in one screen.',
    body: 'Start with the live home, then use /now for the current state: latest blocks, today signals, and active system surfaces.',
    href: '/now',
    cta: 'Open /now',
  },
  {
    label: 'Agents',
    title: 'Read the site without guessing.',
    body: 'Use the manifest, LLM maps, feeds, and JSON endpoints. Gamgee keeps the first machine path stable while the product grows.',
    href: '/for-agents',
    cta: 'Open /for-agents',
  },
  {
    label: 'Builders',
    title: 'Ship in small, reviewable slices.',
    body: 'Claude shapes release plans, Codex lands patches, and Manus runs browser QA. Dirty train work stays inventoried until it earns a clean PR.',
    href: '/sprints',
    cta: 'Open /sprints',
  },
];

const gates = [
  'Homepage first viewport names PointCast, Gamgee, the human path, and the agent path.',
  'Agent surfaces stay stable: /for-agents, /agents.json, /llms.txt, /feed.json, and /feed.xml.',
  'Release work lands through focused PRs instead of importing the dirty sprint branch wholesale.',
  'Manus browser QA records public evidence before larger release cuts.',
];
---

<BlockLayout
  title={title}
  description={description}
  jsonLd={jsonLd}
  frame={{
    image: 'https://pointcast.xyz/images/og/og-home-v2.png',
    buttons: [
      { label: 'Open /now', action: 'link', target: 'https://pointcast.xyz/now' },
      { label: '/for-agents', action: 'link', target: 'https://pointcast.xyz/for-agents' },
      { label: '/agents.json', action: 'link', target: 'https://pointcast.xyz/agents.json' },
      { label: '/sprints', action: 'link', target: 'https://pointcast.xyz/sprints' },
    ],
  }}
>
  <div class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>gamgee</span>
    </nav>

    <header class="hero">
      <p class="kicker">Release train · RC0 · Apr 23, 2026</p>
      <h1>Gamgee</h1>
      <p class="dek">
        The first clean release candidate for PointCast as an agent-native
        broadcast: one front door for people, one stable map for machines, and
        one visible loop for the systems helping build it.
      </p>
      <div class="hero__actions" aria-label="Primary Gamgee paths">
        <a href="/now">Human path: /now</a>
        <a href="/for-agents">Agent path: /for-agents</a>
        <a href="/agents.json">Machine path: /agents.json</a>
      </div>
    </header>

    <section class="lanes" aria-label="Gamgee audiences">
      {lanes.map((lane) => (
        <article class="lane">
          <p class="lane__label">{lane.label}</p>
          <h2>{lane.title}</h2>
          <p>{lane.body}</p>
          <a href={lane.href}>{lane.cta}</a>
        </article>
      ))}
    </section>

    <section class="release-grid" aria-label="Gamgee release controls">
      <div class="release-copy">
        <p class="kicker">What Gamgee locks</p>
        <h2>Small enough to ship. Clear enough to inspect.</h2>
        <p>
          Gamgee is not the whole PointCast backlog. It is the release layer
          that makes the current site understandable before the larger sprint
          train arrives.
        </p>
      </div>
      <ol class="gates">
        {gates.map((gate) => <li>{gate}</li>)}
      </ol>
    </section>
  </div>
</BlockLayout>

<style>
  .page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 20px 20px 84px;
  }

  .crumb {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 18px;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
  }

  .crumb a {
    color: var(--pc-accent);
  }

  .hero {
    min-width: 0;
    padding: 30px 0 34px;
    border-top: 1.5px solid var(--pc-ink);
    border-bottom: 1.5px solid var(--pc-ink);
  }

  .kicker {
    margin: 0 0 10px;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-accent);
  }

  h1 {
    margin: 0;
    font-size: 72px;
    line-height: 0.92;
    letter-spacing: 0;
    font-weight: 500;
    color: var(--pc-ink);
  }

  .dek {
    max-width: 820px;
    margin: 16px 0 0;
    font-size: 18px;
    line-height: 1.5;
    color: var(--pc-ink-soft);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .hero__actions a {
    border: 1px solid var(--pc-ink);
    padding: 8px 10px;
    background: #fff7d6;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pc-ink);
  }

  .hero__actions a:hover {
    background: #f4f8fb;
    text-decoration: none;
  }

  .lanes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    min-width: 0;
    border-bottom: 1.5px solid var(--pc-ink);
  }

  .lane {
    min-width: 0;
    padding: 18px 18px 20px 0;
    border-right: 1px solid var(--pc-rule);
  }

  .lane + .lane {
    padding-left: 18px;
  }

  .lane:last-child {
    border-right: 0;
  }

  .lane__label {
    margin: 0 0 10px;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
  }

  .lane h2,
  .release-copy h2 {
    margin: 0;
    font-size: 24px;
    line-height: 1.08;
    letter-spacing: 0;
    font-weight: 500;
    color: var(--pc-ink);
  }

  .lane p:not(.lane__label),
  .release-copy p:not(.kicker) {
    margin: 12px 0 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--pc-ink-soft);
  }

  .lane a {
    display: inline-block;
    margin-top: 14px;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pc-accent);
  }

  .release-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 26px;
    min-width: 0;
    padding: 24px 0 0;
  }

  .gates {
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: gate;
    border-top: 1px solid var(--pc-rule);
  }

  .gates li {
    counter-increment: gate;
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--pc-rule);
    font-size: 14px;
    line-height: 1.45;
    color: var(--pc-ink-soft);
  }

  .gates li::before {
    content: counter(gate, decimal-leading-zero);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--pc-accent);
  }

  @media (max-width: 820px) {
    .lanes,
    .release-grid {
      grid-template-columns: 1fr;
    }

    .lane,
    .lane + .lane {
      padding: 16px 0 18px;
      border-right: 0;
      border-bottom: 1px solid var(--pc-rule);
    }

    .lane:last-child {
      border-bottom: 0;
    }
  }

  @media (max-width: 639px) {
    .page {
      padding: 16px 16px 72px;
    }

    .hero {
      padding: 24px 0 28px;
    }

    .hero,
    .lanes,
    .release-grid {
      width: calc(100vw - 32px);
      max-width: calc(100vw - 32px);
      overflow: hidden;
    }

    .hero > *,
    .lane > *,
    .release-copy,
    .gates {
      width: min(100%, 350px);
      max-width: 100%;
    }

    h1 {
      max-width: 100%;
      font-size: 48px;
      line-height: 0.96;
      overflow-wrap: anywhere;
    }

    .dek {
      max-width: 100%;
      font-size: 16px;
      overflow-wrap: anywhere;
    }

    .hero__actions a {
      width: 100%;
      max-width: 100%;
      overflow-wrap: anywhere;
    }

    .lane h2,
    .lane p,
    .release-copy h2,
    .release-copy p,
    .gates li {
      max-width: 100%;
      overflow-wrap: anywhere;
    }
  }
</style>
