---
/**
 * /quiz — daily PointCast-lore quiz.
 *
 * Mike 2026-04-20 23:39 UTC ping: "like /compute, great tho we have no
 * visitors thus things like drum, collecting, fun, information, learning
 * are to be important if we want people to participate."
 *
 * One question a day, four choices, a playful + factual "why" on reveal.
 * Streak persists locally. No server. Matches the /cards + /drum/click
 * pattern: visitor-facing fun, repeatable, zero infrastructure.
 *
 * Codex sprint project 3: MCP timed out twice on this brief; cc ships
 * directly per brief fallback rule. Codex shipped the hash script + the
 * oauth-authorization-server stub earlier tonight (2-for-4).
 *
 * Author: cc. Source: Mike 2026-04-20 23:39 UTC ping;
 * brief at docs/briefs/2026-04-20-codex-sprint-next.md #3.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import questions from '../content/quiz/questions.json';

const now = new Date();
const ptDateFormatter = new Intl.DateTimeFormat('en-CA', {
  timeZone: 'America/Los_Angeles',
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
const todayISO = ptDateFormatter.format(now);

function seedFromDateKey(dateKey: string): number {
  return Number(dateKey.replace(/-/g, '')) || 0;
}

// Pick today's question using the PointCast PT date as the seed.
// Same question all PT day; different tomorrow.
function pickToday(pool: Array<Record<string, unknown>>, dateKey: string): Record<string, unknown> {
  const n = pool.length;
  if (n === 0) return {};
  let s = (seedFromDateKey(dateKey) * 2654435761) >>> 0;
  s = (s * 1664525 + 1013904223) >>> 0;
  return pool[s % n];
}

const today = pickToday(questions as Array<Record<string, unknown>>, todayISO);
const prettyToday = new Intl.DateTimeFormat('en-US', {
  weekday: 'long', month: 'long', day: 'numeric',
  timeZone: 'America/Los_Angeles',
}).format(now);

const title = 'Quiz — one a day, four choices, streaks persist';
const description = "A daily PointCast trivia question. Tap an answer, learn the explanation, come back tomorrow for #N+1. Local state, no signup, no leaderboard.";
---

<BlockLayout title={title} description={description}>
  <main class="quiz-page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>quiz</span>
    </nav>

    <header class="head">
      <p class="kicker mono">
        QUIZ · <span id="streak-label">DAY #1 · STREAK 0</span>
      </p>
      <h1 class="title">Today's question.</h1>
      <p class="dek mono">{prettyToday} · {todayISO}</p>
    </header>

    <section class="question" data-question-id={today.id} data-correct={String(today.correct)}>
      <p class={`topic-chip mono topic-chip--${today.topic}`}>{String(today.topic).toUpperCase()}</p>
      <p class="q-text">{today.q}</p>
      <ul class="choices">
        {(today.choices as string[]).map((c, i) => (
          <li>
            <button type="button" class="choice mono" data-index={String(i)}>
              <span class="choice__letter">{String.fromCharCode(65 + i)}</span>
              <span class="choice__text">{c}</span>
            </button>
          </li>
        ))}
      </ul>
      <div class="reveal" id="reveal" hidden>
        <p class="reveal__headline mono" id="reveal-headline">—</p>
        <p class="reveal__why">{today.why}</p>
      </div>
    </section>

    <section class="streak" id="streak-section">
      <p class="section__kicker mono">YOUR STREAK</p>
      <div class="streak__row">
        <p class="streak__stat">
          <span class="streak__num mono" id="streak-current">0</span>
          <span class="streak__lbl mono">CURRENT</span>
        </p>
        <p class="streak__stat">
          <span class="streak__num mono" id="streak-best">0</span>
          <span class="streak__lbl mono">BEST-EVER</span>
        </p>
        <p class="streak__stat">
          <span class="streak__num mono" id="streak-total">0</span>
          <span class="streak__lbl mono">ANSWERED</span>
        </p>
      </div>
      <p class="streak__note mono" id="streak-note">come back tomorrow for another one.</p>
    </section>

    <section class="log">
      <p class="section__kicker mono">PREVIOUS DAYS</p>
      <ol class="log__list" id="log-list">
        <li class="log__empty mono">your answered-days log is empty. solve today's to start.</li>
      </ol>
    </section>

    <p class="foot mono">
      answers live in <code>pc:quiz:answers</code> · streak in <code>pc:quiz:streak</code> · source pool: <a href="https://github.com/MikeHoydich/pointcast/blob/main/src/content/quiz/questions.json">src/content/quiz/questions.json</a> · this is a local game, no server.
    </p>
  </main>
</BlockLayout>

<script is:inline>
(function () {
  'use strict';

  var LS_ANSWERS = 'pc:quiz:answers';
  var LS_STREAK = 'pc:quiz:streak';
  var LS_BEST = 'pc:quiz:best';

  function todayPT() {
    try {
      return new Intl.DateTimeFormat('en-CA', {
        timeZone: 'America/Los_Angeles',
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
      }).format(new Date());
    } catch (e) {
      return new Date().toISOString().slice(0, 10);
    }
  }

  function previousDateKey(dateKey) {
    var bits = dateKey.split('-').map(function (part) { return parseInt(part, 10); });
    if (bits.length !== 3 || !bits[0] || !bits[1] || !bits[2]) return dateKey;
    var d = new Date(Date.UTC(bits[0], bits[1] - 1, bits[2], 12));
    d.setUTCDate(d.getUTCDate() - 1);
    return d.toISOString().slice(0, 10);
  }

  var TODAY_ISO = todayPT();

  function loadAnswers() {
    try { var r = JSON.parse(localStorage.getItem(LS_ANSWERS) || '{}'); return r && typeof r === 'object' ? r : {}; } catch (e) { return {}; }
  }
  function saveAnswers(a) { try { localStorage.setItem(LS_ANSWERS, JSON.stringify(a)); } catch (e) {} }
  function getInt(key, dflt) {
    try { var n = parseInt(localStorage.getItem(key) || '', 10); return isFinite(n) ? n : dflt; } catch (e) { return dflt; }
  }
  function setInt(key, n) { try { localStorage.setItem(key, String(n)); } catch (e) {} }

  function computeStreak(answers) {
    // Consecutive PT days, ending today if answered or yesterday if not.
    var streak = 0;
    var ymd = answers[TODAY_ISO] ? TODAY_ISO : previousDateKey(TODAY_ISO);
    while (true) {
      var a = answers[ymd];
      if (!a || !a.correct) break;
      streak++;
      ymd = previousDateKey(ymd);
    }
    return streak;
  }

  function paintStreak(answers) {
    var cur = computeStreak(answers);
    var best = Math.max(getInt(LS_BEST, 0), cur);
    setInt(LS_BEST, best);
    setInt(LS_STREAK, cur);
    var total = Object.keys(answers).length;
    var curEl = document.getElementById('streak-current');
    var bestEl = document.getElementById('streak-best');
    var totalEl = document.getElementById('streak-total');
    if (curEl) curEl.textContent = String(cur);
    if (bestEl) bestEl.textContent = String(best);
    if (totalEl) totalEl.textContent = String(total);
    var label = document.getElementById('streak-label');
    if (label) label.textContent = 'DAY #' + (total + 1) + ' · STREAK ' + cur;
  }

  function paintLog(answers) {
    var list = document.getElementById('log-list');
    if (!list) return;
    var keys = Object.keys(answers).sort(function (a, b) { return a < b ? 1 : -1; }); // desc
    if (keys.length === 0) return;
    list.innerHTML = '';
    keys.forEach(function (ymd) {
      var a = answers[ymd];
      var li = document.createElement('li');
      li.className = 'log__row log__row--' + (a.correct ? 'ok' : 'wrong');
      var mark = a.correct ? '✓' : '✗';
      li.innerHTML =
        '<span class="log__mark mono">' + mark + '</span>' +
        '<span class="log__date mono">' + ymd + '</span>' +
        '<span class="log__qid mono">' + (a.qId || '') + '</span>';
      list.appendChild(li);
    });
  }

  function init() {
    var section = document.querySelector('.question');
    if (!section) return;
    var correct = parseInt(section.getAttribute('data-correct') || '0', 10);
    var qId = section.getAttribute('data-question-id') || '';

    var answers = loadAnswers();
    var prior = answers[TODAY_ISO];

    // If already answered today, lock + show reveal with the prior choice.
    function lock(chosenIdx) {
      var buttons = section.querySelectorAll('.choice');
      Array.prototype.forEach.call(buttons, function (b) {
        var i = parseInt(b.getAttribute('data-index') || '-1', 10);
        b.disabled = true;
        if (i === correct) b.classList.add('choice--correct');
        else if (i === chosenIdx) b.classList.add('choice--wrong');
      });
      var reveal = document.getElementById('reveal');
      var headline = document.getElementById('reveal-headline');
      if (reveal) reveal.hidden = false;
      if (headline) headline.textContent = chosenIdx === correct ? '✓ RIGHT' : '✗ WRONG — correct was ' + String.fromCharCode(65 + correct);
    }

    if (prior && typeof prior.choice === 'number') {
      lock(prior.choice);
    } else {
      var buttons = section.querySelectorAll('.choice');
      Array.prototype.forEach.call(buttons, function (b) {
        b.addEventListener('click', function () {
          var i = parseInt(b.getAttribute('data-index') || '-1', 10);
          var right = i === correct;
          answers[TODAY_ISO] = { qId: qId, choice: i, correct: right };
          saveAnswers(answers);
          lock(i);
          paintStreak(answers);
          paintLog(answers);
        });
      });
    }

    paintStreak(answers);
    paintLog(answers);
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

<style>
  .quiz-page { max-width: 820px; margin: 0 auto; padding: 24px 20px 80px; color: var(--pc-ink, #12110E); }
  .mono { font-family: var(--pc-font-mono, 'JetBrains Mono Variable', monospace); }

  .crumb { font-family: var(--pc-font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; color: var(--pc-ink-muted, #5F5E5A); }
  .crumb a { color: inherit; text-decoration: none; border-bottom: 1px solid currentColor; }
  .crumb a:hover { color: #E89A2D; }
  .crumb span[aria-hidden] { margin: 0 6px; opacity: 0.5; }

  .head { margin: 10px 0 22px; padding-bottom: 18px; border-bottom: 1px solid var(--pc-rule-soft, #E5E3DE); }
  .kicker { font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: #E89A2D; margin: 0 0 10px; font-weight: 600; }
  .title { font-family: var(--pc-font-sans, 'Inter Variable', system-ui); font-size: clamp(30px, 4.5vw, 44px); font-weight: 500; margin: 0 0 8px; letter-spacing: -0.01em; line-height: 1.1; }
  .dek { font-size: 11px; letter-spacing: 0.08em; color: var(--pc-ink-muted); margin: 0; text-transform: uppercase; }

  .topic-chip {
    display: inline-block;
    font-size: 9.5px;
    letter-spacing: 0.16em;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 2px;
    color: #fff;
    margin: 0 0 14px;
  }
  .topic-chip--pointcast         { background: #E89A2D; }
  .topic-chip--tezos             { background: #5F3DC4; }
  .topic-chip--nouns             { background: #C92A2A; }
  .topic-chip--el-segundo        { background: #185FA5; }
  .topic-chip--drum              { background: #2f8f5f; }
  .topic-chip--federated-compute { background: #8a2432; }
  .topic-chip--codex             { background: #38373A; }

  .question { margin: 0 0 32px; padding: 0; }
  .q-text { font-family: var(--pc-font-sans, 'Inter Variable', system-ui); font-size: clamp(18px, 2.8vw, 22px); line-height: 1.45; margin: 0 0 18px; color: var(--pc-ink); }

  .choices { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .choice {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--pc-rule, #d6d4cd);
    border-radius: 3px;
    background: #fff;
    cursor: pointer;
    text-align: left;
    transition: background 0.12s, border-color 0.12s, transform 0.08s;
  }
  .choice:hover:not(:disabled) { border-color: #E89A2D; background: rgba(232, 154, 45, 0.04); }
  .choice:active:not(:disabled) { transform: translateY(1px); }
  .choice:disabled { cursor: default; }
  .choice__letter { font-weight: 700; color: #E89A2D; font-size: 14px; min-width: 18px; flex-shrink: 0; }
  .choice__text { font-family: var(--pc-font-sans, 'Inter Variable', system-ui); font-size: 15px; line-height: 1.4; color: var(--pc-ink); text-transform: none; letter-spacing: 0; }
  .choice--correct { background: rgba(47, 143, 95, 0.12); border-color: #2f8f5f; }
  .choice--correct .choice__letter { color: #2f8f5f; }
  .choice--wrong { background: rgba(201, 42, 42, 0.1); border-color: #C92A2A; }
  .choice--wrong .choice__letter { color: #C92A2A; }

  .reveal {
    margin: 16px 0 0;
    padding: 14px 16px;
    background: #fbfaf5;
    border-left: 3px solid #E89A2D;
    border-radius: 2px;
  }
  .reveal__headline { font-size: 11px; letter-spacing: 0.14em; margin: 0 0 8px; color: #E89A2D; }
  .reveal__why { font-family: var(--pc-font-sans, 'Inter Variable', system-ui); font-size: 14.5px; line-height: 1.55; margin: 0; color: var(--pc-ink-soft, #38373A); }

  .section__kicker { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--pc-ink-muted); margin: 28px 0 10px; padding-bottom: 6px; border-bottom: 1px dotted var(--pc-rule-soft, #E5E3DE); }

  .streak__row { display: flex; gap: 28px; flex-wrap: wrap; padding: 10px 0 6px; }
  .streak__stat { display: flex; flex-direction: column; gap: 2px; margin: 0; }
  .streak__num { font-size: 26px; font-weight: 600; color: #E89A2D; font-variant-numeric: tabular-nums; line-height: 1; }
  .streak__lbl { font-size: 9px; letter-spacing: 0.16em; color: var(--pc-ink-muted); text-transform: uppercase; }
  .streak__note { font-size: 11px; letter-spacing: 0.06em; color: var(--pc-ink-muted); text-transform: none; margin: 8px 0 0; }

  .log__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
  .log__row {
    display: grid;
    grid-template-columns: 20px 100px 1fr;
    gap: 10px;
    padding: 6px 0;
    border-bottom: 1px dotted var(--pc-rule-soft, #E5E3DE);
    font-size: 12px;
    align-items: baseline;
  }
  .log__mark { font-weight: 700; font-size: 13px; }
  .log__row--ok .log__mark { color: #2f8f5f; }
  .log__row--wrong .log__mark { color: #C92A2A; }
  .log__date { color: var(--pc-ink-muted); font-size: 10.5px; letter-spacing: 0.04em; }
  .log__qid { color: var(--pc-ink-soft); font-size: 10.5px; letter-spacing: 0.06em; }
  .log__empty { color: var(--pc-ink-muted); font-style: italic; padding: 8px 0; font-size: 12px; text-transform: none; letter-spacing: 0; }

  .foot { margin: 30px 0 0; font-size: 10.5px; color: var(--pc-ink-muted); line-height: 1.55; text-transform: none; letter-spacing: 0; }
  .foot code { font-family: var(--pc-font-mono); background: rgba(0, 0, 0, 0.05); padding: 1px 5px; border-radius: 2px; }
  .foot a { color: #E89A2D; text-decoration: underline; }
</style>
