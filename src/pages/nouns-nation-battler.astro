---
/**
 * /nouns-nation-battler - 30v30 automated Nouns gang battler.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Nouns Nation Battler',
  description: 'A browser-playable 30v30 automated Nouns league battler with numbered rosters, scout cards, sim controls, live unit stats, a two-week season, Nouns Bowl final, gang brand kits, rooting stats, Director Mode TV, Amplifier Rift, Crown Rush, and weird terrain battle types, a 20-poster Nouns series, and official Nouns SVG parts.',
  url: 'https://pointcast.xyz/nouns-nation-battler',
  gamePlatform: 'Web browser',
  genre: 'Auto battler',
  inLanguage: 'en-US',
};
---

<BlockLayout
  title="Nouns Nation Battler"
  description="Watch 30 vs 30 automated Nouns gangs play a two-week league into a Nouns Bowl final with numbered rosters, scout cards, sim controls, live unit stats, generated brand kits, rooting stats, Director Mode TV, Amplifier Rift, Crown Rush, Lava Audit, Cloud Court, Trash Planet, Fog Bowl, a 20-poster Nouns series, and official Nouns SVG parts."
  image="/images/og/battle.png"
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/nouns-nation-battler.json', title: 'Nouns Nation Battler manifest (JSON)' }]}
  frame={{
    image: 'https://pointcast.xyz/images/og/battle.png',
    buttons: [
        { label: 'Watch match', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler' },
      { label: 'Game JSON', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler.json' },
      { label: 'TV Cast', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-tv' },
      { label: 'Battle channel', action: 'link', target: 'https://pointcast.xyz/c/btl' },
    ],
  }}
>
  <main class="nation-page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/c/btl">CH.BTL</a>
      <span aria-hidden="true">/</span>
      <span>Nouns Nation Battler</span>
    </nav>

    <section class="intro">
      <p class="kicker">CH.BTL / AUTO-BATTLER V11 DIRECTOR FIELDS</p>
      <h1>Nouns Nation Battler</h1>
      <p>
        Thirty official Nouns sprites per side, eight rotating gangs, a two-week table, playoff bracket,
        Nouns Bowl final, numbered players, scout cards, quick sim controls, live unit stat leaders,
        persistent rooting records, role specials, center control, Amplifier Rift matches with elemental lanes, Crown Rush matches with a contested center crown,
        Lava Audit, Cloud Court, Trash Planet, Fog Bowl, a live battle log, a 20-piece type-heavy poster series, and a dedicated Director Mode TV cast with camera cues, replay bay, Market Pulse, MVP Watch, and Comeback Line cards.
      </p>
      <div class="manifest-row">
        <a href="/games/nouns-nation-battler/index.html" target="_blank" rel="noreferrer">Open full screen</a>
        <a href="/nouns-nation-battler-tv" target="_blank" rel="noreferrer">TV Cast</a>
        <a href="/nouns-nation-battler-posters">Poster Series</a>
        <a href="/nouns-nation-battler.json">Manifest JSON</a>
        <a href="/games/nouns-nation-battler/assets/manifest.json">Sprite manifest</a>
        <a href="https://github.com/mhoydich/pointcast/blob/main/docs/prd/nouns-nation-battler-league.md" target="_blank" rel="noreferrer">League PRD</a>
      </div>
    </section>

    <section class="game-frame" aria-label="Nouns Nation Battler playable frame">
      <iframe src="/games/nouns-nation-battler/index.html" title="Nouns Nation Battler game" loading="eager"></iframe>
    </section>
  </main>
</BlockLayout>

<style>
  .nation-page {
    display: grid;
    gap: 18px;
  }

  .crumb,
  .manifest-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .crumb {
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--muted, #6c6254);
  }

  .intro {
    max-width: 880px;
  }

  .kicker {
    margin: 0 0 8px;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 8px;
    font-size: clamp(2.6rem, 8vw, 6rem);
    line-height: 0.9;
    letter-spacing: 0;
  }

  .intro p {
    margin: 0;
    max-width: 780px;
    font-size: clamp(1rem, 2vw, 1.28rem);
    line-height: 1.45;
  }

  .manifest-row {
    margin-top: 16px;
  }

  .manifest-row a {
    border: 2px solid currentColor;
    padding: 8px 10px;
    font-weight: 900;
    text-decoration: none;
  }

  .game-frame {
    min-height: 740px;
    border: 3px solid currentColor;
    background: #f2eddc;
  }

  .game-frame iframe {
    display: block;
    width: 100%;
    height: min(860px, 92vh);
    min-height: 740px;
    border: 0;
  }

  @media (max-width: 760px) {
    .game-frame,
    .game-frame iframe {
      min-height: 880px;
    }
  }
</style>
