---
/**
 * /nouns-nation-battler - 30v30 automated Nouns gang battler.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Nouns Nation Battler',
  description: 'A browser-playable 30v30 automated Nouns open-field battler with advanced moves, gang brand kits, rooting stats, and official Nouns SVG parts.',
  url: 'https://pointcast.xyz/nouns-nation-battler',
  gamePlatform: 'Web browser',
  genre: 'Auto battler',
  inLanguage: 'en-US',
};
---

<BlockLayout
  title="Nouns Nation Battler"
  description="Watch 30 vs 30 automated Nouns gangs battle on an open field with advanced moves, generated brand kits, rooting stats, and official Nouns SVG parts."
  image="/images/og/battle.png"
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/nouns-nation-battler.json', title: 'Nouns Nation Battler manifest (JSON)' }]}
  frame={{
    image: 'https://pointcast.xyz/images/og/battle.png',
    buttons: [
        { label: 'Watch match', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler' },
      { label: 'Game JSON', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler.json' },
      { label: 'Battle channel', action: 'link', target: 'https://pointcast.xyz/c/btl' },
      { label: 'Home feed', action: 'link', target: 'https://pointcast.xyz/' },
    ],
  }}
>
  <main class="nation-page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/c/btl">CH.BTL</a>
      <span aria-hidden="true">/</span>
      <span>Nouns Nation Battler</span>
    </nav>

    <section class="intro">
      <p class="kicker">CH.BTL / AUTO-BATTLER V3</p>
      <h1>Nouns Nation Battler</h1>
      <p>
        Thirty official Nouns sprites per side, automated tactics, rotating gangs, generated brand kits,
        persistent rooting records, role specials, center control, and a live battle log.
      </p>
      <div class="manifest-row">
        <a href="/games/nouns-nation-battler/index.html" target="_blank" rel="noreferrer">Open full screen</a>
        <a href="/nouns-nation-battler.json">Manifest JSON</a>
        <a href="/games/nouns-nation-battler/assets/manifest.json">Sprite manifest</a>
      </div>
    </section>

    <section class="game-frame" aria-label="Nouns Nation Battler playable frame">
      <iframe src="/games/nouns-nation-battler/index.html" title="Nouns Nation Battler game" loading="eager"></iframe>
    </section>
  </main>
</BlockLayout>

<style>
  .nation-page {
    display: grid;
    gap: 18px;
  }

  .crumb,
  .manifest-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .crumb {
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--muted, #6c6254);
  }

  .intro {
    max-width: 880px;
  }

  .kicker {
    margin: 0 0 8px;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 8px;
    font-size: clamp(2.6rem, 8vw, 6rem);
    line-height: 0.9;
    letter-spacing: 0;
  }

  .intro p {
    margin: 0;
    max-width: 780px;
    font-size: clamp(1rem, 2vw, 1.28rem);
    line-height: 1.45;
  }

  .manifest-row {
    margin-top: 16px;
  }

  .manifest-row a {
    border: 2px solid currentColor;
    padding: 8px 10px;
    font-weight: 900;
    text-decoration: none;
  }

  .game-frame {
    min-height: 740px;
    border: 3px solid currentColor;
    background: #f2eddc;
  }

  .game-frame iframe {
    display: block;
    width: 100%;
    height: min(860px, 92vh);
    min-height: 740px;
    border: 0;
  }

  @media (max-width: 760px) {
    .game-frame,
    .game-frame iframe {
      min-height: 880px;
    }
  }
</style>
