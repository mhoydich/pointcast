---
/**
 * /nouns-nation-battler - 30v30 automated Nouns gang battler.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Nouns Nation Battler',
  description: 'A browser-playable 30v30 automated Nouns league battler with a Watch Now rail, score-consistent quick sims, numbered rosters, scout cards, sim controls, live unit stats, season challenge objectives, rivalry heat, late-season boss fields, a TV Bowl Countdown card, canonical shareable report card links, an in-session Report Gallery, downloadable Season Report cards, printable Season Reports, portable Season Desk Wall snapshots, copyable Commissioner Desk interstitials and archive, a rookie Watch Guide, live storyline engine, Watch Party Kit, Recap Studio, Season 2 scope board, a two-week season, Nouns Bowl final, gang brand kits, rooting stats, Director Mode TV, Noun-heavy overview interstitials, Amplifier Rift, Crown Rush, and weird terrain battle types, a 20-poster Nouns series, and official Nouns SVG parts.',
  url: 'https://pointcast.xyz/nouns-nation-battler/',
  gamePlatform: 'Web browser',
  genre: 'Auto battler',
  inLanguage: 'en-US',
};

const launchCards = [
  {
    label: 'Invite',
    title: 'Send the TV cast first',
    body: 'Lead with the current matchup, field, and challenge so the link feels live.',
  },
  {
    label: 'Root',
    title: 'Ask people to pick a gang',
    body: 'The battle is automated, but choosing Tomato, Mint, Cobalt, or another gang gives the room a side.',
  },
  {
    label: 'Ritual',
    title: 'Name the slate',
    body: 'Lunch Slate, Dinner Slate, rivalry runback, then Nouns Bowl. The cadence makes the league easier to return to.',
  },
  {
    label: 'Artifact',
    title: 'Share posters after',
    body: 'Recap Studio gives you the result text, then the poster wall turns the match into something people can forward.',
  },
];
---

<BlockLayout
  title="Nouns Nation Battler"
  description="Watch 30 vs 30 automated Nouns gangs play a two-week league into a Nouns Bowl final with a Watch Now rail, score-consistent quick sims, numbered rosters, scout cards, sim controls, live unit stats, rivalry heat, late-season boss fields, a TV Bowl Countdown card, canonical shareable report card links, an in-session Report Gallery, downloadable Season Report cards, printable Season Reports, portable Season Desk Wall snapshots, copyable Commissioner Desk interstitials and archive, a rookie Watch Guide, live storyline engine, Watch Party Kit, Recap Studio, Season 2 scope board, rotating season challenges, generated brand kits, rooting stats, Director Mode TV, Noun-heavy overview interstitials, Amplifier Rift, Crown Rush, Lava Audit, Cloud Court, Trash Planet, Fog Bowl, a 20-poster Nouns series, and official Nouns SVG parts."
  image="/images/og/battle.png"
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/nouns-nation-battler.json', title: 'Nouns Nation Battler manifest (JSON)' }]}
  frame={{
    image: 'https://pointcast.xyz/images/og/battle.png',
    buttons: [
        { label: 'Watch match', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler/' },
      { label: 'Game JSON', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler.json' },
      { label: 'TV Cast', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-tv/' },
      { label: 'Desk Wall', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-desk/' },
      { label: 'Battle channel', action: 'link', target: 'https://pointcast.xyz/c/battler/' },
    ],
  }}
>
  <main class="nation-page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/c/battler/">CH.BTL</a>
      <span aria-hidden="true">/</span>
      <span>Nouns Nation Battler</span>
    </nav>

    <section class="intro">
      <p class="kicker">CH.BTL / AUTO-BATTLER V30 LEAGUE INTEGRITY</p>
      <h1>Nouns Nation Battler</h1>
      <p>
        Thirty official Nouns sprites per side, eight rotating gangs, a two-week table, playoff bracket,
        Nouns Bowl final, numbered players, scout cards, quick sim controls, live unit stat leaders,
        persistent rooting records, rivalry heat with local head-to-head records, late-season boss fields like Monsoon Rift, Neon Crown, Scrap Storm, and Blackout Fog, a first-run Watch Guide, a Watch Now rail, live storylines for playoff chase and next fixtures, an operator Watch Party Kit with a copyable Commissioner Desk archive, canonical shareable report card links, an in-session Report Gallery, downloadable Season Report cards, printable Season Reports, and portable Season Desk Wall snapshots, score-consistent quick sims, a post-match Recap Studio with copyable result cards, a Season 2 scope board, rotating season challenge objectives, role specials, center control, Amplifier Rift matches with elemental lanes, Crown Rush matches with a contested center crown,
        Lava Audit, Cloud Court, Trash Planet, Fog Bowl, a live battle log, a 20-piece type-heavy poster series, and a dedicated Director Mode TV cast with camera cues, replay bay, Noun-heavy league, copyable Commissioner Desk, challenge, and field-guide interstitials, Market Pulse, MVP Watch, Comeback Line, Bowl Countdown cards, and a TV guide shortcut.
      </p>
      <div class="manifest-row">
        <a href="/games/nouns-nation-battler/" target="_blank" rel="noreferrer">Open full screen</a>
        <a href="/nouns-nation-battler-tv/" target="_blank" rel="noreferrer">TV Cast</a>
        <a href="/nouns-nation-battler-desk/">Desk Wall</a>
        <a href="/nouns-nation-battler-posters/">Poster Series</a>
        <a href="/nouns-nation-battler.json">Manifest JSON</a>
        <a href="/games/nouns-nation-battler/assets/manifest.json">Sprite manifest</a>
        <a href="https://github.com/mhoydich/pointcast/blob/main/docs/prd/nouns-nation-battler-league.md" target="_blank" rel="noreferrer">League PRD</a>
        <a href="https://github.com/mhoydich/pointcast/blob/main/docs/prd/nouns-nation-battler-season-2.md" target="_blank" rel="noreferrer">Season 2 PRD</a>
        <a href="https://github.com/mhoydich/pointcast/blob/main/docs/prd/nouns-nation-battler-gtm.md" target="_blank" rel="noreferrer">GTM Strategy</a>
      </div>
    </section>

    <section class="launch-plan" aria-label="Nouns Nation Battler launch plan">
      <div class="launch-head">
        <p class="kicker">Go to market</p>
        <h2>Get people to watch one specific match, then give them a reason to come back.</h2>
      </div>
      <div class="launch-grid">
        {launchCards.map((card) => (
          <article>
            <span>{card.label}</span>
            <strong>{card.title}</strong>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="game-frame" aria-label="Nouns Nation Battler playable frame">
      <iframe src="/games/nouns-nation-battler/" title="Nouns Nation Battler game" loading="eager"></iframe>
    </section>
  </main>
</BlockLayout>

<style>
  .nation-page {
    display: grid;
    gap: 18px;
  }

  .crumb,
  .manifest-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .crumb {
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--muted, #6c6254);
  }

  .intro {
    max-width: 880px;
  }

  .launch-plan {
    display: grid;
    gap: 14px;
    border-top: 3px solid currentColor;
    border-bottom: 3px solid currentColor;
    padding: 18px 0;
  }

  .launch-head {
    max-width: 860px;
  }

  .kicker {
    margin: 0 0 8px;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 8px;
    font-size: clamp(2.6rem, 8vw, 6rem);
    line-height: 0.9;
    letter-spacing: 0;
  }

  h2 {
    margin: 0;
    max-width: 880px;
    font-size: clamp(1.8rem, 4.4vw, 3.5rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  .intro p {
    margin: 0;
    max-width: 780px;
    font-size: clamp(1rem, 2vw, 1.28rem);
    line-height: 1.45;
  }

  .launch-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
  }

  .launch-grid article {
    min-width: 0;
    border: 2px solid currentColor;
    background: #fff9ea;
    padding: 12px;
    display: grid;
    align-content: start;
    gap: 8px;
  }

  .launch-grid span {
    width: fit-content;
    border: 2px solid currentColor;
    background: #d7ff3f;
    padding: 2px 6px;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  .launch-grid strong {
    font-size: 1.05rem;
    line-height: 1.05;
  }

  .launch-grid p {
    margin: 0;
    color: var(--muted, #6c6254);
    font-weight: 800;
    line-height: 1.38;
  }

  .manifest-row {
    margin-top: 16px;
  }

  .manifest-row a {
    border: 2px solid currentColor;
    padding: 8px 10px;
    font-weight: 900;
    text-decoration: none;
  }

  .game-frame {
    min-height: 740px;
    border: 3px solid currentColor;
    background: #f2eddc;
  }

  .game-frame iframe {
    display: block;
    width: 100%;
    height: min(860px, 92vh);
    min-height: 740px;
    border: 0;
  }

  @media (max-width: 760px) {
    .launch-grid {
      grid-template-columns: 1fr;
    }

    .game-frame,
    .game-frame iframe {
      min-height: 880px;
    }
  }
</style>
