---
/**
 * /meditate - Ocean-based meditation room.
 *
 * A PointCast-native quiet surface: a timer, breath cadence, ocean focus
 * mode, local tide log, and a machine-readable mirror at /meditate.json.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import OceanMeditation from '../components/OceanMeditation.astro';

const title = 'Ocean Meditation';
const description = 'A PointCast ocean meditation room with timed breathing, focus mode, tide log, and optional ambient tone.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': 'https://pointcast.xyz/meditate',
  name: 'PointCast Ocean Meditation',
  description,
  url: 'https://pointcast.xyz/meditate',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Web',
  isPartOf: {
    '@type': 'WebSite',
    name: 'PointCast',
    url: 'https://pointcast.xyz',
  },
  featureList: [
    'Ocean-based breathing timer',
    '2, 5, and 10 minute sessions',
    'Calm Bay, Deep Current, and Moon Tide programs',
    'Full-screen focus mode',
    'Local tide log stored in the browser',
    'Optional generated ocean tone',
  ],
};
---

<BlockLayout
  title={title}
  description={description}
  image="/images/og/meditate.png"
  jsonLd={jsonLd}
  alternates={[
    { type: 'application/json', href: '/meditate.json', title: 'Ocean meditation room (JSON)' },
  ]}
  frame={{
    image: 'https://pointcast.xyz/images/og/meditate.png',
    buttons: [
      { label: 'Open Ocean Meditation', action: 'link', target: 'https://pointcast.xyz/meditate' },
      { label: 'PointCast Home', action: 'link', target: 'https://pointcast.xyz/' },
    ],
  }}
>
  <div class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>meditate</span>
    </nav>

    <header class="hero">
      <div class="hero__copy">
        <p class="kicker">OCEAN RESET · POINTCAST</p>
        <h1>A two-minute tide you can actually finish.</h1>
        <p class="dek">
          The feed can be dense. This room gives it a shoreline: choose a
          cadence, breathe with the water, and leave with a small local tide
          log instead of another inbox.
        </p>
        <div class="hero__actions">
          <a href="#session" class="hero__cta">Start session</a>
          <a href="/meditate.json" class="hero__link">JSON mirror</a>
        </div>
      </div>
      <figure class="hero__art">
        <img src="/images/tokens/breathe-el-segundo.webp" alt="Breathe El Segundo token artwork" loading="eager" decoding="async" />
        <figcaption class="mono">BREATHE EL SEGUNDO · TOKEN ARTIFACT</figcaption>
      </figure>
    </header>

    <section class="signals" aria-label="Meditation modes">
      <article>
        <span class="mono">CALM BAY</span>
        <strong>4-2-6-2</strong>
        <p>Quick reset between blocks, calls, and shipping.</p>
      </article>
      <article>
        <span class="mono">DEEP CURRENT</span>
        <strong>5-2-7-2</strong>
        <p>Longer exhale for focusing before the next hard thing.</p>
      </article>
      <article>
        <span class="mono">MOON TIDE</span>
        <strong>4-4-4-4</strong>
        <p>Evening square breath for letting the day close.</p>
      </article>
    </section>

    <div id="session">
      <OceanMeditation />
    </div>

    <section class="notes" aria-label="Field notes">
      <div>
        <p class="kicker">DESIGN NOTE</p>
        <h2>Anti-feed, not anti-machine.</h2>
      </div>
      <p>
        PointCast already broadcasts blocks, drums, prize casts, and local
        signals. Ocean Meditation is the counterweight: a feature that uses the
        browser for stillness, then stops.
      </p>
    </section>
  </div>
</BlockLayout>

<style>
  .page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 16px 20px 80px;
  }

  .mono,
  .kicker {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .crumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    color: var(--pc-ink-muted);
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 360px);
    gap: 18px;
    align-items: stretch;
    margin-bottom: 14px;
    padding-bottom: 18px;
    border-bottom: 1.5px solid var(--pc-ink);
  }

  .hero__copy {
    min-height: 410px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 26px 0;
  }

  .kicker {
    margin: 0 0 12px;
    color: #0f6e56;
  }

  h1 {
    max-width: 760px;
    margin: 0;
    font-size: 58px;
    line-height: 0.98;
    letter-spacing: 0;
    font-weight: 500;
  }

  .dek {
    max-width: 700px;
    margin: 18px 0 0;
    color: var(--pc-ink-soft);
    font-size: 19px;
    line-height: 1.55;
  }

  .hero__actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 26px;
  }

  .hero__cta,
  .hero__link {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    padding: 9px 14px;
    border: 1.5px solid currentColor;
    border-radius: 2px;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero__cta {
    color: #fff;
    background: #0f6e56;
  }

  .hero__cta:hover {
    background: #074638;
    text-decoration: none;
  }

  .hero__link {
    color: var(--pc-accent);
    background: #fff;
  }

  .hero__art {
    margin: 0;
    min-height: 410px;
    border: 1.5px solid #993c1d;
    background: #fbeeea;
    display: grid;
    grid-template-rows: 1fr auto;
  }

  .hero__art img {
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    object-position: center 38%;
  }

  .hero__art figcaption {
    padding: 10px;
    border-top: 1.5px solid #993c1d;
    color: #6a2810;
    background: #fff;
  }

  .signals {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 14px;
  }

  .signals article {
    min-height: 136px;
    padding: 12px;
    border: 1px solid var(--pc-rule);
    background: #fff;
  }

  .signals span {
    display: block;
    color: var(--pc-ink-muted);
    margin-bottom: 10px;
  }

  .signals strong {
    display: block;
    font-family: var(--pc-font-mono);
    font-size: 22px;
    line-height: 1.1;
    font-weight: 500;
    color: #0f6e56;
    font-variant-numeric: tabular-nums;
  }

  .signals p {
    margin: 10px 0 0;
    color: var(--pc-ink-soft);
    font-size: 14px;
    line-height: 1.45;
  }

  .notes {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 18px;
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1.5px solid var(--pc-ink);
  }

  .notes h2 {
    margin: 0;
    font-size: 26px;
    font-weight: 500;
    line-height: 1.1;
  }

  .notes p {
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 17px;
    line-height: 1.6;
  }

  @media (max-width: 820px) {
    .hero,
    .notes {
      grid-template-columns: 1fr;
    }

    .hero__copy,
    .hero__art {
      min-height: auto;
    }

    h1 {
      font-size: 44px;
    }

    .signals {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .page {
      padding: 12px 12px 60px;
    }

    h1 {
      font-size: 36px;
    }

    .dek {
      font-size: 17px;
    }
  }
</style>
