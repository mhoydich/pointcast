---
import BlockLayout from '../layouts/BlockLayout.astro';
import { POINTCAST_APPS } from '../lib/pointcast-apps';

const title = 'Apps';
const description = 'Satellite PointCast apps collected in one place: MoodyGold and Offbalance.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://pointcast.xyz/apps',
  name: 'PointCast Apps',
  description,
  url: 'https://pointcast.xyz/apps',
  hasPart: POINTCAST_APPS.map((app) => ({
    '@type': 'WebApplication',
    name: app.name,
    description: app.description,
    url: `https://pointcast.xyz/${app.slug}`,
    sameAs: [app.url, app.repo],
  })),
};
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>apps</span>
    </nav>

    <header class="head">
      <p class="kicker">Apps · PointCast satellite rooms</p>
      <h1>View the rooms from here.</h1>
      <p class="dek">
        MoodyGold and Offbalance still deploy as small standalone apps. PointCast
        now gives them stable front doors, embedded views, and an index.
      </p>
    </header>

    <section class="grid" aria-label="PointCast apps">
      {POINTCAST_APPS.map((app) => (
        <article class="app">
          <p class="app__kicker">{app.channel} · {app.kicker}</p>
          <h2>{app.name}</h2>
          <p>{app.description}</p>
          <div class="app__actions">
            <a href={`/${app.slug}`}>Open on PointCast</a>
            <a href={app.url} target="_blank" rel="noopener">Open direct</a>
          </div>
        </article>
      ))}
    </section>
  </main>
</BlockLayout>

<style>
  .page { max-width: 1040px; margin: 0 auto; padding: 22px 18px 82px; }
  .crumb, .kicker, .app__kicker {
    font-family: var(--pc-font-mono);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .crumb {
    display: flex;
    gap: 8px;
    margin-bottom: 18px;
    font-size: 10px;
    color: var(--pc-ink-muted);
  }
  .head {
    border-top: 1.5px solid var(--pc-ink);
    border-bottom: 1px solid var(--pc-rule-soft);
    padding: 24px 0 26px;
    margin-bottom: 18px;
  }
  .kicker { margin: 0 0 10px; font-size: 10px; color: #8A2432; }
  h1 { margin: 0; font-size: clamp(42px, 8vw, 88px); line-height: 0.95; font-weight: 500; }
  .dek { max-width: 760px; margin: 14px 0 0; font-size: 18px; line-height: 1.5; color: var(--pc-ink-soft); }
  .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
  .app {
    border: 1px solid var(--pc-rule-soft);
    padding: 16px;
    background: #fff;
  }
  .app__kicker { margin: 0 0 10px; font-size: 10px; color: #6B2139; }
  .app h2 { margin: 0; font-size: 28px; line-height: 1; font-weight: 500; }
  .app p { line-height: 1.5; color: var(--pc-ink-soft); }
  .app__actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
  .app__actions a {
    padding: 8px 10px;
    border: 1px solid var(--pc-ink);
    color: var(--pc-ink);
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .app__actions a:hover { background: var(--pc-ink); color: #fff; text-decoration: none; }
  @media (max-width: 760px) {
    .grid { grid-template-columns: 1fr; }
    .dek { font-size: 16px; }
  }
</style>
