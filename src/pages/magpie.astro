  }
  .mg-pill.err { background: rgba(193, 78, 58, 0.13); color: var(--mg-leaf-red); }
  .mg-pill.err .mg-pill-dot { background: var(--mg-leaf-red); animation: none; }
  .mg-pill.checking { background: transparent; color: var(--mg-ink-soft); border: 1px solid var(--mg-rule); }
  .mg-pill.checking .mg-pill-dot { background: var(--mg-clay); opacity: 0.6; }
  .mg-pill.ok { background: var(--mg-sage-tint); color: var(--mg-moss); }

  /* ── Install state ───────────────────────── */
  .mg-install { padding: 40px 32px 20px; display: flex; justify-content: center; }
  .mg-install-card {
    max-width: 640px;
    width: 100%;
    background: var(--mg-card);
    border: 1px solid var(--mg-rule);
    padding: 32px 36px;
    border-radius: 3px;
    box-shadow: 0 1px 0 rgba(30, 28, 20, 0.04);
  }
  .mg-install-kicker { margin: 0 0 10px; }
  .mg-install-title {
    font-family: var(--mg-display);
    font-style: italic;
    font-size: 32px;
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--mg-ink);
    margin: 0 0 14px;
  }
  .mg-install-dek {
    font-size: 15px;
    line-height: 1.55;
    color: var(--mg-ink-soft);
    margin: 0 0 24px;
    max-width: 56ch;
  }
  .mg-install-dek em { font-family: var(--mg-display); font-style: italic; color: var(--mg-ink); }
  .mg-install-steps {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .mg-install-steps li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding-bottom: 16px;
    border-bottom: 1px dotted var(--mg-rule);
  }
  .mg-install-steps li:last-child { border-bottom: none; padding-bottom: 0; }
  .mg-step-n {
    font-family: var(--mg-display);
    font-style: italic;
    font-size: 22px;
    font-weight: 500;
    color: var(--mg-clay);
    line-height: 1;
    flex-shrink: 0;
    width: 28px;
    text-align: center;
  }
  .mg-install-steps li div { flex: 1; font-size: 14px; line-height: 1.55; color: var(--mg-ink); }
  .mg-install-steps li strong { font-weight: 600; color: var(--mg-ink); display: block; margin-bottom: 2px; }
  .mg-install-steps li em { font-family: var(--mg-display); font-style: italic; color: var(--mg-moss); }
  .mg-install-steps li a { color: var(--mg-bronze); text-decoration: underline; text-underline-offset: 2px; text-decoration-color: rgba(126, 90, 42, 0.35); }
  .mg-install-steps li a:hover { text-decoration-color: var(--mg-bronze); color: var(--mg-clay-dark); }
  .mg-install-steps li code { font-family: var(--mg-mono); font-size: 12px; padding: 1px 6px; background: var(--mg-paper-tint); border: 1px solid var(--mg-rule); border-radius: 2px; }

  /* Endpoint "copy this URL into Magpie" block inside step 4. Displays
     the canonical endpoint, makes it one-click copyable. */
  .mg-endpoint-copy {
    margin-top: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    padding: 8px 10px;
    background: var(--mg-paper-tint);
    border: 1px solid var(--mg-rule);
    border-radius: 2px;
  }
  .mg-endpoint-copy-kicker {
    color: var(--mg-moss) !important;
    font-size: 10px;
  }
  .mg-endpoint-copy-url {
    font-family: var(--mg-mono);
    font-size: 12.5px;
    color: var(--mg-clay-dark);
    padding: 2px 6px;
    background: var(--mg-card);
    border: 1px solid var(--mg-rule);
    border-radius: 2px;
    flex: 1 1 220px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .mg-endpoint-copy-btn {
    font-size: 11px !important;
    padding: 4px 10px !important;
    min-width: 64px;
  }
  .mg-endpoint-copy-btn.is-copied {
    color: var(--mg-moss) !important;
    border-color: var(--mg-moss) !important;
  }

  /* Inline endpoint state in the meta strip — flip to warning when
     the local Magpie hasn't set /config.json's pointcast.endpoint. */
  #mg-pcEndpoint.missing {
    color: var(--mg-clay-dark);
    background: color-mix(in srgb, var(--mg-clay) 14%, transparent);
    border: 1px solid var(--mg-clay);
    padding: 1px 6px;
    border-radius: 2px;
    font-family: var(--mg-mono);
    font-size: 11px;
  }
  #mg-pcEndpoint.custom {
    color: var(--mg-moss);
  }

  .mg-install-cta { display: flex; gap: 10px; flex-wrap: wrap; }
  .mg-demo-btn { color: var(--mg-moss) !important; border-color: var(--mg-moss) !important; }
  .mg-demo-btn:hover { background: var(--mg-moss) !important; color: var(--mg-paper) !important; }

  /* v0.6: broadcast destinations panel */
  .mg-destinations {
    margin: 22px 0 8px;
    padding: 16px 18px;
    background: var(--mg-paper-tint);
    border: 1px solid var(--mg-rule);
    border-radius: 3px;
  }
  .mg-destinations-kicker { margin: 0 0 6px; color: var(--mg-moss); }
  .mg-destinations-subkicker { margin: 16px 0 6px; color: var(--mg-ink-mute); }
  .mg-destinations-dek {
    font-family: var(--mg-display);
    font-style: italic;
    font-size: 13px;
    color: var(--mg-ink-soft);
    margin: 0 0 12px;
    line-height: 1.5;
  }
  .mg-destinations-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 8px;
  }
  .mg-destinations-grid li {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    background: var(--mg-card);
    border: 1px solid var(--mg-rule);
    border-radius: 2px;
    font-size: 12px;
  }
  .mg-destinations-grid li.mg-dest-future {
    opacity: 0.6;
    border-style: dashed;
  }
  .mg-destinations-grid li.mg-dest-new {
    background: color-mix(in srgb, var(--mg-moss) 8%, var(--mg-card));
    border-color: color-mix(in srgb, var(--mg-moss) 40%, var(--mg-rule));
    box-shadow: inset 3px 0 0 var(--mg-moss);
  }
  .mg-destinations-grid li.mg-dest-new .mg-dest-code {
    color: var(--mg-moss);
    border-color: var(--mg-moss);
  }
  .mg-dest-code {
    font-family: var(--mg-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--mg-clay);
    padding: 2px 5px;
    border: 0.5px solid var(--mg-clay);
    border-radius: 2px;
    min-width: 24px;
    text-align: center;
  }
  .mg-dest-name { font-weight: 600; color: var(--mg-ink); flex: 0 0 auto; }
  .mg-dest-note { font-family: var(--mg-mono); font-size: 10px; color: var(--mg-ink-mute); margin-left: auto; }

  .mg-settings {
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px dotted var(--mg-rule);
  }
  .mg-settings summary {
    font-family: var(--mg-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mg-clay);
    cursor: pointer;
    padding: 4px 0;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .mg-settings summary::-webkit-details-marker { display: none; }
  .mg-settings summary::before {
    content: "+";
    font-family: var(--mg-display);
    font-size: 15px;
    line-height: 0;
    color: var(--mg-clay);
    margin-right: 4px;
  }
  .mg-settings[open] summary::before { content: "−"; }
  .mg-settings summary:hover { color: var(--mg-clay-dark); }
  .mg-settings-body {
    padding: 12px 0 4px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mg-endpoint-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .mg-endpoint-row input[type="text"] {
    flex: 1;
    min-width: 180px;
    font-family: var(--mg-mono);
    font-size: 12px;
    padding: 7px 10px;
    border: 1px solid var(--mg-rule);
    background: var(--mg-paper);
    color: var(--mg-ink);
    border-radius: 2px;
  }
  .mg-endpoint-row input[type="text"]:focus {
    outline: none;
    border-color: var(--mg-moss);
    box-shadow: 0 0 0 3px rgba(62, 89, 64, 0.08);
  }
  .mg-settings-hint {
    margin: 0;
    font-size: 12px;
    color: var(--mg-ink-soft);
    line-height: 1.5;
  }
  .mg-settings-hint code {
    font-family: var(--mg-mono);
    font-size: 11px;
    padding: 1px 5px;
    background: var(--mg-paper-tint);
    border: 1px solid var(--mg-rule);
    border-radius: 2px;
  }

  .mg-demo-banner {
    margin: 20px 32px 0;
    padding: 10px 18px;
    background: var(--mg-sage-tint);
    border: 1px solid var(--mg-moss);
    border-radius: 3px;
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 12px;
    color: var(--mg-moss-dark);
    flex-wrap: wrap;
  }
  .mg-demo-banner .mg-kicker { color: var(--mg-moss-dark); font-weight: 700; white-space: nowrap; }
  .mg-demo-banner .mg-kicker::before { display: none; }
  .mg-demo-copy { flex: 1; min-width: 220px; font-family: var(--mg-body); font-size: 13px; color: var(--mg-ink); line-height: 1.45; }
  .mg-demo-banner .mg-btn { border-color: var(--mg-moss-dark); color: var(--mg-moss-dark); }
  .mg-demo-banner .mg-btn:hover { background: var(--mg-moss-dark); color: var(--mg-paper); border-color: var(--mg-moss-dark); }

  .mg-btn {
    font-family: var(--mg-mono);
    font-size: 11px;
    font-weight: 600;
    padding: 10px 18px;
    border: 1px solid var(--mg-rule);
    background: transparent;
    color: var(--mg-ink-soft);
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    border-radius: 2px;
    transition: all 0.15s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }
  .mg-btn:hover { background: var(--mg-paper); color: var(--mg-ink); border-color: var(--mg-ink); }
  .mg-btn.primary {
    background: var(--mg-moss);
    color: var(--mg-paper);
    border-color: var(--mg-moss);
    font-weight: 700;
  }
  .mg-btn.primary:hover {
    background: var(--mg-moss-dark);
    border-color: var(--mg-moss-dark);
    transform: translateY(-1px);
    box-shadow: 0 6px 14px rgba(39, 58, 40, 0.28);
  }
  .mg-btn.ghost { background: transparent; color: var(--mg-ink-soft); }

  /* ── Grid ─────────────────────────────────── */
  .mg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 22px;
    padding: 28px 32px;
  }
  .mg-clip {
    background: var(--mg-card);
    border: 1px solid var(--mg-rule);
    border-radius: 3px;
    padding: 14px 18px 12px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: all 0.2s cubic-bezier(0.2, 0.7, 0.3, 1);
    position: relative;
    box-shadow: 0 1px 0 rgba(30, 28, 20, 0.04);
  }
  .mg-clip:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(30, 28, 20, 0.06);
    border-color: var(--mg-moss);
  }
  .mg-clip.pinned::before {
    content: "";
    position: absolute;
    left: -1px;
    top: -1px;
    bottom: -1px;
    width: 4px;
    background: var(--mg-clay);
    border-radius: 3px 0 0 3px;
  }

  .mg-clip-head {
    display: flex;
    gap: 6px;
    align-items: baseline;
    font-family: var(--mg-mono);
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mg-ink-soft);
    padding-bottom: 10px;
    border-bottom: 1px dotted var(--mg-rule);
  }
  .mg-block-code {
    color: var(--mg-clay);
    font-weight: 700;
    letter-spacing: 0.26em;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .mg-block-code::before { content: "◈"; font-size: 9px; color: var(--mg-clay); letter-spacing: 0; }
  .mg-sep { color: var(--mg-rule); }
  .mg-src { font-weight: 500; color: var(--mg-ink); letter-spacing: 0.16em; }
  .mg-ts { margin-left: auto; color: var(--mg-ink-mute); font-weight: 400; }
  .mg-count-badge {
    margin-left: auto;
    font-family: var(--mg-mono);
    font-size: 9px;
    font-weight: 700;
    color: var(--mg-clay);
    background: var(--mg-sage-tint);
    padding: 2px 7px;
    border-radius: 999px;
    letter-spacing: 0.08em;
  }
  .mg-count-badge + .mg-ts { margin-left: 6px; }
  .mg-pin { color: var(--mg-clay); font-size: 10px; margin-left: 4px; }

  .mg-body {
    font-size: 14px;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
    color: var(--mg-ink);
    min-height: 24px;
    position: relative;
    flex: 1;
  }
  .mg-body a {
    color: var(--mg-bronze);
    text-decoration: underline;
    text-decoration-color: rgba(126, 90, 42, 0.35);
    text-underline-offset: 3px;
    transition: all 0.15s;
    word-break: break-all;
  }
  .mg-body a:hover { text-decoration-color: var(--mg-bronze); color: var(--mg-clay-dark); }
  .mg-body.plain { max-height: 160px; overflow: hidden; }
  .mg-body.plain::after {
    content: "";
    position: absolute;
    bottom: 0; left: 0; right: 0; height: 32px;
    background: linear-gradient(transparent, var(--mg-card));
    pointer-events: none;
  }
  .mg-clip:hover .mg-body.plain::after { background: linear-gradient(transparent, var(--mg-card-hover)); }

  .mg-body.unfurled { max-height: none; overflow: visible; display: flex; flex-direction: column; gap: 10px; }
  .mg-unfurl { display: flex; flex-direction: column; gap: 10px; }
  .mg-unfurl-plate {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--mg-paper-tint);
    border: 1px solid var(--mg-rule);
    padding: 4px;
    position: relative;
    overflow: hidden;
  }
  .mg-unfurl-plate img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.95) contrast(1.02);
  }
  .mg-unfurl-plate::after {
    content: "";
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 0 1px rgba(30, 28, 20, 0.08);
    pointer-events: none;
  }
  .mg-unfurl-host-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mg-mono);
    font-size: 10px;
    color: var(--mg-moss);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .mg-favicon {
    width: 14px;
    height: 14px;
    border-radius: 2px;
    object-fit: contain;
    flex-shrink: 0;
    background: var(--mg-paper);
  }
  .mg-host { color: var(--mg-moss); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .mg-unfurl-host-row::after { content: ""; flex: 1; height: 1px; background: var(--mg-rule-soft); margin-left: 4px; }
  .mg-unfurl-title {
    font-family: var(--mg-display);
    font-size: 22px;
    font-weight: 500;
    color: var(--mg-ink);
    line-height: 1.18;
    letter-spacing: -0.015em;
    font-style: italic;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 4px;
  }
  .mg-unfurl-desc {
    font-family: var(--mg-body);
    font-size: 13px;
    line-height: 1.55;
    color: var(--mg-ink-soft);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 2px;
  }
  .mg-unfurl-url {
    font-family: var(--mg-mono);
    font-size: 10px;
    color: var(--mg-ink-mute) !important;
    text-decoration: none !important;
    margin-top: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
    letter-spacing: 0.02em;
  }
  .mg-unfurl-url::before { content: "→ "; color: var(--mg-clay); opacity: 0.7; }
  .mg-unfurl-url:hover { color: var(--mg-clay) !important; }

  .mg-clip-foot {
    display: flex;
    gap: 4px;
    align-items: stretch;
    padding-top: 12px;
    border-top: 1px dotted var(--mg-rule);
    margin-top: auto;
  }
  .mg-act {
    font-family: var(--mg-mono);
    font-size: 10px;
    font-weight: 600;
    padding: 7px 12px;
    border: 1px solid var(--mg-rule);
    background: transparent;
    color: var(--mg-ink-soft);
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    transition: all 0.15s;
    border-radius: 2px;
  }
  .mg-act:hover { background: var(--mg-paper); color: var(--mg-ink); border-color: var(--mg-moss); }
  .mg-act.mg-push {
    background: var(--mg-moss);
    color: var(--mg-paper);
    border-color: var(--mg-moss);
    font-weight: 700;
  }
  .mg-act.mg-push:hover {
    background: var(--mg-moss-dark);
    border-color: var(--mg-moss-dark);
    color: var(--mg-paper);
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(39, 58, 40, 0.22);
  }
  .mg-act.mg-push-expand {
    color: var(--mg-clay);
    border-color: var(--mg-clay);
    font-weight: 700;
  }
  .mg-act.mg-push-expand:hover {
    background: var(--mg-clay);
    color: var(--mg-paper);
    border-color: var(--mg-clay);
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(174, 106, 56, 0.22);
  }
  .mg-result {
    font-family: var(--mg-mono);
    font-size: 9px;
    color: var(--mg-ink-mute);
    margin-left: auto;
    align-self: center;
    padding-left: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .mg-result.ok { color: var(--mg-moss); }
  .mg-result.err { color: var(--mg-leaf-red); }

  .mg-empty {
    grid-column: 1 / -1;
    padding: 80px 20px;
    text-align: center;
    color: var(--mg-ink-mute);
    font-family: var(--mg-display);
    font-style: italic;
    font-size: 17px;
    background: var(--mg-card);
    border: 1px solid var(--mg-rule);
    border-radius: 3px;
  }

  .mg-foot {
    padding: 24px 32px 32px;
    font-family: var(--mg-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mg-ink-mute);
    text-align: center;
    border-top: 1px solid var(--mg-rule-soft);
    margin-top: 24px;
  }
  .mg-foot a {
    color: var(--mg-clay);
    text-decoration: none;
    border-bottom: 1px solid rgba(174, 106, 56, 0.3);
    padding-bottom: 1px;
  }

  /* ── Expansion modal ──────────────────────── */
  .mg-expand-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(30, 28, 20, 0.4);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    padding: 28px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .mg-expand-backdrop.open { opacity: 1; pointer-events: auto; }
  .mg-expand-modal {
    background: var(--mg-paper);
    border: 1px solid var(--mg-rule);
    border-radius: 4px;
    width: 100%;
    max-width: 640px;
    max-height: calc(100vh - 56px);
    overflow-y: auto;
    box-shadow: 0 24px 48px rgba(30, 28, 20, 0.25);
    transform: translateY(12px);
    opacity: 0;
    transition: all 0.24s cubic-bezier(0.2, 0.7, 0.3, 1);
    font-family: var(--mg-body);
  }
  .mg-expand-backdrop.open .mg-expand-modal { transform: translateY(0); opacity: 1; }
  .mg-expand-head {
    padding: 18px 24px 14px;
    border-bottom: 1px solid var(--mg-rule);
    position: relative;
    background: linear-gradient(to bottom, var(--mg-card), var(--mg-paper));
  }
  .mg-expand-kicker { margin: 0; }
  .mg-expand-kicker::before { content: "✤"; font-style: normal; }
  .mg-expand-title {
    font-family: var(--mg-display);
    font-style: italic;
    font-size: 22px;
    font-weight: 500;
    color: var(--mg-ink);
    margin-top: 4px;
    letter-spacing: -0.01em;
  }
  .mg-close {
    position: absolute;
    top: 14px;
    right: 16px;
    background: transparent;
    border: 1px solid var(--mg-rule);
    color: var(--mg-ink-soft);
    font-family: var(--mg-mono);
    font-size: 14px;
    width: 28px;
    height: 28px;
    cursor: pointer;
    border-radius: 2px;
    line-height: 1;
