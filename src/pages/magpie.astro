  <div class="magpie-root">
    <nav class="mg-crumb">
      <a href="/">← Home</a>
    </nav>

    <header class="mg-bar">
      <div class="mg-masthead">
        <div class="mg-brand">
          <span class="mg-kicker">Field clippings · from your machine</span>
          <div class="mg-wordmark">
            <span class="mg-logo" aria-hidden="true">🐦‍⬛</span>
            <strong>Magpie</strong>
          </div>
          <div class="mg-tagline">A specimen book for things worth keeping — pressed at home on PointCast, broadcast from there to Mastodon, Farcaster, and out to bitchat's mesh.</div>
        </div>
        <div class="mg-controls">
          <input id="mg-q" type="search" placeholder="search the archive" autocomplete="off">
          <label class="mg-chk"><input id="mg-pinnedOnly" type="checkbox"> pressed only</label>
          <button id="mg-refresh" type="button" title="reload">↻</button>
        </div>
      </div>
    </header>

    <section class="mg-meta">
      <div>
        <span class="mg-k">node</span>
        <code id="mg-node">127.0.0.1:38473</code>
        <span class="mg-dot">·</span>
        <span class="mg-k">pointcast</span>
        <code id="mg-pcEndpoint">—</code>
        <span class="mg-dot">·</span>
        <span class="mg-k">from</span>
        <code id="mg-pcFrom">—</code>
      </div>
      <div>
        <span id="mg-status" class="mg-pill checking"><span class="mg-pill-dot"></span>checking</span>
      </div>
    </section>

    <section id="mg-install" class="mg-install" hidden>
