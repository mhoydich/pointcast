    <template id="mg-tpl-clip">
      <article class="mg-clip">
        <header class="mg-clip-head">
          <span class="mg-block-code"></span>
          <span class="mg-sep">·</span>
          <span class="mg-src"></span>
          <span class="mg-count-badge" hidden></span>
          <time class="mg-ts"></time>
          <span class="mg-pin" hidden>❋</span>
        </header>
        <div class="mg-body"></div>
        <footer class="mg-clip-foot">
          <button class="mg-act mg-copy" type="button" title="copy text">copy</button>
          <button class="mg-act mg-push" type="button" title="push to PointCast inbox">push →</button>
          <button class="mg-act mg-push-expand" type="button" title="expand into a block">expand ✤</button>
          <span class="mg-result"></span>
        </footer>
      </article>
    </template>

    <div id="mg-expandBackdrop" class="mg-expand-backdrop" hidden>
      <div class="mg-expand-modal" role="dialog" aria-labelledby="mg-expandTitle">
        <header class="mg-expand-head">
          <div class="mg-kicker mg-expand-kicker">Expand into a block</div>
          <div class="mg-expand-title" id="mg-expandTitle">Publish this clip to PointCast</div>
          <button class="mg-close" type="button" aria-label="close" data-mg-close>✕</button>
        </header>

        <div class="mg-expand-body">
          <div class="mg-field-row">
            <div class="mg-field">
              <label class="mg-label" for="mg-xChannel">Channel <span class="mg-hint">where this lives</span></label>
