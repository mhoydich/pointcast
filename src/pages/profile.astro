    font-family: 'Inter Variable', system-ui, sans-serif;
  }

  .pf-section-head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
    padding: 10px 0 12px;
    border-top: 5px solid var(--pf-yellow);
    margin: 28px 0 16px;
  }
  .pf-section-head--blue   { border-top-color: var(--pf-blue); }
  .pf-section-head--green  { border-top-color: var(--pf-green); }
  .pf-section-head--purple { border-top-color: var(--pf-purple); }
  .pf-section-head--orange { border-top-color: var(--pf-orange); }
  .pf-section-head--red    { border-top-color: var(--pf-red); }

  .pf-section-title {
    font-family: 'Lora', Georgia, serif;
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--pf-ink);
  }
  .pf-section-sub {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 11px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--pf-ink-soft);
    margin: 0;
  }
  .pf-section-sub a { color: var(--pf-ink); font-weight: 700; }

  .pf-hero { margin-bottom: 32px; }
  .pf-hero__chrome {
    background: linear-gradient(180deg, #fefaf0 0%, #f8f0dc 100%);
