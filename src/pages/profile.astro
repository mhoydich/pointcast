  }
  .pf-chip span {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 8px; letter-spacing: 0.18em; color: var(--pf-ink-soft); font-weight: 700;
  }
  .pf-chip b {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 11px; color: var(--pf-ink); letter-spacing: 0.04em;
  }
  .pf-chip--wallet { background: linear-gradient(180deg, #fffbe6 0%, #fef0bd 100%); }
  .pf-chip--noun   { background: linear-gradient(180deg, #fef0bd 0%, #f8d878 100%); }
  .pf-chip--since  { background: #fff; }
  .pf-chip--id     { background: #f4f0e4; }

  .pf-hero__state { display: flex; flex-wrap: wrap; gap: 6px; margin: 4px 0 0; }
  .pf-state-pill {
    display: inline-block; background: #fff; border: 1px dashed var(--pf-rule);
    padding: 3px 9px; font-family: 'JetBrains Mono Variable', monospace;
    font-size: 10px; letter-spacing: 0.10em; color: var(--pf-ink);
  }
  .pf-state-pill--mood { border-color: var(--pf-red); color: var(--pf-red); text-transform: uppercase; font-weight: 700; }

  .pf-hero__stamp {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    width: 86px; height: 86px;
    background: var(--pf-red); color: #fff;
