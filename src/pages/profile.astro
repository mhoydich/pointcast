    font-weight: 700;
    border-bottom: 1px dashed var(--pf-rule);
    padding-bottom: 10px;
  }
  .pf-hero__inner {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    gap: 22px;
    align-items: center;
  }
  .pf-hero__avatar {
    position: relative;
    width: 180px;
    height: 180px;
    background: var(--pf-yellow);
