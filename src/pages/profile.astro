  }
  .pf-hero__avatar img { width: 100%; height: 100%; display: block; image-rendering: pixelated; }
  .pf-hero__noun-tag {
    position: absolute;
    bottom: 6px; left: 6px;
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    background: var(--pf-ink);
    color: var(--pf-paper);
    padding: 2px 7px;
