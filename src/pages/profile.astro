---
/**
 * /profile — v2 redesign.
 *
 * Trading-card / arcade-board hybrid in the PointCast palette.
 * Big Noun portrait, saturated stat tiles, poster-wall block grid,
 * cassette-style bath saves, ledger-style wallet table, NFT vault.
 *
 * All data flows from localStorage (pc:*) and TzKT — no server state.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': 'https://pointcast.xyz/profile',
  name: 'Your PointCast profile',
  description: 'Your PointCast broadcast card — Noun, collected blocks, Tezos NFTs, bath saves, paired wallets.',
  url: 'https://pointcast.xyz/profile',
};
---

<BlockLayout title="Profile" description="Your PointCast broadcast card." jsonLd={jsonLd}>

  <main class="pf">

    <section class="pf-hero">
      <div class="pf-hero__chrome">
        <p class="pf-hero__kicker">PROFILE · POINTCAST · CC0 · EL SEGUNDO</p>
        <div class="pf-hero__inner">
          <div class="pf-hero__avatar">
            <img id="pf-noun-img" alt="" src="" />
            <span class="pf-hero__noun-tag" id="pf-noun-tag">noun #—</span>
          </div>
          <div class="pf-hero__id">
            <h1 class="pf-hero__name" id="pf-name">visitor</h1>
            <p class="pf-hero__sub" id="pf-sub">Loading the broadcast card…</p>
            <ul class="pf-hero__chips" id="pf-chips"></ul>
            <p class="pf-hero__state" id="pf-state-line"></p>
          </div>
          <div class="pf-hero__stamp" aria-hidden="true">
            <span class="pf-hero__stamp-line">ON</span>
            <span class="pf-hero__stamp-line pf-hero__stamp-line--big">AIR</span>
            <span class="pf-hero__stamp-line">FM 96.1</span>
          </div>
        </div>
      </div>
    </section>

    <section class="pf-arcade">
      <header class="pf-section-head">
        <h2 class="pf-section-title">STATS</h2>
        <p class="pf-section-sub">this browser&apos;s memory</p>
      </header>
      <div class="pf-arcade__grid" id="pf-stats-grid"></div>
    </section>

    <section class="pf-poster">
      <header class="pf-section-head pf-section-head--blue">
        <h2 class="pf-section-title">COLLECTED</h2>
        <p class="pf-section-sub"><span id="pf-poster-count">0</span> blocks · /today drop history</p>
      </header>
      <div class="pf-poster__wall" id="pf-poster-wall">
        <p class="pf-poster__empty">Loading…</p>
      </div>
    </section>

    <section class="pf-earned">
      <header class="pf-section-head pf-section-head--red">
        <h2 class="pf-section-title">EARNED</h2>
        <p class="pf-section-sub">drum trophies + coffee mugs · pointcast collectibles</p>
      </header>
      <div class="pf-earned__group">
        <p class="pf-earned__group-label">DRUM TROPHIES · <span id="pf-trophy-count">0</span> / 8</p>
        <div class="pf-trophy-grid" id="pf-trophy-grid"></div>
      </div>
      <div class="pf-earned__group">
        <p class="pf-earned__group-label">COFFEE MUGS · <span id="pf-mug-count">0</span> / 5</p>
        <div class="pf-mug-grid" id="pf-mug-grid"></div>
      </div>
    </section>

    <section class="pf-rotation" id="pf-rotation-section" hidden>
      <header class="pf-section-head pf-section-head--green">
        <h2 class="pf-section-title">ROTATION</h2>
        <p class="pf-section-sub"><span id="pf-rot-count">0</span> spotify saves from <a href="/bath">/bath</a></p>
      </header>
      <div class="pf-rotation__grid" id="pf-rotation-grid"></div>
    </section>

    <section class="pf-ledger">
      <header class="pf-section-head pf-section-head--purple">
        <h2 class="pf-section-title">WALLETS</h2>
        <p class="pf-section-sub">paired on this browser · live tzkt data</p>
      </header>
      <div class="pf-ledger__body" id="pf-ledger-body">
        <p class="pf-ledger__empty">No wallets paired yet. <a href="/">Connect via the wallet chip on the home page.</a></p>
      </div>
    </section>

    <section class="pf-vault">
      <header class="pf-section-head pf-section-head--orange">
        <h2 class="pf-section-title">VAULT</h2>
        <p class="pf-section-sub" id="pf-vault-sub">Tezos NFTs · live from tzkt</p>
      </header>
      <div class="pf-vault__grid" id="pf-vault-grid">
        <p class="pf-vault__loading">LOADING VAULT…</p>
      </div>
      <p class="pf-vault__footer" id="pf-vault-footer"></p>
    </section>

    <aside class="pf-machine">
      <p class="pf-machine__label">MACHINE-READABLE</p>
      <ul>
        <li><a href="/for-agents">/for-agents</a></li>
        <li><a href="/blocks.json">/blocks.json</a></li>
      </ul>
    </aside>

  </main>
</BlockLayout>

<script>
  type Wallet = { chain: 'tezos'; address: string; provider: string; addedAt: number; label?: string };
  type CollectedItem = { date: string; blockId: string; at?: string };
  type Save = { spotify_url: string; spotify_type: string; spotify_id: string; mood: string; address?: string; timestamp: string };

  const KEY_WALLETS = 'pc:wallets';
  const KEY_ACTIVE = 'pc:wallet-active';

  function ls(k: string): string | null { try { return localStorage.getItem(k); } catch { return null; } }
  function shortAddr(a: string): string { return a.length > 12 ? `${a.slice(0,6)}…${a.slice(-4)}` : a; }
  function escHtml(s: string): string { return s.replace(/[&<>"']/g, (c) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' } as any)[c]); }
  function escAttr(s: string): string { return escHtml(s); }
  function cheapHashL(s: string): number { let h=5381; for (let i=0;i<s.length;i++) h=((h<<5)+h+s.charCodeAt(i))|0; return h>>>0; }
  function prettyDate(iso: string | null): string {
    if (!iso) return '—';
    try { return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }); } catch { return iso; }
  }

  function loadWallets(): Wallet[] { try { const r = ls(KEY_WALLETS); if (!r) return []; const a = JSON.parse(r); return Array.isArray(a) ? a : []; } catch { return []; } }
  function activeAddress(): string | null { return ls(KEY_ACTIVE); }
  function collectedList(): CollectedItem[] { try { const r = ls('pc:daily:collected'); if (!r) return []; const a = JSON.parse(r); return Array.isArray(a) ? a : []; } catch { return []; } }
  function bathSaves(): Save[] { try { const r = ls('pc:bath:saves'); if (!r) return []; const a = JSON.parse(r); return Array.isArray(a) ? a : []; } catch { return []; } }
  function pollsVotedCount(): number {
    let n = 0;
    try { for (let i = 0; i < localStorage.length; i++) { const k = localStorage.key(i); if (k && k.startsWith('pc:poll:voted:')) n++; } } catch {}
    return n;
  }
  function currentStreak(): number {
    try {
      const arr = collectedList();
      const dates: Record<string, boolean> = {};
      for (const c of arr) if (c && c.date) dates[c.date] = true;
      const today = new Intl.DateTimeFormat('en-CA', { timeZone: 'America/Los_Angeles' }).format(new Date());
      let streak = 0; let cur = today;
      while (dates[cur]) {
        streak++;
        const [y, m, d] = cur.split('-').map((s: string) => parseInt(s, 10));
        const dt = new Date(Date.UTC(y, m - 1, d));
        dt.setUTCDate(dt.getUTCDate() - 1);
        cur = dt.getUTCFullYear() + '-' + String(dt.getUTCMonth() + 1).padStart(2, '0') + '-' + String(dt.getUTCDate()).padStart(2, '0');
      }
      return streak;
    } catch { return 0; }
  }

  function paintHero() {
    let session = ls('pc:session');
    if (!session) {
      try { session = (crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2)); localStorage.setItem('pc:session', session); }
      catch { session = 'anon-' + Math.random().toString(36).slice(2); }
    }
    let nounId = 0;
    const cn = ls('pc:visitor:noun');
    if (cn) nounId = parseInt(cn, 10);
    if (!(nounId >= 0 && nounId < 1200)) {
      nounId = cheapHashL(session) % 1200;
      try { localStorage.setItem('pc:visitor:noun', String(nounId)); } catch {}
    }
    let firstSeen = ls('pc:visitor:firstSeenAt');
    if (!firstSeen) { firstSeen = new Date().toISOString(); try { localStorage.setItem('pc:visitor:firstSeenAt', firstSeen); } catch {} }

    const wallets = loadWallets();
    const active = activeAddress() || (wallets.length ? wallets[wallets.length - 1].address : null);
    const override = ls('pc:visitor:display');
    const isAgent = /gptbot|claudebot|claude-user|anthropic-ai|perplexitybot|oai-searchbot|atlas|google-extended|googlebot|bingbot/i.test(navigator.userAgent);

    let displayName = 'visitor';
    let kindLabel = 'human';
    if (override && override.trim()) { displayName = override.trim(); kindLabel = 'human · named'; }
    else if (active) { displayName = shortAddr(active); kindLabel = 'wallet'; }
    else if (isAgent) {
      const agents = ['GPTBot','ClaudeBot','Claude-User','anthropic-ai','PerplexityBot','OAI-SearchBot','Atlas','Google-Extended','Googlebot','Bingbot'];
      displayName = agents.find((a) => navigator.userAgent.toLowerCase().includes(a.toLowerCase())) || 'agent';
      kindLabel = 'agent';
    }
    else { displayName = 'noun-' + String(nounId).padStart(3, '0'); kindLabel = 'human · anonymous'; }

    const img = document.getElementById('pf-noun-img') as HTMLImageElement | null;
    if (img) { img.src = `https://noun.pics/${nounId}.svg`; img.alt = `your noun · ${nounId}`; }

    const tag = document.getElementById('pf-noun-tag');
    if (tag) tag.textContent = `noun #${nounId}`;

    const nameEl = document.getElementById('pf-name');
    if (nameEl) nameEl.textContent = displayName;

    const subEl = document.getElementById('pf-sub');
    if (subEl) {
      subEl.innerHTML = `<span class="pf-kind">${escHtml(kindLabel)}</span> · here since <time datetime="${firstSeen}">${prettyDate(firstSeen)}</time>`;
    }

    const chipsEl = document.getElementById('pf-chips');
    if (chipsEl) {
      const chips: string[] = [];
      if (active) chips.push(`<li class="pf-chip pf-chip--wallet"><span>WALLET</span><b>${escHtml(shortAddr(active))}</b></li>`);
      chips.push(`<li class="pf-chip pf-chip--noun"><span>NOUN</span><b>#${nounId}</b></li>`);
      chips.push(`<li class="pf-chip pf-chip--since"><span>SINCE</span><b>${escHtml(prettyDate(firstSeen))}</b></li>`);
      const sessHash = String(cheapHashL(session) % 100000).padStart(5, '0');
      chips.push(`<li class="pf-chip pf-chip--id"><span>SESSION</span><b>${sessHash}</b></li>`);
      chipsEl.innerHTML = chips.join('');
    }

    const mood = ls('pc:visitor:mood');
    const listening = ls('pc:visitor:listening');
    const where = ls('pc:visitor:where');
    const stateEl = document.getElementById('pf-state-line');
    if (stateEl) {
      const parts: string[] = [];
      if (mood) parts.push(`<span class="pf-state-pill pf-state-pill--mood">mood · ${escHtml(mood)}</span>`);
      if (listening) parts.push(`<span class="pf-state-pill">playing · ${escHtml(listening)}</span>`);
      if (where) parts.push(`<span class="pf-state-pill">where · ${escHtml(where)}</span>`);
      stateEl.innerHTML = parts.join(' ');
    }
  }

  function paintStats() {
    const grid = document.getElementById('pf-stats-grid');
    if (!grid) return;
    const helloCount = parseInt(ls('pc:hello:count') || '0', 10);
    const drops = collectedList().length;
    const streak = currentStreak();
    const polls = pollsVotedCount();
    const saves = bathSaves().length;
    const voter = (() => { try { const r = ls('pc:voter:state'); return r ? JSON.parse(r) : null; } catch { return null; } })();
    const level = voter?.level ?? 1;
    const xp = voter?.xp ?? 0;
    const wallets = loadWallets().length;

    const stats = [
      { k: 'BLOCKS',  v: drops,       sub: drops ? `${streak}-day streak` : 'visit /today',  color: 'yellow' },
      { k: 'SAVES',   v: saves,       sub: saves ? 'on rotation'           : 'visit /bath',   color: 'green'  },
      { k: 'POLLS',   v: polls,       sub: polls ? 'votes cast'            : 'tap a poll',    color: 'red'    },
      { k: 'HELLO',   v: helloCount,  sub: 'lifetime',                                         color: 'blue'   },
      { k: 'LEVEL',   v: 'L' + level, sub: xp + ' xp',                                         color: 'purple' },
      { k: 'WALLETS', v: wallets,     sub: wallets ? 'paired'              : 'none paired',   color: 'orange' },
    ];
    grid.innerHTML = stats.map((s) => `
      <div class="pf-tile pf-tile--${s.color}">
        <span class="pf-tile__label">${s.k}</span>
        <span class="pf-tile__value">${s.v}</span>
        <span class="pf-tile__sub">${escHtml(s.sub)}</span>
      </div>
    `).join('');
  }

  function paintPosters() {
    const list = collectedList().sort((a, b) => (b.date || '').localeCompare(a.date || ''));
    const wall = document.getElementById('pf-poster-wall');
    const count = document.getElementById('pf-poster-count');
    if (count) count.textContent = String(list.length);
    if (!wall) return;
    if (list.length === 0) {
      wall.innerHTML = '<p class="pf-poster__empty">Nothing collected yet. Visit <a href="/today">/today</a> to collect today&apos;s drop.</p>';
      return;
    }
    wall.innerHTML = list.slice(0, 36).map((d) => `
      <a class="pf-poster__tile" href="/b/${escAttr(d.blockId)}" title="Block №${escAttr(d.blockId)}">
        <div class="pf-poster__img">
          <img src="/images/og/b/${escAttr(d.blockId)}.png" alt="Block №${escAttr(d.blockId)}" loading="lazy"
            onerror="this.parentElement.classList.add('pf-poster__img--err')" />
          <span class="pf-poster__num">№${escHtml(d.blockId)}</span>
        </div>
        <div class="pf-poster__caption">
          <span class="pf-poster__date">${escHtml(d.date || '—')}</span>
        </div>
      </a>
    `).join('');
  }

  const MOOD_DOT: Record<string, string> = {
    warm:'#F5A623', cool:'#4A9EFF', electric:'#FF00AA', earth:'#7B9E5E',
    void:'#8060C0', dawn:'#FFB4A2', neon:'#39FF14', ocean:'#00B4D8',
  };
  function paintRotation() {
    const saves = bathSaves();
    const sec = document.getElementById('pf-rotation-section');
    const grid = document.getElementById('pf-rotation-grid');
    const cnt = document.getElementById('pf-rot-count');
    if (!sec || !grid) return;
    if (!saves.length) { sec.hidden = true; return; }
    sec.hidden = false;
    if (cnt) cnt.textContent = String(saves.length);
    grid.innerHTML = saves.slice(0, 18).map((s) => {
      const dot = MOOD_DOT[s.mood] || '#888';
      const date = s.timestamp ? new Date(s.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '—';
      const type = (s.spotify_type || '').toUpperCase();
      const url = s.spotify_url || `https://open.spotify.com/${escAttr(s.spotify_type)}/${escAttr(s.spotify_id)}`;
      const eh = s.spotify_type === 'track' ? '80' : '152';
      return `
        <div class="pf-cassette">
          <div class="pf-cassette__stripe" style="background:${dot};box-shadow:0 0 12px ${dot}55"></div>
          <div class="pf-cassette__body">
            <iframe src="https://open.spotify.com/embed/${escAttr(s.spotify_type)}/${escAttr(s.spotify_id)}?utm_source=pointcast"
              width="100%" height="${eh}" frameborder="0"
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
            <div class="pf-cassette__meta">
              <span class="pf-cassette__type">${type}</span>
              <span class="pf-cassette__mood">${escHtml(s.mood)}</span>
              <span class="pf-cassette__date">${date}</span>
              <a class="pf-cassette__open" href="${escAttr(url)}" target="_blank" rel="noopener">open ↗</a>
            </div>
          </div>
        </div>
      `;
    }).join('');
  }

  interface Stats { balance: string; nfts: string; ops: string; lastActivity: string; }
  async function fetchStats(addr: string): Promise<Stats> {
    try {
      const [a, n] = await Promise.all([
        fetch(`https://api.tzkt.io/v1/accounts/${addr}`),
        fetch(`https://api.tzkt.io/v1/tokens/balances/count?account=${addr}&balance.gt=0`),
      ]);
      const acc = a.ok ? await a.json() : {};
      const nfts = n.ok ? (await n.text()).trim() : '—';
      return {
        balance: ((acc.balance ?? 0) / 1_000_000).toFixed(2) + ' ꜩ',
        nfts: String(nfts),
        ops: String(acc.numTransactions ?? '—'),
        lastActivity: acc.lastActivity
          ? new Date(acc.lastActivity).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: '2-digit' })
          : '—',
      };
    } catch { return { balance:'—', nfts:'—', ops:'—', lastActivity:'—' }; }
  }

  function paintLedger() {
    const wallets = loadWallets();
    const active = activeAddress();
    const body = document.getElementById('pf-ledger-body');
    if (!body) return;
    if (wallets.length === 0) {
      body.innerHTML = '<p class="pf-ledger__empty">No wallets paired yet. <a href="/">Connect via the wallet chip on the home page.</a></p>';
      return;
    }
    const sorted = [...wallets].sort((a, b) => b.addedAt - a.addedAt);
    body.innerHTML = `
      <div class="pf-table">
        <div class="pf-table__head">
          <span>provider</span>
          <span>address</span>
          <span class="pf-table__num">balance</span>
          <span class="pf-table__num">nfts</span>
          <span class="pf-table__num">ops</span>
          <span class="pf-table__num">last</span>
          <span>added</span>
          <span></span>
        </div>
        ${sorted.map((w) => {
          const isActive = w.address === active || (!active && w === sorted[0]);
          const added = new Date(w.addedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: '2-digit' });
          return `
            <div class="pf-table__row${isActive ? ' pf-table__row--active' : ''}" data-addr="${escAttr(w.address)}">
              <span class="pf-table__provider">
                ${isActive ? '<span class="pf-table__dot" title="active"></span>' : '<span class="pf-table__dot pf-table__dot--off" title="paired"></span>'}
                ${escHtml(w.provider)}
              </span>
              <span class="pf-table__addr"><a href="https://tzkt.io/${escAttr(w.address)}" target="_blank" rel="noopener">${escHtml(shortAddr(w.address))}</a></span>
              <span class="pf-table__num" data-stat="balance">…</span>
              <span class="pf-table__num" data-stat="nfts">…</span>
              <span class="pf-table__num" data-stat="ops">…</span>
              <span class="pf-table__num" data-stat="lastActivity">…</span>
              <span class="pf-table__added">${added}</span>
              <span class="pf-table__actions">
                ${isActive ? '<span class="pf-table__pill">active</span>' : `<button class="pf-table__btn" data-action="switch" data-addr="${escAttr(w.address)}">use</button>`}
                <a class="pf-table__btn" href="https://objkt.com/profile/${escAttr(w.address)}/owned" target="_blank" rel="noopener">objkt</a>
              </span>
            </div>
          `;
        }).join('')}
      </div>
    `;

    sorted.forEach((w) => {
      const row = body.querySelector(`[data-addr="${w.address}"]`);
      if (!row) return;
      fetchStats(w.address).then((s) => {
        const q = (k: string) => row.querySelector(`[data-stat="${k}"]`);
        if (q('balance'))      (q('balance') as HTMLElement).textContent = s.balance;
        if (q('nfts'))         (q('nfts') as HTMLElement).textContent = s.nfts;
        if (q('ops'))          (q('ops') as HTMLElement).textContent = s.ops;
        if (q('lastActivity')) (q('lastActivity') as HTMLElement).textContent = s.lastActivity;
      });
    });

    body.querySelectorAll<HTMLElement>('[data-action="switch"]').forEach((b) => {
      b.addEventListener('click', () => {
        const addr = b.dataset.addr!;
        const list = loadWallets();
        try { localStorage.setItem(KEY_WALLETS, JSON.stringify(list)); } catch {}
        try { localStorage.setItem(KEY_ACTIVE, addr); } catch {}
        const active = list.find((w) => w.address === addr) ?? null;
        if (active) try { localStorage.setItem('pc:wallet', JSON.stringify(active)); } catch {}
        window.dispatchEvent(new CustomEvent('pc:wallet-change', { detail: active }));
        repaint();
      });
    });
  }

  const MIKE_WALLET = 'tz2FjJhB1gb9Xc2qNB7QgFkdBZkGCCRMxdFw';
  const IPFS = 'https://ipfs.io/ipfs/';
  function ipfsHttp(u: string | null | undefined): string | null {
    if (!u) return null;
    if (u.startsWith('ipfs://')) return IPFS + u.slice(7);
    if (u.startsWith('http')) return u;
    return null;
  }
  async function paintVault() {
    const grid = document.getElementById('pf-vault-grid');
    const sub = document.getElementById('pf-vault-sub');
    const footer = document.getElementById('pf-vault-footer');
    if (!grid || !sub || !footer) return;
    const active = activeAddress();
    const wallets = loadWallets();
    const target = active || (wallets[0]?.address) || MIKE_WALLET;
    const isOwn = !!active || wallets.length > 0;
    sub.innerHTML = isOwn
      ? `your wallet · <code>${escHtml(shortAddr(target))}</code> · live from tzkt`
      : `Mike&apos;s wallet · <code>${escHtml(shortAddr(target))}</code> · connect your own to see yours`;
    try {
      const url = `https://api.tzkt.io/v1/tokens/balances?account=${target}&token.standard=fa2&balance.gt=0&limit=60&sort.desc=lastTime&select=token.contract.address as contract,token.tokenId as tokenId,token.metadata as metadata,token.totalSupply as supply,balance`;
      const r = await fetch(url);
      if (!r.ok) throw new Error(`tzkt ${r.status}`);
      const raw: any[] = await r.json();
      const tokens = raw.map((t) => {
        const m = t.metadata || {};
        return {
          contract: t.contract,
          tokenId: String(t.tokenId),
          name: m.name || `Token #${t.tokenId}`,
          thumb: ipfsHttp(m.thumbnailUri) || ipfsHttp(m.displayUri) || ipfsHttp(m.artifactUri) || null,
          supply: Number(t.supply ?? 0),
          balance: Number(t.balance ?? 0),
        };
      }).filter((t) => t.thumb);

      if (tokens.length === 0) {
        grid.innerHTML = '<p class="pf-vault__empty">No NFTs in this wallet yet.</p>';
        footer.textContent = '';
        return;
      }
      grid.innerHTML = tokens.slice(0, 36).map((t) => `
        <a class="pf-nft" href="https://objkt.com/tokens/${escAttr(t.contract)}/${escAttr(t.tokenId)}" target="_blank" rel="noopener">
          <div class="pf-nft__art"><img src="${escAttr(t.thumb!)}" alt="${escAttr(t.name)}" loading="lazy" /></div>
          <p class="pf-nft__name">${escHtml(t.name)}</p>
          <p class="pf-nft__meta">×${t.balance}${t.supply > 0 ? ` · ${t.supply} ed` : ''}</p>
        </a>
      `).join('');
      footer.textContent = `${tokens.length} held · objkt.com links`;
    } catch (e: any) {
      grid.innerHTML = `<p class="pf-vault__error">Couldn&apos;t load vault: ${escHtml(e?.message || 'unknown')}.</p>`;
      footer.textContent = '';
    }
  }

  type Trophy = { id: string; title: string; nounId: number; eyebrow: string; surface: string; threshold: number; progressKey: string; progressType: 'count' | 'set' | 'meta' };
  const TROPHIES: Trophy[] = [
    { id: 'first-tap',        title: 'First Tap',        nounId: 666, eyebrow: 'novice',           surface: '/drum',          threshold:    1, progressKey: 'pc:drumLocalCount',       progressType: 'count' },
    { id: 'true-drummer',     title: 'True Drummer',     nounId: 700, eyebrow: '100 drums',        surface: '/drum-v2',       threshold:  100, progressKey: 'pc:drumLocalCount',       progressType: 'count' },
    { id: 'master-drummer',   title: 'Master Drummer',   nounId: 777, eyebrow: '1,000 drums',      surface: '/drum-v2',       threshold: 1000, progressKey: 'pc:drumLocalCount',       progressType: 'count' },
    { id: 'orchestra-master', title: 'Orchestra Master', nounId: 808, eyebrow: 'all 12 instruments', surface: '/drum-v4',     threshold:   12, progressKey: 'pc:drum-v4:collected',    progressType: 'set'   },
    { id: 'choir-master',     title: 'Choir Master',     nounId: 888, eyebrow: 'all 12 voices',    surface: '/drum-v6',       threshold:   12, progressKey: 'pc:drum-v6:sung',         progressType: 'set'   },
    { id: 'loop-creator',     title: 'Loop Creator',     nounId: 909, eyebrow: 'shared a loop',    surface: '/drum-v5',       threshold:    1, progressKey: 'pc:drum-v5:shared-count', progressType: 'count' },
    { id: 'spotify-jam',      title: 'Spotify Jam',      nounId: 420, eyebrow: 'set the room track', surface: '/drum-v3',     threshold:    1, progressKey: 'pc:drum-v3:track-count',  progressType: 'count' },
    { id: 'grand-master',     title: 'Grand Master',     nounId: 999, eyebrow: 'all trophies',     surface: '/drum-trophies', threshold:    7, progressKey: '_meta',                   progressType: 'meta'  },
  ];
  function trophyProgress(t: Trophy, earnedSet: Set<string>): { current: number; earned: boolean } {
    if (t.progressType === 'meta') return { current: earnedSet.size, earned: earnedSet.size >= t.threshold };
    const raw = ls(t.progressKey);
    if (t.progressType === 'count') { const n = raw ? parseInt(raw, 10) || 0 : 0; return { current: n, earned: n >= t.threshold }; }
    let size = 0;
    if (raw) { try { const a = JSON.parse(raw); if (Array.isArray(a)) size = a.length; else if (a && typeof a === 'object') size = Object.keys(a).length; } catch {} }
    return { current: size, earned: size >= t.threshold };
  }
  function paintTrophies() {
    const grid = document.getElementById('pf-trophy-grid');
    const countEl = document.getElementById('pf-trophy-count');
    if (!grid) return;
    const earnedIds = new Set<string>();
    TROPHIES.forEach((t) => { if (t.progressType !== 'meta') { const { earned } = trophyProgress(t, earnedIds); if (earned) earnedIds.add(t.id); } });
    let total = 0;
    grid.innerHTML = TROPHIES.map((t) => {
      const { current, earned } = trophyProgress(t, earnedIds);
      if (earned) total++;
      const remaining = Math.max(0, t.threshold - current);
      const status = earned ? '<span class="pf-trophy__pill pf-trophy__pill--won">earned</span>' : `<span class="pf-trophy__pill">${remaining} to go</span>`;
      const pct = Math.min(100, Math.round((current / Math.max(1, t.threshold)) * 100));
      return `<a class="pf-trophy${earned ? ' pf-trophy--earned' : ''}" href="${escAttr(t.surface)}" title="${escAttr(t.title)}"><div class="pf-trophy__noun"><img src="https://noun.pics/${t.nounId}.svg" alt="Noun ${t.nounId}" loading="lazy" /><span class="pf-trophy__nounid">#${t.nounId}</span></div><div class="pf-trophy__body"><p class="pf-trophy__eyebrow">${escHtml(t.eyebrow)}</p><h3 class="pf-trophy__title">${escHtml(t.title)}</h3>${status}<div class="pf-trophy__bar"><div class="pf-trophy__bar-fill" style="width:${pct}%"></div></div></div></a>`;
    }).join('');
    if (countEl) countEl.textContent = String(total);
  }
  function paintMugs() {
    const grid = document.getElementById('pf-mug-grid');
    const countEl = document.getElementById('pf-mug-count');
    if (!grid) return;
    const MUGS = [
      { slug: 'ceramic',  label: 'Ceramic',  rarity: 'common',     editions: 333, threshold: 1,  hex: '#5F5E5A' },
      { slug: 'espresso', label: 'Espresso', rarity: 'uncommon',   editions: 144, threshold: 3,  hex: '#0F6E56' },
      { slug: 'latte',    label: 'Latte',    rarity: 'rare',       editions:  64, threshold: 7,  hex: '#185FA5' },
      { slug: 'paper',    label: 'Paper',    rarity: 'ultra-rare', editions:  21, threshold: 15, hex: '#993556' },
      { slug: 'bistro',   label: 'Bistro',   rarity: 'legendary',  editions:   8, threshold: 30, hex: '#c4952e' },
    ];
    let claims: Record<string, any> = {};
    try { const raw = ls('pc:coffee:claims'); if (raw) claims = JSON.parse(raw) || {}; } catch {}
    const cups = (() => { try { return parseInt(ls('pc:coffee:count') || '0', 10) || 0; } catch { return 0; } })();
    let claimed = 0;
    grid.innerHTML = MUGS.map((m) => {
      const has = !!claims[m.slug];
      if (has) claimed++;
      const remaining = Math.max(0, m.threshold - cups);
      const state = has ? '<span class="pf-mug__pill pf-mug__pill--won">claimed</span>' : (remaining === 0 ? '<span class="pf-mug__pill pf-mug__pill--ready">ready</span>' : `<span class="pf-mug__pill">${remaining} cups</span>`);
      return `<a class="pf-mug${has ? ' pf-mug--won' : ''}" href="/coffee" title="${escAttr(m.label)} · ${escAttr(m.rarity)} · ${m.editions} editions"><div class="pf-mug__art" style="background:${m.hex}22;border-color:${m.hex}"><img src="/images/coffee-mugs/${m.slug}.svg" alt="${escAttr(m.label)} mug" loading="lazy" /></div><p class="pf-mug__label">${escHtml(m.label)}</p><p class="pf-mug__rarity" style="color:${m.hex}">${escHtml(m.rarity.toUpperCase())} · ${m.editions} ED</p>${state}</a>`;
    }).join('');
    if (countEl) countEl.textContent = String(claimed);
  }

  function repaint() {
    paintHero();
    paintStats();
    paintPosters();
    paintTrophies();
    paintMugs();
    paintRotation();
    paintLedger();
    void paintVault();
  }
  repaint();
  window.addEventListener('storage', repaint);
  window.addEventListener('pc:wallet-change', repaint);
</script>

<style is:global>
  :root {
    --pf-paper:    #f5efe4;
    --pf-paper-2:  #ede5d3;
