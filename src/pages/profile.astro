  }

  .pf {
    max-width: 980px;
    margin: 0 auto;
    padding: 28px 18px 100px;
    background:
      radial-gradient(circle at 1px 1px, rgba(31,27,21,.06) 1px, transparent 0) 0 0/22px 22px,
      var(--pf-paper);
