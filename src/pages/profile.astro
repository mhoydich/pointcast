  .pf-earned__group { margin: 0 0 18px; }
  .pf-earned__group:last-child { margin-bottom: 0; }
  .pf-earned__group-label { font-family: 'JetBrains Mono Variable', monospace; font-size: 9.5px; letter-spacing: 0.20em; font-weight: 700; margin: 0 0 10px; color: var(--pf-ink); opacity: 0.78; }
  .pf-earned__group-label span { color: var(--pf-red); }
  .pf-trophy-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px; }
  .pf-trophy { display: flex; align-items: stretch; text-decoration: none; color: inherit; background: #fff; border: 2px solid var(--pf-ink); box-shadow: 3px 3px 0 0 var(--pf-ink); transition: transform 0.12s ease, box-shadow 0.12s ease; overflow: hidden; opacity: 0.6; }
  .pf-trophy:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 0 var(--pf-ink); }
  .pf-trophy--earned { opacity: 1; background: linear-gradient(180deg, #fffbe6 0%, #fef0bd 100%); }
  .pf-trophy__noun { width: 80px; flex-shrink: 0; background: var(--pf-paper-2); border-right: 2px solid var(--pf-ink); position: relative; display: flex; align-items: center; justify-content: center; }
  .pf-trophy--earned .pf-trophy__noun { background: var(--pf-yellow); }
  .pf-trophy__noun img { width: 100%; height: auto; display: block; image-rendering: pixelated; filter: grayscale(0.85) opacity(0.6); }
  .pf-trophy--earned .pf-trophy__noun img { filter: none; }
  .pf-trophy__nounid { position: absolute; bottom: 3px; left: 3px; background: var(--pf-ink); color: var(--pf-paper); font-family: 'JetBrains Mono Variable', monospace; font-size: 8px; letter-spacing: 0.10em; padding: 1px 4px; font-weight: 700; }
  .pf-trophy__body { flex: 1; min-width: 0; padding: 8px 10px 10px; display: flex; flex-direction: column; gap: 3px; }
  .pf-trophy__eyebrow { font-family: 'JetBrains Mono Variable', monospace; font-size: 8.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--pf-ink-soft); margin: 0; font-weight: 700; }
  .pf-trophy__title { font-family: 'Lora', Georgia, serif; font-size: 16px; font-weight: 600; line-height: 1.1; margin: 0; color: var(--pf-ink); }
  .pf-trophy__pill { display: inline-block; align-self: flex-start; background: #fff; border: 1px solid var(--pf-ink-soft); padding: 1px 7px; font-family: 'JetBrains Mono Variable', monospace; font-size: 8.5px; letter-spacing: 0.14em; font-weight: 700; color: var(--pf-ink-soft); margin-top: 2px; }
  .pf-trophy__pill--won { background: var(--pf-green); border-color: var(--pf-ink); color: var(--pf-ink); }
  .pf-trophy__bar { height: 4px; background: var(--pf-paper-2); border: 1px solid var(--pf-ink); margin-top: auto; overflow: hidden; }
  .pf-trophy__bar-fill { height: 100%; background: var(--pf-yellow); transition: width 0.5s ease; }
  .pf-trophy--earned .pf-trophy__bar-fill { background: var(--pf-green); }
  .pf-mug-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
  .pf-mug { display: flex; flex-direction: column; align-items: center; gap: 4px; text-decoration: none; color: inherit; background: #fff; border: 2px solid var(--pf-ink); box-shadow: 3px 3px 0 0 var(--pf-ink); padding: 10px 8px 8px; transition: transform 0.12s ease, box-shadow 0.12s ease; opacity: 0.7; }
  .pf-mug:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 0 var(--pf-ink); }
  .pf-mug--won { opacity: 1; }
  .pf-mug__art { width: 100%; aspect-ratio: 1; background: var(--pf-paper-2); border: 2px solid var(--pf-ink); display: flex; align-items: center; justify-content: center; image-rendering: pixelated; }
  .pf-mug__art img { width: 80%; height: 80%; image-rendering: pixelated; }
  .pf-mug__label { font-family: 'Lora', Georgia, serif; font-size: 13px; font-weight: 600; margin: 4px 0 0; color: var(--pf-ink); }
  .pf-mug__rarity { font-family: 'JetBrains Mono Variable', monospace; font-size: 8px; letter-spacing: 0.16em; font-weight: 700; margin: 0; opacity: 0.85; }
  .pf-mug__pill { background: #fff; border: 1px solid var(--pf-ink-soft); padding: 1px 7px; font-family: 'JetBrains Mono Variable', monospace; font-size: 8px; letter-spacing: 0.14em; font-weight: 700; color: var(--pf-ink-soft); margin-top: 2px; }
  .pf-mug__pill--won { background: var(--pf-green); border-color: var(--pf-ink); color: var(--pf-ink); }
  .pf-mug__pill--ready { background: var(--pf-yellow); border-color: var(--pf-ink); color: var(--pf-ink); }
  @media (max-width: 580px) { .pf-mug-grid { grid-template-columns: repeat(3, 1fr); } .pf-trophy-grid { grid-template-columns: 1fr; } }

  .pf-rotation__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 12px; }
  .pf-cassette { display: flex; background: #fff; border: 2px solid var(--pf-ink); box-shadow: 3px 3px 0 0 var(--pf-ink); overflow: hidden; }
  .pf-cassette__stripe { width: 8px; flex-shrink: 0; }
  .pf-cassette__body { flex: 1; min-width: 0; }
  .pf-cassette__body iframe { display: block; width: 100%; border: none; }
