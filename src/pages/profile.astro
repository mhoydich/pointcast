  }
  .pf-hero__stamp-line { font-size: 10px; letter-spacing: 0.14em; font-weight: 700; opacity: 0.95; }
  .pf-hero__stamp-line--big { font-size: 22px; letter-spacing: 0.04em; line-height: 1; margin: 2px 0; }

  .pf-arcade__grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; }
  .pf-tile {
    border: 2px solid var(--pf-ink);
