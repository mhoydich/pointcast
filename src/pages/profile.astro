---
/**
 * /profile — visualize every wallet this browser has paired with.
 *
 * Reads pc:wallets from localStorage (set by WalletChip). Pulls live
 * TzKT data for each (balance, NFT count, ops count, last activity).
 * Shows which is active. Lets the user switch active / remove any.
 *
 * All client-side — no server state. "Your profile" is scoped to this
 * browser + whatever Beacon sessions live in its storage.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import { getCollection } from 'astro:content';
import contracts from '../data/contracts.json';
import market from '../data/market.json';
import { ZEN_CAT_GENESIS_COLLECTIBLES, ZEN_CAT_WORLD_COLLECTIBLES } from '../data/zen-cat-collectibles';
import {
  SHARE_CAMPAIGN_PACKETS,
  SHARE_LANDING_PAGES,
  SHARE_LAUNCH_ASSETS,
  SHARE_SNIPPETS,
} from '../lib/share-kit';

const SITE_URL = 'https://pointcast.xyz';
const absolute = (path: string) => new URL(path, SITE_URL).href;
const isUrl = (value: unknown): value is string => typeof value === 'string' && /^https?:\/\//.test(value);
const local = (path: string) => path.startsWith('http') ? path : absolute(path);

const blocks = (await getCollection('blocks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());
const polls = (await getCollection('polls', ({ data }) => !data.draft))
  .sort((a, b) => b.data.openedAt.getTime() - a.data.openedAt.getTime());
const drops = (await getCollection('drops', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const products = (await getCollection('products', ({ data }) => !data.draft))
  .sort((a, b) => b.data.addedAt.getTime() - a.data.addedAt.getTime());
const gallery = (await getCollection('gallery', ({ data }) => !data.draft))
  .sort((a, b) => b.data.createdAt.getTime() - a.data.createdAt.getTime());
const ethLegacy = (await getCollection('ethLegacy', ({ data }) => !data.draft))
  .sort((a, b) => b.data.addedAt.getTime() - a.data.addedAt.getTime());
const mesh = (await getCollection('mesh', ({ data }) => data.listed !== false))
  .sort((a, b) => b.data.addedAt.getTime() - a.data.addedAt.getTime());

const marketTokens = ((market as any).tokens ?? []) as Array<any>;
const listedMarketTokens = marketTokens.filter((token) => token.listed);
const editionBlocks = blocks.filter((block) => block.data.edition || block.data.type === 'MINT' || block.data.type === 'FAUCET');
const mintBlocks = blocks.filter((block) => block.data.type === 'MINT');
const faucetBlocks = blocks.filter((block) => block.data.type === 'FAUCET');
const mediaBlocks = blocks.filter((block) => block.data.media);
const spotifyBlocks = blocks.filter((block) => {
  const mediaSrc = block.data.media?.src ?? '';
  const externalUrl = block.data.external?.url ?? '';
  return /spotify\.com/i.test(mediaSrc) || /spotify\.com/i.test(externalUrl);
});
const companionBlocks = blocks.filter((block) => (block.data.companions ?? []).length > 0);
const nounBlocks = blocks.filter((block) => typeof block.data.noun === 'number');
const recentNounBlocks = nounBlocks.slice(0, 18);

const visitNounsKt1 = ((contracts as any).visit_nouns?.mainnet ?? '').trim();
const drumTokenKt1 = ((contracts as any).drum_token?.mainnet ?? '').trim();
const prizeCastKt1 = ((contracts as any).prize_cast?.mainnet ?? '').trim();
const zenCatCount = ZEN_CAT_GENESIS_COLLECTIBLES.length + ZEN_CAT_WORLD_COLLECTIBLES.length;

type UrlRow = { label: string; url: string; source: string; kind: string };
const urlRows: UrlRow[] = [];
const addUrl = (label: string, url: unknown, source: string, kind: string) => {
  if (!isUrl(url)) return;
  urlRows.push({ label, url, source, kind });
};

for (const block of blocks) {
  addUrl(block.data.title, block.data.external?.url, `/b/${block.data.id} external`, block.data.type);
  addUrl(block.data.title, block.data.media?.src, `/b/${block.data.id} media`, block.data.media?.kind ?? 'media');
  for (const companion of block.data.companions ?? []) {
    if (companion.surface === 'external') addUrl(companion.label, companion.id, `/b/${block.data.id} companion`, 'companion');
  }
}
for (const drop of drops) addUrl(drop.data.title ?? drop.id, drop.data.url, `/drop/${drop.id}`, drop.data.type);
for (const product of products) addUrl(product.data.name, product.data.url, `/products/${product.data.slug}`, 'product');
for (const node of mesh) {
  addUrl(node.data.name, node.data.url, `/mesh/${node.data.slug}`, 'mesh');
  addUrl(`${node.data.name} feed`, node.data.feedUrl, `/mesh/${node.data.slug}`, 'feed');
}
for (const page of SHARE_LANDING_PAGES) addUrl(page.title, local(page.path), '/share landing page', 'share');
for (const snippet of SHARE_SNIPPETS) addUrl(snippet.label, local(snippet.target), '/share snippet', 'share');
for (const asset of SHARE_LAUNCH_ASSETS) addUrl(asset.title, local(asset.url), '/share launch asset', 'share');
for (const packet of SHARE_CAMPAIGN_PACKETS) {
  addUrl(packet.title, local(packet.targetPath), '/share campaign', 'campaign');
  for (const proof of packet.proofLinks) addUrl(`${packet.title} proof`, local(proof), '/share proof', 'campaign-proof');
}

const urlMap = new Map<string, UrlRow>();
for (const row of urlRows) if (!urlMap.has(row.url)) urlMap.set(row.url, row);
const sourcedUrls = [...urlMap.values()].sort((a, b) => a.kind.localeCompare(b.kind) || a.label.localeCompare(b.label));

const collectibleLanes = [
  {
    label: 'Visit Nouns',
    value: visitNounsKt1 ? 'live' : 'pending',
    note: 'Open-supply Tezos FA2; every tokenId maps to a Nouns seed.',
    href: '/collection/visit-nouns',
    noun: 137,
  },
  {
    label: 'Market inventory',
    value: `${marketTokens.length}`,
    note: `${listedMarketTokens.length} listed from objkt snapshot in src/data/market.json.`,
    href: '/collect',
    noun: 221,
  },
  {
    label: 'Mint + faucet blocks',
    value: `${editionBlocks.length}`,
    note: `${mintBlocks.length} mint blocks and ${faucetBlocks.length} faucet blocks sourced from block JSON.`,
    href: '/editions',
    noun: editionBlocks[0]?.data.noun ?? 927,
  },
  {
    label: 'Tezos holdings',
    value: 'live',
    note: 'Build-time TzKT wallet collection rendered at /collection.',
    href: '/collection',
    noun: 304,
  },
  {
    label: 'Zen Cats',
    value: `${zenCatCount}`,
    note: `${ZEN_CAT_GENESIS_COLLECTIBLES.length} genesis and ${ZEN_CAT_WORLD_COLLECTIBLES.length} world collectibles.`,
    href: '/zen-cats',
    noun: 368,
  },
  {
    label: 'ETH legacy',
    value: `${ethLegacy.length}`,
    note: 'Retrospective token deployments indexed from src/content/eth-legacy.',
    href: '/eth-legacy',
    noun: 45,
  },
];

const surfaceLanes = [
  { label: 'Shared URLs', value: `${sourcedUrls.length}`, note: 'External, media, drop, mesh, product, and share-kit URLs.', href: '/share', noun: 889 },
  { label: 'Spotify / listen', value: `${spotifyBlocks.length}`, note: 'LISTEN blocks and Spotify embeds discovered from block media + external URLs.', href: spotifyBlocks[0] ? `/b/${spotifyBlocks[0].data.id}` : '/blocks.json', noun: spotifyBlocks[0]?.data.noun ?? 222 },
  { label: 'Polls / voting', value: `${polls.length}`, note: 'Schelling-point polls with local vote memory and KV-backed tally endpoints.', href: '/polls', noun: 272 },
  { label: 'Drops', value: `${drops.length}`, note: 'Paste-a-URL inbox archive: Spotify, products, places, articles, and generic links.', href: '/drop', noun: 91 },
  { label: 'Companions', value: `${companionBlocks.length}`, note: 'Blocks with linked polls, clocks, YeePlayer titles, externals, or sibling blocks.', href: '/blocks.json', noun: 1111 },
  { label: 'Gallery + media', value: `${gallery.length + mediaBlocks.length}`, note: `${gallery.length} gallery entries and ${mediaBlocks.length} block media embeds.`, href: '/gallery', noun: 404 },
];

const recentEditionBlocks = editionBlocks.slice(0, 6);
const recentUrls = sourcedUrls.slice(0, 72);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': 'https://pointcast.xyz/profile',
  name: 'PointCast profile v3',
  description: 'Sourced PointCast profile: collectible audit, shared URLs, Spotify/listen links, polls, drops, products, and wallet-local memory.',
  url: 'https://pointcast.xyz/profile',
};
---

<BlockLayout title="Profile v3" description="Sourced PointCast profile: collectibles, shared URLs, Spotify/listen links, voting, drops, products, and wallet-local memory." jsonLd={jsonLd}>
  <div class="page" data-profile-version="v3">
    <nav class="crumb">
      <a href="/">← Home</a>
      <span aria-hidden="true">/</span>
      <span>profile</span>
    </nav>

    <nav class="version-switch" aria-label="Profile version">
      <button type="button" data-version-switch="v3" aria-pressed="true">v3 sourced audit</button>
      <button type="button" data-version-switch="v2" aria-pressed="false">v2 activity</button>
      <button type="button" data-version-switch="v1" aria-pressed="false">v1 identity</button>
    </nav>

    <!-- ─── V3 SOURCED PROFILE ─── -->
    <section class="v3" data-profile-panel="v3">
      <header class="v3-hero">
        <p class="kicker">PROFILE V3 · SOURCED POINTCAST</p>
        <h1>Collectibles, shared URLs, votes, links, drops, and weird useful surfaces.</h1>
        <p class="v3-hero__dek">
          This profile audits what PointCast already knows at build time:
          block editions, Tezos collections, market inventory, Zen Cats, ETH
          legacy tokens, Spotify/listen embeds, polls, products, drops, mesh
          nodes, and share-kit URLs. Older browser-local profile views stay one
          tap away.
        </p>
        <div class="noun-rail" aria-label="Recent PointCast nouns">
          {recentNounBlocks.slice(0, 10).map((block) => (
            <a href={`/b/${block.data.id}`} title={`${block.data.title} · Noun ${block.data.noun}`}>
              <img src={`https://noun.pics/${block.data.noun}.svg`} alt={`Noun ${block.data.noun}`} loading="lazy" />
              <span>№{block.data.noun}</span>
            </a>
          ))}
        </div>
      </header>

      <section class="audit-grid" aria-label="Collectible sources">
        {collectibleLanes.map((lane) => (
          <a class="audit-card" href={lane.href}>
            <img class="audit-card__noun" src={`https://noun.pics/${lane.noun}.svg`} alt="" loading="lazy" />
            <span class="audit-card__label">{lane.label}</span>
            <strong>{lane.value}</strong>
            <span>{lane.note}</span>
          </a>
        ))}
      </section>

      <section class="audit-grid audit-grid--surfaces" aria-label="PointCast surfaces">
        {surfaceLanes.map((lane) => (
          <a class="audit-card audit-card--surface" href={lane.href}>
            <img class="audit-card__noun" src={`https://noun.pics/${lane.noun}.svg`} alt="" loading="lazy" />
            <span class="audit-card__label">{lane.label}</span>
            <strong>{lane.value}</strong>
            <span>{lane.note}</span>
          </a>
        ))}
      </section>

      <section class="source-panel">
        <div class="source-panel__head">
          <div>
            <p class="kicker">COLLECTIBLE LEDGER</p>
            <h2>Every source lane feeding profile v3.</h2>
          </div>
          <a href="/editions.json">/editions.json</a>
        </div>
        <div class="ledger">
          <article>
            <h3>On-chain + market</h3>
            <ul>
              <li><a href="/collection/visit-nouns">Visit Nouns</a> · contract <code>{visitNounsKt1 || 'pending'}</code></li>
              <li><a href="/collect">Collector market</a> · <code>{(market as any).contract}</code> · {marketTokens.length} tokens · {listedMarketTokens.length} listed</li>
              <li><a href="/collection">Mike's Tezos holdings</a> · TzKT live at build time</li>
              <li>DRUM · <code>{drumTokenKt1 || 'pending origination'}</code></li>
              <li>Prize Cast · <code>{prizeCastKt1 || 'pending origination'}</code></li>
            </ul>
          </article>
          <article>
            <h3>Native PointCast collectibles</h3>
            <ul>
              <li><a href="/editions">Editions dashboard</a> · {editionBlocks.length} edition/faucet/mint blocks</li>
              <li><a href="/zen-cats">Zen Cats</a> · {zenCatCount} browser-local collectible cats</li>
              <li><a href="/eth-legacy">ETH legacy</a> · {ethLegacy.length} historical deployments</li>
              <li><a href="/gallery">Gallery</a> · {gallery.length} image works</li>
              <li><a href="/today">Daily drop</a> · browser-local collection at <code>pc:daily:collected</code></li>
            </ul>
          </article>
          <article>
            <h3>Interaction surfaces</h3>
            <ul>
              <li><a href="/polls">Voting</a> · {polls.length} poll definitions</li>
              <li><a href="/drop">Drop inbox</a> · {drops.length} archived dropped URLs</li>
              <li><a href="/products">Products</a> · {products.length} Good Feels/product entries</li>
              <li><a href="/mesh">Mesh</a> · {mesh.length} nodes and feeds</li>
              <li><a href="/share">Share kit</a> · {SHARE_CAMPAIGN_PACKETS.length} campaign packets</li>
            </ul>
          </article>
        </div>
      </section>

      <section class="source-panel">
        <div class="source-panel__head">
          <div>
            <p class="kicker">NOUN TRAIL</p>
            <h2>{nounBlocks.length} blocks currently carry sourced Noun IDs.</h2>
          </div>
          <a href="/collection/visit-nouns">Visit Nouns</a>
        </div>
        <div class="noun-grid">
          {recentNounBlocks.map((block) => (
            <a href={`/b/${block.data.id}`}>
              <img src={`https://noun.pics/${block.data.noun}.svg`} alt={`Noun ${block.data.noun}`} loading="lazy" />
              <span>№{block.data.noun}</span>
              <strong>{block.data.title}</strong>
              <em>/b/{block.data.id}</em>
            </a>
          ))}
        </div>
      </section>

      <section class="source-panel">
        <div class="source-panel__head">
          <div>
            <p class="kicker">RECENT EDITION BLOCKS</p>
            <h2>Mintable, faucet, and collectible block trail.</h2>
          </div>
          <a href="/blocks.json">/blocks.json</a>
        </div>
        <div class="mini-list">
          {recentEditionBlocks.map((block) => (
            <a href={`/b/${block.data.id}`}>
              <span>№{block.data.id} · {block.data.type}</span>
              <strong>{block.data.title}</strong>
              <em>{block.data.edition?.contract ? `${block.data.edition.contract} · token ${block.data.edition.tokenId}` : block.data.dek}</em>
            </a>
          ))}
        </div>
      </section>

      <section class="source-panel">
        <div class="source-panel__head">
          <div>
            <p class="kicker">ALL SOURCED URLS</p>
            <h2>{sourcedUrls.length} deduped URLs from blocks, drops, products, mesh, media, and share kit.</h2>
          </div>
          <a href="/share.json">/share.json</a>
        </div>
        <details class="url-audit" open>
          <summary>Show URL audit</summary>
          <div class="url-list">
            {recentUrls.map((row) => (
              <a href={row.url} target="_blank" rel="noopener">
                <span>{row.kind}</span>
                <strong>{row.label}</strong>
                <em>{row.source}</em>
              </a>
            ))}
          </div>
        </details>
      </section>
    </section>

    <!-- ─── IDENTITY CARD ─── -->
    <section class="identity" id="identity-card" data-profile-panel="v1">
      <div class="identity__avatar">
        <img class="identity__noun" id="identity-noun" alt="" src="" />
      </div>
      <div class="identity__meta">
        <p class="kicker">YOU · PROFILE</p>
        <h1 class="identity__name" id="identity-name">visitor</h1>
        <p class="identity__dek" id="identity-dek">
          Loading…
        </p>
        <p class="identity__hint mono" id="identity-hint"></p>
      </div>
    </section>

    <!-- ─── CURRENT STATE (what you told the peoples) ─── -->
    <section class="state-panel" id="state-panel" data-profile-panel="v1" hidden>
      <p class="kicker">CURRENT STATE · <a href="/#here-tell-panel" id="state-edit-link">edit ↗</a></p>
      <ul class="state-chips" id="state-chips"></ul>
    </section>

    <!-- ─── ACTIVITY ─── -->
    <section class="activity" data-profile-panel="v2">
      <p class="kicker">ACTIVITY · this browser's memory</p>
      <div class="activity__grid" id="activity-grid">
        <!-- JS fills -->
      </div>
      <div class="activity__detail" id="activity-detail">
        <!-- JS fills votes + drops lists -->
      </div>
    </section>

    <!-- ─── WALLETS ─── -->
    <header class="head" data-profile-panel="v2">
      <p class="kicker">WALLETS</p>
      <h2 class="head__h2">Paired on this browser</h2>
      <p class="dek" id="profile-dek">
        Tezos wallets you've connected via Beacon. Live balances + NFT
        counts from TzKT. Server-side: nothing. Clear browser data =
        clear this list.
      </p>
    </header>

    <section id="profile-empty" class="empty" data-profile-panel="v2" hidden>
      <p class="empty__title">No wallets connected yet.</p>
      <p class="empty__body">Connect via the wallet chip in the top-right of the home page. Kukai, Temple, Umami, Airgap — anything on Beacon.</p>
      <p class="empty__cta"><a href="/">← Back to home</a></p>
    </section>

    <section id="profile-list" class="list" data-profile-panel="v2" hidden></section>

    <aside class="agent-strip">
      <p class="agent-strip__label">MACHINE-READABLE</p>
      <ul>
        <li><a href="/for-agents">/for-agents</a></li>
        <li><a href="/blocks.json">/blocks.json</a></li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<script>
  type Wallet = { chain: 'tezos'; address: string; provider: string; addedAt: number; label?: string };

  function setProfileVersion(version: 'v1' | 'v2' | 'v3') {
    const page = document.querySelector<HTMLElement>('.page');
    if (!page) return;
    page.dataset.profileVersion = version;
    document.querySelectorAll<HTMLButtonElement>('[data-version-switch]').forEach((button) => {
      const active = button.dataset.versionSwitch === version;
      button.setAttribute('aria-pressed', active ? 'true' : 'false');
    });
    try { localStorage.setItem('pc:profile-version', version); } catch {}
  }

  document.querySelectorAll<HTMLButtonElement>('[data-version-switch]').forEach((button) => {
    button.addEventListener('click', () => {
      const version = button.dataset.versionSwitch;
      if (version === 'v1' || version === 'v2' || version === 'v3') setProfileVersion(version);
    });
  });

  try {
    const saved = localStorage.getItem('pc:profile-version');
    if (saved === 'v1' || saved === 'v2' || saved === 'v3') setProfileVersion(saved);
  } catch {}

  const KEY_WALLETS = 'pc:wallets';
  const KEY_ACTIVE_ADDR = 'pc:wallet-active';
  const KEY_LEGACY = 'pc:wallet';

  function loadWallets(): Wallet[] {
    try {
      const raw = localStorage.getItem(KEY_WALLETS);
      if (raw) {
        const list = JSON.parse(raw) as Wallet[];
        if (Array.isArray(list)) return list;
      }
    } catch { /* ignore */ }
    return [];
  }

  function activeAddress(): string | null {
    try { return localStorage.getItem(KEY_ACTIVE_ADDR); } catch { return null; }
  }

  function saveWallets(list: Wallet[], newActive: string | null) {
    localStorage.setItem(KEY_WALLETS, JSON.stringify(list));
    if (newActive) localStorage.setItem(KEY_ACTIVE_ADDR, newActive);
    else localStorage.removeItem(KEY_ACTIVE_ADDR);
    const active = list.find((w) => w.address === newActive) ?? null;
    if (active) localStorage.setItem(KEY_LEGACY, JSON.stringify(active));
    else localStorage.removeItem(KEY_LEGACY);
    window.dispatchEvent(new CustomEvent('pc:wallet-change', { detail: active }));
  }

  function short(addr: string) {
    return addr.length > 12 ? `${addr.slice(0, 6)}…${addr.slice(-4)}` : addr;
  }

  const empty = document.getElementById('profile-empty')!;
  const list = document.getElementById('profile-list')!;

  interface LiveStats { balance: string; nfts: string; ops: string; lastActivity: string; }

  async function fetchStats(addr: string): Promise<LiveStats> {
    try {
      const [acc, tokens] = await Promise.all([
        fetch(`https://api.tzkt.io/v1/accounts/${addr}`),
        fetch(`https://api.tzkt.io/v1/tokens/balances/count?account=${addr}&balance.gt=0`),
      ]);
      const a = acc.ok ? await acc.json() : {};
      const n = tokens.ok ? (await tokens.text()).trim() : '—';
      return {
        balance: ((a.balance ?? 0) / 1_000_000).toFixed(4) + ' ꜩ',
        nfts: String(n),
        ops: String(a.numTransactions ?? '—'),
        lastActivity: a.lastActivity
          ? new Date(a.lastActivity).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
          : '—',
      };
    } catch {
      return { balance: '—', nfts: '—', ops: '—', lastActivity: '—' };
    }
  }

  async function render() {
    const wallets = loadWallets();
    const active = activeAddress();

    if (wallets.length === 0) {
      empty.hidden = false;
      list.hidden = true;
      return;
    }
    empty.hidden = true;
    list.hidden = false;
    list.innerHTML = '';

    // Sort newest-first
    const sorted = [...wallets].sort((a, b) => b.addedAt - a.addedAt);

    for (const w of sorted) {
      const isActive = w.address === active || (!active && w === sorted[0]);
      const addedFmt = new Date(w.addedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

      const card = document.createElement('article');
      card.className = 'card' + (isActive ? ' card--active' : '');
      card.innerHTML = `
        <header class="card__head">
          <span class="card__tag">${isActive ? 'active' : 'remembered'}</span>
          <span class="card__provider">${w.provider}</span>
        </header>
        <p class="card__addr">${w.address}</p>
        <div class="card__stats">
          <div class="card__stat"><span>balance</span><b data-stat="balance">…</b></div>
          <div class="card__stat"><span>nfts held</span><b data-stat="nfts">…</b></div>
          <div class="card__stat"><span>total ops</span><b data-stat="ops">…</b></div>
          <div class="card__stat"><span>last active</span><b data-stat="lastActivity">…</b></div>
          <div class="card__stat"><span>connected</span><b>${addedFmt}</b></div>
        </div>
        <div class="card__actions">
          <a class="card__tzkt" href="https://tzkt.io/${w.address}" target="_blank" rel="noopener">TzKT ↗</a>
          <a class="card__tzkt" href="https://objkt.com/profile/${w.address}/owned" target="_blank" rel="noopener">objkt ↗</a>
          ${isActive ? '' : `<button type="button" class="card__switch" data-action="switch" data-addr="${w.address}">Make active</button>`}
          <button type="button" class="card__remove" data-action="remove" data-addr="${w.address}">Remove</button>
        </div>
      `;
      list.appendChild(card);

      // Fetch stats (fire-and-forget, fills the — placeholders)
      fetchStats(w.address).then((stats) => {
        const q = (k: string) => card.querySelector<HTMLElement>(`[data-stat="${k}"]`);
        if (q('balance')) q('balance')!.textContent = stats.balance;
        if (q('nfts')) q('nfts')!.textContent = stats.nfts;
        if (q('ops')) q('ops')!.textContent = stats.ops;
        if (q('lastActivity')) q('lastActivity')!.textContent = stats.lastActivity;
      });
    }

    // Wire switch / remove buttons
    list.querySelectorAll<HTMLElement>('[data-action]').forEach((el) => {
      el.addEventListener('click', () => {
        const addr = el.dataset.addr!;
        const action = el.dataset.action!;
        const current = loadWallets();
        if (action === 'switch') {
          saveWallets(current, addr);
        } else if (action === 'remove') {
          const next = current.filter((w) => w.address !== addr);
          const nextActive = activeAddress() === addr
            ? (next.length > 0 ? next[next.length - 1].address : null)
            : activeAddress();
          saveWallets(next, nextActive);
        }
        void render();
      });
    });
  }

  window.addEventListener('pc:wallet-change', () => void render());
  window.addEventListener('storage', (e) => {
    if (e.key === KEY_WALLETS || e.key === KEY_ACTIVE_ADDR) void render();
  });

  void render();

  // ─── IDENTITY + ACTIVITY BLOCK ─────────────────────────────────
  // Reads every `pc:*` localStorage key the site has written and
  // renders: identity card (noun, name, first-seen), current state
  // panel (mood/listening/where), activity stats grid, and detail
  // lists for votes + drops. No server state; if cleared, everything
  // resets.
  function cheapHashL(s: string): number {
    let h = 5381;
    for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) | 0;
    return h >>> 0;
  }
  function ls(k: string): string | null {
    try { return localStorage.getItem(k); } catch { return null; }
  }
  function shortAddr(a: string): string {
    return a.length > 12 ? `${a.slice(0, 6)}…${a.slice(-4)}` : a;
  }
  function prettyDate(iso: string | null): string {
    if (!iso) return '—';
    try {
      return new Date(iso).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
    } catch { return iso; }
  }
  function countCollected(): number {
    try {
      const raw = ls('pc:daily:collected');
      if (!raw) return 0;
      const arr = JSON.parse(raw);
      return Array.isArray(arr) ? arr.length : 0;
    } catch { return 0; }
  }
  function collectedList(): Array<{date: string, blockId: string, at?: string}> {
    try {
      const raw = ls('pc:daily:collected');
      if (!raw) return [];
      const arr = JSON.parse(raw);
      return Array.isArray(arr) ? arr : [];
    } catch { return []; }
  }
  function pollsVotedList(): Array<{slug: string, optionId: string}> {
    const out: Array<{slug: string, optionId: string}> = [];
    try {
      for (let i = 0; i < localStorage.length; i++) {
        const k = localStorage.key(i);
        if (!k || !k.startsWith('pc:poll:voted:')) continue;
        const slug = k.replace('pc:poll:voted:', '');
        const optionId = localStorage.getItem(k) || '';
        out.push({ slug, optionId });
      }
    } catch {}
    return out;
  }
  function currentStreak(): number {
    try {
      const arr = collectedList();
      const dates: Record<string, boolean> = {};
      for (const c of arr) if (c && c.date) dates[c.date] = true;
      const today = new Intl.DateTimeFormat('en-CA', { timeZone: 'America/Los_Angeles' }).format(new Date());
      let streak = 0;
      let cur = today;
      while (dates[cur]) {
        streak++;
        const [y, m, d] = cur.split('-').map((s: string) => parseInt(s, 10));
        const dt = new Date(Date.UTC(y, m - 1, d));
        dt.setUTCDate(dt.getUTCDate() - 1);
        cur = dt.getUTCFullYear() + '-' + String(dt.getUTCMonth() + 1).padStart(2, '0') + '-' + String(dt.getUTCDate()).padStart(2, '0');
      }
      return streak;
    } catch { return 0; }
  }

  function paintIdentity() {
    let sessionId = ls('pc:session');
    if (!sessionId) {
      try {
        sessionId = (crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2));
        localStorage.setItem('pc:session', sessionId);
      } catch { sessionId = 'anonymous-' + Math.random().toString(36).slice(2); }
    }

    // Noun id
    let nounId = 0;
    const cachedNoun = ls('pc:visitor:noun');
    if (cachedNoun) nounId = parseInt(cachedNoun, 10);
    if (!(nounId >= 0 && nounId < 1200)) {
      nounId = cheapHashL(sessionId) % 1200;
      try { localStorage.setItem('pc:visitor:noun', String(nounId)); } catch {}
    }

    // First seen
    let firstSeen = ls('pc:visitor:firstSeenAt');
    if (!firstSeen) {
      firstSeen = new Date().toISOString();
      try { localStorage.setItem('pc:visitor:firstSeenAt', firstSeen); } catch {}
    }

    const wallets = loadWallets();
    const active = activeAddress() ||
      (wallets.length > 0 ? wallets[wallets.length - 1].address : null);

    // Display name preference: user-set > wallet-short > agent-ua > noun-nnn
    const override = ls('pc:visitor:display');
    const isAgent = /gptbot|claudebot|claude-user|anthropic-ai|perplexitybot|oai-searchbot|atlas|google-extended|googlebot|bingbot/i.test(navigator.userAgent);
    let displayName = 'visitor';
    let kindLabel = 'human';
    if (override && override.trim()) {
      displayName = override.trim();
      kindLabel = 'human · named';
    } else if (active) {
      displayName = shortAddr(active);
      kindLabel = 'wallet';
    } else if (isAgent) {
      const agents = ['GPTBot', 'ClaudeBot', 'Claude-User', 'anthropic-ai', 'PerplexityBot', 'OAI-SearchBot', 'Atlas', 'Google-Extended', 'Googlebot', 'Bingbot'];
      const ua = navigator.userAgent;
      const match = agents.find((a) => ua.toLowerCase().includes(a.toLowerCase()));
      displayName = match || 'agent';
      kindLabel = 'agent';
    } else {
      displayName = 'noun-' + String(nounId).padStart(3, '0');
      kindLabel = 'human · anonymous';
    }

    const img = document.getElementById('identity-noun') as HTMLImageElement;
    const nameEl = document.getElementById('identity-name');
    const dekEl = document.getElementById('identity-dek');
    const hintEl = document.getElementById('identity-hint');
    if (img) { img.src = `https://noun.pics/${nounId}.svg`; img.alt = `your noun · ${nounId}`; }
    if (nameEl) nameEl.textContent = displayName;
    if (dekEl) {
      dekEl.innerHTML = `
        Noun № <strong>${nounId}</strong> ·
        <span class="identity__kind">${kindLabel}</span> ·
        here since <time datetime="${firstSeen}">${prettyDate(firstSeen)}</time>
      `;
    }
    if (hintEl) {
      const notes: string[] = [];
      if (active) notes.push(`active wallet ${shortAddr(active)}`);
      if (!override) notes.push(`anonymous identity — noun id is deterministic from this browser's session`);
      hintEl.textContent = notes.join(' · ');
    }
  }

  function paintState() {
    const mood = ls('pc:visitor:mood');
    const listening = ls('pc:visitor:listening');
    const where = ls('pc:visitor:where');
    const panel = document.getElementById('state-panel');
    const chipsEl = document.getElementById('state-chips');
    if (!panel || !chipsEl) return;
    const any = mood || listening || where;
    panel.hidden = !any;
    if (!any) return;
    const items: Array<{label: string, value: string, kind: string}> = [];
    if (mood) items.push({ label: 'mood', value: mood, kind: 'mood' });
    if (listening) items.push({ label: '🎵 now playing', value: listening, kind: 'listening' });
    if (where) items.push({ label: '📍 where', value: where, kind: 'where' });
    chipsEl.innerHTML = items.map((i) => `
      <li class="state-chip state-chip--${i.kind}">
        <span class="state-chip__label">${i.label}</span>
        <span class="state-chip__value">${escapeHtml(i.value)}</span>
      </li>
    `).join('');
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    } as any)[c]);
  }

  function paintActivity() {
    const helloCount = parseInt(ls('pc:hello:count') || '0', 10);
    const helloLastDay = ls('pc:hello:lastDay') || '—';
    const dropsCount = countCollected();
    const dropsStreak = currentStreak();
    const votesCount = pollsVotedList().length;
    // VoterStats
    const voterState = (() => {
      try {
        const raw = ls('pc:voter:state');
        if (!raw) return null;
        return JSON.parse(raw);
      } catch { return null; }
    })();
    const level = voterState?.level ?? 1;
    const xp = voterState?.xp ?? 0;
    const streak = voterState?.streak ?? 0;
    const title = voterState?.title ?? 'Novice Voter';

    const grid = document.getElementById('activity-grid');
    if (!grid) return;
    const stats = [
      { label: 'HELLO', value: String(helloCount), sub: helloLastDay !== '—' ? `last earned ${helloLastDay}` : '—' },
      { label: 'drops collected', value: String(dropsCount), sub: dropsStreak > 0 ? `${dropsStreak}-day streak` : 'no active streak' },
      { label: 'polls voted', value: String(votesCount), sub: votesCount === 0 ? 'no votes yet' : `unique: ${votesCount}` },
      { label: 'voter level', value: `L${level}`, sub: `${xp} XP · ${title.toLowerCase()}` },
    ];
    grid.innerHTML = stats.map((s) => `
      <div class="stat">
        <span class="stat__label">${s.label}</span>
        <span class="stat__value">${s.value}</span>
        <span class="stat__sub">${s.sub}</span>
      </div>
    `).join('');

    // Detail: votes list + drops list
    const detail = document.getElementById('activity-detail');
    if (!detail) return;
    const votes = pollsVotedList();
    const drops = collectedList().sort((a, b) => (b.date || '').localeCompare(a.date || ''));

    detail.innerHTML = `
      <div class="detail-col">
        <h3 class="detail__h3">polls voted <span class="detail__count">${votes.length}</span></h3>
        ${votes.length === 0 ? '<p class="detail__empty">tap a poll on the home page</p>' :
          `<ul class="detail__list">${votes.map((v) => `
            <li><a href="/poll/${v.slug}"><span class="detail__slug">${v.slug}</span> <span class="detail__pick">→ ${escapeHtml(v.optionId)}</span></a></li>
          `).join('')}</ul>`}
      </div>
      <div class="detail-col">
        <h3 class="detail__h3">drops collected <span class="detail__count">${drops.length}</span></h3>
        ${drops.length === 0 ? '<p class="detail__empty">collect today\'s drop at <a href="/today">/today</a></p>' :
          `<ul class="detail__list">${drops.map((d) => `
            <li><a href="/b/${d.blockId}"><span class="detail__slug">${d.date}</span> <span class="detail__pick">№${d.blockId}</span></a></li>
          `).join('')}</ul>`}
      </div>
    `;
  }

  paintIdentity();
  paintState();
  paintActivity();
  window.addEventListener('storage', () => { paintIdentity(); paintState(); paintActivity(); });
</script>

