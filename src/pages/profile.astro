    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 9.5px;
  }
  .pf-hero__chips { list-style: none; margin: 6px 0 0; padding: 0; display: flex; flex-wrap: wrap; gap: 6px; }
  .pf-chip {
    display: inline-flex; flex-direction: column;
    background: #fff;
    border: 1.5px solid var(--pf-ink);
