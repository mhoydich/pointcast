---
/**
 * /profile — visualize every wallet this browser has paired with.
 *
 * Reads pc:wallets from localStorage (set by WalletChip). Pulls live
 * TzKT data for each (balance, NFT count, ops count, last activity).
 * Shows which is active. Lets the user switch active / remove any.
 *
 * All client-side — no server state. "Your profile" is scoped to this
 * browser + whatever Beacon sessions live in its storage.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': 'https://pointcast.xyz/profile',
  name: 'Your PointCast profile',
  description: 'Every Tezos wallet this browser has paired with PointCast, with live TzKT balance / NFT / activity data.',
  url: 'https://pointcast.xyz/profile',
};
---

<BlockLayout title="Profile" description="Your connected Tezos wallets, visualized." jsonLd={jsonLd}>
  <div class="page">
    <nav class="crumb">
      <a href="/">← Home</a>
      <span aria-hidden="true">/</span>
      <span>profile</span>
    </nav>

    <!-- ─── IDENTITY CARD ─── -->
    <section class="identity" id="identity-card">
      <div class="identity__avatar">
        <img class="identity__noun" id="identity-noun" alt="" src="" />
      </div>
      <div class="identity__meta">
        <p class="kicker">YOU · PROFILE</p>
        <h1 class="identity__name" id="identity-name">visitor</h1>
        <p class="identity__dek" id="identity-dek">
          Loading…
        </p>
        <p class="identity__hint mono" id="identity-hint"></p>
      </div>
    </section>

    <!-- ─── CURRENT STATE (what you told the peoples) ─── -->
    <section class="state-panel" id="state-panel" hidden>
      <p class="kicker">CURRENT STATE · <a href="/#here-tell-panel" id="state-edit-link">edit ↗</a></p>
      <ul class="state-chips" id="state-chips"></ul>
    </section>

    <!-- ─── ACTIVITY ─── -->
    <section class="activity">
      <p class="kicker">ACTIVITY · this browser's memory</p>
      <div class="activity__grid" id="activity-grid">
        <!-- JS fills -->
      </div>
      <div class="activity__detail" id="activity-detail">
        <!-- JS fills votes + drops lists -->
      </div>
    </section>

    <!-- ─── COLLECTED BLOCKS ─── -->
    <section class="blocks-history">
      <p class="kicker">COLLECTED · <span id="blocks-count">0</span> BLOCKS</p>
      <div class="blocks-strip" id="blocks-strip">
        <p class="blocks-empty">Loading…</p>
      </div>
    </section>

    <!-- ─── BATH SAVES ─── -->
    <section class="bath-saves-section" id="bath-saves-section" hidden>
      <p class="kicker">BATH SAVES · <span id="saves-count">0</span> · <a href="/bath">/bath</a></p>
      <div class="saves-grid" id="saves-grid"></div>
    </section>

    <!-- ─── WALLETS ─── -->
    <header class="head">
      <p class="kicker">WALLETS</p>
      <h2 class="head__h2">Paired on this browser</h2>
      <p class="dek" id="profile-dek">
        Tezos wallets you've connected via Beacon. Live balances + NFT
        counts from TzKT. Server-side: nothing. Clear browser data =
        clear this list.
      </p>
    </header>

    <section id="profile-empty" class="empty" hidden>
      <p class="empty__title">No wallets connected yet.</p>
      <p class="empty__body">Connect via the wallet chip in the top-right of the home page. Kukai, Temple, Umami, Airgap — anything on Beacon.</p>
      <p class="empty__cta"><a href="/">← Back to home</a></p>
    </section>

    <section id="profile-list" class="list" hidden></section>

    <!-- ─── TEZOS NFT COLLECTION ─── -->
    <section class="collection">
      <header class="head">
        <p class="kicker">COLLECTION · ON-CHAIN</p>
        <h2 class="head__h2">
          <span id="collection-owner-label">Tezos NFTs</span>
        </h2>
        <p class="dek" id="collection-dek">
          Live from TzKT. <span id="collection-scope">Showing Mike's wallet — connect your own to see your collection here.</span>
        </p>
      </header>
      <div class="collection__grid" id="collection-grid" aria-live="polite">
        <p class="collection__loading mono">LOADING COLLECTION…</p>
      </div>
      <p class="collection__footer mono" id="collection-footer"></p>
    </section>

    <aside class="agent-strip">
      <p class="agent-strip__label">MACHINE-READABLE</p>
      <ul>
        <li><a href="/for-agents">/for-agents</a></li>
        <li><a href="/blocks.json">/blocks.json</a></li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<script>
  type Wallet = { chain: 'tezos'; address: string; provider: string; addedAt: number; label?: string };

  const KEY_WALLETS = 'pc:wallets';
  const KEY_ACTIVE_ADDR = 'pc:wallet-active';
  const KEY_LEGACY = 'pc:wallet';

  function loadWallets(): Wallet[] {
    try {
      const raw = localStorage.getItem(KEY_WALLETS);
      if (raw) {
        const list = JSON.parse(raw) as Wallet[];
        if (Array.isArray(list)) return list;
      }
    } catch { /* ignore */ }
    return [];
  }

  function activeAddress(): string | null {
    try { return localStorage.getItem(KEY_ACTIVE_ADDR); } catch { return null; }
  }

  function saveWallets(list: Wallet[], newActive: string | null) {
    localStorage.setItem(KEY_WALLETS, JSON.stringify(list));
    if (newActive) localStorage.setItem(KEY_ACTIVE_ADDR, newActive);
    else localStorage.removeItem(KEY_ACTIVE_ADDR);
    const active = list.find((w) => w.address === newActive) ?? null;
    if (active) localStorage.setItem(KEY_LEGACY, JSON.stringify(active));
    else localStorage.removeItem(KEY_LEGACY);
    window.dispatchEvent(new CustomEvent('pc:wallet-change', { detail: active }));
  }

  function short(addr: string) {
    return addr.length > 12 ? `${addr.slice(0, 6)}…${addr.slice(-4)}` : addr;
  }

  const empty = document.getElementById('profile-empty')!;
  const list = document.getElementById('profile-list')!;

  // ── COLLECTION · Tezos NFTs via TzKT ────────────────────────────
  const MIKE_WALLET = 'tz2FjJhB1gb9Xc2qNB7QgFkdBZkGCCRMxdFw';
  const IPFS_GATEWAY = 'https://ipfs.io/ipfs/';

  interface NftToken {
    contract: string;
    tokenId: string;
    name: string;
    thumb: string | null;
    mime: string;
    supply: number;
    balance: number;
  }

  function ipfsToHttp(uri: string | null | undefined): string | null {
    if (!uri) return null;
    if (uri.startsWith('ipfs://')) return IPFS_GATEWAY + uri.slice(7);
    if (uri.startsWith('http')) return uri;
    return null;
  }

  async function loadCollection(addr: string, isOwnWallet: boolean) {
    const grid = document.getElementById('collection-grid');
    const scope = document.getElementById('collection-scope');
    const footer = document.getElementById('collection-footer');
    const ownerLabel = document.getElementById('collection-owner-label');
    if (!grid || !scope || !footer || !ownerLabel) return;

    if (isOwnWallet) {
      scope.textContent = `Your connected wallet · ${addr.slice(0, 6)}…${addr.slice(-4)}`;
      ownerLabel.textContent = 'Your Tezos NFTs';
    } else {
      scope.textContent = `Showing Mike's wallet (${addr.slice(0, 6)}…${addr.slice(-4)}) — connect your own to see yours here.`;
      ownerLabel.textContent = "Mike's Tezos NFTs";
    }

    try {
      const url = `https://api.tzkt.io/v1/tokens/balances?account=${addr}&token.standard=fa2&balance.gt=0&limit=60&sort.desc=lastTime&select=token.contract.address as contract,token.tokenId as tokenId,token.metadata as metadata,token.totalSupply as supply,balance`;
      const r = await fetch(url);
      if (!r.ok) throw new Error(`TzKT ${r.status}`);
      const raw: any[] = await r.json();

      const tokens: NftToken[] = raw
        .map((t) => {
          const m = t.metadata || {};
          const thumb =
            ipfsToHttp(m.thumbnailUri) ||
            ipfsToHttp(m.displayUri) ||
            ipfsToHttp(m.artifactUri) ||
            null;
          return {
            contract: t.contract,
            tokenId: String(t.tokenId),
            name: m.name || `Token #${t.tokenId}`,
            thumb,
            mime: m.formats?.[0]?.mimeType || '',
            supply: Number(t.supply ?? 0),
            balance: Number(t.balance ?? 0),
          };
        })
        .filter((t) => t.thumb);

      if (tokens.length === 0) {
        grid.innerHTML = '<p class="collection__empty">No NFTs in this wallet yet.</p>';
        footer.textContent = '';
        return;
      }

      grid.innerHTML = tokens
        .slice(0, 48)
        .map((t) => {
          const objktUrl = `https://objkt.com/tokens/${t.contract}/${t.tokenId}`;
          return `
            <a class="nft" href="${objktUrl}" target="_blank" rel="noopener">
              <div class="nft__art">
                <img src="${t.thumb}" alt="${nftEscAttr(t.name)}" loading="lazy" />
              </div>
              <p class="nft__name">${nftEscHtml(t.name)}</p>
              <p class="nft__meta mono">×${t.balance}${t.supply > 0 ? ` · ${t.supply} ed` : ''}</p>
            </a>
          `;
        })
        .join('');

      footer.textContent = `${tokens.length} held · fetched ${new Date().toISOString().slice(0, 16).replace('T', ' ')} UTC · objkt.com links`;
    } catch (e: any) {
      grid.innerHTML = `<p class="collection__error">Couldn't load collection: ${nftEscHtml(e?.message || 'unknown error')}. Try again in a minute.</p>`;
      footer.textContent = '';
    }
  }

  // Use the existing nftEscHtml helper defined below for string escaping.
  function nftEscAttr(s: string): string { return nftEscHtml(s); }

  // Pick which wallet to show: active connected wallet, or Mike's as fallback.
  function resolveCollectionAddress(): { addr: string; isOwn: boolean } {
    const active = activeAddress();
    if (active) return { addr: active, isOwn: true };
    const wallets = loadWallets();
    if (wallets.length > 0) return { addr: wallets[0].address, isOwn: true };
    return { addr: MIKE_WALLET, isOwn: false };
  }

  const { addr: collectionAddr, isOwn: collectionIsOwn } = resolveCollectionAddress();
  loadCollection(collectionAddr, collectionIsOwn);

  window.addEventListener('pc:wallet-change', () => {
    const { addr, isOwn } = resolveCollectionAddress();
    loadCollection(addr, isOwn);
  });

  interface LiveStats { balance: string; nfts: string; ops: string; lastActivity: string; }

  async function fetchStats(addr: string): Promise<LiveStats> {
    try {
      const [acc, tokens] = await Promise.all([
        fetch(`https://api.tzkt.io/v1/accounts/${addr}`),
        fetch(`https://api.tzkt.io/v1/tokens/balances/count?account=${addr}&balance.gt=0`),
      ]);
      const a = acc.ok ? await acc.json() : {};
      const n = tokens.ok ? (await tokens.text()).trim() : '—';
      return {
        balance: ((a.balance ?? 0) / 1_000_000).toFixed(4) + ' ꜩ',
        nfts: String(n),
        ops: String(a.numTransactions ?? '—'),
        lastActivity: a.lastActivity
          ? new Date(a.lastActivity).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
          : '—',
      };
    } catch {
      return { balance: '—', nfts: '—', ops: '—', lastActivity: '—' };
    }
  }

  async function render() {
    const wallets = loadWallets();
    const active = activeAddress();

    if (wallets.length === 0) {
      empty.hidden = false;
      list.hidden = true;
      return;
    }
    empty.hidden = true;
    list.hidden = false;
    list.innerHTML = '';

    // Sort newest-first
    const sorted = [...wallets].sort((a, b) => b.addedAt - a.addedAt);

    for (const w of sorted) {
      const isActive = w.address === active || (!active && w === sorted[0]);
      const addedFmt = new Date(w.addedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

      const card = document.createElement('article');
      card.className = 'card' + (isActive ? ' card--active' : '');
      card.innerHTML = `
        <header class="card__head">
          <span class="card__tag">${isActive ? 'active' : 'remembered'}</span>
          <span class="card__provider">${w.provider}</span>
        </header>
        <p class="card__addr">${w.address}</p>
        <div class="card__stats">
          <div class="card__stat"><span>balance</span><b data-stat="balance">…</b></div>
          <div class="card__stat"><span>nfts held</span><b data-stat="nfts">…</b></div>
          <div class="card__stat"><span>total ops</span><b data-stat="ops">…</b></div>
          <div class="card__stat"><span>last active</span><b data-stat="lastActivity">…</b></div>
          <div class="card__stat"><span>connected</span><b>${addedFmt}</b></div>
        </div>
        <div class="card__actions">
          <a class="card__tzkt" href="https://tzkt.io/${w.address}" target="_blank" rel="noopener">TzKT ↗</a>
          <a class="card__tzkt" href="https://objkt.com/profile/${w.address}/owned" target="_blank" rel="noopener">objkt ↗</a>
          ${isActive ? '' : `<button type="button" class="card__switch" data-action="switch" data-addr="${w.address}">Make active</button>`}
          <button type="button" class="card__remove" data-action="remove" data-addr="${w.address}">Remove</button>
        </div>
      `;
      list.appendChild(card);

      // Fetch stats (fire-and-forget, fills the — placeholders)
      fetchStats(w.address).then((stats) => {
        const q = (k: string) => card.querySelector<HTMLElement>(`[data-stat="${k}"]`);
        if (q('balance')) q('balance')!.textContent = stats.balance;
        if (q('nfts')) q('nfts')!.textContent = stats.nfts;
        if (q('ops')) q('ops')!.textContent = stats.ops;
        if (q('lastActivity')) q('lastActivity')!.textContent = stats.lastActivity;
      });
    }

    // Wire switch / remove buttons
    list.querySelectorAll<HTMLElement>('[data-action]').forEach((el) => {
      el.addEventListener('click', () => {
        const addr = el.dataset.addr!;
        const action = el.dataset.action!;
        const current = loadWallets();
        if (action === 'switch') {
          saveWallets(current, addr);
        } else if (action === 'remove') {
          const next = current.filter((w) => w.address !== addr);
          const nextActive = activeAddress() === addr
            ? (next.length > 0 ? next[next.length - 1].address : null)
            : activeAddress();
          saveWallets(next, nextActive);
        }
        void render();
      });
    });
  }

  window.addEventListener('pc:wallet-change', () => void render());
  window.addEventListener('storage', (e) => {
    if (e.key === KEY_WALLETS || e.key === KEY_ACTIVE_ADDR) void render();
  });

  void render();

  // ─── IDENTITY + ACTIVITY BLOCK ─────────────────────────────────
  // Reads every `pc:*` localStorage key the site has written and
  // renders: identity card (noun, name, first-seen), current state
  // panel (mood/listening/where), activity stats grid, and detail
  // lists for votes + drops. No server state; if cleared, everything
  // resets.
  function cheapHashL(s: string): number {
    let h = 5381;
    for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) | 0;
    return h >>> 0;
  }
  function ls(k: string): string | null {
    try { return localStorage.getItem(k); } catch { return null; }
  }
  function shortAddr(a: string): string {
    return a.length > 12 ? `${a.slice(0, 6)}…${a.slice(-4)}` : a;
  }
  function prettyDate(iso: string | null): string {
    if (!iso) return '—';
    try {
      return new Date(iso).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
    } catch { return iso; }
  }
  function countCollected(): number {
    try {
      const raw = ls('pc:daily:collected');
      if (!raw) return 0;
      const arr = JSON.parse(raw);
      return Array.isArray(arr) ? arr.length : 0;
    } catch { return 0; }
  }
  function collectedList(): Array<{date: string, blockId: string, at?: string}> {
    try {
      const raw = ls('pc:daily:collected');
      if (!raw) return [];
      const arr = JSON.parse(raw);
      return Array.isArray(arr) ? arr : [];
    } catch { return []; }
  }
  function pollsVotedList(): Array<{slug: string, optionId: string}> {
    const out: Array<{slug: string, optionId: string}> = [];
    try {
      for (let i = 0; i < localStorage.length; i++) {
        const k = localStorage.key(i);
        if (!k || !k.startsWith('pc:poll:voted:')) continue;
        const slug = k.replace('pc:poll:voted:', '');
        const optionId = localStorage.getItem(k) || '';
        out.push({ slug, optionId });
      }
    } catch {}
    return out;
  }
  function currentStreak(): number {
    try {
      const arr = collectedList();
      const dates: Record<string, boolean> = {};
      for (const c of arr) if (c && c.date) dates[c.date] = true;
      const today = new Intl.DateTimeFormat('en-CA', { timeZone: 'America/Los_Angeles' }).format(new Date());
      let streak = 0;
      let cur = today;
      while (dates[cur]) {
        streak++;
        const [y, m, d] = cur.split('-').map((s: string) => parseInt(s, 10));
        const dt = new Date(Date.UTC(y, m - 1, d));
        dt.setUTCDate(dt.getUTCDate() - 1);
        cur = dt.getUTCFullYear() + '-' + String(dt.getUTCMonth() + 1).padStart(2, '0') + '-' + String(dt.getUTCDate()).padStart(2, '0');
      }
      return streak;
    } catch { return 0; }
  }

  function paintIdentity() {
    let sessionId = ls('pc:session');
    if (!sessionId) {
      try {
        sessionId = (crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2));
        localStorage.setItem('pc:session', sessionId);
      } catch { sessionId = 'anonymous-' + Math.random().toString(36).slice(2); }
    }

    // Noun id
    let nounId = 0;
    const cachedNoun = ls('pc:visitor:noun');
    if (cachedNoun) nounId = parseInt(cachedNoun, 10);
    if (!(nounId >= 0 && nounId < 1200)) {
      nounId = cheapHashL(sessionId) % 1200;
      try { localStorage.setItem('pc:visitor:noun', String(nounId)); } catch {}
    }

    // First seen
    let firstSeen = ls('pc:visitor:firstSeenAt');
    if (!firstSeen) {
      firstSeen = new Date().toISOString();
      try { localStorage.setItem('pc:visitor:firstSeenAt', firstSeen); } catch {}
    }

    const wallets = loadWallets();
    const active = activeAddress() ||
      (wallets.length > 0 ? wallets[wallets.length - 1].address : null);

    // Display name preference: user-set > wallet-short > agent-ua > noun-nnn
    const override = ls('pc:visitor:display');
    const isAgent = /gptbot|claudebot|claude-user|anthropic-ai|perplexitybot|oai-searchbot|atlas|google-extended|googlebot|bingbot/i.test(navigator.userAgent);
    let displayName = 'visitor';
    let kindLabel = 'human';
    if (override && override.trim()) {
      displayName = override.trim();
      kindLabel = 'human · named';
    } else if (active) {
      displayName = shortAddr(active);
      kindLabel = 'wallet';
    } else if (isAgent) {
      const agents = ['GPTBot', 'ClaudeBot', 'Claude-User', 'anthropic-ai', 'PerplexityBot', 'OAI-SearchBot', 'Atlas', 'Google-Extended', 'Googlebot', 'Bingbot'];
      const ua = navigator.userAgent;
      const match = agents.find((a) => ua.toLowerCase().includes(a.toLowerCase()));
      displayName = match || 'agent';
      kindLabel = 'agent';
    } else {
      displayName = 'noun-' + String(nounId).padStart(3, '0');
      kindLabel = 'human · anonymous';
    }

    const img = document.getElementById('identity-noun') as HTMLImageElement;
    const nameEl = document.getElementById('identity-name');
    const dekEl = document.getElementById('identity-dek');
    const hintEl = document.getElementById('identity-hint');
    if (img) { img.src = `https://noun.pics/${nounId}.svg`; img.alt = `your noun · ${nounId}`; }
    if (nameEl) nameEl.textContent = displayName;
    if (dekEl) {
      dekEl.innerHTML = `
        Noun № <strong>${nounId}</strong> ·
        <span class="identity__kind">${kindLabel}</span> ·
        here since <time datetime="${firstSeen}">${prettyDate(firstSeen)}</time>
      `;
    }
    if (hintEl) {
      const notes: string[] = [];
      if (active) notes.push(`active wallet ${shortAddr(active)}`);
      if (!override) notes.push(`anonymous identity — noun id is deterministic from this browser's session`);
      hintEl.textContent = notes.join(' · ');
    }
  }

  function paintState() {
    const mood = ls('pc:visitor:mood');
    const listening = ls('pc:visitor:listening');
    const where = ls('pc:visitor:where');
    const panel = document.getElementById('state-panel');
    const chipsEl = document.getElementById('state-chips');
    if (!panel || !chipsEl) return;
    const any = mood || listening || where;
    panel.hidden = !any;
    if (!any) return;
    const items: Array<{label: string, value: string, kind: string}> = [];
    if (mood) items.push({ label: 'mood', value: mood, kind: 'mood' });
    if (listening) items.push({ label: 'now playing', value: listening, kind: 'listening' });
    if (where) items.push({ label: 'where', value: where, kind: 'where' });
    chipsEl.innerHTML = items.map((i) => `
      <li class="state-chip state-chip--${i.kind}">
        <span class="state-chip__label">${i.label}</span>
        <span class="state-chip__value">${nftEscHtml(i.value)}</span>
      </li>
    `).join('');
  }

  function nftEscHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    } as any)[c]);
  }

  function paintActivity() {
    const helloCount = parseInt(ls('pc:hello:count') || '0', 10);
    const helloLastDay = ls('pc:hello:lastDay') || '—';
    const dropsCount = countCollected();
    const dropsStreak = currentStreak();
    const votesCount = pollsVotedList().length;
    // VoterStats
    const voterState = (() => {
      try {
        const raw = ls('pc:voter:state');
        if (!raw) return null;
        return JSON.parse(raw);
      } catch { return null; }
    })();
    const level = voterState?.level ?? 1;
    const xp = voterState?.xp ?? 0;
    const streak = voterState?.streak ?? 0;
    const title = voterState?.title ?? 'Novice Voter';

    const grid = document.getElementById('activity-grid');
    if (!grid) return;
    const bathSaves = (() => { try { const r = ls('pc:bath:saves'); if (!r) return 0; const a = JSON.parse(r); return Array.isArray(a) ? a.length : 0; } catch { return 0; } })();
    const stats = [
      { label: 'HELLO', value: String(helloCount), sub: helloLastDay !== '—' ? `last earned ${helloLastDay}` : '—' },
      { label: 'drops collected', value: String(dropsCount), sub: dropsStreak > 0 ? `${dropsStreak}-day streak` : 'no active streak' },
      { label: 'polls voted', value: String(votesCount), sub: votesCount === 0 ? 'no votes yet' : `unique: ${votesCount}` },
      { label: 'voter level', value: `L${level}`, sub: `${xp} XP · ${title.toLowerCase()}` },
      { label: 'bath saves', value: String(bathSaves), sub: bathSaves > 0 ? 'spotify links saved' : 'none yet — visit /bath' },
    ];
    grid.innerHTML = stats.map((s) => `
      <div class="stat">
        <span class="stat__label">${s.label}</span>
        <span class="stat__value">${s.value}</span>
        <span class="stat__sub">${s.sub}</span>
      </div>
    `).join('');

    // Detail: votes list + drops list
    const detail = document.getElementById('activity-detail');
    if (!detail) return;
    const votes = pollsVotedList();
    const drops = collectedList().sort((a, b) => (b.date || '').localeCompare(a.date || ''));

    detail.innerHTML = `
      <div class="detail-col">
        <h3 class="detail__h3">polls voted <span class="detail__count">${votes.length}</span></h3>
        ${votes.length === 0 ? '<p class="detail__empty">tap a poll on the home page</p>' :
          `<ul class="detail__list">${votes.map((v) => `
            <li><a href="/poll/${v.slug}"><span class="detail__slug">${v.slug}</span> <span class="detail__pick">→ ${nftEscHtml(v.optionId)}</span></a></li>
          `).join('')}</ul>`}
      </div>
      <div class="detail-col">
        <h3 class="detail__h3">drops collected <span class="detail__count">${drops.length}</span></h3>
        ${drops.length === 0 ? '<p class="detail__empty">collect today\'s drop at <a href="/today">/today</a></p>' :
          `<ul class="detail__list">${drops.map((d) => `
            <li><a href="/b/${d.blockId}"><span class="detail__slug">${d.date}</span> <span class="detail__pick">№${d.blockId}</span></a></li>
          `).join('')}</ul>`}
      </div>
    `;
  }

  // ── COLLECTED BLOCKS visual strip ──────────────────────────────────
  function paintBlocks() {
    const list = collectedList().sort((a, b) => (b.date || '').localeCompare(a.date || ''));
    const countEl = document.getElementById('blocks-count');
    const strip = document.getElementById('blocks-strip');
    if (countEl) countEl.textContent = String(list.length);
    if (!strip) return;
    if (list.length === 0) {
      strip.innerHTML = '<p class="blocks-empty">No blocks collected yet. Visit <a href="/today">/today</a> to collect today\'s drop.</p>';
      return;
    }
    strip.innerHTML = list.slice(0, 30).map((d) => `
      <a class="block-tile" href="/b/${nftEscHtml(d.blockId)}" title="Block №${nftEscAttr(d.blockId)}">
        <div class="block-tile__img">
          <img
            src="/images/og/b/${nftEscAttr(d.blockId)}.png"
            alt="Block №${nftEscAttr(d.blockId)}"
            loading="lazy"
            onerror="this.parentElement.classList.add('block-tile__img--err')"
          />
        </div>
        <p class="block-tile__id mono">№${nftEscHtml(d.blockId)}</p>
        <p class="block-tile__date">${nftEscHtml(d.date || '—')}</p>
      </a>
    `).join('');
  }

  // ── BATH SAVES cards ────────────────────────────────────────────────
  const MOOD_DOT: Record<string, string> = {
    warm:'#F5A623', cool:'#4A9EFF', electric:'#FF00AA', earth:'#7B9E5E',
    void:'#8060C0', dawn:'#FFB4A2', neon:'#39FF14', ocean:'#00B4D8',
  };
  function paintBathSaves() {
    const saves: Array<{spotify_url:string;spotify_type:string;spotify_id:string;mood:string;address?:string;timestamp:string}> = [];
    try { const r = ls('pc:bath:saves'); if (r) { const a = JSON.parse(r); if (Array.isArray(a)) saves.push(...a); } } catch {}
    const section = document.getElementById('bath-saves-section');
    const grid = document.getElementById('saves-grid');
    const countEl = document.getElementById('saves-count');
    if (!section || !grid) return;
    if (saves.length === 0) { section.hidden = true; return; }
    section.hidden = false;
    if (countEl) countEl.textContent = String(saves.length);
    grid.innerHTML = saves.slice(0, 16).map((s) => {
      const dot = MOOD_DOT[s.mood] || '#aaa';
      const date = s.timestamp ? new Date(s.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: '2-digit' }) : '—';
      const type = (s.spotify_type || '').toUpperCase();
      const url = s.spotify_url || `https://open.spotify.com/${nftEscAttr(s.spotify_type)}/${nftEscAttr(s.spotify_id)}`;
      const embedH = s.spotify_type === 'track' ? '80' : '152';
      return `
        <div class="save-card">
          <div class="save-card__embed">
            <iframe
              src="https://open.spotify.com/embed/${nftEscAttr(s.spotify_type)}/${nftEscAttr(s.spotify_id)}?utm_source=pointcast"
              width="100%" height="${embedH}" frameborder="0"
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"
            ></iframe>
          </div>
          <div class="save-card__meta">
            <span class="save-card__type">${type}</span>
            <span class="save-card__mood-dot" style="background:${dot};box-shadow:0 0 5px ${dot}" title="${nftEscAttr(s.mood)}"></span>
            <span class="save-card__mood-name">${nftEscHtml(s.mood)}</span>
            <span class="save-card__date">${date}</span>
            <a class="save-card__open" href="${nftEscAttr(url)}" target="_blank" rel="noopener">open ↗</a>
          </div>
        </div>
      `;
    }).join('');
  }

  paintIdentity();
  paintState();
  paintActivity();
  paintBlocks();
  paintBathSaves();
  window.addEventListener('storage', () => { paintIdentity(); paintState(); paintActivity(); paintBlocks(); paintBathSaves(); });
</script>

