    font-weight: 600;
    letter-spacing: -0.02em;
    word-break: break-word;
  }
  .pf-hero__sub {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--pf-ink-soft);
    margin: 0;
  }
  .pf-kind {
    display: inline-block;
    background: var(--pf-ink);
