    pointer-events: none;
  }
  .pf-tile__label { font-family: 'JetBrains Mono Variable', monospace; font-size: 9px; font-weight: 700; letter-spacing: 0.20em; color: var(--pf-ink); opacity: 0.78; }
  .pf-tile__value { font-family: 'Lora', Georgia, serif; font-size: 32px; font-weight: 700; color: var(--pf-ink); line-height: 1; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
  .pf-tile__sub { font-family: 'JetBrains Mono Variable', monospace; font-size: 9px; letter-spacing: 0.08em; color: var(--pf-ink); opacity: 0.68; line-height: 1.3; }
  .pf-tile--yellow { background: var(--pf-yellow); }
  .pf-tile--red    { background: var(--pf-red);    }
  .pf-tile--red    .pf-tile__label, .pf-tile--red .pf-tile__value, .pf-tile--red .pf-tile__sub { color: #fff; }
  .pf-tile--blue   { background: var(--pf-blue);   }
  .pf-tile--blue   .pf-tile__label, .pf-tile--blue .pf-tile__value, .pf-tile--blue .pf-tile__sub { color: #fff; }
  .pf-tile--green  { background: var(--pf-green); }
  .pf-tile--purple { background: var(--pf-purple); }
  .pf-tile--purple .pf-tile__label, .pf-tile--purple .pf-tile__value, .pf-tile--purple .pf-tile__sub { color: #fff; }
  .pf-tile--orange { background: var(--pf-orange); }

  .pf-poster__wall { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; }
  .pf-poster__tile {
    display: block; text-decoration: none; color: inherit;
    background: #fff;
    border: 2px solid var(--pf-ink);
    box-shadow: 4px 4px 0 0 var(--pf-ink);
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }
  .pf-poster__tile:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 0 var(--pf-ink); }
  .pf-poster__img { position: relative; aspect-ratio: 1200 / 630; background: var(--pf-paper-2); overflow: hidden; border-bottom: 2px solid var(--pf-ink); }
  .pf-poster__img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pf-poster__img--err { background: linear-gradient(135deg, #eeeae0 0%, #ddd8cc 100%); }
  .pf-poster__img--err::after { content: 'no image yet'; position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-family: 'JetBrains Mono Variable', monospace; font-size: 10px; letter-spacing: 0.16em; color: #999; }
  .pf-poster__num { position: absolute; top: 6px; left: 6px; background: var(--pf-ink); color: var(--pf-paper); padding: 2px 8px; font-family: 'JetBrains Mono Variable', monospace; font-size: 10px; letter-spacing: 0.10em; font-weight: 700; }
  .pf-poster__caption { padding: 6px 10px 8px; background: #fff; display: flex; justify-content: space-between; align-items: baseline; }
  .pf-poster__date { font-family: 'JetBrains Mono Variable', monospace; font-size: 10px; letter-spacing: 0.10em; color: var(--pf-ink-soft); }
