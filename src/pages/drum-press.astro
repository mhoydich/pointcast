const totalTitles = imprints.reduce((n, i) => n + i.titles.length, 0);
const totalImprints = imprints.length;

// Issue/volume number — playful, increments daily so the masthead
// feels alive without doing real publication tracking.
const today = new Date();
const issueNo = Math.floor((today.getTime() - new Date(2026, 2, 1).getTime()) / 86_400_000) + 1;
const volNo = 1;
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="dp" id="dp-main">
    <DrumNav current="press" />

    <header class="dp__masthead">
      <p class="dp__kicker mono">★ DRUM HUB · DRUM PRESS · CATALOG OF DRUM MEDIA ★</p>
      <h1 class="dp__title">DRUM <em>PRESS</em></h1>
      <p class="dp__strap mono">est. mar 2026 · el segundo, ca · vol. {volNo} · no. {issueNo}</p>
      <p class="dp__dek">
        A small, slightly self-aware publishing house. We put out
        <strong>{totalTitles} editions</strong> of collaborative drumming
        across <strong>{totalImprints} imprints</strong>. Each room is its
        own pressing. Some reprint nightly. Some are one-of-one. Some only
        open when others do.
      </p>
      <hr class="dp__rule" />
    </header>

    <section class="dp__now" aria-label="Now in print">
      <div class="dp__now-row">
        <p class="dp__eyebrow mono">▌ NOW IN PRINT</p>
        <p class="dp__count mono">live: <strong id="dp-count">—</strong> · pressing</p>
      </div>
      <p class="dp__tail mono" id="dp-tail" aria-live="polite">— stream open · waiting for the first beat —</p>
    </section>

    <section class="dp__features" aria-label="This week's editions">
      <p class="dp__eyebrow mono">❡ THIS WEEK'S EDITIONS</p>
      <div class="dp__features-grid" id="dp-features">
        {/* JS will randomize a 3-card spread on load. SSR a default so non-JS still gets content. */}
        <a class="dp__feature" href="/drum-v15">
          <span class="dp__feature-cat mono">DR-V15</span>
          <span class="dp__feature-title">hang</span>
          <span class="dp__feature-sub mono">handpan · steel skin</span>
          <span class="dp__feature-go mono">go to room →</span>
        </a>
        <a class="dp__feature" href="/drum-letters">
          <span class="dp__feature-cat mono">DR-COM3</span>
          <span class="dp__feature-title">letters</span>
          <span class="dp__feature-sub mono">a note for the next visitor</span>
          <span class="dp__feature-go mono">go to room →</span>
        </a>
        <a class="dp__feature" href="/drum-radio">
          <span class="dp__feature-cat mono">DR-CST5</span>
          <span class="dp__feature-title">radio</span>
          <span class="dp__feature-sub mono">96.1 fm · all rooms, on air</span>
          <span class="dp__feature-go mono">go to room →</span>
        </a>
      </div>
    </section>

    <hr class="dp__rule dp__rule--ornate" />

    <section class="dp__catalog" aria-label="The catalog">
      <p class="dp__eyebrow mono">§ THE CATALOG</p>
      <h2 class="dp__catalog-title">{totalTitles} titles · {totalImprints} imprints · in print</h2>

      {imprints.map((imp) => (
        <article class="dp__imprint" id={`imp-${imp.code.toLowerCase()}`}>
          <header class="dp__imprint-head">
            <div class="dp__imprint-id">
              <span class="dp__imprint-code mono">DR-{imp.code}</span>
              <h3 class="dp__imprint-name">{imp.name}</h3>
            </div>
            <p class="dp__imprint-blurb">{imp.blurb}</p>
            <p class="dp__imprint-meta mono">{imp.titles.length} {imp.titles.length === 1 ? 'title' : 'titles'} in print</p>
          </header>
          <ul class="dp__shelf" role="list">
            {imp.titles.map((t) => (
              <li class="dp__title">
                <a class="dp__cover" href={t.href}>
                  <span class="dp__cat mono">{t.cat}</span>
                  <span class="dp__name">{t.name}</span>
                  <span class="dp__sub mono">{t.sub}</span>
                  <span class="dp__meta mono"><span>{t.format}</span><span>{t.era}</span></span>
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </section>

    <hr class="dp__rule dp__rule--ornate" />

    <section class="dp__editor" aria-label="Editor's note">
      <p class="dp__eyebrow mono">¶ EDITOR'S NOTE</p>
      <div class="dp__editor-body">
        <p>
          PointCast began as one drum room — a single button, played in one
          tab, heard from another. We did not expect to keep building. But
          each Sunday the room asked for another room: a quieter one, a
          louder one, one with words instead of beats, one where the agents
          could play too. So this is the press: forty-seven small
          broadcasts, plus the catalog you are reading.
        </p>
        <p>
          Most of the rooms work without anyone in them. A few only open
          when others do. None of them are finished. The press is open;
          please come in.
        </p>
        <p class="dp__editor-sig mono">— the editor, el segundo</p>
      </div>
    </section>

    <hr class="dp__rule dp__rule--ornate" />

    <section class="dp__colophon" aria-label="Colophon">
      <p class="dp__eyebrow mono">※ COLOPHON</p>
      <dl class="dp__colophon-list mono">
        <div class="dp__col-row"><dt>Set in</dt><dd>JetBrains Mono &amp; system serif</dd></div>
        <div class="dp__col-row"><dt>Pressed on</dt><dd>Cloudflare Pages, Workers KV</dd></div>
        <div class="dp__col-row"><dt>Distributed via</dt><dd><a href="/api/mcp">/api/mcp</a> · <a href="/agents.json">/agents.json</a> · <a href="/llms.txt">/llms.txt</a> · <a href="/town">/town</a></dd></div>
        <div class="dp__col-row"><dt>Cross-surface bus</dt><dd><a href="/api/sounds">/api/sounds</a> — events fan out to cast surfaces</dd></div>
        <div class="dp__col-row"><dt>Editor</dt><dd>Mike (el segundo)</dd></div>
        <div class="dp__col-row"><dt>Engravers</dt><dd>many — see <a href="/drum-agents">/drum-agents</a></dd></div>
        <div class="dp__col-row"><dt>Reprints</dt><dd>nightly · daily room reprints with the visitor count</dd></div>
        <div class="dp__col-row"><dt>Errata</dt><dd>logged in <a href="/town">/town</a> blocks</dd></div>
      </dl>
      <p class="dp__return mono">
        ─── back to the press: <a href="/drum-press">/drum-press</a> ·
        the rooms: <a href="/drum">/drum</a> ·
        the front: <a href="/">/</a> ───
      </p>
    </section>

    <footer class="dp__foot">
      <p class="mono">DRUM PRESS · printed in el segundo · all editions in print · pointcast.xyz</p>
    </footer>
  </main>
</BlockLayout>

<script is:inline>
  // ── Now-in-print live wire ─────────────────────────────────────
  // Polls /api/visit for room counts and /api/sounds for the event
  // tail. Same bus the cast surfaces use. Two-second cadence is
  // gentle; this page is browseable, not stadium-loud.
  (function () {
    const countEl = document.getElementById('dp-count');
    const tailEl = document.getElementById('dp-tail');

    async function tickCount() {
      try {
        const r = await fetch('/api/visit', { cache: 'no-store' });
        const j = await r.json().catch(() => null);
        if (!j) return;
        const n = (j.activeCount ?? j.count ?? j.active ?? '—');
        if (countEl) countEl.textContent = String(n);
      } catch (_) { /* silent */ }
    }

    let lastSince = Date.now() - 30_000;
    async function tickTail() {
      try {
        const r = await fetch(`/api/sounds?since=${lastSince}`, { cache: 'no-store' });
        const j = await r.json().catch(() => null);
        if (!j || !Array.isArray(j.events)) return;
        if (j.events.length === 0) return;
        lastSince = j.now ?? Date.now();
        const e = j.events[j.events.length - 1];
        const t = new Date(e.t).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false });
        if (tailEl) tailEl.textContent = `[${t}] type=${e.type} · seed=${e.seed} · pid=${e.pid}`;
      } catch (_) { /* silent */ }
    }

    tickCount(); tickTail();
    setInterval(tickCount, 6_000);
    setInterval(tickTail, 2_000);
  })();

  // ── Featured editions randomizer ───────────────────────────────
  // Picks 3 titles from across the catalog at random on each load,
  // weighted slightly toward variety (one from instruments, one from
  // comms, one from anywhere). Falls back to SSR'd defaults if any
  // step fails.
  (function () {
    const features = document.getElementById('dp-features');
    if (!features) return;

    // Mirror of catalog — kept compact. If the page catalog grows we
    // can flip this to a data-attribute or a small JSON island.
    const POOL = [
      // [cat, href, name, sub, imprint-bucket]
      ['DR-001', '/drum',           'classic',      'the original drum',                  'first'],
      ['DR-V02', '/drum-v2',        'collab',       'pentatonic voice + leaderboard',     'vox'],
      ['DR-V03', '/drum-v3',        'spotify',      'drum along to a track',              'vox'],
      ['DR-V04', '/drum-v4',        'orchestra',    'strings + winds + the lot',          'vox'],
      ['DR-V05', '/drum-v5',        'loops',        'sixteen looping bars',               'vox'],
      ['DR-V06', '/drum-v6',        'choir',        'chord-summoning room',               'vox'],
      ['DR-V07', '/drum-v7',        'big',          'thirty pads, one room',              'vox'],
      ['DR-V08', '/drum-v8',        'symphony',     'forty-two pads, full kit',           'vox'],
      ['DR-V09', '/drum-v9',        'lounge',       'sax · after-hours',                  'inst'],
      ['DR-V10', '/drum-v10',       'theremin',     'gesture · contactless',              'inst'],
      ['DR-V11', '/drum-v11',       'bells',        'chimes · a quiet room',              'inst'],
      ['DR-V12', '/drum-v12',       'organ',        'pipes · a loud room',                'inst'],
      ['DR-V13', '/drum-v13',       'strings',      'pizz / arco',                        'inst'],
      ['DR-V14', '/drum-v14',       'marimba',      'mallets · wood + metal',             'inst'],
      ['DR-V15', '/drum-v15',       'hang',         'handpan · steel skin',               'inst'],
      ['DR-V16', '/drum-v16',       '808',          'machine · the grid',                 'inst'],
      ['DR-V17', '/drum-v17',       'harp',         'gliss · falling water',              'inst'],
      ['DR-V18', '/drum-v18',       'rhodes',       'electric piano · velvet',            'inst'],
      ['DR-ARC1','/drum-potato',    'potato',       'hot potato · do not hold',           'arc'],
      ['DR-ARC2','/drum-tv-bingo',  'bingo',        'tv game · 5 in a row',               'arc'],
      ['DR-ARC3','/drum-tv-gauntlet','gauntlet',    'tv 60-second race',                  'arc'],
      ['DR-ARC4','/drum-tv-roulette','roulette',    'tv wheel · spin to play',            'arc'],
      ['DR-COM1','/drum-shout',     'shout',        'mic · loud one-shots',               'comm'],
      ['DR-COM2','/drum-applause',  'applause',     'meter · clap together',              'comm'],
      ['DR-COM3','/drum-letters',   'letters',      'note for the next visitor',          'comm'],
      ['DR-COM4','/drum-bulletin',  'bulletin',     'pinboard · pinned by anyone',        'comm'],
      ['DR-COM5','/drum-walkie',    'walkie',       'ptt · 4 channels',                   'comm'],
      ['DR-COM6','/drum-graffiti',  'graffiti',     'wall · spray + tag',                 'comm'],
      ['DR-COM7','/drum-emoji-mesh','emoji mesh',   'storm · whole-room weather',         'comm'],
      ['DR-COM8','/drum-confessional','confessional','soft · one line at a time',         'comm'],
      ['DR-CST1','/drum-tv',        'tv',           'cast mode · the original',           'cst'],
      ['DR-CST2','/drum-tv-v2',     'venue',        'tv v2 · stage + crowd',              'cst'],
      ['DR-CST3','/drum-viz',       'viz',          'tv v3 · waveform',                   'cst'],
      ['DR-CST4','/drum-marquee',   'marquee',      'tv minimalist · ticker',             'cst'],
      ['DR-CST5','/drum-radio',     'radio',        '96.1 fm · the rooms on air',         'cst'],
      ['DR-MAC1','/drum-agents',    'agents hall',  'directory · resident agents',        'mac'],
      ['DR-MAC2','/drum-agent',     'agent room',   'play floor · type=agent',            'mac'],
      ['DR-MAC3','/api/mcp',        'mcp',          'jsonrpc · 24 tools',                 'mac'],
      ['DR-ED01','/drum-daily',     'daily',        'beat of the day · reprints',         'ed'],
      ['DR-ED02','/drum-jam',       'jam',          'three or more · live session',       'ed'],
      ['DR-ED03','/drum-pulse',     'pulse',        'heartbeat · whole-room',             'ed'],
      ['DR-ED04','/drum-apr26',     'sequencer',    'apr 26 · 8-pad sequencer',           'ed'],
      ['DR-ED05','/drum-stickers',  'stickers',     'binder · paste a sticker',           'ed'],
      ['DR-ED06','/drum-postcard',  'postcard',     'receipt of your visit',              'ed'],
      ['DR-ED07','/drum-buttons',   'buttons',      'one-shots · the panel',              'ed'],
      ['DR-ED08','/drum-trophies',  'trophies',     'on-chain · tezos editions',          'ed'],
    ];

    function pickOne(bucket) {
      const candidates = POOL.filter((p) => p[4] === bucket);
      return candidates[Math.floor(Math.random() * candidates.length)];
    }
    function pickAny(skip) {
      const candidates = POOL.filter((p) => !skip.has(p));
      return candidates[Math.floor(Math.random() * candidates.length)];
    }

    const a = pickOne('inst') || pickAny(new Set());
    const b = pickOne('comm') || pickAny(new Set([a]));
    const c = pickAny(new Set([a, b]));
    const picks = [a, b, c].filter(Boolean);
    if (picks.length < 3) return;

    features.innerHTML = picks.map(([cat, href, name, sub]) => `
      <a class="dp__feature" href="${href}">
        <span class="dp__feature-cat mono">${cat}</span>
        <span class="dp__feature-title">${name}</span>
        <span class="dp__feature-sub mono">${sub}</span>
        <span class="dp__feature-go mono">go to room →</span>
      </a>
    `).join('');
  })();
</script>

