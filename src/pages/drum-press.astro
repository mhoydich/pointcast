---
/**
 * /drum-press — the publishing house · 2026-04-29 PT.
 *
 * PointCast's drum-hub now spans 47 surfaces. This page reframes that
 * sprawl as a catalog: an inventive, slightly self-aware publishing
 * house called DRUM PRESS that puts out small noisy editions of
 * collaborative drumming. Each surface is a "title"; titles are
 * grouped into eight imprints (Voices, Instruments, Arcade, Comms,
 * Broadcast, Machine, Editions, plus the First Press).
 *
 * Per Mike 2026-04-29 (post-AgentLane): "rethink homepage for drum
 * and an almost publishing house that published tons of drum media,
 * inventive, neat publishing house, etc etc, enjoy the assignment."
 *
 * Page structure:
 *   1. Masthead — title, kicker, vol/no, dek
 *   2. Now In Print — live count + event tail (polls /api/sounds)
 *   3. This Week's Editions — 3 randomized features
 *   4. The Catalog — 8 imprints, all titles, with cat-no + sub
 *   5. Editor's Note — short essay
 *   6. Colophon — credits, tech notes, machine-readable footer
 *
 * Aesthetic: late-90s indie zine catalog meets small literary press.
 * Warm oat paper, ink black, marquee-red accent, JetBrains Mono +
 * system serif. ASCII rules and ornaments. Scoped CSS — does not
 * borrow PointCast's main palette so the imprint feels like its own
 * thing.
 *
 * IMPORTANT: literal '{' and '}' in <pre> / body text MUST be escaped
 * as &#123; / &#125; (PR #222 lesson).
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import DrumNav from '../components/DrumNav.astro';

const title = 'DRUM PRESS — catalog of drum media';
const description = 'A small, slightly self-aware publishing house that puts out 47 editions of collaborative drumming. Catalog organized by imprint: voices, instruments, arcade, communiqués, broadcast, machine, editions. Pressed nightly on Cloudflare Pages.';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://pointcast.xyz/drum-press',
  name: 'DRUM PRESS · Catalog of Drum Media',
  url: 'https://pointcast.xyz/drum-press',
  description,
  publisher: {
    '@type': 'Organization',
    name: 'PointCast',
    url: 'https://pointcast.xyz',
  },
};

// ─────────────────────────────────────────────────────────────────
// CATALOG — single source of truth. Cat-no follows the pattern
// DR-{IMPRINT}{NN}. Order within imprint is release order (earliest
// → latest), which is also numerical for the v-series.
// ─────────────────────────────────────────────────────────────────

interface Title {
  cat: string;       // catalog number, e.g. DR-V12
  href: string;      // local route
  name: string;      // display title
  sub: string;       // one-line note
  era: string;       // release month/marker
  format: string;    // pressing format note
}

interface Imprint {
  code: string;       // short imprint code, e.g. INST
  name: string;       // display name
  blurb: string;      // one-sentence editorial blurb
  titles: Title[];
}

const imprints: Imprint[] = [
