---
/**
 * /nouns-open-circuit/match/{id} - shareable v2 fixture receipt page.
 */
import BlockLayout from '../../../layouts/BlockLayout.astro';
import {
  NOC_ENDPOINTS,
  NOC_FIXTURES,
  buildNocFixtureReceipt,
  buildNocTacticsPacket,
  nocClubBySlug,
} from '../../../lib/nouns-open-circuit';

export async function getStaticPaths() {
  return NOC_FIXTURES.map((fixture) => {
    const packet = buildNocTacticsPacket({ clubSlug: fixture.home, fixtureId: fixture.id });
    const receipt = buildNocFixtureReceipt(packet);
    return {
      params: { id: fixture.id },
      props: { fixture, packet, receipt },
    };
  });
}

const { fixture, packet, receipt } = Astro.props;
const home = nocClubBySlug(fixture.home);
const away = nocClubBySlug(fixture.away);
const winner = nocClubBySlug(receipt.winner);
const title = `Nouns Open Circuit - ${fixture.id}`;
const description = `${home.code} vs ${away.code}, seed ${fixture.seed}, receipt ${receipt.eventHash}.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsEvent',
  name: `Nouns Open Circuit ${fixture.id}`,
  description,
  url: `${NOC_ENDPOINTS.human}/match/${fixture.id}`,
  competitor: [
    { '@type': 'SportsTeam', name: home.name },
    { '@type': 'SportsTeam', name: away.name },
  ],
  result: `${winner.name} ${receipt.score}`,
};
---

<BlockLayout
  title={title}
  description={description}
  image="/images/og/battle.png"
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/nouns-open-circuit.json', title: 'Nouns Open Circuit manifest (JSON)' }]}
  frame={{
    image: 'https://pointcast.xyz/images/og/battle.png',
    buttons: [
      { label: 'League Desk', action: 'link', target: NOC_ENDPOINTS.human },
      { label: 'Circuit JSON', action: 'link', target: NOC_ENDPOINTS.json },
      { label: 'Nation Battler', action: 'link', target: NOC_ENDPOINTS.incumbent },
    ],
  }}
>
  <main class="match-page">
    <nav class="match-nav" aria-label="Nouns Open Circuit breadcrumb">
      <a href="/nouns-open-circuit">Nouns Open Circuit</a>
      <span>/</span>
      <strong>{fixture.id}</strong>
    </nav>

    <section class="match-hero" aria-label="Fixture receipt">
      <div>
        <p class="kicker">{fixture.tag} / {fixture.tempo}</p>
        <h1>{home.code} vs {away.code}</h1>
        <p>{fixture.label} resolves into a v2 receipt with packet hash, event hash, agent trail, and a stable citation.</p>
      </div>
      <div class="score-card">
        <span>winner</span>
        <strong>{winner.code}</strong>
        <b>{receipt.score}</b>
        <small>{receipt.eventHash}</small>
      </div>
    </section>

    <section class="team-row" aria-label="Fixture clubs">
      <article style={`--club:${home.color};`}>
        <img src={home.image} alt="" loading="eager" />
        <div>
          <span>{home.code}</span>
          <strong>{home.name}</strong>
          <p>{home.doctrine}</p>
        </div>
      </article>
      <article style={`--club:${away.color};`}>
        <img src={away.image} alt="" loading="eager" />
        <div>
          <span>{away.code}</span>
          <strong>{away.name}</strong>
          <p>{away.doctrine}</p>
        </div>
      </article>
    </section>

    <section class="receipt-grid" aria-label="Packet and receipt">
      <article>
        <div class="panel-head">
          <span>Tactics Packet</span>
          <strong>{packet.formation}</strong>
        </div>
        <pre>{JSON.stringify(packet, null, 2)}</pre>
      </article>

      <article>
        <div class="panel-head">
          <span>Fixture Receipt</span>
          <strong>{receipt.packetHash}</strong>
        </div>
        <pre>{JSON.stringify(receipt, null, 2)}</pre>
      </article>
    </section>

    <section class="timeline" aria-label="Agent timeline">
      <div class="panel-head">
        <span>Agent Trail</span>
        <strong>{receipt.agents.length} agents</strong>
      </div>
      {receipt.timeline.map((event) => {
        const actor = nocClubBySlug(event.actor);
        return (
          <article>
            <b>{event.minute}' {event.agent}</b>
            <strong>{event.artifact}</strong>
            <span>{actor.code} +{event.delta}</span>
            <p>{event.note}</p>
          </article>
        );
      })}
    </section>
  </main>
</BlockLayout>

<style>
  .match-page {
    display: grid;
    gap: 14px;
    color: #15161a;
  }

  .match-nav,
  .kicker,
  .score-card span,
  .score-card small,
  .panel-head span,
  .timeline b,
  .timeline span {
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace);
    letter-spacing: 0;
  }

  .match-nav {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    font-size: 0.8rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  .match-nav a {
    color: #185fa5;
    text-decoration: none;
  }

  .match-hero {
    min-height: min(480px, calc(100vh - 180px));
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 0.38fr);
    gap: 16px;
    align-items: stretch;
    border: 3px solid #15161a;
    background:
      linear-gradient(100deg, rgba(239, 125, 45, 0.16), transparent 40%, rgba(24, 95, 165, 0.14)),
      #fff9ea;
    box-shadow: 6px 6px 0 #15161a;
    padding: 18px;
  }

  .match-hero > div:first-child {
    display: grid;
    align-content: center;
    gap: 12px;
  }

  .kicker,
  .score-card span,
  .score-card small,
  .panel-head span,
  .timeline b,
  .timeline span {
    color: #64675f;
    font-size: 0.75rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 10vw, 8rem);
    line-height: 0.88;
  }

  .match-hero p {
    max-width: 760px;
    margin: 0;
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.45;
    font-weight: 850;
  }

  .score-card {
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 8px;
    border: 3px solid #15161a;
    background: #fffdf5;
    padding: 16px;
    text-align: center;
  }

  .score-card strong {
    font-size: clamp(3rem, 8vw, 5.4rem);
    line-height: 0.9;
  }

  .score-card b {
    font-size: 2rem;
  }

  .team-row,
  .receipt-grid {
    display: grid;
    gap: 12px;
  }

  .team-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .team-row article,
  .receipt-grid article,
  .timeline {
    min-width: 0;
    border: 3px solid #15161a;
    background: #fff9ea;
    padding: 12px;
  }

  .team-row article {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 12px;
    border-left: 10px solid var(--club);
  }

  .team-row img {
    width: 92px;
    height: 92px;
    border: 2px solid #15161a;
    background: #fffdf5;
    image-rendering: pixelated;
  }

  .team-row span {
    color: var(--club);
    font-weight: 1000;
  }

  .team-row strong {
    display: block;
    font-size: 1.25rem;
  }

  .team-row p {
    margin: 5px 0 0;
    line-height: 1.35;
    font-weight: 850;
  }

  .receipt-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .panel-head {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
  }

  .panel-head strong {
    min-width: 0;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    text-align: right;
  }

  pre {
    min-height: 360px;
    max-height: 520px;
    overflow: auto;
    margin: 0;
    border: 2px solid #15161a;
    background: #101216;
    color: #fffdf5;
    padding: 10px;
    font-size: 0.78rem;
    line-height: 1.45;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }

  .timeline {
    display: grid;
    gap: 8px;
  }

  .timeline .panel-head {
    margin-bottom: 0;
  }

  .timeline article {
    display: grid;
    grid-template-columns: 120px 1fr 72px;
    gap: 8px;
    align-items: center;
    border: 2px solid #15161a;
    background: #fffdf5;
    padding: 8px;
  }

  .timeline strong {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .timeline p {
    grid-column: 1 / -1;
    margin: 0;
    color: #4a4d47;
    font-weight: 850;
  }

  @media (max-width: 820px) {
    .match-hero,
    .team-row,
    .receipt-grid,
    .timeline article {
      grid-template-columns: 1fr;
    }

    .team-row article {
      grid-template-columns: 76px 1fr;
    }

    .team-row img {
      width: 76px;
      height: 76px;
    }
  }

  @media (max-width: 560px) {
    .match-hero {
      min-height: 0;
      padding: 12px;
    }

    h1 {
      font-size: clamp(2.6rem, 18vw, 4.6rem);
    }
  }
</style>
