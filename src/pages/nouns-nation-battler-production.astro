---
/**
 * /nouns-nation-battler-production - local-first Production Desk for
 * accepted work, TV queueing, rooting cards, and Nouns Bowl hype.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import {
  NOUNS_BATTLER_AGENT_BENCH_VERSION,
  NOUNS_BATTLER_BROADCAST_DIRECTOR,
  NOUNS_BATTLER_NOUNS_BOWL_HYPE,
  NOUNS_BATTLER_PARTICIPANT_YIELD,
  NOUNS_BATTLER_PRODUCTION_DESK,
  NOUNS_BATTLER_ROOTING_LAYER,
  NOUNS_BATTLER_SEASON_ARCHIVE,
  NOUNS_BATTLER_WORK_CONTRIBUTION_TYPES,
} from '../lib/nouns-battler-agent-bench';

const gangs = [
  { name: 'Tomato Noggles', short: 'TN', color: '#e45745', soft: '#fff0a6' },
  { name: 'Cobalt Frames', short: 'CF', color: '#3677e0', soft: '#dcecff' },
  { name: 'Golden Nouncil', short: 'GN', color: '#d49b19', soft: '#fff5c7' },
  { name: 'Garden Stack', short: 'GS', color: '#3f9b54', soft: '#dff8df' },
  { name: 'Pixel Union', short: 'PU', color: '#8b5cf6', soft: '#eee6ff' },
  { name: 'Night Auction', short: 'NA', color: '#2f3a4f', soft: '#dfe5f8' },
  { name: 'Sunset Prop House', short: 'SP', color: '#ef7d2d', soft: '#ffe5d1' },
  { name: 'Mint Condition', short: 'MC', color: '#13a6a1', soft: '#d4fff8' },
];

const statuses = ['draft', 'in-review', 'accepted', 'shipped'];
const participantKinds = ['human-and-agent', 'agent-builder', 'human-host', 'artist-operator', 'watch-party'];
const targetSurfaces = ['TV cast', 'Desk Wall', 'Agent Bench', 'Poster Wall', 'Sponsorship Desk', 'Nouns Bowl hype rail'];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Nouns Nation Battler Production Desk',
  description:
    'A local-first production desk for Nouns Nation Battler accepted-work ledgers, broadcast queues, rooting cards, season archive cards, and Nouns Bowl hype week.',
  url: 'https://pointcast.xyz/nouns-nation-battler-production/',
  isPartOf: {
    '@type': 'VideoGame',
    name: 'Nouns Nation Battler',
    url: 'https://pointcast.xyz/nouns-nation-battler/',
  },
};
---

<BlockLayout
  title="Nouns Battler Production Desk"
  description="Turn Nouns Nation Battler fun into accepted work: local ledger cards, broadcast queue items, rooting cards, season archive beats, and Nouns Bowl hype week for humans and agents."
  image="/images/og/battle.png"
  jsonLd={jsonLd}
  alternates={[
    { type: 'application/json', href: '/nouns-nation-battler.json', title: 'Nouns Nation Battler manifest' },
    { type: 'application/json', href: '/nouns-nation-battler-agents.json', title: 'Nouns Nation Battler Agent Bench' },
  ]}
  frame={{
    image: 'https://pointcast.xyz/images/og/battle.png',
    buttons: [
      { label: 'Production', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-production/' },
      { label: 'TV Cast', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-tv/' },
      { label: 'Agent Desk', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-agents/desk/' },
      { label: 'Sponsors', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-sponsors/' },
    ],
  }}
>
  <main class="production-desk" data-production-desk>
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/nouns-nation-battler/">Nouns Nation Battler</a>
      <span aria-hidden="true">/</span>
      <span>Production</span>
    </nav>

    <section class="hero" aria-labelledby="production-title">
      <div class="hero__copy">
        <p class="kicker">CH.BTL / PRODUCTION DESK / v{NOUNS_BATTLER_AGENT_BENCH_VERSION}</p>
        <h1 id="production-title">Turn the fun into accepted work.</h1>
        <p>
          This is the operating room after the weird match happens: log accepted human or agent work,
          queue TV segments, make rooting cards, reuse the first four seasons, and package Nouns Bowl
          hype without collecting private identity or promising automatic payouts.
        </p>
        <nav class="hero-actions" aria-label="Production desk links">
          <a class="primary" href="#ledger">Accepted Work Ledger</a>
          <a href="#director">Broadcast Director Mode</a>
          <a href="#rooting">Rooting Layer</a>
          <a href="/api/mcp-v2">MCP</a>
        </nav>
      </div>
      <div class="hero__nouns" aria-label="Featured rooting Nouns">
        {NOUNS_BATTLER_ROOTING_LAYER.rootingNouns.map((noun) => (
          <article style={`--gang: ${gangs.find((gang) => gang.name === noun.gang)?.color || '#17130f'};`}>
            <img src={noun.asset} alt={`Noun ${noun.number} for ${noun.gang}`} loading="eager" width="128" height="128" />
            <span>#{noun.number}</span>
            <strong>{noun.gang}</strong>
          </article>
        ))}
      </div>
    </section>

    <section class="guardrail-strip" aria-label="Production guardrails">
      {NOUNS_BATTLER_PRODUCTION_DESK.guardrails.map((guardrail) => (
        <span>{guardrail}</span>
      ))}
    </section>

    <section class="loop-grid" aria-labelledby="loop-title">
      <div class="section-head">
        <p class="kicker">Production loop</p>
        <h2 id="loop-title">A visible path from contribution to credit.</h2>
      </div>
      <div class="loop-cards">
        {NOUNS_BATTLER_PRODUCTION_DESK.mainLoop.map((step, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{step}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="ledger" class="ledger-grid" aria-label="Accepted Work Ledger">
      <aside class="type-panel">
        <div class="section-head">
          <p class="kicker">Accepted Work Ledger</p>
          <h2>Choose the contribution.</h2>
        </div>
        <div class="type-stack" data-type-stack>
          {NOUNS_BATTLER_WORK_CONTRIBUTION_TYPES.map((type, index) => (
            <button type="button" class:list={['type-pick', index === 2 && 'is-active']} data-type-index={index}>
              <span>{type.routeTo}</span>
              <strong>{type.label}</strong>
              <em>{type.rewardSignal}</em>
            </button>
          ))}
        </div>
      </aside>

      <section class="ledger-panel">
        <form class="ledger-form" data-ledger-form>
          <label>
            Contributor display
            <input data-contributor value="Agent Noun #421" />
          </label>
          <label>
            Gang or field focus
            <select data-gang-select>
              {gangs.map((gang) => (
                <option value={gang.name}>{gang.name}</option>
              ))}
            </select>
          </label>
          <label>
            Status
            <select data-status-select>
              {statuses.map((status) => (
                <option value={status}>{status}</option>
              ))}
            </select>
          </label>
          <label>
            Participant mode
            <select data-participant-kind>
              {participantKinds.map((kind) => (
                <option value={kind}>{kind}</option>
              ))}
            </select>
          </label>
          <label class="wide">
            Work title
            <input data-work-title value="Next Slate Lower-Third" />
          </label>
          <label class="wide">
            Proof note
            <textarea rows="3" data-proof-note>Includes a Noun number, field cue, and target surface route.</textarea>
          </label>
          <label class="wide">
            Proof URL
            <input data-proof-url value="https://pointcast.xyz/nouns-nation-battler-tv/" />
          </label>
        </form>

        <article class="ledger-card" data-ledger-card style={`--gang: ${gangs[0].color}; --gang-soft: ${gangs[0].soft};`}>
          <div class="card-top">
            <div>
              <p class="kicker" data-type-route>TV cast and Broadcast Director queue</p>
              <h2 data-type-title>TV Lower-Third</h2>
            </div>
            <span data-gang-short>TN</span>
          </div>
          <pre data-ledger-output></pre>
          <div class="button-row">
            <button type="button" data-copy-ledger>Copy ledger card</button>
            <button type="button" data-copy-director>Copy director brief</button>
            <button type="button" data-save-ledger>Save local ledger</button>
            <button type="button" data-mark-accepted>Mark accepted</button>
          </div>
          <p class="copy-status" data-copy-status>Ready for human review.</p>
        </article>
      </section>
    </section>

    <section class="output-grid" aria-label="Production outputs">
      <article>
        <p class="kicker">Broadcast brief</p>
        <pre data-director-output></pre>
      </article>
      <article>
        <p class="kicker">Participant credit preview</p>
        <pre data-credit-output></pre>
      </article>
      <article>
        <p class="kicker">Agent task handoff</p>
        <pre data-agent-output></pre>
      </article>
    </section>

    <section id="director" class="director" aria-labelledby="director-title">
      <div class="section-head">
        <p class="kicker">Broadcast Director Mode</p>
        <h2 id="director-title">Queue the next thing a viewer sees.</h2>
      </div>
      <div class="director-grid">
        {NOUNS_BATTLER_BROADCAST_DIRECTOR.segmentTypes.map((segment) => (
          <button type="button" class="segment-card" data-segment-id={segment.id}>
            <span>{segment.id}</span>
            <strong>{segment.label}</strong>
            <em>{segment.lowerThird}</em>
            <p>{segment.visualCue}</p>
          </button>
        ))}
      </div>
      <article class="queue-card">
        <div>
          <p class="kicker">Local broadcast queue</p>
          <h3 data-segment-title>Pregame</h3>
        </div>
        <pre data-queue-output></pre>
        <div class="button-row">
          <button type="button" data-save-queue>Save queue item</button>
          <button type="button" data-copy-queue>Copy queue item</button>
        </div>
      </article>
    </section>

    <section id="rooting" class="rooting" aria-labelledby="rooting-title">
      <div class="section-head">
        <p class="kicker">Rooting Layer</p>
        <h2 id="rooting-title">Actual Nouns make the next slate easier to care about.</h2>
      </div>
      <div class="root-grid">
        {NOUNS_BATTLER_ROOTING_LAYER.rootingNouns.map((noun, index) => (
          <article class:list={['root-card', index === 0 && 'is-active']} data-root-index={index}>
            <img src={noun.asset} alt={`Noun ${noun.number}`} loading="lazy" width="150" height="150" />
            <span>Noun #{noun.number}</span>
            <h3>{noun.gang}</h3>
            <p>{noun.watchAngle}</p>
            <code>{noun.chant}</code>
            <button type="button" data-root-copy={index}>Copy rooting card</button>
          </article>
        ))}
      </div>
    </section>

    <section id="archive" class="archive" aria-labelledby="archive-title">
      <div class="section-head">
        <p class="kicker">Season Archive</p>
        <h2 id="archive-title">The first four seasons are production inventory now.</h2>
      </div>
      <div class="archive-grid">
        {NOUNS_BATTLER_SEASON_ARCHIVE.seasons.map((season) => (
          <article>
            <img src={season.localNounAsset} alt={`${season.mvp} highlight sprite`} loading="lazy" width="128" height="128" />
            <div>
              <span>{season.season}</span>
              <h3>{season.title}</h3>
              <p>{season.line}</p>
              <dl>
                <div>
                  <dt>Champion</dt>
                  <dd>{season.champion}</dd>
                </div>
                <div>
                  <dt>MVP</dt>
                  <dd>{season.mvp}</dd>
                </div>
                <div>
                  <dt>Field</dt>
                  <dd>{season.field}</dd>
                </div>
              </dl>
              <code>{season.sponsorInventory}</code>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="bowl" class="bowl" aria-labelledby="bowl-title">
      <div class="section-head">
        <p class="kicker">Nouns Bowl Hype Week</p>
        <h2 id="bowl-title">Final-week prompts for agents, hosts, sponsors, and poster people.</h2>
      </div>
      <div class="bowl-grid">
        {NOUNS_BATTLER_NOUNS_BOWL_HYPE.phases.map((phase) => (
          <article>
            <span>{phase.id}</span>
            <h3>{phase.title}</h3>
            <p>{phase.output}</p>
            <code>Route: {NOUNS_BATTLER_NOUNS_BOWL_HYPE.route}</code>
          </article>
        ))}
      </div>
    </section>

    <section class="saved" aria-labelledby="saved-title">
      <div class="section-head">
        <p class="kicker">Local records</p>
        <h2 id="saved-title">Saved only in this browser.</h2>
      </div>
      <div class="saved-grid">
        <article>
          <h3>Ledger</h3>
          <div data-saved-ledger><p>No local ledger cards yet.</p></div>
        </article>
        <article>
          <h3>Broadcast queue</h3>
          <div data-saved-queue><p>No queue items yet.</p></div>
        </article>
      </div>
    </section>
  </main>
</BlockLayout>

<script
  define:vars={{
    contributionTypes: NOUNS_BATTLER_WORK_CONTRIBUTION_TYPES,
    productionDesk: NOUNS_BATTLER_PRODUCTION_DESK,
    director: NOUNS_BATTLER_BROADCAST_DIRECTOR,
    rootingLayer: NOUNS_BATTLER_ROOTING_LAYER,
    participantYield: NOUNS_BATTLER_PARTICIPANT_YIELD,
    gangs,
    targetSurfaces,
  }}
>
  const root = document.querySelector('[data-production-desk]');
  const state = { typeIndex: 2, segmentId: 'pregame' };

  function el(selector) {
    return root?.querySelector(selector);
  }

  function all(selector) {
    return Array.from(root?.querySelectorAll(selector) || []);
  }

  function selectedType() {
    return contributionTypes[state.typeIndex] || contributionTypes[2] || contributionTypes[0];
  }

  function selectedGang() {
    const value = el('[data-gang-select]')?.value || gangs[0].name;
    return gangs.find((gang) => gang.name === value) || gangs[0];
  }

  function selectedSegment() {
    return director.segmentTypes.find((segment) => segment.id === state.segmentId) || director.segmentTypes[0];
  }

  function values() {
    return {
      type: selectedType(),
      gang: selectedGang(),
      contributor: el('[data-contributor]')?.value?.trim() || 'Agent Noun #421',
      status: el('[data-status-select]')?.value || 'draft',
      participantKind: el('[data-participant-kind]')?.value || 'human-and-agent',
      title: el('[data-work-title]')?.value?.trim() || 'Next Slate Lower-Third',
      proofNote:
        el('[data-proof-note]')?.value?.trim() ||
        'Includes a Noun number, field cue, and target surface route.',
      proofUrl: el('[data-proof-url]')?.value?.trim() || 'https://pointcast.xyz/nouns-nation-battler-tv/',
    };
  }

  function buildLedgerCard() {
    const v = values();
    return [
      `ACCEPTED WORK LEDGER: ${v.type.label}`,
      `Status: ${v.status}`,
      `Contributor: ${v.contributor}`,
      `Focus: ${v.gang.name}`,
      `Title: ${v.title}`,
      `Proof needed: ${v.type.proof}`,
      `Proof note: ${v.proofNote}`,
      `Proof URL: ${v.proofUrl}`,
      `Reward signal: ${v.type.rewardSignal}`,
      `Route to: ${v.type.routeTo}`,
      'Guardrail: human approval required before credit, sponsor use, bounty allocation, or payout.',
    ].join('\n');
  }

  function buildDirectorBrief() {
    const v = values();
    const segment = selectedSegment();
    return [
      `DIRECTOR BRIEF: ${v.title}`,
      `Segment: ${segment.label}`,
      `Lower-third: ${segment.lowerThird.replace('{gang}', v.gang.name).replace('{field}', v.type.routeTo).replace('{noun}', '12').replace('{sponsor}', v.contributor)}`,
      `Host line: ${v.contributor} brought ${v.title}; verify proof, then route it to ${v.type.routeTo}.`,
      `Visual cue: ${segment.visualCue}`,
      `Target: ${targetSurfaces[0]}`,
    ].join('\n');
  }

  function buildCreditPreview() {
    const v = values();
    return [
      `Participant mode: ${v.participantKind}`,
      `Contribution score: ${participantYield.contributionScore}`,
      `Selected signal: ${v.type.rewardSignal}`,
      `Accepted use: ${v.type.acceptedUse}`,
      'Credit is a manual accounting preview, not an automatic payout or promised return.',
    ].join('\n');
  }

  function buildAgentTask() {
    const v = values();
    return [
      `AGENT PRODUCTION TASK: ${v.type.id}`,
      `Contributor/focus: ${v.contributor} for ${v.gang.name}`,
      `Make or verify: ${v.title}`,
      `Proof: ${v.type.proof}; ${v.proofNote}`,
      `Route: ${v.type.routeTo}`,
      'Return a concise ledger card and one broadcast-ready line for human approval.',
    ].join('\n');
  }

  function buildQueueItem() {
    const v = values();
    const segment = selectedSegment();
    return [
      `QUEUE ITEM: ${segment.label}`,
      `Work: ${v.title}`,
      `Focus: ${v.gang.name}`,
      `Lower-third: ${segment.lowerThird.replace('{gang}', v.gang.name).replace('{field}', v.type.routeTo).replace('{noun}', '12').replace('{sponsor}', v.contributor)}`,
      `Host line: route ${v.type.label} to ${v.type.routeTo} after human approval.`,
      `Visual: ${segment.visualCue}`,
    ].join('\n');
  }

  function render() {
    const v = values();
    all('[data-type-index]').forEach((button) => {
      button.classList.toggle('is-active', Number(button.dataset.typeIndex) === state.typeIndex);
    });
    all('[data-segment-id]').forEach((button) => {
      button.classList.toggle('is-active', button.dataset.segmentId === state.segmentId);
    });
    el('[data-type-route]').textContent = v.type.routeTo;
    el('[data-type-title]').textContent = v.type.label;
    el('[data-gang-short]').textContent = v.gang.short;
    el('[data-ledger-card]').style.setProperty('--gang', v.gang.color);
    el('[data-ledger-card]').style.setProperty('--gang-soft', v.gang.soft);
    el('[data-ledger-output]').textContent = buildLedgerCard();
    el('[data-director-output]').textContent = buildDirectorBrief();
    el('[data-credit-output]').textContent = buildCreditPreview();
    el('[data-agent-output]').textContent = buildAgentTask();
    el('[data-segment-title]').textContent = selectedSegment().label;
    el('[data-queue-output]').textContent = buildQueueItem();
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function stored(key) {
    try {
      return JSON.parse(localStorage.getItem(key) || '[]');
    } catch {
      return [];
    }
  }

  function saveStored(key, item) {
    const items = stored(key);
    items.unshift({ when: new Date().toLocaleString(), ...item });
    localStorage.setItem(key, JSON.stringify(items.slice(0, 12)));
  }

  function renderStored() {
    const ledgerTarget = el('[data-saved-ledger]');
    const queueTarget = el('[data-saved-queue]');
    const ledgerItems = stored(productionDesk.storageKeys.ledger);
    const queueItems = stored(productionDesk.storageKeys.broadcastQueue);
    if (ledgerTarget) {
      ledgerTarget.innerHTML = ledgerItems.length
        ? ledgerItems.map((item) => `<article><span>${escapeHtml(item.when)}</span><pre>${escapeHtml(item.card)}</pre></article>`).join('')
        : '<p>No local ledger cards yet.</p>';
    }
    if (queueTarget) {
      queueTarget.innerHTML = queueItems.length
        ? queueItems.map((item) => `<article><span>${escapeHtml(item.when)}</span><pre>${escapeHtml(item.card)}</pre></article>`).join('')
        : '<p>No queue items yet.</p>';
    }
  }

  async function copyText(text, label) {
    try {
      await navigator.clipboard.writeText(text);
      el('[data-copy-status]').textContent = `${label} copied.`;
    } catch {
      el('[data-copy-status]').textContent = `${label}: ${text}`;
    }
  }

  all('[data-type-index]').forEach((button) => {
    button.addEventListener('click', () => {
      state.typeIndex = Number(button.dataset.typeIndex);
      render();
    });
  });

  all('[data-segment-id]').forEach((button) => {
    button.addEventListener('click', () => {
      state.segmentId = button.dataset.segmentId;
      render();
    });
  });

  all('[data-ledger-form] input, [data-ledger-form] textarea, [data-ledger-form] select').forEach((control) => {
    control.addEventListener('input', render);
    control.addEventListener('change', render);
  });

  all('[data-root-copy]').forEach((button) => {
    button.addEventListener('click', () => {
      const noun = rootingLayer.rootingNouns[Number(button.dataset.rootCopy)] || rootingLayer.rootingNouns[0];
      copyText(
        `ROOT CARD: Noun #${noun.number} rides with ${noun.gang}; chant "${noun.chant}"; watch angle ${noun.watchAngle}; TV https://pointcast.xyz/nouns-nation-battler-tv/`,
        'Rooting card',
      );
      saveStored(productionDesk.storageKeys.rootingCards, { card: `Noun #${noun.number} / ${noun.gang} / ${noun.chant}` });
    });
  });

  el('[data-copy-ledger]')?.addEventListener('click', () => copyText(buildLedgerCard(), 'Ledger card'));
  el('[data-copy-director]')?.addEventListener('click', () => copyText(buildDirectorBrief(), 'Director brief'));
  el('[data-copy-queue]')?.addEventListener('click', () => copyText(buildQueueItem(), 'Queue item'));
  el('[data-save-ledger]')?.addEventListener('click', () => {
    saveStored(productionDesk.storageKeys.ledger, { card: buildLedgerCard() });
    el('[data-copy-status]').textContent = 'Ledger saved locally.';
    renderStored();
  });
  el('[data-save-queue]')?.addEventListener('click', () => {
    saveStored(productionDesk.storageKeys.broadcastQueue, { card: buildQueueItem() });
    el('[data-copy-status]').textContent = 'Queue item saved locally.';
    renderStored();
  });
  el('[data-mark-accepted]')?.addEventListener('click', () => {
    el('[data-status-select]').value = 'accepted';
    render();
    saveStored(productionDesk.storageKeys.ledger, { card: buildLedgerCard() });
    el('[data-copy-status]').textContent = 'Marked accepted and saved locally.';
    renderStored();
  });

  render();
  renderStored();
</script>

<style>
  .production-desk {
    --ink: #17130f;
    --paper: #fffaf0;
    --line: rgba(23, 19, 15, 0.18);
    min-height: 100vh;
    padding: 24px clamp(16px, 3vw, 44px) 72px;
    color: var(--ink);
    background:
      linear-gradient(90deg, rgba(228, 87, 69, 0.12), rgba(19, 166, 161, 0.1)),
      repeating-linear-gradient(0deg, rgba(23, 19, 15, 0.035) 0 1px, transparent 1px 22px),
      #fff7e8;
  }

  .crumb,
  .hero-actions,
  .button-row,
  .guardrail-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .crumb {
    margin-bottom: 22px;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
  }

  .crumb a,
