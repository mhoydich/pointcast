---
import BlockLayout from '../layouts/BlockLayout.astro';

const CONTRACT = 'KT1HZVd9Cjc2CMe3sQvXgbxhpJkdena21pih';
const OBJKT_COLLECTION_URL = `https://objkt.com/collections/tezos/${CONTRACT}`;
const TZKT_CONTRACT_URL = `https://tzkt.io/${CONTRACT}/tokens`;
const TZKT_TOKENS_API = `https://api.tzkt.io/v1/tokens?contract=${CONTRACT}&limit=48&select=tokenId,metadata`;
const OBJKT_GRAPHQL = 'https://data.objkt.com/v3/graphql';

type CollectionStats = {
  items: number;
  owners: number;
  floorMutez: number | null;
  volume24hMutez: number | null;
  volumeTotalMutez: number | null;
};

type Token = {
  tokenId: string;
  name: string;
  traits: { name: string; value: string }[];
  cdn: string;
  fallback: string;
  objkt: string;
};

const fallbackStats: CollectionStats = {
  items: 37802,
  owners: 5712,
  floorMutez: 9590000,
  volume24hMutez: 7204990,
  volumeTotalMutez: 412916549713,
};

function tez(mutez: number | null) {
  if (mutez === null || Number.isNaN(mutez)) return '—';
  const value = mutez / 1_000_000;
  return `${new Intl.NumberFormat('en-US', {
    minimumFractionDigits: value >= 100 ? 0 : 2,
    maximumFractionDigits: value >= 100 ? 0 : 2,
  }).format(value)} ꜩ`;
}

function count(value: number) {
  return new Intl.NumberFormat('en-US').format(value);
}

function ipfsToGateway(uri?: string) {
  if (!uri) return '';
  return uri.startsWith('ipfs://')
    ? `https://ipfs.io/ipfs/${uri.replace('ipfs://', '')}`
    : uri;
}

async function getCollectionStats(): Promise<CollectionStats> {
  const query = `
    query Collection($address:String!) {
      fa(where:{contract:{_eq:$address}}) {
        editions
        items
        owners
        floor_price
        volume_24h
        volume_total
      }
    }
  `;

  try {
    const res = await fetch(OBJKT_GRAPHQL, {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ query, variables: { address: CONTRACT } }),
    });
    if (!res.ok) return fallbackStats;
    const json = await res.json();
    const fa = json?.data?.fa?.[0];
    if (!fa) return fallbackStats;
    return {
      items: Number(fa.items ?? fa.editions ?? fallbackStats.items),
      owners: Number(fa.owners ?? fallbackStats.owners),
      floorMutez: fa.floor_price === null ? null : Number(fa.floor_price),
      volume24hMutez: fa.volume_24h === null ? null : Number(fa.volume_24h),
      volumeTotalMutez: fa.volume_total === null ? null : Number(fa.volume_total),
    };
  } catch {
    return fallbackStats;
  }
}

async function getTokens(): Promise<Token[]> {
  try {
    const res = await fetch(TZKT_TOKENS_API);
    if (!res.ok) return [];
    const rows = await res.json();
    return rows.map((row: any) => {
      const tokenId = String(row.tokenId);
      const metadata = row.metadata ?? {};
      const fallback =
        ipfsToGateway(metadata.thumbnailUri) ||
        ipfsToGateway(metadata.displayUri) ||
        ipfsToGateway(metadata.artifactUri);

      return {
        tokenId,
        name: metadata.name ?? `Skele ${tokenId}`,
        traits: Array.isArray(metadata.attributes) ? metadata.attributes : [],
        cdn: `https://assets.objkt.media/file/assets-003/${CONTRACT}/${tokenId}/thumb400`,
        fallback,
        objkt: `https://objkt.com/tokens/${CONTRACT}/${tokenId}`,
      };
    });
  } catch {
    return [];
  }
}

const [stats, tokens] = await Promise.all([getCollectionStats(), getTokens()]);

const traitAnatomy = [
  { name: 'Hat', examples: '🎧 💀 👑 🧢' },
  { name: 'Glasses', examples: '🧡 🤓 😎 🥽' },
  { name: 'Body', examples: '🏆 🥝 🍄 🧊' },
  { name: 'Arm', examples: '🍎 🥚 ⚡ 🪩' },
  { name: 'Hand', examples: '🍆 🧹 🦴 🔑' },
  { name: 'Bottom', examples: '🎉 💀 👖 🛼' },
  { name: 'Top', examples: '🟡 🌭 🌈 🧃' },
  { name: 'Background', examples: '👻 🥶 🌊 🔥' },
];

const title = 'randomly common skeles';
const description =
  'A PointCast-native room for randomly common skeles, the 37,802-piece animated FA2 collection by John Karel on Tezos.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://pointcast.xyz/rcs',
  name: 'randomly common skeles',
  description,
  url: 'https://pointcast.xyz/rcs',
  mainEntity: {
    '@type': 'VisualArtwork',
    name: 'randomly common skeles',
    creator: { '@type': 'Person', name: 'John Karel' },
    artform: 'Animated GIF generative collection',
    identifier: CONTRACT,
    url: OBJKT_COLLECTION_URL,
  },
};
---

<BlockLayout title="RCS" description={description} jsonLd={jsonLd}>
  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>rcs</span>
    </nav>

    <header class="hero">
      <div>
        <p class="kicker">POINTCAST · TEZOS COLLECTION</p>
        <h1>randomly common skeles</h1>
        <p class="dek">
          Thirty-seven thousand animated skeletons, each built from eight emoji
          traits and sealed as an FA2 token on Tezos. Common by name, wildly
          specific in the hand.
        </p>
      </div>
      <figure class="hero-card">
        <img src={tokens[0]?.cdn} data-fallback={tokens[0]?.fallback} alt={tokens[0]?.name ?? 'randomly common skele'} />
        <figcaption>{tokens[0]?.name ?? 'RCS'}</figcaption>
      </figure>
    </header>

    <section class="stats" aria-label="Collection stats">
      <article>
        <span>items</span>
        <strong>{count(stats.items)}</strong>
      </article>
      <article>
        <span>owners</span>
        <strong>{count(stats.owners)}</strong>
      </article>
      <article>
        <span>floor</span>
        <strong>{tez(stats.floorMutez)}</strong>
      </article>
      <article>
        <span>24h vol</span>
        <strong>{tez(stats.volume24hMutez)}</strong>
      </article>
      <article>
        <span>total vol</span>
        <strong>{tez(stats.volumeTotalMutez)}</strong>
      </article>
      <article class="contract">
        <span>contract</span>
        <strong>{CONTRACT.slice(0, 8)}…{CONTRACT.slice(-6)}</strong>
      </article>
    </section>

    <section class="grid-head">
      <div>
        <p class="kicker">LIVE GRID</p>
        <h2>48 skeles from the contract</h2>
      </div>
      <a class="button" href={OBJKT_COLLECTION_URL} target="_blank" rel="noopener">
        Browse all {count(stats.items)}
      </a>
    </section>

    <section class="token-grid" aria-label="randomly common skeles token grid">
      {tokens.map((token) => (
        <a class="token" href={token.objkt} target="_blank" rel="noopener">
          <img src={token.cdn} data-fallback={token.fallback} alt={token.name} loading="lazy" />
          <span class="token__name">{token.name}</span>
          <span class="token__id">#{token.tokenId.slice(0, 8)}…</span>
        </a>
      ))}
    </section>

    <section class="story">
      <article>
        <p class="kicker">ABOUT</p>
        <h2>Skeletons as a common language.</h2>
        <p>
          Randomly common skeles are randomly generated skeleton GIFs by John
          Karel, coded through objkt and minted on Tezos. The collection has the
          feeling of a tiny toybox with a very large population: every skele
          shares the same dance, but the emoji anatomy turns each one into a
          small character read.
        </p>
        <p>
          PointCast keeps this page as a clean front door for humans and agents:
          one contract, current market stats, a fast visual sample, and direct
          links back to the canonical marketplaces and indexers.
        </p>
      </article>

      <article class="traits">
        <p class="kicker">ANATOMY</p>
        <h2>Eight traits, infinite attitude.</h2>
        <div class="trait-grid">
          {traitAnatomy.map((trait) => (
            <div class="trait">
              <span>{trait.name}</span>
              <strong>{trait.examples}</strong>
            </div>
          ))}
        </div>
      </article>
    </section>

    <section class="agent-strip" aria-label="Machine-readable resources">
      <p class="kicker">MACHINE-READABLE</p>
      <ul>
        <li><a href={TZKT_TOKENS_API}>TzKT token API</a></li>
        <li><a href={OBJKT_COLLECTION_URL}>objkt collection</a></li>
        <li><a href={TZKT_CONTRACT_URL}>contract on TzKT</a></li>
        <li><a href="/for-agents">/for-agents</a></li>
      </ul>
    </section>
  </main>
</BlockLayout>

<script>
  document.querySelectorAll('img[data-fallback]').forEach((img) => {
    img.addEventListener('error', () => {
      const fallback = img.getAttribute('data-fallback');
      if (fallback && img.getAttribute('src') !== fallback) img.setAttribute('src', fallback);
    }, { once: true });
  });
</script>

<style>
  .page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 22px 18px 88px;
  }

  .crumb,
  .kicker,
  .button,
  .stats span,
  .token__id,
  .agent-strip li {
    font-family: var(--pc-font-mono);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .crumb {
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
    font-size: 10px;
    color: var(--pc-ink-muted);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 320px);
    gap: 28px;
    align-items: end;
    border-top: 1.5px solid var(--pc-ink);
    border-bottom: 1px solid var(--pc-rule-soft);
    padding: 28px 0 30px;
  }

  .kicker {
    margin: 0 0 10px;
    font-size: 10px;
    color: #8a2432;
  }

  h1,
  h2 {
    margin: 0;
    font-weight: 500;
    letter-spacing: 0;
  }

  h1 {
    max-width: 820px;
    font-size: clamp(52px, 9vw, 118px);
    line-height: 0.9;
  }

  h2 {
    font-size: clamp(30px, 5vw, 54px);
    line-height: 0.96;
  }

  .dek {
    max-width: 720px;
    margin: 18px 0 0;
    font-size: 18px;
    line-height: 1.5;
    color: var(--pc-ink-soft);
  }

  .hero-card {
    margin: 0;
    border: 1px solid var(--pc-rule);
    background: #fff;
    padding: 10px;
  }

  .hero-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    background: #f5f5f2;
  }

  figcaption {
    margin-top: 8px;
    color: var(--pc-ink-muted);
    font-size: 13px;
    overflow-wrap: anywhere;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    border-bottom: 1px solid var(--pc-rule-soft);
  }

  .stats article {
    min-height: 88px;
    padding: 14px 12px;
    border-right: 1px solid var(--pc-rule-soft);
  }

  .stats article:first-child {
    border-left: 1px solid var(--pc-rule-soft);
  }

  .stats span {
    display: block;
    margin-bottom: 10px;
    color: var(--pc-ink-muted);
    font-size: 10px;
  }

  .stats strong {
    display: block;
    font-size: clamp(20px, 2.4vw, 32px);
    line-height: 1;
    overflow-wrap: anywhere;
  }

  .contract strong {
    font-family: var(--pc-font-mono);
    font-size: 16px;
  }

  .grid-head {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: end;
    margin: 44px 0 18px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 10px 12px;
    border: 1px solid var(--pc-ink);
    color: var(--pc-ink);
    font-size: 11px;
    white-space: nowrap;
  }

  .button:hover {
    background: var(--pc-ink);
    color: #fff;
    text-decoration: none;
  }

  .token-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 10px;
  }

  .token {
    display: block;
    border: 1px solid var(--pc-rule-soft);
    background: #fff;
    color: var(--pc-ink);
    padding: 8px;
    min-width: 0;
  }

  .token:hover {
    border-color: var(--pc-ink);
    text-decoration: none;
  }

  .token img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    background: #f5f5f2;
  }

  .token__name,
  .token__id {
    display: block;
    min-width: 0;
  }

  .token__name {
    margin-top: 8px;
    font-size: 14px;
    line-height: 1.15;
    overflow-wrap: anywhere;
  }

  .token__id {
    margin-top: 5px;
    color: var(--pc-ink-muted);
    font-size: 9px;
  }

  .story {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 34px;
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--pc-rule);
  }

  .story p {
    margin: 14px 0 0;
    color: var(--pc-ink-soft);
    font-size: 17px;
    line-height: 1.55;
  }

  .trait-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    margin-top: 18px;
  }

  .trait {
    border: 1px solid var(--pc-rule-soft);
    padding: 12px;
    background: #fff;
  }

  .trait span {
    display: block;
    color: var(--pc-ink-muted);
    font-size: 13px;
  }

  .trait strong {
    display: block;
    margin-top: 8px;
    font-size: 23px;
    line-height: 1.1;
  }

  .agent-strip {
    margin-top: 44px;
    padding: 16px;
    border: 1px solid var(--pc-rule-soft);
    background: #f8f8f6;
  }

  .agent-strip ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .agent-strip li {
    font-size: 10px;
  }

  @media (max-width: 920px) {
    .hero,
    .story {
      grid-template-columns: 1fr;
    }

    .hero-card {
      max-width: 320px;
    }

    .stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .token-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .hero {
      gap: 20px;
    }

    .dek {
      font-size: 16px;
    }

    .grid-head {
      display: block;
    }

    .button {
      margin-top: 16px;
      width: 100%;
      justify-content: center;
      white-space: normal;
      text-align: center;
    }

    .stats,
    .token-grid,
    .trait-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .stats article:nth-child(odd) {
      border-left: 1px solid var(--pc-rule-soft);
    }

    .token__name {
      font-size: 13px;
    }
  }
</style>
