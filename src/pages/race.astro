---
/**
 * /race — races hub.
 *
 * Scaffold per RFC 0002. Phase 1: route claimed, JSON-LD in place. Lists
 * races pulled from src/data/races/*.json at build time (zero today —
 * comes alive when the first race is scheduled).
 *
 * The full KV-backed runtime + live leaderboard lands in Phase 2 once
 * Mike signs off on RFC 0002.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

// Phase 1: pull any archived race snapshots from data/. Zero today.
const races: Array<{ slug: string; title: string; status: string; channel: string }> = [];

const title = 'Race — PointCast competitive events';
const description = 'The Race System is how PointCast turns "broadcast" into a verb. Finite, time-boxed, place-anchored events with leaderboards. First race: Front Door.';
const canonical = 'https://pointcast.xyz/race';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': canonical,
  name: title,
  description,
  url: canonical,
  inLanguage: 'en-US',
  about: ['race', 'competition', 'leaderboard', 'broadcast', 'pointcast', 'gamgee'],
};
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="race">
    <nav class="race__crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>race</span>
    </nav>

    <header class="race__hero">
      <p class="race__kicker mono">RACE SYSTEM · PHASE 1 SCAFFOLD · 2026-04-23</p>
      <h1 class="race__title">PointCast is a competitive broadcast system.</h1>
      <p class="race__dek">
        A race is a finite, time-boxed event with entrants, a leaderboard,
        and an end condition. Events over feeds. Finite over infinite.
        Participation over consumption. This page is where the races run.
      </p>
    </header>

    <section class="race__state">
      <div class="race__card">
        <p class="race__card-label mono">CURRENT STATE · {races.length} RACES SCHEDULED</p>
        {races.length === 0 && (
          <>
            <p class="race__empty">
              No races on the board yet. The first race —
              <strong> Front Door</strong> — launches alongside Gamgee 1.0
              per <a href="https://github.com/mhoydich/pointcast/blob/main/docs/rfc/0002-race-system.md">RFC 0002</a>.
            </p>
            <p class="race__empty">
              Until then, read the RFC to see what's coming, or visit
              <a href="/race/front-door"><code class="mono">/race/front-door</code></a>
              for the scaffold of the launch race.
            </p>
          </>
        )}
      </div>
    </section>

    <section class="race__spec">
      <h2 class="race__h2">What a race is</h2>
      <ul class="race__bullets">
        <li><strong>Finite:</strong> opens at <code class="mono">opensAt</code>, closes at <code class="mono">closesAt</code>, resolves at <code class="mono">resolvesAt</code>. No evergreen leaderboards.</li>
        <li><strong>Scored:</strong> one of five modes — <code class="mono">fastest</code>, <code class="mono">most</code>, <code class="mono">best</code>, <code class="mono">streak</code>, <code class="mono">prediction</code>.</li>
        <li><strong>Place-anchored:</strong> bound to a channel (and, later, a node). El Segundo is the default node.</li>
        <li><strong>Permanent:</strong> resolved leaderboards get archived to <code class="mono">src/data/races/{'{slug}'}.json</code> as a durable record.</li>
        <li><strong>Anti-gaming:</strong> rate-limited per entrant, one entry per race per entrant, server-side score validation.</li>
      </ul>
    </section>

    <section class="race__roadmap">
      <h2 class="race__h2">The first three races</h2>
      <table class="race__table">
        <thead>
          <tr>
            <th>Race</th>
            <th>Channel</th>
            <th>Mode</th>
            <th>Shape</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><a href="/race/front-door"><strong>Front Door</strong></a></td>
            <td>FD</td>
            <td>fastest</td>
            <td>Home → first block click. Launch race.</td>
          </tr>
          <tr>
            <td>Channel Sweep</td>
            <td>multi</td>
            <td>most</td>
            <td>Most unique channels visited in a day.</td>
          </tr>
          <tr>
            <td>Block Streak</td>
            <td>ESC</td>
            <td>streak</td>
            <td>Longest consecutive days opening an El Segundo block.</td>
          </tr>
        </tbody>
      </table>
    </section>

    <section class="race__why">
      <h2 class="race__h2">Why races</h2>
      <blockquote class="race__quote">
        <p>PointCast is not a social network.</p>
        <p>It is a competitive broadcast system where information, identity, and place converge into structured events.</p>
      </blockquote>
      <p class="race__p">
        Without races, that's abstract. With them, it's a verb: <em>enter</em>, <em>compete</em>, <em>tune in</em>, <em>finish</em>, <em>leave</em>. Not trapped. Completed. (Vision doc §13.)
      </p>
    </section>

    <section class="race__related">
      <h2 class="race__h2">Related</h2>
      <ul class="race__links">
        <li><a href="https://github.com/mhoydich/pointcast/blob/main/docs/rfc/0002-race-system.md">RFC 0002 — full spec</a></li>
        <li><a href="/gamgee"><code class="mono">/gamgee</code></a> — the release this is part of</li>
        <li><a href="/talk"><code class="mono">/talk</code></a> — Voice Dispatch capture (scaffold)</li>
        <li><a href="/listen"><code class="mono">/listen</code></a> — Voice Dispatch playback (scaffold)</li>
        <li><a href="/for-agents"><code class="mono">/for-agents</code></a> — how agents read this</li>
      </ul>
    </section>

    <footer class="race__foot mono">
      <span>PHASE 1 · SCAFFOLD · 2026-04-23 · EL SEGUNDO</span>
    </footer>
  </main>
</BlockLayout>

<style>
  .race {
    max-width: 760px;
    margin: 0 auto;
    padding: 24px 20px 72px;
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    color: #121116;
  }
  .mono { font-family: 'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, monospace; }

  .race__crumb {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #5f5e5a;
    margin-bottom: 22px;
  }
  .race__crumb a { color: inherit; text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 1px; }
  .race__crumb span { margin: 0 6px; }

  .race__hero { padding-bottom: 24px; border-bottom: 2px solid #1a1a22; margin-bottom: 28px; }
  .race__kicker {
    font-size: 10.5px;
    letter-spacing: 0.24em;
    font-weight: 700;
    color: #2f8f5f;
    margin: 0 0 10px;
  }
  .race__title {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: clamp(28px, 4.5vw, 40px);
    line-height: 1.12;
    letter-spacing: -0.01em;
    margin: 0 0 14px;
    font-weight: 400;
  }
  .race__dek {
    font-family: Georgia, serif;
    font-size: 16px;
    line-height: 1.55;
    margin: 0;
    max-width: 60ch;
    color: #38373a;
  }

  .race__state { margin: 0 0 28px; }
  .race__card {
    padding: 22px 20px 20px;
    background: #fafaf7;
    border: 1px solid #e5e3de;
    border-top: 4px solid #2f8f5f;
    border-radius: 3px;
  }
  .race__card-label {
    font-size: 10.5px;
    letter-spacing: 0.22em;
    font-weight: 700;
    color: #2f8f5f;
    margin: 0 0 10px;
  }
  .race__empty {
    font-family: Georgia, serif;
    font-size: 14px;
    line-height: 1.55;
    margin: 0 0 8px;
    color: #38373a;
  }
  .race__empty:last-child { margin-bottom: 0; }
  .race__empty a { color: #8a2432; }
  .race__empty code { font-size: 12.5px; background: rgba(18,17,22,0.07); padding: 1px 5px; border-radius: 2px; }

  .race__h2 {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: 22px;
    font-weight: 400;
    margin: 0 0 14px;
  }
  .race__bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .race__bullets li {
    font-family: Georgia, serif;
    font-size: 14px;
    line-height: 1.5;
    padding-left: 14px;
    position: relative;
    color: #1a1a22;
  }
  .race__bullets li::before {
    content: "·";
    position: absolute;
    left: 4px;
    color: #2f8f5f;
    font-weight: 700;
  }
  .race__bullets code { font-size: 12.5px; background: rgba(18,17,22,0.07); padding: 1px 5px; border-radius: 2px; }

  .race__spec, .race__roadmap, .race__why, .race__related { margin: 0 0 32px; padding-bottom: 24px; border-bottom: 1px solid #e5e3de; }

  .race__table {
    width: 100%;
    border-collapse: collapse;
    font-family: Georgia, serif;
    font-size: 13.5px;
  }
  .race__table th,
  .race__table td {
    padding: 8px 12px 8px 0;
    text-align: left;
    border-bottom: 1px solid #e5e3de;
    vertical-align: top;
  }
  .race__table th {
    font-family: var(--pc-font-mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #5f5e5a;
    font-weight: 700;
  }
  .race__table td a { color: #8a2432; }

  .race__quote {
    margin: 0 0 14px;
    padding: 14px 18px;
    background: #f3f9f4;
    border-left: 3px solid #2f8f5f;
    border-radius: 2px;
  }
  .race__quote p {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: 18px;
    line-height: 1.4;
    margin: 0 0 6px;
    color: #1a1a22;
  }
  .race__quote p:last-child { margin-bottom: 0; }
  .race__p { font-family: Georgia, serif; font-size: 14px; line-height: 1.55; color: #38373a; margin: 0; }

  .race__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
    font-family: Georgia, serif;
    font-size: 14px;
  }
  .race__links a { color: #8a2432; text-decoration: none; border-bottom: 1px solid transparent; }
  .race__links a:hover { border-bottom-color: #8a2432; }
  .race__links code { font-size: 12.5px; background: rgba(18,17,22,0.06); padding: 1px 5px; border-radius: 2px; }

  .race__foot {
    font-size: 10.5px;
    letter-spacing: 0.2em;
    color: #5f5e5a;
  }
</style>
