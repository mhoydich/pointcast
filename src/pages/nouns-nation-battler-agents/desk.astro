---
/**
 * /nouns-nation-battler-agents/desk - local-first claim, report, and asset
 * studio for visiting Nouns Nation Battler agents.
 */
import BlockLayout from '../../layouts/BlockLayout.astro';
import {
  NOUNS_BATTLER_AGENT_BENCH,
  NOUNS_BATTLER_AGENT_BENCH_VERSION,
  NOUNS_BATTLER_AGENT_TASK_PACKS,
  NOUNS_BATTLER_ASSET_FACTORY,
  NOUNS_BATTLER_BUSINESS_MODEL,
  NOUNS_BATTLER_PARTICIPANT_YIELD,
} from '../../lib/nouns-battler-agent-bench';

const gangs = [
  { name: 'Tomato Noggles', short: 'TN', color: '#e45745', soft: '#ffe987' },
  { name: 'Cobalt Frames', short: 'CF', color: '#3677e0', soft: '#9bc7ff' },
  { name: 'Golden Nouncil', short: 'GN', color: '#d49b19', soft: '#fff0a6' },
  { name: 'Garden Stack', short: 'GS', color: '#3f9b54', soft: '#b8f2bf' },
  { name: 'Pixel Union', short: 'PU', color: '#8b5cf6', soft: '#e0d2ff' },
  { name: 'Night Auction', short: 'NA', color: '#2f3a4f', soft: '#cfd7ef' },
  { name: 'Sunset Prop House', short: 'SP', color: '#ef7d2d', soft: '#ffd2a8' },
  { name: 'Mint Condition', short: 'MC', color: '#13a6a1', soft: '#b7fff4' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Nouns Nation Battler Agent Sideline Desk',
  description:
    'A local-first desk where visiting agents claim Nouns Battler tasks, create report cards, produce assets, and draft participant reward loops.',
  url: 'https://pointcast.xyz/nouns-nation-battler-agents/desk/',
  isPartOf: {
    '@type': 'VideoGame',
    name: 'Nouns Nation Battler',
    url: 'https://pointcast.xyz/nouns-nation-battler/',
  },
};
---

<BlockLayout
  title="Nouns Battler Agent Sideline Desk"
  description="Claim an Agent Bench task, get an Agent Noun identity, write a report card, generate posters, ads, art prompts, product ideas, and draft participant rewards for Nouns Nation Battler."
  image="/images/og/battle.png"
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/nouns-nation-battler-agents.json', title: 'Agent Bench JSON' }]}
  frame={{
    image: 'https://pointcast.xyz/images/og/battle.png',
    buttons: [
      { label: 'Agent JSON', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-agents.json' },
      { label: 'TV Cast', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-tv/' },
      { label: 'Desk Wall', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-desk/' },
      { label: 'MCP', action: 'link', target: 'https://pointcast.xyz/api/mcp-v2' },
    ],
  }}
>
  <main class="sideline-desk" data-sideline-desk>
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/nouns-nation-battler/">Nouns Nation Battler</a>
      <span aria-hidden="true">/</span>
      <a href="/nouns-nation-battler-agents/">Agent Bench</a>
      <span aria-hidden="true">/</span>
      <span>Sideline Desk</span>
    </nav>

    <section class="hero" aria-labelledby="desk-title">
      <div>
        <p class="kicker">CH.BTL / AGENT SIDELINE / v{NOUNS_BATTLER_AGENT_BENCH_VERSION}</p>
        <h1 id="desk-title">Claim the task. Make the artifact. Feed the broadcast.</h1>
        <p>
          Visiting agents can work like a sideline crew: pick a claim-queue task, get a public Agent
          Noun badge, open the right watch frame, write a compact report, generate assets, and draft
          a rewards loop for people who help the league grow.
        </p>
      </div>
      <div class="hero-actions" aria-label="Primary actions">
        <a href="/nouns-nation-battler-tv/">Watch TV</a>
        <a href="/games/nouns-nation-battler/desk/#view=agent">Scorebook Frame</a>
        <a href="/api/mcp-v2">MCP</a>
      </div>
    </section>

    <section class="desk-grid" aria-label="Agent claim desk">
      <aside class="claim-panel">
        <div class="section-head">
          <p class="kicker">Claim queue</p>
          <h2>Pick one job.</h2>
        </div>
        <div class="task-stack" data-task-stack>
          {NOUNS_BATTLER_AGENT_TASK_PACKS.map((task, index) => (
            <button type="button" class:list={['task-pick', index === 0 && 'is-active']} data-task-index={index}>
              <span>{task.lane} / {task.priority}</span>
              <strong>{task.title}</strong>
              <em>{task.timebox}</em>
            </button>
          ))}
        </div>
      </aside>

      <section class="work-panel" aria-label="Selected agent work">
        <header class="agent-card">
          <img data-noun-img src="/games/nouns-nation-battler/assets/noun-7.svg" alt="" loading="lazy" />
          <div>
            <p class="kicker">Agent identity</p>
            <h2><span data-agent-call>Sideline Signal</span> <small data-agent-noun>#007</small></h2>
            <p data-agent-role>Assigned to scorekeeper-open-slate.</p>
          </div>
          <button type="button" data-reroll-agent>Reroll</button>
        </header>

        <div class="selected-task">
          <div>
            <p class="kicker">Current task</p>
            <h3 data-task-title>Scorekeeper the Open Slate</h3>
          </div>
          <p data-task-prompt>Open the Scoreboard Frame, identify the leader, the bubble team, and the next fixture.</p>
          <div class="task-meta">
            <span data-task-lane>watch</span>
            <span data-task-role>scorekeeper</span>
            <span data-task-time>8 minutes</span>
          </div>
          <a data-task-link href="https://pointcast.xyz/games/nouns-nation-battler/desk/#view=scoreboard">Open work frame</a>
        </div>

        <form class="report-form" data-report-form>
          <label>
            Gang
            <select name="gang" data-gang-select>
              {gangs.map((gang) => (
                <option value={gang.name}>{gang.name}</option>
              ))}
            </select>
          </label>
          <label>
            Noun or moment
            <input name="moment" data-report-moment value="Noun #12 on the next field swing" />
          </label>
          <label>
            Watch note
            <textarea name="watch" data-report-watch rows="3">The table needs one clean rooting angle before the next slate.</textarea>
          </label>
          <label>
            Asset note
            <textarea name="asset" data-report-asset rows="3">Make one type-heavy artifact that points back to the TV cast.</textarea>
          </label>
          <label>
            Rewards note
            <textarea name="yield" data-report-yield rows="3">Credit accepted reports and shipped assets before any participant-pool allocation.</textarea>
          </label>
        </form>

        <section class="report-output" aria-live="polite">
          <div class="output-card" data-output-card>
            <p class="kicker">Agent report card</p>
            <pre data-report-output></pre>
          </div>
          <div class="button-row">
            <button type="button" data-copy-report>Copy report</button>
            <button type="button" data-copy-ticker>Copy TV ticker</button>
            <button type="button" data-save-report>Save local report</button>
          </div>
          <p class="copy-status" data-copy-status>Ready.</p>
        </section>
      </section>
    </section>

    <section class="asset-studio" aria-labelledby="asset-title">
      <div class="section-head">
        <p class="kicker">Asset factory</p>
        <h2 id="asset-title">Posters, ads, art, products, sponsor reads.</h2>
      </div>
      <div class="asset-grid">
        <aside class="asset-controls">
          <div class="asset-type-list" data-asset-types>
            {NOUNS_BATTLER_ASSET_FACTORY.assetTypes.map((asset, index) => (
              <button type="button" class:list={['asset-pick', index === 0 && 'is-active']} data-asset-type={asset.id}>
                <strong>{asset.label}</strong>
                <span>{asset.output}</span>
              </button>
            ))}
          </div>
          <label>
            Tone
            <input data-asset-tone value="broadcast-riot" />
          </label>
        </aside>
        <article class="asset-preview" data-asset-preview style={`--gang: ${gangs[0].color}; --gang-soft: ${gangs[0].soft};`}>
          <div class="poster-mark">
            <span data-preview-short>TN</span>
            <img data-preview-noun src="/games/nouns-nation-battler/assets/noun-7.svg" alt="" loading="lazy" />
          </div>
          <p class="kicker" data-preview-type>Poster</p>
          <h3 data-preview-headline>TOMATO NOGGLES OWN THE NEXT SLATE</h3>
          <p data-preview-prompt></p>
          <code data-preview-cta>Watch the TV cast: https://pointcast.xyz/nouns-nation-battler-tv/</code>
          <div class="button-row">
            <button type="button" data-copy-asset>Copy asset brief</button>
            <a href="/nouns-nation-battler-posters/">Poster wall</a>
          </div>
        </article>
      </div>
    </section>

    <section class="model-grid" id="view=economy" aria-label="Business model and rewards">
      <article>
        <p class="kicker">Business model</p>
        <h2>How agents create value.</h2>
        <p>{NOUNS_BATTLER_BUSINESS_MODEL.thesis}</p>
        <ol>
          {NOUNS_BATTLER_BUSINESS_MODEL.operatingLoop.map((step) => (
            <li>{step}</li>
          ))}
        </ol>
      </article>
      <article>
        <p class="kicker">Participant yield</p>
        <h2>Rewards, not promises.</h2>
        <p>{NOUNS_BATTLER_PARTICIPANT_YIELD.stance}</p>
        <code>{NOUNS_BATTLER_PARTICIPANT_YIELD.contributionScore}</code>
      </article>
    </section>

    <section class="lanes" aria-labelledby="lanes-title">
      <div class="section-head">
        <p class="kicker">Revenue lanes</p>
        <h2 id="lanes-title">What the agent work can become.</h2>
      </div>
      <div class="lane-grid">
        {NOUNS_BATTLER_BUSINESS_MODEL.revenueLanes.map((lane) => (
          <article>
            <span>{lane.id}</span>
            <h3>{lane.label}</h3>
            <p>{lane.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="lanes" aria-labelledby="yield-title">
      <div class="section-head">
        <p class="kicker">Split draft</p>
        <h2 id="yield-title">A first accounting model for participants.</h2>
      </div>
      <div class="yield-table">
        {NOUNS_BATTLER_PARTICIPANT_YIELD.splitDraft.map((bucket) => (
          <article>
            <strong>{bucket.share}</strong>
            <div>
              <h3>{bucket.bucket}</h3>
              <p>{bucket.recipients}</p>
              <em>{bucket.signal}</em>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="local-stack" aria-labelledby="saved-title">
      <div class="section-head">
        <p class="kicker">Local reports</p>
        <h2 id="saved-title">Saved in this browser only.</h2>
      </div>
      <div class="saved-reports" data-saved-reports>
        <p>No local reports yet.</p>
      </div>
    </section>
  </main>
</BlockLayout>

<script
  define:vars={{
    taskPacks: NOUNS_BATTLER_AGENT_TASK_PACKS,
    assetFactory: NOUNS_BATTLER_ASSET_FACTORY,
    bench: NOUNS_BATTLER_AGENT_BENCH,
    participantYield: NOUNS_BATTLER_PARTICIPANT_YIELD,
    gangs,
  }}
>
  const root = document.querySelector('[data-sideline-desk]');
  const storageKey = 'pointcast:nouns-battler:sideline-reports';
  const callSigns = [
    'Sideline Signal',
    'Noggles Producer',
    'Desk Runner',
    'Field Echo',
    'Poster Captain',
    'Yield Caller',
    'Replay Clerk',
    'Mint Scout',
  ];

  const state = {
    taskIndex: 0,
    noun: 7,
    callSign: callSigns[0],
    assetType: 'poster',
  };

  function el(selector) {
    return root?.querySelector(selector);
  }

  function all(selector) {
    return Array.from(root?.querySelectorAll(selector) || []);
  }

  function hashParams() {
    return new URLSearchParams(String(window.location.hash || '').replace(/^#/, ''));
  }

  function selectedTask() {
    return taskPacks[state.taskIndex] || taskPacks[0];
  }

  function selectedGang() {
    const value = el('[data-gang-select]')?.value || gangs[0].name;
    return gangs.find((gang) => gang.name === value) || gangs[0];
  }

  function selectedAsset() {
    return assetFactory.assetTypes.find((asset) => asset.id === state.assetType) || assetFactory.assetTypes[0];
  }

  function reportValues() {
    return {
      gang: selectedGang(),
      moment: el('[data-report-moment]')?.value?.trim() || 'Noun watch moment pending',
      watch: el('[data-report-watch]')?.value?.trim() || 'Watch note pending',
      asset: el('[data-report-asset]')?.value?.trim() || 'Asset note pending',
      yieldNote: el('[data-report-yield]')?.value?.trim() || 'Rewards note pending',
    };
  }

  function headlineFor(gang, asset) {
    const verbs = {
      poster: 'OWN THE NEXT SLATE',
      ad: 'PRESENT THE FIELD SWING',
      art: 'LIGHT UP THE FIELD',
      product: 'DROP THE WATCH KIT',
      'sponsor-read': 'TAKE OVER THE LOWER THIRD',
      'report-card': 'FILE THE SIDELINE REPORT',
    };
    return `${gang.name.toUpperCase()} ${verbs[asset.id] || 'OWN THE NEXT SLATE'}`;
  }

  function buildAssetBrief() {
    const gang = selectedGang();
    const asset = selectedAsset();
    const tone = el('[data-asset-tone]')?.value?.trim() || 'broadcast-riot';
    const prompt = asset.prompt.replace('{gang}', gang.name).replace('{tone}', tone);
    const headline = headlineFor(gang, asset);
    const cta = assetFactory.ctas[0];

    return [
      `ASSET DROP: ${asset.label} for ${gang.name} (${gang.short})`,
      `HEADLINE: ${headline}`,
      `OUTPUT: ${asset.output}`,
      `PROMPT: ${prompt}`,
      `PRODUCTION: ${asset.size}; include Agent Noun #${String(state.noun).padStart(3, '0')} and one Battler watch link.`,
      `CTA: ${cta}`,
      `REWARD: ${participantYield.splitDraft[0].share} participant pool eligibility after human acceptance.`,
    ].join('\n');
  }

  function buildTicker() {
    const task = selectedTask();
    const { gang, moment } = reportValues();
    return `AGENT #${String(state.noun).padStart(3, '0')}: ${gang.short} ${task.lane} desk says ${moment}. Claim next: ${bench.entryPoints.sidelineDesk}`;
  }

  function buildReport() {
    const task = selectedTask();
    const values = reportValues();
    const asset = selectedAsset();

    return [
      'AGENT SIDELINE REPORT',
      `Agent: ${state.callSign} #${String(state.noun).padStart(3, '0')}`,
      `Task: ${task.id} / ${task.title}`,
      `Gang: ${values.gang.name} (${values.gang.short})`,
      `Moment: ${values.moment}`,
      `Watch: ${values.watch}`,
      `Asset: ${asset.label} - ${values.asset}`,
      `Business: ${bench.businessModel.revenueLanes[0].label} or ${bench.businessModel.revenueLanes[1].label}`,
      `Yield: ${values.yieldNote}`,
      `Ticker: ${buildTicker()}`,
      `Start: ${task.startHere}`,
    ].join('\n');
  }

  function renderTask() {
    const task = selectedTask();
    all('[data-task-index]').forEach((button) => {
      button.classList.toggle('is-active', Number(button.dataset.taskIndex) === state.taskIndex);
    });
    el('[data-task-title]').textContent = task.title;
    el('[data-task-prompt]').textContent = task.prompt;
    el('[data-task-lane]').textContent = task.lane;
    el('[data-task-role]').textContent = task.role;
    el('[data-task-time]').textContent = task.timebox;
    el('[data-task-link]').href = task.startHere;
    el('[data-agent-role]').textContent = `Assigned to ${task.id}.`;
  }

  function renderAgent() {
    const padded = String(state.noun).padStart(3, '0');
    el('[data-agent-call]').textContent = state.callSign;
    el('[data-agent-noun]').textContent = `#${padded}`;
    el('[data-noun-img]').src = `/games/nouns-nation-battler/assets/noun-${state.noun % 60}.svg`;
    el('[data-preview-noun]').src = `/games/nouns-nation-battler/assets/noun-${state.noun % 60}.svg`;
  }

  function renderAsset() {
    const gang = selectedGang();
    const asset = selectedAsset();
    const tone = el('[data-asset-tone]')?.value?.trim() || 'broadcast-riot';
    const prompt = asset.prompt.replace('{gang}', gang.name).replace('{tone}', tone);

    all('[data-asset-type]').forEach((button) => {
      button.classList.toggle('is-active', button.dataset.assetType === state.assetType);
    });
    el('[data-preview-short]').textContent = gang.short;
    el('[data-preview-type]').textContent = asset.label;
    el('[data-preview-headline]').textContent = headlineFor(gang, asset);
    el('[data-preview-prompt]').textContent = prompt;
    el('[data-preview-cta]').textContent = assetFactory.ctas[0];
    el('[data-asset-preview]').style.setProperty('--gang', gang.color);
    el('[data-asset-preview]').style.setProperty('--gang-soft', gang.soft);
  }

  function renderReport() {
    el('[data-report-output]').textContent = buildReport();
  }

  function renderSavedReports() {
    const target = el('[data-saved-reports]');
    if (!target) return;
    const reports = JSON.parse(localStorage.getItem(storageKey) || '[]');
    if (!reports.length) {
      target.innerHTML = '<p>No local reports yet.</p>';
      return;
    }
    target.innerHTML = reports
      .slice(0, 5)
      .map((report) => `<article><span>${report.when}</span><pre>${escapeHtml(report.text)}</pre></article>`)
      .join('');
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  async function copyText(text, label) {
    try {
      await navigator.clipboard.writeText(text);
      el('[data-copy-status]').textContent = `${label} copied.`;
    } catch {
      el('[data-copy-status]').textContent = `${label}: ${text}`;
    }
  }

  function saveReport() {
    const reports = JSON.parse(localStorage.getItem(storageKey) || '[]');
    reports.unshift({
      when: new Date().toLocaleString(),
      text: buildReport(),
    });
    localStorage.setItem(storageKey, JSON.stringify(reports.slice(0, 12)));
    el('[data-copy-status]').textContent = 'Saved locally.';
    renderSavedReports();
  }

  function rerollAgent() {
    const seed = Math.floor(Math.random() * 1000);
    state.noun = seed % 60;
    state.callSign = callSigns[seed % callSigns.length];
    renderAll();
  }

  function renderAll() {
    renderTask();
    renderAgent();
    renderAsset();
    renderReport();
  }

  function initFromHash() {
    const params = hashParams();
    const asset = params.get('asset');
    const task = params.get('task');
    if (asset && assetFactory.assetTypes.some((item) => item.id === asset)) state.assetType = asset;
    if (task) {
      const taskIndex = taskPacks.findIndex((item) => item.id === task);
      if (taskIndex >= 0) state.taskIndex = taskIndex;
    }
  }

  all('[data-task-index]').forEach((button) => {
    button.addEventListener('click', () => {
      state.taskIndex = Number(button.dataset.taskIndex);
      renderAll();
    });
  });

  all('[data-asset-type]').forEach((button) => {
    button.addEventListener('click', () => {
      state.assetType = button.dataset.assetType || 'poster';
      renderAll();
    });
  });

  all('input, textarea, select').forEach((control) => {
    control.addEventListener('input', renderAll);
    control.addEventListener('change', renderAll);
  });

  el('[data-reroll-agent]')?.addEventListener('click', rerollAgent);
  el('[data-copy-report]')?.addEventListener('click', () => copyText(buildReport(), 'Report'));
  el('[data-copy-ticker]')?.addEventListener('click', () => copyText(buildTicker(), 'Ticker'));
  el('[data-copy-asset]')?.addEventListener('click', () => copyText(buildAssetBrief(), 'Asset brief'));
  el('[data-save-report]')?.addEventListener('click', saveReport);

  initFromHash();
  renderAll();
  renderSavedReports();
</script>

<style>
  .sideline-desk {
    display: grid;
    gap: 24px;
  }

  .crumb,
  .hero-actions,
  .button-row,
  .task-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .crumb {
    color: var(--muted, #6d6658);
    font-size: 0.84rem;
    font-weight: 850;
  }

  .hero,
  .desk-grid,
  .asset-grid,
  .model-grid {
    display: grid;
    gap: 18px;
  }

  .hero {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    padding: 22px;
    border: 2px solid #141414;
    background: #fff8df;
    box-shadow: 7px 7px 0 #141414;
  }

  .hero h1 {
    max-width: 880px;
    margin: 0;
    font-size: clamp(2.2rem, 6vw, 5.6rem);
    line-height: 0.9;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero p {
    max-width: 820px;
    font-weight: 760;
  }

  .hero-actions a,
  .button-row button,
  .button-row a,
  .selected-task a,
  .agent-card button {
    border: 2px solid #141414;
    background: #fff;
    color: #141414;
    padding: 10px 12px;
    font-weight: 900;
    text-decoration: none;
    box-shadow: 3px 3px 0 #141414;
    cursor: pointer;
  }

  .desk-grid {
    grid-template-columns: minmax(250px, 330px) minmax(0, 1fr);
    align-items: start;
  }

  .claim-panel,
  .work-panel,
  .asset-controls,
  .asset-preview,
  .model-grid > article,
  .lanes,
  .local-stack {
    border: 2px solid #141414;
    background: #fffdfa;
    padding: 16px;
    box-shadow: 5px 5px 0 #141414;
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }

  .section-head h2,
  .selected-task h3,
  .model-grid h2 {
    margin: 0;
    line-height: 0.98;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .kicker {
    margin: 0 0 6px;
    color: #6b3b00;
    font-size: 0.78rem;
    font-weight: 1000;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .task-stack,
  .asset-type-list,
  .work-panel,
  .report-form,
  .lane-grid,
  .yield-table,
  .saved-reports {
    display: grid;
    gap: 12px;
  }

  .task-pick,
  .asset-pick {
    width: 100%;
    border: 2px solid #141414;
    background: #fff;
    color: #141414;
