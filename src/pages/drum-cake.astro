/* candles */
.dc-candle .dc-flame__shape { opacity: 0.18; transform-origin: center; transform-box: fill-box; }
.dc-candle .dc-flame__glow { opacity: 0; }
.dc-candle .dc-flame.lit .dc-flame__shape { opacity: 1; animation: dc-flicker 0.45s ease-in-out infinite alternate; }
.dc-candle .dc-flame.lit .dc-flame__glow { opacity: 1; animation: dc-glow 1.2s ease-in-out infinite alternate; }
