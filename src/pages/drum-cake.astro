.dc-candle .dc-smoke.puff circle { animation: dc-puff 1.6s ease-out forwards; }
.dc-candle .dc-smoke.puff circle:nth-child(2) { animation-delay: 0.12s; }
.dc-candle .dc-smoke.puff circle:nth-child(3) { animation-delay: 0.24s; }

@keyframes dc-flicker {
  0%   { transform: scaleY(1) scaleX(1)   translateY(0); }
  50%  { transform: scaleY(1.08) scaleX(0.95) translateY(-1px); }
  100% { transform: scaleY(0.95) scaleX(1.05) translateY(1px); }
