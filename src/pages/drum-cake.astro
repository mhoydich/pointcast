  0%   { opacity: 0; transform: translateY(0) scale(0.6); }
  20%  { opacity: 0.6; transform: translateY(-2px) scale(0.9); }
  60%  { opacity: 0.4; transform: translateY(-14px) scale(1.2); }
  100% { opacity: 0; transform: translateY(-30px) scale(1.5); }
}

/* action button */
