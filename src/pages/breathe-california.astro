---
/**
 * /breathe-california - Tezos-backed breathing room.
 *
 * A sibling to /meditate using one of Mike's objkt tokens as the anchor.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import OceanMeditation from '../components/OceanMeditation.astro';

const token = {
  name: 'Breathe California',
  contract: 'KT1Qc77qoVQadgwCqrqscWsgQ75aa3Rt1MrP',
  tokenId: '10',
  image: '/images/tokens/10.png',
  url: 'https://objkt.com/tokens/KT1Qc77qoVQadgwCqrqscWsgQ75aa3Rt1MrP/10',
  description: 'Southern California breathwork token, routed back through PointCast as a quiet two-minute room.',
};

const title = 'Breathe California';
const description = 'A PointCast breathing room anchored to Mike Hoydich\'s Breathe California token on Tezos.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': 'https://pointcast.xyz/breathe-california',
  name: 'PointCast Breathe California',
  description,
  url: 'https://pointcast.xyz/breathe-california',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Web',
  isPartOf: {
    '@type': 'WebSite',
    name: 'PointCast',
    url: 'https://pointcast.xyz',
  },
  associatedMedia: {
    '@type': 'ImageObject',
    name: token.name,
    url: `https://assets.objkt.media/file/assets-003/${token.contract}/${token.tokenId}/thumb400`,
    contentUrl: token.url,
  },
  featureList: [
    'Tezos token-backed breathing timer',
    '2, 5, and 10 minute sessions',
    'Calm Bay, Deep Current, and Moon Tide programs',
    'Full-screen focus mode',
    'Local tide log stored in the browser',
    'Optional generated ocean tone',
  ],
};
---

<BlockLayout
  title={title}
  description={description}
  image="/images/og/meditate.png"
  jsonLd={jsonLd}
  alternates={[
    { type: 'application/json', href: '/breathe-california.json', title: 'Breathe California room (JSON)' },
  ]}
  frame={{
    image: 'https://pointcast.xyz/images/og/meditate.png',
    buttons: [
      { label: 'Open Breathe California', action: 'link', target: 'https://pointcast.xyz/breathe-california' },
      { label: 'View on objkt', action: 'link', target: token.url },
    ],
  }}
>
  <div class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>breathe-california</span>
    </nav>

    <header class="hero">
      <div class="hero__copy">
        <p class="kicker">TEZOS RESET · POINTCAST</p>
        <h1>A California breath you can actually finish.</h1>
        <p class="dek">
          One objkt token becomes a small room: pick a cadence, let the coast
          set the tempo, and leave with a local tide log instead of another tab
          asking for more.
        </p>
        <div class="hero__actions">
          <a href="#session" class="hero__cta">Start session</a>
          <a href={token.url} class="hero__link" target="_blank" rel="noopener">View on objkt</a>
          <a href="/breathe-california.json" class="hero__link">JSON mirror</a>
        </div>
      </div>
      <figure class="hero__art">
        <img src={token.image} alt={`${token.name} token artwork`} loading="eager" decoding="async" />
        <figcaption class="mono">BREATHE CALIFORNIA · TEZOS TOKEN {token.tokenId}</figcaption>
      </figure>
    </header>

    <section class="signals" aria-label="Breathing modes">
      <article>
        <span class="mono">COAST LIGHT</span>
        <strong>4-2-6-2</strong>
        <p>Short reset for stepping out of the feed and back into the body.</p>
      </article>
      <article>
        <span class="mono">HIGHWAY HUM</span>
        <strong>5-2-7-2</strong>
        <p>Longer exhale for clearing motion, noise, and task residue.</p>
      </article>
      <article>
        <span class="mono">PACIFIC SQUARE</span>
        <strong>4-4-4-4</strong>
        <p>Even rhythm for closing the loop before the next block.</p>
      </article>
    </section>

    <div id="session">
      <OceanMeditation
        artifact={{
          name: token.name,
          image: token.image,
          alt: `${token.name} token artwork`,
          description: token.description,
          url: token.url,
        }}
      />
    </div>

    <section class="notes" aria-label="Field notes">
      <div>
        <p class="kicker">TOKEN NOTE</p>
        <h2>On-chain art as a place to pause.</h2>
      </div>
      <p>
        The objkt URL is the proof surface; this page is the use surface. The
        token stays collectible on Tezos, while PointCast turns it into a
        repeatable two-minute ritual.
      </p>
    </section>
  </div>
</BlockLayout>

<style>
  .page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 16px 20px 80px;
  }

  .mono,
  .kicker {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .crumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    color: var(--pc-ink-muted);
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 360px);
    gap: 18px;
    align-items: stretch;
    margin-bottom: 14px;
    padding-bottom: 18px;
    border-bottom: 1.5px solid var(--pc-ink);
  }

  .hero__copy {
    min-height: 410px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 26px 0;
  }

  .kicker {
    margin: 0 0 12px;
    color: #6e4a0f;
  }

  h1 {
    max-width: 760px;
    margin: 0;
    font-size: 58px;
    line-height: 0.98;
    letter-spacing: 0;
    font-weight: 500;
  }

  .dek {
    max-width: 700px;
    margin: 18px 0 0;
    color: var(--pc-ink-soft);
    font-size: 19px;
    line-height: 1.55;
  }

  .hero__actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 26px;
  }

  .hero__cta,
  .hero__link {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    padding: 9px 14px;
    border: 1.5px solid currentColor;
    border-radius: 2px;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero__cta {
    color: #fff;
    background: #6e4a0f;
  }

  .hero__cta:hover {
    background: #4b3208;
    text-decoration: none;
  }

  .hero__link {
    color: #6e4a0f;
    background: #fff;
  }

  .hero__art {
    margin: 0;
    min-height: 410px;
    border: 1.5px solid #6e4a0f;
    background: #f7f1df;
    display: grid;
    grid-template-rows: 1fr auto;
  }

  .hero__art img {
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    object-position: center 42%;
  }

  .hero__art figcaption {
    padding: 10px;
    border-top: 1.5px solid #6e4a0f;
    color: #4b3208;
    background: #fff;
  }

  .signals {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 14px;
  }

  .signals article {
    min-height: 136px;
    padding: 12px;
    border: 1px solid var(--pc-rule);
    background: #fff;
  }

  .signals span {
    display: block;
    color: var(--pc-ink-muted);
    margin-bottom: 10px;
  }

  .signals strong {
    display: block;
    font-family: var(--pc-font-mono);
    font-size: 22px;
    line-height: 1.1;
    font-weight: 500;
    color: #6e4a0f;
    font-variant-numeric: tabular-nums;
  }

  .signals p {
    margin: 10px 0 0;
    color: var(--pc-ink-soft);
    font-size: 14px;
    line-height: 1.45;
  }

  .notes {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 18px;
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1.5px solid var(--pc-ink);
  }

  .notes h2 {
    margin: 0;
    font-size: 26px;
    font-weight: 500;
    line-height: 1.1;
  }

  .notes p {
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 17px;
    line-height: 1.6;
  }

  @media (max-width: 820px) {
    .hero,
    .notes {
      grid-template-columns: 1fr;
    }

    .hero__copy,
    .hero__art {
      min-height: auto;
    }

    h1 {
      font-size: 44px;
    }

    .signals {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .page {
      padding: 12px 12px 60px;
    }

    h1 {
      font-size: 36px;
    }

    .dek {
      font-size: 17px;
    }
  }
</style>
