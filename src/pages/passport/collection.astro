---
import BlockLayout from '../../layouts/BlockLayout.astro';
import WalletChip from '../../components/WalletChip.astro';
import {
  PASSPORT_IMAGE_GENERATOR,
  PASSPORT_STAMPS,
  PASSPORT_STORAGE_KEY,
  passportDateKey,
} from '../../lib/passport';
import {
  PASSPORT_COMPANION_COLLECTION,
  PASSPORT_STAMP_COLLECTION,
  PASSPORT_STAMP_PRD_PATH,
  passportCompanionNounId,
  passportStampMintPlan,
} from '../../lib/passport-mint';
import posterSet from '../../data/passport-posters.json';

const today = passportDateKey();
const firstCompanionId = passportCompanionNounId(PASSPORT_STAMPS[0]);
const lastCompanionId = passportCompanionNounId(PASSPORT_STAMPS[PASSPORT_STAMPS.length - 1]);
const companionRange = `#${firstCompanionId}-#${lastCompanionId}`;
const stampRows = PASSPORT_STAMPS.map((stamp) => ({
  stamp,
  mint: passportStampMintPlan(stamp),
}));
const leadPoster = posterSet.posters[0];
const title = 'Passport Collection';
const description =
  'The PointCast Station Passport collection cabinet: stamp sheet, book, poster set, metadata, and Tezos mint status.';

const clientPayload = {
  storageKey: PASSPORT_STORAGE_KEY,
  today,
  total: PASSPORT_STAMPS.length,
  stamps: PASSPORT_STAMPS.map((stamp) => ({
    slug: stamp.slug,
    code: stamp.code,
    name: stamp.name,
  })),
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://pointcast.xyz/passport/collection',
  name: 'PointCast Passport Collection Cabinet',
  description,
  url: 'https://pointcast.xyz/passport/collection',
  isPartOf: {
    '@type': 'WebApplication',
    name: 'PointCast Station Passport',
    url: 'https://pointcast.xyz/passport',
  },
};
---

<BlockLayout
  title={title}
  description={description}
  image={leadPoster.image}
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/passport/collection.json', title: 'Passport Collection JSON' }]}
  frame={{
    image: `https://pointcast.xyz${leadPoster.image}`,
    aspectRatio: '1:1',
    buttons: [
      { label: 'Collection', action: 'link', target: 'https://pointcast.xyz/passport/collection' },
      { label: 'Book', action: 'link', target: 'https://pointcast.xyz/passport/book' },
      { label: 'Passport', action: 'link', target: 'https://pointcast.xyz/passport' },
    ],
  }}
>
  <div class="page">
    <script type="application/json" id="passport-collection-data" set:html={JSON.stringify(clientPayload)} />

    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/passport">passport</a>
      <span aria-hidden="true">/</span>
      <span>collection</span>
    </nav>

    <header class="hero">
      <div>
        <div class="hero__top">
          <p class="kicker">COLLECTION CABINET · {PASSPORT_IMAGE_GENERATOR.model} · {today}</p>
          <WalletChip />
        </div>
        <h1>Stamps, posters, book, proof.</h1>
        <p class="dek">
          The whole Station Passport as a collectible shelf: claim stamps locally,
          open the booklet, inspect the poster set, and mint live Tezos companion
          proofs from the main stamp board while native stamp-art tokens wait for
          Passport Stamps FA2 origination.
        </p>
      </div>
      <section class="collection-score" aria-label="Collection progress">
        <p class="collection-score__label">cabinet fill</p>
        <strong><span data-collection-count>0</span>/{PASSPORT_STAMPS.length}</strong>
        <div class="collection-score__meter"><span data-collection-meter></span></div>
        <p>Shared with the book and stamp board through <code>{PASSPORT_STORAGE_KEY}</code>.</p>
      </section>
    </header>

    <section class="feature-grid" aria-label="Passport collection objects">
      <a class="feature-tile feature-tile--book" href="/passport/book">
        <img src={leadPoster.image} alt="Origin Stamp poster cover" width="1200" height="1800" />
        <span>Book</span>
        <strong>Open the bound passport</strong>
      </a>
      <a class="feature-tile" href="/passport/posters">
        <img src={posterSet.posters[5].image} alt="PCH Horizon passport poster" width="1200" height="1800" loading="lazy" />
        <span>Posters</span>
        <strong>View all ten launch prints</strong>
      </a>
      <a class="feature-tile" href="/passport/routes">
        <img src={posterSet.posters[1].image} alt="South Bay Run passport poster" width="1200" height="1800" loading="lazy" />
        <span>Routes</span>
        <strong>Complete route visas</strong>
      </a>
      <a class="feature-tile" href="/passport/receipts">
        <img src={posterSet.posters[3].image} alt="Ridge Port Mesh passport poster" width="1200" height="1800" loading="lazy" />
        <span>Receipts</span>
        <strong>Review mint proof cards</strong>
      </a>
      <a class="feature-tile feature-tile--mint" href="/passport#el-segundo">
        <div class="mint-object">
          <p>{PASSPORT_COMPANION_COLLECTION.name}</p>
          <strong>{companionRange}</strong>
          <span>{PASSPORT_COMPANION_COLLECTION.entrypoint} · mainnet</span>
        </div>
        <span>Mint path</span>
        <strong>Mint Tezos companion proofs</strong>
      </a>
    </section>

    <section class="mint-brief" aria-labelledby="mint-brief-title">
      <div>
        <p class="kicker">MINT STATUS · TRUTH LABEL</p>
        <h2 id="mint-brief-title">Live proof now, native stamp next.</h2>
      </div>
      <div class="mint-brief__grid">
        <article>
          <p class="mini-label">live companion</p>
          <p>
            <strong>{PASSPORT_COMPANION_COLLECTION.name}</strong> maps {PASSPORT_STAMPS[0].code}-{PASSPORT_STAMPS[PASSPORT_STAMPS.length - 1].code} to
            Visit Nouns {companionRange} through <code>{PASSPORT_COMPANION_COLLECTION.entrypoint}</code>.
            Minting requires a wallet signature from the stamp board.
          </p>
        </article>
        <article>
          <p class="mini-label">native stamp art</p>
          <p>
            <strong>{PASSPORT_STAMP_COLLECTION.name}</strong> is {PASSPORT_STAMP_COLLECTION.status}.
            Contract source and metadata are ready; the KT1 still needs compile,
            shadownet smoke mint, and mainnet origination. <a href={PASSPORT_STAMP_PRD_PATH}>PRD</a>
          </p>
        </article>
      </div>
    </section>

    <section class="stamp-cabinet" aria-labelledby="stamp-cabinet-title">
      <div class="section-head">
        <div>
          <p class="kicker">STAMP SHEET</p>
          <h2 id="stamp-cabinet-title">{PASSPORT_STAMPS.length} station objects</h2>
        </div>
        <div class="cabinet-actions">
          <button type="button" class="tool-btn" data-claim-route>Stamp today's feel</button>
          <button type="button" class="tool-btn tool-btn--quiet" data-export-collection>Export</button>
        </div>
      </div>
      <div class="stamp-grid">
        {stampRows.map(({ stamp, mint }) => (
          <article class="stamp-object" data-collection-stamp={stamp.slug} style={`--stamp-color:${stamp.color};`}>
            <a class="stamp-object__art" href={`/passport/art/${stamp.slug}.svg`}>
              <img src={`/passport/art/${stamp.slug}.svg`} alt={`${stamp.name} passport stamp`} loading="lazy" />
            </a>
            <div class="stamp-object__copy">
              <p>{stamp.code} · {stamp.band}</p>
              <h3>{stamp.name}</h3>
              <span>{stamp.direction} · {stamp.miles} mi</span>
            </div>
            <div class="stamp-object__actions">
              <button
                type="button"
                data-collection-claim={stamp.slug}
                data-stamp-name={stamp.name}
                data-stamp-code={stamp.code}
              >
                Collect
              </button>
              <a href={`/passport#${stamp.slug}`}>Mint</a>
              <a href={`/passport/stamps/${stamp.slug}.json`}>JSON</a>
              <a href={`/passport/receipts#${stamp.slug}`}>Receipt</a>
            </div>
            <p class="stamp-object__mint">
              {mint.current.mode === 'passport-stamp-native' ? 'native stamp' : 'proof noun'} #{mint.current.tokenId} · {mint.current.priceLabel}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="poster-cabinet" aria-labelledby="poster-cabinet-title">
      <div class="section-head">
        <div>
          <p class="kicker">POSTER DRAWER · {posterSet.generator.model}</p>
          <h2 id="poster-cabinet-title">Launch art for the route</h2>
        </div>
        <a class="text-link" href="/passport/posters">Open poster wall</a>
      </div>
      <div class="poster-grid">
        {posterSet.posters.map((poster) => (
          <a class="poster-object" href={poster.image}>
            <img src={poster.image} alt={`${poster.title} PointCast Passport poster`} width="1200" height="1800" loading="lazy" />
            <span>{poster.number} · {poster.title}</span>
          </a>
        ))}
      </div>
    </section>

    <aside class="agent-strip">
      <p class="agent-strip__label">MACHINE-READABLE</p>
      <ul>
        <li><a href="/passport/collection.json">/passport/collection.json</a></li>
        <li><a href="/passport/book.json">/passport/book.json</a></li>
        <li><a href="/passport/routes.json">/passport/routes.json</a></li>
        <li><a href="/passport/receipts.json">/passport/receipts.json</a></li>
        <li><a href="/passport.json">/passport.json</a></li>
        <li><a href="/passport/posters.json">/passport/posters.json</a></li>
        <li><a href="/agents.json">/agents.json</a></li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<script>
  (function () {
    var dataEl = document.getElementById('passport-collection-data');
    if (!dataEl) return;

    var data = {};
    try { data = JSON.parse(dataEl.textContent || '{}'); } catch (e) { return; }

    var storageKey = data.storageKey || 'pc:station-passport:v1';
    var total = Number(data.total || 0);
    var countEl = document.querySelector('[data-collection-count]');
    var meterEl = document.querySelector('[data-collection-meter]');
    var exportBtn = document.querySelector('[data-export-collection]');
    var claimRouteBtn = document.querySelector('[data-claim-route]');

    function emptyState() {
      return { version: 1, updatedAt: null, stamps: {}, mints: {} };
    }

    function readState() {
      try {
        var raw = localStorage.getItem(storageKey);
        if (!raw) return emptyState();
        var parsed = JSON.parse(raw);
        if (!parsed || typeof parsed !== 'object' || !parsed.stamps) return emptyState();
        if (!parsed.mints || typeof parsed.mints !== 'object') parsed.mints = {};
        return parsed;
      } catch (e) {
        return emptyState();
      }
    }

    function writeState(state) {
      state.updatedAt = new Date().toISOString();
      try { localStorage.setItem(storageKey, JSON.stringify(state)); } catch (e) {}
    }

    function paint() {
      var state = readState();
      var n = Object.keys(state.stamps || {}).length;
      if (countEl) countEl.textContent = String(n);
      if (meterEl) meterEl.style.width = total ? Math.round((n / total) * 100) + '%' : '0%';

      document.querySelectorAll('[data-collection-stamp]').forEach(function (card) {
        var slug = card.getAttribute('data-collection-stamp') || '';
        var stamped = Boolean(state.stamps && state.stamps[slug]);
        var minted = Boolean(state.mints && state.mints[slug]);
        card.classList.toggle('is-stamped', stamped);
        card.classList.toggle('is-minted', minted);
        var btn = card.querySelector('[data-collection-claim]');
        if (btn) btn.textContent = stamped ? 'Collected' : 'Collect';
      });
    }

    function stamp(slug, name, code) {
      var state = readState();
      state.stamps[slug] = {
        slug: slug,
        station: name || slug,
        code: code || '',
        date: data.today,
        at: new Date().toISOString(),
      };
      writeState(state);
      paint();
      window.dispatchEvent(new CustomEvent('pc:passport-updated', {
        detail: { slug: slug, count: Object.keys(state.stamps || {}).length, total: total },
      }));
    }

    document.querySelectorAll('[data-collection-claim]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        stamp(
          btn.getAttribute('data-collection-claim') || '',
          btn.getAttribute('data-stamp-name') || '',
          btn.getAttribute('data-stamp-code') || '',
        );
      });
    });

    if (claimRouteBtn) {
      claimRouteBtn.addEventListener('click', function () {
        (data.stamps || []).slice(0, 4).forEach(function (entry) {
          stamp(entry.slug, entry.name, entry.code);
        });
      });
    }

    if (exportBtn) {
      exportBtn.addEventListener('click', function () {
        var payload = {
          exportedAt: new Date().toISOString(),
          source: 'https://pointcast.xyz/passport/collection',
          storageKey: storageKey,
          passport: readState(),
        };
        var blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = 'pointcast-passport-collection.json';
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(function () { URL.revokeObjectURL(url); }, 1000);
      });
    }

    paint();
  })();
</script>

<style>
  .page {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 20px 0 88px;
  }

  .crumb,
  .kicker,
  .mini-label,
  .collection-score__label,
  .feature-tile span,
  .stamp-object__copy p,
  .stamp-object__copy span,
  .stamp-object__actions,
  .stamp-object__mint,
  .poster-object span,
  .text-link,
  .tool-btn,
  .agent-strip__label {
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .crumb {
    display: flex;
    gap: 8px;
    color: var(--pc-ink-muted);
    margin-bottom: 20px;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 310px;
    gap: 28px;
    align-items: stretch;
    padding-bottom: 24px;
    border-bottom: 1.5px solid var(--pc-ink);
  }

  .hero__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 10px;
  }

  .kicker {
    margin: 0 0 10px;
    color: #8a2432;
  }

  .hero h1 {
    margin: 0;
    max-width: 760px;
    font-size: 62px;
    line-height: 0.96;
    font-weight: 500;
  }

  .dek {
    margin: 16px 0 0;
    max-width: 72ch;
    color: var(--pc-ink-soft);
    font-size: 16px;
    line-height: 1.55;
  }

  .collection-score {
    display: grid;
    align-content: space-between;
    gap: 12px;
    min-width: 0;
    padding: 16px;
    border: 1px solid var(--pc-ink);
    background: #fff;
    box-shadow: 8px 8px 0 #e9e5dd;
  }

  .collection-score p {
    margin: 0;
    color: var(--pc-ink-muted);
    font-size: 13px;
    line-height: 1.4;
  }

  .collection-score strong {
    font-size: 42px;
    line-height: 1;
    font-weight: 500;
  }

  .collection-score code {
    word-break: break-word;
  }

  .collection-score__meter {
    height: 12px;
    border: 1px solid var(--pc-ink);
    background: repeating-linear-gradient(90deg, #f7f5f0 0 8px, #ece8de 8px 16px);
    overflow: hidden;
  }

  .collection-score__meter span {
    display: block;
    width: 0;
    height: 100%;
    background: #0f6e56;
    transition: width 160ms ease;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    gap: 14px;
    margin: 26px 0;
  }

  .feature-tile {
    position: relative;
    display: grid;
    align-content: end;
    min-height: 360px;
    padding: 16px;
    border: 1px solid var(--pc-rule);
    background: #111;
    color: #fffaf0;
    overflow: hidden;
    text-decoration: none;
  }

  .feature-tile img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.82;
    transition: transform 180ms ease;
  }

  .feature-tile:hover img {
    transform: scale(1.012);
  }

  .feature-tile span,
  .feature-tile strong {
    position: relative;
    z-index: 1;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.42);
  }

  .feature-tile strong {
    max-width: 14ch;
    font-size: 30px;
    line-height: 1;
    font-weight: 500;
  }

  .feature-tile--book {
    min-height: 420px;
  }

  .feature-tile--mint {
    background:
      radial-gradient(circle at 70% 20%, rgba(240, 185, 74, 0.34), transparent 36%),
      linear-gradient(135deg, #182c25, #111);
  }

  .mint-object {
    display: grid;
    gap: 10px;
    place-items: center;
    align-self: center;
    justify-self: center;
    width: min(100%, 260px);
    aspect-ratio: 1;
    margin-bottom: 24px;
    border: 2px solid #fffaf0;
    border-radius: 50%;
    color: #fffaf0;
    text-align: center;
  }

  .mint-object p,
  .mint-object span {
    margin: 0;
    max-width: 18ch;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    text-transform: uppercase;
  }

  .mint-object strong {
    max-width: none;
    font-size: 32px;
  }

  .mint-brief {
    display: grid;
    grid-template-columns: 0.82fr 1.18fr;
    gap: 24px;
    margin: 28px 0;
    padding: 18px 0;
    border-top: 1px solid var(--pc-rule-soft);
    border-bottom: 1px solid var(--pc-rule);
  }

  .mint-brief h2 {
    margin: 0;
    max-width: 16ch;
    font-size: 28px;
    line-height: 1.05;
    font-weight: 500;
  }

  .mint-brief__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .mint-brief article {
    padding: 14px;
    border: 1px solid var(--pc-rule);
    background: #fff;
  }

  .mint-brief p {
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 13px;
    line-height: 1.45;
  }

  .mint-brief strong,
  .mint-brief code {
    color: var(--pc-ink);
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: end;
    margin-bottom: 12px;
  }

  .section-head h2 {
    margin: 0;
    font-size: 24px;
    line-height: 1.08;
    font-weight: 500;
  }

  .cabinet-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tool-btn {
    min-height: 38px;
    padding: 8px 12px;
    border: 1px solid var(--pc-ink);
    background: var(--pc-ink);
    color: #fff;
    font: inherit;
    cursor: pointer;
  }

  .tool-btn--quiet {
    background: #fff;
    color: var(--pc-ink);
  }

  .stamp-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .stamp-object {
    display: grid;
    gap: 10px;
    min-width: 0;
    padding: 12px;
    border: 1px solid var(--pc-rule);
    background: #fff;
  }

  .stamp-object.is-stamped {
    border-color: var(--stamp-color);
    box-shadow: inset 0 0 0 4px color-mix(in srgb, var(--stamp-color) 16%, transparent);
  }

  .stamp-object.is-minted {
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--stamp-color) 12%, #fff), #fff 48%);
  }

  .stamp-object__art {
    display: block;
    aspect-ratio: 1;
    border: 2px solid var(--stamp-color);
    background: #fffdf7;
    overflow: hidden;
  }

  .stamp-object__art img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .stamp-object__copy p,
  .stamp-object__copy span,
  .stamp-object__mint {
    margin: 0;
    color: var(--stamp-color);
  }

  .stamp-object__copy h3 {
    margin: 5px 0;
    font-size: 22px;
    line-height: 1.04;
    font-weight: 500;
  }

  .stamp-object__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .stamp-object__actions button {
    min-height: 32px;
    padding: 6px 9px;
    border: 1px solid var(--stamp-color);
    background: var(--stamp-color);
    color: #fff;
    font: inherit;
    cursor: pointer;
  }

  .stamp-object.is-stamped .stamp-object__actions button {
    background: #fff;
    color: var(--stamp-color);
  }

  .stamp-object__mint {
    color: var(--pc-ink-muted);
  }

  .poster-cabinet {
    margin-top: 32px;
  }

  .text-link {
    color: #8a2432;
  }

  .poster-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .poster-object {
    display: grid;
    gap: 8px;
    color: var(--pc-ink);
    text-decoration: none;
  }

  .poster-object img {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border: 1px solid var(--pc-rule);
    background: #111;
  }

  .poster-object span {
    color: var(--pc-ink-muted);
  }

  .agent-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    margin-top: 30px;
    padding: 14px 0;
    border-top: 1px solid var(--pc-rule-soft);
  }

  .agent-strip__label {
    margin: 0;
    color: var(--pc-ink-muted);
  }

  .agent-strip ul {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 980px) {
    .hero,
    .mint-brief,
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      font-size: 46px;
    }

    .stamp-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .poster-grid {
