---
import BlockLayout from '../../layouts/BlockLayout.astro';
import posterSet from '../../data/passport-posters.json';

const posters = posterSet.posters;
const title = 'Passport Posters';
const description =
  'Ten gpt-image-2 campaign posters for PointCast Station Passport stamps and the Tezos mint path.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  '@id': 'https://pointcast.xyz/passport/posters',
  name: 'PointCast Passport Stamps Poster Set',
  description,
  url: 'https://pointcast.xyz/passport/posters',
  associatedMedia: posters.map((poster) => ({
    '@type': 'ImageObject',
    name: poster.title,
    caption: `${poster.subtitle} · ${poster.badge}`,
    contentUrl: `https://pointcast.xyz${poster.image}`,
    thumbnailUrl: `https://pointcast.xyz${poster.image}`,
    encodingFormat: 'image/png',
  })),
};
---

<BlockLayout
  title={title}
  description={description}
  image="/posters/passport/origin-stamp.png"
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/passport/posters.json', title: 'Passport Posters JSON' }]}
  frame={{
    image: 'https://pointcast.xyz/posters/passport/origin-stamp.png',
    aspectRatio: '1:1',
    buttons: [
      { label: 'Open Passport', action: 'link', target: 'https://pointcast.xyz/passport' },
      { label: 'Mint Plan', action: 'link', target: 'https://pointcast.xyz/passport.json' },
      { label: 'Posters JSON', action: 'link', target: 'https://pointcast.xyz/passport/posters.json' },
    ],
  }}
>
  <div class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/passport">passport</a>
      <span aria-hidden="true">/</span>
      <span>posters</span>
    </nav>

    <header class="hero">
      <div>
        <p class="kicker">OPENAI · {posterSet.generator.model} · TEZOS CAMPAIGN</p>
        <h1>Passport posters for the mint path.</h1>
      </div>
      <p class="dek">
        Ten generated campaign pieces for the Station Passport launch: source art
        from the image generator, exact typography composited in the repo, and
        public image URLs for social posts, agent manifests, and mint receipts.
      </p>
    </header>

    <section class="poster-grid" aria-label="Passport poster set">
      {posters.map((poster) => (
        <article class="poster-card">
          <a class="poster-card__image" href={poster.image}>
            <img src={poster.image} alt={`${poster.title} PointCast Passport Stamps poster`} width="1200" height="1800" loading="lazy" />
          </a>
          <div class="poster-card__copy">
            <p class="poster-card__num">POSTER {poster.number} · {poster.stampCodes.join(' / ')}</p>
            <h2>{poster.title}</h2>
            <p>{poster.subtitle}</p>
            <div class="poster-card__links">
              <a href={poster.cta.replace('pointcast.xyz', '')}>Passport</a>
              <a href={poster.image}>PNG</a>
              <a href={poster.sourceImage}>Source</a>
            </div>
          </div>
        </article>
      ))}
    </section>

    <aside class="agent-strip">
      <p class="agent-strip__label">MACHINE-READABLE</p>
      <ul>
        <li><a href="/passport/posters.json">/passport/posters.json</a></li>
        <li><a href="/passport.json">/passport.json</a></li>
        <li><a href="/agents.json">/agents.json</a></li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<style>
  .page {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 20px 0 88px;
  }

  .crumb,
  .kicker,
  .poster-card__num,
  .poster-card__links,
  .agent-strip__label {
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .crumb {
    display: flex;
    gap: 8px;
    color: var(--pc-ink-muted);
    margin-bottom: 20px;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.65fr);
    gap: 28px;
    align-items: end;
    padding-bottom: 26px;
    border-bottom: 1.5px solid var(--pc-ink);
  }

  .kicker {
    margin: 0 0 10px;
    color: #8a2432;
  }

  .hero h1 {
    margin: 0;
    max-width: 820px;
    font-size: 58px;
    line-height: 0.96;
    font-weight: 500;
  }

  .dek {
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 16px;
    line-height: 1.55;
  }

  .poster-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 16px;
    margin-top: 26px;
  }

  .poster-card {
    border: 1px solid var(--pc-rule);
    background: #fff;
  }

  .poster-card__image {
    display: block;
    background: #111;
    line-height: 0;
    overflow: hidden;
  }

  .poster-card__image img {
    width: 100%;
    height: auto;
    transition: transform 180ms ease;
  }

  .poster-card__image:hover img {
    transform: scale(1.012);
  }

  .poster-card__copy {
    display: grid;
    gap: 6px;
    padding: 12px;
  }

  .poster-card__num {
    margin: 0;
    color: #8a2432;
  }

  .poster-card h2 {
    margin: 0;
    font-size: 20px;
    line-height: 1.08;
    font-weight: 500;
  }

  .poster-card p {
    margin: 0;
    color: var(--pc-ink-muted);
    font-size: 13px;
    line-height: 1.35;
  }

  .poster-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }

  .agent-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    margin-top: 30px;
    padding: 14px 0;
    border-top: 1px solid var(--pc-rule-soft);
  }

  .agent-strip__label {
    margin: 0;
    color: var(--pc-ink-muted);
  }

  .agent-strip ul {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 1080px) {
    .poster-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .hero h1 {
      font-size: 40px;
    }

    .poster-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 480px) {
    .page {
      width: min(100% - 24px, 1180px);
      padding-top: 14px;
    }

    .poster-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
