<!--
  Admin action dispatcher — handles every form with class "admin-action-form".
  Reads data-entrypoint + data-kt1 + data-slug from the form, builds the
  Taquito call, and signs via Beacon. Currently only set_administrator is
  wired; future entrypoints (set_metadata_base_cid, register_tokens, etc.)
  drop into the same dispatcher by adding a case in `buildArgs(...)`.

  Two responsibilities, isolated:

  1. Copy-source button — wired up unconditionally because it lives on
     DRAFT-status pages (no liveKt1), and the user just wants the source
     in their clipboard.

  2. Admin action dispatcher (LIVE contracts only) — handles every form
     with class "admin-action-form".

  Plain JavaScript inside a regular <script> (no is:inline, no lang="ts")
  so Vite bundles + transpiles. Type hints via JSDoc only — see
  /admin/deploy/new for the rationale.
-->
<script>
  // ── Copy source button (DRAFT contracts) ─────────────────────────
  // Reads the <pre id="contract-source-pre"> textContent and writes it
  // to the clipboard. Same content was rendered server-side at build
  // time from contracts/v2/<slug>.py — no fetch needed at runtime.
  (function wireCopySource() {
    const btn = document.getElementById('copy-source-btn');
    if (!btn) return;
    const sourceId = btn.getAttribute('data-source-id') || 'contract-source-pre';
    const labelEl = btn.querySelector('.copy-label');
    const originalLabel = labelEl ? labelEl.textContent : btn.textContent;

    btn.addEventListener('click', async () => {
      const pre = document.getElementById(sourceId);
      if (!pre) {
        if (labelEl) labelEl.textContent = 'source not found';
        return;
      }
      const text = pre.textContent || '';
      try {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          await navigator.clipboard.writeText(text);
        } else {
          // Fallback for older browsers / non-secure contexts.
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        if (labelEl) labelEl.textContent = '✓ copied — paste in smartpy.io/ide';
        setTimeout(() => {
          if (labelEl && originalLabel) labelEl.textContent = originalLabel;
        }, 2500);
      } catch (err) {
        if (labelEl) labelEl.textContent = 'copy failed: ' + (err && err.message ? err.message : 'unknown');
      }
    });
  })();

  // ── Admin action dispatcher (LIVE contracts only) ────────────────
  const tzAddrRe = /^tz[123][1-9A-HJ-NP-Za-km-z]{33}$/;
  const RPC_MAINNET = 'https://mainnet.api.tez.ie';

  /**
   * Build the call arguments for an entrypoint based on its declared
   * data-arg-type. Returns the args ready to pass into
   * `methodsObject[entrypoint](args)` plus a summary string for status.
   * Throws with a user-readable message if validation fails.
   *
   * Supported arg types:
   *   - "address"        → string, validated as tz-shaped
   *   - "string"         → arbitrary non-empty string
   *   - "nat-string-map" → JSON object {"0":"name", "1":"name", ...} → MichelsonMap
   *
   * @param {string} entrypoint
   * @param {string} argType
   * @param {FormData} fd
   * @param {string} connectedAddr
   * @param {any} mmCtor          MichelsonMap constructor (lazy-imported)
   */
  function buildCall(entrypoint, argType, fd, connectedAddr, mmCtor) {
    // Address — validated, defaults to connected wallet if blank.
    if (argType === 'address') {
      const raw = (fd.get('value') || fd.get('new_admin') || '').toString().trim();
      const target = raw || connectedAddr;
      if (!target || !tzAddrRe.test(target)) {
        throw new Error('address must be tz1/tz2/tz3 (' + (raw ? 'invalid format' : 'no wallet connected') + ')');
      }
      return { args: target, summary: entrypoint + '(' + target.slice(0, 8) + '…' + target.slice(-4) + ')' };
    }
    // Plain string.
    if (argType === 'string') {
      const raw = (fd.get('value') || '').toString().trim();
      if (!raw) throw new Error('string value is required');
      return { args: raw, summary: entrypoint + '("' + raw.slice(0, 40) + (raw.length > 40 ? '…' : '') + '")' };
    }
    // map nat → string. Submit as a MichelsonMap.
    if (argType === 'nat-string-map') {
      const raw = (fd.get('mug_names') || fd.get('value') || '').toString().trim();
      if (!raw) throw new Error('JSON map is required');
      let parsed;
      try {
        parsed = JSON.parse(raw);
      } catch (e) {
        throw new Error('JSON parse failed: ' + (e && e.message ? e.message : 'invalid'));
      }
      if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {
        throw new Error('expected a JSON object (e.g. {"0": "Ceramic Mug", "1": "Espresso Cup"})');
      }
      const entries = Object.entries(parsed);
      if (entries.length === 0) throw new Error('map is empty');
      const m = new mmCtor();
      for (const [k, v] of entries) {
        const id = parseInt(k, 10);
        if (Number.isNaN(id)) throw new Error('map key "' + k + '" is not a valid nat');
        if (typeof v !== 'string') throw new Error('value for ' + k + ' must be a string');
        m.set(id, v);
      }
      return { args: m, summary: entrypoint + '(' + entries.length + ' entries)' };
    }
    // Fallback: legacy single-arg "address" (set_administrator without arg-type set).
    if (entrypoint === 'set_administrator') {
      return buildCall(entrypoint, 'address', fd, connectedAddr, mmCtor);
    }
    throw new Error('unsupported arg-type: ' + argType);
  }

  function connectedAddress() {
    try {
      const raw = localStorage.getItem('pc:wallet');
      if (!raw) return null;
      const w = JSON.parse(raw);
      if (w && typeof w.address === 'string' && w.chain === 'tezos') return w.address;
      return null;
    } catch {
      return null;
    }
  }

  document.querySelectorAll('.admin-action-form').forEach((form) => {
    const f = /** @type {HTMLFormElement} */ (form);
    const statusEl = f.querySelector('.action-status');
    const btn = /** @type {HTMLButtonElement|null} */ (f.querySelector('button[type="submit"]'));
    const btnLabel = f.querySelector('.btn-label');

    function setStatus(html) {
      if (statusEl) statusEl.innerHTML = html;
    }
    function setBusy(busy, label) {
      if (btn) btn.disabled = busy;
      if (btnLabel && label) btnLabel.textContent = label;
    }

    f.addEventListener('submit', async (e) => {
      e.preventDefault();
      const entrypoint = f.getAttribute('data-entrypoint') || '';
      const argType = f.getAttribute('data-arg-type') || 'address';
      const kt1 = f.getAttribute('data-kt1') || '';
      if (!entrypoint || !kt1) {
        setStatus('form misconfigured · missing data-entrypoint or data-kt1');
        return;
      }

      setBusy(true, 'Loading Taquito…');
      setStatus('loading taquito…');

      let TezosToolkit, BeaconWallet, MichelsonMap;
      try {
        ({ TezosToolkit, MichelsonMap } = await import('@taquito/taquito'));
        ({ BeaconWallet } = await import('@taquito/beacon-wallet'));
      } catch (err) {
        setStatus('failed to load taquito: ' + (err && err.message ? err.message : 'unknown'));
        setBusy(false, 'Sign + send');
        return;
      }

      let call;
      try {
        const connected = connectedAddress() || '';
        const fd = new FormData(f);
        call = buildCall(entrypoint, argType, fd, connected, MichelsonMap);
      } catch (err) {
        setStatus('input error: ' + (err && err.message ? err.message : 'unknown'));
        setBusy(false, 'Sign + send');
        return;
      }

      setStatus('preparing · ' + call.summary);

      try {

        const tezos = new TezosToolkit(RPC_MAINNET);
        const wallet = new BeaconWallet({
          name: 'PointCast Admin',
          network: { type: 'mainnet', rpcUrl: RPC_MAINNET },
        });
        tezos.setWalletProvider(wallet);

        setBusy(true, 'Connecting…');
        setStatus('connect kukai…');

        const existing = await wallet.client.getActiveAccount();
        if (!existing || (existing.network && existing.network.type !== 'mainnet')) {
          try { await wallet.clearActiveAccount(); } catch { /* ignore */ }
          await wallet.client.requestPermissions();
        }

        setBusy(true, 'Confirm in Kukai…');
        setStatus('confirm in kukai · ' + call.summary);

        const contract = await tezos.wallet.at(kt1);
        const methods = contract.methodsObject;
        if (typeof methods[entrypoint] !== 'function') {
          throw new Error('contract does not expose entrypoint ' + entrypoint);
        }
        const op = await methods[entrypoint](call.args).send();
        const opHash = op && op.opHash ? op.opHash : '';
        if (opHash) setStatus('✓ broadcast ' + opHash.slice(0, 10) + '… · confirming…');

        await op.confirmation();
        setStatus(
          '✓ confirmed · <a href="https://tzkt.io/' + (opHash || kt1) +
          '" target="_blank" rel="noopener" class="text-warm hover:text-ink no-underline">tzkt &nearr;</a>',
        );
        setBusy(false, 'Done ✓');

        // Auto-refresh the live state panel after 3s so the new admin
        // shows up without a manual reload.
        setTimeout(() => window.location.reload(), 3000);
      } catch (err) {
        // eslint-disable-next-line no-console
        console.error('admin action failed:', err);
        let msg = err && err.message ? err.message : null;
        if (!msg && err && err.errors && err.errors[0]) {
          const e0 = err.errors[0];
          msg = (e0.id || e0.kind || '') + (e0.msg ? ': ' + e0.msg : '');
        }
        if (!msg) msg = String(err);
        if (/ABORTED|reject|cancel/i.test(msg)) {
          setStatus('signing cancelled');
        } else if (/NOT_ADMIN|admin/i.test(msg) && /assert/i.test(msg)) {
          setStatus('rejected: contract says you are not the admin');
        } else {
          setStatus('error: ' + String(msg).slice(0, 280));
        }
        setBusy(false, 'Sign + send');
      }
    });
  });
</script>

