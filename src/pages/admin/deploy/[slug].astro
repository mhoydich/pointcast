---
/**
 * /admin/deploy/[slug] — per-contract management.
 *
 * Reads `src/data/contracts.json[slug]` at build time and renders a focused
 * landing page for one contract. Surfaces:
 *   - Status badge + KT1 (if live)
 *   - Links: tzkt, better-call.dev, objkt, GitHub source, runbook, brief
 *   - Action recommendations based on status
 *   - Recent on-chain ops (client-side fetch from tzkt API for LIVE
 *     contracts only — kept lightweight so a stale tzkt response doesn't
 *     block the page from rendering)
 *
 * v1 doesn't yet expose register-tokens / set-metadata / transfer-admin
 * forms inline (those still flow through the per-feature surface — e.g.
 * /coffee for mug minting). The Originate action lands on
 * /admin/deploy/new?prefill=<slug> which is the one wallet-aware path
 * we keep tightly maintained.
 *
 * Pre-renders one page per registered contract via getStaticPaths.
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import WalletConnect from '../../../components/WalletConnect.astro';
import contracts from '../../../data/contracts.json';
import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';

export async function getStaticPaths() {
  const data = (await import('../../../data/contracts.json')).default as Record<string, any>;
  return Object.keys(data)
    .filter((k) => !k.startsWith('_'))
    .map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const all = contracts as Record<string, any>;
const entry = slug && typeof slug === 'string' ? all[slug] : null;

if (!entry) {
  // Astro 4+ supports `Astro.redirect`; this is the simplest way to
  // bounce unknown slugs back to the dashboard.
  return Astro.redirect('/admin/deploy');
}

const SLUG_DISPLAY: Record<string, string> = {
  visit_nouns: 'Visit Nouns FA2',
  coffee_mugs: 'Coffee Mugs FA2',
  birthdays: 'Birthdays FA2',
  drum_token: 'Drum Token',
  marketplace: 'PointCast Marketplace',
  prize_cast: 'Prize Cast',
  agent_derby_receipts: 'Agent Derby Receipts',
};

const SLUG_DESCRIPTION: Record<string, string> = {
  visit_nouns:
    'One Noun NFT per visit · public mint · royalty 5% · Sprint v1 launch contract.',
  coffee_mugs:
    'Five rarity-tiered mug NFTs claimable from /coffee · public free mint (gas-only) · edition caps 333/144/64/21/8.',
  birthdays:
    'Open-edition birthday cards · one token_id per BIRTHDAY block · claimable from /b/{id} and /cake.',
  drum_token: 'PointCast utility token (FA1.2 plan).',
  marketplace: 'On-site listings + sales escrow (planned).',
  prize_cast: 'Race-winner prize escrow contract (planned).',
  agent_derby_receipts: 'Public receipt ledger for Agent Derby races.',
};

const SLUG_FEATURE_PAGE: Record<string, string> = {
  visit_nouns: '/',
  coffee_mugs: '/coffee',
  birthdays: '/cake',
};

const name = SLUG_DISPLAY[slug as string] || (slug as string);
const description = SLUG_DESCRIPTION[slug as string] || '';
const featurePage = SLUG_FEATURE_PAGE[slug as string] || null;

const liveKt1 =
  entry.mainnet && typeof entry.mainnet === 'string' && entry.mainnet.startsWith('KT1')
    ? entry.mainnet
    : null;
const shadowKt1 =
  entry.shadownet && typeof entry.shadownet === 'string' && entry.shadownet.startsWith('KT1')
    ? entry.shadownet
    : null;

const contractFile = existsSync(resolve(`contracts/v2/${slug}_fa2.py`))
  ? `contracts/v2/${slug}_fa2.py`
  : existsSync(resolve(`contracts/v2/${slug}.py`))
    ? `contracts/v2/${slug}.py`
    : null;

// Read the SmartPy source at build time so the per-contract page can
// expose a "Copy source" button. The button writes the source to the
// clipboard via navigator.clipboard.writeText so Mike can paste a fresh
// buffer into the SmartPy IDE without his previous session bleeding
// through (the IDE persists the last edit per browser → opening
// smartpy.io/ide while compiling Coffee Mugs would re-open Coffee
// Mugs even when the goal is Prize Cast or Birthdays).
const contractSource: string | null = contractFile
  ? (() => {
      try {
        return readFileSync(resolve(contractFile), 'utf-8');
      } catch {
        return null;
      }
    })()
  : null;

const artifactsAvailable =
  existsSync(resolve(`public/admin/_artifacts/${slug}-contract.json`)) &&
  existsSync(resolve(`public/admin/_artifacts/${slug}-storage.json`));

type Status = 'LIVE' | 'STAGED' | 'DRAFT' | 'WRITTEN';
let status: Status;
if (liveKt1) status = 'LIVE';
else if (artifactsAvailable) status = 'STAGED';
else if (contractFile) status = 'DRAFT';
else status = 'WRITTEN';

const STATUS_TONE: Record<Status, string> = {
  LIVE: 'bg-emerald-500/15 text-emerald-700 border-emerald-500/30',
  STAGED: 'bg-warm/20 text-warm border-warm/40',
  DRAFT: 'bg-amber-500/15 text-amber-700 border-amber-500/30',
  WRITTEN: 'bg-ink-soft/15 text-ink-soft border-ink-soft/30',
};

const symbol = entry.symbol ?? null;
const runbook = entry?._notes?.runbook ?? null;
const brief = entry?._notes?.brief ?? null;
const purpose = entry?._notes?.purpose ?? null;
const mainnetNotes = entry._mainnet_notes ?? null;
const shadownetNotes = entry._shadownet_notes ?? null;
---

<BaseLayout title={`${name} · Admin · Deploy`} description={description}>
  <div class="max-w-[52rem] mx-auto px-4 pt-6 md:pt-10 pb-20">

    <!-- Masthead band -->
    <div class="-mx-4 px-4 py-2.5 border-y border-rule/50 flex items-center justify-between gap-3 mb-6">
      <div class="flex items-center gap-3 min-w-0">
        <a
          href="/"
          class="font-mono text-sm md:text-base font-bold tracking-[0.28em] uppercase text-ink leading-none hover:text-warm transition-colors no-underline"
        >
          PointCast
        </a>
        <a
          href="/admin/deploy"
          class="font-mono text-[0.58rem] tracking-[0.22em] uppercase text-warm hover:text-ink transition-colors no-underline"
        >
          / admin / deploy /
        </a>
        <span class="font-mono text-[0.58rem] tracking-[0.22em] uppercase text-ink-soft/70 truncate">
          {slug}
        </span>
      </div>
      <WalletConnect />
    </div>

    <!-- Header -->
    <header class="mb-6">
      <div class="flex items-center gap-2 flex-wrap mb-2">
        <span class="font-mono text-[0.54rem] tracking-[0.22em] uppercase text-warm">
          contract
        </span>
        <span class={`px-1.5 py-0.5 rounded-sm border text-[0.5rem] tracking-[0.16em] uppercase font-mono leading-none ${STATUS_TONE[status]}`}>
          {status}
        </span>
        <span class="px-1.5 py-0.5 rounded-sm border border-rule/40 text-[0.5rem] tracking-[0.16em] uppercase font-mono leading-none text-ink-soft bg-card">
          tz
        </span>
        {symbol && (
          <span class="font-mono text-[0.55rem] tracking-[0.14em] uppercase text-ink-soft/70">
            ${symbol}
          </span>
        )}
      </div>
      <h1 class="font-serif italic text-[1.8rem] md:text-[2.2rem] text-ink font-medium leading-[1.1] mb-2">
        {name}
      </h1>
      <p class="text-[0.92rem] text-ink/70 leading-relaxed">
        {purpose || description}
      </p>
    </header>

    <!-- KT1 panel -->
    {liveKt1 && (
      <section class="mb-6 p-4 rounded-md border border-emerald-500/30 bg-emerald-500/5">
        <p class="font-mono text-[0.54rem] tracking-[0.22em] uppercase text-emerald-700 mb-1">
          mainnet · live
        </p>
        <p class="font-mono text-[0.85rem] text-ink mb-3 break-all">
          {liveKt1}
        </p>
        <div class="flex flex-wrap gap-1.5">
          <a
            href={`https://tzkt.io/${liveKt1}/operations`}
            target="_blank" rel="noopener"
            class="inline-flex items-center px-2.5 py-1 rounded-sm bg-card border border-rule/40 font-mono text-[0.55rem] tracking-[0.14em] uppercase text-ink hover:border-warm hover:text-warm transition-colors no-underline"
          >
            tzkt &nearr;
          </a>
          <a
            href={`https://better-call.dev/mainnet/${liveKt1}`}
            target="_blank" rel="noopener"
            class="inline-flex items-center px-2.5 py-1 rounded-sm bg-card border border-rule/40 font-mono text-[0.55rem] tracking-[0.14em] uppercase text-ink hover:border-warm hover:text-warm transition-colors no-underline"
          >
            better-call.dev &nearr;
          </a>
          <a
            href={`https://objkt.com/collection/${liveKt1}`}
            target="_blank" rel="noopener"
            class="inline-flex items-center px-2.5 py-1 rounded-sm bg-card border border-rule/40 font-mono text-[0.55rem] tracking-[0.14em] uppercase text-ink hover:border-warm hover:text-warm transition-colors no-underline"
          >
            objkt &nearr;
          </a>
          {featurePage && (
            <a
              href={featurePage}
              class="inline-flex items-center px-2.5 py-1 rounded-sm bg-warm text-paper font-mono text-[0.55rem] tracking-[0.14em] uppercase hover:bg-ink transition-colors no-underline"
            >
              {featurePage} &rarr;
            </a>
          )}
        </div>
      </section>
    )}

    {shadowKt1 && !liveKt1 && (
      <section class="mb-6 p-4 rounded-md border border-warm/40 bg-warm/5">
        <p class="font-mono text-[0.54rem] tracking-[0.22em] uppercase text-warm mb-1">
          shadownet · testnet
        </p>
        <p class="font-mono text-[0.85rem] text-ink mb-3 break-all">
          {shadowKt1}
        </p>
        <a
          href={`https://shadownet.tzkt.io/${shadowKt1}/operations`}
          target="_blank" rel="noopener"
          class="inline-flex items-center px-2.5 py-1 rounded-sm bg-card border border-rule/40 font-mono text-[0.55rem] tracking-[0.14em] uppercase text-ink hover:border-warm hover:text-warm transition-colors no-underline"
        >
          shadownet tzkt &nearr;
        </a>
      </section>
    )}

    <!-- Action panel — varies by status -->
    <section class="mb-6">
      <h2 class="font-mono text-[0.6rem] tracking-[0.2em] uppercase text-ink mb-3 border-b border-rule/40 pb-1.5">
        actions
      </h2>

      {status === 'LIVE' && (
        <div class="space-y-3">
          {featurePage && (
            <a
              href={featurePage}
              class="block p-3 rounded-md border border-rule/30 bg-card/40 hover:border-warm hover:bg-card transition-colors no-underline"
            >
              <p class="font-medium text-ink mb-0.5">Mint / interact &rarr;</p>
              <p class="text-[0.85rem] text-ink-soft">
                Open the public-facing page where wallets can mint or interact with this contract.
              </p>
            </a>
          )}
          <a
            href={`/admin/deploy/new?prefill=${slug}`}
            class="block p-3 rounded-md border border-rule/30 bg-card/40 hover:border-warm hover:bg-card transition-colors no-underline"
          >
            <p class="font-medium text-ink mb-0.5">Re-deploy a fresh copy &rarr;</p>
            <p class="text-[0.85rem] text-ink-soft">
              Originate a new instance of this contract (e.g. for a separate edition or to fix an orphan).
              Auto-patches the admin field to your wallet.
            </p>
          </a>
        </div>
      )}

      {status === 'STAGED' && (
        <div class="space-y-3">
          <a
            href={`/admin/deploy/new?prefill=${slug}`}
            class="block p-3 rounded-md border border-warm/40 bg-warm/10 hover:bg-warm/20 transition-colors no-underline"
          >
            <p class="font-medium text-ink mb-0.5">Originate &rarr;</p>
            <p class="text-[0.85rem] text-ink-soft">
              Pre-staged Michelson is ready. The Publisher will load it,
              auto-patch the admin field, and send the origination through Kukai.
            </p>
          </a>
        </div>
      )}

      {status === 'DRAFT' && (
        <div class="space-y-3">
          <div class="p-3 rounded-md border border-rule/30 bg-card/40">
            <p class="font-medium text-ink mb-1">Compile to Michelson</p>
            <p class="text-[0.85rem] text-ink-soft mb-3 leading-relaxed">
              SmartPy IDE persists the last open buffer per browser, so opening it
              cold often shows a different contract. Click <strong>Copy source</strong>{' '}
              first, open the IDE, <kbd class="px-1 rounded bg-paper border border-rule/40 text-[0.7rem]">⌘A</kbd> to
              select all, paste, then <strong>Run</strong> &mdash; download the contract +
              storage JSONs and paste them into the Publisher.
            </p>
            <div class="flex flex-wrap gap-1.5 mb-2">
              {contractSource && (
                <button
                  type="button"
                  id="copy-source-btn"
                  data-source-id="contract-source-pre"
                  class="inline-flex items-center px-2.5 py-1 rounded-sm bg-warm text-paper font-mono text-[0.55rem] tracking-[0.14em] uppercase hover:bg-ink transition-colors cursor-pointer"
                >
                  <span class="copy-label">↥ Copy source ({(contractSource.length / 1024).toFixed(1)} KB)</span>
                </button>
              )}
              <a
                href="https://smartpy.io/ide"
                target="_blank" rel="noopener"
                class="inline-flex items-center px-2.5 py-1 rounded-sm bg-card border border-rule/40 font-mono text-[0.55rem] tracking-[0.14em] uppercase text-ink hover:border-warm hover:text-warm transition-colors no-underline"
              >
                smartpy.io/ide &nearr;
              </a>
              {contractFile && (
                <a
                  href={`https://github.com/mhoydich/pointcast/blob/main/${contractFile}`}
                  target="_blank" rel="noopener"
                  class="inline-flex items-center px-2.5 py-1 rounded-sm bg-card border border-rule/40 font-mono text-[0.55rem] tracking-[0.14em] uppercase text-ink hover:border-warm hover:text-warm transition-colors no-underline"
                >
                  github &nearr;
                </a>
              )}
            </div>
            {contractSource && (
              <details class="mt-3">
                <summary class="font-mono text-[0.55rem] tracking-[0.18em] uppercase text-ink-soft cursor-pointer hover:text-warm">
                  preview source ({contractSource.split(/\r?\n/).length} lines)
                </summary>
                <pre id="contract-source-pre" class="mt-2 font-mono text-[0.62rem] text-ink/85 overflow-x-auto whitespace-pre p-2 rounded bg-paper border border-rule/30 max-h-[24rem] overflow-y-auto">{contractSource}</pre>
              </details>
            )}
          </div>
          <a
            href={`/admin/deploy/new?prefill=${slug}`}
            class="block p-3 rounded-md border border-rule/30 bg-card/40 hover:border-warm hover:bg-card transition-colors no-underline"
          >
            <p class="font-medium text-ink mb-0.5">Originate (manual paste) &rarr;</p>
            <p class="text-[0.85rem] text-ink-soft">
              Open the Publisher and paste the compiled JSON. The
              <code class="font-mono text-[0.78rem] bg-paper px-1 py-0.5 rounded">?prefill</code>
              query tries to load pre-staged artifacts first, then falls back to manual paste.
            </p>
          </a>
        </div>
      )}

      {status === 'WRITTEN' && (
        <div class="p-3 rounded-md border border-rule/30 bg-card/40">
          <p class="font-medium text-ink mb-1">Sketch only &mdash; no source yet</p>
          <p class="text-[0.85rem] text-ink-soft">
            The slot exists in <code class="font-mono text-[0.78rem] bg-paper px-1 py-0.5 rounded">contracts.json</code>
            but no SmartPy source has been written yet. Add
            <code class="font-mono text-[0.78rem] bg-paper px-1 py-0.5 rounded">contracts/v2/{slug}.py</code>
            to advance to DRAFT.
          </p>
        </div>
      )}
    </section>

    <!-- Admin actions (LIVE FA2 only) -->
    {liveKt1 && (
      <section id="admin-actions" class="mb-6">
        <h2 class="font-mono text-[0.6rem] tracking-[0.2em] uppercase text-ink mb-3 border-b border-rule/40 pb-1.5">
          admin actions
        </h2>
        <p class="text-[0.85rem] text-ink-soft/80 mb-3 leading-relaxed">
          These call FA2 admin entrypoints from your connected wallet. Each
          op is signed in Kukai and broadcast to mainnet &mdash; you pay gas,
          you bear the consequence. Read the field labels carefully before
          signing.
        </p>

        <!-- register_tokens — for FA2 contracts with a tokens registry in contracts.json -->
        {entry.tokens && Object.keys(entry.tokens).length > 0 && entry.registerEntrypoint !== false && slug !== 'visit_nouns' && (
          <details id="register-tokens" class="mb-2 p-3 rounded-md border border-warm/40 bg-warm/5" open>
            <summary class="font-mono text-[0.62rem] tracking-[0.18em] uppercase text-ink cursor-pointer">
              register_tokens <span class="text-warm ml-1">— register {Object.keys(entry.tokens).length} token names</span>
            </summary>
            <form
              class="admin-action-form mt-3 space-y-2"
              data-entrypoint="register_tokens"
              data-arg-type="nat-string-map"
              data-kt1={liveKt1}
              data-slug={slug}
            >
              <label class="block">
                <span class="font-mono text-[0.54rem] tracking-[0.18em] uppercase text-ink-soft/70 block mb-1">
                  token names (token_id → display name)
                </span>
                <textarea
                  name="mug_names"
                  rows="6"
                  class="w-full font-mono text-[0.78rem] p-2 rounded border border-rule/40 bg-paper text-ink focus:border-warm focus:outline-none"
                >{JSON.stringify(typeof entry.tokens === 'object' && !Array.isArray(entry.tokens) && entry.tokens && typeof Object.values(entry.tokens)[0] === 'string' ? entry.tokens : Object.fromEntries(Object.entries(entry.tokens).map(([k, v]: any) => [k, v?.recipient_name ?? v?.name ?? k])), null, 2)}</textarea>
              </label>
              <p class="font-mono text-[0.5rem] tracking-[0.16em] uppercase text-ink-soft/50">
                idempotent: contract rejects with ALREADY_REGISTERED if tokens were registered already
              </p>
              <button
                type="submit"
                class="inline-flex items-center justify-center px-4 py-2 rounded-md bg-warm text-paper font-mono text-[0.6rem] tracking-[0.14em] uppercase hover:bg-ink transition-colors cursor-pointer disabled:opacity-60 disabled:cursor-wait"
              >
                <span class="btn-label">Sign + send</span>
              </button>
              <p class="action-status font-mono text-[0.55rem] tracking-[0.14em] uppercase text-ink-soft/70 min-h-[0.9rem]" role="status" aria-live="polite"></p>
            </form>
          </details>
        )}

        <!-- set_metadata_base_uri — only for contracts that use this entrypoint pattern -->
        {entry.metadata_base_uri && (
          <details class="mb-2 p-3 rounded-md border border-rule/30 bg-card/40">
            <summary class="font-mono text-[0.62rem] tracking-[0.18em] uppercase text-ink cursor-pointer">
              set_metadata_base_uri <span class="text-ink-soft ml-1">— update token metadata host</span>
            </summary>
            <form
              class="admin-action-form mt-3 space-y-2"
              data-entrypoint="set_metadata_base_uri"
              data-arg-type="string"
              data-kt1={liveKt1}
              data-slug={slug}
            >
              <label class="block">
                <span class="font-mono text-[0.54rem] tracking-[0.18em] uppercase text-ink-soft/70 block mb-1">
                  new base URI
                </span>
                <input
                  type="text"
                  name="value"
                  value={entry.metadata_base_uri}
                  class="w-full font-mono text-[0.78rem] p-2 rounded border border-rule/40 bg-paper text-ink focus:border-warm focus:outline-none"
                />
              </label>
              <p class="font-mono text-[0.5rem] tracking-[0.16em] uppercase text-ink-soft/50">
                migrate to ipfs:// or rotate gateway without re-originating
              </p>
              <button
                type="submit"
                class="inline-flex items-center justify-center px-4 py-2 rounded-md bg-ink text-paper font-mono text-[0.6rem] tracking-[0.14em] uppercase hover:bg-warm transition-colors cursor-pointer disabled:opacity-60 disabled:cursor-wait"
              >
                <span class="btn-label">Sign + send</span>
              </button>
              <p class="action-status font-mono text-[0.55rem] tracking-[0.14em] uppercase text-ink-soft/70 min-h-[0.9rem]" role="status" aria-live="polite"></p>
            </form>
          </details>
        )}

        <!-- set_administrator — universal -->
        <details id="transfer-admin" class="mb-2 p-3 rounded-md border border-rose-500/30 bg-rose-500/5">
          <summary class="font-mono text-[0.62rem] tracking-[0.18em] uppercase text-ink cursor-pointer">
            set_administrator <span class="text-rose-700 ml-1">— transfer admin</span>
          </summary>
          <form
            class="admin-action-form mt-3 space-y-2"
            data-entrypoint="set_administrator"
            data-arg-type="address"
            data-kt1={liveKt1}
            data-slug={slug}
          >
            <label class="block">
              <span class="font-mono text-[0.54rem] tracking-[0.18em] uppercase text-ink-soft/70 block mb-1">
                new admin address
              </span>
              <input
                type="text"
                name="value"
                placeholder="tz2FjJhB1gb9Xc2qNB7QgFkdBZkGCCRMxdFw (your connected wallet by default)"
                class="w-full font-mono text-[0.78rem] p-2 rounded border border-rule/40 bg-paper text-ink focus:border-warm focus:outline-none"
              />
            </label>
            <p class="font-mono text-[0.5rem] tracking-[0.16em] uppercase text-ink-soft/50">
              leave blank to use your connected wallet · double-check before signing — this is irreversible
            </p>
            <button
              type="submit"
              class="inline-flex items-center justify-center px-4 py-2 rounded-md bg-rose-600 text-paper font-mono text-[0.6rem] tracking-[0.14em] uppercase hover:bg-rose-700 transition-colors cursor-pointer disabled:opacity-60 disabled:cursor-wait"
            >
              <span class="btn-label">Sign + send</span>
            </button>
            <p class="action-status font-mono text-[0.55rem] tracking-[0.14em] uppercase text-ink-soft/70 min-h-[0.9rem]" role="status" aria-live="polite"></p>
          </form>
        </details>
      </section>
    )}

    <!-- Docs panel -->
    {(brief || runbook || contractFile) && (
      <section class="mb-6">
        <h2 class="font-mono text-[0.6rem] tracking-[0.2em] uppercase text-ink mb-3 border-b border-rule/40 pb-1.5">
          docs
        </h2>
        <ul class="space-y-1 text-[0.9rem]">
          {contractFile && (
            <li>
              <a
                href={`https://github.com/mhoydich/pointcast/blob/main/${contractFile}`}
                target="_blank" rel="noopener"
                class="text-warm hover:text-ink transition-colors"
              >
                <span class="font-mono text-[0.7rem] text-ink-soft mr-2">source</span>
                {contractFile} &nearr;
              </a>
            </li>
          )}
          {runbook && (
            <li>
              <a
                href={`https://github.com/mhoydich/pointcast/blob/main/${runbook}`}
                target="_blank" rel="noopener"
                class="text-warm hover:text-ink transition-colors"
              >
                <span class="font-mono text-[0.7rem] text-ink-soft mr-2">runbook</span>
                {runbook} &nearr;
              </a>
            </li>
          )}
          {brief && (
            <li>
              <a
                href={`https://github.com/mhoydich/pointcast/blob/main/${brief}`}
                target="_blank" rel="noopener"
                class="text-warm hover:text-ink transition-colors"
              >
                <span class="font-mono text-[0.7rem] text-ink-soft mr-2">brief</span>
                {brief} &nearr;
              </a>
            </li>
          )}
        </ul>
      </section>
    )}

    <!-- Origination notes -->
    {(mainnetNotes || shadownetNotes) && (
      <section class="mb-6">
