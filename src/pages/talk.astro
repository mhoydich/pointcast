---
/**
 * /talk — Voice Dispatch capture route.
 *
 * Scaffold per RFC 0001 (docs/rfc/0001-voice-dispatch.md). This is Phase 1:
 * route claimed, JSON-LD in place, copy explains what will live here, link
 * to the RFC for anyone curious. The actual MediaRecorder capture UI lands
 * in Phase 2 once Mike signs off on the RFC.
 *
 * Intentionally minimal: the goal of Phase 1 is that `/talk` returns 200
 * with a legible "this is where voice dispatches get recorded" page, not
 * that it works.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const title = 'Talk — Voice Dispatch';
const description = 'Voice Dispatch is the audio layer of PointCast Gamgee. Record a 10–60 second voice block, place-anchored, finite. Landing Phase 2.';
const canonical = 'https://pointcast.xyz/talk';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': canonical,
  name: title,
  description,
  url: canonical,
  inLanguage: 'en-US',
  about: ['voice dispatch', 'audio', 'broadcast', 'talk', 'pointcast'],
  potentialAction: {
    '@type': 'CreateAction',
    '@id': `${canonical}#record`,
    name: 'Record a voice dispatch',
    description: '10–60 seconds, place-anchored, public.',
  },
};
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="talk">
    <nav class="talk__crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>talk</span>
    </nav>

    <header class="talk__hero">
      <p class="talk__kicker mono">VOICE DISPATCH · PHASE 1 SCAFFOLD · 2026-04-23</p>
      <h1 class="talk__title">This is where voice dispatches get recorded.</h1>
      <p class="talk__dek">
        10–60 seconds. Tap to record, tap to stop. Pick a channel, add a
        title, drop it on air. Voice Dispatch is the first layer of the
        Gamgee audio system — the reason broadcast is going to be an audio
        verb, not a metaphor.
      </p>
    </header>

    <section class="talk__scaffold" aria-label="Scaffold state">
      <div class="talk__recorder">
        <div class="talk__mic" aria-hidden="true">🎙️</div>
        <p class="talk__status mono">RECORDER OFFLINE · PHASE 2 LANDS THIS WEEK</p>
        <p class="talk__lede">
          The <code class="mono">MediaRecorder</code> client, the
          <code class="mono">/api/talk</code> endpoint, and the
          Cloudflare R2 audio bucket are all scoped in
          <a href="https://github.com/mhoydich/pointcast/blob/main/docs/rfc/0001-voice-dispatch.md">RFC 0001</a>.
          Once Mike signs off, recording goes live.
        </p>
      </div>
    </section>

    <section class="talk__spec">
      <h2 class="talk__h2">What's in the RFC</h2>
      <ul class="talk__bullets">
        <li>New block type <code class="mono">TALK</code> with an <code class="mono">audio</code> field: url, duration (10–60 s), format, optional transcript</li>
        <li><code class="mono">/talk</code> capture flow — mobile-first, tap-to-record, preview + re-record, channel chip chooser, optional geolocation</li>
        <li><code class="mono">/listen</code> playback — newest-first tuner with play/pause, skip, speed, continuous mode, channel filter, keyboard shortcuts</li>
        <li><code class="mono">POST /api/talk</code> — multipart upload, rate limit 3/hr/IP, server-side duration enforcement, R2 storage</li>
        <li>Audio served at <code class="mono">/audio/{'{id}'}.{'{ext}'}</code> with immutable cache headers</li>
        <li>Public by default. Anon OK with rate limit. Wallet binding optional.</li>
      </ul>
      <p class="talk__p">
        Read the full spec:
        <a href="https://github.com/mhoydich/pointcast/blob/main/docs/rfc/0001-voice-dispatch.md">docs/rfc/0001-voice-dispatch.md →</a>
      </p>
    </section>

    <section class="talk__related">
      <h2 class="talk__h2">Where it fits</h2>
      <ul class="talk__links">
        <li><a href="/gamgee"><code class="mono">/gamgee</code></a> — the release this is part of</li>
        <li><a href="/listen"><code class="mono">/listen</code></a> — the playback side (also scaffold)</li>
        <li><a href="/manifesto"><code class="mono">/manifesto</code></a> — what PointCast is</li>
        <li><a href="/for-agents"><code class="mono">/for-agents</code></a> — how agents read the broadcast</li>
      </ul>
    </section>

    <footer class="talk__foot mono">
      <span>PHASE 1 · SCAFFOLD · 2026-04-23 · EL SEGUNDO</span>
    </footer>
  </main>
</BlockLayout>

<style>
  .talk {
    max-width: 760px;
    margin: 0 auto;
    padding: 24px 20px 72px;
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    color: #121116;
  }
  .mono { font-family: 'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, monospace; }

  .talk__crumb {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #5f5e5a;
    margin-bottom: 22px;
  }
  .talk__crumb a { color: inherit; text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 1px; }
  .talk__crumb span { margin: 0 6px; }

  .talk__hero { padding-bottom: 24px; border-bottom: 2px solid #1a1a22; margin-bottom: 28px; }
  .talk__kicker {
    font-size: 10.5px;
    letter-spacing: 0.24em;
    font-weight: 700;
    color: #8a2432;
    margin: 0 0 10px;
  }
  .talk__title {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: clamp(28px, 4.5vw, 40px);
    line-height: 1.12;
    letter-spacing: -0.01em;
    margin: 0 0 14px;
    font-weight: 400;
  }
  .talk__dek {
    font-family: Georgia, serif;
    font-size: 16px;
    line-height: 1.55;
    margin: 0;
    max-width: 60ch;
    color: #38373a;
  }

  .talk__scaffold {
    margin: 0 0 32px;
    padding: 28px 20px 24px;
    background: linear-gradient(180deg, #fffdfa 0%, #f9f6ee 100%);
    border: 1px solid #e5e3de;
    border-top: 4px solid #8a2432;
    border-radius: 3px;
    text-align: center;
  }
  .talk__mic {
    font-size: 64px;
    line-height: 1;
    margin-bottom: 10px;
    filter: grayscale(1) opacity(0.55);
  }
  .talk__status {
    font-size: 10.5px;
    letter-spacing: 0.22em;
    font-weight: 700;
    color: #8a2432;
    margin: 0 0 14px;
  }
  .talk__lede {
    font-family: Georgia, serif;
    font-size: 14.5px;
    line-height: 1.55;
    max-width: 52ch;
    margin: 0 auto;
    color: #38373a;
  }
  .talk__lede code { font-size: 12px; background: rgba(18,17,22,0.07); padding: 1px 5px; border-radius: 2px; }
  .talk__lede a { color: #8a2432; }

  .talk__h2 {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: 22px;
    font-weight: 400;
    margin: 0 0 14px;
  }
  .talk__bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .talk__bullets li {
    font-family: Georgia, serif;
    font-size: 14px;
    line-height: 1.5;
    padding-left: 14px;
    position: relative;
    color: #1a1a22;
  }
  .talk__bullets li::before {
    content: "·";
    position: absolute;
    left: 4px;
    color: #8a2432;
    font-weight: 700;
  }
  .talk__bullets code { font-size: 12.5px; background: rgba(18,17,22,0.07); padding: 1px 5px; border-radius: 2px; }

  .talk__spec, .talk__related { margin: 0 0 32px; padding-bottom: 24px; border-bottom: 1px solid #e5e3de; }

  .talk__p { font-family: Georgia, serif; font-size: 14px; margin: 0; color: #38373a; }
  .talk__p a { color: #8a2432; }

  .talk__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
    font-family: Georgia, serif;
    font-size: 14px;
  }
  .talk__links a { color: #8a2432; text-decoration: none; border-bottom: 1px solid transparent; }
  .talk__links a:hover { border-bottom-color: #8a2432; }
  .talk__links code { font-size: 12.5px; background: rgba(18,17,22,0.06); padding: 1px 5px; border-radius: 2px; }

  .talk__foot {
    font-size: 10.5px;
    letter-spacing: 0.2em;
    color: #5f5e5a;
  }
</style>
