---
import BaseLayout from '../layouts/BaseLayout.astro';

const links = [
  {
    category: 'Create',
    items: [
      {
        title: 'Are.na',
        url: 'https://www.are.na/mike-hoydich',
        description: 'Visual research, mood boards, and collected references. The thinking before the thinking.',
        tag: 'collect',
      },
      {
        title: 'Midjourney',
        url: 'https://www.midjourney.com',
        description: 'AI image generation. Where the art direction happens before the pixels.',
        tag: 'generate',
      },
    ],
  },
  {
    category: 'Build',
    items: [
      {
        title: 'GitHub',
        url: 'https://github.com/mhoydich',
        description: 'Code, repos, and open-source work. Everything ships from here.',
        tag: 'code',
      },
      {
        title: 'Claude',
        url: 'https://claude.ai',
        description: 'The other half of Cowork. Where the collaboration lives.',
        tag: 'ai',
      },
    ],
  },
  {
    category: 'Culture',
    items: [
      {
        title: 'Nouns DAO',
        url: 'https://nouns.wtf',
        description: 'One Noun auctioned every day, forever. CC0. The ethos behind everything here.',
        tag: 'dao',
      },
      {
        title: 'Good Feels',
        url: 'https://goodfeels.com',
        description: 'Cannabis company. Mike is COO. Where taste meets the real world.',
        tag: 'work',
      },
    ],
  },
];
---

<BaseLayout title="Links" description="Tools, communities, and corners of the internet that inform PointCast.">
  <div class="max-w-[34rem] mx-auto px-4 py-12 md:py-16">
    <header class="mb-10">
      <div class="kicker">Directory</div>
      <h1 class="font-serif text-[1.65rem] text-ink font-medium italic mb-3 leading-[1.15]">
        Links
      </h1>
      <p class="text-[0.95rem] text-ink-soft leading-relaxed max-w-md">
        Tools, communities, and corners of the internet that inform the work.
      </p>
    </header>

    <div class="space-y-0">
      {links.map((group, gi) => (
        <section class="card-obs" aria-label={group.category}>
          <h2 class="font-serif text-lg text-ink font-semibold mb-4">
            <span class="card-obs-num">{String(gi + 1).padStart(2, '0')}</span>{group.category}
          </h2>

          <div class="space-y-3">
            {group.items.map(link => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener"
                class="tldr-link group"
              >
                <span class="tldr-num">{link.tag}</span>
                <span>
                  <span class="tldr-title group-hover:text-warm transition-colors">{link.title}</span>
                  <span class="tldr-sub"> — {link.description}</span>
                </span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <p class="editorial-close mt-10">
      The tools change. The taste doesn't.
    </p>
  </div>
</BaseLayout>
