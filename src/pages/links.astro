---
import BaseLayout from '../layouts/BaseLayout.astro';

const links = [
  {
    category: 'Work',
    items: [
      {
        title: 'Good Feels',
        url: 'https://shop.getgoodfeels.com',
        description: 'Cannabis company. Mike is COO. Premium THC drinks and edibles — taste-first, always.',
        tag: 'shop',
      },
      {
        title: 'GitHub',
        url: 'https://github.com/mhoydich',
        description: 'Code, repos, and open-source work. Everything ships from here.',
        tag: 'code',
      },
    ],
  },
  {
    category: 'Create',
    items: [
      {
        title: 'Are.na',
        url: 'https://www.are.na/mike-hoydich',
        description: 'Visual research, mood boards, and collected references. The thinking before the thinking.',
        tag: 'collect',
      },
      {
        title: 'Midjourney',
        url: 'https://www.midjourney.com',
        description: 'AI image generation. Where the art direction happens before the pixels.',
        tag: 'generate',
      },
      {
        title: 'Claude',
        url: 'https://claude.ai',
        description: 'The other half of Cowork. Where the collaboration lives.',
        tag: 'ai',
      },
    ],
  },
  {
    category: 'Reference',
    items: [
      {
        title: 'Nouns',
        url: 'https://github.com/nounsDAO',
        description: 'On-chain generative art. CC0 pixel art, open-source contracts, public-domain culture.',
        tag: 'cc0',
      },
    ],
  },
];
---

<BaseLayout title="Links" description="Tools, shops, and corners of the internet that inform PointCast.">
  <div class="max-w-[34rem] mx-auto px-4 py-12 md:py-16">
    <header class="mb-10">
      <div class="kicker">Directory</div>
      <h1 class="font-serif text-[1.65rem] text-ink font-medium italic mb-3 leading-[1.15]">
        Links
      </h1>
      <p class="text-[0.95rem] text-ink-soft leading-relaxed max-w-md">
        Tools, shops, and corners of the internet that inform the work.
      </p>
    </header>

    <!-- Overview -->
    <section class="card-obs" aria-label="Overview">
      <h2 class="font-serif text-lg text-ink font-semibold mb-3">
        <span class="card-obs-num">00</span>Overview
      </h2>
      <div class="text-[0.95rem] text-ink/80 leading-relaxed space-y-3">
        <p>
          PointCast is published by Mike Hoydich — COO at
          <a href="https://shop.getgoodfeels.com" target="_blank" rel="noopener" class="text-accent underline underline-offset-2 decoration-accent/30 hover:decoration-accent transition-colors">Good Feels</a>,
          builder, and creative technologist based in El Segundo, California.
        </p>
        <p>
          Everything here is made with Claude. The tools below are the rest of the stack — where ideas start, where they get shaped, and where they ship.
        </p>
      </div>
    </section>

    {links.map((group, gi) => (
      <section class="card-obs" aria-label={group.category}>
        <h2 class="font-serif text-lg text-ink font-semibold mb-4">
          <span class="card-obs-num">{String(gi + 1).padStart(2, '0')}</span>{group.category}
        </h2>

        <div class="space-y-3">
          {group.items.map(link => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener"
              class="tldr-link group"
            >
              <span class="tldr-num">{link.tag}</span>
              <span>
                <span class="tldr-title group-hover:text-warm transition-colors">{link.title}</span>
                <span class="tldr-sub"> — {link.description}</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    ))}

    <p class="editorial-close mt-10">
      The tools change. The taste doesn't.
    </p>
  </div>
</BaseLayout>
