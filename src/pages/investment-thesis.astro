---
/**
 * /investment-thesis - investor memo for Nouns Nation Builder, agents,
 * Nouns Builder infrastructure, and AI-operated cultural software.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import {
  INVESTMENT_THESIS,
  INVESTMENT_THESIS_VERSION,
  capitalPlan,
  diligencePlan,
  githubSignals,
  returnPaths,
  risks,
  thesisPillars,
  thesisSources,
  whyNow,
} from '../lib/investment-thesis';
import {
  NOUNS_NATION_ROADMAP,
  threeYearRoadmap,
} from '../lib/nouns-nation-roadmap';

const title = 'Nouns Nation Builder investment thesis V2';
const description = INVESTMENT_THESIS.summary;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': 'https://pointcast.xyz/investment-thesis#article',
  headline: 'Nouns Nation Builder investment thesis V2',
  description,
  datePublished: '2026-04-29',
  dateModified: '2026-04-29',
  url: 'https://pointcast.xyz/investment-thesis',
  inLanguage: 'en-US',
  author: { '@id': 'https://pointcast.xyz/#person' },
  publisher: { '@id': 'https://pointcast.xyz/#org' },
  image: 'https://pointcast.xyz/images/og/battle.png',
  about: [
    'Nouns DAO',
    'Nouns Builder',
    'agent-native media',
    'Model Context Protocol',
    'Nouns Nation Battler',
    'AI agents',
  ],
  mainEntityOfPage: 'https://pointcast.xyz/investment-thesis',
};
---

<BlockLayout
  title={title}
  description={description}
  image="/images/og/battle.png"
  jsonLd={jsonLd}
  alternates={[
    { type: 'application/json', href: '/investment-thesis.json', title: 'Nouns Nation Builder investment thesis JSON' },
    { type: 'application/json', href: '/nouns-nation/roadmap.json', title: 'Nouns Nation Builder Roadmap V2 JSON' },
    { type: 'application/vnd.openxmlformats-officedocument.presentationml.presentation', href: '/decks/nouns-nation-builder-roadmap-v2.pptx', title: 'Nouns Nation Builder Roadmap V2 deck' },
    { type: 'application/json', href: '/nouns-nation-battler-agents.json', title: 'Nouns Nation Battler Agent Bench JSON' },
  ]}
  frame={{
    image: 'https://pointcast.xyz/images/og/battle.png',
    buttons: [
      { label: 'Read thesis', action: 'link', target: 'https://pointcast.xyz/investment-thesis' },
      { label: 'Roadmap V2', action: 'link', target: NOUNS_NATION_ROADMAP.url },
      { label: 'Pitch deck', action: 'link', target: NOUNS_NATION_ROADMAP.deck },
      { label: 'Thesis JSON', action: 'link', target: 'https://pointcast.xyz/investment-thesis.json' },
      { label: 'Nation Hub', action: 'link', target: 'https://pointcast.xyz/nouns-nation/' },
    ],
  }}
>
  <main class="thesis">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/nouns-nation/">Nouns Nation</a>
      <span aria-hidden="true">/</span>
      <span>Investment thesis</span>
    </nav>

    <section class="hero" aria-labelledby="thesis-title">
      <div class="hero__copy">
        <p class="kicker">Investor memo / {INVESTMENT_THESIS_VERSION}</p>
        <h1 id="thesis-title">Nouns Nation Builder V2.</h1>
        <p class="dek">{INVESTMENT_THESIS.summary}</p>
        <dl class="hero__stats" aria-label="Investment summary">
          <div><dt>{INVESTMENT_THESIS.allocation.firstCheck.split(' ')[0]}</dt><dd>first check floor</dd></div>
          <div><dt>$250k</dt><dd>first tranche ceiling</dd></div>
          <div><dt>90</dt><dd>day proof window</dd></div>
        </dl>
        <div class="actions" aria-label="Thesis actions">
          <a href="/nouns-nation/roadmap">3-year roadmap</a>
          <a href={NOUNS_NATION_ROADMAP.deck}>Pitch deck</a>
          <a href="#capital">Capital plan</a>
          <a href="/nouns-nation/">Nation hub</a>
          <a href="/investment-thesis.json">JSON mirror</a>
        </div>
      </div>
      <aside class="hero__asset" aria-label="Nouns visual and investor terminal">
        <figure class="noun-card">
          <img src="https://noun.pics/421.svg" alt="Noun 421 from the Nouns CC0 artwork set" width="420" height="420" loading="eager" />
          <figcaption>Actual Nouns CC0 art as the cultural primitive.</figcaption>
        </figure>
        <div class="terminal" aria-label="Investment terminal">
          <span>asset: nouns nation builder</span>
          <span>edge: cc0 culture + agent labor</span>
          <span>surface: tv, venues, json, mcp</span>
          <span>risk: governance + retention + legal</span>
          <strong>decision: fund in tranches</strong>
        </div>
      </aside>
    </section>

    <section class="ticker" aria-label="Investment wire">
      <span>Nouns Builder makes nounish DAOs easier to deploy.</span>
      <span>Agents need readable venues, manifests, tasks, and tools.</span>
      <span>PointCast GitHub now shows Battle Desk V3, Nouns Nation, co-presence, press catalog, and V2 roadmap receipts.</span>
      <span>Invest in the operating system, not only a one-off game.</span>
    </section>

    <section class="section" id="memo" aria-labelledby="memo-title">
      <p class="eyebrow">Memo</p>
      <h2 id="memo-title">The one-screen thesis.</h2>
      <div class="pillar-grid">
        {thesisPillars.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="why-now" aria-labelledby="why-now-title">
      <p class="eyebrow">Why Now</p>
      <h2 id="why-now-title">The timing is suddenly less theoretical.</h2>
      <div class="why-grid">
        {whyNow.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="roadmap" aria-labelledby="roadmap-title">
      <p class="eyebrow">Roadmap V2</p>
      <h2 id="roadmap-title">The upside is a venue ladder, not a token first.</h2>
      <p class="section-lede">
        The attached roadmap runs from browser room to living-room TV, then to
        partner venues, and finally to a ticketed live final format. It follows
        the progress of agent building tools: agents lower the operating cost
        of scorekeeping, highlights, recaps, QA, sponsor inventory, and
        machine-readable distribution.
      </p>
      <div class="roadmap-grid">
        {threeYearRoadmap.map((year) => (
          <article>
            <span>{year.calendar}</span>
            <h3>{year.title}</h3>
            <p>{year.headline}</p>
            <a href="/nouns-nation/roadmap">Open roadmap</a>
          </article>
        ))}
      </div>
    </section>

    <section class="section split" id="capital" aria-labelledby="capital-title">
      <div>
        <p class="eyebrow">Capital</p>
        <h2 id="capital-title">Fund the venue, prove the ritual, delay the token.</h2>
        <p>
          I would not start by selling a DAO token or promising collectible upside.
          I would fund product velocity, distribution, and agent task quality first,
          while stacking credits, sponsors, and ecosystem grants around the work.
        </p>
      </div>
      <div class="stack-list">
        {capitalPlan.map((item) => (
          <article>
            <span>{item.label}</span>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" aria-labelledby="returns-title">
      <p class="eyebrow">Return Paths</p>
      <h2 id="returns-title">Three ways the capital can come back.</h2>
      <div class="return-grid">
        {returnPaths.map((item) => (
          <article>
            <span>{item.label}</span>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="github" aria-labelledby="github-title">
      <p class="eyebrow">GitHub Read</p>
      <h2 id="github-title">Latest signals checked before publishing.</h2>
      <div class="github-grid">
        {githubSignals.map((item) => (
          <article>
            <span>{item.label}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <a href={item.url}>Open source</a>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="risks" aria-labelledby="risks-title">
      <p class="eyebrow">Risk Register</p>
      <h2 id="risks-title">The investment case fails if these stay unresolved.</h2>
      <div class="risk-list">
        {risks.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="diligence" aria-labelledby="diligence-title">
      <p class="eyebrow">Diligence</p>
      <h2 id="diligence-title">A 90-day proof plan.</h2>
      <div class="diligence-grid">
        {diligencePlan.map((item) => (
          <article>
            <span>{item.window}</span>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section sources" id="sources" aria-labelledby="sources-title">
      <p class="eyebrow">Sources</p>
      <h2 id="sources-title">Checked sources.</h2>
      <div class="source-grid">
        {thesisSources.map((source) => (
          <a href={source.url}>
            <strong>{source.label}</strong>
            <span>{source.note}</span>
          </a>
        ))}
      </div>
      <p class="disclaimer">
        This is a strategic investment memo, not personalized financial advice,
        a public securities offering, or legal advice. Any token, DAO,
        revenue-share, or collectible structure needs counsel before launch.
      </p>
    </section>
  </main>
</BlockLayout>

<style>
  .thesis {
    max-width: 1180px;
    margin: 0 auto;
    padding: 22px 18px 96px;
    color: var(--pc-ink, #12110e);
  }

  .crumb,
  .actions,
  .ticker,
  .source-grid a {
    display: flex;
    align-items: center;
  }

  .crumb {
    gap: 8px;
    margin-bottom: 18px;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
    gap: 22px;
    align-items: stretch;
    padding: 24px;
    border: 2px solid currentColor;
    background: #fbf6e8;
    box-shadow: 10px 10px 0 #15130f;
  }

  .kicker,
  .eyebrow {
    margin: 0 0 10px;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 760px;
    margin-bottom: 14px;
    font-size: clamp(3rem, 9vw, 7.5rem);
    line-height: 0.86;
    letter-spacing: 0;
  }

  h2 {
    margin-bottom: 12px;
    font-size: clamp(2rem, 4.6vw, 4.2rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  h3 {
    margin-bottom: 8px;
    font-size: 1.2rem;
    line-height: 1.05;
  }

  .dek {
    max-width: 760px;
    font-size: 1.15rem;
    line-height: 1.55;
  }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin: 22px 0;
  }

  .hero__stats div,
  .pillar-grid article,
  .why-grid article,
  .roadmap-grid article,
  .stack-list article,
  .return-grid article,
  .github-grid article,
  .risk-list article,
  .diligence-grid article {
    min-width: 0;
    padding: 14px;
    border: 1.5px solid currentColor;
    background: #fffdf6;
  }

  .hero__stats dt {
    margin: 0;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 1.8rem;
    font-weight: 500;
  }

  .hero__stats dd {
    margin: 4px 0 0;
    color: var(--pc-ink-muted, #5f5e5a);
  }

  .actions {
    gap: 8px;
    flex-wrap: wrap;
  }

  .actions a,
  .github-grid a {
    padding: 9px 11px;
    border: 1.5px solid currentColor;
    background: #15130f;
    color: #fff8df;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 0.82rem;
    text-decoration: none;
  }

  .hero__asset {
    display: grid;
    align-content: center;
    gap: 12px;
    padding: 14px;
    background:
      repeating-linear-gradient(0deg, rgba(168,255,58,0.08) 0 1px, transparent 1px 4px),
      #050310;
    color: #fff8df;
    border: 1.5px solid currentColor;
  }

  .noun-card {
    display: grid;
    justify-items: center;
    gap: 8px;
    margin: 0;
    padding: 12px;
    border: 1.5px solid #a8ff3a;
    background: rgba(255,255,255,0.06);
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    text-align: center;
  }

  .noun-card img {
    width: min(220px, 100%);
    height: auto;
    image-rendering: pixelated;
    background: #f8f4d8;
    border: 2px solid #a8ff3a;
  }

  .noun-card figcaption {
    margin: 0;
    color: #d9fff0;
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .terminal {
    display: grid;
    gap: 6px;
    padding: 12px;
    border: 1.5px solid #a8ff3a;
    background: #020403;
    color: #a8ff3a;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
  }

  .terminal span,
  .terminal strong {
    display: block;
    padding: 6px 8px;
    background: rgba(168,255,58,0.08);
    font-weight: 400;
  }

  .terminal strong {
    color: #050310;
    background: #a8ff3a;
    font-weight: 500;
  }

  .ticker {
    gap: 10px;
    flex-wrap: wrap;
    margin: 22px 0;
    padding: 10px;
    border-top: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 0.82rem;
  }

  .ticker span {
    padding: 6px 8px;
    background: #eef7ff;
    border: 1px solid #9cb4d8;
  }

  .section {
    margin: 0 0 22px;
    padding: 22px 0 0;
    border-top: 2px solid currentColor;
  }

  .pillar-grid,
  .why-grid,
  .roadmap-grid,
  .return-grid,
  .github-grid,
  .risk-list,
  .diligence-grid,
  .source-grid {
    display: grid;
    gap: 12px;
  }

  .pillar-grid,
  .roadmap-grid,
  .diligence-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .why-grid,
  .github-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .return-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .risk-list {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 18px;
    align-items: start;
  }

  .stack-list {
    display: grid;
    gap: 10px;
  }

  .stack-list span,
  .roadmap-grid span,
  .return-grid span,
  .github-grid span,
  .diligence-grid span {
    display: inline-block;
    width: fit-content;
    margin-bottom: 8px;
    padding: 3px 7px;
    background: #d7ff3f;
    border: 1.5px solid currentColor;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  .github-grid span {
    background: #ffcd4d;
  }

  .roadmap-grid a {
    display: inline-flex;
    width: fit-content;
    margin-top: 4px;
    color: #12110e;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 0.82rem;
  }

  .section p,
  .section-lede,
  .pillar-grid p,
  .why-grid p,
  .roadmap-grid p,
  .stack-list p,
  .return-grid p,
  .github-grid p,
  .risk-list p,
  .diligence-grid p {
    color: var(--pc-ink-muted, #5f5e5a);
    line-height: 1.5;
  }

  .source-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .source-grid a {
    min-width: 0;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    padding: 12px;
    border: 1.5px solid currentColor;
    color: inherit;
    background: #fffdf6;
    text-decoration: none;
  }

  .source-grid span {
    color: var(--pc-ink-muted, #5f5e5a);
    text-align: right;
    line-height: 1.35;
  }

  .disclaimer {
    margin: 14px 0 0;
    padding: 12px;
    background: #15130f;
    color: #fff8df;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  @media (max-width: 980px) {
    .hero,
    .split {
      grid-template-columns: 1fr;
    }

    .why-grid,
    .github-grid,
    .risk-list,
    .source-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .thesis {
      padding-inline: 12px;
    }

    .hero {
      padding: 16px;
      box-shadow: 6px 6px 0 #15130f;
    }

    .hero__stats,
    .pillar-grid,
    .why-grid,
    .roadmap-grid,
    .return-grid,
    .github-grid,
    .risk-list,
    .diligence-grid,
    .source-grid {
      grid-template-columns: 1fr;
    }

    .source-grid a {
      display: grid;
    }

    .source-grid span {
      text-align: left;
    }
  }
</style>
