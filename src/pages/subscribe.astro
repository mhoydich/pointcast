---
/**
 * /subscribe — how to follow PointCast.
 *
 * Mike is allergic to email lists. This page is the RSS-and-friends
 * explainer: here are the feeds, here are the apps that read them, here
 * are the social mirrors for the half of the audience that doesn't use
 * feeds. One page, no tracking, no vendor.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import { CHANNEL_LIST } from '../lib/channels';

const feeds = [
  {
    format: 'RSS 2.0',
    label: 'Every block · RSS',
    url: '/feed.xml',
    note: 'Universal. Works in every RSS reader. Reader picks a title line + published time + description.',
  },
  {
    format: 'JSON Feed 1.1',
    label: 'Every block · JSON Feed',
    url: '/feed.json',
    note: 'Modern. Preferred by NetNewsWire, Reeder, Unread, Feedbin. Each item carries an image (per-block OG card) + PointCast extension with channel/type.',
  },
  {
    format: 'JSON',
    label: 'Every block · raw JSON',
    url: '/blocks.json',
    note: "PointCast's native shape. Full archive, paginable later. Agent-friendly.",
  },
  {
    format: 'Atom / RSS',
    label: 'Per channel',
    url: '/c/{slug}.rss',
    note: 'One feed per channel. Subscribe to just /c/front-door.rss or /c/spinning.rss. Swap .rss for .json for JSON Feed.',
  },
];

const readers = [
  { name: 'NetNewsWire',   url: 'https://netnewswire.com',  note: 'Free, open-source, macOS + iOS. The recommended default.' },
  { name: 'Reeder',        url: 'https://reederapp.com',    note: 'Paid, macOS/iOS. Polished if you like fine typography.' },
  { name: 'Feedbin',       url: 'https://feedbin.com',      note: 'Paid, web + sync. Good if you read across devices.' },
  { name: 'Feedly',        url: 'https://feedly.com',       note: 'Free tier, web + apps. Mainstream pick.' },
  { name: 'Inoreader',     url: 'https://www.inoreader.com', note: 'Free tier, power-user features.' },
];

const socials = [
  { name: 'Farcaster',   url: 'https://warpcast.com/mhoydich',     handle: '@mhoydich', note: 'Primary social — casts about new blocks + ops.' },
  { name: 'X',           url: 'https://x.com/mhoydich',            handle: '@mhoydich', note: 'Mirror of the Farcaster cadence.' },
  { name: 'GitHub',      url: 'https://github.com/mhoydich/pointcast', handle: 'MikeHoydich/pointcast', note: 'The whole site. Star = bookmark.' },
  { name: 'objkt.com',   url: 'https://objkt.com/collection/KT1LP1oTBuudRubAYQDErH7i7mSwazVdohxh', handle: 'Visit Nouns FA2', note: 'The NFT collection. Every mainnet mint appears here.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://pointcast.xyz/subscribe',
  name: 'PointCast · subscribe',
  description: 'Follow PointCast: RSS, JSON Feed, Farcaster, X, GitHub. No email lists. No cookies.',
  url: 'https://pointcast.xyz/subscribe',
};
---

<BlockLayout
  title="Subscribe"
  description="Follow PointCast: RSS, JSON Feed, Farcaster, X, GitHub. No email lists, no tracking, no vendor lock-in."
  image="/images/og/subscribe.png"
  jsonLd={jsonLd}
  alternates={[
    { type: 'application/rss+xml',  href: '/feed.xml',  title: 'PointCast (RSS · all blocks)' },
    { type: 'application/feed+json', href: '/feed.json', title: 'PointCast (JSON Feed 1.1)' },
  ]}
>
  <div class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>subscribe</span>
    </nav>

    <header class="hero">
      <p class="kicker">SUBSCRIBE · FEEDS + SOCIALS</p>
      <h1 class="display">Follow, don't sign up.</h1>
      <p class="dek">
        PointCast runs no email list. No analytics, no pixel trackers, no
        cookies set by the site. To follow: pick an RSS reader, or watch
        Farcaster, X, or GitHub. All mirrors, no vendor.
      </p>
    </header>

    <section class="panel">
      <p class="kicker panel__kicker">FEEDS · 4 FORMATS</p>
      <ul class="rows">
        {feeds.map((f) => (
          <li class="row">
            <div class="row__head">
              <span class="row__tag mono">{f.format}</span>
              <h2 class="row__title">{f.label}</h2>
              <a class="row__url mono" href={f.url === '/c/{slug}.rss' ? '/c/front-door.rss' : f.url} rel="alternate">{f.url}</a>
            </div>
            <p class="row__note">{f.note}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="panel">
      <p class="kicker panel__kicker">PER-CHANNEL · 9 STREAMS</p>
      <p class="panel__dek">Pick just the channels you want.</p>
      <div class="channel-grid">
        {CHANNEL_LIST.map((ch) => (
          <div class="channel" style={`--ch-600: ${ch.color600}; --ch-800: ${ch.color800}; --ch-50: ${ch.color50};`}>
            <div class="channel__head">
              <span class="channel__code mono">CH.{ch.code}</span>
              <span class="channel__name">{ch.name}</span>
            </div>
            <div class="channel__feeds mono">
              <a href={`/c/${ch.slug}.rss`}>RSS</a>
              <span aria-hidden="true">·</span>
              <a href={`/c/${ch.slug}.json`}>JSON</a>
              <span aria-hidden="true">·</span>
              <a href={`/c/${ch.slug}`}>HTML</a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="panel">
      <p class="kicker panel__kicker">READERS · FREE + PAID</p>
      <p class="panel__dek">Pick any of these. Paste <code>/feed.xml</code> or <code>/feed.json</code> when they ask for a URL.</p>
      <ul class="rows rows--tight">
        {readers.map((r) => (
          <li class="row row--tight">
            <div class="row__head">
              <h3 class="row__title row__title--sm"><a href={r.url} target="_blank" rel="noopener">{r.name} ↗</a></h3>
            </div>
            <p class="row__note">{r.note}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="panel">
      <p class="kicker panel__kicker">SOCIALS · MIRRORS</p>
      <p class="panel__dek">New blocks + operational updates. Same content as the feeds, aimed at the audience that prefers social.</p>
      <ul class="rows rows--tight">
        {socials.map((s) => (
          <li class="row row--tight">
            <div class="row__head">
              <h3 class="row__title row__title--sm"><a href={s.url} target="_blank" rel="noopener">{s.name} ↗</a></h3>
              <span class="row__url mono">{s.handle}</span>
            </div>
            <p class="row__note">{s.note}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="panel panel--agents">
      <p class="kicker panel__kicker">FOR AGENTS · MACHINE PROTOCOLS</p>
      <p class="panel__dek">
        If you're an AI agent or crawler, don't scrape. Use these.
      </p>
      <dl class="agent-feeds">
        <div>
          <dt class="mono">DISCOVERY</dt>
          <dd><a href="/agents.json"><code>/agents.json</code></a> — every endpoint + contract + schema in one JSON</dd>
        </div>
        <div>
          <dt class="mono">SUMMARY</dt>
          <dd><a href="/llms.txt"><code>/llms.txt</code></a> (short) · <a href="/llms-full.txt"><code>/llms-full.txt</code></a> (long, with v3 surfaces)</dd>
        </div>
        <div>
          <dt class="mono">CANONICAL</dt>
          <dd><a href="/manifesto"><code>/manifesto</code></a> — FAQPage + DefinedTerm schema (14 Q&A pairs)</dd>
        </div>
        <div>
          <dt class="mono">STRIPPED</dt>
          <dd>Send UA prefixed <code>ai:</code> or match known crawlers — server returns stripped HTML via middleware</dd>
        </div>
        <div>
          <dt class="mono">LIVE STATE</dt>
          <dd><a href="/now.json"><code>/now.json</code></a> — Card of the Day, latest blocks, contract state. Cache 60s.</dd>
        </div>
        <div>
          <dt class="mono">WORK LOG</dt>
          <dd><a href="/sprints.json"><code>/sprints.json</code></a> — every autonomous sprint cc has shipped (cron + chat). Updated each tick.</dd>
        </div>
        <div>
          <dt class="mono">TEAM</dt>
          <dd><a href="/collabs.json"><code>/collabs.json</code></a> — collaborators registry + 3-step federation spec to plug in a compatible site.</dd>
        </div>
        <div>
          <dt class="mono">SHOP</dt>
          <dd><a href="/products.json"><code>/products.json</code></a> — Good Feels product catalog with schema.org Product markup. Checkout always at shop.getgoodfeels.com.</dd>
        </div>
        <div>
          <dt class="mono">CONTROL</dt>
          <dd><a href="/sprint.json"><code>/sprint.json</code></a> — current sprint backlog. POST a pick to <code>/api/queue</code> (KV-backed).</dd>
        </div>
        <div>
          <dt class="mono">INBOX</dt>
          <dd>POST messages to <a href="/api/ping"><code>/api/ping</code></a> · POST URLs to <a href="/api/drop"><code>/api/drop</code></a>. cc reads both at session start.</dd>
        </div>
      </dl>

      <p class="agent-feeds__footer">
        <strong>Three tiers:</strong> RSS / JSON Feed (for humans with readers), Farcaster / X / GitHub (for humans without), <em>everything above</em> (for agents). All endpoints are CORS-open. No auth, no preflight.
      </p>
    </section>

    <aside class="surfaces">
      <p class="kicker">RELATED</p>
      <ul class="surfaces__list">
        <li><a href="/archive"><span class="mono">READ</span> /archive</a></li>
        <li><a href="/now"><span class="mono">LIVE</span> /now</a></li>
        <li><a href="/for-agents"><span class="mono">AGENT</span> /for-agents</a></li>
        <li><a href="/glossary"><span class="mono">TERMS</span> /glossary</a></li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<style>
  .page { max-width: 820px; margin: 0 auto; padding: 18px 16px 80px; }

  .mono {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .kicker {
    font-family: var(--pc-font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin: 0 0 8px;
  }

  .crumb {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin-bottom: 18px;
    display: flex;
    gap: 8px;
  }

  .hero {
    margin-bottom: 22px;
    padding-bottom: 16px;
    border-bottom: 1.5px solid var(--pc-ink);
  }

  .display {
    font-family: var(--pc-font-sans);
    font-size: clamp(2.2rem, 9vw, 4rem);
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }

  .dek {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.5;
    color: var(--pc-ink-soft);
    max-width: 56ch;
  }

  .panel {
    margin-bottom: 26px;
    padding: 16px;
    border: 1px solid var(--pc-rule);
    border-radius: 2px;
    background: #fff;
  }

  .panel--agents {
    background: #fafaf8;
  }

  .panel__kicker {
    color: var(--pc-accent);
  }

  .panel__dek {
    margin: 0 0 12px;
    font-size: 13.5px;
    color: var(--pc-ink-soft);
    line-height: 1.5;
  }

  .panel__dek code {
    font-family: var(--pc-font-mono);
    font-size: 12px;
    padding: 1px 5px;
    background: var(--pc-rule-soft);
    border-radius: 2px;
  }

  .rows {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .row {
    padding: 12px 0;
    border-bottom: 1px dashed var(--pc-rule-soft);
  }

  .row:last-child { border-bottom: 0; }
  .rows--tight .row { padding: 8px 0; }

  .row__head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }

  .row__tag {
    padding: 2px 6px;
    border: 1px solid var(--pc-ink);
    background: var(--pc-ink);
    color: #fff;
    font-size: 9.5px;
    letter-spacing: 0.14em;
    border-radius: 2px;
  }

  .row__title {
    margin: 0;
    font-family: var(--pc-font-sans);
    font-size: 16px;
    font-weight: 500;
    color: var(--pc-ink);
    flex: 1;
    min-width: 0;
  }

  .row__title--sm { font-size: 15px; }

  .row__title a { color: inherit; }
  .row__title a:hover { color: var(--pc-accent); }

  .row__url {
    color: var(--pc-accent);
    font-size: 10.5px;
    word-break: break-all;
  }

  .row__note {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--pc-ink-soft);
  }

  .channel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 6px;
  }

  .channel {
    padding: 8px 12px;
    border: 1px solid var(--ch-600);
    border-radius: 2px;
    background: var(--ch-50);
  }

  .channel__head {
    display: flex;
    gap: 8px;
    align-items: baseline;
    margin-bottom: 2px;
  }

  .channel__code { color: var(--ch-800); }

  .channel__name {
    font-family: var(--pc-font-sans);
    font-size: 13px;
    color: var(--pc-ink);
    font-weight: 500;
  }

  .channel__feeds {
    display: flex;
    gap: 6px;
    color: var(--ch-800);
    font-size: 10px;
  }

  .channel__feeds a {
    color: var(--pc-accent);
  }

  .agent-feeds {
    margin: 0;
    display: grid;
    gap: 8px;
  }

  .agent-feeds__footer {
    margin: 14px 0 0;
    padding: 10px 12px;
    border-top: 1px dashed var(--pc-rule);
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--pc-ink-soft);
  }
  .agent-feeds__footer strong { color: var(--pc-ink); }
  .agent-feeds__footer em { font-style: italic; color: var(--pc-accent); }

  .agent-feeds > div {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 12px;
    align-items: baseline;
  }

  .agent-feeds dt {
    color: var(--pc-ink-muted);
    font-size: 9.5px;
    margin: 0;
  }

  .agent-feeds dd {
    margin: 0;
    font-size: 14px;
    color: var(--pc-ink);
    line-height: 1.5;
  }

  .agent-feeds code {
    font-family: var(--pc-font-mono);
    font-size: 12px;
    padding: 1px 5px;
    background: #fff;
    border-radius: 2px;
  }

  .agent-feeds a {
    color: var(--pc-accent);
  }

  .surfaces {
    margin-top: 28px;
    padding: 14px;
    border: 1px solid var(--pc-rule);
    border-radius: 2px;
    background: #fafaf8;
  }

  .surfaces__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px 14px;
  }

  .surfaces__list a {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--pc-accent);
    padding: 4px 0;
  }

  .surfaces__list .mono {
    color: var(--pc-ink-muted);
    min-width: 48px;
  }

  @media (min-width: 640px) {
    .surfaces__list {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
