---
/**
 * /lantern — a single paper lantern you can leave on.
 *
 * One image. No controls, no audio, no clock, no interaction.
 * The lantern glows steadily; its color slowly shifts through
 * the tide palette swatches over a 24-minute cycle. A small
 * wisp of light drifts upward.
 *
 * Companion to /tide and /sit. Quieter than either. Designed
 * to leave on a screen at the end of the day.
 *
 * Local-only "kept on for" counter persists in localStorage as
 * pc:lantern:minutes — survives reload, never sent anywhere.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const title = '/lantern';
const description =
  'A single paper lantern you can leave on. Color slowly shifts through the tide palette swatches. No controls, no audio. Local-only minutes counter.';
---

<BlockLayout title={title} description={description}>
  <main class="ln" id="ln-main">
    <div class="ln__sky" aria-hidden="true"></div>
    <div class="ln__lantern" aria-hidden="true">
      <div class="ln__glow"></div>
      <div class="ln__paper">
        <div class="ln__pleat ln__pleat--1"></div>
        <div class="ln__pleat ln__pleat--2"></div>
        <div class="ln__pleat ln__pleat--3"></div>
        <div class="ln__pleat ln__pleat--4"></div>
        <div class="ln__pleat ln__pleat--5"></div>
      </div>
      <div class="ln__top"></div>
      <div class="ln__bottom"></div>
      <div class="ln__cord"></div>
    </div>
    <div class="ln__wisp" aria-hidden="true"></div>

    <p class="ln__count mono" id="ln-count">kept on · — minutes</p>
  </main>
</BlockLayout>

<script is:inline>
(function () {
  'use strict';

  /* Palette ring — same swatches as /tide, but only the warm "glow"
     candidates (no STORM, no NIGHTTIDE darks, no KELP greens). The
     lantern wants warm light. */
  var GLOW_COLORS = [
    '#FFB496', // daybreak orb
    '#FFEEC2', // coral orb
    '#F5DEA8', // lagoon orb
    '#FFE9D8', // daybreak foam
    '#FFE0D6', // coral foam
    '#FFD4C2', // daybreak sky
    '#FFC4B0', // coral sky
  ];
  var SKY_COLORS = [
    '#0a0a0e',
    '#0a0c14',
    '#0c0a14',
    '#0e0a0a',
  ];
  var CYCLE_MS = 24 * 60 * 1000; // 24 min for one full glow loop
  var SKY_MS = 6 * 60 * 1000;    // 6 min for sky to nudge

  function lerpHex(a, b, t) {
    var ar = parseInt(a.slice(1, 3), 16), ag = parseInt(a.slice(3, 5), 16), ab = parseInt(a.slice(5, 7), 16);
    var br = parseInt(b.slice(1, 3), 16), bg = parseInt(b.slice(3, 5), 16), bb = parseInt(b.slice(5, 7), 16);
    var r = Math.round(ar + (br - ar) * t);
    var g = Math.round(ag + (bg - ag) * t);
    var bl = Math.round(ab + (bb - ab) * t);
    return '#' + [r, g, bl].map(function (n) { return n.toString(16).padStart(2, '0'); }).join('');
  }
  function pickColor(arr, ms, cycleMs) {
    var n = arr.length;
    var pos = (ms % cycleMs) / cycleMs * n;
    var i = Math.floor(pos);
    var t = pos - i;
    return lerpHex(arr[i % n], arr[(i + 1) % n], t);
  }

  /* Apply current colors */
  var t0 = performance.now();
  var startedAt = Date.now();

  function tick() {
    var now = performance.now();
    var ms = now - t0;
    var glow = pickColor(GLOW_COLORS, ms, CYCLE_MS);
    var sky = pickColor(SKY_COLORS, ms, SKY_MS);
    var main = document.getElementById('ln-main');
    if (main) {
      main.style.setProperty('--glow', glow);
      main.style.setProperty('--sky', sky);
    }
  }
  tick();
  setInterval(tick, 4000);

  /* "kept on for" counter — local only */
  function loadMinutes() {
    try {
      var raw = localStorage.getItem('pc:lantern:minutes');
      var n = raw ? parseInt(raw, 10) : 0;
      return Number.isFinite(n) && n >= 0 ? n : 0;
    } catch (e) { return 0; }
  }
  function saveMinutes(n) {
    try { localStorage.setItem('pc:lantern:minutes', String(n)); } catch (e) {}
  }
  var minutes = loadMinutes();
  var sessionStart = Date.now();

  function renderCount() {
    var sessionMin = Math.floor((Date.now() - sessionStart) / 60000);
    var total = minutes + sessionMin;
    var el = document.getElementById('ln-count');
    if (el) {
      if (total === 0) el.textContent = 'kept on · just lit';
      else if (total === 1) el.textContent = 'kept on · 1 minute';
      else el.textContent = 'kept on · ' + total + ' minutes';
    }
  }
  renderCount();
  // tick the visible counter every 30s; persist every 60s
  setInterval(renderCount, 30000);
  setInterval(function () {
    var sessionMin = Math.floor((Date.now() - sessionStart) / 60000);
    saveMinutes(minutes + sessionMin);
  }, 60000);
  // persist on unload too
  window.addEventListener('beforeunload', function () {
    var sessionMin = Math.floor((Date.now() - sessionStart) / 60000);
    saveMinutes(minutes + sessionMin);
  });
})();
</script>

<style is:global>
  body:has(.ln) { margin: 0; overflow: hidden; background: #04040a; }

  .ln {
    --glow: #FFB496;
    --sky: #0a0a0e;
    position: fixed; inset: 0;
    width: 100vw; height: 100vh; height: 100dvh;
    overflow: hidden;
    background: var(--sky);
    transition: background 4s ease;
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    cursor: none;
  }

  .ln__sky {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 50%, color-mix(in oklab, var(--glow) 8%, transparent), transparent 60%);
    transition: background 4s ease;
  }

  /* Lantern: scaled to viewport, centered */
  .ln__lantern {
    position: absolute;
    top: 44%; left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(180px, 28vmin, 360px);
    aspect-ratio: 1 / 1.18;
    animation: ln-bob 9s ease-in-out infinite;
  }
  @keyframes ln-bob {
    0%, 100% { transform: translate(-50%, -50%) translateY(0); }
    50%      { transform: translate(-50%, -50%) translateY(-1.2%); }
  }

  /* The glow halo behind the paper */
  .ln__glow {
    position: absolute; inset: -40%;
    background: radial-gradient(ellipse at 50% 55%, var(--glow) 0%, color-mix(in oklab, var(--glow) 60%, transparent) 28%, transparent 65%);
    filter: blur(36px);
    opacity: 0.95;
    animation: ln-pulse 6s ease-in-out infinite;
    transition: background 4s ease;
  }
  @keyframes ln-pulse {
    0%, 100% { opacity: 0.85; transform: scale(1); }
    50%      { opacity: 1.00; transform: scale(1.04); }
  }

  /* The paper body of the lantern — vertical pleated panels */
  .ln__paper {
    position: absolute;
    top: 8%; left: 8%; right: 8%; bottom: 12%;
    border-radius: 50% / 38%;
    background:
      radial-gradient(ellipse at 50% 38%, color-mix(in oklab, var(--glow) 88%, #fff 12%) 0%, var(--glow) 50%, color-mix(in oklab, var(--glow) 60%, #200 40%) 100%);
    box-shadow: inset 0 -8% 14% color-mix(in oklab, var(--glow) 50%, #200 50%);
    overflow: hidden;
    transition: background 4s ease;
  }
  .ln__pleat {
    position: absolute; top: 0; bottom: 0; width: 1px;
    background: rgba(0, 0, 0, 0.18);
  }
  .ln__pleat--1 { left: 18%; }
  .ln__pleat--2 { left: 36%; }
  .ln__pleat--3 { left: 50%; opacity: 0.6; }
  .ln__pleat--4 { left: 64%; }
  .ln__pleat--5 { left: 82%; }

  .ln__top {
    position: absolute; top: 0; left: 22%; right: 22%; height: 9%;
    background: #1a1410;
    border-radius: 4px 4px 0 0;
  }
  .ln__bottom {
    position: absolute; bottom: 0; left: 28%; right: 28%; height: 7%;
    background: #1a1410;
    border-radius: 0 0 4px 4px;
  }
  .ln__cord {
    position: absolute;
    top: -32%; left: 50%;
    width: 1.5px; height: 36%;
    background: rgba(255, 255, 255, 0.18);
    transform: translateX(-50%);
  }

  /* A wisp of warm light drifting upward */
  .ln__wisp {
    position: absolute;
    top: 25%; left: 50%;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--glow);
    filter: blur(8px);
    opacity: 0.5;
    transform: translate(-50%, 0);
    animation: ln-wisp 7s ease-out infinite;
    transition: background 4s ease;
  }
  @keyframes ln-wisp {
    0%   { transform: translate(-50%, 0)   scale(0.4); opacity: 0; }
    20%  {                                  opacity: 0.7; }
    100% { transform: translate(-30%, -42vh) scale(1.5); opacity: 0; }
  }

  /* The minutes counter */
  .ln__count {
    position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%);
    color: rgba(255, 230, 200, 0.55);
    font-size: 10.5px; letter-spacing: 0.20em; font-weight: 700;
    text-transform: lowercase;
    user-select: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .ln__lantern, .ln__glow, .ln__wisp { animation: none !important; }
    .ln__wisp { opacity: 0; }
  }

  @media (max-width: 520px) {
    .ln__lantern { top: 42%; width: clamp(140px, 50vmin, 240px); }
    .ln__count { font-size: 9.5px; bottom: 20px; }
  }
</style>
