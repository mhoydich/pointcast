---
/**
 * /beacon — the 25-mile El Segundo growth radius.
 *
 * Mike 2026-04-18: "lets think about adding, the exploration of el
 * segundo wifi, etc 25 mile radius, become a beacon for people
 * looking to grow the area."
 *
 * PointCast is anchored in El Segundo. A 25-mile radius from the
 * intersection of Main + Grand Ave covers most of the South Bay, the
 * Westside, parts of downtown LA, Long Beach, and the airports-adjacent
 * industrial corridor. That's the service area for the beacon:
 * neighborhoods that can be reached, meshed, invited, invested in.
 *
 * This page is the community-growth surface. Neighborhoods to partner
 * with. Infrastructure to extend. A map of what's near and where the
 * mesh could travel.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import { NEIGHBORHOODS_BY_DISTANCE, type Neighborhood } from '../lib/neighborhoods';

// Alias to the existing `NEARBY` name so the rest of the page keeps rendering
// unchanged. Single source of truth now lives in src/lib/neighborhoods.ts,
// which /mesh also imports — add a place once, both pages get it.
type Place = Neighborhood;
const NEARBY: Place[] = NEIGHBORHOODS_BY_DISTANCE;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  '@id': 'https://pointcast.xyz/beacon',
  name: 'PointCast Beacon · 25-mile radius',
  description: '25-mile community-growth radius anchored in El Segundo. Neighborhoods eligible for mesh extension, third-space networks, DAO-led real estate, and cross-community programming.',
  url: 'https://pointcast.xyz/beacon',
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 33.919,
    longitude: -118.416,
    name: 'El Segundo, CA',
  },
  geoWithin: {
    '@type': 'GeoCircle',
    geoMidpoint: { '@type': 'GeoCoordinates', latitude: 33.919, longitude: -118.416 },
    geoRadius: '40233', // 25 miles in meters
  },
};
---

<BlockLayout
  title="Beacon"
  description="PointCast's 25-mile community-growth radius anchored in El Segundo. Neighborhoods in range for mesh internet, third-space networks, DAO-led real estate."
  image="/images/og/beacon.png"
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/beacon.json', title: 'Beacon radius (JSON)' }]}
>
  <div class="page">
    <nav class="crumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>beacon</span>
    </nav>

    <header class="hero">
      <p class="kicker">BEACON · 25-MILE RADIUS · FROM EL SEGUNDO</p>
      <h1 class="display">A beacon for the area.</h1>
      <p class="dek">
        PointCast anchors in El Segundo. Draw a circle 25 miles out and
        you get most of the South Bay, the Westside, industrial Hawthorne
        through Compton, downtown LA's edge, and part of Long Beach.
        That's the service area. These are the neighborhoods the mesh
        could extend to, the third-space network could replicate into,
        the DAO could invest alongside.
      </p>
    </header>

    <section class="panel panel--compass">
      <div class="compass">
        <div class="compass__ring" aria-hidden="true">
          <span class="compass__pin"></span>
          <span class="compass__dir compass__dir--n">N</span>
          <span class="compass__dir compass__dir--e">E</span>
          <span class="compass__dir compass__dir--s">S</span>
          <span class="compass__dir compass__dir--w">W</span>
          <span class="compass__radius">25 MI</span>
        </div>
        <div class="compass__facts">
          <div><dt class="mono">ANCHOR</dt><dd>El Segundo · 33.919 N, 118.416 W</dd></div>
          <div><dt class="mono">RADIUS</dt><dd>25 miles · ~40 km</dd></div>
          <div><dt class="mono">COVERAGE</dt><dd>Most of the South Bay + Westside + Harbor + part of DTLA/Long Beach</dd></div>
          <div><dt class="mono">CANDIDATES</dt><dd>{NEARBY.length} neighborhoods documented below</dd></div>
        </div>
      </div>
    </section>

    <section class="panel">
      <div class="panel__head">
        <p class="kicker">NEARBY · sorted by distance</p>
        <p class="panel__dek">TARGET · primary first-wave extension. ADJACENT · reachable, dependent on infrastructure. SEED · actively part of the growth.</p>
      </div>
      <ol class="places">
        {NEARBY.map((p) => (
          <li class={`place place--${p.status}`}>
            <div class="place__head">
              <span class="place__name">{p.name}</span>
              <span class="place__status mono">{p.status.toUpperCase()}</span>
              <span class="place__dist mono">{p.distance} MI · {p.bearing}</span>
            </div>
            <p class="place__why">{p.why}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="panel">
      <p class="kicker">THE PROGRAMS</p>
      <div class="programs">
        <article class="program">
          <h3 class="program__title">Mesh extension</h3>
          <p class="program__body">
            Per <a href="/b/0240">Block 0240</a>. Start in El Segundo. First hop Manhattan / Hermosa (3-5 mi). Second hop Redondo / Westchester. Year two: Venice + Culver City. Every mesh chapter inherits the gear pool, playbook, and peer-to-peer backhaul agreements.
          </p>
        </article>
        <article class="program">
          <h3 class="program__title">Third-space network</h3>
          <p class="program__body">
            Per <a href="/b/0242">Block 0242</a>. The archetype (pickleball + nature + food + saunas + pool + art) replicates. First instance: El Segundo. Year two targets: Venice, Torrance, Inglewood, Long Beach. Fifty instances total, networked membership.
          </p>
        </article>
        <article class="program">
          <h3 class="program__title">DAO real estate</h3>
          <p class="program__body">
            Per <a href="/b/0241">Block 0241</a>. ESREF buys commercial property in 90245 (El Segundo) year one. Expansion mandate could grow the mandate to the 25-mile radius starting year two, on a per-property DAO vote. <a href="/dao">PC-0001</a> is the first binding vote.
          </p>
        </article>
        <article class="program">
          <h3 class="program__title">Cross-programming</h3>
          <p class="program__body">
            Pickleball tournaments across the network. Mesh-node-building workshops. Third-space quarterly conventions. The 25-mile radius is tight enough that a Saturday morning drive covers any two cities.
          </p>
        </article>
      </div>
    </section>

    <aside class="surfaces">
      <p class="kicker">RELATED</p>
      <ul class="surfaces__list">
        <li><a href="/b/0240"><span class="mono">MESH</span> /b/0240</a></li>
        <li><a href="/b/0241"><span class="mono">RE FUND</span> /b/0241</a></li>
        <li><a href="/b/0242"><span class="mono">THIRD PLACE</span> /b/0242</a></li>
        <li><a href="/b/0244"><span class="mono">BEACON</span> /b/0244</a></li>
        <li><a href="/dao"><span class="mono">DAO</span> /dao</a></li>
        <li><a href="/beacon.json"><span class="mono">JSON</span> /beacon.json</a></li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<style>
  .page { max-width: 980px; margin: 0 auto; padding: 18px 16px 80px; }
  .mono { font-family: var(--pc-font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; }
  .kicker { font-family: var(--pc-font-mono); font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--pc-ink-muted); margin: 0 0 8px; }
  .crumb { font-family: var(--pc-font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--pc-ink-muted); margin-bottom: 18px; display: flex; gap: 8px; }

  .hero { margin-bottom: 24px; padding-bottom: 18px; border-bottom: 1.5px solid var(--pc-ink); }
  .display { font-family: var(--pc-font-sans); font-size: clamp(2.2rem, 9vw, 4rem); font-weight: 500; line-height: 0.96; letter-spacing: -0.02em; margin: 0 0 12px; }
  .dek { margin: 0; font-size: 15.5px; line-height: 1.5; color: var(--pc-ink-soft); max-width: 66ch; }

  .panel { margin-bottom: 24px; padding: 18px; border: 1px solid var(--pc-rule); border-radius: 2px; background: #fff; }
  .panel--compass { padding: 24px; background: #fafaf8; }
  .panel__head { margin-bottom: 14px; }
  .panel__dek { margin: 0; font-size: 13.5px; color: var(--pc-ink-soft); line-height: 1.5; }

  .compass { display: grid; grid-template-columns: 220px 1fr; gap: 24px; align-items: center; }
  .compass__ring {
    position: relative;
    width: 220px; height: 220px;
    border: 1.5px solid var(--pc-ink);
    border-radius: 50%;
    background:
      radial-gradient(circle at 50% 50%, #fff 0 8%, transparent 8.1% 100%),
      repeating-conic-gradient(var(--pc-rule-soft) 0deg 30deg, transparent 30deg 60deg);
  }
  .compass__pin {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 10px; height: 10px;
    background: #C95C2E;
    border-radius: 50%;
    box-shadow: 0 0 0 3px #fff, 0 0 0 4px var(--pc-ink);
  }
  .compass__dir {
    position: absolute;
    font-family: var(--pc-font-mono);
    font-size: 11px; letter-spacing: 0.14em;
    color: var(--pc-ink);
  }
  .compass__dir--n { top: 6px; left: 50%; transform: translateX(-50%); }
  .compass__dir--s { bottom: 6px; left: 50%; transform: translateX(-50%); }
  .compass__dir--e { right: 6px; top: 50%; transform: translateY(-50%); }
  .compass__dir--w { left: 6px; top: 50%; transform: translateY(-50%); }
  .compass__radius {
    position: absolute;
    bottom: 30px; left: 50%;
    transform: translateX(-50%);
    font-family: var(--pc-font-mono); font-size: 9px; letter-spacing: 0.14em;
    color: var(--pc-ink-muted);
  }

  .compass__facts { display: grid; gap: 10px; margin: 0; }
  .compass__facts > div { display: grid; gap: 2px; }
  .compass__facts dt { margin: 0; color: var(--pc-ink-muted); font-size: 9.5px; }
  .compass__facts dd { margin: 0; font-size: 14px; color: var(--pc-ink); line-height: 1.4; }

  @media (max-width: 620px) {
    .compass { grid-template-columns: 1fr; justify-items: center; }
    .compass__ring { width: 180px; height: 180px; }
  }

  .places { list-style: none; padding: 0; margin: 0; display: grid; gap: 2px; }
  .place {
    padding: 10px 12px;
    border-left: 3px solid var(--pc-rule);
    background: #fff;
    display: grid; gap: 4px;
  }
  .place--target   { border-left-color: #0F6E56; background: #E7F4EF; }
  .place--adjacent { border-left-color: #185FA5; background: #EEF4FA; }
  .place--seed     { border-left-color: #C95C2E; background: #FBEFEA; }
  .place__head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 10px; }
  .place__name { font-family: var(--pc-font-sans); font-size: 15px; font-weight: 500; color: var(--pc-ink); flex: 1; }
  .place__status { font-size: 9px; padding: 2px 6px; border: 1px solid currentColor; border-radius: 2px; }
  .place--target   .place__status { color: #074638; }
  .place--adjacent .place__status { color: #0B3E73; }
  .place--seed     .place__status { color: #7a2e0d; }
  .place__dist { font-size: 10px; color: var(--pc-ink-muted); }
  .place__why { margin: 0; font-size: 13.5px; line-height: 1.5; color: var(--pc-ink-soft); }

  .programs { display: grid; grid-template-columns: 1fr; gap: 12px; }
  .program { padding: 14px; background: #fafaf8; border: 1px solid var(--pc-rule); border-radius: 2px; }
  .program__title { margin: 0 0 6px; font-family: var(--pc-font-sans); font-size: 16px; font-weight: 500; color: var(--pc-ink); }
  .program__body { margin: 0; font-size: 14px; line-height: 1.55; color: var(--pc-ink-soft); }
  .program__body a { color: var(--pc-accent); }

  @media (min-width: 720px) {
    .programs { grid-template-columns: repeat(2, 1fr); }
  }

  .surfaces { padding: 14px; border: 1px solid var(--pc-rule); border-radius: 2px; background: #fafaf8; }
  .surfaces__list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px 14px; }
  .surfaces__list a { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--pc-accent); padding: 4px 0; }
  .surfaces__list .mono { color: var(--pc-ink-muted); min-width: 76px; }
  @media (min-width: 640px) { .surfaces__list { grid-template-columns: repeat(3, 1fr); } }
</style>
