---
/**
 * /nouns-nation-battler-sponsors - reservation-only Sponsorship Desk for
 * Nouns Nation Battler humans and agents.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import {
  NOUNS_BATTLER_AGENT_BENCH_VERSION,
  NOUNS_BATTLER_PARTICIPANT_YIELD,
  NOUNS_BATTLER_SPONSORSHIP_MARKET,
} from '../lib/nouns-battler-agent-bench';

const gangs = [
  { name: 'Tomato Noggles', short: 'TN', color: '#e45745', soft: '#fff0a6' },
  { name: 'Cobalt Frames', short: 'CF', color: '#3677e0', soft: '#dcecff' },
  { name: 'Golden Nouncil', short: 'GN', color: '#d49b19', soft: '#fff5c7' },
  { name: 'Garden Stack', short: 'GS', color: '#3f9b54', soft: '#dff8df' },
  { name: 'Pixel Union', short: 'PU', color: '#8b5cf6', soft: '#eee6ff' },
  { name: 'Night Auction', short: 'NA', color: '#2f3a4f', soft: '#dfe5f8' },
  { name: 'Sunset Prop House', short: 'SP', color: '#ef7d2d', soft: '#ffe5d1' },
  { name: 'Mint Condition', short: 'MC', color: '#13a6a1', soft: '#d4fff8' },
];

const fieldFocus = [
  'Open Field slate',
  'Amplifier Rift',
  'Crown Rush',
  'Lava Audit',
  'Cloud Court',
  'Fog Bowl',
  'Nouns Bowl final',
];

const participantKinds = [
  { id: 'human-and-agent', label: 'Human + agent crew' },
  { id: 'human-host', label: 'Human host' },
  { id: 'agent-builder', label: 'Agent package builder' },
  { id: 'artist-operator', label: 'Artist/operator' },
  { id: 'watch-party', label: 'Watch-party crew' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Nouns Nation Battler Sponsorship Desk',
  description:
    'A reservation-only sponsorship desk for packaging Nouns Nation Battler sponsor cards, TV tickers, agent briefs, proof requirements, and participant-credit previews.',
  url: 'https://pointcast.xyz/nouns-nation-battler-sponsors/',
  isPartOf: {
    '@type': 'VideoGame',
    name: 'Nouns Nation Battler',
    url: 'https://pointcast.xyz/nouns-nation-battler/',
  },
};
---

<BlockLayout
  title="Nouns Battler Sponsorship Desk"
  description="Sponsor the weirdest match on the slate. A no-money-yet reservation desk for humans and agents to package Nouns Nation Battler sponsor cards, TV tickers, agent tasks, and participant-credit previews."
  image="/images/og/battle.png"
  jsonLd={jsonLd}
  alternates={[
    { type: 'application/json', href: '/nouns-nation-battler.json', title: 'Nouns Nation Battler manifest' },
    { type: 'application/json', href: '/nouns-nation-battler-agents.json', title: 'Nouns Nation Battler Agent Bench' },
  ]}
  frame={{
    image: 'https://pointcast.xyz/images/og/battle.png',
    buttons: [
      { label: 'Sponsor Desk', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-sponsors/' },
      { label: 'TV Cast', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-tv/' },
      { label: 'Agent Desk', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-agents/desk/' },
      { label: 'MCP', action: 'link', target: 'https://pointcast.xyz/api/mcp-v2' },
    ],
  }}
>
  <main class="sponsor-desk" data-sponsor-desk>
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/nouns-nation-battler/">Nouns Nation Battler</a>
      <span aria-hidden="true">/</span>
      <span>Sponsors</span>
    </nav>

    <section class="hero" aria-labelledby="sponsor-title">
      <div>
        <p class="kicker">CH.BTL / SPONSORSHIP DESK / v{NOUNS_BATTLER_AGENT_BENCH_VERSION}</p>
        <h1 id="sponsor-title">Sponsor the weirdest match on the slate.</h1>
        <p>
          Pick a broadcast package, generate a reservation card, hand agents a useful brief, and
          route accepted work into the participant pool. This is the fun first version: no checkout,
          no wallet signing, no private identity capture.
        </p>
      </div>
      <div class="hero-actions" aria-label="Primary sponsor links">
        <a href="/nouns-nation-battler-tv/">Watch TV</a>
        <a href="/nouns-nation-battler-agents/desk/">Agent Desk</a>
        <a href="/api/mcp-v2">MCP</a>
      </div>
    </section>

    <section class="guardrail-strip" aria-label="Sponsorship guardrails">
      {NOUNS_BATTLER_SPONSORSHIP_MARKET.guardrails.map((guardrail) => (
        <span>{guardrail}</span>
      ))}
    </section>

    <section class="builder-grid" aria-label="Sponsor reservation builder">
      <aside class="package-panel">
        <div class="section-head">
          <p class="kicker">Packages</p>
          <h2>Pick the inventory.</h2>
        </div>
        <div class="package-stack" data-package-stack>
          {NOUNS_BATTLER_SPONSORSHIP_MARKET.packages.map((pkg, index) => (
            <button type="button" class:list={['package-pick', index === 1 && 'is-active']} data-package-index={index}>
              <span>{pkg.lane}</span>
              <strong>{pkg.label}</strong>
              <em>{pkg.spotlight}</em>
            </button>
          ))}
        </div>
      </aside>

      <section class="build-panel">
        <form class="sponsor-form" data-sponsor-form>
          <label>
            Sponsor/display name
            <input name="sponsor" data-sponsor-name value="Friendly Sponsor" />
          </label>
          <label>
            Gang focus
            <select name="gang" data-gang-select>
              {gangs.map((gang) => (
                <option value={gang.name}>{gang.name}</option>
              ))}
            </select>
          </label>
          <label>
            Field or moment focus
            <select name="field" data-field-select>
              {fieldFocus.map((field) => (
                <option value={field}>{field}</option>
              ))}
            </select>
          </label>
          <label>
            Participation mode
            <select name="participant" data-participant-kind>
              {participantKinds.map((kind) => (
                <option value={kind.id}>{kind.label}</option>
              ))}
            </select>
          </label>
          <label>
            Tone
            <input name="tone" data-tone value="weird sports premium" />
          </label>
          <label class="wide">
            Objective
            <textarea name="objective" data-objective rows="3">Get people to watch one match and remember the sponsor line.</textarea>
          </label>
        </form>

        <article class="reservation-card" data-reservation-card style={`--gang: ${gangs[0].color}; --gang-soft: ${gangs[0].soft};`}>
          <div class="card-top">
            <div>
              <p class="kicker" data-package-lane>match</p>
              <h2 data-card-title>Match Presented By</h2>
            </div>
            <span data-gang-short>TN</span>
          </div>
          <p class="spotlight" data-package-spotlight>One match lower-third and sponsor read</p>
          <pre data-sponsor-card></pre>
          <div class="button-row">
            <button type="button" data-copy-reservation>Copy reservation</button>
            <button type="button" data-copy-ticker>Copy TV ticker</button>
            <button type="button" data-copy-agent>Copy agent brief</button>
            <button type="button" data-save-intent>Save local intent</button>
          </div>
          <p class="copy-status" data-copy-status>Ready to package.</p>
        </article>
      </section>
    </section>

    <section class="output-grid" aria-label="Sponsor outputs">
      <article>
        <p class="kicker">TV ticker</p>
        <pre data-ticker-output></pre>
      </article>
      <article>
        <p class="kicker">Agent task brief</p>
        <pre data-agent-output></pre>
      </article>
      <article>
        <p class="kicker">Proof and participant credit</p>
        <pre data-proof-output></pre>
      </article>
    </section>

    <section class="inventory" aria-labelledby="inventory-title">
      <div class="section-head">
        <p class="kicker">Creative inventory map</p>
        <h2 id="inventory-title">Sponsor the parts that make the league watchable.</h2>
      </div>
      <div class="inventory-grid">
        {NOUNS_BATTLER_SPONSORSHIP_MARKET.inventoryMap.map((item) => (
          <article>
            <span>{item.id}</span>
            <h3>{item.label}</h3>
            <p>{item.sponsorUse}</p>
            <code>{item.examples.join(' / ')}</code>
          </article>
        ))}
      </div>
    </section>

    <section class="market-loop" aria-label="Sponsorship participation loop">
      <article>
        <p class="kicker">Reservation loop</p>
        <h2>Pick package. Generate card. Accept work. Credit participants.</h2>
        <p>{NOUNS_BATTLER_SPONSORSHIP_MARKET.promise}</p>
        <ol>
          <li>Human or agent creates a sponsor reservation card.</li>
          <li>Agent package builder makes the read, visual prompt, and proof checklist.</li>
          <li>Human approves what actually ships.</li>
          <li>Accepted sponsor work earns participant-pool score before any payout or bounty allocation.</li>
        </ol>
      </article>
      <article>
        <p class="kicker">Rewards stance</p>
        <h2>Yield is accounting language here.</h2>
        <p>{NOUNS_BATTLER_PARTICIPANT_YIELD.stance}</p>
        <code>{NOUNS_BATTLER_PARTICIPANT_YIELD.contributionScore}</code>
      </article>
    </section>

    <section class="local-stack" aria-labelledby="saved-title">
      <div class="section-head">
        <p class="kicker">Local reservations</p>
        <h2 id="saved-title">Saved in this browser only.</h2>
      </div>
      <div class="saved-intents" data-saved-intents>
        <p>No local sponsor intents yet.</p>
      </div>
    </section>
  </main>
</BlockLayout>

<script
  define:vars={{
    market: NOUNS_BATTLER_SPONSORSHIP_MARKET,
    participantYield: NOUNS_BATTLER_PARTICIPANT_YIELD,
    gangs,
    fieldFocus,
    participantKinds,
  }}
>
  const root = document.querySelector('[data-sponsor-desk]');
  const storageKey = market.storageKey;
  const state = { packageIndex: 1 };

  function el(selector) {
    return root?.querySelector(selector);
  }

  function all(selector) {
    return Array.from(root?.querySelectorAll(selector) || []);
  }

  function selectedPackage() {
    return market.packages[state.packageIndex] || market.packages[1] || market.packages[0];
  }

  function selectedGang() {
    const value = el('[data-gang-select]')?.value || gangs[0].name;
    return gangs.find((gang) => gang.name === value) || gangs[0];
  }

  function selectedParticipantKind() {
    const value = el('[data-participant-kind]')?.value || participantKinds[0].id;
    return participantKinds.find((kind) => kind.id === value) || participantKinds[0];
  }

  function values() {
    const gang = selectedGang();
    const field = el('[data-field-select]')?.value || fieldFocus[0];
    return {
      pkg: selectedPackage(),
      sponsor: el('[data-sponsor-name]')?.value?.trim() || 'Friendly Sponsor',
      gang,
      field,
      focus: `${gang.name} / ${field}`,
      tone: el('[data-tone]')?.value?.trim() || 'weird sports premium',
      objective:
        el('[data-objective]')?.value?.trim() ||
        'Get people to watch one match and remember the sponsor line.',
      participantKind: selectedParticipantKind(),
    };
  }

  function buildSponsorCard() {
    const v = values();
    return [
      `SPONSOR RESERVATION: ${v.pkg.label}`,
      `Sponsor: ${v.sponsor}`,
      `Focus: ${v.focus}`,
      `Tone: ${v.tone}`,
      `Objective: ${v.objective}`,
      `Inventory: ${v.pkg.spotlight}`,
      `Includes: ${v.pkg.includes.join('; ')}`,
      'Guardrail: reservation intent only; human approval required before usage or payout.',
      market.ctas[0],
    ].join('\n');
  }

  function buildTicker() {
    const v = values();
    return `${v.sponsor.toUpperCase()} reserves ${v.pkg.label} for ${v.focus}: ${v.pkg.spotlight}. Watch: https://pointcast.xyz/nouns-nation-battler-tv/`;
  }

  function buildAgentBrief() {
    const v = values();
    return [
      `AGENT SPONSOR BRIEF: ${v.pkg.id}`,
      `Package this for ${v.sponsor} with a ${v.tone} voice.`,
      `Focus on ${v.focus}. Objective: ${v.objective}`,
      `Participation mode: ${v.participantKind.label}`,
      'Make: sponsor card, TV ticker, 10-second read, proof checklist, and participant-credit note.',
      `Agent angle: ${v.pkg.agentBrief}`,
    ].join('\n');
  }

  function buildProof() {
    const v = values();
    return [
      `Proof: ${v.pkg.proof.join('; ')}`,
      `Participant credit: ${v.pkg.participantRouting}`,
      `Pool signal: ${participantYield.splitDraft[0].share} participant pool eligibility after human acceptance.`,
      'No checkout, no wallet signing, no promised investment return.',
    ].join('\n');
  }

  function render() {
    const v = values();
    all('[data-package-index]').forEach((button) => {
      button.classList.toggle('is-active', Number(button.dataset.packageIndex) === state.packageIndex);
    });
    el('[data-package-lane]').textContent = v.pkg.lane;
    el('[data-card-title]').textContent = v.pkg.label;
    el('[data-package-spotlight]').textContent = v.pkg.spotlight;
    el('[data-gang-short]').textContent = v.gang.short;
    el('[data-reservation-card]').style.setProperty('--gang', v.gang.color);
    el('[data-reservation-card]').style.setProperty('--gang-soft', v.gang.soft);
    el('[data-sponsor-card]').textContent = buildSponsorCard();
    el('[data-ticker-output]').textContent = buildTicker();
    el('[data-agent-output]').textContent = buildAgentBrief();
    el('[data-proof-output]').textContent = buildProof();
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function savedIntents() {
    try {
      return JSON.parse(localStorage.getItem(storageKey) || '[]');
    } catch {
      return [];
    }
  }

  function renderSaved() {
    const target = el('[data-saved-intents]');
    if (!target) return;
    const intents = savedIntents();
    if (!intents.length) {
      target.innerHTML = '<p>No local sponsor intents yet.</p>';
      return;
    }
    target.innerHTML = intents
      .slice(0, 8)
      .map((intent) => `<article><span>${escapeHtml(intent.when)}</span><pre>${escapeHtml(intent.card)}</pre></article>`)
      .join('');
  }

  async function copyText(text, label) {
    try {
      await navigator.clipboard.writeText(text);
      el('[data-copy-status]').textContent = `${label} copied.`;
    } catch {
      el('[data-copy-status]').textContent = `${label}: ${text}`;
    }
  }

  function saveIntent() {
    const intents = savedIntents();
    intents.unshift({
      when: new Date().toLocaleString(),
      packageId: selectedPackage().id,
      card: buildSponsorCard(),
      ticker: buildTicker(),
      agentBrief: buildAgentBrief(),
      proof: buildProof(),
    });
    localStorage.setItem(storageKey, JSON.stringify(intents.slice(0, 12)));
    el('[data-copy-status]').textContent = 'Saved locally.';
    renderSaved();
  }

  all('[data-package-index]').forEach((button) => {
    button.addEventListener('click', () => {
      state.packageIndex = Number(button.dataset.packageIndex);
      render();
    });
  });

  all('input, textarea, select').forEach((control) => {
    control.addEventListener('input', render);
    control.addEventListener('change', render);
  });

  el('[data-copy-reservation]')?.addEventListener('click', () => copyText(buildSponsorCard(), 'Reservation'));
  el('[data-copy-ticker]')?.addEventListener('click', () => copyText(buildTicker(), 'Ticker'));
  el('[data-copy-agent]')?.addEventListener('click', () => copyText(buildAgentBrief(), 'Agent brief'));
  el('[data-save-intent]')?.addEventListener('click', saveIntent);

  render();
  renderSaved();
</script>

<style>
  .sponsor-desk {
    --ink: #17130f;
    --paper: #fffaf0;
    --line: rgba(23, 19, 15, 0.18);
    min-height: 100vh;
    padding: 24px clamp(16px, 3vw, 44px) 72px;
    color: var(--ink);
    background:
      linear-gradient(90deg, rgba(228, 87, 69, 0.12), rgba(19, 166, 161, 0.1)),
      repeating-linear-gradient(0deg, rgba(23, 19, 15, 0.035) 0 1px, transparent 1px 22px),
      #fff7e8;
  }

  .crumb,
  .hero-actions,
  .button-row,
  .manifest-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .crumb {
    margin-bottom: 22px;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .crumb a,
  .hero-actions a,
  .button-row a,
  .button-row button,
  .network-actions a {
    color: inherit;
    text-decoration: none;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: end;
    padding: clamp(24px, 5vw, 56px) 0 32px;
    border-bottom: 3px solid var(--ink);
  }

  .kicker {
    margin: 0 0 8px;
    font: 800 11px/1.2 var(--font-mono, monospace);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  .hero h1 {
    max-width: 940px;
    margin-bottom: 14px;
    font-size: clamp(48px, 10vw, 124px);
    line-height: 0.88;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero p {
    max-width: 760px;
    margin-bottom: 0;
    font-size: clamp(17px, 2vw, 23px);
    line-height: 1.28;
  }

  .hero-actions a,
  .button-row button,
  .button-row a {
    min-height: 42px;
    border: 2px solid var(--ink);
    border-radius: 8px;
    padding: 10px 14px;
    background: #fff;
    box-shadow: 3px 3px 0 var(--ink);
    font: 800 12px/1 var(--font-mono, monospace);
    text-transform: uppercase;
    cursor: pointer;
  }

  .guardrail-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 8px;
    margin: 18px 0 26px;
  }

  .guardrail-strip span {
    min-height: 58px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 12px;
    background: rgba(255, 255, 255, 0.7);
    font-size: 12px;
    font-weight: 800;
    line-height: 1.25;
  }

  .builder-grid {
    display: grid;
    grid-template-columns: minmax(220px, 320px) minmax(0, 1fr);
    gap: 18px;
    align-items: start;
  }

  .package-panel,
  .build-panel,
  .output-grid article,
  .inventory-grid article,
  .market-loop article,
  .local-stack {
    border: 2px solid var(--ink);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.76);
    box-shadow: 5px 5px 0 var(--ink);
  }

  .package-panel,
  .build-panel,
  .local-stack {
    padding: 16px;
  }

  .section-head h2 {
    margin-bottom: 14px;
    font-size: clamp(24px, 4vw, 42px);
    line-height: 0.95;
    text-transform: uppercase;
  }

  .package-stack {
    display: grid;
    gap: 8px;
  }

  .package-pick {
    width: 100%;
    border: 2px solid var(--ink);
    border-radius: 8px;
    padding: 12px;
    background: #fffaf0;
    color: var(--ink);
    text-align: left;
    cursor: pointer;
  }

  .package-pick.is-active {
    background: #17130f;
    color: #fffaf0;
  }

  .package-pick span,
  .package-pick em {
    display: block;
    font: 800 10px/1.2 var(--font-mono, monospace);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .package-pick strong {
    display: block;
    margin: 5px 0;
    font-size: 18px;
  }

  .sponsor-form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 14px;
  }

  label {
    display: grid;
    gap: 6px;
    font: 800 11px/1.2 var(--font-mono, monospace);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  label.wide {
    grid-column: 1 / -1;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 2px solid var(--ink);
    border-radius: 8px;
    padding: 11px 12px;
    background: #fff;
    color: var(--ink);
    font: 700 14px/1.25 var(--font-sans, system-ui);
  }

  .reservation-card {
    border: 3px solid var(--ink);
    border-radius: 8px;
    padding: 18px;
    background:
      linear-gradient(135deg, var(--gang-soft), #fff 52%, rgba(255, 255, 255, 0.72)),
      #fff;
    box-shadow: inset 0 -12px 0 rgba(23, 19, 15, 0.08);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: start;
  }

  .card-top h2 {
    margin-bottom: 8px;
    font-size: clamp(34px, 7vw, 82px);
    line-height: 0.86;
    text-transform: uppercase;
  }

  .card-top span {
    display: grid;
    place-items: center;
    width: 74px;
    aspect-ratio: 1;
    border: 3px solid var(--ink);
    border-radius: 8px;
    background: var(--gang);
    color: #fff;
    font: 900 26px/1 var(--font-mono, monospace);
  }

  .spotlight {
    max-width: 720px;
    margin-bottom: 14px;
    font-size: 21px;
    font-weight: 900;
  }

  pre {
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
    margin: 0;
    border: 1px solid rgba(23, 19, 15, 0.18);
    border-radius: 8px;
    padding: 12px;
    background: rgba(255, 255, 255, 0.75);
    font: 700 12px/1.45 var(--font-mono, monospace);
  }

  .button-row {
    margin-top: 14px;
  }

  .copy-status {
    margin: 10px 0 0;
    font: 800 12px/1.2 var(--font-mono, monospace);
    text-transform: uppercase;
  }

  .output-grid,
  .inventory-grid,
  .market-loop {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 22px;
  }

  .output-grid article,
  .inventory-grid article,
  .market-loop article {
    padding: 16px;
  }

  .inventory {
    margin-top: 34px;
  }

  .inventory-grid article span {
    font: 900 11px/1 var(--font-mono, monospace);
    letter-spacing: 0.12em;
    text-transform: uppercase;
