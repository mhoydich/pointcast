---
/**
 * /federated — directory of sites federated with PointCast.
 *
 * Growth page. Every federated site gets a card with description,
 * topic tags, operator, feed URL, and a "visit" button. At the top,
 * a one-line CTA pointing curious operators to /federate. At the
 * bottom, the full compute-ledger-v0 spec link + the JSON mirror at
 * /federation.json.
 *
 * Schema: CollectionPage + ItemList with one ListItem per site.
 * Each site is a WebSite entity with url + sameAs + about fields.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import { FEDERATED_SITES, ROLE_META, groupByRole, liveFederationCount } from '../lib/federation';

const groups = groupByRole();
const liveCount = liveFederationCount();
const totalCount = FEDERATED_SITES.length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      '@id': 'https://pointcast.xyz/federated',
      name: 'Federated sites — PointCast',
      description: `${liveCount} sites federated with PointCast. Siblings, partners, and mirrors that exchange reciprocal links, feeds, and compute ledgers with pointcast.xyz.`,
      url: 'https://pointcast.xyz/federated',
      isPartOf: { '@type': 'WebSite', '@id': 'https://pointcast.xyz/#website' },
    },
    {
      '@type': 'ItemList',
      '@id': 'https://pointcast.xyz/federated#list',
      numberOfItems: totalCount,
      itemListOrder: 'https://schema.org/ItemListOrderDescending',
      itemListElement: FEDERATED_SITES.map((s, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'WebSite',
          '@id': s.url,
          name: s.name,
          url: s.url,
          description: s.description,
          ...(s.feed ? { potentialAction: { '@type': 'SubscribeAction', target: s.feed } } : {}),
        },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://pointcast.xyz/federated#breadcrumb',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://pointcast.xyz/' },
        { '@type': 'ListItem', position: 2, name: 'Federated', item: 'https://pointcast.xyz/federated' },
      ],
    },
  ],
};
---

<BlockLayout
  title="Federated"
  description={`${liveCount} sites federated with PointCast — siblings, partners, and mirrors that exchange reciprocal links, feeds, and compute ledgers. Open protocol, three-step registration.`}
  image="/images/og-home-v3.png"
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/federation.json', title: 'Federation registry (JSON)' }]}
>
  <article class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>Federated</span>
    </nav>

    <header class="hero">
      <p class="kicker">FEDERATED · {liveCount} SITES · CC0 OPEN PROTOCOL</p>
      <h1 class="display">Federated sites.</h1>
      <p class="dek">
        Every site listed below publishes a feed PointCast ingests and
        links back to pointcast.xyz from theirs. Reciprocal traffic, shared
        audiences, no lock-in. Registration is three steps: publish a feed,
        link back, email <a href="mailto:hello@pointcast.xyz">hello@pointcast.xyz</a>.
      </p>
      <p class="dek">
        Full protocol spec: <a href="/federate">/federate</a>.
        Machine-readable registry: <a href="/federation.json">/federation.json</a>.
      </p>
    </header>

    {groups.map((group) => {
      const meta = ROLE_META[group.role];
      return (
        <section class="group" style={`--role-accent: ${meta.accent}`}>
          <header class="group__head">
            <h2 class="group__title">{meta.label} <span class="group__count mono">· {group.sites.length}</span></h2>
            <p class="group__note">{meta.note}</p>
          </header>
          <ul class="sites">
            {group.sites.map((s) => (
              <li class="site">
                <div class="site__head">
                  <h3 class="site__name">
                    <a href={s.url} target="_blank" rel="noopener">{s.name} ↗</a>
                  </h3>
                  <p class="site__operator mono">
                    {s.operator}{s.since ? ` · since ${s.since}` : ''}
                  </p>
                </div>
                <p class="site__description">{s.description}</p>
                {s.topics.length > 0 && (
                  <p class="site__topics mono">
                    {s.topics.map((t, i) => <>{i > 0 && <span aria-hidden="true"> · </span>}<span>{t}</span></>)}
                  </p>
                )}
                <div class="site__meta">
                  {s.feed && <a class="site__chip mono" href={s.feed} target="_blank" rel="noopener">feed</a>}
                  {s.computeJson && <a class="site__chip mono" href={s.computeJson} target="_blank" rel="noopener">/compute.json</a>}
                  {s.blocksJson && <a class="site__chip mono" href={s.blocksJson} target="_blank" rel="noopener">/blocks.json</a>}
                  {s.agentsJson && <a class="site__chip mono" href={s.agentsJson} target="_blank" rel="noopener">/agents.json</a>}
                  {s.llmsTxt && <a class="site__chip mono" href={s.llmsTxt} target="_blank" rel="noopener">/llms.txt</a>}
                  {s.twitter && <a class="site__chip mono" href={`https://x.com/${s.twitter.replace(/^@/, '')}`} target="_blank" rel="noopener">{s.twitter.startsWith('@') ? s.twitter : `@${s.twitter}`}</a>}
                  {s.farcaster && <a class="site__chip mono" href={`https://warpcast.com/${s.farcaster.replace(/^@/, '')}`} target="_blank" rel="noopener">{s.farcaster.startsWith('@') ? s.farcaster : `@${s.farcaster}`}</a>}
                  {s.github && <a class="site__chip mono" href={`https://github.com/${s.github.replace(/^@/, '')}`} target="_blank" rel="noopener">GH</a>}
                  {s.reciprocates && <span class="site__chip site__chip--ok mono">↔ reciprocates</span>}
                </div>
                {s.notes && <p class="site__notes">{s.notes}</p>}
              </li>
            ))}
          </ul>
        </section>
      );
    })}

    <section class="cta">
      <p class="cta__kicker mono">RUN A SITE? FEDERATE WITH US.</p>
      <h2 class="cta__title">Three steps to plug in.</h2>
      <ol class="cta__steps">
        <li><strong>Publish a feed</strong> — RSS 2.0 or JSON Feed 1.1. Any path you want.</li>
        <li><strong>Link back</strong> — drop a small "Federated with PointCast" badge in your footer, linking to <code>/federated</code>.</li>
        <li><strong>Email us</strong> — <a href="mailto:hello@pointcast.xyz">hello@pointcast.xyz</a> with your site URL. We add you to this page + <code>/federation.json</code> within 24h.</li>
      </ol>
      <p class="cta__foot">
        Bonus: if you also ship <code>/compute.json</code> per the
        <a href="https://github.com/MikeHoydich/pointcast/blob/main/docs/rfc/compute-ledger-v0.md" target="_blank" rel="noopener">compute-ledger-v0 RFC</a>,
        your ship log mirrors into <a href="/compute">/compute</a> automatically.
      </p>
      <p class="cta__foot">
        Full walkthrough: <a href="/federate">/federate</a>.
      </p>
    </section>

    <footer class="related">
      <p class="related__label">RELATED</p>
      <ul>
        <li><a href="/federate">/federate — how to federate with PointCast</a></li>
        <li><a href="/federation.json">/federation.json — machine-readable registry</a></li>
        <li><a href="/collabs">/collabs — human + AI collaborators registry</a></li>
        <li><a href="/compute">/compute — federated ship ledger</a></li>
        <li><a href="/mesh">/mesh — local · online · agent meshes</a></li>
        <li><a href="/for-agents">/for-agents — agent discovery manifest</a></li>
      </ul>
    </footer>
  </article>
</BlockLayout>

<style>
  .page { max-width: 820px; margin: 0 auto; padding: 18px 18px 80px; }
  .mono { font-family: var(--pc-font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; }

  .crumb {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin-bottom: 18px;
  }
  .crumb a { color: var(--pc-accent); }

  .hero { margin-bottom: 28px; padding-bottom: 18px; border-bottom: 1.5px solid var(--pc-ink); }
  .kicker {
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pc-accent);
    margin: 0 0 10px;
  }
  .display { font-family: var(--pc-font-sans); font-size: 40px; font-weight: 500; line-height: 1.05; margin: 0 0 12px; }
  @media (max-width: 600px) { .display { font-size: 30px; } }
  .dek { font-size: 16px; line-height: 1.55; color: var(--pc-ink-soft); margin: 0 0 8px; max-width: 60ch; }
  .dek a { color: var(--pc-accent); }

  .group { margin: 28px 0; }
  .group__head { margin-bottom: 12px; border-left: 3px solid var(--role-accent); padding-left: 12px; }
  .group__title {
    font-family: var(--pc-font-sans);
    font-size: 22px;
    font-weight: 500;
    margin: 0 0 2px;
  }
  .group__count { color: var(--pc-ink-muted); font-size: 12px; letter-spacing: 0.14em; }
  .group__note { margin: 0; font-size: 13px; color: var(--pc-ink-soft); }

  .sites { list-style: none; padding: 0; margin: 0; display: grid; gap: 12px; }
  .site {
    padding: 14px 16px;
    border: 1px solid var(--pc-rule);
    border-left: 3px solid var(--role-accent);
    border-radius: 2px;
    background: #fff;
  }
  .site__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }
  .site__name { margin: 0; font-family: var(--pc-font-sans); font-size: 18px; font-weight: 500; }
  .site__name a { color: var(--pc-ink); text-decoration: none; }
  .site__name a:hover { color: var(--pc-accent); }
  .site__operator { margin: 0; color: var(--pc-ink-muted); }
  .site__description { margin: 0 0 6px; font-size: 14.5px; line-height: 1.55; color: var(--pc-ink); }
  .site__topics {
    margin: 0 0 8px;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--pc-ink-muted);
  }
  .site__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 8px;
  }
  .site__chip {
    padding: 3px 8px;
    border: 1px solid var(--pc-rule);
    background: #fafaf8;
    color: var(--pc-accent);
    border-radius: 2px;
    text-decoration: none;
    transition: background-color 120ms;
  }
  .site__chip:hover { background: #fff; border-color: var(--pc-ink-muted); text-decoration: none; }
  .site__chip--ok {
    background: #e7f4ef;
    color: #074638;
    border-color: #0F6E56;
  }
  .site__notes {
    margin: 6px 0 0;
    font-size: 12.5px;
    color: var(--pc-ink-muted);
    line-height: 1.5;
    border-top: 1px dashed var(--pc-rule-soft);
    padding-top: 6px;
  }

  .cta {
    margin: 40px 0 0;
    padding: 24px;
    border: 1.5px solid var(--pc-ink);
    border-radius: 2px;
    background: linear-gradient(180deg, #12110E 0%, #1c1814 100%);
    color: #f2efe9;
  }
  .cta__kicker { margin: 0 0 10px; color: #e89a2d; letter-spacing: 0.2em; }
  .cta__title {
    font-family: var(--pc-font-sans);
    font-size: 24px;
    font-weight: 500;
    margin: 0 0 14px;
    color: #f7ecd4;
  }
  .cta__steps {
    margin: 0 0 14px;
    padding-left: 20px;
    font-size: 15px;
    line-height: 1.6;
    color: #f2efe9;
  }
  .cta__steps li { margin-bottom: 6px; }
  .cta__steps strong { color: #fff; font-weight: 500; }
  .cta__steps code {
    font-family: var(--pc-font-mono);
    font-size: 13px;
    background: rgba(255, 246, 229, 0.12);
    padding: 1px 5px;
    border-radius: 2px;
  }
  .cta__foot {
    margin: 10px 0 0;
    font-size: 13.5px;
    color: color-mix(in oklab, #f2efe9 70%, transparent);
  }
  .cta__foot a { color: #e89a2d; }
  .cta__foot code {
    font-family: var(--pc-font-mono);
    font-size: 12.5px;
    background: rgba(255, 246, 229, 0.12);
    padding: 1px 5px;
    border-radius: 2px;
  }

  .related {
    margin-top: 40px;
    padding-top: 16px;
    border-top: 1.5px solid var(--pc-ink);
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .related__label { margin: 0 0 8px; color: var(--pc-ink-soft); }
  .related ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
  .related a { color: var(--pc-accent); }
</style>
