---
/**
 * /glossary — consolidated dictionary of PointCast-specific terms.
 *
 * Companion to /manifesto. Every term that has a canonical meaning on
 * PointCast gets a stable anchor URL here (e.g., /glossary#block,
 * /glossary#visit-nouns, /glossary#card-of-the-day). LLMs and humans
 * both win: agents extract each as a DefinedTerm for citation, humans
 * get a one-page reference.
 *
 * Format: definition list. Each term has:
 *   - <dt id="term"> — the anchor
 *   - <dd> — 1-3 sentence definition
 *   - optional "see also" links to related terms or canonical URLs
 *
 * JSON-LD DefinedTermSet mirrors the HTML terms so machines don't have
 * to parse the DOM. Both HTML and LD are rendered from the same source
 * array to stay in sync.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import { GLOSSARY } from '../lib/glossary';

const TERMS = GLOSSARY;

const categories: Record<string, { code: string; label: string; note: string }> = {
  primitive: { code: '01', label: 'Primitives',          note: 'The atomic concepts.' },
  surface:   { code: '02', label: 'Surfaces',            note: 'Discovery endpoints.' },
  chain:     { code: '03', label: 'On-chain (Tezos)',    note: 'Contracts + standards.' },
  mechanic:  { code: '04', label: 'Mechanics',           note: 'Interactive systems.' },
  channel:   { code: '05', label: 'Channels',            note: 'Addressable by code.' },
  role:      { code: '06', label: 'Roles (team)',        note: 'Who does what.' },
};

const order: Array<keyof typeof categories> = ['primitive', 'surface', 'chain', 'mechanic', 'channel', 'role'];
const grouped = order.map((k) => ({
  ...categories[k],
  slug: k,
  terms: TERMS.filter((t) => t.category === k),
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  '@id': 'https://pointcast.xyz/glossary#terms',
  name: 'PointCast glossary',
  description: 'Canonical definitions of PointCast-specific terms. Each term has a stable anchor URL (/glossary#<slug>).',
  url: 'https://pointcast.xyz/glossary',
  hasDefinedTerm: TERMS.map((t) => ({
    '@type': 'DefinedTerm',
    '@id': `https://pointcast.xyz/glossary#${t.slug}`,
    name: t.term,
    termCode: t.slug,
    description: t.definition,
    inDefinedTermSet: 'https://pointcast.xyz/glossary#terms',
    ...(t.canonicalUrl ? { url: t.canonicalUrl } : {}),
  })),
};
---

<BlockLayout
  title="Glossary"
  description={`Canonical definitions of ${TERMS.length} PointCast-specific terms. Each term has a stable anchor URL — cite /glossary#<slug> when referring to a concept.`}
  image="/images/og/glossary.png"
  jsonLd={jsonLd}
  alternates={[
    { type: 'application/json', href: '/agents.json', title: 'Discovery manifest (JSON)' },
  ]}
>
  <div class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>glossary</span>
    </nav>

    <header class="hero">
      <p class="kicker">GLOSSARY · {TERMS.length} TERMS</p>
      <h1 class="display">What the words mean.</h1>
      <p class="dek">
        Every PointCast-specific term in one place. Each has a stable anchor
        URL — cite <code>/glossary#&lt;slug&gt;</code> when referring to a
        concept. Machine-readable via inline <code>DefinedTermSet</code>
        JSON-LD.
      </p>
    </header>

    <nav class="toc" aria-label="Category table of contents">
      {grouped.map((g) => (
        <a class="toc__chip" href={`#cat-${g.slug}`}>
          <span class="mono">{g.code}</span>
          <span>{g.label}</span>
          <span class="toc__count mono">{g.terms.length}</span>
        </a>
      ))}
    </nav>

    {grouped.map((g) => (
      <section class="cat" id={`cat-${g.slug}`}>
        <header class="cat__head">
          <p class="cat__code mono">{g.code} · {g.label.toUpperCase()}</p>
          <p class="cat__note">{g.note}</p>
        </header>
        <dl class="terms">
          {g.terms.map((t) => (
            <div class="term">
              <dt id={t.slug} class="term__dt">
                <a href={`#${t.slug}`} class="term__anchor" aria-label="Permalink">#</a>
                <span class="term__name">{t.term}</span>
                <code class="term__slug mono">{t.slug}</code>
              </dt>
              <dd class="term__dd">
                <p>{t.definition}</p>
                {(t.seeAlso || t.canonicalUrl) && (
                  <p class="term__meta mono">
                    {t.canonicalUrl && (
                      <a href={t.canonicalUrl} class="term__canon">CANONICAL ↗</a>
                    )}
                    {t.seeAlso && t.seeAlso.length > 0 && (
                      <>
                        {t.canonicalUrl && <span class="term__meta-sep">·</span>}
                        SEE ALSO {t.seeAlso.map((s, i) => (
                          <>
                            {i > 0 && <span class="term__meta-comma">,</span>}
                            <a href={`#${s}`} class="term__see">{s}</a>
                          </>
                        ))}
                      </>
                    )}
                  </p>
                )}
              </dd>
            </div>
          ))}
        </dl>
      </section>
    ))}

    <aside class="surfaces">
      <p class="kicker">RELATED</p>
      <ul class="surfaces__list">
        <li><a href="/manifesto"><span class="mono">CANONICAL</span> /manifesto</a></li>
        <li><a href="/for-agents"><span class="mono">ENDPOINTS</span> /for-agents</a></li>
        <li><a href="/agents.json"><span class="mono">JSON</span> /agents.json</a></li>
        <li><a href="/stack"><span class="mono">TECH</span> /stack</a></li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<style>
  .page {
    max-width: 820px;
    margin: 0 auto;
    padding: 18px 16px 80px;
  }

  .mono {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .kicker {
    font-family: var(--pc-font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin: 0 0 8px;
  }

  .crumb {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin-bottom: 18px;
    display: flex;
    gap: 8px;
  }

  .hero {
    margin-bottom: 22px;
    padding-bottom: 16px;
    border-bottom: 1.5px solid var(--pc-ink);
  }

  .display {
    font-family: var(--pc-font-sans);
    font-size: clamp(2.2rem, 8.5vw, 3.8rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }

  .dek {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.5;
    color: var(--pc-ink-soft);
    max-width: 56ch;
  }

  .dek code {
    font-family: var(--pc-font-mono);
    font-size: 13px;
    padding: 1px 5px;
    background: var(--pc-rule-soft);
    border-radius: 2px;
  }

  .toc {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 24px;
  }

  .toc__chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    border: 1px solid var(--pc-rule);
    border-radius: 2px;
    background: #fff;
    color: var(--pc-ink);
    font-size: 12px;
    font-weight: 500;
    transition: border-color 0.1s, background-color 0.1s;
  }

  .toc__chip:hover {
    border-color: var(--pc-ink);
    background: #fafaf8;
    text-decoration: none;
  }

  .toc__chip .mono {
    color: var(--pc-accent);
    font-size: 9.5px;
  }

  .toc__count {
    color: var(--pc-ink-muted);
    font-size: 9.5px;
  }

  .cat {
    margin-bottom: 26px;
    scroll-margin-top: 16px;
  }

  .cat__head {
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--pc-rule);
  }

  .cat__code {
    margin: 0 0 4px;
    color: var(--pc-accent);
    font-size: 10.5px;
    letter-spacing: 0.18em;
  }

  .cat__note {
    margin: 0;
    font-size: 13px;
    color: var(--pc-ink-soft);
  }

  .terms {
    display: grid;
    gap: 16px;
    margin: 0;
  }

  .term {
    padding: 12px 0;
    border-bottom: 1px dashed var(--pc-rule-soft);
    display: grid;
    gap: 6px;
  }

  .term:last-child {
    border-bottom: 0;
  }

  .term__dt {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    scroll-margin-top: 20px;
  }

  .term__anchor {
    color: var(--pc-ink-muted);
    font-family: var(--pc-font-mono);
    font-size: 14px;
    text-decoration: none;
    flex-shrink: 0;
    font-weight: 400;
  }

  .term__anchor:hover {
    color: var(--pc-accent);
  }

  .term__dt:target .term__anchor {
    color: var(--pc-accent);
  }

  .term__name {
    font-family: var(--pc-font-sans);
    font-size: 17px;
    font-weight: 500;
    color: var(--pc-ink);
  }

  .term__dt:target .term__name {
    color: var(--pc-accent);
  }

  .term__slug {
    color: var(--pc-ink-muted);
    font-size: 9.5px;
    padding: 1px 5px;
    background: var(--pc-rule-soft);
    border-radius: 2px;
    text-transform: none;
    letter-spacing: 0.04em;
  }

  .term__dd {
    margin: 0;
    padding-left: 24px;
    display: grid;
    gap: 6px;
  }

  .term__dd p {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--pc-ink-soft);
  }

  .term__meta {
    color: var(--pc-ink-muted);
    font-size: 9.5px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 8px;
    align-items: baseline;
  }

  .term__meta-sep {
    color: var(--pc-rule);
  }

  .term__meta-comma {
    color: var(--pc-ink-muted);
    margin-left: -4px;
  }

  .term__canon {
    color: var(--pc-accent);
  }

  .term__see {
    color: var(--pc-accent);
  }

  .term__see:hover {
    color: var(--pc-ink);
  }

  .surfaces {
    margin-top: 32px;
    padding: 14px;
    border: 1px solid var(--pc-rule);
    border-radius: 2px;
    background: #fafaf8;
  }

  .surfaces__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px 14px;
  }

  .surfaces__list a {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--pc-accent);
    padding: 4px 0;
  }

  .surfaces__list .mono {
    color: var(--pc-ink-muted);
    min-width: 80px;
  }

  @media (min-width: 640px) {
    .surfaces__list {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 480px) {
    .term__dd {
      padding-left: 0;
    }
  }
</style>
