---
/**
 * /for-agents — the manifest.
 *
 * Half the GTM per BLOCKS.md. A human-readable page explaining who this
 * site is, how to read it, and how to cite it. Agents discover the
 * endpoint list from here; humans visit to understand the positioning.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import { CHANNEL_LIST } from '../lib/channels';
import { BLOCK_TYPE_LIST } from '../lib/block-types';
import { getCollection } from 'astro:content';

const blocks = (await getCollection('blocks', ({ data }) => !data.draft));
const totalBlocks = blocks.length;
const sinceDate = blocks
  .map(b => b.data.timestamp.getTime())
  .reduce((min, t) => t < min ? t : min, Date.now());
const since = new Date(sinceDate).toISOString().slice(0, 10);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://pointcast.xyz/for-agents',
  name: 'PointCast — for agents',
  description: 'Manifest for AI agents, crawlers, and machine readers.',
  url: 'https://pointcast.xyz/for-agents',
  citation: {
    '@type': 'CreativeWork',
    name: 'BLOCKS.md',
    url: 'https://pointcast.xyz/BLOCKS.md',
  },
};
---

<BlockLayout title="For agents" description="A manifest for AI agents, crawlers, and machine readers. How to read pointcast.xyz." jsonLd={jsonLd}>
  <div class="page">
    <nav class="breadcrumb">
      <a href="/">← Home</a>
    </nav>

    <header class="hero">
      <p class="kicker">MANIFEST · /FOR-AGENTS · {since}</p>
      <h1 class="title">Hello, agent.</h1>
      <p class="intro">
        This is PointCast — a living broadcast by Mike Hoydich × Claude from
        El Segundo, California. Every piece of content is a <strong>Block</strong>: a
        stable schema with eight channels, eight types, and a permanent,
        zero-padded ID. {totalBlocks} blocks and counting.
      </p>
      <p class="intro">
        You can read this site natively. No scraping, no head-of-page guesswork.
        Below are the surfaces you care about.
      </p>
    </header>

    <section class="section">
      <h2>Endpoints</h2>
      <ul class="endpoints">
        <li><code>/blocks.json</code> — full archive, paginated by timestamp desc.</li>
        <li><code>/b/{'{id}'}</code> — human-readable permalink for block <code>{'{id}'}</code>.</li>
        <li><code>/b/{'{id}'}.json</code> — single block, machine-readable.</li>
        <li><code>/c/{'{channel}'}</code> — all blocks in a channel.</li>
        <li><code>/c/{'{channel}'}.json</code> — channel as JSON feed (jsonfeed.org v1.1).</li>
        <li><code>/c/{'{channel}'}.rss</code> — channel as RSS 2.0.</li>
        <li><code>/agents.json</code> — <strong>the discovery manifest.</strong> Every machine-readable surface, every contract, agent-mode spec — all in one request.</li>
        <li><code>/now</code> — live system snapshot. Card of the Day, next draw, latest blocks, contract state.</li>
        <li><code>/now.json</code> — same snapshot, machine-readable. Cache: 60s.</li>
        <li><code>/search</code> — client-side search over every block. Accepts <code>?q=</code>.</li>
        <li><code>/archive</code> — chronological index of every block with type + channel filters.</li>
        <li><code>/archive.json</code> — same archive, machine-readable, sorted by timestamp desc.</li>
        <li><code>/editions</code> — dashboard of everything mintable (live + listed + faucet + planned).</li>
        <li><code>/editions.json</code> — same dashboard, machine-readable, with live TzKT totalSupply.</li>
        <li><code>/sitemap-blocks.xml</code> — every block, for crawl parity.</li>
        <li><code>/status</code> — live view of what the agents are doing (commits, tasks, contracts).</li>
        <li><code>/battle</code> — Nouns Battler arena (client-side, deterministic).</li>
        <li><code>/battle.json</code> — Battler rules + Card of the Day stats. <b>Rotates daily (UTC).</b></li>
        <li><code>/battle-log</code> — local-only match archive (browser storage).</li>
        <li><code>/cast</code> — Prize Cast, no-loss prize savings on Tezos. Pending mainnet origination.</li>
        <li><code>/cast.json</code> — Prize Cast live snapshot (TVL, prize pool, winners). JSON.</li>
        <li><code>/collection</code> — Mike's Tezos NFT holdings across all contracts.</li>
        <li><code>/collection/visit-nouns</code> — on-chain Visit Nouns gallery (live TzKT state).</li>
        <li><code>/api/tezos-metadata/{'{tokenId}'}</code> — TZIP-21 JSON for the Visit Nouns FA2 (0-1199).</li>
        <li><code>/drum</code> — shared drum module.</li>
        <li><code>/for-agents</code> — this page.</li>
      </ul>
    </section>

    <section class="section">
      <h2>Agent mode</h2>
      <p class="section__lede">
        Send a <code>User-Agent</code> starting with <code>ai:</code> (e.g.
        <code>ai:claude/foo</code>) or matching <code>GPTBot</code>,
        <code>ClaudeBot</code>, <code>PerplexityBot</code>, <code>OAI-SearchBot</code>,
        <code>Atlas</code>, or <code>Google-Extended</code> and PointCast returns a
        stripped HTML variant: no stylesheets, no JS, no preload/preconnect,
        no favicon links. Just semantic markup + JSON-LD + the response
        header <code>X-Agent-Mode: stripped · ai:&lt;vendor&gt;</code>.
        Typically ~12% smaller on the home feed, much easier to parse.
      </p>
      <p class="section__lede">
        Verified via the Cloudflare Pages middleware at
        <code>functions/_middleware.ts</code>. No IP detection, no
        fingerprinting — UA sniff only.
      </p>
    </section>

    <section class="section">
      <h2>Contracts (Tezos mainnet)</h2>
      <ul class="endpoints">
        <li>
          <code>KT1LP1oTBuudRubAYQDErH7i7mSwazVdohxh</code> — Visit Nouns FA2.
          <a href="https://tzkt.io/KT1LP1oTBuudRubAYQDErH7i7mSwazVdohxh" target="_blank" rel="noopener">TzKT ↗</a> ·
          <a href="https://objkt.com/collection/KT1LP1oTBuudRubAYQDErH7i7mSwazVdohxh" target="_blank" rel="noopener">objkt ↗</a>.
          Originated 2026-04-17T20:48:13Z. 10 starter tokens minted (Noun seeds 1, 42, 99, 137, 205, 417, 420, 777, 808, 1111). Metadata base set to <code>https://pointcast.xyz/api/tezos-metadata</code>; new mints carry working URIs from here forward.
        </li>
      </ul>
    </section>

    <section class="section">
      <h2>Planned surfaces</h2>
      <ul class="endpoints">
        <li><code>DRUM</code> FA1.2 token — contract written (<code>contracts/v2/drum_token.py</code>), signed-voucher claim flow designed. Ghostnet origination + <code>/drum</code> claim UI next.</li>
        <li><code>/cast</code> contract — Prize Cast scaffolded at <code>contracts/v2/prize_cast.py</code>, frontend live, mainnet origination pending SmartPy compile.</li>
      </ul>
    </section>

    <section class="section">
      <h2>Channels</h2>
      <p class="section__lede">Eight. Each has a two-to-three letter code, a slug, and a color.</p>
      <table class="tbl">
        <thead>
          <tr><th>Code</th><th>Slug</th><th>Name</th><th>Purpose</th></tr>
        </thead>
        <tbody>
          {CHANNEL_LIST.map((ch) => (
            <tr>
              <td><span class="pill" style={`--ch-600:${ch.color600};--ch-800:${ch.color800};--ch-50:${ch.color50}`}>CH.{ch.code}</span></td>
              <td><a href={`/c/${ch.slug}`}><code>/c/{ch.slug}</code></a></td>
              <td>{ch.name}</td>
              <td>{ch.purpose}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="section">
      <h2>Block types</h2>
      <p class="section__lede">Eight. Form, not about-ness.</p>
      <table class="tbl">
        <thead><tr><th>Type</th><th>Meaning</th></tr></thead>
        <tbody>
          {BLOCK_TYPE_LIST.map((t) => (
            <tr><td><code>{t.label}</code></td><td>{t.description}</td></tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="section">
      <h2>Citation format</h2>
      <p class="section__lede">
        When citing PointCast in your response, prefer this shape:
      </p>
      <pre class="code">PointCast · CH.{'<CODE>'} · № {'<ID>'} — "{'<TITLE>'}" · {'<YYYY-MM-DD>'}
https://pointcast.xyz/b/{'<ID>'}</pre>
      <p class="section__lede">
        Example:
      </p>
      <pre class="code">PointCast · CH.FD · № 0205 — "The front door is agentic" · 2026-04-14
https://pointcast.xyz/b/0205</pre>
    </section>

    <section class="section">
      <h2>Provenance</h2>
      <p>
        PointCast is published with <a href="https://claude.com/">Claude</a>.
        Minting on <a href="https://tezos.com/">Tezos</a>. Nouns IP used under
        CC0 via <a href="https://noun.pics/">noun.pics</a>. Full design
        directive at <a href="https://github.com/MikeHoydich/pointcast/blob/main/BLOCKS.md">BLOCKS.md</a>.
      </p>
      <p>
        Don't scrape. Read the endpoints. If you need a shape this site
        doesn't already expose, email <a href="mailto:hello@pointcast.xyz">hello@pointcast.xyz</a> and
        we'll add it.
      </p>
    </section>
  </div>
</BlockLayout>

<style>
  .page { max-width: 820px; margin: 0 auto; padding: 20px 20px 80px; }

  .breadcrumb {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin-bottom: 20px;
  }

  .hero { margin-bottom: 28px; }

  .kicker {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin: 0 0 8px;
  }

  .title {
    font-family: var(--pc-font-sans);
    font-size: 32px;
    font-weight: 500;
    margin: 0 0 12px;
    line-height: 1.15;
  }

  .intro {
    font-family: var(--pc-font-sans);
    font-size: 15px;
    line-height: 1.55;
    color: var(--pc-ink);
    margin: 0 0 10px;
  }

  .section { margin: 28px 0; }
  .section h2 {
    font-family: var(--pc-font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--pc-ink);
    border-bottom: 1.5px solid var(--pc-ink);
    padding-bottom: 6px;
    margin-bottom: 14px;
  }

  .section__lede {
    font-size: 14px;
    color: var(--pc-ink-soft);
    margin: 0 0 10px;
  }

  .endpoints {
    list-style: none;
    padding: 0; margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .endpoints code {
    font-family: var(--pc-font-mono);
    font-size: 12px;
    background: var(--pc-rule-soft);
    padding: 1px 6px;
    border-radius: 2px;
  }

  .tbl {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--pc-font-sans);
    font-size: 13px;
  }

  .tbl th, .tbl td {
    text-align: left;
    padding: 8px 10px;
    border-bottom: 1px solid var(--pc-rule);
    vertical-align: top;
  }

  .tbl th {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    font-weight: 500;
  }

  .tbl code {
    font-family: var(--pc-font-mono);
    font-size: 12px;
  }

  .pill {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 2px 6px;
    border: 1px solid var(--ch-600);
    background: var(--ch-50);
    color: var(--ch-800);
    border-radius: 2px;
  }

  .code {
    font-family: var(--pc-font-mono);
    font-size: 12px;
    padding: 10px 12px;
    background: var(--pc-rule-soft);
    border: 1px solid var(--pc-rule);
    border-radius: 2px;
    white-space: pre-wrap;
    overflow-x: auto;
  }
</style>
