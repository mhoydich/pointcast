---
/**
 * /race/front-door — the launch race scaffold.
 *
 * Per RFC 0002 section "The first race: Front Door."
 *
 * Phase 1: static state card, countdown-placeholder, "how to enter" copy,
 * empty leaderboard. No KV, no client instrumentation, no live data.
 * Phase 2 wires arrive/engage events + KV-backed leaderboard.
 */
import BlockLayout from '../../layouts/BlockLayout.astro';

const title = 'Front Door — the launch race';
const description = 'The first PointCast race. Land on /, click your first block, lowest ms wins. Scaffold per RFC 0002.';
const canonical = 'https://pointcast.xyz/race/front-door';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsEvent',
  '@id': canonical,
  name: 'PointCast · Front Door',
  description,
  url: canonical,
  sport: 'PointCast broadcast race',
  eventStatus: 'EventScheduled',
  location: {
    '@type': 'Place',
    name: 'El Segundo, CA (default node)',
    url: 'https://pointcast.xyz/local',
  },
  about: ['race', 'front door', 'fastest', 'pointcast', 'gamgee'],
};
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="fd">
    <nav class="fd__crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <a href="/race">race</a>
      <span aria-hidden="true">›</span>
      <span>front-door</span>
    </nav>

    <header class="fd__hero">
      <p class="fd__kicker mono">RACE · FRONT DOOR · PHASE 1 SCAFFOLD</p>
      <h1 class="fd__title">Front Door.</h1>
      <p class="fd__dek">
        The launch race. Land on <code class="mono">/</code>, click your first block,
        lowest milliseconds wins. Daily reset at midnight Pacific. Anon-friendly
        — nounId, wallet, or session all count.
      </p>
    </header>

    <section class="fd__state">
      <div class="fd__status-card">
        <p class="fd__status-label mono">STATUS · SCHEDULED</p>
        <p class="fd__status-line">Opens on Gamgee 1.0 launch day.</p>
        <p class="fd__status-lede">
          The schema, the routes, and this page are the scaffold. The arrive+engage
          instrumentation, the KV leaderboard, and the live countdown land in
          Phase 2 per <a href="https://github.com/mhoydich/pointcast/blob/main/docs/rfc/0002-race-system.md">RFC 0002</a>.
        </p>
      </div>
    </section>

    <section class="fd__how">
      <h2 class="fd__h2">How to enter (Phase 2+)</h2>
      <ol class="fd__steps">
        <li>
          <strong>Land.</strong> Open <a href="/"><code class="mono">pointcast.xyz/</code></a>.
          The client emits <code class="mono">race:front-door:arrive</code>.
        </li>
        <li>
          <strong>Click.</strong> Tap the first BlockCard that catches you. The
          client emits <code class="mono">race:front-door:engage</code>.
        </li>
        <li>
          <strong>Score.</strong> Server computes <code class="mono">engage.ts - arrive.ts</code> in ms.
          Lower is better.
        </li>
        <li>
          <strong>Tune in.</strong> Leaderboard resolves at 23:59:59 Pacific. Winner's
          nounId lights up the home strip the next day.
        </li>
      </ol>
      <p class="fd__fine-print">
        One entry per entrant per day. Per-IP rate limit. Subsequent visits on the
        same day don't overwrite your best time (best-of-the-day stands).
      </p>
    </section>

    <section class="fd__leaderboard">
      <h2 class="fd__h2">Leaderboard</h2>
      <div class="fd__board">
        <p class="fd__board-empty mono">NO ENTRIES YET · RACE OPENS ON GAMGEE 1.0 LAUNCH</p>
        <ol class="fd__board-list" aria-label="Front Door leaderboard (empty, scheduled)">
          <li><span class="rank mono">1</span><span class="entrant">—</span><span class="score mono">— ms</span></li>
          <li><span class="rank mono">2</span><span class="entrant">—</span><span class="score mono">— ms</span></li>
          <li><span class="rank mono">3</span><span class="entrant">—</span><span class="score mono">— ms</span></li>
          <li><span class="rank mono">4</span><span class="entrant">—</span><span class="score mono">— ms</span></li>
          <li><span class="rank mono">5</span><span class="entrant">—</span><span class="score mono">— ms</span></li>
        </ol>
      </div>
    </section>

    <section class="fd__meta">
      <h2 class="fd__h2">Race spec</h2>
      <dl class="fd__dl">
        <dt>Mode</dt><dd><code class="mono">fastest</code></dd>
        <dt>Channel</dt><dd><code class="mono">FD</code> · Front Door</dd>
        <dt>Opens</dt><dd>Midnight Pacific, each race day</dd>
        <dt>Closes</dt><dd>23:59:59 Pacific, same day</dd>
        <dt>Resolves</dt><dd>Midnight Pacific, the next day</dd>
        <dt>Prize (v1)</dt><dd>Attribution — winner's nounId on home strip next day</dd>
        <dt>Archive</dt><dd><code class="mono">src/data/races/front-door-{'{YYYY-MM-DD}'}.json</code></dd>
      </dl>
    </section>

    <footer class="fd__foot mono">
      <span>PHASE 1 · SCAFFOLD · 2026-04-23 · EL SEGUNDO · RFC 0002</span>
    </footer>
  </main>
</BlockLayout>

<style>
  .fd {
    max-width: 760px;
    margin: 0 auto;
    padding: 24px 20px 72px;
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    color: #121116;
  }
  .mono { font-family: 'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, monospace; }

  .fd__crumb {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #5f5e5a;
    margin-bottom: 22px;
  }
  .fd__crumb a { color: inherit; text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 1px; }
  .fd__crumb span { margin: 0 6px; }

  .fd__hero { padding-bottom: 24px; border-bottom: 2px solid #1a1a22; margin-bottom: 28px; }
  .fd__kicker {
    font-size: 10.5px;
    letter-spacing: 0.24em;
    font-weight: 700;
    color: #2f8f5f;
    margin: 0 0 10px;
  }
  .fd__title {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: clamp(44px, 8vw, 72px);
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0 0 14px;
    font-weight: 400;
  }
  .fd__dek {
    font-family: Georgia, serif;
    font-size: 16px;
    line-height: 1.55;
    margin: 0;
    max-width: 60ch;
    color: #38373a;
  }
  .fd__dek code { font-size: 12.5px; background: rgba(18,17,22,0.07); padding: 1px 5px; border-radius: 2px; }

  .fd__state { margin: 0 0 28px; }
  .fd__status-card {
    padding: 22px 20px 20px;
    background: #f3f9f4;
    border: 1px solid #d1e4d6;
    border-top: 4px solid #2f8f5f;
    border-radius: 3px;
  }
  .fd__status-label {
    font-size: 10.5px;
    letter-spacing: 0.22em;
    font-weight: 700;
    color: #2f8f5f;
    margin: 0 0 8px;
  }
  .fd__status-line {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: 22px;
    line-height: 1.2;
    margin: 0 0 10px;
    color: #1a1a22;
  }
  .fd__status-lede {
    font-family: Georgia, serif;
    font-size: 14px;
    line-height: 1.55;
    margin: 0;
    color: #38373a;
  }
  .fd__status-lede a { color: #8a2432; }

  .fd__h2 {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: 22px;
    font-weight: 400;
    margin: 0 0 14px;
  }

  .fd__steps {
    padding-left: 20px;
    margin: 0 0 14px;
    font-family: Georgia, serif;
    font-size: 14.5px;
    line-height: 1.55;
    color: #1a1a22;
  }
  .fd__steps li { margin-bottom: 8px; }
  .fd__steps code { font-size: 12.5px; background: rgba(18,17,22,0.07); padding: 1px 5px; border-radius: 2px; }
  .fd__steps a { color: #8a2432; }
  .fd__fine-print { font-family: Georgia, serif; font-size: 12.5px; line-height: 1.5; color: #5f5e5a; margin: 0; font-style: italic; }

  .fd__how, .fd__leaderboard, .fd__meta { margin: 0 0 32px; padding-bottom: 24px; border-bottom: 1px solid #e5e3de; }

  .fd__board {
    padding: 18px 18px 14px;
    background: #fafaf7;
    border: 1px solid #e5e3de;
    border-radius: 3px;
  }
  .fd__board-empty {
    font-size: 10px;
    letter-spacing: 0.2em;
    font-weight: 700;
    color: #8a2432;
    margin: 0 0 14px;
    text-align: center;
  }
  .fd__board-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .fd__board-list li {
    display: grid;
    grid-template-columns: 30px 1fr auto;
    gap: 10px;
    align-items: baseline;
    padding: 6px 0;
    border-bottom: 1px dashed #e5e3de;
  }
  .fd__board-list li:last-child { border-bottom: 0; }
  .fd__board-list .rank { font-size: 11px; font-weight: 700; color: #5f5e5a; }
  .fd__board-list .entrant { font-family: Georgia, serif; font-size: 14px; color: #1a1a22; }
  .fd__board-list .score { font-size: 11px; color: #5f5e5a; }

  .fd__dl {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 8px 14px;
    font-family: Georgia, serif;
    font-size: 13.5px;
    margin: 0;
  }
  .fd__dl dt {
    font-family: var(--pc-font-mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #5f5e5a;
    font-weight: 700;
    align-self: baseline;
  }
  .fd__dl dd { margin: 0; color: #1a1a22; }
  .fd__dl code { font-size: 12.5px; background: rgba(18,17,22,0.07); padding: 1px 5px; border-radius: 2px; }

  .fd__foot {
    font-size: 10.5px;
    letter-spacing: 0.18em;
    color: #5f5e5a;
  }
</style>
