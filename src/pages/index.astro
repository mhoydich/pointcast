---
/**
 * pointcast.xyz v2 — home grid.
 *
 * Every content surface is a Block (per BLOCKS.md). The home page is a
 * dense auto-fit grid of BlockCards, most recent first. Size variants
 * are honored on desktop; mobile collapses to a single column with a
 * sticky channel chip bar at top.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import BlockCard from '../components/BlockCard.astro';
import BlockReorder from '../components/BlockReorder.astro';
import PresenceBar from '../components/PresenceBar.astro';
import WalletChip from '../components/WalletChip.astro';
import HomeMajors from '../components/HomeMajors.astro';
import FreshDeck from '../components/FreshDeck.astro';
// PollsOnHome removed from home 2026-04-20 21:30 PT (Phase 3 collapse) —
// polls live in ActionDrawers now. Component file stays on disk for /polls.
// MoodChip import removed 2026-04-20 15:30 PT per Mike: "have this in
// the bar, and then once you select it goes away, ... mood is gone from
// the homepage". Mood selection now lives in CoNavigator's left zone —
// the inline mood picker popover opens when the mood chip is tapped
// before a mood is set. File src/components/MoodChip.astro stays on
// disk in case the top-of-home surface returns.
import FreshStrip from '../components/FreshStrip.astro';
import VisitorHereStrip from '../components/VisitorHereStrip.astro';
import NetworkStrip from '../components/NetworkStrip.astro';
import TodayOnPointCast from '../components/TodayOnPointCast.astro';
// DailyDropStrip removed from home 2026-04-20 21:30 PT (Phase 3 collapse)
// — daily drop lives in ActionDrawers. Component file stays on disk.
// SportsStrip moved to /sports 2026-04-20 21:30 PT — dedicated page;
// import stays so /sports can keep rendering the same component.
import SportsStrip from '../components/SportsStrip.astro';
// ComputeStrip was already collapsed into PulseStrip Phase 1 — import
// kept for future dedicated surface; PingStrip removed from home
// 2026-04-20 21:30 PT (Phase 3 collapse) in favor of ActionDrawers.
import PulseStrip from '../components/PulseStrip.astro';
import HeroBlock from '../components/HeroBlock.astro';
import TopOfMorning from '../components/TopOfMorning.astro';
import ActionDrawers from '../components/ActionDrawers.astro';
import TankStrip from '../components/TankStrip.astro';
import GamgeeFrontDoor from '../components/GamgeeFrontDoor.astro';
// Phase 1 of home rethink 2026-04-20 18:20 PT: StateStrip + FreshStrip
// + VisitorHereStrip + ComputeStrip collapse into one PulseStrip.
// These components stay on disk in case the expanded surfaces get their
// own pages later (e.g. /state for the full state-strip view).
// import StateStrip from '../components/StateStrip.astro';
// import FreshStrip from '../components/FreshStrip.astro';
// import VisitorHereStrip from '../components/VisitorHereStrip.astro';
// import ComputeStrip from '../components/ComputeStrip.astro';
import MorningPara from '../components/MorningPara.astro';

// Removed 2026-04-19 21:55 PT per Mike: "six things isn't working,
// morning brief isn't working, novice voter isn't working, remove
// for now". Old MorningBrief, TodayStrip, VoterStats components still
// on disk; not imported. Can return when a new shape is agreed.
import { CHANNEL_LIST } from '../lib/channels';
import { getCollection } from 'astro:content';

const blocks = (await getCollection('blocks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

const blockCount = blocks.length;
const homeDescription = `PointCast is an agent-native broadcast from El Segundo — ${blockCount} Blocks, stable machine surfaces, and the Gamgee release train for humans, agents, and builders.`;

// SEO: emit an @graph with CollectionPage + SiteNavigationElement so
// Google gets an explicit site-structure signal. The nav element lists
// the 9 channels plus the 3 SEO pillars (/el-segundo, /agent-native,
// /nouns) and the major tools (/manifesto, /glossary, /archive) — the
// primary navigation crawlers should treat as the skeleton of the site.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      '@id': 'https://pointcast.xyz/#home',
      name: 'PointCast Gamgee front door',
      description: homeDescription,
      url: 'https://pointcast.xyz/',
      inLanguage: 'en-US',
      isPartOf: { '@type': 'WebSite', '@id': 'https://pointcast.xyz/#website' },
      hasPart: blocks.slice(0, 20).map((b) => ({
        '@type': 'CreativeWork',
        '@id': `https://pointcast.xyz/b/${b.data.id}`,
        name: b.data.title,
        datePublished: b.data.timestamp.toISOString(),
        url: `https://pointcast.xyz/b/${b.data.id}`,
      })),
    },
    // Primary navigation — channels, pillars, tools. Google treats
    // SiteNavigationElement as a hint about what the site's top-level
    // structure actually is (vs. all the incidental internal links).
    {
      '@type': 'SiteNavigationElement',
      '@id': 'https://pointcast.xyz/#nav-channels',
      name: 'Channels',
      hasPart: CHANNEL_LIST.map((c) => ({
        '@type': 'SiteNavigationElement',
        name: c.name,
        description: c.intro ?? c.purpose,
        url: `https://pointcast.xyz/c/${c.slug}`,
      })),
    },
    {
      '@type': 'SiteNavigationElement',
      '@id': 'https://pointcast.xyz/#nav-pillars',
      name: 'Pillars',
      hasPart: [
        { '@type': 'SiteNavigationElement', name: 'El Segundo', url: 'https://pointcast.xyz/el-segundo', description: 'Local SEO pillar for El Segundo, California (ZIP 90245) — things to do, South Bay creative/tech scene, the 25-mile beacon.' },
        { '@type': 'SiteNavigationElement', name: 'Agent-native', url: 'https://pointcast.xyz/agent-native', description: 'How PointCast implements llms.txt, agents.json, stripped-HTML crawl mode, Content-Signals, and Farcaster Frames.' },
        { '@type': 'SiteNavigationElement', name: 'Nouns on Tezos', url: 'https://pointcast.xyz/nouns', description: 'Visit Nouns FA2 open-supply NFT, Nouns Battler deterministic fighter, and CC0 proliferation culture on Tezos.' },
      ],
    },
    {
      '@type': 'SiteNavigationElement',
      '@id': 'https://pointcast.xyz/#nav-tools',
      name: 'Tools',
      hasPart: [
        { '@type': 'SiteNavigationElement', name: 'Manifesto', url: 'https://pointcast.xyz/manifesto' },
        { '@type': 'SiteNavigationElement', name: 'Start here', url: 'https://pointcast.xyz/start' },
        { '@type': 'SiteNavigationElement', name: 'Share kit', url: 'https://pointcast.xyz/share' },
        { '@type': 'SiteNavigationElement', name: 'Glossary', url: 'https://pointcast.xyz/glossary' },
        { '@type': 'SiteNavigationElement', name: 'Archive', url: 'https://pointcast.xyz/archive' },
        { '@type': 'SiteNavigationElement', name: 'Resources', url: 'https://pointcast.xyz/resources' },
        { '@type': 'SiteNavigationElement', name: 'For agents', url: 'https://pointcast.xyz/for-agents' },
      ],
    },
  ],
};

const alternates = [
  { type: 'application/json', href: '/blocks.json', title: 'All blocks (JSON)' },
  { type: 'application/rss+xml', href: '/feed.xml', title: 'PointCast (RSS · all blocks)' },
  { type: 'application/feed+json', href: '/feed.json', title: 'PointCast (JSON Feed 1.1)' },
  ...CHANNEL_LIST.map((c) => ({
    type: 'application/rss+xml',
    href: `/c/${c.slug}.rss`,
    title: `PointCast · ${c.name} (RSS)`,
  })),
];
---

<BlockLayout
  title="Home"
  description={homeDescription}
  jsonLd={jsonLd}
  alternates={alternates}
  frame={{
    image: 'https://pointcast.xyz/images/og/og-home-v2.png',
    buttons: [
      { label: 'Open /gamgee', action: 'link', target: 'https://pointcast.xyz/gamgee' },
      { label: 'Open /now', action: 'link', target: 'https://pointcast.xyz/now' },
      { label: '/for-agents', action: 'link', target: 'https://pointcast.xyz/for-agents' },
      { label: '/agents.json', action: 'link', target: 'https://pointcast.xyz/agents.json' },
    ],
  }}
>
  <div class="page">

    <h1 class="sr-only">PointCast Gamgee — an agent-native broadcast from El Segundo with human and machine-readable paths.</h1>

    <!-- Masthead — one line. Wordmark, block count, current time, agent link. -->
    <header class="masthead">
      <a href="/" class="wordmark" aria-label="PointCast home">POINTCAST</a>
      <span class="sep" aria-hidden="true">·</span>
      <span class="meta">{blockCount} BLOCKS</span>
      <span class="sep" aria-hidden="true">·</span>
      <time class="meta time" id="pc-clock">— : —</time>
      <PresenceBar />
      <span class="spacer" aria-hidden="true"></span>
      <WalletChip />
      <a href="/for-agents" class="agent-link">/for-agents →</a>
    </header>

    <GamgeeFrontDoor blockCount={blockCount} />

    <!-- Hero Block — Phase 2 of home rethink. Daily deterministic pick
         from a curated pool rendered as a full editorial card above
         everything else. Codex shipped 2026-04-20 17:40 PT (3rd Codex
         single-file win of the night). Plan: docs/plans/2026-04-20-
         home-rethink.md Option A Phase 2. -->
    <HeroBlock />

    <!-- TOP OF THE MORNING — 3 auto-curated fresh blocks from the last 24h,
         sits right under the hero. Sprint #91 Theme E-1 (2026-04-21). -->
    <TopOfMorning />

    <!-- PULSE — one-line home signal strip. Phase 1 of home rethink
         (docs/plans/2026-04-20-home-rethink.md, Option A). Collapses
         five prior strips (StateStrip + FreshStrip + VisitorHereStrip
         + ComputeStrip + masthead-PresenceBar) into one scannable line
         answering "is PointCast alive right now?" Signals: n here · cc
         working/idle · last ship · next ship · you last back. -->
    <PulseStrip />

    {/* PingStrip removed 2026-04-20 21:30 PT (Phase 3 collapse) — the
        ping composer lives in ActionDrawers at the bottom of home now,
        and in /cos which is a dedicated phone surface. Also in the
        CoNavigator bar bench→ping chip. Three places is enough. */}

    {/* MoodChip removed from home 2026-04-20 15:30 PT per Mike: "have
        this in the bar, and then once you select it goes away ... mood
        is gone from the homepage". Mood selection is now an inline
        popover in CoNavigator's left zone. */}

    {/* FreshStrip / VisitorHereStrip / ComputeStrip / StateStrip all
        collapsed into PulseStrip above — Phase 1 of home rethink per
        docs/plans/2026-04-20-home-rethink.md. Components stay on disk
