---
/**
 * pointcast.xyz v2 — home grid.
 *
 * Every content surface is a Block (per BLOCKS.md). The home page is a
 * dense CSS grid of BlockCards, most recent first. Size variants are
 * honored on desktop (2x1, 2x2, 3x2 etc.); mobile collapses to a single
 * column and tablet to two columns.
 *
 * No sidebar. No top nav. Channel colors ARE the navigation — the reader
 * learns the colors and navigates by them.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BlockCard from '../components/BlockCard.astro';
import { CHANNEL_LIST } from '../lib/channels';
import { getCollection } from 'astro:content';

const blocks = (await getCollection('blocks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

const blockCount = blocks.length;
---

<BaseLayout title="PointCast v2" description="A living broadcast from El Segundo — dispatches, faucets, visits, and mints on Tezos. Mike Hoydich × Claude.">
  <div class="page">

    <!-- Masthead — one line. Wordmark, block count, current time. -->
    <header class="masthead">
      <a href="/" class="wordmark">POINTCAST</a>
      <span class="masthead__sep" aria-hidden="true">·</span>
      <span class="masthead__meta">{blockCount} BLOCKS</span>
      <span class="masthead__sep" aria-hidden="true">·</span>
      <time class="masthead__meta masthead__time" id="pc-clock">— : —</time>
      <span class="masthead__sep masthead__sep--wide" aria-hidden="true"></span>
      <a href="/for-agents" class="masthead__agent-link">/for-agents →</a>
    </header>

    <!-- Channel legend — tappable chips, also a visual glossary. -->
    <nav class="channels" aria-label="Channels">
      {CHANNEL_LIST.map((ch) => (
        <a class="channel-chip" href={`/c/${ch.slug}`} style={`--ch-600: ${ch.color600}; --ch-800: ${ch.color800}; --ch-50: ${ch.color50};`}>
          <span class="channel-chip__dot" aria-hidden="true"></span>
          <span class="channel-chip__code">CH.{ch.code}</span>
          <span class="channel-chip__name">{ch.name}</span>
        </a>
      ))}
    </nav>

    <!-- The grid — every block. -->
    <main class="grid" role="main">
      {blocks.map((block) => <BlockCard block={block} />)}
    </main>

    <!-- Footer — endpoint list. Agent-oriented. -->
    <footer class="endpoints">
      <p class="endpoints__label">ENDPOINTS</p>
      <ul class="endpoints__list">
        <li><a href="/blocks.json">/blocks.json</a></li>
        <li><a href="/sitemap-blocks.xml">/sitemap-blocks.xml</a></li>
        <li><a href="/for-agents">/for-agents</a></li>
        <li><a href="/visits">/visits</a></li>
      </ul>
    </footer>

  </div>
</BaseLayout>

<script is:inline>
  // Live clock — updates every 10s in PT. Monospace, matches header.
  (function() {
    const el = document.getElementById('pc-clock');
    if (!el) return;
    const fmt = new Intl.DateTimeFormat('en-US', {
      hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'America/Los_Angeles'
    });
    function tick() {
      const parts = fmt.formatToParts(new Date());
      const h = parts.find(p => p.type === 'hour')?.value ?? '—';
      const m = parts.find(p => p.type === 'minute')?.value ?? '—';
      el.textContent = `${h}:${m} PT`;
    }
    tick();
    setInterval(tick, 10_000);
  })();
</script>

<style>
  .page {
    max-width: 1480px;
    margin: 0 auto;
    padding: 16px 20px 80px;
  }

  .masthead {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding-bottom: 10px;
    border-bottom: 1.5px solid #12110E;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .wordmark {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0.22em;
    color: #12110E;
    text-decoration: none;
  }

  .wordmark:hover { color: #185FA5; }

  .masthead__meta {
    color: #38373A;
    font-weight: 400;
  }

  .masthead__time { min-width: 60px; }

  .masthead__sep { color: #C4C2BC; }

  .masthead__sep--wide { flex: 1; background: transparent; }

  .masthead__agent-link {
    color: #185FA5;
    text-decoration: none;
    font-weight: 500;
  }

  .masthead__agent-link:hover { text-decoration: underline; }

  .channels {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 14px 0;
    border-bottom: 1px dashed #C4C2BC;
    margin-bottom: 14px;
  }

  .channel-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    border: 1px solid var(--ch-600);
    background: var(--ch-50);
    color: var(--ch-800);
    text-decoration: none;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 1px;
    transition: background-color 0.12s;
  }

  .channel-chip:hover {
    background: color-mix(in oklab, var(--ch-600) 20%, #fff);
  }

  .channel-chip__dot {
    display: inline-block;
    width: 7px; height: 7px;
    background: var(--ch-600);
    border-radius: 50%;
  }

  .channel-chip__code { font-weight: 500; }

  .channel-chip__name { font-weight: 400; color: #38373A; }

  .grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: minmax(160px, auto);
    grid-auto-flow: dense;
    gap: 8px;
    margin-top: 14px;
  }

  @media (max-width: 1279px) {
    .grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 1023px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 639px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  .endpoints {
    margin-top: 48px;
    padding-top: 16px;
    border-top: 1.5px solid #12110E;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .endpoints__label { margin: 0; color: #38373A; font-weight: 500; }

  .endpoints__list {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .endpoints__list a {
    color: #185FA5;
    text-decoration: none;
  }

  .endpoints__list a:hover { text-decoration: underline; }
</style>
