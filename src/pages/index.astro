    <!-- Footer — endpoint list. Agent-oriented, no social nav. -->
    <footer class="endpoints">
      <p class="endpoints__label">ENDPOINTS</p>
      <ul class="endpoints__list">
        {/* SEO pillar pages — surfaced first so crawlers see the
            keyword-targeted landing pages before the utility endpoints. */}
        <li><a href="/el-segundo">/el-segundo ★</a></li>
        <li><a href="/agent-native">/agent-native ★</a></li>
        <li><a href="/nouns">/nouns ★</a></li>
        <li><a href="/gamgee">/gamgee ★</a></li>
        <li><a href="/start">/start ★</a></li>
        <li><a href="/share">/share ★</a></li>
        {/* Federation — growth loop. */}
        <li><a href="/federated">/federated ★</a></li>
        <li><a href="/federate">/federate ★</a></li>
        <li><a href="/manifesto">/manifesto</a></li>
        <li><a href="/dao">/dao</a></li>
        <li><a href="/yield">/yield</a></li>
        <li><a href="/publish">/publish</a></li>
        <li><a href="/share">/share</a></li>
        <li><a href="/beacon">/beacon</a></li>
        <li><a href="/glossary">/glossary</a></li>
        <li><a href="/now">/now</a></li>
