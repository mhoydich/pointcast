<script is:inline>
  (function() {
    const el = document.getElementById('pc-clock');
    if (!el) return;
    const fmt = new Intl.DateTimeFormat('en-US', {
      hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'America/Los_Angeles'
    });
    function tick() {
      const parts = fmt.formatToParts(new Date());
      const h = parts.find(p => p.type === 'hour')?.value ?? '—';
      const m = parts.find(p => p.type === 'minute')?.value ?? '—';
      el.textContent = `${h}:${m} PT`;
    }
    tick();
    setInterval(tick, 10_000);
  })();
</script>

<style>
  .page {
    max-width: 1480px;
    margin: 0 auto;
    padding: 16px 20px 80px;
  }

  /* Zone dividers — thin mono kickers marking the verb-flow between
     groups of components on the home. Per Mike 2026-04-19 21:35 PT
     "visit → update my stuffs → daily content → interaction → scroll". */
  .zone-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 14px 0 6px;
    padding: 0;
    font-size: 9px;
    letter-spacing: 0.24em;
    color: var(--pc-ink-soft);
    font-weight: 600;
    text-transform: uppercase;
  }
  .zone-divider__line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--pc-rule, #d6d4cd), transparent);
  }
  .zone-divider__label {
    padding: 0 4px;
    white-space: nowrap;
  }
  @media (max-width: 620px) {
    .zone-divider { gap: 6px; font-size: 8.5px; letter-spacing: 0.2em; }
    .zone-divider__label { padding: 0 2px; }
  }

  /* Visually-hidden h1 — semantic document outline for a11y + SEO without
     disrupting the masthead-as-title visual design. Technique: Bootstrap
     sr-only pattern. Screen readers announce, sighted users don't see it. */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .masthead {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding-bottom: 10px;
    border-bottom: 1.5px solid var(--pc-ink);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .wordmark {
    font-family: var(--pc-font-mono);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0.22em;
    color: var(--pc-ink);
  }
  .wordmark:hover { color: var(--pc-accent); text-decoration: none; }

  .meta { color: var(--pc-ink-soft); font-weight: 400; }
  .time { min-width: 60px; }
  .sep { color: var(--pc-rule); }
  .spacer { flex: 1; }

  .agent-link { color: var(--pc-accent); font-weight: 500; }

  @media (max-width: 639px) {
    .masthead {
      align-items: center;
      flex-wrap: wrap;
      gap: 8px 10px;
      padding-bottom: 12px;
    }

    .wordmark {
      flex: 0 0 100%;
      font-size: 20px;
      letter-spacing: 0.2em;
    }

    .sep,
    .spacer {
      display: none;
    }

    .meta {
      font-size: 10px;
    }

    .time {
      min-width: auto;
    }

    :global(.wallet-chip) {
      max-width: calc(100% - 116px);
    }

    .agent-link {
      margin-left: auto;
      white-space: nowrap;
    }
  }

  /* Channel chip bar — flex-wrap desktop, horizontal-scroll + sticky on mobile */
  .channels {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 14px 0;
    border-bottom: 1px dashed var(--pc-rule);
    margin-bottom: 14px;
    background: var(--pc-bg);
  }

  @media (max-width: 767px) {
    .channels {
      flex-wrap: nowrap;
      overflow-x: auto;
      overflow-y: hidden;
      position: sticky;
      top: 0;
      z-index: 10;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .channels::-webkit-scrollbar { display: none; }
    .chip { flex-shrink: 0; }
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    border: 1px solid var(--ch-600);
    background: var(--ch-50);
    color: var(--ch-800);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background-color 0.12s;
  }
  .chip:hover {
    background: color-mix(in oklab, var(--ch-600) 20%, #fff);
    text-decoration: none;
  }
  .chip__dot {
    display: inline-block;
    width: 7px; height: 7px;
    background: var(--ch-600);
    border-radius: 50%;
  }
  .chip__code { font-weight: 500; }
  .chip__name { font-weight: 400; color: var(--pc-ink-soft); }

  /* Self-healing grid per BLOCKS.md: auto-fit + minmax(220px, 1fr) */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    grid-auto-rows: minmax(170px, auto);
    grid-auto-flow: dense;
    gap: 8px;
    margin-top: 14px;
  }

  @media (max-width: 639px) {
    .grid {
      grid-template-columns: 1fr;
      /* Mike 2026-04-18 home-mobile-lighten: more breathing room between
         cards on mobile. The horizontal gap is moot at single-column;
         the vertical gap is what makes the scroll feel airier. */
      gap: 16px;
      grid-auto-rows: minmax(120px, auto);
    }
  }

  /* ══ SCROLL RHYTHM ═════════════════════════════════════════════════════
     Per-position decoration so the feed doesn't read as 48 identical tiles.
     Rules layer in source order — each block matches based on its DOM
     index (grid-auto-flow:dense doesn't change nth-child). Deliberately
     subtle: varies tone, weight, and micro-detail, never layout. */

  /* Every 5th card gets a paper-tint fill over the standard white. */
  .grid :global(.block-card:nth-child(5n+2):not(.type-visit):not(.type-note):not(.block-card--detail)) {
    background: #fafaf7;
  }

  /* Every 7th card gets a thicker 3px left accent (was 6px only on READ). */
  .grid :global(.block-card:nth-child(7n+3):not(.type-visit):not(.block-card--detail)) {
    border-left-width: 3px;
  }

  /* Every 9th card drops the border entirely and relies on a faint
     shadow instead — reads as an "open" card amid the bordered ones. */
  .grid :global(.block-card:nth-child(9n+4):not(.type-visit):not(.type-note):not(.type-link):not(.type-mint):not(.type-faucet):not(.block-card--detail)) {
    border-color: transparent;
    box-shadow: 0 0 0 1px var(--pc-rule, #C4C2BC), inset 4px 0 0 var(--ch-600);
  }

  /* Every 11th card inverts: dark bg + light text. Only applies where
     it won't collide with VISIT (which is already dark). */
