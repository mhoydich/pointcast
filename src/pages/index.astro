---
/**
 * pointcast.xyz v2 — home grid.
 *
 * Every content surface is a Block (per BLOCKS.md). The home page is a
 * dense auto-fit grid of BlockCards, most recent first. Size variants
 * are honored on desktop; mobile collapses to a single column with a
 * sticky channel chip bar at top.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import BlockCard from '../components/BlockCard.astro';
import BlockReorder from '../components/BlockReorder.astro';
import PresenceBar from '../components/PresenceBar.astro';
import WalletChip from '../components/WalletChip.astro';
import HomeMajors from '../components/HomeMajors.astro';
import FreshDeck from '../components/FreshDeck.astro';
import PollsOnHome from '../components/PollsOnHome.astro';
import MoodChip from '../components/MoodChip.astro';
import FreshStrip from '../components/FreshStrip.astro';
import VisitorHereStrip from '../components/VisitorHereStrip.astro';
import NetworkStrip from '../components/NetworkStrip.astro';
import TodayOnPointCast from '../components/TodayOnPointCast.astro';
import DailyDropStrip from '../components/DailyDropStrip.astro';
import SportsStrip from '../components/SportsStrip.astro';
import MorningPara from '../components/MorningPara.astro';

// Removed 2026-04-19 21:55 PT per Mike: "six things isn't working,
// morning brief isn't working, novice voter isn't working, remove
// for now". Old MorningBrief, TodayStrip, VoterStats components still
// on disk; not imported. Can return when a new shape is agreed.
import { CHANNEL_LIST } from '../lib/channels';
import { getCollection } from 'astro:content';

const blocks = (await getCollection('blocks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

const blockCount = blocks.length;

// JSON-LD — make the home a CollectionPage so agents can parse the list.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://pointcast.xyz/#home',
  name: 'PointCast',
  description: 'A living broadcast from El Segundo. Every piece is a Block.',
  url: 'https://pointcast.xyz/',
  inLanguage: 'en-US',
  hasPart: blocks.slice(0, 20).map((b) => ({
    '@type': 'CreativeWork',
    '@id': `https://pointcast.xyz/b/${b.data.id}`,
    name: b.data.title,
    datePublished: b.data.timestamp.toISOString(),
    url: `https://pointcast.xyz/b/${b.data.id}`,
  })),
};

const alternates = [
  { type: 'application/json', href: '/blocks.json', title: 'All blocks (JSON)' },
  { type: 'application/rss+xml', href: '/feed.xml', title: 'PointCast (RSS · all blocks)' },
  { type: 'application/feed+json', href: '/feed.json', title: 'PointCast (JSON Feed 1.1)' },
  ...CHANNEL_LIST.map((c) => ({
    type: 'application/rss+xml',
    href: `/c/${c.slug}.rss`,
    title: `PointCast · ${c.name} (RSS)`,
  })),
];
---

<BlockLayout
  title="Home"
  jsonLd={jsonLd}
  alternates={alternates}
  frame={{
    image: 'https://pointcast.xyz/images/og/og-home-v2.png',
    buttons: [
      { label: 'Open home feed', action: 'link', target: 'https://pointcast.xyz/' },
      { label: 'Manifesto', action: 'link', target: 'https://pointcast.xyz/manifesto' },
      { label: 'Editions', action: 'link', target: 'https://pointcast.xyz/editions' },
      { label: '/battle', action: 'link', target: 'https://pointcast.xyz/battle' },
    ],
  }}
>
  <div class="page">

    <h1 class="sr-only">PointCast — a living broadcast from El Segundo. Every piece of content is a Block.</h1>

    <!-- Masthead — one line. Wordmark, block count, current time, agent link. -->
    <header class="masthead">
      <a href="/" class="wordmark" aria-label="PointCast home">POINTCAST</a>
      <span class="sep" aria-hidden="true">·</span>
      <span class="meta">{blockCount} BLOCKS</span>
      <span class="sep" aria-hidden="true">·</span>
      <time class="meta time" id="pc-clock">— : —</time>
      <PresenceBar />
      <span class="spacer" aria-hidden="true"></span>
      <WalletChip />
      <a href="/for-agents" class="agent-link">/for-agents →</a>
    </header>

    <!-- Fresh strip — top-of-page freshness signal + one-tap action.
         Per Mike 2026-04-19 morning feedback "top not fresh enough and
         nothing to do". Shows HELLO / N NEW / CAUGHT UP badges based on
         localStorage lastVisit; CTA routes to newest or random older. -->
    <FreshStrip />

    <!-- MoodChip — moved to top per Mike 2026-04-20 13:55 PT: "yah let
         move mood up, and then yah make the selection of the mood change
         the mood, that animation, and yah the ability to play music,
         neater ui and then you are rolling thru the site in that mood."
         Setting your mood first means every page that follows renders
         with the tint + the soundtrack follows you. -->
    <MoodChip />

    <!-- Visitor "peoples here" strip — represents YOU as a noun avatar +
         ghost slots that light up when other visitors connect. Per Mike
         2026-04-19 20:30 PT. -->
    <VisitorHereStrip />

    <!-- Network strip — surfaces /here (live congregation), /for-nodes
         (become a node), /workbench (who's building what). Per Mike
         2026-04-20 11:15 PT: "look to refresh homepage, include new
         blocks, approach, etc · i'm pushing claude, codex and soon manus
         to start interacting, let me know if there is a page we can
         track that activity". -->
    <NetworkStrip />

    <!-- Today on PointCast — hand-curated day-specific highlights.
         Per Mike 2026-04-20 12:20 PT: "on homepage, it should likely
         be all the interesting things we were talking about today from
         clock to bitcoin, to 420, to feature updates, to things to try,
         to learnings, to how to learn, to entertainment, kinda thing,
         and very monday stuffs as, today is monday." -->
    <TodayOnPointCast />

    <!-- Daily drop collect inline. Per Mike 2026-04-20 13:20 PT:
         "have on homepage, ability to collect daily drop." Shared
         localStorage with /today so claim here, claim there, same count. -->
    <DailyDropStrip />

    <!-- Sports — recent global-major results. Per Mike 2026-04-20
         13:20 PT: "try a couple of sports updates of the latest results
         from last night or today, start with global major." Client-side
         fetches ESPN scoreboards, 10-min cache. -->
    <SportsStrip />

    {/* MoodChip moved above VisitorHereStrip per Mike 2026-04-20 13:55 PT. */}

    {/* MorningPara removed 2026-04-20 13:00 PT per Mike: "remove brief
         from homepage." TodayOnPointCast is the current editorial-strip
         surface; the morning paragraph was redundant. Component file
         stays on disk. */}

    <!-- Live polls strip — pool now includes 4 fresh polls (codex-project
         bet, sunday-ES, april-register, sunday-soundtrack) on top of the
         existing 12. Per Mike 2026-04-19 21:55 PT "more fresh polls". -->
    <PollsOnHome />

    <!-- Fresh deck — 3 random blocks cloned client-side from the grid below
         so every page-view gets a different top. Per Mike 2026-04-18 block
         0272 + /sprint pick. -->
    <FreshDeck />

    <!-- Channel legend — sticky-horizontal on mobile, flex-wrap on desktop. -->
    <nav class="channels" aria-label="Channels">
      {CHANNEL_LIST.map((ch) => (
        <a class="chip" href={`/c/${ch.slug}`} style={`--ch-600: ${ch.color600}; --ch-800: ${ch.color800}; --ch-50: ${ch.color50};`}>
          <span class="chip__dot" aria-hidden="true"></span>
          <span class="chip__code">CH.{ch.code}</span>
          <span class="chip__name">{ch.name}</span>
        </a>
      ))}
    </nav>

    <!-- Majors — inline modules for /drum + /cast.
         Mike 2026-04-17: "make sure the majors, like drum or pool
         together, have some type of module on the home page prior to
         click" + "likely have ability to drum get started". -->
    <HomeMajors />

    <!-- The grid — every block. Drag-and-drop reordering is client-side +
         localStorage-only; no server state. -->
    <BlockReorder>
      <section class="grid" role="main">
        {blocks.map((block) => <BlockCard block={block} />)}
      </section>
    </BlockReorder>

    <!-- Footer — endpoint list. Agent-oriented, no social nav. -->
    <footer class="endpoints">
      <p class="endpoints__label">ENDPOINTS</p>
      <ul class="endpoints__list">
        <li><a href="/manifesto">/manifesto</a></li>
        <li><a href="/dao">/dao</a></li>
        <li><a href="/yield">/yield</a></li>
        <li><a href="/publish">/publish</a></li>
        <li><a href="/beacon">/beacon</a></li>
        <li><a href="/glossary">/glossary</a></li>
        <li><a href="/now">/now</a></li>
        <li><a href="/search">/search</a></li>
        <li><a href="/archive">/archive</a></li>
        <li><a href="/timeline">/timeline</a></li>
        <li><a href="/editions">/editions</a></li>
        <li><a href="/subscribe">/subscribe</a></li>
        <li><a href="/changelog">/changelog</a></li>
        <li><a href="/stack">/stack</a></li>
        <li><a href="/ai-stack">/ai-stack</a></li>
        <li><a href="/yee">/yee</a></li>
        <li><a href="/mesh">/mesh</a></li>
        <li><a href="/collabs">/collabs</a></li>
        <li><a href="/ping">/ping</a></li>
        <li><a href="/sprint">/sprint</a></li>
        <li><a href="/sprints">/sprints</a></li>
        <li><a href="/drop">/drop</a></li>
        <li><a href="/products">/products</a></li>
        <li><a href="/polls">/polls</a></li>
        <li><a href="/briefs">/briefs</a></li>
        <li><a href="/gallery">/gallery</a></li>
        <li><a href="/moods">/moods</a></li>
        <li><a href="/local">/local</a></li>
        <li><a href="/today">/today ★</a></li>
        <li><a href="/tv">/tv ↗</a></li>
        <li><a href="/eth-legacy">/eth-legacy</a></li>
        <li><a href="https://shop.getgoodfeels.com" target="_blank" rel="noopener">shop ↗</a></li>
        <li><a href="/agents.json">/agents.json</a></li>
        <li><a href="/blocks.json">/blocks.json</a></li>
        <li><a href="/for-agents">/for-agents</a></li>
        <li><a href="/battle">/battle</a></li>
        <li><a href="/cast">/cast</a></li>
        <li><a href="/drum">/drum</a></li>
        <li><a href="/status">/status</a></li>
        <li><a href="/collection">/collection</a></li>
        <li><a href="/profile">/profile</a></li>
        <li><a href="/collect">/collect</a></li>
        <li><a href="/about">/about</a></li>
      </ul>
    </footer>

  </div>
</BlockLayout>

<script is:inline>
  (function() {
    const el = document.getElementById('pc-clock');
    if (!el) return;
    const fmt = new Intl.DateTimeFormat('en-US', {
      hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'America/Los_Angeles'
    });
    function tick() {
      const parts = fmt.formatToParts(new Date());
      const h = parts.find(p => p.type === 'hour')?.value ?? '—';
      const m = parts.find(p => p.type === 'minute')?.value ?? '—';
      el.textContent = `${h}:${m} PT`;
    }
    tick();
    setInterval(tick, 10_000);
  })();
</script>

<style>
  .page {
    max-width: 1480px;
    margin: 0 auto;
    padding: 16px 20px 80px;
  }

  /* Zone dividers — thin mono kickers marking the verb-flow between
     groups of components on the home. Per Mike 2026-04-19 21:35 PT
     "visit → update my stuffs → daily content → interaction → scroll". */
  .zone-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 14px 0 6px;
    padding: 0;
    font-size: 9px;
    letter-spacing: 0.24em;
    color: var(--pc-ink-soft);
    font-weight: 600;
    text-transform: uppercase;
  }
  .zone-divider__line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--pc-rule, #d6d4cd), transparent);
  }
  .zone-divider__label {
    padding: 0 4px;
    white-space: nowrap;
  }
  @media (max-width: 620px) {
    .zone-divider { gap: 6px; font-size: 8.5px; letter-spacing: 0.2em; }
    .zone-divider__label { padding: 0 2px; }
  }

  /* Visually-hidden h1 — semantic document outline for a11y + SEO without
     disrupting the masthead-as-title visual design. Technique: Bootstrap
     sr-only pattern. Screen readers announce, sighted users don't see it. */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .masthead {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding-bottom: 10px;
    border-bottom: 1.5px solid var(--pc-ink);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .wordmark {
    font-family: var(--pc-font-mono);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0.22em;
    color: var(--pc-ink);
  }
  .wordmark:hover { color: var(--pc-accent); text-decoration: none; }

  .meta { color: var(--pc-ink-soft); font-weight: 400; }
  .time { min-width: 60px; }
  .sep { color: var(--pc-rule); }
  .spacer { flex: 1; }

  .agent-link { color: var(--pc-accent); font-weight: 500; }

  /* Channel chip bar — flex-wrap desktop, horizontal-scroll + sticky on mobile */
  .channels {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 14px 0;
    border-bottom: 1px dashed var(--pc-rule);
    margin-bottom: 14px;
    background: var(--pc-bg);
  }

  @media (max-width: 767px) {
    .channels {
      flex-wrap: nowrap;
      overflow-x: auto;
      overflow-y: hidden;
      position: sticky;
      top: 0;
      z-index: 10;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .channels::-webkit-scrollbar { display: none; }
    .chip { flex-shrink: 0; }
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    border: 1px solid var(--ch-600);
    background: var(--ch-50);
    color: var(--ch-800);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background-color 0.12s;
  }
  .chip:hover {
    background: color-mix(in oklab, var(--ch-600) 20%, #fff);
    text-decoration: none;
  }
  .chip__dot {
    display: inline-block;
    width: 7px; height: 7px;
    background: var(--ch-600);
    border-radius: 50%;
  }
  .chip__code { font-weight: 500; }
  .chip__name { font-weight: 400; color: var(--pc-ink-soft); }

  /* Self-healing grid per BLOCKS.md: auto-fit + minmax(220px, 1fr) */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    grid-auto-rows: minmax(170px, auto);
    grid-auto-flow: dense;
    gap: 8px;
    margin-top: 14px;
  }

  @media (max-width: 639px) {
    .grid {
      grid-template-columns: 1fr;
      /* Mike 2026-04-18 home-mobile-lighten: more breathing room between
         cards on mobile. The horizontal gap is moot at single-column;
         the vertical gap is what makes the scroll feel airier. */
      gap: 16px;
      grid-auto-rows: minmax(120px, auto);
    }
  }

  /* ══ SCROLL RHYTHM ═════════════════════════════════════════════════════
     Per-position decoration so the feed doesn't read as 48 identical tiles.
     Rules layer in source order — each block matches based on its DOM
     index (grid-auto-flow:dense doesn't change nth-child). Deliberately
     subtle: varies tone, weight, and micro-detail, never layout. */

  /* Every 5th card gets a paper-tint fill over the standard white. */
  .grid :global(.block-card:nth-child(5n+2):not(.type-visit):not(.type-note):not(.block-card--detail)) {
    background: #fafaf7;
  }

  /* Every 7th card gets a thicker 3px left accent (was 6px only on READ). */
  .grid :global(.block-card:nth-child(7n+3):not(.type-visit):not(.block-card--detail)) {
    border-left-width: 3px;
  }

  /* Every 9th card drops the border entirely and relies on a faint
     shadow instead — reads as an "open" card amid the bordered ones. */
  .grid :global(.block-card:nth-child(9n+4):not(.type-visit):not(.type-note):not(.type-link):not(.type-mint):not(.type-faucet):not(.block-card--detail)) {
    border-color: transparent;
    box-shadow: 0 0 0 1px var(--pc-rule, #C4C2BC), inset 4px 0 0 var(--ch-600);
  }

  /* Every 11th card inverts: dark bg + light text. Only applies where
     it won't collide with VISIT (which is already dark). */
  .grid :global(.block-card:nth-child(11n+6):not(.type-visit):not(.type-mint):not(.type-faucet):not(.type-listen):not(.type-watch):not(.block-card--detail)) {
    background: #12110E;
    border-color: var(--ch-800);
  }

  .grid :global(.block-card:nth-child(11n+6):not(.type-visit):not(.type-mint):not(.type-faucet):not(.type-listen):not(.type-watch):not(.block-card--detail) .block-card__title) {
    color: #f2efe9;
  }

  .grid :global(.block-card:nth-child(11n+6):not(.type-visit):not(.type-mint):not(.type-faucet):not(.type-listen):not(.type-watch):not(.block-card--detail) .block-card__dek),
  .grid :global(.block-card:nth-child(11n+6):not(.type-visit):not(.type-mint):not(.type-faucet):not(.type-listen):not(.type-watch):not(.block-card--detail) .block-card__body) {
    color: #c4c2bc;
  }

  .grid :global(.block-card:nth-child(11n+6):not(.type-visit):not(.type-mint):not(.type-faucet):not(.type-listen):not(.type-watch):not(.block-card--detail) .block-card__header),
  .grid :global(.block-card:nth-child(11n+6):not(.type-visit):not(.type-mint):not(.type-faucet):not(.type-listen):not(.type-watch):not(.block-card--detail) .block-card__code),
  .grid :global(.block-card:nth-child(11n+6):not(.type-visit):not(.type-mint):not(.type-faucet):not(.type-listen):not(.type-watch):not(.block-card--detail) .block-card__time),
  .grid :global(.block-card:nth-child(11n+6):not(.type-visit):not(.type-mint):not(.type-faucet):not(.type-listen):not(.type-watch):not(.block-card--detail) .block-card__kicker) {
    color: color-mix(in oklab, var(--ch-600) 55%, #fff);
  }

  .grid :global(.block-card:nth-child(11n+6):not(.type-visit):not(.type-mint):not(.type-faucet):not(.type-listen):not(.type-watch):not(.block-card--detail) .block-card__meta) {
    color: color-mix(in oklab, var(--ch-600) 55%, #fff);
  }

  .grid :global(.block-card:nth-child(11n+6):not(.type-visit):not(.type-mint):not(.type-faucet):not(.type-listen):not(.type-watch):not(.block-card--detail):hover .block-card__title) {
    color: #fff;
  }

  .endpoints {
    margin-top: 48px;
    padding-top: 16px;
    border-top: 1.5px solid var(--pc-ink);
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .endpoints__label { margin: 0; color: var(--pc-ink-soft); font-weight: 500; }
  .endpoints__list {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .endpoints__list a { color: var(--pc-accent); }
</style>
