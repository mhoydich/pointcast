        <li><a href="/drop">/drop</a></li>
        <li><a href="/products">/products</a></li>
        <li><a href="/polls">/polls</a></li>
        <li><a href="/briefs">/briefs</a></li>
        <li><a href="/gallery">/gallery</a></li>
