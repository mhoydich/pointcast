---
/**
 * pointcast.xyz v2 — home grid.
 *
 * Every content surface is a Block (per BLOCKS.md). The home page is a
 * dense auto-fit grid of BlockCards, most recent first. Size variants
 * are honored on desktop; mobile collapses to a single column with a
 * sticky channel chip bar at top.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import BlockCard from '../components/BlockCard.astro';
import BlockReorder from '../components/BlockReorder.astro';
import PresenceBar from '../components/PresenceBar.astro';
import WalletChip from '../components/WalletChip.astro';
import RaceInstrumentation from '../components/RaceInstrumentation.astro';
import HomeMajors from '../components/HomeMajors.astro';
import FreshDeck from '../components/FreshDeck.astro';
import PollsOnHome from '../components/PollsOnHome.astro';
import MoodChip from '../components/MoodChip.astro';
import FreshStrip from '../components/FreshStrip.astro';
import VisitorHereStrip from '../components/VisitorHereStrip.astro';
import NetworkStrip from '../components/NetworkStrip.astro';
import TodayOnPointCast from '../components/TodayOnPointCast.astro';
import DailyDropStrip from '../components/DailyDropStrip.astro';
import SportsStrip from '../components/SportsStrip.astro';
import MorningPara from '../components/MorningPara.astro';
import NativePlantingYield from '../components/NativePlantingYield.astro';
import AgentLedger from '../components/AgentLedger.astro';
import HomeFireplace from '../components/HomeFireplace.astro';
import GameRail from '../components/GameRail.astro';
import AppLaunchStrip from '../components/AppLaunchStrip.astro';
import FreshToday from '../components/FreshToday.astro';
import ThisWeek from '../components/ThisWeek.astro';
import PointCastPlayStrip from '../components/PointCastPlayStrip.astro';
import ZenCatTodayCard from '../components/ZenCatTodayCard.astro';

// Removed 2026-04-19 21:55 PT per Mike: "six things isn't working,
// morning brief isn't working, novice voter isn't working, remove
// for now". Old MorningBrief, TodayStrip, VoterStats components still
// on disk; not imported. Can return when a new shape is agreed.
import { CHANNEL_LIST } from '../lib/channels';
import { getCollection } from 'astro:content';

// Sprint 23 (Mike 2026-04-24 Fri morning): "lets get the landing page
// landing correct, need to keep the content fresh, this has been
// around for days."
//
// Previous version pinned HELLO_MIKE_BLOCK_ID='0334' + HOUSEPLANTS_
// FIRST_BLOCK_ID='0333' literally — blocks authored 2026-04-22 that
// kept showing up as the two blocks above the fold. Replaced with a
// dynamic picker that always surfaces the freshest editorial:
//
//   helloMikeBlock  — latest VISIT-type block (top-of-home greeting)
//   firstBlock      — latest READ-type block (main editorial)
//
// Falls back cleanly when no block of a type exists. No hardcoded ids,
// so new blocks (like 0344 this morning) bubble up without a code
// change.
const allBlocks = (await getCollection('blocks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

// Freshness gates — prevent stale blocks from camping the top of the
// home when no newer block of that type has landed. Different
// thresholds per slot:
//   · helloMikeBlock (VISIT, top-of-home greeting) — 24h. "Someone
//     just visited" signal. Anything older reads as stale.
//   · firstBlock (READ, main editorial pin) — 120h (5d). Editorial
//     recaps have more shelf life; the Four-Sprints block is relevant
//     all weekend.
// When a slot's candidate is too old the slot goes empty and the grid
// below takes over.
const FRESH_VISIT_MS = 24 * 60 * 60 * 1000;
const FRESH_READ_MS = 120 * 60 * 60 * 1000;
const nowMs = Date.now();
function ageMs(b: { data: { timestamp: Date } }): number {
  return nowMs - b.data.timestamp.getTime();
}

const latestRead = allBlocks.find((b) => b.data.type === 'READ') ?? allBlocks[0] ?? null;
const firstBlock = latestRead && ageMs(latestRead) < FRESH_READ_MS ? latestRead : null;

const latestVisit = allBlocks.find(
  (b) => b.data.type === 'VISIT' && b.data.id !== firstBlock?.data.id,
);
const helloMikeBlock = latestVisit && ageMs(latestVisit) < FRESH_VISIT_MS ? latestVisit : null;
const pinnedBlockIds = new Set([firstBlock?.data.id, helloMikeBlock?.data.id].filter(Boolean));
const blocks = allBlocks.filter((block) => !pinnedBlockIds.has(block.data.id));
const blockCount = allBlocks.length;

// Count blocks shipped today in PT — a tiny "+N today" affordance on
// the masthead when the day has been busy. Sprint 34 cozy flourish.
const ptDayKey = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/Los_Angeles' }))
  .toISOString().slice(0, 10);
const blocksToday = allBlocks.filter((b) => {
  const t = b.data.timestamp instanceof Date ? b.data.timestamp : new Date(b.data.timestamp);
  // Convert block timestamp to PT day for comparison.
  const ptStr = new Date(t.toLocaleString('en-US', { timeZone: 'America/Los_Angeles' }))
    .toISOString().slice(0, 10);
  return ptStr === ptDayKey;
}).length;

const homeDescription = 'PointCast is an agent-native broadcast from El Segundo: a human-readable home, machine-readable feeds, and the Gamgee release train in one place.';

// JSON-LD — make the home a CollectionPage so agents can parse the list.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://pointcast.xyz/#home',
  name: 'PointCast Gamgee front door',
  description: homeDescription,
  url: 'https://pointcast.xyz/',
  inLanguage: 'en-US',
  hasPart: allBlocks.slice(0, 20).map((b) => ({
    '@type': 'CreativeWork',
    '@id': `https://pointcast.xyz/b/${b.data.id}`,
    name: b.data.title,
    datePublished: b.data.timestamp.toISOString(),
    url: `https://pointcast.xyz/b/${b.data.id}`,
  })),
};

const alternates = [
  { type: 'application/json', href: '/blocks.json', title: 'All blocks (JSON)' },
  { type: 'application/rss+xml', href: '/feed.xml', title: 'PointCast (RSS · all blocks)' },
  { type: 'application/feed+json', href: '/feed.json', title: 'PointCast (JSON Feed 1.1)' },
  ...CHANNEL_LIST.map((c) => ({
    type: 'application/rss+xml',
    href: `/c/${c.slug}.rss`,
    title: `PointCast · ${c.name} (RSS)`,
  })),
];
---

<BlockLayout
  title="Home"
  description={homeDescription}
  jsonLd={jsonLd}
  alternates={alternates}
  frame={{
    image: 'https://pointcast.xyz/images/og/og-home-v2.png',
    buttons: [
      { label: 'Open /gamgee', action: 'link', target: 'https://pointcast.xyz/gamgee' },
      { label: 'Open /now', action: 'link', target: 'https://pointcast.xyz/now' },
      { label: '/for-agents', action: 'link', target: 'https://pointcast.xyz/for-agents' },
      { label: '/agents.json', action: 'link', target: 'https://pointcast.xyz/agents.json' },
    ],
  }}
>
  <div class="page">

    <h1 class="sr-only">PointCast Gamgee - an agent-native broadcast from El Segundo with human and machine-readable paths.</h1>

    <!-- Masthead — one line. Wordmark, block count, current time, agent
         link. Sprint 23 adds:
         · hour-tinted sky strip above the row (client-set data-bucket)
         · Front Door race chip (scheduled until Mike flips opensAt in
           src/lib/races.ts). Uses the same buckets as /wire.
         Sprint 24 adds:
         · mood-tinted accent (data-mood) responding to MoodChip's
           `pc:mood-changed` event. Layers a colored glow on top of the
           sky without overriding the time-of-day gradient — mood is an
           accent, time-of-day is the base. -->
    <div class="masthead-sky" data-sky-bucket="midday" data-mood="" data-weather="" aria-hidden="true"></div>
    <header class="masthead" id="pc-masthead" data-sky-bucket="midday" data-mood="" data-weather="">
      <a href="/" class="wordmark" aria-label="PointCast home">POINTCAST</a>
      <span class="sep" aria-hidden="true">·</span>
      <span class="meta">{blockCount} BLOCKS{blocksToday > 0 && (<span class="meta__today" title="Blocks shipped today">{` · +${blocksToday} TODAY`}</span>)}</span>
      <span class="sep" aria-hidden="true">·</span>
      <time class="meta time" id="pc-clock">— : —</time>
      <PresenceBar />
      <a
        href="/race/front-door"
        class="race-chip mono"
        id="pc-race-chip"
        title="Front Door race — fastest page-load to first-click, daily."
      >
        <span class="race-chip__dot" aria-hidden="true"></span>
        <span class="race-chip__label">RACE · FRONT DOOR</span>
        <span class="race-chip__status" id="pc-race-status">SCHEDULED</span>
      </a>
      <span class="spacer" aria-hidden="true"></span>
      <WalletChip />
      <a href="/for-agents" class="agent-link">/for-agents →</a>
    </header>

    <script is:inline>
      // Sprint 23: tint the masthead sky strip by time-of-day and show
      // a Front Door race chip. Buckets match /wire's sky pick so the
      // whole site reads coherent as the day moves.
      (function () {
        'use strict';
        var head = document.getElementById('pc-masthead');
        var sky  = document.querySelector('.masthead-sky');
        if (!head || !sky) return;
        function bucket() {
          var h = new Date().getHours() + new Date().getMinutes() / 60;
          if (h < 6)       return 'smallhours';
          if (h < 10)      return 'morning';
          if (h < 15)      return 'midday';
          if (h < 18)      return 'golden';
          if (h < 21)      return 'blue';
          return 'evening';
        }
        function apply() {
          var b = bucket();
          head.setAttribute('data-sky-bucket', b);
          sky.setAttribute('data-sky-bucket', b);
        }
        apply();
        setInterval(apply, 60_000);

        // Sprint 24: mood → masthead accent. MoodChip writes the
        // mood id to localStorage.pc:mood and dispatches
        // pc:mood-changed{detail:{moodId}}. We apply both on load
        // (so persisted mood tints on arrival) and on change.
        function applyMood(id) {
          var m = (id || '').toLowerCase();
          head.setAttribute('data-mood', m);
          sky.setAttribute('data-mood', m);
        }
        try { applyMood(localStorage.getItem('pc:mood') || ''); } catch (e) {}
        window.addEventListener('pc:mood-changed', function (e) {
          var id = e && e.detail && e.detail.moodId;
          applyMood(id);
        });

        // Sprint 27: weather → masthead secondary tint. Hits the
        // existing /api/weather ad-hoc endpoint for El Segundo
        // (33.92, -118.42). Returns `{ condition, tempF, sunset }`
        // with condition in: clear / mostly clear / partly cloudy /
        // overcast / fog / drizzle / rain / showers / storm / snow /
        // unknown. We map to a small set of tint tokens + cache the
        // label in sessionStorage so subsequent tab-opens paint
        // immediately without a round-trip.
        function weatherTokenFromCondition(cond) {
          var c = (cond || '').toLowerCase();
          if (c === 'clear' || c === 'mostly clear') return 'clear';
          if (c === 'partly cloudy')                 return 'partly';
          if (c === 'overcast')                      return 'overcast';
          if (c === 'fog')                           return 'marine';
          if (c === 'drizzle' || c === 'rain' || c === 'showers') return 'rain';
          if (c === 'storm')                         return 'storm';
          if (c === 'snow')                          return 'cold';
          return '';
        }
        function applyWeather(token, tempF) {
          var t = token || '';
          head.setAttribute('data-weather', t);
          sky.setAttribute('data-weather', t);
          if (typeof tempF === 'number' && !isNaN(tempF)) {
            head.setAttribute('data-weather-temp', String(Math.round(tempF)));
            sky.setAttribute('data-weather-temp', String(Math.round(tempF)));
          }
        }
        // Paint from cache first so reloads feel instant.
        try {
          var cached = sessionStorage.getItem('pc:weather');
          if (cached) {
            var c = JSON.parse(cached);
            if (c && c.ts && Date.now() - c.ts < 900_000) {
              applyWeather(c.token, c.tempF);
            }
          }
        } catch (e) {}
        // Then refresh from the endpoint.
        fetch('/api/weather?lat=33.92&lng=-118.42&label=el-segundo', { cache: 'no-store' })
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (d) {
            if (!d || !d.ok) return;
            var token = weatherTokenFromCondition(d.condition);
            applyWeather(token, d.tempF);
            try {
              sessionStorage.setItem('pc:weather', JSON.stringify({
                ts: Date.now(), token: token, tempF: d.tempF, condition: d.condition
              }));
            } catch (e) {}
            // Broadcast for any other component that cares (e.g. the
            // hearth could dial back the ember animation on rain).
            window.dispatchEvent(new CustomEvent('pc:weather-changed', {
              detail: { token: token, tempF: d.tempF, condition: d.condition }
            }));
          })
          .catch(function () { /* keep whatever was cached */ });

        // Front Door race chip live hydrate. /api/race/front-door/
        // leaderboard returns race meta including derived status
        // ('scheduled' | 'open' | 'closed' | 'resolved'). When the KV
        // isn't bound, the endpoint still returns race meta with
        // `reason: kv-unbound` so we can color + label correctly.
        var chip   = document.getElementById('pc-race-chip');
        var status = document.getElementById('pc-race-status');
        if (chip && status) {
          chip.setAttribute('data-status', 'scheduled');

          function refreshChip() {
            fetch('/api/race/front-door/leaderboard', { cache: 'no-store' })
              .then(function (r) { return r.ok ? r.json() : null; })
              .then(function (d) {
                if (!d || !d.race) return;
                var s = (d.race.status || 'scheduled').toLowerCase();
                chip.setAttribute('data-status', s);
                var label = s.toUpperCase();
                if (s === 'open' && typeof d.count === 'number' && d.count > 0) {
                  label = 'OPEN · ' + d.count + ' IN';
                } else if (s === 'resolved' && d.race.resolvesAt) {
                  label = 'RESOLVED';
                }
                // Sprint 25: if the viewer has submitted and we know their
                // rank, show it: "OPEN · #3 · 12 IN"
                try {
                  var rank = localStorage.getItem('pc:race:front-door:rank');
                  if (s === 'open' && rank) {
                    label = 'OPEN · #' + rank + (typeof d.count === 'number' && d.count > 0 ? ' · ' + d.count + ' IN' : '');
                  }
                } catch (e) {}
                status.textContent = label;
              })
              .catch(function () { /* keep default SCHEDULED */ });
          }
          refreshChip();

          // Re-fetch the leaderboard when our own instrumentation
          // submits a score, so the viewer sees their own rank show up
          // on the chip within ~400ms of clicking a block.
          window.addEventListener('pc:race:submitted', function () {
            setTimeout(refreshChip, 400);
          });
          // And every 45s while the tab is open so the count refreshes
          // as other visitors submit.
          setInterval(refreshChip, 45_000);
        }
      })();
    </script>

    <!-- Race instrumentation — invisible; starts the Front Door clock
         on page load and submits a score on the first block-card
         click. Sprint 25. -->
    <RaceInstrumentation slug="front-door" />

    <HomeFireplace />

    <GameRail />

    <section class="gamgee-front-door" aria-labelledby="gamgee-front-door-title">
      <div class="gamgee-front-door__copy">
        <p class="gamgee-front-door__kicker">Gamgee RC0 · <a href="/mythos" class="gamgee-front-door__mythos">The Mythos →</a></p>
        <h2 id="gamgee-front-door-title" class="gamgee-front-door__title">PointCast is an agent-native broadcast from El Segundo.</h2>
        <p class="gamgee-front-door__dek">Humans get the live home. Agents get stable manifests, feeds, and a visible release ledger. Gamgee is the clean release candidate that keeps both sides pointed at the same truth.</p>
        <ul class="gamgee-front-door__signals" aria-label="Gamgee release signals">
          <li>{blockCount} blocks</li>
          <li>Claude + Codex + Manus</li>
          <li>Stable agent surfaces</li>
        </ul>
      </div>
      <nav class="gamgee-front-door__paths" aria-label="Gamgee entry points">
        <a href="/gamgee" class="gamgee-front-door__path">
          <span class="gamgee-front-door__label">For the release</span>
          <span class="gamgee-front-door__target">/gamgee</span>
          <span class="gamgee-front-door__note">Open the public RC0 anchor.</span>
        </a>
        <a href="/now" class="gamgee-front-door__path">
          <span class="gamgee-front-door__label">For humans</span>
          <span class="gamgee-front-door__target">/now</span>
          <span class="gamgee-front-door__note">See what is live today.</span>
        </a>
        <a href="/for-agents" class="gamgee-front-door__path">
          <span class="gamgee-front-door__label">For agents</span>
          <span class="gamgee-front-door__target">/for-agents</span>
          <span class="gamgee-front-door__note">Read the operating surface.</span>
        </a>
        <a href="/agents.json" class="gamgee-front-door__path">
          <span class="gamgee-front-door__label">For tools</span>
          <span class="gamgee-front-door__target">/agents.json</span>
          <span class="gamgee-front-door__note">Parse the canonical manifest.</span>
        </a>
      </nav>
      <AgentLedger />
      <FreshToday />
      <ThisWeek />
    </section>

    {helloMikeBlock && (
      <section class="hello-module" aria-label="Hello Mike module">
        <BlockCard block={helloMikeBlock} />
      </section>
    )}

    {firstBlock && (
      <section class="first-block" aria-label="Featured block on PointCast">
        <BlockCard block={firstBlock} />
      </section>
    )}

    <!-- Fresh strip — top-of-page freshness signal + one-tap action.
         Per Mike 2026-04-19 morning feedback "top not fresh enough and
         nothing to do". Shows HELLO / N NEW / CAUGHT UP badges based on
         localStorage lastVisit; CTA routes to newest or random older. -->
    <FreshStrip />

    <!-- MoodChip — moved to top per Mike 2026-04-20 13:55 PT: "yah let
         move mood up, and then yah make the selection of the mood change
         the mood, that animation, and yah the ability to play music,
         neater ui and then you are rolling thru the site in that mood."
         Setting your mood first means every page that follows renders
         with the tint + the soundtrack follows you. -->
    <MoodChip />

    <!-- Visitor "peoples here" strip — represents YOU as a noun avatar +
         ghost slots that light up when other visitors connect. Per Mike
         2026-04-19 20:30 PT. -->
    <VisitorHereStrip />

    <!-- Network strip — surfaces /here (live congregation), /for-nodes
         (become a node), /workbench (who's building what). Per Mike
         2026-04-20 11:15 PT: "look to refresh homepage, include new
         blocks, approach, etc · i'm pushing claude, codex and soon manus
         to start interacting, let me know if there is a page we can
         track that activity". -->
    <NetworkStrip />

    <AppLaunchStrip />

    <ZenCatTodayCard />

    <PointCastPlayStrip />

    <!-- Today on PointCast — hand-curated day-specific highlights.
         Per Mike 2026-04-20 12:20 PT: "on homepage, it should likely
         be all the interesting things we were talking about today from
         clock to bitcoin, to 420, to feature updates, to things to try,
         to learnings, to how to learn, to entertainment, kinda thing,
         and very monday stuffs as, today is monday." -->
    <TodayOnPointCast />

    <!-- Daily drop collect inline. Per Mike 2026-04-20 13:20 PT:
         "have on homepage, ability to collect daily drop." Shared
         localStorage with /today so claim here, claim there, same count. -->
    <DailyDropStrip />

    <!-- Sports — recent global-major results. Per Mike 2026-04-20
         13:20 PT: "try a couple of sports updates of the latest results
         from last night or today, start with global major." Client-side
         fetches ESPN scoreboards, 10-min cache. -->
    <SportsStrip />

    {/* MoodChip moved above VisitorHereStrip per Mike 2026-04-20 13:55 PT. */}

    {/* MorningPara removed 2026-04-20 13:00 PT per Mike: "remove brief
         from homepage." TodayOnPointCast is the current editorial-strip
         surface; the morning paragraph was redundant. Component file
         stays on disk. */}

    <!-- Live polls strip — pool now includes 4 fresh polls (codex-project
         bet, sunday-ES, april-register, sunday-soundtrack) on top of the
         existing 12. Per Mike 2026-04-19 21:55 PT "more fresh polls". -->
    <PollsOnHome />

    <!-- Fresh deck — 3 random blocks cloned client-side from the grid below
         so every page-view gets a different top. Per Mike 2026-04-18 block
         0272 + /sprint pick. -->
    <FreshDeck />

    <!-- Channel legend — sticky-horizontal on mobile, flex-wrap on desktop. -->
    <nav class="channels" aria-label="Channels">
      {CHANNEL_LIST.map((ch) => (
        <a class="chip" href={`/c/${ch.slug}`} style={`--ch-600: ${ch.color600}; --ch-800: ${ch.color800}; --ch-50: ${ch.color50};`}>
          <span class="chip__dot" aria-hidden="true"></span>
          <span class="chip__code">CH.{ch.code}</span>
          <span class="chip__name">{ch.name}</span>
        </a>
      ))}
    </nav>

    <!-- Majors — inline modules for /drum + /cast + /meditate.
         Mike 2026-04-17: "make sure the majors, like drum or pool
         together, have some type of module on the home page prior to
         click" + "likely have ability to drum get started". -->
    <HomeMajors />

    <NativePlantingYield />

    <!-- The grid — every block. Drag-and-drop reordering is client-side +
         localStorage-only; no server state. -->
    <BlockReorder>
      <section class="grid" role="main">
        {blocks.map((block) => <BlockCard block={block} />)}
      </section>
    </BlockReorder>

    <!-- Footer — endpoint list. Agent-oriented, no social nav. -->
    <footer class="endpoints">
      <p class="endpoints__label">ENDPOINTS</p>
      <ul class="endpoints__list">
        <li><a href="/manifesto">/manifesto</a></li>
        <li><a href="/dao">/dao</a></li>
        <li><a href="/yield">/yield</a></li>
        <li><a href="/nouns-cola">/nouns-cola</a></li>
        <li><a href="/nouns-cola-crush">/nouns-cola-crush</a></li>
        <li><a href="/publish">/publish</a></li>
        <li><a href="/beacon">/beacon</a></li>
