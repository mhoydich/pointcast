---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const projects = await getCollection('projects', ({ data }) => !data.draft);

const allContent = [
  ...posts.map(p => ({ ...p, collection: 'posts' as const, type: p.data.type })),
  ...projects.map(p => ({ ...p, collection: 'projects' as const, type: 'project' as const })),
].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const lead = allContent[0];
const wire = allContent.slice(1);

const typeLabel: Record<string, string> = {
  newsletter: 'Dispatch',
  article: 'Article',
  essay: 'Essay',
  project: 'Project',
  art: 'Art',
};

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

// Random Noun IDs for inline decoration
const nounIds = Array.from({ length: 5 }, () => Math.floor(Math.random() * 1876));
---

<BaseLayout title="Home">
  <div class="max-w-[34rem] mx-auto px-4 pt-10 md:pt-16 pb-20">

    <!-- Masthead — data-forward, inspired by original PointCast Network (1996) -->
    <header class="mb-10">
      <!-- Network ID line -->
      <div class="flex items-center justify-between pb-2 mb-4 border-b border-rule/50">
        <div class="flex items-center gap-3">
          <span class="font-mono text-[0.6rem] tracking-[0.22em] uppercase text-ink font-semibold">PC</span>
          <span class="font-mono text-[0.6rem] tracking-[0.14em] uppercase text-ink-soft/60">PointCast Network</span>
        </div>
        <span class="pill"><span class="pill-dot"></span>Live</span>
      </div>

      <!-- Data line -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mb-4 font-mono text-[0.58rem] tracking-[0.14em] uppercase text-ink-soft/70">
        <span>{new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase()}</span>
        <span class="text-warm/40">&bull;</span>
        <span>{allContent.length} dispatches</span>
        <span class="text-warm/40">&bull;</span>
        <span>El Segundo, CA</span>
        <span class="text-warm/40">&bull;</span>
        <span>Mike Hoydich &times; Claude</span>
      </div>

      <!-- Ticker — headline crawler -->
      <div class="ticker" aria-label="Recent headlines">
        <div class="ticker-track">
          {/* Duplicate items for seamless loop */}
          {[...allContent, ...allContent].map((item) => {
            const href = item.collection === 'posts' ? `/posts/${item.id}` : `/projects/${item.id}`;
            return (
              <>
                <div class="ticker-item">
                  <span class="text-warm/60">{typeLabel[item.type] || 'Post'}</span>
                  <a href={href}>{item.data.title}</a>
                </div>
                <span class="ticker-sep">&loz;</span>
              </>
            );
          })}
        </div>
      </div>
    </header>

    <!-- Lead story -->
    {lead && (
      <section aria-label="Lead story" class="mb-12">
        <div class="flex items-center gap-3 mb-3">
          <span class="font-mono text-[0.62rem] tracking-[0.18em] uppercase text-warm">
            {typeLabel[lead.type] || 'Post'} &middot; {fmtDate(lead.data.date)}
          </span>
          <img
            src={`https://noun.pics/${nounIds[1]}.svg`}
            alt=""
            aria-hidden="true"
            width="20"
            height="20"
            class="rounded-sm opacity-30"
            style="image-rendering: pixelated;"
          />
        </div>

        <a href={lead.collection === 'posts' ? `/posts/${lead.id}` : `/projects/${lead.id}`} class="group block">
          <h2 class="font-serif text-[1.5rem] md:text-[1.75rem] text-ink font-medium italic leading-[1.15] mb-3 group-hover:text-warm transition-colors">
            {lead.data.title}
          </h2>
        </a>

        <p class="text-[0.95rem] text-ink/75 leading-relaxed mb-4">
          {lead.data.description}
        </p>

        <a
          href={lead.collection === 'posts' ? `/posts/${lead.id}` : `/projects/${lead.id}`}
          class="inline-flex items-center gap-2 text-warm font-mono text-[0.62rem] tracking-[0.14em] uppercase hover:underline"
        >
          Read {typeLabel[lead.type]?.toLowerCase() || 'post'} &rarr;
        </a>
      </section>
    )}

    <!-- Noun strip — inline creative element -->
    <div class="flex items-center gap-3 py-4 border-y border-rule/50 mb-8 overflow-hidden" aria-hidden="true">
      <span class="font-mono text-[0.54rem] tracking-[0.22em] uppercase text-ink-soft/30 shrink-0">on-chain</span>
      <div class="flex gap-2 overflow-hidden">
        {nounIds.map(id => (
          <img
            src={`https://noun.pics/${id}.svg`}
            alt=""
            width="32"
            height="32"
            class="rounded-sm opacity-40 hover:opacity-100 transition-opacity"
            style="image-rendering: pixelated;"
          />
        ))}
      </div>
      <span class="font-mono text-[0.54rem] tracking-[0.22em] uppercase text-ink-soft/30 shrink-0">cc0</span>
    </div>

    <!-- The Wire -->
    <section aria-label="Recent" class="mb-12">
      <div class="flex items-center gap-3 mb-5">
        <div class="h-px flex-1 bg-rule"></div>
        <h2 class="font-mono text-[0.62rem] tracking-[0.22em] uppercase text-ink-soft">The Wire</h2>
        <div class="h-px flex-1 bg-rule"></div>
      </div>

      <div class="space-y-0">
        {wire.map((item, i) => {
          const href = item.collection === 'posts' ? `/posts/${item.id}` : `/projects/${item.id}`;
          return (
            <a href={href} class="group flex items-center gap-4 py-3.5 border-b border-rule/50 hover:bg-card-hover/50 -mx-3 px-3 rounded-md transition-colors">
              <span class="font-mono text-[0.58rem] tracking-[0.14em] uppercase text-ink-soft/50 w-16 shrink-0">
                {fmtDate(item.data.date)}
              </span>
              <span class="font-mono text-[0.54rem] tracking-[0.18em] uppercase text-warm/60 w-14 shrink-0">
                {typeLabel[item.type] || 'Post'}
              </span>
              <span class="font-serif text-[0.95rem] text-ink group-hover:text-warm transition-colors font-medium leading-snug flex-1">
                {item.data.title}
              </span>
              {i === 0 && (
                <img
                  src={`https://noun.pics/${nounIds[2]}.svg`}
                  alt=""
                  aria-hidden="true"
                  width="22"
                  height="22"
                  class="rounded-sm opacity-20 group-hover:opacity-50 transition-opacity shrink-0 hidden sm:block"
                  style="image-rendering: pixelated;"
                />
              )}
            </a>
          );
        })}
      </div>

      <div class="mt-6">
        <a href="/feed" class="inline-flex items-center gap-2 text-ink-soft font-mono text-[0.62rem] tracking-[0.14em] uppercase hover:text-warm transition-colors">
          Full archive &rarr;
        </a>
      </div>
    </section>

    <!-- Sign-off -->
    <footer class="border-t border-rule pt-6 flex items-center justify-between">
      <p class="font-serif italic text-ink-soft text-[0.9rem]">
        Where taste meets machine.
      </p>
      <img
        src={`https://noun.pics/${nounIds[4]}.svg`}
        alt=""
        aria-hidden="true"
        width="24"
        height="24"
        class="rounded-sm opacity-25"
        style="image-rendering: pixelated;"
      />
    </footer>

  </div>
</BaseLayout>
