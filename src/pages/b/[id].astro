---
/**
 * /b/{id} — single-block permalink. JSON-LD + alternates surface.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import BlockLayout from '../../layouts/BlockLayout.astro';
import BlockCard from '../../components/BlockCard.astro';
import MintButton from '../../components/MintButton.astro';
import FeedbackStrip from '../../components/FeedbackStrip.astro';
import { CHANNELS } from '../../lib/channels';

export async function getStaticPaths() {
  const blocks = (await getCollection('blocks', ({ data }) => !data.draft))
    .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

  return blocks.map((block, idx) => ({
    params: { id: block.data.id },
    props: {
      block,
      // Adjacent blocks in reverse-chronological order — "prev" = next older
      // (scroll forward in the feed), "next" = next newer (scroll backward).
      // Naming matches the /b/[id] visitor's mental model: "next block" is
      // the one that was published more recently.
      prev: blocks[idx + 1] ?? null,
      next: blocks[idx - 1] ?? null,
      // Up to 4 related blocks from the same channel, excluding self.
      related: blocks
        .filter((b, i) => i !== idx && b.data.channel === block.data.channel)
        .slice(0, 4),
    },
  }));
}

interface Props {
  block: CollectionEntry<'blocks'>;
  prev: CollectionEntry<'blocks'> | null;
  next: CollectionEntry<'blocks'> | null;
  related: CollectionEntry<'blocks'>[];
}
const { block, prev, next, related } = Astro.props;
const ch = CHANNELS[block.data.channel];

function shortTitle(t: string, max = 40) {
  return t.length > max ? t.slice(0, max - 1) + '…' : t;
}

// SEO: title is the block title alone so the SERP snippet leads with
// human-scanable content, not the CH.{code} · {id} prefix that used to
// eat ~14 chars. BlockLayout appends " — PointCast" automatically. The
// channel + id still appear in the description + breadcrumb + H1 below.
const title = block.data.title;

// SEO: per-type description fallback so NOTE / LINK / VISIT blocks —
// whose body is often 1-3 sentences — don't end up with a meta that
// duplicates the title. Pattern: dek first, then per-type hint + body
// tail, then a safe channel-purpose fallback. Output always ≤ 180 chars.
function buildDescription(): string {
  const dek = block.data.dek?.trim();
  if (dek) return dek.length > 180 ? dek.slice(0, 177) + '…' : dek;

  const body = block.data.body?.trim() ?? '';
  const bodyTail = body.length > 140 ? body.slice(0, 137) + '…' : body;
  const dateStr = block.data.timestamp.toISOString().slice(0, 10);

  switch (block.data.type) {
    case 'READ':
      return bodyTail || `${ch.name} dispatch · ${dateStr} · PointCast`;
    case 'LISTEN': {
      const host = (() => { try { return new URL(block.data.external?.url ?? '', 'https://pointcast.xyz').host.replace(/^www\./, ''); } catch { return ''; } })();
      return `Listening note · ${host || ch.name} · ${dateStr}${bodyTail ? ' — ' + bodyTail : ''}`.slice(0, 180);
    }
    case 'WATCH': {
      const host = (() => { try { return new URL(block.data.external?.url ?? '', 'https://pointcast.xyz').host.replace(/^www\./, ''); } catch { return ''; } })();
      return `Watch · ${host || ch.name} · ${dateStr}${bodyTail ? ' — ' + bodyTail : ''}`.slice(0, 180);
    }
    case 'MINT': {
      const price = block.data.edition?.price === 'free' ? 'free' : `${(block.data.edition?.price as any)?.tez ?? ''} ꜩ`;
      return `Editionable on Tezos · ${price} · CH.${ch.code} ${ch.name} · PointCast`.slice(0, 180);
    }
    case 'FAUCET':
      return `Free daily claim · CH.${ch.code} ${ch.name} · ${dateStr} · PointCast faucet`.slice(0, 180);
    case 'NOTE':
      return bodyTail ? `Note · ${bodyTail}` : `Short note · CH.${ch.code} ${ch.name} · ${dateStr}`;
    case 'VISIT':
      return bodyTail ? `Visit log · ${bodyTail}` : `Visit log entry · ${dateStr} · PointCast`;
    case 'LINK': {
      const host = (() => { try { return new URL(block.data.external?.url ?? '', 'https://pointcast.xyz').host.replace(/^www\./, ''); } catch { return ''; } })();
      return `External link${host ? ' · ' + host : ''}${bodyTail ? ' — ' + bodyTail : ''}`.slice(0, 180);
    }
    default:
      return bodyTail || `${ch.name} · PointCast · ${dateStr}`;
  }
}
const description = buildDescription();
const ogImage = `/images/og/b/${block.data.id}.png`;
const ogImageAbs = `https://pointcast.xyz${ogImage}`;

// SEO: per-channel pillar mapping — every Block surfaces a single
// "Part of" link to the most-relevant SEO pillar. Drives internal-link
// juice from the long tail (individual blocks) to the three
// high-priority landing pages. Kept to 1 link to avoid clutter.
const PILLAR_BY_CHANNEL: Record<string, { url: string; label: string; note: string }> = {
  FD:  { url: '/agent-native', label: 'Agent-native web', note: 'How PointCast ships llms.txt, agents.json, stripped-HTML, and Frames.' },
  ESC: { url: '/el-segundo',   label: 'El Segundo, California', note: 'The local pillar — things to do, tech scene, 25-mile beacon.' },
  BTL: { url: '/nouns',        label: 'Nouns on Tezos', note: 'Visit Nouns FA2 + Nouns Battler + CC0 proliferation.' },
  CRT: { url: '/el-segundo',   label: 'El Segundo, California', note: 'Pickleball at El Segundo Rec Park — part of the local pillar.' },
  GF:  { url: '/el-segundo',   label: 'El Segundo, California', note: 'Good Feels is based in El Segundo — see the local pillar.' },
  GDN: { url: '/el-segundo',   label: 'El Segundo, California', note: 'Coastal SoCal birds + weather — part of the local lens.' },
  SPN: { url: '/blocks',       label: 'Blocks — the primitive', note: 'Every Block (including LISTEN blocks) follows the same schema.' },
  FCT: { url: '/nouns',        label: 'Nouns on Tezos', note: 'Free faucet claims run on the same Tezos FA2 stack.' },
  VST: { url: '/agent-native', label: 'Agent-native web', note: 'The visit log tracks both humans and AI agents — agent-native by design.' },
};
const pillar = PILLAR_BY_CHANNEL[block.data.channel];

// SEO / GEO: citation-ready text. Used for both the JSON-LD `citation`
// field and the visible "Cite this block" widget so agents and humans
// see the same canonical format.
const citationDate = block.data.timestamp.toISOString().slice(0, 10);
const citationShort = `PointCast · CH.${ch.code} · № ${block.data.id} — "${block.data.title}" · ${citationDate}`;
const citationFull = `${citationShort}\nhttps://pointcast.xyz/b/${block.data.id}`;

// SEO: conditional schema.org @type per block type. Was a single generic
// CreativeWork — too broad for rich results. Now READ blocks become
// BlogPosting (Article rich-result eligible), NOTE → SocialMediaPosting,
// VISIT → BlogPosting (articleSection: "Visit log"), MINT/FAUCET → Product
// with Offer, LISTEN → MusicRecording, WATCH → VideoObject, LINK stays as
// CreativeWork. Shared fields (author, publisher, breadcrumb, image,
// mainEntityOfPage) stay consistent across all types.
const sharedAuthor = {
  '@type': 'Person',
  '@id': 'https://pointcast.xyz/#person',
  name: 'Mike Hoydich',
};
const sharedPublisher = {
  '@type': 'Organization',
  '@id': 'https://pointcast.xyz/#org',
  name: 'PointCast',
  logo: { '@type': 'ImageObject', url: 'https://pointcast.xyz/images/og-home-v3.png' },
};
const blockUrl = `https://pointcast.xyz/b/${block.data.id}`;

function buildPrimarySchema(): Record<string, unknown> {
  const base: Record<string, unknown> = {
    '@id': blockUrl,
    identifier: block.data.id,
    name: block.data.title,
    headline: block.data.title.length > 110 ? block.data.title.slice(0, 109) + '…' : block.data.title,
    description,
    datePublished: block.data.timestamp.toISOString(),
    dateModified: block.data.timestamp.toISOString(),
    inLanguage: 'en-US',
    url: blockUrl,
    mainEntityOfPage: blockUrl,
    image: ogImageAbs,
    author: sharedAuthor,
    publisher: sharedPublisher,
    isPartOf: { '@type': 'CollectionPage', name: ch.name, url: `https://pointcast.xyz/c/${ch.slug}` },
    // SEO / GEO: canonical citation text for LLMs. Matches the visible
    // "Cite this block" widget so humans and agents use the same shape.
    citation: citationShort,
  };

  const body = block.data.body ?? '';
  const wordCount = body ? body.trim().split(/\s+/).length : undefined;

  switch (block.data.type) {
    case 'READ': {
      const readMin = (block.data as any).readingTime?.match(/\d+/)?.[0];
      return {
        '@type': 'BlogPosting',
        ...base,
        articleSection: ch.name,
        articleBody: body,
        ...(wordCount ? { wordCount } : {}),
        ...(readMin ? { timeRequired: `PT${readMin}M` } : {}),
      };
    }
    case 'NOTE':
      return {
        '@type': 'SocialMediaPosting',
        ...base,
        articleBody: body,
        ...(wordCount ? { wordCount } : {}),
      };
    case 'VISIT':
      return {
        '@type': 'BlogPosting',
        ...base,
        articleSection: 'Visit log',
        articleBody: body,
        ...(wordCount ? { wordCount } : {}),
      };
    case 'LISTEN':
      return {
        '@type': 'MusicRecording',
        ...base,
        ...(block.data.external?.url ? { url: block.data.external.url, sameAs: block.data.external.url } : {}),
      };
    case 'WATCH':
      return {
        '@type': 'VideoObject',
        ...base,
        thumbnailUrl: ogImageAbs,
        uploadDate: block.data.timestamp.toISOString(),
        ...(block.data.external?.url ? { contentUrl: block.data.external.url, embedUrl: block.data.external.url } : {}),
      };
    case 'MINT':
    case 'FAUCET': {
      const isFree = block.data.edition?.price === 'free';
      const tezPrice = isFree ? 0 : (block.data.edition?.price as any)?.tez ?? 0;
      return {
        '@type': 'Product',
        ...base,
        category: block.data.type === 'FAUCET' ? 'NFT / Faucet' : 'NFT / Edition',
        brand: sharedPublisher,
        offers: {
          '@type': 'Offer',
          url: blockUrl,
          price: tezPrice,
          priceCurrency: 'XTZ',
          availability: 'https://schema.org/InStock',
          seller: sharedPublisher,
        },
      };
    }
    case 'LINK':
    default:
      return {
        '@type': 'CreativeWork',
        ...base,
        ...(block.data.external?.url ? { mainEntity: { '@type': 'URL', url: block.data.external.url } } : {}),
      };
  }
}

// SEO: HowTo schema overlay — when a block is flagged as a how-to
// (via `meta.format: "howto"` + optional `meta.howto.steps[]`), we emit
// an additional HowTo entity into the @graph. Google treats HowTo as
// eligible for rich results (numbered step carousel in SERPs). The
// detection is explicit — we don't try to infer how-to shape from the
// body. Block 0246 (acupuncture self-study) is the seed example.
const howtoMeta = (block.data as any)?.meta?.howto;
const isHowTo = (block.data as any)?.meta?.format === 'howto' && howtoMeta?.steps?.length > 0;
const howtoSchema = isHowTo
  ? {
      '@type': 'HowTo',
      '@id': `https://pointcast.xyz/b/${block.data.id}#howto`,
      name: howtoMeta.name ?? block.data.title,
      description: howtoMeta.description ?? description,
      totalTime: howtoMeta.totalTime, // ISO 8601 duration e.g. PT30M
      estimatedCost: howtoMeta.cost,  // { '@type': 'MonetaryAmount', currency, value }
      supply: howtoMeta.supplies,     // array of { '@type': 'HowToSupply', name }
      tool: howtoMeta.tools,          // array of { '@type': 'HowToTool', name }
      step: howtoMeta.steps.map((s: any, i: number) => ({
        '@type': 'HowToStep',
        position: i + 1,
        name: s.name,
        text: s.text,
        ...(s.url ? { url: s.url } : {}),
        ...(s.image ? { image: s.image } : {}),
      })),
    }
  : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    buildPrimarySchema(),
    ...(howtoSchema ? [howtoSchema] : []),
    {
      '@type': 'BreadcrumbList',
      '@id': `https://pointcast.xyz/b/${block.data.id}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://pointcast.xyz/' },
        { '@type': 'ListItem', position: 2, name: `CH.${ch.code} · ${ch.name}`, item: `https://pointcast.xyz/c/${ch.slug}` },
        { '@type': 'ListItem', position: 3, name: `№ ${block.data.id}`, item: `https://pointcast.xyz/b/${block.data.id}` },
      ],
    },
  ],
};

const alternates = [
  { type: 'application/json', href: `/b/${block.data.id}.json`, title: 'Machine-readable block' },
  { type: 'application/json', href: `/c/${ch.slug}.json`, title: `${ch.name} (JSON feed)` },
  { type: 'application/rss+xml', href: `/c/${ch.slug}.rss`, title: `${ch.name} (RSS)` },
  // SEO / federation / growth: oEmbed discovery link — when someone
  // pastes this URL into WordPress, Ghost, Discourse, etc., the editor
  // reads this <link> and fetches /oembed.json for a rich preview.
  { type: 'application/json+oembed', href: `/oembed.json?url=https%3A%2F%2Fpointcast.xyz%2Fb%2F${block.data.id}`, title: `${block.data.title} (oEmbed)` },
];

/**
 * Farcaster Frame — every block becomes a 1-button Frame when shared
 * in Warpcast / any Farcaster client. MINT-type blocks get an extra
 * "Open on objkt" button when the edition is on mainnet. The objkt
 * link takes you to the collect page, where Beacon-wallet signing
 * happens in-app until Frame v2 mint actions are reliable.
 */
const frameButtons: Array<{ label: string; action?: 'link' | 'post'; target?: string }> = [
  { label: 'Open on PointCast', action: 'link', target: `https://pointcast.xyz/b/${block.data.id}` },
];
if ((block.data.type === 'MINT' || block.data.type === 'FAUCET') && block.data.edition?.contract?.startsWith('KT1') && block.data.edition?.marketplace === 'objkt') {
  frameButtons.push({
    label: 'View on objkt',
    action: 'link',
    target: `https://objkt.com/tokens/${block.data.edition.contract}/${block.data.edition.tokenId}`,
  });
}
if (block.data.external?.url) {
  const pretty = (() => {
    try { return new URL(block.data.external.url, 'https://pointcast.xyz').host.replace(/^www\./, ''); }
    catch { return ''; }
  })();
  if (pretty && pretty !== 'pointcast.xyz' && frameButtons.length < 4) {
    frameButtons.push({
      label: `→ ${pretty}`,
      action: 'link',
      target: block.data.external.url,
    });
  }
}
const frame = {
  image: `https://pointcast.xyz/images/og/b/${block.data.id}.png`,
  aspectRatio: '1.91:1' as const,
  buttons: frameButtons,
};
---

<BlockLayout title={title} description={description} image={ogImage} jsonLd={jsonLd} alternates={alternates} frame={frame}>
  <div class="page">
    <h1 class="sr-only">CH.{ch.code} · Block № {block.data.id} — {block.data.title}</h1>

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">← All blocks</a>
      <span aria-hidden="true">/</span>
      <a href={`/c/${ch.slug}`} style={`color: ${ch.color800}`}>CH.{ch.code} · {ch.name}</a>
      <span aria-hidden="true">/</span>
      <span>№ {block.data.id}</span>
    </nav>

    {block.data.mood && (
      <div class="mood-strip">
        <a href={`/mood/${block.data.mood}`} class="mood-chip mono" aria-label={`Mood: ${block.data.mood}`}>
          <span class="mood-chip__label">MOOD</span>
          <span class="mood-chip__sep" aria-hidden="true">·</span>
          <span class="mood-chip__slug">{block.data.mood.replace(/-/g, ' ')}</span>
          <span class="mood-chip__arrow" aria-hidden="true">→</span>
        </a>
      </div>
    )}

    <div class="detail-frame">
      <BlockCard block={block} detail />
    </div>

    {/* External CTA — any block with external.url that isn't MINT/FAUCET
        (those get their own mint-strip below). Internal URLs like /drum,
        /battle stay in-tab; cross-origin URLs open new tabs. Fixes the
        "dead click on /b/0220 Card of the Day" that Mike caught 2026-04-17. */}
    {block.data.external && !(block.data.type === 'MINT' || block.data.type === 'FAUCET') && (() => {
      const url = block.data.external.url;
      const isInternal = (() => {
        try {
          const u = new URL(url, 'https://pointcast.xyz');
          return u.host.replace(/^www\./, '') === 'pointcast.xyz';
        } catch { return false; }
      })();
      const label = block.data.external.label || 'Open';
      const pretty = (() => {
        try {
          const u = new URL(url, 'https://pointcast.xyz');
          const h = u.host.replace(/^www\./, '');
          return h === 'pointcast.xyz' ? u.pathname : h;
        } catch { return ''; }
      })();
      return (
        <a
          class="external-cta"
          href={url}
          target={isInternal ? '_self' : '_blank'}
          rel={isInternal ? undefined : 'noopener noreferrer'}
          style={`--ch-600: ${ch.color600}; --ch-800: ${ch.color800}; --ch-50: ${ch.color50};`}
        >
          <span class="external-cta__label">→ {label}</span>
          <span class="external-cta__host">{pretty}</span>
        </a>
      );
    })()}

    {/* Mint / claim surface — only on MINT and FAUCET types with an edition */}
    {(block.data.type === 'MINT' || block.data.type === 'FAUCET') && block.data.edition && (
      <div class="mint-strip">
        <MintButton
          contract={block.data.edition.contract}
          tokenId={block.data.edition.tokenId}
          priceMutez={block.data.edition.price === 'free' ? 0 : Math.round(((block.data.edition.price as any)?.tez ?? 0) * 1_000_000)}
          kind={block.data.type === 'FAUCET' ? 'faucet' : 'mint'}
        />
        {block.data.edition.marketplace && block.data.edition.contract.startsWith('KT1') && (
          <a
            class="mint-strip__secondary"
            href={`https://objkt.com/tokens/${block.data.edition.contract}/${block.data.edition.tokenId}`}
            target="_blank"
            rel="noopener"
          >View on objkt ↗</a>
        )}
      </div>
    )}

    {(prev || next) && (
      <nav class="block-nav" aria-label="Adjacent blocks">
        {prev ? (
          <a class="block-nav__link block-nav__link--prev" href={`/b/${prev.data.id}`}>
            <span class="block-nav__dir mono">← OLDER</span>
            <span class="block-nav__meta mono">CH.{CHANNELS[prev.data.channel].code} · №{prev.data.id}</span>
            <span class="block-nav__title">{shortTitle(prev.data.title, 52)}</span>
          </a>
        ) : <span class="block-nav__link block-nav__link--empty"></span>}
        {next ? (
          <a class="block-nav__link block-nav__link--next" href={`/b/${next.data.id}`}>
            <span class="block-nav__dir mono">NEWER →</span>
            <span class="block-nav__meta mono">CH.{CHANNELS[next.data.channel].code} · №{next.data.id}</span>
            <span class="block-nav__title">{shortTitle(next.data.title, 52)}</span>
          </a>
        ) : <span class="block-nav__link block-nav__link--empty"></span>}
      </nav>
    )}

    {/* Companions — editor-curated cross-links. Rendered above auto-related
        so explicit adjacencies (e.g. "also playable on /yee") surface first.
        Per Mike 2026-04-18 Q2 #1 — playlist blocks linking their YeePlayer
        siblings. */}
    {block.data.companions && block.data.companions.length > 0 && (
      <section class="companions" aria-label="Companion surfaces">
        <p class="companions__kicker mono">COMPANIONS · ALSO PLAYABLE / RELATED</p>
        <ul class="companions__list">
          {block.data.companions.map((c) => {
            // Resolve href: 4-digit id → /b/{id} or /yee/{id} depending on surface hint.
            // Full path starting with / → used as-is.
            const isDigit = /^\d{4}$/.test(c.id);
            let href: string;
            if (c.id.startsWith('/') || c.id.startsWith('http')) {
              href = c.id;
            } else if (isDigit && c.surface === 'yee') {
              href = `/yee/${c.id}`;
            } else if (isDigit && c.surface === 'clock') {
              href = `/clock/${c.id}`;
            } else if (isDigit && c.surface === 'poll') {
              href = `/poll/${c.id}`;  // treats id as a poll slug — unusual shape
            } else if (isDigit) {
              href = `/b/${c.id}`;
            } else if (c.surface === 'poll') {
              href = `/poll/${c.id}`;
            } else {
              href = c.id;  // fallback — already a slug/path
            }
            const surfaceLabel = c.surface === 'yee' ? 'YEE'
              : c.surface === 'clock' ? 'CLOCK'
              : c.surface === 'poll' ? 'POLL'
              : c.surface === 'external' ? 'EXT'
              : 'BLOCK';
            return (
              <li>
                <a href={href} class={`companions__item companions__item--${c.surface ?? 'block'}`}>
                  <span class="companions__surface mono">{surfaceLabel}</span>
                  <span class="companions__label">{c.label}</span>
                  <span class="companions__arrow mono" aria-hidden="true">→</span>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    {related.length > 0 && (
      <section class="related" aria-label="Related blocks">
        <div class="related__head">
          <p class="related__kicker mono" style={`color: ${ch.color800}`}>MORE FROM CH.{ch.code} · {ch.name.toUpperCase()}</p>
          <a class="related__all" href={`/c/${ch.slug}`}>See channel →</a>
        </div>
        <ul class="related__list">
          {related.map((r) => (
            <li>
              <a href={`/b/${r.data.id}`} class="related__item">
                <span class="related__id mono">№{r.data.id}</span>
                <span class="related__type mono">{r.data.type}</span>
                <span class="related__title">{shortTitle(r.data.title, 60)}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* SEO: Cite this block — visible copy-to-clipboard widget + canonical
        citation format. The same text ships as `citation` in the JSON-LD
        so LLMs crawling the page see the preferred citation form. */}
    <section class="cite" aria-labelledby="cite-heading">
      <div class="cite__head">
        <p class="cite__label mono" id="cite-heading">CITE THIS BLOCK</p>
        <button class="cite__copy mono" type="button" data-cite-copy aria-label="Copy citation">Copy</button>
      </div>
      <pre class="cite__text" data-cite-text>{citationFull}</pre>
      <p class="cite__note">
        Permanent URL. Safe to cite forever — block IDs never re-use and
        never redirect. Agents: see <a href="/manifesto">/manifesto</a> for
        the full citation guide.
      </p>
    </section>

    {/* SEO: single-pillar context link. Drives internal-link juice from
        the long tail (~150+ blocks) to the three keyword-targeted SEO
        pillars + /blocks reference. Channel → pillar mapping in the
        frontmatter. */}
    {pillar && (
      <aside class="pillar-context" aria-label="Related pillar">
        <p class="pillar-context__kicker mono">PART OF</p>
        <a class="pillar-context__link" href={pillar.url}>
          <span class="pillar-context__title">{pillar.label}</span>
          <span class="pillar-context__note">{pillar.note}</span>
          <span class="pillar-context__arrow" aria-hidden="true">→</span>
        </a>
      </aside>
    )}

    <FeedbackStrip blockId={block.data.id} />

    <aside class="agent-strip">
      <p class="agent-strip__label">MACHINE-READABLE</p>
      <ul>
        <li><a href={`/b/${block.data.id}.json`}>/b/{block.data.id}.json</a></li>
        <li><a href={`/c/${ch.slug}.json`}>/c/{ch.slug}.json</a></li>
        <li><a href={`/c/${ch.slug}.rss`}>/c/{ch.slug}.rss</a></li>
        <li><a href="/archive">/archive</a></li>
        <li><a href="/for-agents">/for-agents</a></li>
      </ul>
    </aside>

    {/* Clipboard handler for the Cite-this widget. Scoped to this page. */}
    <script is:inline>
      document.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-cite-copy]');
        if (!btn) return;
        const text = document.querySelector('[data-cite-text]')?.textContent ?? '';
        if (!text) return;
        navigator.clipboard?.writeText(text).then(() => {
          const original = btn.textContent;
          btn.textContent = 'Copied';
          btn.setAttribute('data-copied', 'true');
          setTimeout(() => {
            btn.textContent = original;
            btn.removeAttribute('data-copied');
          }, 1800);
        });
      });
    </script>
  </div>
</BlockLayout>

