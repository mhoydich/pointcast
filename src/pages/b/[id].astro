---
/**
 * /b/{id} — single-block permalink. JSON-LD + alternates surface.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import BlockLayout from '../../layouts/BlockLayout.astro';
import BlockCard from '../../components/BlockCard.astro';
import MintButton from '../../components/MintButton.astro';
import { CHANNELS } from '../../lib/channels';

export async function getStaticPaths() {
  const blocks = await getCollection('blocks', ({ data }) => !data.draft);
  return blocks.map((block) => ({
    params: { id: block.data.id },
    props: { block },
  }));
}

interface Props { block: CollectionEntry<'blocks'>; }
const { block } = Astro.props;
const ch = CHANNELS[block.data.channel];

const title = `CH.${ch.code} · ${block.data.id} — ${block.data.title}`;
const description = block.data.dek ?? block.data.body?.slice(0, 180) ?? block.data.title;
const ogImage = `/images/og/b/${block.data.id}.png`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  '@id': `https://pointcast.xyz/b/${block.data.id}`,
  identifier: block.data.id,
  name: block.data.title,
  description,
  datePublished: block.data.timestamp.toISOString(),
  inLanguage: 'en-US',
  isPartOf: {
    '@type': 'Collection',
    name: ch.name,
    url: `https://pointcast.xyz/c/${ch.slug}`,
  },
  encodingFormat: 'application/json',
  ...(block.data.external?.url ? { mainEntity: { '@type': 'URL', url: block.data.external.url } } : {}),
  ...(block.data.edition
    ? { offers: { '@type': 'Offer', price: block.data.edition.price === 'free' ? 0 : block.data.edition.price?.tez, priceCurrency: 'XTZ' } }
    : {}),
};

const alternates = [
  { type: 'application/json', href: `/b/${block.data.id}.json`, title: 'Machine-readable block' },
  { type: 'application/json', href: `/c/${ch.slug}.json`, title: `${ch.name} (JSON feed)` },
  { type: 'application/rss+xml', href: `/c/${ch.slug}.rss`, title: `${ch.name} (RSS)` },
];
---

<BlockLayout title={title} description={description} image={ogImage} jsonLd={jsonLd} alternates={alternates}>
  <div class="page">
    <h1 class="sr-only">CH.{ch.code} · Block № {block.data.id} — {block.data.title}</h1>

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">← All blocks</a>
      <span aria-hidden="true">/</span>
      <a href={`/c/${ch.slug}`} style={`color: ${ch.color800}`}>CH.{ch.code} · {ch.name}</a>
      <span aria-hidden="true">/</span>
      <span>№ {block.data.id}</span>
    </nav>

    <div class="detail-frame">
      <BlockCard block={block} detail />
    </div>

    {/* External CTA — any block with external.url that isn't MINT/FAUCET
        (those get their own mint-strip below). Internal URLs like /drum,
        /battle stay in-tab; cross-origin URLs open new tabs. Fixes the
        "dead click on /b/0220 Card of the Day" that Mike caught 2026-04-17. */}
    {block.data.external && !(block.data.type === 'MINT' || block.data.type === 'FAUCET') && (() => {
      const url = block.data.external.url;
      const isInternal = (() => {
        try {
          const u = new URL(url, 'https://pointcast.xyz');
          return u.host.replace(/^www\./, '') === 'pointcast.xyz';
        } catch { return false; }
      })();
      const label = block.data.external.label || 'Open';
      const pretty = (() => {
        try {
          const u = new URL(url, 'https://pointcast.xyz');
          const h = u.host.replace(/^www\./, '');
          return h === 'pointcast.xyz' ? u.pathname : h;
        } catch { return ''; }
      })();
      return (
        <a
          class="external-cta"
          href={url}
          target={isInternal ? '_self' : '_blank'}
          rel={isInternal ? undefined : 'noopener noreferrer'}
          style={`--ch-600: ${ch.color600}; --ch-800: ${ch.color800}; --ch-50: ${ch.color50};`}
        >
          <span class="external-cta__label">→ {label}</span>
          <span class="external-cta__host">{pretty}</span>
        </a>
      );
    })()}

    {/* Mint / claim surface — only on MINT and FAUCET types with an edition */}
    {(block.data.type === 'MINT' || block.data.type === 'FAUCET') && block.data.edition && (
      <div class="mint-strip">
        <MintButton
          contract={block.data.edition.contract}
          tokenId={block.data.edition.tokenId}
          priceMutez={block.data.edition.price === 'free' ? 0 : Math.round(((block.data.edition.price as any)?.tez ?? 0) * 1_000_000)}
          kind={block.data.type === 'FAUCET' ? 'faucet' : 'mint'}
        />
        {block.data.edition.marketplace && block.data.edition.contract.startsWith('KT1') && (
          <a
            class="mint-strip__secondary"
            href={`https://objkt.com/tokens/${block.data.edition.contract}/${block.data.edition.tokenId}`}
            target="_blank"
            rel="noopener"
          >View on objkt ↗</a>
        )}
      </div>
    )}

    <aside class="agent-strip">
      <p class="agent-strip__label">MACHINE-READABLE</p>
      <ul>
        <li><a href={`/b/${block.data.id}.json`}>/b/{block.data.id}.json</a></li>
        <li><a href={`/c/${ch.slug}.json`}>/c/{ch.slug}.json</a></li>
        <li><a href={`/c/${ch.slug}.rss`}>/c/{ch.slug}.rss</a></li>
        <li><a href="/for-agents">/for-agents</a></li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<style>
  .page {
    max-width: 820px;
    margin: 0 auto;
    padding: 20px 20px 80px;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin-bottom: 20px;
  }

  .breadcrumb a { color: var(--pc-accent); }

  /* Detail-mode block ignores grid spans (no parent grid context) */
  .detail-frame :global(.block-card) {
    grid-column: auto;
    grid-row: auto;
  }

  .external-cta {
    margin-top: 14px;
    padding: 14px 16px;
    border: 1.5px solid var(--ch-600);
    border-radius: 2px;
    background: var(--ch-50);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    color: var(--ch-800);
    text-decoration: none;
    transition: background-color 0.12s;
  }
  .external-cta:hover {
    background: color-mix(in oklab, var(--ch-600) 18%, #fff);
    text-decoration: none;
  }
  .external-cta__label {
    font-family: var(--pc-font-sans);
    font-size: 15px;
    font-weight: 500;
  }
  .external-cta__host {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
  }

  .mint-strip {
    margin-top: 14px;
    padding: 14px;
    border: 1.5px solid var(--pc-ink);
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mint-strip__secondary {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-accent);
  }

  .agent-strip {
    margin-top: 24px;
    padding-top: 14px;
    border-top: 1px dashed var(--pc-rule);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .agent-strip__label { margin: 0 0 6px; color: var(--pc-ink-soft); font-weight: 500; }
  .agent-strip ul {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
</style>
