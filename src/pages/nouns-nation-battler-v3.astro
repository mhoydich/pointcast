      <div class="sprint-grid">
        <section class="sprint-timeline" aria-labelledby="timeline-title">
          <p class="kicker">Launch calendar</p>
          <h3 id="timeline-title">The next season should feel scheduled before it feels big.</h3>
          <div>
            {sprintTimeline.map((item) => (
              <article>
                <span>{item.day}</span>
                <strong>{item.title}</strong>
                <p>{item.body}</p>
