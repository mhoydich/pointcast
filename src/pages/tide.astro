  .tide__foam span:nth-child(10) { left: 67%; animation-duration: 16s; animation-delay:  3.5s; width: 6px; }
  .tide__foam span:nth-child(11) { left: 74%; animation-duration: 14s; animation-delay:  6.5s; width: 5px; }
  .tide__foam span:nth-child(12) { left: 81%; animation-duration: 18s; animation-delay:  0.8s; width: 7px; }
