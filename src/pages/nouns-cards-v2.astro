---
import BlockLayout from '../layouts/BlockLayout.astro';
import MintButton from '../components/MintButton.astro';
import contracts from '../data/contracts.json';

const KT1 = (contracts as any).visit_nouns?.mainnet ?? '';
const mintPriceMutez = Number((contracts as any).visit_nouns?.mintPriceMutez ?? 0);
const description = 'A global set of 33 mintable PointCast Nouns cards: clean real Nouns and real Nouns staged with 3D depth.';

const cards = [
  { id: 33, title: 'Tokyo Dawn', route: '/tv', channel: 'Tokyo', asset: '01', note: 'Transit glow, vending light, first train signal.' },
  { id: 88, title: 'Seoul Switchboard', route: '/for-agents', channel: 'Seoul', asset: '02', note: 'Fast chat, bright rooms, agent-ready rhythm.' },
  { id: 137, title: 'Mexico City Air', route: '/now', channel: 'Mexico City', asset: '03', note: 'Morning traffic, museum colors, wide avenue pulse.' },
  { id: 205, title: 'Lagos Market', route: '/publish', channel: 'Lagos', asset: '04', note: 'Open-air commerce with a broadcast backbone.' },
  { id: 217, title: 'Nairobi Mesh', route: '/mesh', channel: 'Nairobi', asset: '05', note: 'Local nodes, open air, network heat.' },
  { id: 284, title: 'Mumbai Monsoon', route: '/room-weather', channel: 'Mumbai', asset: '06', note: 'Rain-bright streets and practical coordination.' },
  { id: 313, title: 'El Segundo Signal', route: '/local', channel: 'El Segundo', asset: '07', note: 'PointCast home base, coastal and operational.' },
  { id: 354, title: 'Dubai Nightline', route: '/timeline', channel: 'Dubai', asset: '08', note: 'Glass, desert, airport-time cadence.' },
  { id: 387, title: 'Singapore Ledger', route: '/editions', channel: 'Singapore', asset: '09', note: 'Clean rails, clean receipts, clean mint flow.' },
  { id: 420, title: 'Bangkok Orchard', route: '/garden-yield', channel: 'Bangkok', asset: '10', note: 'Street fruit, garden notes, humid evening light.' },
  { id: 447, title: 'Jakarta Dispatch', route: '/feed.xml', channel: 'Jakarta', asset: '01', note: 'Many islands, one signal surface.' },
  { id: 501, title: 'Sydney Current', route: '/new-ocean', channel: 'Sydney', asset: '02', note: 'Harbor motion and blue-hour collection energy.' },
  { id: 523, title: 'London Late Show', route: '/tv', channel: 'London', asset: '03', note: 'Rain on glass, borough-by-borough signal.' },
  { id: 557, title: 'Paris Archive', route: '/archive', channel: 'Paris', asset: '04', note: 'A card for notes, cafes, and tiny histories.' },
  { id: 601, title: 'Berlin Room', route: '/radio', channel: 'Berlin', asset: '05', note: 'Club-adjacent radio with sober tooling.' },
  { id: 642, title: 'Lisbon Light', route: '/walk', channel: 'Lisbon', asset: '06', note: 'Hill paths, tiled edges, a soft walking route.' },
  { id: 689, title: 'Reykjavik Beacon', route: '/beacon', channel: 'Reykjavik', asset: '07', note: 'North Atlantic quiet with a bright on-chain mark.' },
  { id: 742, title: 'New York Stack', route: '/stack', channel: 'New York', asset: '08', note: 'Dense blocks, faster publishing, louder proof.' },
  { id: 777, title: 'Toronto Commons', route: '/dao', channel: 'Toronto', asset: '09', note: 'Civic calm, public notes, shared mint rails.' },
  { id: 808, title: 'Vancouver Rain', route: '/moods', channel: 'Vancouver', asset: '10', note: 'Soft weather card for the evergreen loop.' },
  { id: 842, title: 'Los Angeles Field', route: '/tv/los-angeles', channel: 'Los Angeles', asset: '01', note: 'Wide signal, many neighborhoods, one card.' },
  { id: 888, title: 'Honolulu Drift', route: '/meditate', channel: 'Honolulu', asset: '02', note: 'Ocean rest, slower attention, mintable memory.' },
  { id: 925, title: 'Sao Paulo Pulse', route: '/sprint', channel: 'Sao Paulo', asset: '03', note: 'City-scale velocity with a clean collector layer.' },
  { id: 969, title: 'Buenos Aires Night', route: '/collabs', channel: 'Buenos Aires', asset: '04', note: 'Late dinner, bright rooms, collaborative dispatch.' },
  { id: 1001, title: 'Santiago Ridge', route: '/nature', channel: 'Santiago', asset: '05', note: 'Mountain line, clear sky, grounded proof.' },
  { id: 1042, title: 'Bogota Altitude', route: '/garden-yield', channel: 'Bogota', asset: '06', note: 'High city air and native-plant intelligence.' },
  { id: 1077, title: 'Cairo Sun', route: '/glossary', channel: 'Cairo', asset: '07', note: 'Old stone, new index, durable definitions.' },
  { id: 1111, title: 'Marrakech Courtyard', route: '/products', channel: 'Marrakech', asset: '08', note: 'Color, shade, objects with a collecting story.' },
  { id: 1138, title: 'Accra Broadcast', route: '/share', channel: 'Accra', asset: '09', note: 'Music, makers, outbound social signal.' },
  { id: 1164, title: 'Johannesburg Gold', route: '/collection', channel: 'Johannesburg', asset: '10', note: 'Marketplace energy and a clean Tezos path.' },
  { id: 1189, title: 'Istanbul Crossing', route: '/routes', channel: 'Istanbul', asset: '01', note: 'Two continents, one route map, mintable proof.' },
  { id: 1193, title: 'Taipei Packet', route: '/ai-stack', channel: 'Taipei', asset: '02', note: 'Silicon weather, small tools, bright packets.' },
  { id: 1199, title: 'Auckland Return', route: '/today', channel: 'Auckland', asset: '03', note: 'Tomorrow-facing card at the edge of the map.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://pointcast.xyz/nouns-cards-v2',
  name: 'PointCast Nouns Cards v2',
  description,
  url: 'https://pointcast.xyz/nouns-cards-v2',
};
---

<BlockLayout title="Nouns Cards v2" description={description} jsonLd={jsonLd}>
  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>Nouns Cards v2</span>
    </nav>

    <header class="head">
      <p class="kicker">Actual Nouns · global 33 · Tezos mintable</p>
      <h1>Thirty-three real Nouns, wired for the world.</h1>
      <p>
        No generated fake Nouns. Every subject below is loaded directly from
        <code>noun.pics</code>. Direction A is clean and card-like. Direction B
        uses the generated PointCast backgrounds with 3D staging around the same real Noun art.
        Each card can mint through the Visit Nouns FA2 on Tezos mainnet.
      </p>
      <div class="actions">
        <a href="#actual">Global 33</a>
        <a href="#depth">3D creative</a>
        <a href={`https://objkt.com/collection/${KT1}`} target="_blank" rel="noopener">objkt collection</a>
        <a href="/collection/visit-nouns">Visit Nouns collection</a>
        <a href="/nouns-cards-v3">v3 grit edition</a>
      </div>
    </header>

    <section id="actual" class="section" aria-labelledby="actual-title">
      <div class="section__head">
        <p class="kicker">Direction A</p>
        <h2 id="actual-title">Global Nouns cards</h2>
      </div>
      <div class="clean-grid">
        {cards.map((card) => (
          <article class="clean-card">
            <header>
              <span>POINTCAST</span>
              <span>PCVN-{card.asset}</span>
            </header>
            <div class="clean-card__noun">
              <img src={`https://noun.pics/${card.id}.svg`} alt={`Noun ${card.id}`} width="320" height="320" loading="lazy" />
            </div>
            <div class="clean-card__copy">
              <p>{card.channel}</p>
              <h3>{card.title}</h3>
              <span>Noun #{card.id} · real noun.pics SVG</span>
              <small>{card.note}</small>
            </div>
            <footer>
              <a href={card.route}>Route</a>
              <a href={`https://objkt.com/tokens/${KT1}/${card.id}`} target="_blank" rel="noopener">objkt</a>
              <a href={`https://noun.pics/${card.id}.svg`} target="_blank" rel="noopener">Noun SVG</a>
            </footer>
            <div class="mint-row">
              <MintButton contract={KT1} tokenId={card.id} priceMutez={mintPriceMutez} label="Mint on Tezos" />
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="depth" class="section" aria-labelledby="depth-title">
      <div class="section__head">
        <p class="kicker">Direction B</p>
        <h2 id="depth-title">Global Nouns, 3D PointCast stages</h2>
      </div>
      <div class="depth-grid">
        {cards.map((card, index) => (
          <article class="depth-card">
            <img
              class="depth-card__bg"
              src={`/images/nouns-cards/pointcast-noun-card-${card.asset}.png`}
              alt=""
              width="1024"
              height="1024"
              loading={index < 3 ? 'eager' : 'lazy'}
            />
            <div class="depth-card__scene">
              <header>
                <span>POINTCAST</span>
                <span>NOUN #{card.id}</span>
              </header>
              <div class="depth-card__noun" aria-label={`Noun ${card.id}`}>
                <span class="depth-card__shadow" aria-hidden="true"></span>
                <span class="depth-card__slab depth-card__slab--back" aria-hidden="true"></span>
                <span class="depth-card__slab depth-card__slab--mid" aria-hidden="true"></span>
                <img src={`https://noun.pics/${card.id}.svg`} alt={`Noun ${card.id}`} width="320" height="320" loading="lazy" />
              </div>
              <div class="depth-card__copy">
                <p>{card.channel}</p>
                <h3>{card.title}</h3>
                <span>{card.note}</span>
              </div>
            </div>
            <footer>
              <a href={card.route}>Open</a>
              <a href={`https://noun.pics/${card.id}.svg`} target="_blank" rel="noopener">Real Noun</a>
              <a href={`https://objkt.com/tokens/${KT1}/${card.id}`} target="_blank" rel="noopener">Tezos</a>
            </footer>
            <div class="depth-card__mint">
              <MintButton contract={KT1} tokenId={card.id} priceMutez={mintPriceMutez} label="Mint" />
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</BlockLayout>

<style>
  .page {
    max-width: 1440px;
    margin: 0 auto;
    padding: 20px 20px 90px;
  }

  .crumb,
  .kicker,
  .actions,
  .clean-card header,
  .clean-card footer,
  .clean-card__copy p,
  .clean-card__copy span,
  .depth-card header,
  .depth-card footer,
  .depth-card__copy p,
  .depth-card__copy span {
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .crumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
    color: var(--pc-ink-soft, #5f5e5a);
    font-size: 10px;
  }

  a {
    color: var(--pc-accent, #185fa5);
  }

  .head {
    display: grid;
    gap: 12px;
    margin-bottom: 24px;
    padding: 18px 0;
    border-top: 1.5px solid var(--pc-ink, #12110e);
    border-bottom: 1.5px solid var(--pc-ink, #12110e);
  }

  .kicker {
    margin: 0;
    color: var(--pc-accent, #185fa5);
    font-size: 10px;
  }

  h1,
  .section__head h2 {
    margin: 0;
    color: var(--pc-ink, #12110e);
    font-family: var(--pc-font-sans, system-ui, sans-serif);
    font-weight: 540;
    letter-spacing: 0;
  }

  h1 {
    max-width: 920px;
    font-size: clamp(42px, 8vw, 96px);
    line-height: 0.92;
  }

  .head p:not(.kicker) {
    max-width: 74ch;
    margin: 0;
    color: var(--pc-ink-soft, #5f5e5a);
    font-size: 16px;
    line-height: 1.5;
  }

  .head code {
    color: var(--pc-ink, #12110e);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    font-size: 10px;
  }

  .section {
    margin-top: 28px;
    scroll-margin-top: 72px;
  }

  .section__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1.5px solid var(--pc-ink, #12110e);
  }

  .section__head h2 {
    font-size: clamp(28px, 5vw, 58px);
    line-height: 0.95;
  }

  .clean-grid,
  .depth-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
  }

  .clean-card,
  .depth-card {
    min-width: 0;
    border: 1.5px solid var(--pc-ink, #12110e);
    background: var(--pc-paper, #fffaf0);
  }

  .clean-card header,
  .clean-card footer,
  .depth-card header,
  .depth-card footer {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    padding: 9px 10px;
    font-size: 9px;
  }

  .clean-card header,
  .depth-card header {
    border-bottom: 1.5px solid var(--pc-ink, #12110e);
    color: var(--pc-ink, #12110e);
  }

  .clean-card footer,
  .depth-card footer {
    border-top: 1.5px solid var(--pc-ink, #12110e);
  }

  .clean-card__noun {
    display: grid;
    place-items: center;
    aspect-ratio: 1;
    padding: 18px;
    background:
      linear-gradient(135deg, rgba(24, 95, 165, 0.11), transparent 42%),
      linear-gradient(315deg, rgba(232, 154, 45, 0.18), transparent 36%),
      #f7f1e4;
  }

  .clean-card__noun img {
    width: min(82%, 280px);
    height: auto;
    image-rendering: pixelated;
  }

  .clean-card__copy {
    display: grid;
    gap: 4px;
    padding: 12px;
    min-height: 126px;
    border-top: 1.5px solid var(--pc-ink, #12110e);
  }

  .clean-card__copy p,
  .depth-card__copy p {
    margin: 0;
    color: var(--pc-accent, #185fa5);
    font-size: 9px;
    font-weight: 700;
  }

  .clean-card__copy h3,
  .depth-card__copy h3 {
    margin: 0;
    color: var(--pc-ink, #12110e);
    font-family: var(--pc-font-sans, system-ui, sans-serif);
    font-size: clamp(18px, 2vw, 24px);
    line-height: 1;
    font-weight: 650;
    letter-spacing: 0;
  }

  .clean-card__copy span {
    color: var(--pc-ink, #12110e);
    font-size: 8.5px;
  }

  .clean-card__copy small {
    color: var(--pc-ink-soft, #5f5e5a);
    font-size: 12px;
    line-height: 1.3;
  }

  .mint-row,
  .depth-card__mint {
    padding: 10px;
    border-top: 1.5px solid var(--pc-ink, #12110e);
    background: rgba(255, 250, 240, 0.96);
  }

  .mint-row :global(.mint-btn),
  .depth-card__mint :global(.mint-btn) {
    width: 100%;
  }

  .mint-row :global(.mint-status),
  .depth-card__mint :global(.mint-status) {
    min-height: 1rem;
    overflow-wrap: anywhere;
  }

  .depth-card {
    position: relative;
    overflow: hidden;
  }

  .depth-card__bg {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }

  .depth-card__scene {
    position: absolute;
    inset: 0 0 31px;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: 10px;
    perspective: 900px;
    pointer-events: none;
  }

  .depth-card__scene header {
    padding: 0;
    border: 0;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.75);
  }

  .depth-card__noun {
    position: relative;
    align-self: center;
    justify-self: center;
    width: 62%;
    max-width: 250px;
    min-width: 150px;
    aspect-ratio: 1;
    transform: rotateX(10deg) rotateY(-11deg) translateY(-4px);
    transform-style: preserve-3d;
  }

  .depth-card__noun img,
  .depth-card__slab,
  .depth-card__shadow {
    position: absolute;
    inset: 0;
  }

  .depth-card__noun img {
    display: block;
    width: 100%;
    height: auto;
    padding: 11px;
    border: 2px solid rgba(18, 17, 14, 0.95);
    background: rgba(255, 250, 240, 0.94);
    image-rendering: pixelated;
    transform: translateZ(48px);
    filter: drop-shadow(16px 18px 0 rgba(18, 17, 14, 0.22));
  }

  .depth-card__slab {
    border: 2px solid rgba(18, 17, 14, 0.65);
    background: rgba(24, 95, 165, 0.54);
  }

  .depth-card__slab--back {
    transform: translate3d(18px, 19px, 12px);
    background: rgba(232, 154, 45, 0.72);
  }

  .depth-card__slab--mid {
    transform: translate3d(10px, 11px, 30px);
    background: rgba(15, 110, 86, 0.62);
  }

  .depth-card__shadow {
    top: auto;
    height: 26%;
    transform: translate3d(24px, 74%, -20px) rotateX(72deg);
    border-radius: 50%;
    background: rgba(18, 17, 14, 0.28);
    filter: blur(8px);
  }

  .depth-card__copy {
    display: grid;
    gap: 4px;
    padding: 10px;
    border: 1.5px solid rgba(18, 17, 14, 0.85);
    background: rgba(255, 250, 240, 0.91);
  }

  .depth-card__copy span {
    color: var(--pc-ink-soft, #5f5e5a);
    font-size: 9px;
    line-height: 1.3;
  }

  @media (max-width: 1180px) {
    .clean-grid,
    .depth-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .section__head {
      display: grid;
      align-items: start;
    }

    .clean-grid,
    .depth-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
