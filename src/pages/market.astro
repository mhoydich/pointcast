    color: var(--color-warm);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }
  .market__link:hover { color: var(--color-ink); }
  .market__pending-pill {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 999px;
    background: rgba(168, 130, 50, 0.1);
    color: rgb(150, 110, 30);
    border: 1px solid rgba(168, 130, 50, 0.25);
    font-family: var(--font-mono, monospace);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  @media (max-width: 540px) {
    .market__about { grid-template-columns: 1fr; }
    .market__title { font-size: 30px; }
    .market__dek { font-size: 15px; }
  }
</style>

<script>
  // /market — three-mode flow + browse grid + list form + buy.
  // Plain JS, Vite-bundled. Lazy-imports Taquito + Beacon on the actual
  // sign click so the browse path stays fast (~200ms vs. ~3s with eager
  // Taquito loaded).

  const MARKETPLACE_KT1 = "MARKETPLACE_KT1_PLACEHOLDER";  // overwritten below

  function readMarketplaceKt1() {
    const form = document.getElementById('market-list-form');
    return (form && form.getAttribute('data-marketplace-kt1')) || '';
  }

  function readWallet() {
    try {
      const raw = localStorage.getItem('pc:wallet');
      if (!raw) return null;
      const w = JSON.parse(raw);
      return (w && w.address && w.chain === 'tezos') ? w : null;
    } catch (e) { return null; }
  }

  // Read the live-collections registry the Astro frontmatter wrote into a
  // data-attribute on the list form. The registry has slug + name + kt1 for
  // each live FA2 we know about — adding a new collection in contracts.json
  // surfaces here automatically at next build.
  function readCollections() {
    const form = document.getElementById('market-list-form');
    const raw = form && form.getAttribute('data-collections');
    if (!raw) return [];
    try { return JSON.parse(raw); } catch (e) { return []; }
  }

  function findCollectionByKt1(kt1) {
    if (!kt1) return null;
    const list = readCollections();
    for (let i = 0; i < list.length; i++) {
      if (list[i].kt1 === kt1) return list[i];
    }
    return null;
  }

  // Per-collection conventions: image URI pattern + token-id → name lookups.
  // Keyed by slug from contracts.json so adding a collection is one place.
  const COLLECTION_RULES = {
    coffee_mugs: {
      imageFor: function (tokenId) {
        const slugs = { 0: 'ceramic', 1: 'espresso', 2: 'latte', 3: 'paper', 4: 'bistro' };
        const slug = slugs[String(tokenId)];
        return slug ? '/images/coffee-mugs/' + slug + '.svg' : null;
      },
      nameFor: function (tokenId) {
        const names = { 0: 'Ceramic Mug', 1: 'Espresso Cup', 2: 'Latte Glass', 3: 'Paper Cup', 4: 'Bistro Cup' };
        return names[String(tokenId)] || ('Coffee Mug #' + tokenId);
      },
      maxTokenId: 4,
    },
    visit_nouns: {
      imageFor: function (tokenId) { return 'https://noun.pics/' + tokenId + '.svg'; },
      nameFor: function (tokenId) { return 'Visit Noun #' + tokenId; },
      maxTokenId: 1199,
    },
    window_snapshots: {
      imageFor: function (tokenId) {
        const slugs = { 0: '0-galley', 1: '1-long-room', 2: '2-lamp-wall' };
        const slug = slugs[String(tokenId)];
        return slug ? '/images/window-snapshots/' + slug + '.jpg' : null;
      },
      nameFor: function (tokenId) {
        const names = { 0: 'Galley', 1: 'Long Room', 2: 'Lamp Wall' };
        return names[String(tokenId)] || ('Window Snapshot #' + tokenId);
      },
      maxTokenId: 2,
    },
  };

  function imageUriFor(fa2Kt1, tokenId) {
    const c = findCollectionByKt1(fa2Kt1);
    const rules = c && COLLECTION_RULES[c.slug];
    return rules ? rules.imageFor(tokenId) : null;
  }

  function collectionNameFor(fa2Kt1) {
    const c = findCollectionByKt1(fa2Kt1);
    if (c) return c.name;
    return fa2Kt1 ? (fa2Kt1.slice(0, 8) + '…' + fa2Kt1.slice(-4)) : '';
  }

  function tokenNameFor(fa2Kt1, tokenId) {
    const c = findCollectionByKt1(fa2Kt1);
    const rules = c && COLLECTION_RULES[c.slug];
    return rules ? rules.nameFor(tokenId) : ('Token #' + tokenId);
  }

  function shortAddr(a) {
    if (!a) return '?';
    return a.slice(0, 6) + '…' + a.slice(-4);
  }

  function setMode(mode, label) {
    const row = document.getElementById('market-status-row');
    const lbl = document.getElementById('market-status-label');
    if (row) row.setAttribute('data-mode', mode);
    if (lbl) lbl.textContent = label;
  }

  function setListEnabled(enabled, label) {
    const btn = document.getElementById('market-list-btn');
    const lbl = document.getElementById('market-list-label');
    if (btn) btn.disabled = !enabled;
    if (lbl && label) lbl.textContent = label;
  }

  // ── Your tokens ──────────────────────────────────────────────────────
  // Query FA2 balances for each supported live collection and surface what
  // the connected wallet could list. One TzKT call per collection (parallel).
  async function loadMyTokens() {
    const grid = document.getElementById('market-mine-grid');
    const summary = document.getElementById('market-mine-summary');
    const empty = document.getElementById('market-mine-empty');
    if (!grid || !summary) return;

    const wallet = readWallet();
    const colls = readCollections();

    if (!wallet) {
      grid.hidden = true;
      grid.innerHTML = '';
      if (empty) empty.hidden = true;
      summary.textContent = 'connect a wallet to see what you can list';
      return;
    }
    if (colls.length === 0) {
      grid.hidden = true;
      grid.innerHTML = '';
      if (empty) empty.hidden = true;
      summary.textContent = 'no live collections yet';
      return;
    }

    summary.textContent = 'reading your FA2 balances…';

    try {
      // Parallel TzKT balance calls — one per live collection.
      const responses = await Promise.all(
        colls.map(function (c) {
          const url =
            'https://api.tzkt.io/v1/tokens/balances' +
            '?account=' + encodeURIComponent(wallet.address) +
            '&token.contract=' + encodeURIComponent(c.kt1) +
            '&balance.gt=0' +
            '&select=token.tokenId,balance' +
            '&limit=200';
          return fetch(url, { cache: 'no-store' })
            .then(function (r) { if (!r.ok) throw new Error('tzkt ' + r.status); return r.json(); })
            .then(function (rows) { return { coll: c, rows: Array.isArray(rows) ? rows : [] }; })
            .catch(function () { return { coll: c, rows: [] }; });
        })
      );

      // Flatten into a list of { coll, tokenId, balance } cards.
      const cards = [];
      for (let i = 0; i < responses.length; i++) {
        const { coll, rows } = responses[i];
        for (let j = 0; j < rows.length; j++) {
          const row = rows[j];
          // tzkt's select=token.tokenId,balance returns
          // [{ "token.tokenId": "0", "balance": "1" }, ...]
          const tokenIdRaw = row['token.tokenId'] !== undefined ? row['token.tokenId'] : (row.tokenId !== undefined ? row.tokenId : null);
          if (tokenIdRaw == null) continue;
          const tokenId = parseInt(tokenIdRaw, 10);
          const balance = parseInt(row.balance || '0', 10) || 0;
          if (balance <= 0) continue;
          cards.push({ coll, tokenId, balance });
        }
      }

      if (cards.length === 0) {
        grid.hidden = true;
        grid.innerHTML = '';
        if (empty) empty.hidden = false;
        summary.textContent = 'wallet ' + shortAddr(wallet.address) + ' · no listable tokens yet';
        return;
      }

      if (empty) empty.hidden = true;
      grid.hidden = false;
      summary.textContent =
        cards.length + ' listable token' + (cards.length === 1 ? '' : 's') +
        ' · wallet ' + shortAddr(wallet.address);

      grid.innerHTML = cards.map(function (card) {
        const imageUri = imageUriFor(card.coll.kt1, card.tokenId);
        const name = tokenNameFor(card.coll.kt1, card.tokenId);
        const balanceLabel = card.balance > 1 ? ('×' + card.balance + ' held') : 'held';
        return (
          '<li class="market-card market-card--mine" data-fa2="' + card.coll.kt1 + '" data-token-id="' + card.tokenId + '">' +
            '<div class="market-card__art">' +
              (imageUri ? '<img src="' + imageUri + '" alt="' + name + '" loading="lazy" />' : '<svg viewBox="0 0 24 24"><rect width="24" height="24" fill="#eee"/></svg>') +
            '</div>' +
            '<div class="market-card__body">' +
              '<p class="market-card__collection">' + card.coll.name + ' · #' + card.tokenId + '</p>' +
              '<p class="market-card__name">' + name + '</p>' +
              '<p class="market-card__seller">' + balanceLabel + '</p>' +
              '<button class="market-card__buy" data-list-fa2="' + card.coll.kt1 + '" data-list-token="' + card.tokenId + '">List →</button>' +
            '</div>' +
          '</li>'
        );
      }).join('');

      grid.querySelectorAll('[data-list-fa2]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          prefillListForm(btn.getAttribute('data-list-fa2'), parseInt(btn.getAttribute('data-list-token'), 10));
        });
      });
    } catch (err) {
      const msg = (err && err.message) ? err.message : String(err);
      grid.hidden = true;
      grid.innerHTML = '';
      if (empty) empty.hidden = true;
      summary.textContent = 'failed to read your balances: ' + msg;
    }
  }

  function prefillListForm(fa2Kt1, tokenId) {
    const collEl = /** @type {HTMLSelectElement|null} */ (document.getElementById('market-list-collection'));
    const tokenEl = /** @type {HTMLInputElement|null} */ (document.getElementById('market-list-token-id'));
    const priceEl = /** @type {HTMLInputElement|null} */ (document.getElementById('market-list-price'));
    if (collEl) {
      for (let i = 0; i < collEl.options.length; i++) {
        if (collEl.options[i].value === fa2Kt1) {
          collEl.selectedIndex = i;
          break;
        }
      }
    }
    if (tokenEl) tokenEl.value = String(tokenId);
    const form = document.getElementById('market-list-form');
    if (form && form.scrollIntoView) form.scrollIntoView({ behavior: 'smooth', block: 'center' });
    if (priceEl) setTimeout(function () { try { priceEl.focus(); } catch (e) {} }, 600);
  }

  // ── Browse grid ──────────────────────────────────────────────────────
  async function loadAsks() {
    const grid = document.getElementById('market-grid');
    const empty = document.getElementById('market-empty');
    const summary = document.getElementById('market-browse-summary');
    const kt1 = readMarketplaceKt1();

    if (!grid) return;

    if (!kt1 || !kt1.startsWith('KT1')) {
      setMode('pending', 'marketplace · awaiting origination');
      setListEnabled(false, 'awaiting marketplace contract');
      if (summary) summary.textContent = 'marketplace contract not yet originated · ' +
        'admin can deploy at /admin/deploy/marketplace';
      return;
    }

    setMode('loading', 'fetching listings…');
    if (summary) summary.textContent = 'reading marketplace storage…';

    try {
      // 1. Find the asks bigmap pointer
      const sRes = await fetch('https://api.tzkt.io/v1/contracts/' + kt1 + '/storage', { cache: 'no-store' });
      if (!sRes.ok) throw new Error('tzkt /storage ' + sRes.status);
      const storage = await sRes.json();
      const asksPointer = (typeof storage.asks === 'number') ? storage.asks : null;
      if (asksPointer == null) throw new Error('storage.asks missing or not a bigmap pointer');

      // 2. List the ask records
      const kRes = await fetch(
        'https://api.tzkt.io/v1/bigmaps/' + asksPointer + '/keys?limit=100&select=key,value&active=true&sort.desc=id',
        { cache: 'no-store' },
      );
      if (!kRes.ok) throw new Error('tzkt /bigmaps ' + kRes.status);
      const keys = await kRes.json();

      const wallet = readWallet();
      const myAddr = (wallet && wallet.address) || '';

      grid.innerHTML = '';
      if (!Array.isArray(keys) || keys.length === 0) {
        setMode('empty', 'live · no listings yet');
        if (summary) summary.textContent = 'no listings · be the first to list below';
        if (empty) empty.style.display = '';
        else grid.innerHTML = '<li class="market__empty mono">no listings yet · be the first to list below</li>';
        return;
      }
      setMode('active', keys.length + ' listing' + (keys.length === 1 ? '' : 's') + ' live');
      if (summary) summary.textContent = keys.length + ' active listing' + (keys.length === 1 ? '' : 's');

      grid.innerHTML = keys.map(function (row) {
        const askId = row.key;
        const v = row.value || {};
        const fa2Kt1 = v.fa2_contract;
        const tokenId = v.token_id;
        const seller = v.seller;
        const priceMutez = parseInt(v.amount_mutez, 10) || 0;
        const priceXtz = (priceMutez / 1_000_000).toFixed(priceMutez % 1_000_000 === 0 ? 0 : 2);
        const royaltyBps = parseInt(v.royalty_bps, 10) || 0;

        const imageUri = imageUriFor(fa2Kt1, tokenId);
        const name = tokenNameFor(fa2Kt1, tokenId);
        const collection = collectionNameFor(fa2Kt1);
        const isSelf = myAddr && seller && seller.toLowerCase() === myAddr.toLowerCase();

        return (
          '<li class="market-card" data-ask-id="' + askId + '" data-fa2="' + fa2Kt1 + '" data-token-id="' + tokenId + '" data-price="' + priceMutez + '">' +
            '<div class="market-card__art">' +
              (imageUri ? '<img src="' + imageUri + '" alt="' + name + '" loading="lazy" />' : '<svg viewBox="0 0 24 24"><rect width="24" height="24" fill="#eee"/></svg>') +
            '</div>' +
            '<div class="market-card__body">' +
              '<p class="market-card__collection">' + collection + ' · #' + tokenId + '</p>' +
              '<p class="market-card__name">' + name + '</p>' +
              '<p class="market-card__price">' + priceXtz + ' ꜩ</p>' +
              '<p class="market-card__seller">seller ' + shortAddr(seller) + (royaltyBps > 0 ? ' · ' + (royaltyBps / 100).toFixed(1) + '% royalty' : '') + '</p>' +
              (isSelf
                ? '<div class="market-card__own">' +
                    '<div class="market-card__update-row">' +
                      '<input type="number" class="market-card__update-input" data-update-input="' + askId + '" min="0" step="0.000001" placeholder="' + priceXtz + '" />' +
                      '<button class="market-card__update-btn" data-update-ask="' + askId + '" title="update price">↻</button>' +
                    '</div>' +
                    '<button class="market-card__buy" data-state="self" data-cancel-ask="' + askId + '" title="cancel this listing">your listing · cancel</button>' +
                  '</div>'
                : '<button class="market-card__buy" data-buy-ask="' + askId + '">Buy for ' + priceXtz + ' ꜩ</button>') +
            '</div>' +
          '</li>'
        );
      }).join('');

      // Wire buy handlers per card
      grid.querySelectorAll('[data-buy-ask]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const card = btn.closest('.market-card');
          if (!card) return;
          buyAsk(parseInt(btn.getAttribute('data-buy-ask'), 10), parseInt(card.getAttribute('data-price'), 10), btn);
        });
      });
      // Wire cancel handlers for own listings
      grid.querySelectorAll('[data-cancel-ask]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          cancelAsk(parseInt(btn.getAttribute('data-cancel-ask'), 10), btn);
        });
      });
      // Wire update_ask handlers for own listings
      grid.querySelectorAll('[data-update-ask]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const askId = parseInt(btn.getAttribute('data-update-ask'), 10);
          const input = grid.querySelector('[data-update-input="' + askId + '"]');
          const newXtz = input ? parseFloat(input.value) : NaN;
          if (Number.isNaN(newXtz) || newXtz < 0) {
            btn.textContent = '?';
            setTimeout(function () { btn.textContent = '↻'; }, 1500);
            return;
          }
          updateAsk(askId, Math.floor(newXtz * 1_000_000), btn);
        });
      });
    } catch (err) {
      const msg = (err && err.message) ? err.message : String(err);
      setMode('pending', 'marketplace · tzkt error');
      if (summary) summary.textContent = 'failed to load listings: ' + msg;
    }
  }

  // ── Buy flow ─────────────────────────────────────────────────────────
  async function buyAsk(askId, priceMutez, btn) {
    const wallet = readWallet();
    if (!wallet) {
      try { window.dispatchEvent(new CustomEvent('pc:open-wallet-menu')); } catch (e) {}
      return;
    }
    const kt1 = readMarketplaceKt1();
    if (!kt1) return;

    const original = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'awaiting kukai…';

    try {
      const taquito = await import('@taquito/taquito');
      const beacon = await import('@taquito/beacon-wallet');
      const tezos = new taquito.TezosToolkit('https://mainnet.api.tez.ie');
      const beaconWallet = new beacon.BeaconWallet({
        name: 'PointCast Market',
        network: { type: 'mainnet' },
      });
      tezos.setWalletProvider(beaconWallet);
      const active = await beaconWallet.client.getActiveAccount();
      if (!active || (active.network && active.network.type !== 'mainnet')) {
        try { await beaconWallet.clearActiveAccount(); } catch (e) {}
        await beaconWallet.client.requestPermissions();
      }
      const contract = await tezos.wallet.at(kt1);
      const op = await contract.methodsObject
        .fulfill_ask(askId)
        .send({ amount: priceMutez, mutez: true });
      btn.textContent = 'broadcast ' + (op.opHash || '').slice(0, 8) + '…';
      await op.confirmation();
      btn.textContent = '✓ bought';
      // Refresh the grid to drop the now-fulfilled ask.
      setTimeout(loadAsks, 1500);
    } catch (err) {
      const msg = (err && err.message) ? err.message : String(err);
      if (/ABORTED|reject|cancel/i.test(msg)) btn.textContent = 'cancelled';
      else if (/INCORRECT_AMOUNT/i.test(msg)) btn.textContent = 'price changed · refresh';
      else if (/NotEnoughBalance|balance/i.test(msg)) btn.textContent = 'not enough ꜩ';
      else btn.textContent = 'error: ' + msg.slice(0, 40);
      setTimeout(function () { btn.disabled = false; btn.textContent = original; }, 4000);
    }
  }

  // ── Cancel flow (seller's own listings) ─────────────────────────────
  async function cancelAsk(askId, btn) {
    const wallet = readWallet();
    if (!wallet) return;
    const kt1 = readMarketplaceKt1();
    if (!kt1) return;

    const original = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'awaiting kukai…';

    try {
      const taquito = await import('@taquito/taquito');
      const beacon = await import('@taquito/beacon-wallet');
      const tezos = new taquito.TezosToolkit('https://mainnet.api.tez.ie');
      const beaconWallet = new beacon.BeaconWallet({
        name: 'PointCast Market',
        network: { type: 'mainnet' },
      });
      tezos.setWalletProvider(beaconWallet);
      const active = await beaconWallet.client.getActiveAccount();
      if (!active || (active.network && active.network.type !== 'mainnet')) {
        try { await beaconWallet.clearActiveAccount(); } catch (e) {}
        await beaconWallet.client.requestPermissions();
      }
      const contract = await tezos.wallet.at(kt1);
      const op = await contract.methodsObject.cancel_ask(askId).send();
      btn.textContent = 'broadcast ' + (op.opHash || '').slice(0, 8) + '…';
      await op.confirmation();
      btn.textContent = '✓ cancelled';
      // Refresh the grid to drop the now-cancelled ask.
      setTimeout(loadAsks, 1500);
    } catch (err) {
      const msg = (err && err.message) ? err.message : String(err);
      if (/ABORTED|reject|cancel/i.test(msg)) btn.textContent = 'cancelled · retry?';
      else if (/NOT_SELLER/i.test(msg)) btn.textContent = 'not the seller (?)';
      else if (/ASK_NOT_FOUND/i.test(msg)) btn.textContent = 'already gone';
      else btn.textContent = 'error: ' + msg.slice(0, 40);
      setTimeout(function () { btn.disabled = false; btn.textContent = original; }, 4000);
    }
  }

  // ── Update flow (seller's own listings, change price w/o cancel+relist) ─
  async function updateAsk(askId, newPriceMutez, btn) {
    const wallet = readWallet();
    if (!wallet) return;
    const kt1 = readMarketplaceKt1();
    if (!kt1) return;

    const original = btn.textContent;
    btn.disabled = true;
    btn.textContent = '…';

    try {
      const taquito = await import('@taquito/taquito');
      const beacon = await import('@taquito/beacon-wallet');
      const tezos = new taquito.TezosToolkit('https://mainnet.api.tez.ie');
      const beaconWallet = new beacon.BeaconWallet({
        name: 'PointCast Market',
        network: { type: 'mainnet' },
      });
      tezos.setWalletProvider(beaconWallet);
      const active = await beaconWallet.client.getActiveAccount();
      if (!active || (active.network && active.network.type !== 'mainnet')) {
        try { await beaconWallet.clearActiveAccount(); } catch (e) {}
        await beaconWallet.client.requestPermissions();
      }
      const contract = await tezos.wallet.at(kt1);
      // update_ask has two positional params (ask_id, new_amount_mutez)
      // and no %annots in the compiled parameter type, so we call it via
      // .methods (positional API) — methodsObject's named-arg form rejects
      // with "Parameters Invalid" at Beacon validation. cancel_ask /
      // fulfill_ask are single-param so methodsObject works for them.
      const op = await contract.methods
        .update_ask(askId, newPriceMutez)
        .send();
      btn.textContent = '…' + (op.opHash || '').slice(0, 6);
      await op.confirmation();
      btn.textContent = '✓';
      setTimeout(loadAsks, 1500);
    } catch (err) {
      const msg = (err && err.message) ? err.message : String(err);
      if (/ABORTED|reject|cancel/i.test(msg)) btn.textContent = '✗';
      else if (/NOT_SELLER/i.test(msg)) btn.textContent = '!';
      else btn.textContent = 'err';
      setTimeout(function () { btn.disabled = false; btn.textContent = original; }, 4000);
    }
  }

  // ── Recent sales feed (fulfill_ask ops in last ~24h) ────────────────
  async function loadRecentSales() {
    const root = document.getElementById('market-sales');
    const kt1 = readMarketplaceKt1();
    if (!root || !kt1 || !kt1.startsWith('KT1')) return;
    try {
      const url = 'https://api.tzkt.io/v1/operations/transactions' +
        '?target=' + kt1 +
        '&entrypoint=fulfill_ask&status=applied' +
        '&select=hash,sender,timestamp,amount,parameter&limit=8&sort.desc=id';
      const res = await fetch(url, { cache: 'no-store' });
      if (!res.ok) throw new Error('tzkt ' + res.status);
      const ops = await res.json();
      const wrap = document.getElementById('market-sales-wrap');
      if (!Array.isArray(ops) || ops.length === 0) {
        if (wrap) wrap.hidden = true;
        return;
      }
      if (wrap) wrap.hidden = false;
      const now = Date.now();
      root.innerHTML = ops.map(function (op) {
        const buyer = (op.sender && op.sender.address) || '';
        const buyerShort = buyer ? (buyer.slice(0, 6) + '…' + buyer.slice(-4)) : '?';
        const amountMutez = parseInt(op.amount, 10) || 0;
        const amountXtz = (amountMutez / 1_000_000).toFixed(amountMutez % 1_000_000 === 0 ? 0 : 2);
        const ts = op.timestamp ? new Date(op.timestamp).getTime() : 0;
        const diffSec = ts ? Math.max(0, (now - ts) / 1000) : 0;
        let when = '';
        if (diffSec < 60) when = Math.floor(diffSec) + 's ago';
        else if (diffSec < 3600) when = Math.floor(diffSec / 60) + 'm ago';
        else if (diffSec < 86400) when = Math.floor(diffSec / 3600) + 'h ago';
        else when = Math.floor(diffSec / 86400) + 'd ago';
        const hash = op.hash || '';
        return (
          '<li class="market-sale-row">' +
            '<span class="market-sale-buyer">' + buyerShort + '</span>' +
            '<span class="market-sale-dot">·</span>' +
            '<span class="market-sale-price">' + amountXtz + ' ꜩ</span>' +
            '<span class="market-sale-dot">·</span>' +
            '<span class="market-sale-time">' + when + '</span>' +
            (hash ? '<a class="market-sale-link" href="https://tzkt.io/' + hash + '" target="_blank" rel="noopener">tzkt &nearr;</a>' : '') +
          '</li>'
        );
      }).join('');
    } catch (e) {
      const wrap = document.getElementById('market-sales-wrap');
      if (wrap) wrap.hidden = true;
    }
  }

  // ── List form ────────────────────────────────────────────────────────
  async function listToken(e) {
    e.preventDefault();
    const wallet = readWallet();
    if (!wallet) {
      try { window.dispatchEvent(new CustomEvent('pc:open-wallet-menu')); } catch (err) {}
      return;
    }
    const kt1 = readMarketplaceKt1();
    if (!kt1) return;

    const collEl = document.getElementById('market-list-collection');
    const tokenEl = document.getElementById('market-list-token-id');
    const priceEl = document.getElementById('market-list-price');
    const royaltyEl = document.getElementById('market-list-royalty');
    const status = document.getElementById('market-list-status');
    const fa2Kt1 = collEl && collEl.value;
    const tokenId = parseInt(tokenEl && tokenEl.value, 10);
    const priceXtz = parseFloat(priceEl && priceEl.value);
    const royaltyBps = parseInt(royaltyEl && royaltyEl.value, 10);

    if (!fa2Kt1 || Number.isNaN(tokenId) || Number.isNaN(priceXtz) || Number.isNaN(royaltyBps)) {
      if (status) status.textContent = 'fill all fields first';
      return;
    }
    if (royaltyBps < 0 || royaltyBps > 10000) {
      if (status) status.textContent = 'royalty must be 0-10000 bps';
      return;
    }
    const priceMutez = Math.floor(priceXtz * 1_000_000);

    setListEnabled(false, 'awaiting kukai…');
    if (status) status.textContent = 'preparing batched ops…';

    try {
      const taquito = await import('@taquito/taquito');
      const beacon = await import('@taquito/beacon-wallet');
      const tezos = new taquito.TezosToolkit('https://mainnet.api.tez.ie');
      const beaconWallet = new beacon.BeaconWallet({
        name: 'PointCast Market',
        network: { type: 'mainnet' },
      });
      tezos.setWalletProvider(beaconWallet);
      const active = await beaconWallet.client.getActiveAccount();
      if (!active || (active.network && active.network.type !== 'mainnet')) {
        try { await beaconWallet.clearActiveAccount(); } catch (e) {}
        await beaconWallet.client.requestPermissions();
      }

      const fa2 = await tezos.wallet.at(fa2Kt1);
      const market = await tezos.wallet.at(kt1);

      // FA2 update_operators expects a list of variants; Taquito's
      // methodsObject for update_operators takes an array of records
      // with add_operator or remove_operator fields.
      const updateOpsParams = [
        { add_operator: { owner: wallet.address, operator: kt1, token_id: tokenId } },
      ];

      const batch = tezos.wallet.batch()
        .withContractCall(fa2.methodsObject.update_operators(updateOpsParams))
        .withContractCall(market.methodsObject.list_ask({
          fa2_contract: fa2Kt1,
          token_id: tokenId,
          amount_mutez: priceMutez,
          royalty_bps: royaltyBps,
        }));
      const op = await batch.send();
      if (status) status.textContent = 'broadcast ' + (op.opHash || '').slice(0, 10) + '… · confirming';
      await op.confirmation();
      if (status) status.innerHTML = '✓ listed · <a href="https://tzkt.io/' + (op.opHash || '') + '" target="_blank" rel="noopener">tzkt &nearr;</a>';
      setListEnabled(true, 'List another');
      // Refresh the browse grid so the new ask shows up.
      setTimeout(loadAsks, 1800);
    } catch (err) {
      const msg = (err && err.message) ? err.message : String(err);
      if (status) {
        if (/ABORTED|reject|cancel/i.test(msg)) status.textContent = 'cancelled';
        else status.textContent = 'error: ' + msg.slice(0, 80);
      }
      setListEnabled(true, 'Try again');
    }
  }

  // Wire form submit
  const form = document.getElementById('market-list-form');
  if (form) form.addEventListener('submit', listToken);

  // Initial: enable list button if marketplace + collections + wallet line up.
  function syncListButtonState() {
    const kt1 = readMarketplaceKt1();
    const wallet = readWallet();
    const collEl = /** @type {HTMLSelectElement|null} */ (document.getElementById('market-list-collection'));
    const hasCollections = !!(collEl && collEl.options.length > 0 && collEl.options[0].value);
    if (!kt1) {
      setListEnabled(false, 'awaiting marketplace contract');
    } else if (!hasCollections) {
      setListEnabled(false, 'no live collections to list from');
    } else if (!wallet) {
      setListEnabled(true, 'Connect wallet to list');
    } else {
      setListEnabled(true, 'Sign + list (one signature, two ops)');
    }
  }
  syncListButtonState();

  window.addEventListener('pc:wallet-change', function () {
    syncListButtonState();
    loadAsks();
    loadMyTokens();
  });

  // Kick off the browse fetch on load + every 60s.
  loadAsks();
  setInterval(loadAsks, 60_000);
  // Your tokens panel — initial + after wallet change. No interval since
  // FA2 balances only change after the user takes an action that triggers
  // a wallet event.
  loadMyTokens();
  // Recent sales feed alongside browse polling
  loadRecentSales();
  setInterval(loadRecentSales, 60_000);
</script>
