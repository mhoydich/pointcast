---
/**
 * /market — PointCast NFT marketplace.
 *
 * Browse + list + buy across every PointCast FA2 collection through
 * the multi-collection marketplace contract (contracts/v2/marketplace.py).
 *
 * Three-mode page:
 *   1. PENDING  — contracts.marketplace.mainnet not yet populated. Shows
 *      "marketplace launching soon" with a link to /admin/deploy/marketplace
 *      so Mike (or any admin) can originate from the Publisher.
 *   2. EMPTY    — contract live but no asks yet. Shows the "list a token"
 *      form for connected wallets that own a PointCast NFT, plus a "be
 *      the first to list" empty state on the browse side.
 *   3. ACTIVE   — contract live with at least one ask. Browse grid renders
 *      from tzkt's asks bigmap; each card is buyable with one Beacon sign.
 *
 * Listing flow (seller, two ops batched into one Kukai signature):
 *   1. fa2.update_operators([{add_operator: {owner: seller,
 *      operator: marketplace_kt1, token_id}}])
 *   2. marketplace.list_ask(fa2_contract, token_id, price_mutez, royalty_bps)
 *
 * Buying flow (buyer, one signature):
 *   marketplace.fulfill_ask(ask_id) with amount = ask.amount_mutez (mutez).
 *
 * Mode is detected at runtime via tzkt's /storage endpoint — page can ship
 * before the contract is live and auto-flip when contracts.json is updated
 * with the originated KT1.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import WalletConnect from '../components/WalletConnect.astro';
import contracts from '../data/contracts.json';

const marketplaceKt1 = ((contracts as any).marketplace?.mainnet ?? '').trim();
const marketplaceLive = marketplaceKt1.startsWith('KT1');
const platformFeeBps = (contracts as any).marketplace?.platformFeeBps ?? 250;

const supported = ((contracts as any).marketplace?.supportedCollections ?? []) as string[];
// Each supported collection becomes a select option in the list form +
// a filter chip on the browse grid. We pull KT1 + display name for each.
const SLUG_NAMES: Record<string, string> = {
  coffee_mugs: 'Coffee Mugs',
  visit_nouns: 'Visit Nouns',
  birthdays: 'Birthdays',
  drum_token: 'Drum Token',
  window_snapshots: 'Window Snapshots',
};
const collections = supported
  .map((slug) => {
    const entry = (contracts as any)[slug];
    const kt1 = entry?.mainnet?.trim?.() || '';
    return {
      slug,
      name: SLUG_NAMES[slug] || slug,
      kt1,
      live: kt1.startsWith('KT1'),
    };
  })
  .filter((c) => c.live); // only show collections with a live KT1
// Compact registry the in-page script reads via a data-attribute on the
// form. Adding a new live collection in contracts.json + supportedCollections
// is enough — the form, browse grid, and "Your tokens" panel all pick it up.
const collectionsRegistry = collections.map((c) => ({ slug: c.slug, name: c.name, kt1: c.kt1 }));
---

<BaseLayout
  title="Market · PointCast"
  description="PointCast NFT marketplace — buy and list Coffee Mugs, Visit Nouns, and every PointCast FA2 collection on Tezos."
>
  <div class="market">
    <!-- Masthead — same warm-mono treatment as /coffee + /drum + /admin. -->
    <header class="market__masthead">
      <a href="/" class="market__home">PointCast</a>
      <span class="market__path">/ market</span>
      <span class="market__masthead-spacer"></span>
      <WalletConnect />
    </header>

    <header class="market__hero">
      <p class="market__kicker mono">PointCast Market · Tezos · multi-collection</p>
      <h1 class="market__title">Trade every mug, noun, and card on PointCast.</h1>
      <p class="market__dek">
        One marketplace, every collection. Sellers list with a price they pick.
        Buyers fill the ask with one signature. {platformFeeBps / 100}% platform
        fee, royalty per-listing, payment splits at fulfill time.
      </p>
      <div class="market__status-row mono" id="market-status-row" data-mode="loading">
        <span class="market__status-dot" aria-hidden="true"></span>
        <span class="market__status-label" id="market-status-label">checking marketplace status…</span>
      </div>
      <p class="market__hero-link mono">
        Need the whole desk? <a href="/marketplace">Open /marketplace</a> for royalties, referral links, trade tickets, and share cards.
      </p>
    </header>

    <!-- Browse grid — populated from tzkt at runtime. -->
    <section class="market__section" aria-labelledby="market-browse-title">
      <header class="market__section-head">
        <h2 id="market-browse-title" class="market__section-title">Listings</h2>
        <p class="market__section-dek mono" id="market-browse-summary">loading…</p>
      </header>
      <ul class="market__grid" id="market-grid" role="list">
        <li class="market__empty mono" id="market-empty">no listings yet · be the first to list below</li>
      </ul>
    </section>

    <!-- Your tokens — surfaces FA2 holdings from supported collections so
         the user can list anything they own with a one-click form pre-fill. -->
    <section class="market__section" aria-labelledby="market-mine-title">
      <header class="market__section-head">
        <h2 id="market-mine-title" class="market__section-title">Your tokens</h2>
        <p class="market__section-dek mono" id="market-mine-summary">connect a wallet to see what you can list</p>
      </header>
      <ul class="market__grid market__grid--mine" id="market-mine-grid" role="list" hidden></ul>
      <p class="market__mine-empty mono" id="market-mine-empty" hidden>connected wallet holds no tokens from supported collections yet · pour a cup at <a href="/coffee">/coffee</a> or visit <a href="/visit-nouns">/visit-nouns</a> to claim one</p>
    </section>

    <!-- List a token — only meaningful when a wallet is connected. -->
    <section class="market__section" aria-labelledby="market-list-title">
      <header class="market__section-head">
        <h2 id="market-list-title" class="market__section-title">List your token</h2>
        <p class="market__section-dek mono">connect a wallet that owns a PointCast NFT · pick the collection + token + price · sign once.</p>
      </header>
      <form class="market__list-form" id="market-list-form" action="javascript:void(0)" data-marketplace-kt1={marketplaceKt1} data-collections={JSON.stringify(collectionsRegistry)}>
        <label class="market__field">
          <span class="market__field-label mono">collection</span>
          <select name="collection" id="market-list-collection" required>
            {collections.length === 0 ? (
              <option value="" disabled selected>no live collections yet</option>
            ) : (
              collections.map((c) => (
                <option value={c.kt1} data-slug={c.slug}>{c.name}</option>
              ))
            )}
          </select>
        </label>
        <label class="market__field">
          <span class="market__field-label mono">token id</span>
          <input type="number" name="token_id" id="market-list-token-id" min="0" placeholder="0" required />
        </label>
        <label class="market__field">
          <span class="market__field-label mono">price (ꜩ)</span>
          <input type="number" name="price_xtz" id="market-list-price" min="0" step="0.000001" placeholder="1.0" required />
        </label>
        <label class="market__field">
          <span class="market__field-label mono">royalty (bps · 750 = 7.5%)</span>
          <input type="number" name="royalty_bps" id="market-list-royalty" min="0" max="10000" value="750" required />
        </label>
        <div class="market__list-actions">
          <button type="submit" id="market-list-btn" class="market__btn mono" disabled>
            <span id="market-list-label">awaiting marketplace contract</span>
          </button>
          <p class="market__list-status mono" id="market-list-status" role="status" aria-live="polite"></p>
        </div>
      </form>
      <p class="market__list-foot mono">
        listing fires two ops in one Kukai signature: <code>update_operators</code> on the FA2 (gives the marketplace permission to transfer your token) + <code>list_ask</code> on the marketplace (creates the listing). cancel or update price anytime from the card.
      </p>
    </section>

    <!-- Recent sales feed — fulfill_ask ops (visitor-facing social proof) -->
    <aside class="market__sales-wrap" id="market-sales-wrap" hidden aria-labelledby="market-sales-title">
      <header class="market__section-head">
        <h2 id="market-sales-title" class="market__section-title">Recent sales</h2>
        <p class="market__section-dek mono">live tzkt feed · last 8 fulfilled asks</p>
      </header>
      <ol class="market__sales mono" id="market-sales" role="list"></ol>
    </aside>

    <!-- About / spec -->
    <section class="market__section" aria-labelledby="market-about-title">
      <h2 id="market-about-title" class="market__section-title">How it works</h2>
      <dl class="market__about">
        <div>
          <dt>Contract</dt>
          <dd>
            {marketplaceLive ? (
              <a class="market__link" href={`https://tzkt.io/${marketplaceKt1}`} target="_blank" rel="noopener">{marketplaceKt1}</a>
            ) : (
              <span class="market__pending-pill">awaiting origination · /admin/deploy/marketplace</span>
            )}
          </dd>
        </div>
        <div>
          <dt>Platform fee</dt>
          <dd>{platformFeeBps / 100}% per sale · routes to PointCast treasury</dd>
        </div>
        <div>
          <dt>Royalty</dt>
          <dd>seller-set per listing · default 7.5% · routes to creator on each sale</dd>
        </div>
        <div>
          <dt>Supported collections</dt>
          <dd>
            {collections.length > 0
              ? collections.map((c) => c.name).join(' · ')
              : 'awaiting at least one live collection'}
          </dd>
        </div>
        <div>
          <dt>Source</dt>
          <dd>
            <a class="market__link" href="https://github.com/mhoydich/pointcast/blob/main/contracts/v2/marketplace.py" target="_blank" rel="noopener">contracts/v2/marketplace.py &nearr;</a>
          </dd>
        </div>
        <div>
          <dt>Admin</dt>
          <dd>
            <a class="market__link" href="/admin/deploy/marketplace/">/admin/deploy/marketplace &rarr;</a>
          </dd>
        </div>
      </dl>
    </section>
  </div>
</BaseLayout>

<style>
  .market {
    max-width: 960px;
    margin: 0 auto;
    padding: 16px 20px 96px;
    color: var(--color-ink);
  }
  .market__masthead {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0 14px;
    margin-bottom: 28px;
    border-bottom: 1px solid var(--color-rule, rgba(0,0,0,0.08));
  }
  .market__home {
    font-family: var(--font-mono, monospace);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-ink);
    text-decoration: none;
  }
  .market__home:hover { color: var(--color-warm); }
  .market__path {
    font-family: var(--font-mono, monospace);
    font-size: 9.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-warm);
  }
  .market__masthead-spacer { flex: 1; }

  .market__hero { margin-bottom: 36px; }
  .market__kicker {
    color: var(--color-warm);
    font-size: 9.5px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    margin: 0 0 8px;
  }
  .market__title {
    font-family: var(--font-display, serif);
    font-style: italic;
    font-size: 38px;
    line-height: 1.05;
    color: var(--color-ink);
    margin: 0 0 14px;
    font-weight: 500;
  }
  .market__dek {
    color: var(--color-ink-soft);
    font-size: 16px;
    line-height: 1.5;
    margin: 0 0 16px;
    max-width: 640px;
  }
  .market__status-row {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--color-card, rgba(0,0,0,0.04));
    border: 1px solid var(--color-rule, rgba(0,0,0,0.1));
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .market__status-dot {
    display: block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-ink-soft);
  }
  .market__status-row[data-mode="pending"] .market__status-dot { background: rgb(168, 130, 50); }
  .market__status-row[data-mode="empty"] .market__status-dot { background: rgb(120, 120, 120); }
  .market__status-row[data-mode="active"] .market__status-dot { background: rgb(30, 160, 80); animation: market-pulse 2.4s infinite; }
  .market__hero-link {
    margin: 10px 0 0;
    color: var(--color-ink-soft);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .market__hero-link a {
    color: var(--color-ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  @keyframes market-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(30, 160, 80, 0.6); }
    50% { box-shadow: 0 0 0 6px rgba(30, 160, 80, 0); }
  }

  .market__section {
    margin-bottom: 48px;
  }
  .market__section-head {
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-rule, rgba(0,0,0,0.08));
  }
  .market__section-title {
    font-family: var(--font-display, serif);
    font-size: 22px;
    margin: 0 0 4px;
    color: var(--color-ink);
    font-weight: 600;
  }
  .market__section-dek {
    color: var(--color-ink-soft);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0;
  }

  .market__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
  }
  .market__empty {
    grid-column: 1 / -1;
    padding: 32px 16px;
    text-align: center;
    color: var(--color-ink-soft);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.7;
    border: 1px dashed var(--color-rule, rgba(0,0,0,0.15));
    border-radius: 12px;
  }
  .market-card {
    background: var(--color-paper, #fff);
    border: 1px solid var(--color-rule, rgba(0,0,0,0.1));
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    display: flex;
    flex-direction: column;
  }
  .market-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-warm);
    box-shadow: 0 8px 24px -12px rgba(184, 115, 51, 0.35);
  }
  .market-card__art {
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-card, rgba(0,0,0,0.03));
    overflow: hidden;
  }
  .market-card__art img,
  .market-card__art svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }
  .market-card__body {
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  .market-card__name {
    font-weight: 600;
    color: var(--color-ink);
    font-size: 13px;
    margin: 0;
  }
  .market-card__collection {
    font-family: var(--font-mono, monospace);
    color: var(--color-warm);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0;
  }
  .market-card__price {
    font-family: var(--font-mono, monospace);
    font-size: 14px;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0;
  }
  .market-card__seller {
    font-family: var(--font-mono, monospace);
    color: var(--color-ink-soft);
    font-size: 9.5px;
    letter-spacing: 0.04em;
    margin: 0;
  }
  .market-card__buy {
    margin-top: auto;
    padding: 12px 16px;
    border: 2px solid var(--color-warm, #b87333);
    border-radius: 999px;
    background: var(--color-warm, #b87333);
    color: var(--color-paper, #fff);
    font-family: var(--font-mono, monospace);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.12s ease, background 0.15s ease, box-shadow 0.15s ease;
    box-shadow: 0 4px 14px -6px rgba(184, 115, 51, 0.55);
  }
  .market-card__buy:hover:not(:disabled) {
    background: var(--color-ink, #1f1d1a);
    border-color: var(--color-ink, #1f1d1a);
    transform: translateY(-1px);
    box-shadow: 0 6px 18px -6px rgba(31, 29, 26, 0.55);
  }
  .market-card__buy:disabled { opacity: 0.6; cursor: not-allowed; }
  .market-card__buy[data-state="self"] {
    background: var(--color-card, rgba(0,0,0,0.04));
    color: var(--color-ink-soft);
    border-color: var(--color-rule, rgba(0,0,0,0.15));
    cursor: pointer;
    font-size: 10px;
    padding: 8px 12px;
    box-shadow: none;
  }
  .market-card__buy[data-state="self"]:hover:not(:disabled) {
    background: rgba(220, 38, 38, 0.08);
    color: rgb(180, 30, 30);
    border-color: rgba(220, 38, 38, 0.25);
    transform: none;
  }
  .market-card__own {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .market-card__update-row {
    display: flex;
    gap: 4px;
  }
  .market-card__update-input {
    flex: 1;
    padding: 6px 8px;
    border: 1px solid var(--color-rule, rgba(0,0,0,0.15));
    border-radius: 6px;
    background: var(--color-paper, #fff);
    font-family: var(--font-mono, monospace);
    font-size: 11px;
    color: var(--color-ink);
  }
  .market-card__update-btn {
    padding: 6px 10px;
    border: 1px solid var(--color-rule, rgba(0,0,0,0.15));
    background: var(--color-card, rgba(0,0,0,0.04));
    border-radius: 6px;
    cursor: pointer;
    font-family: var(--font-mono, monospace);
    font-size: 12px;
    color: var(--color-ink);
  }
  .market-card__update-btn:hover {
    border-color: var(--color-warm);
    color: var(--color-warm);
  }

  /* Make the Sign + list button equally prominent */
  .market__btn {
    padding: 14px 22px;
    font-size: 12px;
    box-shadow: 0 4px 14px -6px rgba(31, 29, 26, 0.45);
  }
  .market__btn:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px -6px rgba(184, 115, 51, 0.55);
  }

  /* Sales feed */
  .market__sales-wrap {
    margin: 0 0 36px;
    padding: 18px;
    background: var(--color-card, rgba(0,0,0,0.025));
    border: 1px solid var(--color-rule, rgba(0,0,0,0.08));
    border-radius: 12px;
  }
  .market__sales {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .market-sale-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
    color: var(--color-ink-soft);
    font-size: 11px;
    padding: 6px 0;
    border-bottom: 1px dashed var(--color-rule, rgba(0,0,0,0.06));
  }
  .market-sale-row:last-child { border-bottom: none; }
  .market-sale-buyer {
    color: var(--color-ink);
    font-weight: 600;
  }
  .market-sale-price {
    color: var(--color-warm);
    font-weight: 700;
  }
  .market-sale-dot { opacity: 0.4; }
  .market-sale-time {
    margin-left: auto;
    font-size: 10px;
    opacity: 0.7;
  }
  .market-sale-link {
    color: var(--color-warm);
    text-decoration: none;
    font-size: 10px;
    border-bottom: 1px solid currentColor;
  }
  .market-sale-link:hover { color: var(--color-ink); }

  /* Your tokens panel — same card grid as listings, with a slightly warmer
     border so the eye reads it as "mine, listable" rather than "for sale". */
  .market__grid--mine .market-card {
    border-color: rgba(184, 115, 51, 0.25);
    background: linear-gradient(180deg, var(--color-paper, #fff) 0%, rgba(184, 115, 51, 0.04) 100%);
  }
  .market__grid--mine .market-card:hover {
    border-color: var(--color-warm);
    box-shadow: 0 8px 24px -12px rgba(184, 115, 51, 0.45);
  }
  .market__mine-empty {
    padding: 28px 16px;
    text-align: center;
    color: var(--color-ink-soft);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px dashed var(--color-rule, rgba(0,0,0,0.15));
    border-radius: 12px;
  }
  .market__mine-empty a {
    color: var(--color-warm);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }
  .market__mine-empty a:hover { color: var(--color-ink); }

  .market__list-form {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    background: var(--color-card, rgba(0,0,0,0.025));
    padding: 18px;
    border-radius: 12px;
    border: 1px solid var(--color-rule, rgba(0,0,0,0.08));
  }
  .market__field { display: flex; flex-direction: column; gap: 4px; }
  .market__field-label {
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .market__field input,
  .market__field select {
    padding: 8px 10px;
    border: 1px solid var(--color-rule, rgba(0,0,0,0.15));
    background: var(--color-paper, #fff);
    border-radius: 8px;
    font-family: var(--font-mono, monospace);
    font-size: 13px;
    color: var(--color-ink);
  }
  .market__list-actions {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 4px;
  }
  .market__btn {
    padding: 12px 18px;
    border-radius: 999px;
    background: var(--color-ink);
    color: var(--color-paper);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border: 1px solid var(--color-ink);
    cursor: pointer;
    transition: background 0.15s ease;
    align-self: flex-start;
  }
  .market__btn:not(:disabled):hover {
    background: var(--color-warm);
    border-color: var(--color-warm);
  }
  .market__btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .market__list-status {
    color: var(--color-ink-soft);
    font-size: 9.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    min-height: 1em;
    margin: 0;
  }
  .market__list-foot {
    color: var(--color-ink-soft);
    font-size: 9.5px;
    letter-spacing: 0.14em;
