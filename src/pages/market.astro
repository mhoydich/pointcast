    opacity: 0.7;
  }
  .market__list-foot code {
    font-family: var(--font-mono, monospace);
    background: var(--color-card, rgba(0,0,0,0.05));
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 11px;
    color: var(--color-ink);
    letter-spacing: 0;
    text-transform: none;
  }

  .market__about {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px 24px;
    margin: 0;
  }
  .market__about > div {
    border-bottom: 1px dashed var(--color-rule, rgba(0,0,0,0.06));
    padding-bottom: 8px;
  }
  .market__about dt {
    font-family: var(--font-mono, monospace);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    margin-bottom: 4px;
  }
