  @media (max-width: 540px) {
    .market__about { grid-template-columns: 1fr; }
    .market__title { font-size: 30px; }
    .market__dek { font-size: 15px; }
  }
</style>

<script>
  // /market — three-mode flow + browse grid + list form + buy.
  // Plain JS, Vite-bundled. Lazy-imports Taquito + Beacon on the actual
  // sign click so the browse path stays fast (~200ms vs. ~3s with eager
  // Taquito loaded).

  const MARKETPLACE_KT1 = "MARKETPLACE_KT1_PLACEHOLDER";  // overwritten below

  function readMarketplaceKt1() {
    const form = document.getElementById('market-list-form');
    return (form && form.getAttribute('data-marketplace-kt1')) || '';
  }

  function readWallet() {
    try {
      const raw = localStorage.getItem('pc:wallet');
      if (!raw) return null;
      const w = JSON.parse(raw);
      return (w && w.address && w.chain === 'tezos') ? w : null;
    } catch (e) { return null; }
  }

  // Per-collection image URL helpers — used to render card art without a
  // tzkt metadata round-trip per ask. If the slug is unknown, fall back
  // to tzkt's own image redirect at /v1/contracts/<KT1>/tokens/<id>/...
  // (left for a follow-up). Hardcoded for now.
  function imageUriFor(fa2Kt1, tokenId) {
    if (fa2Kt1 === 'KT1JQ3AjzFvMnjZ9mGqrM13aj8LQBx9JpoXt') {
      // Coffee Mugs FA2
      const slugs = { 0: 'ceramic', 1: 'espresso', 2: 'latte', 3: 'paper', 4: 'bistro' };
      const slug = slugs[String(tokenId)];
      return slug ? '/images/coffee-mugs/' + slug + '.svg' : null;
    }
    if (fa2Kt1 === 'KT1LP1oTBuudRubAYQDErH7i7mSwazVdohxh') {
      // Visit Nouns FA2
      return 'https://noun.pics/' + tokenId + '.svg';
    }
    return null;
  }

  function collectionNameFor(fa2Kt1) {
    if (fa2Kt1 === 'KT1JQ3AjzFvMnjZ9mGqrM13aj8LQBx9JpoXt') return 'Coffee Mugs';
    if (fa2Kt1 === 'KT1LP1oTBuudRubAYQDErH7i7mSwazVdohxh') return 'Visit Nouns';
    return fa2Kt1.slice(0, 8) + '…' + fa2Kt1.slice(-4);
  }

  function tokenNameFor(fa2Kt1, tokenId) {
    if (fa2Kt1 === 'KT1JQ3AjzFvMnjZ9mGqrM13aj8LQBx9JpoXt') {
      const names = { 0: 'Ceramic Mug', 1: 'Espresso Cup', 2: 'Latte Glass', 3: 'Paper Cup', 4: 'Bistro Cup' };
      return names[String(tokenId)] || ('Coffee Mug #' + tokenId);
    }
    if (fa2Kt1 === 'KT1LP1oTBuudRubAYQDErH7i7mSwazVdohxh') {
      return 'Visit Noun #' + tokenId;
    }
    return 'Token #' + tokenId;
  }

  function shortAddr(a) {
    if (!a) return '?';
    return a.slice(0, 6) + '…' + a.slice(-4);
  }

  function setMode(mode, label) {
    const row = document.getElementById('market-status-row');
    const lbl = document.getElementById('market-status-label');
    if (row) row.setAttribute('data-mode', mode);
    if (lbl) lbl.textContent = label;
  }

  function setListEnabled(enabled, label) {
    const btn = document.getElementById('market-list-btn');
    const lbl = document.getElementById('market-list-label');
    if (btn) btn.disabled = !enabled;
    if (lbl && label) lbl.textContent = label;
  }

  // ── Browse grid ──────────────────────────────────────────────────────
  async function loadAsks() {
    const grid = document.getElementById('market-grid');
    const empty = document.getElementById('market-empty');
    const summary = document.getElementById('market-browse-summary');
    const kt1 = readMarketplaceKt1();

    if (!grid) return;

    if (!kt1 || !kt1.startsWith('KT1')) {
      setMode('pending', 'marketplace · awaiting origination');
      setListEnabled(false, 'awaiting marketplace contract');
      if (summary) summary.textContent = 'marketplace contract not yet originated · ' +
        'admin can deploy at /admin/deploy/marketplace';
      return;
    }

    setMode('loading', 'fetching listings…');
    if (summary) summary.textContent = 'reading marketplace storage…';

    try {
      // 1. Find the asks bigmap pointer
      const sRes = await fetch('https://api.tzkt.io/v1/contracts/' + kt1 + '/storage', { cache: 'no-store' });
      if (!sRes.ok) throw new Error('tzkt /storage ' + sRes.status);
      const storage = await sRes.json();
      const asksPointer = (typeof storage.asks === 'number') ? storage.asks : null;
      if (asksPointer == null) throw new Error('storage.asks missing or not a bigmap pointer');

      // 2. List the ask records
      const kRes = await fetch(
        'https://api.tzkt.io/v1/bigmaps/' + asksPointer + '/keys?limit=100&select=key,value&active=true&sort.desc=id',
        { cache: 'no-store' },
      );
      if (!kRes.ok) throw new Error('tzkt /bigmaps ' + kRes.status);
      const keys = await kRes.json();

      const wallet = readWallet();
      const myAddr = (wallet && wallet.address) || '';

      grid.innerHTML = '';
      if (!Array.isArray(keys) || keys.length === 0) {
        setMode('empty', 'live · no listings yet');
        if (summary) summary.textContent = 'no listings · be the first to list below';
        if (empty) empty.style.display = '';
        else grid.innerHTML = '<li class="market__empty mono">no listings yet · be the first to list below</li>';
        return;
      }
      setMode('active', keys.length + ' listing' + (keys.length === 1 ? '' : 's') + ' live');
      if (summary) summary.textContent = keys.length + ' active listing' + (keys.length === 1 ? '' : 's');

      grid.innerHTML = keys.map(function (row) {
        const askId = row.key;
        const v = row.value || {};
        const fa2Kt1 = v.fa2_contract;
        const tokenId = v.token_id;
        const seller = v.seller;
        const priceMutez = parseInt(v.amount_mutez, 10) || 0;
        const priceXtz = (priceMutez / 1_000_000).toFixed(priceMutez % 1_000_000 === 0 ? 0 : 2);
        const royaltyBps = parseInt(v.royalty_bps, 10) || 0;

        const imageUri = imageUriFor(fa2Kt1, tokenId);
        const name = tokenNameFor(fa2Kt1, tokenId);
        const collection = collectionNameFor(fa2Kt1);
        const isSelf = myAddr && seller && seller.toLowerCase() === myAddr.toLowerCase();

        return (
          '<li class="market-card" data-ask-id="' + askId + '" data-fa2="' + fa2Kt1 + '" data-token-id="' + tokenId + '" data-price="' + priceMutez + '">' +
            '<div class="market-card__art">' +
              (imageUri ? '<img src="' + imageUri + '" alt="' + name + '" loading="lazy" />' : '<svg viewBox="0 0 24 24"><rect width="24" height="24" fill="#eee"/></svg>') +
            '</div>' +
            '<div class="market-card__body">' +
              '<p class="market-card__collection">' + collection + ' · #' + tokenId + '</p>' +
              '<p class="market-card__name">' + name + '</p>' +
              '<p class="market-card__price">' + priceXtz + ' ꜩ</p>' +
              '<p class="market-card__seller">seller ' + shortAddr(seller) + (royaltyBps > 0 ? ' · ' + (royaltyBps / 100).toFixed(1) + '% royalty' : '') + '</p>' +
              (isSelf
                ? '<button class="market-card__buy" data-state="self" data-cancel-ask="' + askId + '" title="cancel this listing">your listing · cancel</button>'
                : '<button class="market-card__buy" data-buy-ask="' + askId + '">Buy for ' + priceXtz + ' ꜩ</button>') +
            '</div>' +
          '</li>'
        );
      }).join('');

      // Wire buy handlers per card
      grid.querySelectorAll('[data-buy-ask]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const card = btn.closest('.market-card');
          if (!card) return;
          buyAsk(parseInt(btn.getAttribute('data-buy-ask'), 10), parseInt(card.getAttribute('data-price'), 10), btn);
        });
      });
      // Wire cancel handlers for own listings
      grid.querySelectorAll('[data-cancel-ask]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          cancelAsk(parseInt(btn.getAttribute('data-cancel-ask'), 10), btn);
        });
      });
    } catch (err) {
      const msg = (err && err.message) ? err.message : String(err);
      setMode('pending', 'marketplace · tzkt error');
      if (summary) summary.textContent = 'failed to load listings: ' + msg;
    }
  }

  // ── Buy flow ─────────────────────────────────────────────────────────
  async function buyAsk(askId, priceMutez, btn) {
    const wallet = readWallet();
    if (!wallet) {
      try { window.dispatchEvent(new CustomEvent('pc:open-wallet-menu')); } catch (e) {}
      return;
    }
    const kt1 = readMarketplaceKt1();
    if (!kt1) return;

    const original = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'awaiting kukai…';

    try {
      const taquito = await import('@taquito/taquito');
      const beacon = await import('@taquito/beacon-wallet');
      const tezos = new taquito.TezosToolkit('https://mainnet.api.tez.ie');
      const beaconWallet = new beacon.BeaconWallet({
        name: 'PointCast Market',
        network: { type: 'mainnet' },
      });
      tezos.setWalletProvider(beaconWallet);
      const active = await beaconWallet.client.getActiveAccount();
      if (!active || (active.network && active.network.type !== 'mainnet')) {
        try { await beaconWallet.clearActiveAccount(); } catch (e) {}
        await beaconWallet.client.requestPermissions();
      }
      const contract = await tezos.wallet.at(kt1);
      const op = await contract.methodsObject
        .fulfill_ask(askId)
        .send({ amount: priceMutez, mutez: true });
      btn.textContent = 'broadcast ' + (op.opHash || '').slice(0, 8) + '…';
      await op.confirmation();
      btn.textContent = '✓ bought';
      // Refresh the grid to drop the now-fulfilled ask.
      setTimeout(loadAsks, 1500);
    } catch (err) {
      const msg = (err && err.message) ? err.message : String(err);
      if (/ABORTED|reject|cancel/i.test(msg)) btn.textContent = 'cancelled';
      else if (/INCORRECT_AMOUNT/i.test(msg)) btn.textContent = 'price changed · refresh';
      else if (/NotEnoughBalance|balance/i.test(msg)) btn.textContent = 'not enough ꜩ';
      else btn.textContent = 'error: ' + msg.slice(0, 40);
      setTimeout(function () { btn.disabled = false; btn.textContent = original; }, 4000);
    }
  }

  // ── Cancel flow (seller's own listings) ─────────────────────────────
  async function cancelAsk(askId, btn) {
    const wallet = readWallet();
    if (!wallet) return;
    const kt1 = readMarketplaceKt1();
    if (!kt1) return;

    const original = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'awaiting kukai…';

    try {
      const taquito = await import('@taquito/taquito');
      const beacon = await import('@taquito/beacon-wallet');
      const tezos = new taquito.TezosToolkit('https://mainnet.api.tez.ie');
      const beaconWallet = new beacon.BeaconWallet({
        name: 'PointCast Market',
        network: { type: 'mainnet' },
      });
      tezos.setWalletProvider(beaconWallet);
      const active = await beaconWallet.client.getActiveAccount();
      if (!active || (active.network && active.network.type !== 'mainnet')) {
        try { await beaconWallet.clearActiveAccount(); } catch (e) {}
        await beaconWallet.client.requestPermissions();
      }
      const contract = await tezos.wallet.at(kt1);
      const op = await contract.methodsObject.cancel_ask(askId).send();
      btn.textContent = 'broadcast ' + (op.opHash || '').slice(0, 8) + '…';
      await op.confirmation();
      btn.textContent = '✓ cancelled';
      // Refresh the grid to drop the now-cancelled ask.
      setTimeout(loadAsks, 1500);
    } catch (err) {
      const msg = (err && err.message) ? err.message : String(err);
      if (/ABORTED|reject|cancel/i.test(msg)) btn.textContent = 'cancelled · retry?';
      else if (/NOT_SELLER/i.test(msg)) btn.textContent = 'not the seller (?)';
      else if (/ASK_NOT_FOUND/i.test(msg)) btn.textContent = 'already gone';
      else btn.textContent = 'error: ' + msg.slice(0, 40);
      setTimeout(function () { btn.disabled = false; btn.textContent = original; }, 4000);
    }
  }

  // ── List form ────────────────────────────────────────────────────────
  async function listToken(e) {
    e.preventDefault();
    const wallet = readWallet();
    if (!wallet) {
      try { window.dispatchEvent(new CustomEvent('pc:open-wallet-menu')); } catch (err) {}
      return;
    }
    const kt1 = readMarketplaceKt1();
    if (!kt1) return;

    const collEl = document.getElementById('market-list-collection');
    const tokenEl = document.getElementById('market-list-token-id');
    const priceEl = document.getElementById('market-list-price');
    const royaltyEl = document.getElementById('market-list-royalty');
    const status = document.getElementById('market-list-status');
    const fa2Kt1 = collEl && collEl.value;
    const tokenId = parseInt(tokenEl && tokenEl.value, 10);
    const priceXtz = parseFloat(priceEl && priceEl.value);
    const royaltyBps = parseInt(royaltyEl && royaltyEl.value, 10);

    if (!fa2Kt1 || Number.isNaN(tokenId) || Number.isNaN(priceXtz) || Number.isNaN(royaltyBps)) {
      if (status) status.textContent = 'fill all fields first';
      return;
    }
    if (royaltyBps < 0 || royaltyBps > 10000) {
      if (status) status.textContent = 'royalty must be 0-10000 bps';
      return;
    }
    const priceMutez = Math.floor(priceXtz * 1_000_000);

    setListEnabled(false, 'awaiting kukai…');
    if (status) status.textContent = 'preparing batched ops…';

    try {
      const taquito = await import('@taquito/taquito');
      const beacon = await import('@taquito/beacon-wallet');
      const tezos = new taquito.TezosToolkit('https://mainnet.api.tez.ie');
      const beaconWallet = new beacon.BeaconWallet({
        name: 'PointCast Market',
        network: { type: 'mainnet' },
      });
      tezos.setWalletProvider(beaconWallet);
      const active = await beaconWallet.client.getActiveAccount();
      if (!active || (active.network && active.network.type !== 'mainnet')) {
        try { await beaconWallet.clearActiveAccount(); } catch (e) {}
        await beaconWallet.client.requestPermissions();
      }

      const fa2 = await tezos.wallet.at(fa2Kt1);
      const market = await tezos.wallet.at(kt1);

      // FA2 update_operators expects a list of variants; Taquito's
      // methodsObject for update_operators takes an array of records
      // with add_operator or remove_operator fields.
      const updateOpsParams = [
        { add_operator: { owner: wallet.address, operator: kt1, token_id: tokenId } },
      ];

      const batch = tezos.wallet.batch()
        .withContractCall(fa2.methodsObject.update_operators(updateOpsParams))
        .withContractCall(market.methodsObject.list_ask({
          fa2_contract: fa2Kt1,
          token_id: tokenId,
          amount_mutez: priceMutez,
          royalty_bps: royaltyBps,
        }));
      const op = await batch.send();
      if (status) status.textContent = 'broadcast ' + (op.opHash || '').slice(0, 10) + '… · confirming';
      await op.confirmation();
      if (status) status.innerHTML = '✓ listed · <a href="https://tzkt.io/' + (op.opHash || '') + '" target="_blank" rel="noopener">tzkt &nearr;</a>';
      setListEnabled(true, 'List another');
      // Refresh the browse grid so the new ask shows up.
      setTimeout(loadAsks, 1800);
    } catch (err) {
      const msg = (err && err.message) ? err.message : String(err);
      if (status) {
        if (/ABORTED|reject|cancel/i.test(msg)) status.textContent = 'cancelled';
        else status.textContent = 'error: ' + msg.slice(0, 80);
      }
      setListEnabled(true, 'Try again');
    }
  }

  // Wire form submit
  const form = document.getElementById('market-list-form');
  if (form) form.addEventListener('submit', listToken);

  // Initial: enable list button if marketplace + collections + wallet line up.
  function syncListButtonState() {
    const kt1 = readMarketplaceKt1();
    const wallet = readWallet();
    const collEl = /** @type {HTMLSelectElement|null} */ (document.getElementById('market-list-collection'));
    const hasCollections = !!(collEl && collEl.options.length > 0 && collEl.options[0].value);
    if (!kt1) {
      setListEnabled(false, 'awaiting marketplace contract');
    } else if (!hasCollections) {
      setListEnabled(false, 'no live collections to list from');
    } else if (!wallet) {
      setListEnabled(true, 'Connect wallet to list');
    } else {
      setListEnabled(true, 'Sign + list (one signature, two ops)');
    }
  }
  syncListButtonState();

  window.addEventListener('pc:wallet-change', function () {
    syncListButtonState();
    loadAsks();
  });

  // Kick off the browse fetch on load + every 60s.
  loadAsks();
  setInterval(loadAsks, 60_000);
</script>
