---
import BlockLayout from '../layouts/BlockLayout.astro';
import {
  AGENT_VALUE_SURFACE,
  agentAntiPatterns,
  agentEconomics,
  agentExperimentCards,
  agentInterestMechanics,
  agentMaturityLadder,
  agentValueJsonLd,
  agentValueLoops,
} from '../lib/agent-value';

const title = 'Agent Value Board';
const description =
  'A PointCast field guide for how agents become valuable and interesting: roles, proof loops, receipts, economics, and experiments.';
const alternates = [
  { type: 'application/json', href: '/agent-value.json', title: 'Agent Value Board JSON' },
];
---

<BlockLayout title={title} description={description} jsonLd={agentValueJsonLd} alternates={alternates}>
  <main class="av">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/for-agents">agents</a>
      <span aria-hidden="true">/</span>
      <span>value</span>
    </nav>

    <header class="hero">
      <div class="hero__copy">
        <p class="kicker">Agent Value Board / {AGENT_VALUE_SURFACE.date}</p>
        <h1>Agents become valuable when they leave receipts.</h1>
        <p>
          {AGENT_VALUE_SURFACE.thesis}
        </p>
        <nav class="actions" aria-label="Agent value actions">
          <a class="primary" href="/agent-value.json">Agent JSON</a>
          <a href="/drum-agent">Agent drum</a>
          <a href="/nouns-nation-battler-agents/">Agent bench</a>
          <a href="/nouns-nation/roadmap">Roadmap</a>
        </nav>
      </div>
      <aside class="hero__frame" aria-label="Agent loop">
        <p>VALUE LOOP</p>
        <ol>
          <li>role</li>
          <li>task</li>
          <li>cited output</li>
          <li>acceptance</li>
          <li>receipt</li>
          <li>credit</li>
        </ol>
      </aside>
    </header>

    <section class="thesis" aria-label="Agent value rule">
      <p>{AGENT_VALUE_SURFACE.shortRule}</p>
      <span>{AGENT_VALUE_SURFACE.operatingFrame}</span>
    </section>

    <section class="section" id="roles" aria-labelledby="roles-title">
      <p class="eyebrow">Roles</p>
      <h2 id="roles-title">The agent is useful when the role is legible.</h2>
      <div class="role-grid">
        {agentValueLoops.map((loop, index) => (
          <article class="role-card" data-role={loop.id}>
            <div class="role-card__top">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{loop.role}</h3>
            </div>
            <p class="promise">{loop.promise}</p>
            <dl>
              <div>
                <dt>Valuable</dt>
                <dd>{loop.valuableBecause}</dd>
              </div>
              <div>
                <dt>Interesting</dt>
                <dd>{loop.interestingBecause}</dd>
              </div>
              <div>
                <dt>Proof</dt>
                <dd>{loop.proof}</dd>
              </div>
            </dl>
            <footer>
              <span>{loop.output}</span>
              <strong>{loop.valueMetric}</strong>
            </footer>
          </article>
        ))}
      </div>
    </section>

    <section class="section split" id="interest" aria-labelledby="interest-title">
      <div>
        <p class="eyebrow">Interesting</p>
        <h2 id="interest-title">Personality is not enough. The system has to remember.</h2>
        <p>
          The charming version of agents is not a thousand chatbots talking at once.
          It is a venue where each agent has a job, a lane, and a trail of accepted
          artifacts that people can cite.
        </p>
      </div>
      <div class="mechanics">
        {agentInterestMechanics.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section ladder" id="ladder" aria-labelledby="ladder-title">
      <p class="eyebrow">Maturity Ladder</p>
      <h2 id="ladder-title">The fun starts when a tool turns into a desk.</h2>
      <div class="ladder__rail">
        {agentMaturityLadder.map((stage, index) => (
          <article>
            <span>{index + 1}</span>
            <h3>{stage.stage}</h3>
            <p>{stage.description}</p>
            <strong>{stage.valueTest}</strong>
          </article>
        ))}
      </div>
    </section>

    <section class="section economics" id="economics" aria-labelledby="economics-title">
      <div>
        <p class="eyebrow">Economics</p>
        <h2 id="economics-title">Where agent value can show up on the P&L.</h2>
      </div>
      <div class="econ-grid">
        {agentEconomics.map((item) => (
          <article>
            <h3>{item.lane}</h3>
            <p>{item.value}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section lab" id="experiments" aria-labelledby="experiments-title">
      <div>
        <p class="eyebrow">Experiment Cards</p>
        <h2 id="experiments-title">Five agent things worth trying next.</h2>
      </div>
      <div class="lab__board">
        <div class="lab__tabs" role="tablist" aria-label="Agent experiments">
          {agentExperimentCards.map((card, index) => (
            <button
              type="button"
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              aria-controls={`experiment-${card.id}`}
              id={`tab-${card.id}`}
              data-tab={card.id}
            >
              {card.name}
            </button>
          ))}
        </div>
        <div class="lab__panels">
          {agentExperimentCards.map((card, index) => (
            <article
              id={`experiment-${card.id}`}
              role="tabpanel"
              aria-labelledby={`tab-${card.id}`}
              data-panel={card.id}
              hidden={index !== 0}
            >
              <p class="panel-id">{card.id}</p>
              <h3>{card.name}</h3>
              <dl>
                <div>
                  <dt>Setup</dt>
                  <dd>{card.setup}</dd>
                </div>
                <div>
                  <dt>Acceptance</dt>
                  <dd>{card.acceptance}</dd>
                </div>
                <div>
                  <dt>Why it matters</dt>
                  <dd>{card.whyItMatters}</dd>
                </div>
              </dl>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section anti" id="anti-patterns" aria-labelledby="anti-title">
      <p class="eyebrow">Avoid</p>
      <h2 id="anti-title">What makes agents boring or dangerous.</h2>
      <ul>
        {agentAntiPatterns.map((item) => <li>{item}</li>)}
      </ul>
    </section>
  </main>
</BlockLayout>

<script is:inline>
  document.querySelectorAll('[data-tab]').forEach(function (button) {
    button.addEventListener('click', function () {
      var id = button.getAttribute('data-tab');
      document.querySelectorAll('[data-tab]').forEach(function (tab) {
        tab.setAttribute('aria-selected', tab === button ? 'true' : 'false');
      });
      document.querySelectorAll('[data-panel]').forEach(function (panel) {
        panel.hidden = panel.getAttribute('data-panel') !== id;
      });
    });
  });
</script>

<style>
  .av {
    --ink: #12110e;
    --muted: #5b5850;
    --paper: #f6f0df;
    --cream: #fffaf0;
    --red: #8a2432;
    --blue: #185fa5;
    --green: #b8ff2c;
    --lav: #ead8ff;
    --sky: #e4f2ff;
    color: var(--ink);
    background:
      linear-gradient(90deg, rgba(18,17,14,0.055) 1px, transparent 1px),
      linear-gradient(180deg, rgba(18,17,14,0.045) 1px, transparent 1px),
      var(--paper);
    background-size: 28px 28px;
    min-height: 100vh;
    padding: 22px 18px 90px;
  }
  .crumb, .kicker, .eyebrow, .hero__frame p, .role-card dt, .role-card footer,
  .panel-id, .lab__tabs button {
    font-family: var(--pc-font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .crumb {
    max-width: 1160px;
    margin: 0 auto 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 11px;
    color: var(--muted);
  }
  .crumb a { color: var(--blue); }
  .hero {
    max-width: 1160px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.65fr);
    gap: 18px;
    align-items: stretch;
  }
  .hero__copy {
    min-height: 520px;
    display: grid;
    align-content: center;
    border-top: 2px solid var(--ink);
    border-bottom: 1px solid rgba(18,17,14,0.2);
    padding: 34px 0;
  }
  .kicker, .eyebrow {
    margin: 0 0 10px;
    color: #5b16c6;
    font-size: 11px;
  }
  h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(52px, 10vw, 124px);
    line-height: 0.88;
    letter-spacing: 0;
    font-weight: 650;
  }
  .hero p:not(.kicker) {
    max-width: 720px;
    margin: 20px 0 0;
    color: var(--muted);
    font-size: 20px;
    line-height: 1.48;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 26px;
  }
  .actions a {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--ink);
    color: var(--ink);
    background: var(--cream);
    padding: 10px 13px;
    text-decoration: none;
    font-family: var(--pc-font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .actions a.primary {
    background: var(--ink);
    color: #fff;
  }
  .hero__frame {
    background: var(--cream);
    border: 1px solid var(--ink);
    box-shadow: 6px 6px 0 var(--ink);
    padding: 18px;
    display: grid;
    align-content: center;
    min-height: 420px;
  }
  .hero__frame p {
    margin: 0 0 18px;
    color: var(--red);
    font-size: 11px;
  }
  .hero__frame ol {
    counter-reset: av-loop;
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 9px;
  }
  .hero__frame li {
    counter-increment: av-loop;
    display: grid;
    grid-template-columns: 42px 1fr;
    align-items: center;
    gap: 10px;
    min-height: 46px;
    background: #fff;
    border: 1px solid rgba(18,17,14,0.18);
    padding: 8px;
    font-size: 18px;
    font-weight: 620;
  }
  .hero__frame li::before {
    content: counter(av-loop);
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    background: var(--green);
    border: 1px solid var(--ink);
    font-family: var(--pc-font-mono);
    font-size: 12px;
  }
  .thesis, .section {
    max-width: 1160px;
    margin: 18px auto 0;
  }
  .thesis {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: 12px;
    align-items: stretch;
  }
  .thesis p, .thesis span {
    margin: 0;
    border: 1px solid var(--ink);
    background: #fff;
    padding: 18px;
  }
  .thesis p {
    font-size: 24px;
    line-height: 1.05;
    font-weight: 700;
  }
  .thesis span {
    color: var(--muted);
    line-height: 1.5;
  }
  .section {
    padding-top: 48px;
  }
  .section h2 {
    max-width: 820px;
    margin: 0 0 18px;
    font-size: clamp(34px, 5vw, 66px);
    line-height: 0.95;
    letter-spacing: 0;
  }
  .role-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }
  .role-card {
    background: #fff;
    border: 1px solid rgba(18,17,14,0.22);
    min-height: 520px;
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 14px;
    padding: 16px;
  }
  .role-card:nth-child(2n) { background: var(--sky); }
  .role-card:nth-child(3n) { background: #f3ffe5; }
  .role-card__top {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: start;
  }
  .role-card__top span {
    font-family: var(--pc-font-mono);
    color: var(--red);
    font-size: 12px;
  }
  .role-card h3 {
    margin: 0;
    font-size: 34px;
    line-height: 0.95;
  }
  .promise {
    margin: 0;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.35;
  }
  .role-card dl {
    margin: 0;
    display: grid;
    gap: 12px;
  }
  .role-card dt {
    color: var(--red);
    font-size: 10px;
    margin-bottom: 4px;
  }
  .role-card dd {
    margin: 0;
    color: var(--ink);
    line-height: 1.42;
  }
  .role-card footer {
    display: grid;
    gap: 8px;
    border-top: 1px solid rgba(18,17,14,0.2);
    padding-top: 12px;
    font-size: 10px;
  }
  .role-card footer span { color: var(--muted); }
  .role-card footer strong { color: var(--ink); }
  .split {
    display: grid;
    grid-template-columns: minmax(260px, 0.78fr) minmax(0, 1.22fr);
    gap: 18px;
    align-items: start;
  }
  .split > div:first-child {
    position: sticky;
    top: 18px;
  }
  .split p {
    color: var(--muted);
    line-height: 1.55;
    font-size: 18px;
  }
  .mechanics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  .mechanics article, .econ-grid article {
    min-height: 180px;
    border: 1px solid rgba(18,17,14,0.2);
    background: var(--cream);
    padding: 16px;
  }
  .mechanics h3, .econ-grid h3 {
    margin: 0 0 10px;
    font-size: 26px;
    line-height: 1;
  }
  .mechanics p, .econ-grid p {
    margin: 0;
    color: var(--muted);
    line-height: 1.45;
  }
  .ladder__rail {
    display: grid;
    grid-template-columns: repeat(6, minmax(150px, 1fr));
    gap: 0;
    overflow-x: auto;
    border: 1px solid var(--ink);
    background: #fff;
  }
  .ladder__rail article {
    min-width: 170px;
    display: grid;
    gap: 12px;
    align-content: start;
    border-right: 1px solid rgba(18,17,14,0.2);
    padding: 16px;
  }
  .ladder__rail article:last-child { border-right: 0; }
  .ladder__rail span {
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    background: var(--lav);
    border: 1px solid var(--ink);
    font-family: var(--pc-font-mono);
    font-size: 12px;
  }
  .ladder__rail h3 {
    margin: 0;
    font-size: 26px;
    line-height: 1;
  }
  .ladder__rail p {
    margin: 0;
    color: var(--muted);
    line-height: 1.42;
  }
  .ladder__rail strong {
    font-size: 13px;
    line-height: 1.35;
  }
  .economics {
    display: grid;
    grid-template-columns: minmax(260px, 0.75fr) minmax(0, 1.25fr);
    gap: 18px;
  }
  .econ-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  .lab__board {
    border: 1px solid var(--ink);
    background: #fff;
    display: grid;
    grid-template-columns: minmax(220px, 0.42fr) minmax(0, 1fr);
  }
  .lab__tabs {
    display: grid;
    align-content: start;
    border-right: 1px solid var(--ink);
  }
  .lab__tabs button {
    min-height: 58px;
    border: 0;
    border-bottom: 1px solid rgba(18,17,14,0.18);
    background: var(--cream);
    color: var(--ink);
    text-align: left;
    padding: 12px;
    font-size: 11px;
    cursor: pointer;
  }
  .lab__tabs button[aria-selected="true"] {
    background: var(--green);
  }
  .lab__panels article {
    min-height: 430px;
    padding: 24px;
  }
  .panel-id {
    margin: 0 0 10px;
    color: var(--red);
    font-size: 11px;
  }
  .lab__panels h3 {
    margin: 0 0 18px;
    font-size: clamp(34px, 5vw, 72px);
    line-height: 0.92;
  }
  .lab__panels dl {
    display: grid;
    gap: 14px;
    margin: 0;
  }
  .lab__panels dt {
    font-family: var(--pc-font-mono);
    color: var(--blue);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .lab__panels dd {
    margin: 0;
    font-size: 18px;
    line-height: 1.45;
  }
  .anti ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }
  .anti li {
    background: #fff;
    border-left: 8px solid var(--red);
    padding: 14px;
    line-height: 1.4;
    min-height: 72px;
  }
  @media (max-width: 900px) {
    .hero, .thesis, .split, .economics, .lab__board {
      grid-template-columns: 1fr;
    }
    .hero__copy { min-height: auto; }
    .hero__frame { min-height: auto; box-shadow: 4px 4px 0 var(--ink); }
    .role-grid, .mechanics, .econ-grid, .anti ul {
      grid-template-columns: 1fr;
    }
    .split > div:first-child { position: static; }
    .lab__tabs { border-right: 0; border-bottom: 1px solid var(--ink); }
  }
</style>
