---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Mcp {
  slug: string;          // anchor + repo name
  name: string;          // display name
  blurb: string;         // one-line pitch
  description: string;   // longer description
  liveUrl?: string;      // public URL where it runs
  embedSnippet?: string; // for fireplaces: a sample iframe snippet
  github?: string;       // repo URL if open source
  tools: string[];       // list of MCP tools this server exposes
  tags: string[];        // visual tag chips
  status: "live" | "preview" | "wip";
  channel?: string;      // pointcast channel code if related
}

const MCPS: Mcp[] = [
  {
    slug: "digital-fireplace",
    name: "Digital Fireplace",
    blurb: "34 embeddable pixel-art fireplaces. Brought to you by Good Feels.",
    description: "An MCP server and a self-hosted gallery of 34 pixel-art fireplaces — stone hearths, CRT yule logs, plasma reactors, glowing joints, sparklers, phoenix eggs. Each one is a single self-contained HTML page with a tap-to-light audio gate and a Good Feels attribution. Embed any of them with one iframe. CC0.",
    liveUrl: "/fireplaces/index.html",
    embedSnippet: `<iframe src="https://pointcast.xyz/fireplaces/joint-tray.html"
        width="800" height="500" frameborder="0" allow="autoplay"
        title="Good Feels · digital fireplace"
        style="border:none;"></iframe>`,
    github: "https://github.com/mhoydich/digital-fireplace-mcp",
    tools: [
      "fireplace_list_styles",
      "fireplace_get_html",
      "fireplace_get_embed_code",
      "fireplace_get_url",
      "fireplace_random",
      "fireplace_get_gallery_url",
      "fireplace_recommend",
    ],
    tags: ["fire", "pixel-art", "embed", "cc0", "good-feels"],
    status: "live",
  },
  {
    slug: "pointcast-control-deck",
    name: "PointCast Control Deck",
    blurb: "Real-time dashboard for pointcast.xyz — presence, wire, channel meter.",
    description: "A geocities-meets-SimCity live dashboard that polls pointcast.xyz every few seconds: who's in the room, what's on the wire, blocks per channel, and the most recent broadcast. Late-90s web chrome, channel-coloured bars, scrolling marquee, blinking LEDs.",
    liveUrl: undefined,
    tools: [
      "(local stdio · runs against pointcast.xyz public APIs)",
    ],
    tags: ["pointcast", "real-time", "dashboard", "wire"],
    status: "preview",
    channel: "FCT",
  },
];
---

<BaseLayout
  title="MCPs"
  description="Mike's MCP servers — small Model Context Protocol servers that plug into Claude Cowork. Brought to you by Good Feels."
  image="/images/og-about.png"
>
  <div class="mcps-page">
    <a href="/" class="back-link">&larr; PointCast</a>

    <header class="page-head">
      <div class="kicker">MCPs</div>
      <h1>Neat MCPs</h1>
      <p class="lead">
        Small <a href="https://modelcontextprotocol.io" target="_blank" rel="noopener">Model Context Protocol</a> servers
        that plug into Claude Cowork (and any other MCP client). Built in public from El Segundo.
        Brought to you by <a href="https://shop.getgoodfeels.com" target="_blank" rel="noopener sponsored">Good Feels</a>.
      </p>
    </header>

    <div class="mcps-grid">
      {MCPS.map(m => (
        <article class={`mcp ${m.status}`} id={m.slug}>
          <header class="mcp-head">
            <div class="status-pip">{m.status}</div>
            <h2>{m.name}</h2>
            <p class="blurb">{m.blurb}</p>
          </header>

          <p class="desc">{m.description}</p>

          {m.tags.length > 0 && (
            <div class="tags">
              {m.tags.map(t => <span class="tag">{t}</span>)}
            </div>
          )}

          <div class="tools">
            <div class="tools-label">Tools</div>
            <ul>
              {m.tools.map(t => <li><code>{t}</code></li>)}
            </ul>
          </div>

          {m.embedSnippet && (
            <details class="embed">
              <summary>embed snippet</summary>
              <pre>{m.embedSnippet}</pre>
            </details>
          )}

          <div class="actions">
            {m.liveUrl && <a href={m.liveUrl} class="btn primary">open gallery →</a>}
            {m.github && <a href={m.github} target="_blank" rel="noopener" class="btn">github →</a>}
          </div>
        </article>
      ))}
    </div>

    <footer class="page-foot">
      <p>
        Want to wire one into your Claude Code? Each repo's README has the JSON snippet for <code>~/.claude/settings.json</code>.
        Want one built for your team? <a href="/about">Drop me a line</a>.
      </p>
    </footer>
  </div>
</BaseLayout>

<style>
  .mcps-page {
    max-width: 56rem;
    margin: 0 auto;
    padding: 3rem 1rem 5rem;
  }
  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft, #8a7860);
    text-decoration: none;
  }
  .back-link:hover { color: var(--warm, #d86440); }

  .page-head { margin-bottom: 2.4rem; }
  .kicker {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--warm, #d86440);
    margin-bottom: 0.6rem;
  }
  .page-head h1 {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 2.2rem;
    font-style: italic;
    line-height: 1.1;
    margin-bottom: 0.8rem;
  }
  .lead {
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--ink, #2a1a14);
    opacity: 0.85;
  }
  .lead a {
    color: var(--warm, #d86440);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }

  .mcps-grid {
    display: grid;
    gap: 1.4rem;
  }

  .mcp {
    border: 2px solid var(--ink, #2a1a14);
    background: var(--cream, #f5e8c8);
    padding: 1.2rem 1.3rem 1.4rem;
    box-shadow: 5px 5px 0 #000;
    position: relative;
  }

  .status-pip {
    position: absolute;
    top: 0; right: 0;
    background: var(--ink, #2a1a14);
    color: var(--cream, #f5e8c8);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
  }
  .mcp.live .status-pip { background: #186a3b; color: #fff; }
  .mcp.preview .status-pip { background: #d86440; color: #fff; }
  .mcp.wip .status-pip { background: #888; color: #fff; }

  .mcp-head h2 {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.4rem;
    margin-bottom: 0.3rem;
  }
  .blurb {
    font-size: 0.92rem;
    color: var(--ink, #2a1a14);
    opacity: 0.75;
    margin-bottom: 0.8rem;
  }
  .desc {
    font-size: 0.92rem;
    line-height: 1.55;
    margin: 0.8rem 0 1rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }
  .tag {
    background: rgba(42, 26, 20, 0.08);
    color: var(--ink, #2a1a14);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    letter-spacing: 0.04em;
  }

  .tools {
    background: rgba(42, 26, 20, 0.04);
    padding: 0.8rem 1rem;
    border: 1px dashed var(--ink, #2a1a14);
    margin-bottom: 1rem;
  }
  .tools-label {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft, #8a7860);
    margin-bottom: 0.4rem;
  }
  .tools ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.2rem 0.8rem;
  }
  .tools code {
    font-size: 0.78rem;
    color: var(--ink, #2a1a14);
  }

  .embed {
    margin-bottom: 1rem;
  }
  .embed summary {
    cursor: pointer;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--ink-soft, #8a7860);
    margin-bottom: 0.4rem;
  }
  .embed summary:hover { color: var(--warm, #d86440); }
  .embed pre {
    background: var(--ink, #2a1a14);
    color: var(--cream, #f5e8c8);
    padding: 0.8rem 1rem;
    font-size: 0.7rem;
    line-height: 1.5;
    overflow-x: auto;
    margin-top: 0.5rem;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-block;
    padding: 0.5rem 0.9rem;
    border: 2px solid var(--ink, #2a1a14);
    background: transparent;
    color: var(--ink, #2a1a14);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.1s;
  }
  .btn:hover { background: var(--ink, #2a1a14); color: var(--cream, #f5e8c8); }
  .btn.primary { background: var(--warm, #d86440); color: #fff; border-color: var(--warm, #d86440); }
  .btn.primary:hover { filter: brightness(0.92); }

  .page-foot {
    margin-top: 3rem;
    padding-top: 1.6rem;
    border-top: 1px dashed var(--ink-soft, #8a7860);
    font-size: 0.85rem;
    color: var(--ink-soft, #8a7860);
    line-height: 1.55;
  }
  .page-foot a {
    color: var(--warm, #d86440);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .page-foot code {
    background: rgba(42, 26, 20, 0.08);
    padding: 0.05rem 0.35rem;
    font-size: 0.78rem;
  }
</style>
