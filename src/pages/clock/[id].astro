---
/**
 * /clock/{id} — Collab Clock companion page.
 *
 * Live-ticking world clock that reads its zones from two sources:
 *   1. src/lib/collaborators.ts — when clock.includeCollaborators !== false
 *   2. block JSON clock.zones[] — manual extras
 *
 * Entirely client-side after first paint: Intl.DateTimeFormat handles DST
 * and offsets, a setInterval(1s) updates the readouts, no deps.
 *
 * Distinct from /b/{id} — that page stays the canonical, agent-readable
 * record. /clock/{id} is the live companion, same pattern as /yee/{id}.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import BlockLayout from '../../layouts/BlockLayout.astro';
import { CHANNELS } from '../../lib/channels';
import { COLLABORATORS } from '../../lib/collaborators';
import { resolveZones } from '../../lib/timezones';
import {
  moonPhase,
  sunTimes,
  planetaryHour,
  season,
  nextEquinoxOrSolstice,
  zodiacOfDate,
} from '../../lib/sky';
import { nearestShower } from '../../lib/meteor-showers';

export async function getStaticPaths() {
  const blocks = await getCollection('blocks', ({ data }) =>
    !data.draft && data.clock !== undefined,
  );
  return blocks.map((block) => ({
    params: { id: block.data.id },
    props: { block },
  }));
}

interface Props {
  block: CollectionEntry<'blocks'>;
}
const { block } = Astro.props;
const data = block.data;
const ch = CHANNELS[data.channel];

const zones = resolveZones(data.clock, COLLABORATORS);

/**
 * Prerender sky data server-side for each zone. Client JS re-derives
 * these every minute so the planetary hour / sun altitude stay fresh
 * without a page rebuild.
 */
const renderNow = new Date();

function formatInZone(d: Date, tz: string, opts: Intl.DateTimeFormatOptions): string {
  return new Intl.DateTimeFormat('en-US', { ...opts, timeZone: tz }).format(d);
}

function hhmm(d: Date | null, tz: string): string {
  if (!d) return '—';
  return formatInZone(d, tz, { hour: '2-digit', minute: '2-digit', hour12: false });
}

function dayLengthLabel(ms: number): string {
  if (ms <= 0) return 'polar night';
  if (ms >= 86_400_000 - 1000) return 'polar day';
  const totalMin = Math.round(ms / 60_000);
  const h = Math.floor(totalMin / 60);
  const m = totalMin % 60;
  return `${h}h ${String(m).padStart(2, '0')}m of daylight`;
}

/** Minutes past local midnight for `d` in `tz`. Returns null if d is null. */
function localMinutes(d: Date | null, tz: string): number | null {
  if (!d) return null;
  const parts = new Intl.DateTimeFormat('en-GB', {
    timeZone: tz, hour: '2-digit', minute: '2-digit', hour12: false,
  }).formatToParts(d);
  const h = parts.find((p) => p.type === 'hour')?.value;
  const m = parts.find((p) => p.type === 'minute')?.value;
  if (h === undefined || m === undefined) return null;
  return parseInt(h, 10) * 60 + parseInt(m, 10);
}

/**
 * Polar projection onto a 100×100 viewBox. Zenith at center (50,50),
 * horizon ring at radius 48. North at top, East at right (standard
 * astronomer's dome: altitude=90° at center, 0° at edge).
 */
function skyPoint(altitudeDeg: number, azimuthDeg: number): { x: number; y: number } {
  const altClamped = Math.max(0, altitudeDeg);
  const r = ((90 - altClamped) / 90) * 48;
  const az = (azimuthDeg * Math.PI) / 180;
  // azimuth 0=N (up), 90=E (right). x = r·sin(az), y = -r·cos(az) (flip for SVG).
  const x = 50 + r * Math.sin(az);
  const y = 50 - r * Math.cos(az);
  return { x, y };
}

/** Compass direction label from azimuth. */
function bearing(az: number): string {
  const dirs = ['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW'];
  const idx = Math.round(((az % 360) / 45)) % 8;
  return dirs[idx];
}

/** Distance from equator as a fraction (0 at equator, 1 at pole). */
function equatorRatio(lat: number): number {
  return Math.min(1, Math.abs(lat) / 90);
}

/** Parse "HH:MM" → minutes past midnight. Returns null on bad input. */
function parseHHMM(s: string): number | null {
  const m = /^(\d{2}):(\d{2})$/.exec(s);
  if (!m) return null;
  return parseInt(m[1], 10) * 60 + parseInt(m[2], 10);
}

/** Find the ritual whose window contains `nowMin` (local minutes past
 *  midnight). Handles wrap-past-midnight via from > to. Returns null
 *  when nothing matches. */
function findRitual(nowMin: number, rituals: Array<{ from: string; to: string; label: string; glyph?: string }> | undefined) {
  if (!rituals || !rituals.length) return null;
  for (const r of rituals) {
    const from = parseHHMM(r.from);
    const to = parseHHMM(r.to);
    if (from === null || to === null) continue;
    if (from <= to) {
      if (nowMin >= from && nowMin < to) return r;
    } else {
      if (nowMin >= from || nowMin < to) return r;
    }
  }
  return null;
}

/** Default time format when a zone doesn't specify one: US + UK → 12h,
 *  everything else → 24h. */
function defaultTimeFormat(tz: string): '12' | '24' {
  if (tz.startsWith('America/')) return '12';
  if (tz === 'Europe/London') return '12';
  return '24';
}

const zonesSky = zones.map((z) => {
  const s = sunTimes(renderNow, z.lat, z.lon, renderNow);
  const ph = planetaryHour(renderNow, z.lat, z.lon, z.tz);
  const se = season(renderNow, z.lat);
  const sunPt = skyPoint(s.altitudeDeg, s.azimuthDeg);
  const nowMin = localMinutes(renderNow, z.tz) ?? 0;
  const ritual = findRitual(nowMin, z.rituals);
  const timeFormat = z.timeFormat ?? defaultTimeFormat(z.tz);
  return {
    zone: z,
    sun: {
      sunriseLocal: hhmm(s.sunrise, z.tz),
      sunsetLocal: hhmm(s.sunset, z.tz),
      dayLength: dayLengthLabel(s.dayLengthMs),
      altitudeDeg: s.altitudeDeg,
      azimuthDeg: s.azimuthDeg,
      bearing: bearing(s.azimuthDeg),
      isDay: s.isDay,
      domeX: sunPt.x,
      domeY: sunPt.y,
      nowMin,
    },
    planetaryHour: ph,
    season: se,
    latHemi: z.lat >= 0 ? 'N' : 'S',
    latAbs: Math.abs(z.lat).toFixed(1),
    equator: equatorRatio(z.lat),
    ritual,
    timeFormat,
  };
});

// Global sky ribbon data — computed once for the page (moon + shower + marker
// are location-independent except for hemisphere nuance we don't track here).
const moon = moonPhase(renderNow);
const nextMarker = nextEquinoxOrSolstice(renderNow);
const shower = nearestShower(renderNow);
const zodiac = zodiacOfDate(renderNow);

function fmtCountdown(msUntil: number): string {
  const days = Math.floor(msUntil / 86_400_000);
  const hours = Math.floor((msUntil % 86_400_000) / 3_600_000);
  if (days >= 2) return `${days}d`;
  if (days === 1) return `1d ${hours}h`;
  return `${hours}h`;
}

const moonCountdown = fmtCountdown(moon.nextFullAt.getTime() - renderNow.getTime());
const newMoonCountdown = fmtCountdown(moon.nextNewAt.getTime() - renderNow.getTime());
// Show the closer of full/new as the headline countdown.
const moonNextLabel = (moon.nextFullAt.getTime() - renderNow.getTime())
  < (moon.nextNewAt.getTime() - renderNow.getTime())
  ? `full in ${moonCountdown}`
  : `new in ${newMoonCountdown}`;

const title = data.title;
const description = `A clock that carries its sky. ${zones.length} zones with live sun arcs, planetary hours, season, and the moon overhead. CH.${ch.code} № ${data.id}.`;
const ogImage = `/images/og/b/${data.id}.png`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: title,
  description,
  applicationCategory: 'Utility',
  operatingSystem: 'Web Browser (any)',
  url: `https://pointcast.xyz/clock/${data.id}`,
  isPartOf: {
    '@type': 'CreativeWork',
    '@id': `https://pointcast.xyz/b/${data.id}`,
  },
};
---

<BlockLayout title={title} description={description} image={ogImage} jsonLd={jsonLd}>
  <div
    class="clock-page"
    style={`--ch-600: ${ch.color600}; --ch-800: ${ch.color800}; --ch-50: ${ch.color50};`}
  >
    <header class="clock-head">
      <p class="clock-head__kicker mono">
        CH.{ch.code} · № {data.id}
      </p>
      <h1 class="clock-head__title">{data.title}</h1>
      {data.body && <p class="clock-head__body">{data.body}</p>}
      <p class="clock-head__links mono">
        <a href={`/b/${data.id}`}>← BLOCK</a>
        <span aria-hidden="true">·</span>
        <a href={`/b/${data.id}.json`}>JSON</a>
      </p>
    </header>

    <aside class="sky-ribbon" aria-label="Sky now">
      <div class="sky-ribbon__cell">
        <p class="sky-ribbon__kicker mono">MOON</p>
        <p class="sky-ribbon__value">
          <span class="sky-ribbon__glyph" aria-hidden="true">{moon.glyph}</span>
          {moon.label}
          <span class="sky-ribbon__muted">· {Math.round(moon.illumination * 100)}% lit · {moonNextLabel}</span>
        </p>
      </div>
      {shower && (
        <div class="sky-ribbon__cell">
          <p class="sky-ribbon__kicker mono">
            {shower.inWindow ? 'SHOWER' : 'NEXT SHOWER'}
          </p>
          <p class="sky-ribbon__value">
            <span class="sky-ribbon__glyph" aria-hidden="true">{shower.shower.glyph}</span>
            {shower.shower.name}
            <span class="sky-ribbon__muted">
              · {shower.daysUntil === 0
                  ? 'peaks tonight'
                  : shower.daysUntil > 0
                    ? `peak in ${shower.daysUntil}d`
                    : `peak was ${-shower.daysUntil}d ago`}
              · from {shower.shower.radiant}
            </span>
          </p>
        </div>
      )}
      <div class="sky-ribbon__cell">
        <p class="sky-ribbon__kicker mono">COMING</p>
        <p class="sky-ribbon__value">
          <span class="sky-ribbon__glyph" aria-hidden="true">☼</span>
          {nextMarker.label}
          <span class="sky-ribbon__muted">· in {nextMarker.daysUntil}d</span>
        </p>
      </div>
      <div class="sky-ribbon__cell">
        <p class="sky-ribbon__kicker mono">ZODIAC</p>
        <p class="sky-ribbon__value">
          <span class="sky-ribbon__glyph" aria-hidden="true">{zodiac.glyph}</span>
          Sun in {zodiac.name}
          <span class="sky-ribbon__muted">· day {zodiac.dayInSign}</span>
        </p>
      </div>
    </aside>

    <section class="clock-grid" aria-label="World clock">
      {zonesSky.map(({ zone: z, sun, planetaryHour: ph, season: se, latHemi, latAbs, equator, ritual, timeFormat }) => (
        <article
          class="clock-card"
          data-tz={z.tz}
          data-origin={z.origin}
          data-lat={z.lat}
          data-lon={z.lon}
          data-time-format={timeFormat}
          data-rituals={z.rituals ? JSON.stringify(z.rituals) : ''}
        >
          <div class="clock-card__top">
            <div class="clock-card__top-text">
              <p class="clock-card__label">{z.label}</p>
              {z.region && <p class="clock-card__region">{z.region}</p>}
              {z.facts && Object.keys(z.facts).length > 0 && (
                <ul class="clock-card__facts mono" aria-label="Place stats">
                  {Object.entries(z.facts).map(([k, v]) => (
                    <li>
                      <span class="clock-card__fact-key">{k}</span>
                      <span class="clock-card__fact-val">{v}</span>
                    </li>
                  ))}
                </ul>
              )}
              <p class="clock-card__latline mono">
                {latAbs}°{latHemi}
                <span class="clock-card__sep" aria-hidden="true">·</span>
                {sun.isDay
                  ? <span>sun {Math.round(sun.altitudeDeg)}° up · {sun.bearing}</span>
                  : <span>sun {Math.abs(Math.round(sun.altitudeDeg))}° below</span>}
              </p>
            </div>

            {/* Per-zone sky dome — polar projection of the local sky RIGHT NOW.
                Zenith at center, horizon at the ring. Sun plotted at its actual
                azimuth + altitude. When sun is below horizon, it falls on the
                outer "underworld" arc so the viewer sees how deep under. */}
            <svg class="skydome" viewBox="0 0 100 100" aria-hidden="true" data-role="skydome">
              {/* Below-horizon disc (visible when sun is down) */}
              <circle cx="50" cy="50" r="48" fill="#0B0E1F" />
              {/* Above-horizon disc — graded from zenith blue to horizon amber */}
              <defs>
                <radialGradient id={`sky-grad-${data.id}-${z.label.replace(/[^a-zA-Z0-9]/g, '')}`} cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#7FC5E8" />
                  <stop offset="70%" stop-color="#D3E7F1" />
                  <stop offset="95%" stop-color="#F7D7A8" />
                  <stop offset="100%" stop-color="#D88A4A" />
                </radialGradient>
              </defs>
              {sun.isDay && (
                <circle cx="50" cy="50" r="48" fill={`url(#sky-grad-${data.id}-${z.label.replace(/[^a-zA-Z0-9]/g, '')})`} />
              )}
              {/* Horizon ring */}
              <circle cx="50" cy="50" r="48" fill="none" stroke="#12110E" stroke-opacity="0.25" stroke-width="0.8" />
              {/* Altitude rings at 30° and 60° */}
              <circle cx="50" cy="50" r="32" fill="none" stroke="#12110E" stroke-opacity="0.08" stroke-width="0.5" stroke-dasharray="1 2" />
              <circle cx="50" cy="50" r="16" fill="none" stroke="#12110E" stroke-opacity="0.08" stroke-width="0.5" stroke-dasharray="1 2" />
              {/* Compass cardinal ticks */}
              <g fill="var(--pc-ink-muted, #5F5E5A)" font-family="JetBrains Mono, monospace" font-size="7" text-anchor="middle">
                <text x="50" y="5.5">N</text>
                <text x="97" y="52.5">E</text>
                <text x="50" y="99">S</text>
                <text x="3" y="52.5">W</text>
              </g>
              {/* Sun body at its (alt, az) projection */}
              <circle
                data-role="sun-body"
                cx={sun.domeX}
                cy={sun.domeY}
                r={sun.isDay ? 5.5 : 4}
                fill={sun.isDay ? '#FFE65C' : '#4A4770'}
                stroke={sun.isDay ? '#FBB040' : '#2A2748'}
                stroke-width="1"
                opacity={sun.isDay ? '1' : '0.55'}
              />
              {/* Sun rays when up high (altitude > 30°) — a subtle halo */}
              {sun.isDay && sun.altitudeDeg > 30 && (
                <circle
                  cx={sun.domeX}
                  cy={sun.domeY}
                  r="9"
                  fill="none"
                  stroke="#FBB040"
                  stroke-opacity="0.35"
                  stroke-width="0.6"
                />
              )}
            </svg>
          </div>

          <p class="clock-card__time mono" aria-live="off">
            <span class="clock-card__hm" data-role="hm">—:—</span><span
              class="clock-card__sec"
              data-role="sec"
            >:—</span><span class="clock-card__ap" data-role="ap"></span>
          </p>
          <p class="clock-card__date mono" data-role="date">—</p>
          <p class="clock-card__status mono" data-role="status" data-bucket="">—</p>
          <p
            class={ritual ? 'clock-card__ritual clock-card__ritual--active' : 'clock-card__ritual'}
            data-role="ritual"
          >
            {ritual ? (
              <>
                {ritual.glyph && <span class="clock-card__ritual-glyph" aria-hidden="true">{ritual.glyph}</span>}
                <span class="clock-card__ritual-label">{ritual.label}</span>
              </>
            ) : (
              <span class="clock-card__ritual-quiet">quiet hour</span>
            )}
          </p>

          <div class="clock-card__sky" aria-label="Sky here">
            <p class="clock-card__sky-line mono">
              <span aria-hidden="true">↑</span>
              <span data-role="sunrise">{sun.sunriseLocal}</span>
              <span class="clock-card__sky-muted">· {sun.dayLength}</span>
              <span aria-hidden="true">↓</span>
              <span data-role="sunset">{sun.sunsetLocal}</span>
            </p>
            {ph && (
              <p class="clock-card__sky-line mono" data-role="phour">
                <span aria-hidden="true">{ph.glyph}</span>
                <span data-role="phour-planet">{ph.planet}</span>
                <span class="clock-card__sky-sep">hour</span>
                <span class="clock-card__sky-muted" data-role="phour-meta">
                  · {ph.index} of 12 · {ph.phase}
                </span>
              </p>
            )}
            <p class="clock-card__sky-line mono" data-role="season">
              <span aria-hidden="true">{se.glyph}</span>
              {se.name}
              <span class="clock-card__sky-muted">· day {se.dayOfSeason} of {se.lengthDays}</span>
            </p>
            {z.seasonal && (
              <p class="clock-card__seasonal">{z.seasonal}</p>
            )}
          </div>

          {z.landmarks && z.landmarks.length > 0 && (
            <section class="clock-card__landmarks" aria-label="Nearby">
              <p class="clock-card__landmarks-kicker mono">NEARBY</p>
              <ul class="clock-card__landmarks-list">
                {z.landmarks.map((l) => <li>{l}</li>)}
              </ul>
            </section>
          )}

          <p class="clock-card__tz mono" title={z.tz}>{z.tz}</p>
        </article>
      ))}
    </section>

    <footer class="clock-foot mono">
      <p>
        Tick interval · 1s for the hour · 60s for the sky. Sun, moon,
        planetary hour, season, and the meteor calendar are all pure math
        from <code>(lat, lon, date, now)</code> — no APIs, no keys.
        <code>Intl.DateTimeFormat</code> handles DST in the browser.
      </p>
    </footer>
  </div>
</BlockLayout>

<script is:inline>
  (() => {
    const cards = document.querySelectorAll('[data-tz]');
    if (!cards.length) return;

    const fmtCache = {};
    const dateFmtCache = {};

    function getFmt(tz, hour12) {
      const key = `${tz}:${hour12 ? '12' : '24'}`;
      if (!fmtCache[key]) {
        try {
          fmtCache[key] = new Intl.DateTimeFormat('en-US', {
            timeZone: tz,
            hour: hour12 ? 'numeric' : '2-digit',
            minute: '2-digit',
            second: '2-digit',
            hour12: !!hour12,
          });
        } catch (err) {
          console.warn('clock: bad timezone', tz, err);
          return null;
        }
      }
      return fmtCache[key];
    }

    function getDateFmt(tz) {
      if (!dateFmtCache[tz]) {
        try {
          dateFmtCache[tz] = new Intl.DateTimeFormat('en-US', {
            timeZone: tz, weekday: 'short', month: 'short', day: 'numeric',
          });
        } catch (err) { return null; }
      }
      return dateFmtCache[tz];
    }

    function bucketFor(hour) {
      if (hour >= 22 || hour < 6) return { key: 'night', glyph: '🌙', label: 'Late night' };
      if (hour < 9)               return { key: 'early', glyph: '☕', label: 'Pre-coffee' };
      if (hour < 12)              return { key: 'morning', glyph: '🌅', label: 'Morning' };
      if (hour < 18)              return { key: 'work', glyph: '🟢', label: 'Working hours' };
      return { key: 'evening', glyph: '🍷', label: 'Evening' };
    }

    function parseHHMM(s) {
      const m = /^(\d{2}):(\d{2})$/.exec(s);
      return m ? parseInt(m[1], 10) * 60 + parseInt(m[2], 10) : null;
    }

    function findRitual(nowMin, rituals) {
      if (!rituals || !rituals.length) return null;
      for (const r of rituals) {
        const from = parseHHMM(r.from), to = parseHHMM(r.to);
        if (from === null || to === null) continue;
        if (from <= to) { if (nowMin >= from && nowMin < to) return r; }
        else            { if (nowMin >= from || nowMin < to) return r; }
      }
      return null;
    }

    function tick() {
      const now = new Date();
      for (const el of cards) {
        const tz = el.getAttribute('data-tz');
        if (!tz) continue;
        const timeFormat = el.getAttribute('data-time-format') || '24';
        const is12 = timeFormat === '12';
        const fmt = getFmt(tz, is12);
        if (!fmt) continue;
        const parts = fmt.formatToParts(now);
        const pick = (t) => parts.find((p) => p.type === t)?.value ?? '';
        const hm = `${pick('hour')}:${pick('minute')}`;
        const sec = `:${pick('second')}`;
        const ap = is12 ? (pick('dayPeriod') || '') : '';

        const hmEl = el.querySelector('[data-role="hm"]');
        const secEl = el.querySelector('[data-role="sec"]');
        const apEl = el.querySelector('[data-role="ap"]');
        const dateEl = el.querySelector('[data-role="date"]');
        const statusEl = el.querySelector('[data-role="status"]');
        if (hmEl && hmEl.textContent !== hm) hmEl.textContent = hm;
        if (secEl && secEl.textContent !== sec) secEl.textContent = sec;
        if (apEl && apEl.textContent !== ap) apEl.textContent = ap ? ' ' + ap : '';
        if (dateEl) {
          const df = getDateFmt(tz);
          if (df) {
            const d = df.format(now);
            if (dateEl.textContent !== d) dateEl.textContent = d;
          }
        }

        // 24h-hour for bucket + ritual matching (ritual.from/to are 24h).
        const fmt24 = getFmt(tz, false);
        let hour24 = 0, nowMin = 0;
        if (fmt24) {
          const p24 = fmt24.formatToParts(now);
          const h24 = parseInt(p24.find((p) => p.type === 'hour')?.value || '0', 10);
          const m24 = parseInt(p24.find((p) => p.type === 'minute')?.value || '0', 10);
          hour24 = h24;
          nowMin = h24 * 60 + m24;
        }

        if (statusEl) {
          const b = bucketFor(hour24);
          const text = `${b.glyph} ${b.label}`;
          if (statusEl.textContent !== text) statusEl.textContent = text;
          if (statusEl.getAttribute('data-bucket') !== b.key) {
            statusEl.setAttribute('data-bucket', b.key);
          }
        }

        // Ritual — re-match each tick so the chip rolls over cleanly.
        const ritualEl = el.querySelector('[data-role="ritual"]');
        if (ritualEl) {
          let rituals = null;
          const raw = el.getAttribute('data-rituals');
          if (raw) { try { rituals = JSON.parse(raw); } catch {} }
          const r = findRitual(nowMin, rituals);
          if (r) {
            const next = (r.glyph ? r.glyph + ' ' : '') + r.label;
            if (ritualEl.textContent?.trim() !== next.trim()) {
              ritualEl.innerHTML = (r.glyph ? `<span class="clock-card__ritual-glyph" aria-hidden="true">${r.glyph}</span>` : '') + `<span class="clock-card__ritual-label">${r.label}</span>`;
            }
            ritualEl.classList.add('clock-card__ritual--active');
          } else {
            if (!ritualEl.querySelector('.clock-card__ritual-quiet')) {
              ritualEl.innerHTML = '<span class="clock-card__ritual-quiet">quiet hour</span>';
            }
            ritualEl.classList.remove('clock-card__ritual--active');
          }
        }
      }
    }

    tick();
    setInterval(tick, 1000);
  })();
</script>

<script>
  /**
   * Sky refresh — re-run the astronomical helpers every minute so the
   * planetary hour (which ticks over roughly every 60min) and sun
   * altitude / isDay flag stay fresh between page rebuilds. The initial
   * values are server-rendered; this just updates them in place.
   */
  import { sunTimes, planetaryHour } from '../../lib/sky';

  function skyPoint(altitudeDeg: number, azimuthDeg: number): { x: number; y: number } {
    const altClamped = Math.max(0, altitudeDeg);
    const r = ((90 - altClamped) / 90) * 48;
    const az = (azimuthDeg * Math.PI) / 180;
    return { x: 50 + r * Math.sin(az), y: 50 - r * Math.cos(az) };
  }

  function bearing(az: number): string {
    const dirs = ['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW'];
    return dirs[Math.round(((az % 360) / 45)) % 8];
  }

  const CARDS = document.querySelectorAll<HTMLElement>('.clock-card[data-lat][data-lon]');

  function fmt(d: Date | null, tz: string, opts: Intl.DateTimeFormatOptions): string {
    if (!d) return '—';
    return new Intl.DateTimeFormat('en-US', { ...opts, timeZone: tz }).format(d);
  }

  function refresh() {
    const now = new Date();
    for (const card of CARDS) {
      const tz = card.dataset.tz;
      const lat = parseFloat(card.dataset.lat ?? '');
      const lon = parseFloat(card.dataset.lon ?? '');
      if (!tz || !Number.isFinite(lat) || !Number.isFinite(lon)) continue;

      const s = sunTimes(now, lat, lon, now);
      const ph = planetaryHour(now, lat, lon, tz);

      const sunriseEl = card.querySelector<HTMLElement>('[data-role="sunrise"]');
      const sunsetEl = card.querySelector<HTMLElement>('[data-role="sunset"]');
      if (sunriseEl) sunriseEl.textContent = fmt(s.sunrise, tz, { hour: '2-digit', minute: '2-digit', hour12: false });
      if (sunsetEl) sunsetEl.textContent = fmt(s.sunset, tz, { hour: '2-digit', minute: '2-digit', hour12: false });

      // Re-plot the sun on the polar sky dome.
      const sunBody = card.querySelector<SVGCircleElement>('[data-role="sun-body"]');
      if (sunBody) {
        const pt = skyPoint(s.altitudeDeg, s.azimuthDeg);
        sunBody.setAttribute('cx', String(pt.x));
        sunBody.setAttribute('cy', String(pt.y));
        sunBody.setAttribute('r', s.isDay ? '5.5' : '4');
        sunBody.setAttribute('fill', s.isDay ? '#FFE65C' : '#4A4770');
        sunBody.setAttribute('stroke', s.isDay ? '#FBB040' : '#2A2748');
        sunBody.setAttribute('opacity', s.isDay ? '1' : '0.55');
      }

      const phPlanet = card.querySelector<HTMLElement>('[data-role="phour-planet"]');
      const phMeta = card.querySelector<HTMLElement>('[data-role="phour-meta"]');
      if (ph && phPlanet) phPlanet.textContent = ph.planet;
      if (ph && phMeta) phMeta.textContent = `· ${ph.index} of 12 · ${ph.phase}`;
      if (ph) {
        const phLine = card.querySelector<HTMLElement>('[data-role="phour"]');
        const glyph = phLine?.querySelector<HTMLElement>('span[aria-hidden="true"]');
        if (glyph) glyph.textContent = ph.glyph;
      }
    }
  }

  refresh();
  setInterval(refresh, 60_000);
</script>

