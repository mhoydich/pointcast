---
/**
 * /clock/{id} — Collab Clock companion page.
 *
 * Live-ticking world clock that reads its zones from two sources:
 *   1. src/lib/collaborators.ts — when clock.includeCollaborators !== false
 *   2. block JSON clock.zones[] — manual extras
 *
 * Entirely client-side after first paint: Intl.DateTimeFormat handles DST
 * and offsets, a setInterval(1s) updates the readouts, no deps.
 *
 * Distinct from /b/{id} — that page stays the canonical, agent-readable
 * record. /clock/{id} is the live companion, same pattern as /yee/{id}.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import BlockLayout from '../../layouts/BlockLayout.astro';
import { CHANNELS } from '../../lib/channels';
import { COLLABORATORS } from '../../lib/collaborators';
import { resolveZones } from '../../lib/timezones';
import {
  moonPhase,
  sunTimes,
  planetaryHour,
  season,
  nextEquinoxOrSolstice,
  zodiacOfDate,
} from '../../lib/sky';
import { nearestShower } from '../../lib/meteor-showers';

export async function getStaticPaths() {
  const blocks = await getCollection('blocks', ({ data }) =>
    !data.draft && data.clock !== undefined,
  );
  return blocks.map((block) => ({
    params: { id: block.data.id },
    props: { block },
  }));
}

interface Props {
  block: CollectionEntry<'blocks'>;
}
const { block } = Astro.props;
const data = block.data;
const ch = CHANNELS[data.channel];

const zones = resolveZones(data.clock, COLLABORATORS);

/**
 * Prerender sky data server-side for each zone. Client JS re-derives
 * these every minute so the planetary hour / sun altitude stay fresh
 * without a page rebuild.
 */
const renderNow = new Date();

function formatInZone(d: Date, tz: string, opts: Intl.DateTimeFormatOptions): string {
  return new Intl.DateTimeFormat('en-US', { ...opts, timeZone: tz }).format(d);
}

function hhmm(d: Date | null, tz: string): string {
  if (!d) return '—';
  return formatInZone(d, tz, { hour: '2-digit', minute: '2-digit', hour12: false });
}

function dayLengthLabel(ms: number): string {
  if (ms <= 0) return 'polar night';
  if (ms >= 86_400_000 - 1000) return 'polar day';
  const totalMin = Math.round(ms / 60_000);
  const h = Math.floor(totalMin / 60);
  const m = totalMin % 60;
  return `${h}h ${String(m).padStart(2, '0')}m of daylight`;
}

/** Minutes past local midnight for `d` in `tz`. Returns null if d is null. */
function localMinutes(d: Date | null, tz: string): number | null {
  if (!d) return null;
  const parts = new Intl.DateTimeFormat('en-GB', {
    timeZone: tz, hour: '2-digit', minute: '2-digit', hour12: false,
  }).formatToParts(d);
  const h = parts.find((p) => p.type === 'hour')?.value;
  const m = parts.find((p) => p.type === 'minute')?.value;
  if (h === undefined || m === undefined) return null;
  return parseInt(h, 10) * 60 + parseInt(m, 10);
}

const zonesSky = zones.map((z) => {
  const s = sunTimes(renderNow, z.lat, z.lon, renderNow);
  const ph = planetaryHour(renderNow, z.lat, z.lon, z.tz);
  const se = season(renderNow, z.lat);
  return {
    zone: z,
    sun: {
      sunriseLocal: hhmm(s.sunrise, z.tz),
      sunsetLocal: hhmm(s.sunset, z.tz),
      dayLength: dayLengthLabel(s.dayLengthMs),
      altitudeDeg: s.altitudeDeg,
      isDay: s.isDay,
      // Positions on a 24h strip (0..1440 minutes past local midnight).
      // Used by the <SunStrip> SVG so we can show the sun on its arc.
      sunriseMin: localMinutes(s.sunrise, z.tz),
      sunsetMin: localMinutes(s.sunset, z.tz),
      nowMin: localMinutes(renderNow, z.tz) ?? 0,
      solarNoonMin: localMinutes(s.solarNoon, z.tz),
    },
    planetaryHour: ph,
    season: se,
  };
});

// Global sky ribbon data — computed once for the page (moon + shower + marker
// are location-independent except for hemisphere nuance we don't track here).
const moon = moonPhase(renderNow);
const nextMarker = nextEquinoxOrSolstice(renderNow);
const shower = nearestShower(renderNow);
const zodiac = zodiacOfDate(renderNow);

function fmtCountdown(msUntil: number): string {
  const days = Math.floor(msUntil / 86_400_000);
  const hours = Math.floor((msUntil % 86_400_000) / 3_600_000);
  if (days >= 2) return `${days}d`;
  if (days === 1) return `1d ${hours}h`;
  return `${hours}h`;
}

const moonCountdown = fmtCountdown(moon.nextFullAt.getTime() - renderNow.getTime());
const newMoonCountdown = fmtCountdown(moon.nextNewAt.getTime() - renderNow.getTime());
// Show the closer of full/new as the headline countdown.
const moonNextLabel = (moon.nextFullAt.getTime() - renderNow.getTime())
  < (moon.nextNewAt.getTime() - renderNow.getTime())
  ? `full in ${moonCountdown}`
  : `new in ${newMoonCountdown}`;

const title = data.title;
const description = `A clock that carries its sky. ${zones.length} zones with live sun arcs, planetary hours, season, and the moon overhead. CH.${ch.code} № ${data.id}.`;
const ogImage = `/images/og/b/${data.id}.png`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: title,
  description,
  applicationCategory: 'Utility',
  operatingSystem: 'Web Browser (any)',
  url: `https://pointcast.xyz/clock/${data.id}`,
  isPartOf: {
    '@type': 'CreativeWork',
    '@id': `https://pointcast.xyz/b/${data.id}`,
  },
};
---

<BlockLayout title={title} description={description} image={ogImage} jsonLd={jsonLd}>
  <div
    class="clock-page"
    style={`--ch-600: ${ch.color600}; --ch-800: ${ch.color800}; --ch-50: ${ch.color50};`}
  >
    <header class="clock-head">
      <p class="clock-head__kicker mono">
        CH.{ch.code} · № {data.id}
      </p>
      <h1 class="clock-head__title">{data.title}</h1>
      {data.body && <p class="clock-head__body">{data.body}</p>}
      <p class="clock-head__links mono">
        <a href={`/b/${data.id}`}>← BLOCK</a>
        <span aria-hidden="true">·</span>
        <a href={`/b/${data.id}.json`}>JSON</a>
      </p>
    </header>

    <aside class="sky-ribbon" aria-label="Sky now">
      <div class="sky-ribbon__cell">
        <p class="sky-ribbon__kicker mono">MOON</p>
        <p class="sky-ribbon__value">
          <span class="sky-ribbon__glyph" aria-hidden="true">{moon.glyph}</span>
          {moon.label}
          <span class="sky-ribbon__muted">· {Math.round(moon.illumination * 100)}% lit · {moonNextLabel}</span>
        </p>
      </div>
      {shower && (
        <div class="sky-ribbon__cell">
          <p class="sky-ribbon__kicker mono">
            {shower.inWindow ? 'SHOWER' : 'NEXT SHOWER'}
          </p>
          <p class="sky-ribbon__value">
            <span class="sky-ribbon__glyph" aria-hidden="true">{shower.shower.glyph}</span>
            {shower.shower.name}
            <span class="sky-ribbon__muted">
              · {shower.daysUntil === 0
                  ? 'peaks tonight'
                  : shower.daysUntil > 0
                    ? `peak in ${shower.daysUntil}d`
                    : `peak was ${-shower.daysUntil}d ago`}
              · from {shower.shower.radiant}
            </span>
          </p>
        </div>
      )}
      <div class="sky-ribbon__cell">
        <p class="sky-ribbon__kicker mono">COMING</p>
        <p class="sky-ribbon__value">
          <span class="sky-ribbon__glyph" aria-hidden="true">☼</span>
          {nextMarker.label}
          <span class="sky-ribbon__muted">· in {nextMarker.daysUntil}d</span>
        </p>
      </div>
      <div class="sky-ribbon__cell">
        <p class="sky-ribbon__kicker mono">ZODIAC</p>
        <p class="sky-ribbon__value">
          <span class="sky-ribbon__glyph" aria-hidden="true">{zodiac.glyph}</span>
          Sun in {zodiac.name}
          <span class="sky-ribbon__muted">· day {zodiac.dayInSign}</span>
        </p>
      </div>
    </aside>

    <section class="clock-grid" aria-label="World clock">
      {zonesSky.map(({ zone: z, sun, planetaryHour: ph, season: se }) => (
        <article
          class="clock-card"
          data-tz={z.tz}
          data-origin={z.origin}
          data-lat={z.lat}
          data-lon={z.lon}
        >
          <p class="clock-card__label">{z.label}</p>
          <p class="clock-card__time mono" aria-live="off">
            <span class="clock-card__hm" data-role="hm">—:—</span><span
              class="clock-card__sec"
              data-role="sec"
            >:—</span>
          </p>
          <p class="clock-card__date mono" data-role="date">—</p>
          <p class="clock-card__status mono" data-role="status" data-bucket="">—</p>

          <div class="clock-card__sky" aria-label="Sky here">
            <div class="sun-strip-wrap">
              <svg
                class="sun-strip"
                viewBox="0 0 1440 28"
                preserveAspectRatio="none"
                aria-hidden="true"
                data-role="sun-strip"
                data-sunrise={sun.sunriseMin ?? ''}
                data-sunset={sun.sunsetMin ?? ''}
                data-solar-noon={sun.solarNoonMin ?? ''}
                data-now={sun.nowMin}
                data-is-day={sun.isDay ? '1' : '0'}
              >
                <defs>
                  <linearGradient id={`sun-grad-${data.id}-${z.label.replace(/[^a-zA-Z0-9]/g, '')}`} x1="0" x2="1" y1="0" y2="0">
                    <stop offset="0%" stop-color="#D88A4A" />
                    <stop offset="15%" stop-color="#F5D563" />
                    <stop offset="50%" stop-color="#FBF6D4" />
                    <stop offset="85%" stop-color="#F5D563" />
                    <stop offset="100%" stop-color="#C26040" />
                  </linearGradient>
                </defs>
                {/* Night base — full 24h indigo slab. */}
                <rect x="0" y="0" width="1440" height="28" fill="#0B0E1F" />
                {/* Day band from sunrise to sunset — server-rendered; client-updated
                    via data-sunrise/sunset attributes on rebuild. */}
                {sun.sunriseMin !== null && sun.sunsetMin !== null && (
                  <rect
                    data-role="day-band"
                    x={sun.sunriseMin}
                    y="0"
                    width={sun.sunsetMin - sun.sunriseMin}
                    height="28"
                    fill={`url(#sun-grad-${data.id}-${z.label.replace(/[^a-zA-Z0-9]/g, '')})`}
                  />
                )}
                {/* Hour ticks at 06, 12, 18 */}
                <g stroke="#FFFFFF" stroke-opacity="0.18" stroke-width="1">
                  <line x1="360" y1="0" x2="360" y2="28" />
                  <line x1="720" y1="0" x2="720" y2="28" />
                  <line x1="1080" y1="0" x2="1080" y2="28" />
                </g>
                {/* Now marker */}
                <line
                  data-role="now-marker"
                  x1={sun.nowMin}
                  y1="-2"
                  x2={sun.nowMin}
                  y2="30"
                  stroke="#12110E"
                  stroke-width="3"
                  stroke-linecap="round"
                />
                {/* Sun or moon glyph at current position */}
                <circle
                  data-role="now-body"
                  cx={sun.nowMin}
                  cy="14"
                  r={sun.isDay ? 9 : 7}
                  fill={sun.isDay ? '#FFE65C' : '#D9D6EF'}
                  stroke={sun.isDay ? '#FBB040' : '#8B85C3'}
                  stroke-width="1.5"
                />
              </svg>
              <p class="sun-strip__labels mono" aria-hidden="true">
                <span class="sun-strip__rise" data-role="sunrise">{sun.sunriseLocal}</span>
                <span class="sun-strip__daylen" data-role="daylen">{sun.dayLength}</span>
                <span class="sun-strip__set" data-role="sunset">{sun.sunsetLocal}</span>
              </p>
            </div>
            {ph && (
              <p class="clock-card__sky-line mono" data-role="phour">
                <span aria-hidden="true">{ph.glyph}</span>
                <span data-role="phour-planet">{ph.planet}</span>
                <span class="clock-card__sky-sep">hour</span>
                <span class="clock-card__sky-muted" data-role="phour-meta">
                  · {ph.index} of 12 · {ph.phase}
                </span>
              </p>
            )}
            <p class="clock-card__sky-line mono" data-role="season">
              <span aria-hidden="true">{se.glyph}</span>
              {se.name}
              <span class="clock-card__sky-muted">· day {se.dayOfSeason} of {se.lengthDays}</span>
            </p>
          </div>

          <p class="clock-card__tz mono" title={z.tz}>{z.tz}</p>
        </article>
      ))}
    </section>

    <footer class="clock-foot mono">
      <p>
        Tick interval · 1s for the hour · 60s for the sky. Sun, moon,
        planetary hour, season, and the meteor calendar are all pure math
        from <code>(lat, lon, date, now)</code> — no APIs, no keys.
        <code>Intl.DateTimeFormat</code> handles DST in the browser.
      </p>
    </footer>
  </div>
</BlockLayout>

<script is:inline>
  (() => {
    const cards = document.querySelectorAll('[data-tz]');
    if (!cards.length) return;

    const fmt = {};
    const dateFmt = {};
    for (const el of cards) {
      const tz = el.getAttribute('data-tz');
      if (!tz || fmt[tz]) continue;
      try {
        fmt[tz] = new Intl.DateTimeFormat('en-US', {
          timeZone: tz,
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
          hour12: false,
        });
        dateFmt[tz] = new Intl.DateTimeFormat('en-US', {
          timeZone: tz,
          weekday: 'short',
          month: 'short',
          day: 'numeric',
        });
      } catch (err) {
        console.warn('clock: bad timezone', tz, err);
      }
    }

    /** Hour → register bucket. Tuned to a working rhythm rather than
     *  textbook day/night: early morning gets its own register because
     *  "pre-coffee" reads differently from "morning-meeting." */
    function bucketFor(hour) {
      if (hour >= 22 || hour < 6) return { key: 'night', glyph: '🌙', label: 'Late night' };
      if (hour < 9)               return { key: 'early', glyph: '☕', label: 'Pre-coffee' };
      if (hour < 12)              return { key: 'morning', glyph: '🌅', label: 'Morning' };
      if (hour < 18)              return { key: 'work', glyph: '🟢', label: 'Working hours' };
      return { key: 'evening', glyph: '🍷', label: 'Evening' };
    }

    function tick() {
      const now = new Date();
      for (const el of cards) {
        const tz = el.getAttribute('data-tz');
        if (!tz || !fmt[tz]) continue;
        const parts = fmt[tz].formatToParts(now);
        const pick = (t) => parts.find((p) => p.type === t)?.value ?? '';
        const hm = `${pick('hour')}:${pick('minute')}`;
        const sec = `:${pick('second')}`;
        const hmEl = el.querySelector('[data-role="hm"]');
        const secEl = el.querySelector('[data-role="sec"]');
        const dateEl = el.querySelector('[data-role="date"]');
        const statusEl = el.querySelector('[data-role="status"]');
        if (hmEl && hmEl.textContent !== hm) hmEl.textContent = hm;
        if (secEl && secEl.textContent !== sec) secEl.textContent = sec;
        if (dateEl) {
          const d = dateFmt[tz].format(now);
          if (dateEl.textContent !== d) dateEl.textContent = d;
        }
        if (statusEl) {
          const b = bucketFor(parseInt(pick('hour'), 10));
          const text = `${b.glyph} ${b.label}`;
          if (statusEl.textContent !== text) statusEl.textContent = text;
          if (statusEl.getAttribute('data-bucket') !== b.key) {
            statusEl.setAttribute('data-bucket', b.key);
          }
        }
      }
    }

    tick();
    setInterval(tick, 1000);
  })();
</script>

<script>
  /**
   * Sky refresh — re-run the astronomical helpers every minute so the
   * planetary hour (which ticks over roughly every 60min) and sun
   * altitude / isDay flag stay fresh between page rebuilds. The initial
   * values are server-rendered; this just updates them in place.
   */
  import { sunTimes, planetaryHour } from '../../lib/sky';

  const CARDS = document.querySelectorAll<HTMLElement>('.clock-card[data-lat][data-lon]');

  function fmt(d: Date | null, tz: string, opts: Intl.DateTimeFormatOptions): string {
    if (!d) return '—';
    return new Intl.DateTimeFormat('en-US', { ...opts, timeZone: tz }).format(d);
  }

  function refresh() {
    const now = new Date();
    for (const card of CARDS) {
      const tz = card.dataset.tz;
      const lat = parseFloat(card.dataset.lat ?? '');
      const lon = parseFloat(card.dataset.lon ?? '');
      if (!tz || !Number.isFinite(lat) || !Number.isFinite(lon)) continue;

      const s = sunTimes(now, lat, lon, now);
      const ph = planetaryHour(now, lat, lon, tz);

      // Compute local minutes past midnight for the strip now-marker.
      const nowParts = new Intl.DateTimeFormat('en-GB', {
        timeZone: tz, hour: '2-digit', minute: '2-digit', hour12: false,
      }).formatToParts(now);
      const nowMin =
        parseInt(nowParts.find((p) => p.type === 'hour')?.value ?? '0', 10) * 60 +
        parseInt(nowParts.find((p) => p.type === 'minute')?.value ?? '0', 10);

      const sunriseEl = card.querySelector<HTMLElement>('[data-role="sunrise"]');
      const sunsetEl = card.querySelector<HTMLElement>('[data-role="sunset"]');
      if (sunriseEl) sunriseEl.textContent = fmt(s.sunrise, tz, { hour: '2-digit', minute: '2-digit', hour12: false });
      if (sunsetEl) sunsetEl.textContent = fmt(s.sunset, tz, { hour: '2-digit', minute: '2-digit', hour12: false });

      // Move the now-marker line + sun/moon body to the new nowMin position.
      const marker = card.querySelector<SVGLineElement>('[data-role="now-marker"]');
      const body = card.querySelector<SVGCircleElement>('[data-role="now-body"]');
      if (marker) {
        marker.setAttribute('x1', String(nowMin));
        marker.setAttribute('x2', String(nowMin));
      }
      if (body) {
        body.setAttribute('cx', String(nowMin));
        body.setAttribute('r', s.isDay ? '9' : '7');
        body.setAttribute('fill', s.isDay ? '#FFE65C' : '#D9D6EF');
        body.setAttribute('stroke', s.isDay ? '#FBB040' : '#8B85C3');
      }

      const phPlanet = card.querySelector<HTMLElement>('[data-role="phour-planet"]');
      const phMeta = card.querySelector<HTMLElement>('[data-role="phour-meta"]');
      if (ph && phPlanet) phPlanet.textContent = ph.planet;
      if (ph && phMeta) phMeta.textContent = `· ${ph.index} of 12 · ${ph.phase}`;
      if (ph) {
        const phLine = card.querySelector<HTMLElement>('[data-role="phour"]');
        const glyph = phLine?.querySelector<HTMLElement>('span[aria-hidden="true"]');
        if (glyph) glyph.textContent = ph.glyph;
      }
    }
  }

  refresh();
  setInterval(refresh, 60_000);
</script>

<style>
  .clock-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 24px 96px;
    color: var(--pc-ink, #12110E);
  }

  .clock-head {
    border-bottom: 1px solid var(--pc-rule-soft, #E5E3DE);
    padding-bottom: 20px;
    margin-bottom: 28px;
  }

  .clock-head__kicker {
    font-family: var(--pc-font-mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ch-800);
    margin: 0 0 12px;
  }

  .clock-head__title {
    font-family: var(--pc-font-sans);
    font-size: 28px;
    font-weight: 500;
    line-height: 1.15;
    margin: 0 0 12px;
    color: var(--pc-ink, #12110E);
  }

  .clock-head__body {
    font-family: var(--pc-font-sans);
    font-size: 15px;
    line-height: 1.6;
    color: var(--pc-ink-soft, #38373A);
    max-width: 62ch;
    margin: 0 0 16px;
  }

  .clock-head__links {
    font-family: var(--pc-font-mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    color: var(--pc-ink-muted, #5F5E5A);
  }
  .clock-head__links a {
    color: var(--ch-800);
  }
  .clock-head__links span {
    opacity: 0.5;
  }

  .sky-ribbon {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 10px 18px;
    padding: 14px 16px;
    margin: 0 0 24px;
    border: 1px solid var(--ch-600);
    border-left-width: 4px;
    background: linear-gradient(180deg, #0B0E1F 0%, #181333 100%);
    color: #EDEAF7;
    border-radius: 2px;
  }
  .sky-ribbon__cell {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sky-ribbon__kicker {
    font-family: var(--pc-font-mono);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #8B85C3;
    margin: 0;
    font-weight: 500;
  }
  .sky-ribbon__value {
    font-family: var(--pc-font-sans);
    font-size: 13.5px;
    line-height: 1.35;
    margin: 0;
    color: #F5F2FC;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 4px;
  }
  .sky-ribbon__glyph {
    font-size: 16px;
    line-height: 1;
    margin-right: 4px;
  }
  .sky-ribbon__muted {
    color: #9A93D0;
    font-size: 12px;
  }

  .clock-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 14px;
  }

  .clock-card__sky {
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px dashed color-mix(in oklab, var(--ch-600) 22%, #fff);
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .sun-strip-wrap {
    margin-bottom: 4px;
  }
  .sun-strip {
    display: block;
    width: 100%;
    height: 22px;
    border-radius: 2px;
    overflow: hidden;
    box-shadow: inset 0 0 0 1px rgba(18, 17, 14, 0.15);
  }
  .sun-strip__labels {
    margin: 3px 0 0;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--pc-font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pc-ink-muted, #5F5E5A);
    gap: 6px;
  }
  .sun-strip__rise,
  .sun-strip__set {
    color: var(--ch-800);
    font-weight: 500;
  }
  .sun-strip__daylen {
    flex: 1;
    text-align: center;
    font-size: 8.5px;
    opacity: 0.7;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .clock-card__sky-line {
    font-family: var(--pc-font-mono);
    font-size: 10.5px;
