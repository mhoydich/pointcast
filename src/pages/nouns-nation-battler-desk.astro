---
/**
 * /nouns-nation-battler-desk - local season desk wall for Nouns Nation Battler.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: 'Nouns Nation Battler Desk Wall',
  description: 'A portable local host wall for Nouns Nation Battler Commissioner Desk reads, recap cards, run sheets, canonical shareable report card links, an in-session Report Gallery, downloadable Season Report cards, printable Season Reports, and snapshot links.',
  url: 'https://pointcast.xyz/nouns-nation-battler-desk/',
  inLanguage: 'en-US',
};
---

<BlockLayout
  title="Nouns Nation Battler Desk Wall"
  description="A portable season wall for Nouns Nation Battler hosts with saved Commissioner Desk reads, Recap Studio cards, a copyable run sheet, canonical shareable report card links, an in-session Report Gallery, downloadable Season Report cards, printable Season Reports, and snapshot links."
  image="/images/og/battle.png"
  jsonLd={jsonLd}
  frame={{
    image: 'https://pointcast.xyz/images/og/battle.png',
    buttons: [
      { label: 'Desk Wall', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-desk/' },
      { label: 'TV Cast', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-tv/' },
      { label: 'Game Room', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler/' },
      { label: 'Game JSON', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler.json' },
    ],
  }}
>
  <main class="desk-page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/nouns-nation-battler/">Nouns Nation Battler</a>
      <span aria-hidden="true">/</span>
      <span>Desk Wall</span>
    </nav>

    <section class="intro">
      <p class="kicker">CH.BTL / AUTO-BATTLER V30 CANONICAL CARD LINKS</p>
      <h1>Nouns Nation Battler Desk Wall</h1>
      <p>
        A portable host wall for the current browser or a shared snapshot link: saved Commissioner Desk reads,
        Recap Studio result cards, top-line season state, one copyable run sheet, a printable Season Report, canonical shareable card links, an in-session gallery, and downloadable 16:9 report cards for group chat, lunch review, or stream notes.
      </p>
      <div class="manifest-row">
        <a href="/games/nouns-nation-battler/desk/" target="_blank" rel="noreferrer">Open desk wall</a>
        <a href="/nouns-nation-battler/">Game room</a>
        <a href="/nouns-nation-battler-tv/" target="_blank" rel="noreferrer">TV Cast</a>
        <a href="/nouns-nation-battler-posters/">Poster Series</a>
      </div>
    </section>

    <section class="desk-frame" aria-label="Nouns Nation Battler local desk wall">
      <iframe src="/games/nouns-nation-battler/desk/" title="Nouns Nation Battler local desk wall" loading="eager"></iframe>
    </section>
  </main>
</BlockLayout>

<style>
  .desk-page {
    display: grid;
    gap: 18px;
  }

  .crumb,
  .manifest-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .crumb {
    color: var(--muted, #6c6254);
    font-size: 0.85rem;
    font-weight: 800;
  }

  .intro {
    max-width: 980px;
  }

  .kicker {
    margin: 0 0 8px;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 8px;
    font-size: clamp(2.6rem, 8vw, 6rem);
    line-height: 0.9;
    letter-spacing: 0;
  }

  .intro p {
    margin: 0;
    max-width: 840px;
    font-size: clamp(1rem, 2vw, 1.28rem);
    line-height: 1.45;
  }

  .manifest-row {
    margin-top: 16px;
  }

  .manifest-row a {
    border: 2px solid currentColor;
    padding: 8px 10px;
    font-weight: 850;
    text-decoration: none;
  }

  .desk-frame {
    min-height: 86vh;
    border: 3px solid currentColor;
    overflow: hidden;
    background: #f3ecdc;
  }

  .desk-frame iframe {
    width: 100%;
    min-height: 86vh;
    border: 0;
    display: block;
  }
</style>
