    /* v0.24: NIP-05 verification glyph. `ok` is moss, `mismatch` is
       oxblood so a malicious nip05 doesn't sneak past as "verified". */
    .sp-friends-verify {
      display: inline-block;
      margin-left: 4px;
      width: 14px; height: 14px; line-height: 14px;
      text-align: center;
      font-size: 10px; font-weight: 700;
