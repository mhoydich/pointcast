---
/**
 * /sparrow/friends — federated reading lists (v0.22).
 *
 * Pure client-rendered. Two halves:
 *
 *  · Top — a "publish my saved list publicly" toggle + a management
 *    UI for adding/removing friend pubkeys. Friends are stored as
 *    { pubkey: <64-hex>, alias?: string } in localStorage under
 *    `sparrow:friends`. Alias is optional — purely for the UI; it's
 *    never broadcast anywhere.
 *
 *  · Bottom — on load we REQ kind-30078 events with authors = friend
 *    pubkeys and #d = sparrow-public-saved-v1 from each configured
 *    relay. Each event's content is expected to be a JSON body
 *    matching { saved: { value: string[], updated_at }, profile?: {...} }.
 *    We take the newest event per author, resolve block ids to their
 *    title/channel via a server-shipped lookup, and render a grouped
 *    feed of their saved blocks.
 *
 * v0.22 is intentionally hex-only. npub1… (bech32) decode is a future
 * polish — Sparrow doesn't ship a bech32 helper yet, and pasting hex
 * is fine for the first users.
 */
import SparrowLayout from '../../layouts/SparrowLayout.astro';
import { getCollection } from 'astro:content';
import { CHANNEL_LIST } from '../../lib/channels';

const all = (await getCollection('blocks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

const lookup = Object.fromEntries(
  all.map((b) => [
    b.data.id,
    {
      id: b.data.id,
      title: b.data.title,
      dek: b.data.dek ?? '',
      channel: b.data.channel,
      type: b.data.type,
    },
  ]),
);
const channelNameByCode = Object.fromEntries(CHANNEL_LIST.map((c) => [c.code, c.name]));
---

<SparrowLayout
  title="Friends — federated reading lists"
  description="See what other Sparrow readers are saving. Opt-in on both sides."
  canonicalPath="/sparrow/friends"
  homeHref="/sparrow"
>
  <section class="sp-reel" aria-label="friends">
    <header class="sp-reel-head">
      <span class="sp-kicker">✦ friends · federated reading lists</span>
      <span class="sp-aside-mono" style="margin-left: auto;">
        <span data-sp-friends-count>0</span> following ·
        <span data-sp-friends-state>needs a NIP-07 signer</span>
      </span>
    </header>

    <p class="sp-about-dek" style="margin: 4px 0 18px;">
      Sparrow v0.22 opens a narrow two-way door: opt in to publish
      <em>just your saved list</em> as a public Nostr event, and/or
      subscribe to someone else's by pasting their pubkey. Everything
      else — visited state, reactions, private sync — stays private.
    </p>

    <div class="sp-friends-getting-started" data-sp-gs aria-label="getting started checklist">
      <header class="sp-friends-gs-head">
        <span class="sp-friends-kicker">✦ join the federation</span>
        <span class="sp-friends-gs-meta" data-sp-gs-meta>0 of 4 steps done</span>
      </header>
      <ol class="sp-friends-gs-list" data-sp-gs-list>
        <li data-sp-gs-step="signer"><span class="sp-friends-gs-tick">○</span> <strong>Connect a NIP-07 signer</strong> — install Alby or nos2x, then click the <em>sync</em> pill in the HUD</li>
        <li data-sp-gs-step="public"><span class="sp-friends-gs-tick">○</span> <strong>Turn on "publish my saved list publicly"</strong> below so friends can find what you're reading</li>
        <li data-sp-gs-step="follow"><span class="sp-friends-gs-tick">○</span> <strong>Follow at least one npub</strong> — paste a hex pubkey or npub1… into the form further down (or try the starters)</li>
        <li data-sp-gs-step="ambient"><span class="sp-friends-gs-tick">○</span> <strong>(Optional) Enable ambient presence</strong> so friends see you're reading in the bottom-left strip</li>
      </ol>
    </div>

    <div class="sp-friends-invite" data-sp-invite aria-label="invite friends" hidden>
      <header class="sp-friends-gs-head">
        <span class="sp-friends-kicker">✦ invite others</span>
        <span class="sp-friends-gs-meta">one-click follow link</span>
      </header>
      <p class="sp-friends-publisher-hint" style="margin:0 0 8px;">
        Share this URL. When someone opens it in Sparrow, the add-friend form
        pre-fills with your pubkey — they just click <em>follow →</em>.
      </p>
      <div class="sp-friends-invite-row">
        <input type="text" data-sp-invite-url readonly />
        <button type="button" class="sp-friends-invite-copy" data-sp-invite-copy>copy</button>
      </div>
    </div>

    <div class="sp-friends-starters" data-sp-starters aria-label="starter pubkeys">
      <header class="sp-friends-gs-head">
        <span class="sp-friends-kicker">✦ starters · suggested follows</span>
        <span class="sp-friends-gs-meta">scaffold · edit <code>STARTERS</code> to curate</span>
      </header>
      <ul class="sp-friends-starters-list" data-sp-starters-list></ul>
    </div>

    <div class="sp-friends-publisher" data-sp-publisher aria-label="publisher controls">
      <span class="sp-friends-kicker">✦ my public saved list</span>
      <label class="sp-friends-toggle">
        <input type="checkbox" data-sp-public-saved-toggle />
        <span class="sp-friends-toggle-label">publish my saved list publicly</span>
      </label>
      <p class="sp-friends-publisher-hint" data-sp-publisher-hint>
        Off. Your saved list stays on this device (plus any peer-node /
        private sync channels you've enabled).
      </p>
      <p class="sp-friends-publisher-hint sp-friends-publisher-sig" data-sp-publisher-sig hidden>
        Events signed by <code data-sp-self-npub>…</code> ·
        d-tag <code>sparrow-public-saved-v1</code> · kind <code>30078</code>
      </p>
      <label class="sp-friends-toggle sp-friends-toggle-sub">
        <input type="checkbox" data-sp-chime-toggle />
        <span class="sp-friends-toggle-label">chime when a friend saves something</span>
      </label>
      <p class="sp-friends-publisher-hint">
        Off by default. Plays a soft two-note tone (Web Audio, no
        asset) when a live "just saved" toast lands. Toasts appear
        regardless — muting this just silences them.
      </p>
      <label class="sp-friends-toggle sp-friends-toggle-sub">
        <input type="checkbox" data-sp-ambient-toggle />
        <span class="sp-friends-toggle-label">ambient presence — broadcast "I'm here now"</span>
      </label>
      <p class="sp-friends-publisher-hint">
        Off by default. Publishes an ephemeral <code>kind 20078</code>
        event every 60s while this tab is foregrounded, so followed
        signers know you're reading. Relays don't store these; they
        disappear the moment you close the tab. Bottom-left strip
        shows friends who are here right now.
      </p>
    </div>

    <div class="sp-friends-manage" data-sp-manage aria-label="following">
      <span class="sp-friends-kicker">✦ people I'm following</span>
      <form class="sp-friends-form" data-sp-friends-form>
        <label>
          <span>pubkey (hex or npub1…)</span>
          <input
            type="text"
            name="pubkey"
            autocomplete="off"
            spellcheck="false"
            placeholder="3bf0c63f… or npub1…"
            required
          />
        </label>
        <label>
          <span>alias (optional)</span>
          <input
            type="text"
            name="alias"
            autocomplete="off"
            maxlength="40"
            placeholder="e.g. mhoydich"
          />
        </label>
        <button type="submit">follow →</button>
      </form>
      <ul class="sp-friends-list" data-sp-friends-list></ul>
      <p class="sp-friends-empty" data-sp-friends-empty>
        Nobody followed yet. Add a pubkey above to start pulling their public saved lists.
      </p>
      <div class="sp-friends-opml">
        <span class="sp-friends-kicker">✦ opml · federation portability</span>
        <div class="sp-friends-opml-row">
          <button type="button" class="sp-friends-opml-btn" data-sp-opml-friends-export>export friends ↓</button>
          <label class="sp-friends-opml-btn">
            <input type="file" accept=".opml,.xml,application/xml,text/xml" data-sp-opml-friends-import hidden />
            import ↑
          </label>
          <span class="sp-friends-opml-status" data-sp-opml-friends-status></span>
        </div>
      </div>
    </div>

    <div class="sp-friends-feed" data-sp-friends-feed aria-label="their reading">
      <header class="sp-friends-feed-head">
        <span class="sp-friends-kicker">✦ what they're reading</span>
        <span class="sp-friends-feed-ctas">
          <a href="/sparrow/signals" class="sp-friends-activity-cta">
            <span aria-hidden="true">✦</span> signals recap
          </a>
          <a href="/sparrow/friends/activity" class="sp-friends-activity-cta">
            <span aria-hidden="true">⟶</span> activity timeline
          </a>
        </span>
      </header>
      <div class="sp-friends-feed-body" data-sp-friends-feed-body></div>
      <p class="sp-friends-feed-empty" data-sp-friends-feed-empty>
        Nothing to show yet. When you follow someone who's opted to
        publish their saved list, their receipts land here.
      </p>
    </div>
  </section>

  <script id="sp-friends-lookup" type="application/json" set:html={JSON.stringify({ lookup, channelNameByCode })} />

  <script is:inline>
    // Client-side controller for /sparrow/friends.
    //
    // Everything here hangs off localStorage + the Nostr relay pool.
    // We reuse the relay list from the main SparrowLayout via
    // `sparrow:nostr-relays` (falls back to the same default pool:
    // damus + primal + nos.lol). We do NOT re-implement NIP-07 connect
    // flow — the HUD sync pill already owns that; when it's lit, the
    // self-pubkey is in `sparrow:nostr-pubkey`.

    (function () {
      const KEY_FRIENDS          = 'sparrow:friends';
      const KEY_PUBLIC_SAVED     = 'sparrow:public-saved-enabled';
      const KEY_SELF_PUBKEY      = 'sparrow:nostr-pubkey';
      const KEY_RELAYS           = 'sparrow:nostr-relays';
      const KEY_PROFILES         = 'sparrow:profiles';
      const D_TAG                = 'sparrow-public-saved-v1';
      const SYNC_KIND            = 30078;
      const PROFILE_KIND         = 0;                 // NIP-01 kind-0 metadata
      const PROFILE_TTL_MS       = 24 * 60 * 60 * 1000; // 24h cache
      const DEFAULT_RELAYS = [
        'wss://relay.damus.io',
        'wss://relay.primal.net',
        'wss://nos.lol',
      ];

      // ─── v0.23 · NIP-19 bech32 (npub1…) ──────────────────────────
      // Self-contained bech32 codec so users can paste npub1… from
      // any Nostr client into the friends form, and we can render the
      // HUD self-pubkey as a short npub1 instead of hex. Follows BIP-173.
      const BECH32_ALPHABET = 'qpzry9x8gf2tvdw0s3jn54khce6mua7l';
      const BECH32_CHARMAP = {};
      for (let i = 0; i < BECH32_ALPHABET.length; i++) BECH32_CHARMAP[BECH32_ALPHABET[i]] = i;

      function bech32Polymod(values) {
        const GEN = [0x3b6a57b2, 0x26508e6d, 0x1ea119fa, 0x3d4233dd, 0x2a1462b3];
        let chk = 1;
        for (const v of values) {
          const top = chk >>> 25;
          chk = ((chk & 0x1ffffff) << 5) ^ v;
          for (let i = 0; i < 5; i++) if ((top >>> i) & 1) chk ^= GEN[i];
        }
        return chk;
      }
      function bech32HrpExpand(hrp) {
        const out = [];
        for (let i = 0; i < hrp.length; i++) out.push(hrp.charCodeAt(i) >>> 5);
        out.push(0);
        for (let i = 0; i < hrp.length; i++) out.push(hrp.charCodeAt(i) & 31);
        return out;
      }
      function bech32Verify(hrp, data) {
        return bech32Polymod(bech32HrpExpand(hrp).concat(data)) === 1;
      }
      function bech32Decode(str) {
        if (typeof str !== 'string') return null;
        str = str.toLowerCase();
        const pos = str.lastIndexOf('1');
        if (pos < 1 || pos + 7 > str.length || str.length > 90) return null;
        const hrp = str.substring(0, pos);
        const dataPart = str.substring(pos + 1);
        const data = [];
        for (const c of dataPart) {
          const v = BECH32_CHARMAP[c];
          if (v === undefined) return null;
          data.push(v);
        }
        if (!bech32Verify(hrp, data)) return null;
        return { hrp, data: data.slice(0, -6) };
      }
      function convertBits(data, fromBits, toBits, pad) {
        let acc = 0, bits = 0;
        const out = [];
        const maxv = (1 << toBits) - 1;
        for (const v of data) {
          if (v < 0 || (v >>> fromBits) !== 0) return null;
          acc = (acc << fromBits) | v;
          bits += fromBits;
          while (bits >= toBits) {
            bits -= toBits;
            out.push((acc >>> bits) & maxv);
          }
        }
        if (pad) { if (bits > 0) out.push((acc << (toBits - bits)) & maxv); }
        else if (bits >= fromBits || ((acc << (toBits - bits)) & maxv)) return null;
        return out;
      }
      function bech32CreateChecksum(hrp, data) {
        const values = bech32HrpExpand(hrp).concat(data).concat([0, 0, 0, 0, 0, 0]);
        const polymod = bech32Polymod(values) ^ 1;
        const out = [];
        for (let i = 0; i < 6; i++) out.push((polymod >>> (5 * (5 - i))) & 31);
        return out;
      }
      function bech32Encode(hrp, data) {
        const combined = data.concat(bech32CreateChecksum(hrp, data));
        let out = hrp + '1';
        for (const v of combined) out += BECH32_ALPHABET[v];
        return out;
      }

      // Public helpers. Return hex|npub string, or null on any failure.
      function npubToHex(npub) {
        if (typeof npub !== 'string') return null;
        const s = npub.trim().toLowerCase();
        if (!s.startsWith('npub1')) return null;
        const decoded = bech32Decode(s);
        if (!decoded || decoded.hrp !== 'npub') return null;
        const bytes = convertBits(decoded.data, 5, 8, false);
        if (!bytes || bytes.length !== 32) return null;
        return bytes.map((b) => b.toString(16).padStart(2, '0')).join('');
      }
      function hexToNpub(hex) {
        if (!/^[0-9a-f]{64}$/i.test(hex)) return null;
        const h = hex.toLowerCase();
        const bytes = [];
        for (let i = 0; i < h.length; i += 2) bytes.push(parseInt(h.substring(i, i + 2), 16));
        const words = convertBits(bytes, 8, 5, true);
        if (!words) return null;
        return bech32Encode('npub', words);
      }
      // Accept either hex-64 or npub1…; return normalized hex or null.
      function parsePubkey(input) {
        const raw = String(input || '').trim();
        if (/^[0-9a-f]{64}$/i.test(raw)) return raw.toLowerCase();
        if (raw.toLowerCase().startsWith('npub1')) return npubToHex(raw);
        return null;
      }

      const lookupBlob = document.getElementById('sp-friends-lookup');
      const state = lookupBlob ? JSON.parse(lookupBlob.textContent || '{}') : { lookup: {}, channelNameByCode: {} };
      const { lookup, channelNameByCode } = state;

      const readFriends = () => {
        try {
          const raw = JSON.parse(localStorage.getItem(KEY_FRIENDS) || '[]');
          if (!Array.isArray(raw)) return [];
          return raw
            .map((f) => (typeof f === 'string'
              ? { pubkey: f, alias: '', muted: false }
              : (f && typeof f === 'object' && typeof f.pubkey === 'string')
                ? {
                    pubkey: f.pubkey.toLowerCase(),
                    alias:  (f.alias || '').slice(0, 40),
                    muted:  !!f.muted,
                  }
                : null))
            .filter((f) => f && /^[0-9a-f]{64}$/.test(f.pubkey));
        } catch { return []; }
      };
      const writeFriends = (list) => {
        try { localStorage.setItem(KEY_FRIENDS, JSON.stringify(list)); } catch {}
      };
      const getRelays = () => {
        try {
          const raw = localStorage.getItem(KEY_RELAYS);
          const list = raw ? JSON.parse(raw) : null;
          if (Array.isArray(list) && list.length) {
            return list.filter((u) => typeof u === 'string' && u.startsWith('ws'));
          }
        } catch {}
        return DEFAULT_RELAYS;
      };

      const hasNip07 = () =>
        typeof window !== 'undefined'
        && !!window.nostr
        && typeof window.nostr.signEvent === 'function';

      const shortPk = (pk) => (pk ? `${pk.slice(0, 8)}…${pk.slice(-4)}` : '—');

      // ─── DOM refs ─────────────────────────────────────────────────
      const countEl         = document.querySelector('[data-sp-friends-count]');
      const stateEl         = document.querySelector('[data-sp-friends-state]');
      const listEl          = document.querySelector('[data-sp-friends-list]');
      const emptyEl         = document.querySelector('[data-sp-friends-empty]');
      const form            = document.querySelector('[data-sp-friends-form]');
      const pubToggle       = document.querySelector('[data-sp-public-saved-toggle]');
      const pubHint         = document.querySelector('[data-sp-publisher-hint]');
      const pubSig          = document.querySelector('[data-sp-publisher-sig]');
      const pubSigNpub      = document.querySelector('[data-sp-self-npub]');
      const feedBody        = document.querySelector('[data-sp-friends-feed-body]');
      const feedEmpty       = document.querySelector('[data-sp-friends-feed-empty]');

      // ─── UI rendering ─────────────────────────────────────────────
      function paintState() {
        const friends = readFriends();
        const selfPk  = (localStorage.getItem(KEY_SELF_PUBKEY) || '').toLowerCase();
        const selfNpub = selfPk ? hexToNpub(selfPk) : null;
        const selfDisplay = selfNpub ? `${selfNpub.slice(0, 12)}…${selfNpub.slice(-4)}` : shortPk(selfPk);
        if (countEl) countEl.textContent = String(friends.length);
        if (stateEl) {
          stateEl.textContent = hasNip07()
            ? (selfPk ? `signed in · ${selfDisplay}` : 'signer detected · open the HUD pill to connect')
            : 'needs a NIP-07 signer';
        }
        if (pubSigNpub && selfPk) pubSigNpub.textContent = selfDisplay;
        if (pubToggle) pubToggle.checked = localStorage.getItem(KEY_PUBLIC_SAVED) === '1';
        if (pubHint) {
          pubHint.textContent = pubToggle?.checked
            ? 'On. Every save/unsave re-publishes a kind-30078 addressable event carrying just the saved ids. The event replaces the previous one on every relay — no garbage pile.'
            : 'Off. Your saved list stays on this device (plus any peer-node / private sync channels you\'ve enabled).';
        }
        if (pubSig) pubSig.hidden = !(pubToggle?.checked && selfPk);
      }

      function paintFriendsList() {
        const friends = readFriends();
        if (!listEl) return;
        listEl.innerHTML = '';
        if (emptyEl) emptyEl.hidden = friends.length > 0;
        for (const f of friends) {
          // Prefer local alias, fall back to kind-0 profile name.
          const prof = profileFor(f.pubkey);
          const profName = profileName(f.pubkey);
          const displayName = f.alias || profName || '';
          const aliasSource = f.alias ? 'local' : (profName ? 'nostr' : 'none');
          const npubShort = (hexToNpub(f.pubkey) || f.pubkey).slice(0, 14) + '…';
          // v0.24: NIP-05 verified checkmark. `verifiedStateFor` returns
          // "ok" (verified, pubkey matched), "mismatch" (resolved but
          // different pubkey — suspicious), "pending" (in-flight),
          // "unchecked" (no nip05 / never fetched).
          const v = verifiedStateFor(f.pubkey);
          const verifyGlyph =
            v === 'ok'       ? '<span class="sp-friends-verify is-ok" title="NIP-05 resolves to this pubkey">✓</span>'
          : v === 'mismatch' ? '<span class="sp-friends-verify is-bad" title="NIP-05 points to a different pubkey">!</span>'
          : v === 'pending'  ? '<span class="sp-friends-verify is-pending" title="verifying NIP-05…">…</span>'
          :                    '';
          // v0.24: picture thumbnail. Lazy-loaded, CSP-safe (https-only
          // allowed via profile storage filter), onerror-hidden so a
          // 404 thumbnail doesn't leave a broken-image glyph.
          const pictureHTML = prof?.picture
            ? `<img
                class="sp-friends-pic"
                src="${escapeHTML(prof.picture)}"
                alt=""
                loading="lazy"
                referrerpolicy="no-referrer"
                decoding="async"
                onerror="this.style.display='none'"
              />`
            : `<span class="sp-friends-pic sp-friends-pic-placeholder" aria-hidden="true">✦</span>`;
          const li = document.createElement('li');
          li.className = 'sp-friends-row' + (f.muted ? ' is-muted' : '');
          li.innerHTML = `
            ${pictureHTML}
            <span class="sp-friends-pk">
              ${displayName ? `<strong>${escapeHTML(displayName)}</strong>` : ''}
              ${displayName && aliasSource === 'nostr' ? '<span class="sp-friends-src" title="name pulled from NIP-01 kind-0 profile">🛰</span>' : ''}
              ${displayName ? ' · ' : ''}
              <code title="${f.pubkey}">${escapeHTML(npubShort)}</code>
              ${prof?.nip05 ? `<span class="sp-friends-nip05">${escapeHTML(prof.nip05)}${verifyGlyph}</span>` : ''}
              ${f.muted ? '<span class="sp-friends-muted-tag">muted</span>' : ''}
            </span>
            <span class="sp-friends-row-actions">
              <button
                type="button"
                class="sp-friends-mute"
                data-sp-mute="${f.pubkey}"
                aria-pressed="${f.muted ? 'true' : 'false'}"
                title="${f.muted ? 'unmute — resume showing saves from this friend' : 'mute — keep following but hide saves from the lane / feed / toasts'}"
              >${f.muted ? '🔇 unmute' : '🔈 mute'}</button>
              <button type="button" class="sp-friends-unfollow" data-pubkey="${f.pubkey}">unfollow</button>
            </span>
          `;
          listEl.appendChild(li);
        }
      }

      function escapeHTML(s) {
        return (s || '').replace(/[&<>"']/g, (c) => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
        }[c]));
      }

      // ─── Form handling ────────────────────────────────────────────
      form?.addEventListener('submit', (e) => {
        e.preventDefault();
        const fd = new FormData(form);
        const raw    = String(fd.get('pubkey') || '').trim();
        const alias  = String(fd.get('alias')  || '').trim().slice(0, 40);
        const pubkey = parsePubkey(raw);
        const input  = form.querySelector('input[name="pubkey"]');
        if (!pubkey) {
          // Nudge the user: bad hex or bad npub1 checksum.
          if (input) {
            input.setCustomValidity('Need 64 hex chars or a valid npub1…');
            input.reportValidity();
            setTimeout(() => input.setCustomValidity(''), 1500);
          }
          return;
        }
        if (input) input.setCustomValidity('');
        const friends = readFriends();
        if (!friends.some((f) => f.pubkey === pubkey)) {
          friends.unshift({ pubkey, alias });
          writeFriends(friends);
        } else if (alias) {
          // Update alias on an already-followed friend.
          for (const f of friends) if (f.pubkey === pubkey) f.alias = alias;
          writeFriends(friends);
        }
        form.reset();
        paintFriendsList();
        paintState();
        subscribeToFriends();
        refreshProfiles();
      });

      listEl?.addEventListener('click', (e) => {
        const mute = e.target.closest('[data-sp-mute]');
        if (mute) {
          const pubkey = mute.getAttribute('data-sp-mute');
          const list = readFriends();
          for (const f of list) {
            if (f.pubkey === pubkey) f.muted = !f.muted;
          }
          writeFriends(list);
          paintFriendsList();
          repaintFeed();
          return;
        }
        const btn = e.target.closest('[data-sp--unfollow], .sp-friends-unfollow');
        if (!btn) return;
        const pubkey = btn.getAttribute('data-pubkey');
        if (!pubkey) return;
        writeFriends(readFriends().filter((f) => f.pubkey !== pubkey));
        paintFriendsList();
        paintState();
        repaintFeed(); // drop any rendered cards from the removed author
      });

      pubToggle?.addEventListener('change', () => {
        try { localStorage.setItem(KEY_PUBLIC_SAVED, pubToggle.checked ? '1' : '0'); } catch {}
        paintState();
      });

      // v0.26: chime opt-in. Cheap — just a localStorage flag the
      // SparrowLayout watcher reads on each toast.
      const chimeToggle = document.querySelector('[data-sp-chime-toggle]');
      if (chimeToggle) {
        chimeToggle.checked = localStorage.getItem('sparrow:friends-chime-enabled') === '1';
        chimeToggle.addEventListener('change', () => {
          try { localStorage.setItem('sparrow:friends-chime-enabled', chimeToggle.checked ? '1' : '0'); } catch {}
        });
      }

      // v0.30: ambient presence opt-in. Writing the flag takes effect
      // at the next page load (SparrowLayout wires its presence timer
      // at boot; enabling mid-session just means we don't broadcast
      // until a reload, which is intentional — explicit user opt-in
      // per session-boundary).
      const ambientToggle = document.querySelector('[data-sp-ambient-toggle]');
      if (ambientToggle) {
        ambientToggle.checked = localStorage.getItem('sparrow:ambient-enabled') === '1';
        ambientToggle.addEventListener('change', () => {
          try { localStorage.setItem('sparrow:ambient-enabled', ambientToggle.checked ? '1' : '0'); } catch {}
        });
      }

      // ─── Feed subscription ────────────────────────────────────────
      // Per-author newest kind-30078 event under #d = sparrow-public-saved-v1.
      const newestByAuthor = new Map(); // pubkey -> { created_at, body, event_id }
      const openSockets    = [];

      function subscribeToFriends() {
        // Non-muted friends only drive the subscription authors list;
        // muted entries are kept in sparrow:friends so users don't lose
        // them, but no relay cycles spent fetching their events.
        const friends = readFriends().filter((f) => !f.muted);
        if (!friends.length) { repaintFeed(); return; }
        const relays = getRelays();
        const subId  = `sp-fr-${Math.random().toString(36).slice(2, 10)}`;
        const authors = friends.map((f) => f.pubkey);
        const filter = { kinds: [SYNC_KIND], authors, '#d': [D_TAG], limit: authors.length * 2 };

        for (const url of relays) {
          try {
            const ws = new WebSocket(url);
            openSockets.push(ws);
            ws.addEventListener('open', () => {
              try { ws.send(JSON.stringify(['REQ', subId, filter])); } catch {}
            });
            ws.addEventListener('message', (msg) => {
              let frame;
              try { frame = JSON.parse(msg.data); } catch { return; }
              if (!Array.isArray(frame)) return;
              if (frame[0] === 'EVENT' && frame[1] === subId && frame[2]) {
                ingestEvent(frame[2]);
              } else if (frame[0] === 'EOSE' && frame[1] === subId) {
                try { ws.send(JSON.stringify(['CLOSE', subId])); } catch {}
                try { ws.close(); } catch {}
                repaintFeed();
              }
            });
            setTimeout(() => { try { if (ws.readyState <= 1) ws.close(); } catch {} }, 8000);
          } catch {}
        }
        // Best-effort: repaint after a brief delay even if no EOSE lands.
        setTimeout(repaintFeed, 2500);
      }

      function ingestEvent(ev) {
        if (!ev || ev.kind !== SYNC_KIND || typeof ev.content !== 'string') return;
        if (typeof ev.pubkey !== 'string' || typeof ev.created_at !== 'number') return;
        // Confirm d-tag (relay may be permissive).
        const isOurs = Array.isArray(ev.tags) && ev.tags.some(
          (t) => Array.isArray(t) && t[0] === 'd' && t[1] === D_TAG,
        );
        if (!isOurs) return;

        let body;
        try { body = JSON.parse(ev.content); } catch { return; }
        if (!body || typeof body !== 'object') return;
        const savedValue = body?.saved?.value;
        if (!Array.isArray(savedValue)) return;

        const prior = newestByAuthor.get(ev.pubkey);
        if (!prior || ev.created_at > prior.created_at) {
          newestByAuthor.set(ev.pubkey, {
            created_at: ev.created_at,
            event_id:   ev.id,
            body,
          });
        }
      }

      function repaintFeed() {
        if (!feedBody) return;
        feedBody.innerHTML = '';
        const friends = readFriends();
        // Muted friends stay in the manage list but never render a
        // card here. The subscription above also skips them so no
        // relay data is wasted on muted authors.
        const active = friends.filter((f) => !f.muted);
        const followed = new Set(active.map((f) => f.pubkey));
        const rows = active
          .map((f) => ({ friend: f, entry: newestByAuthor.get(f.pubkey) }))
          .filter((x) => x.entry && followed.has(x.friend.pubkey));

        if (feedEmpty) feedEmpty.hidden = rows.length > 0;

        for (const { friend, entry } of rows) {
          const savedIds = (entry.body?.saved?.value || []).filter((id) => typeof id === 'string');
          const updatedAt = entry.body?.saved?.updated_at || '';
          const profName  = profileName(friend.pubkey);
          const displayName = friend.alias || profName || '';
          const prof = profileFor(friend.pubkey);
          const v = verifiedStateFor(friend.pubkey);
          const verifyGlyph =
            v === 'ok'       ? ' <span class="sp-friends-verify is-ok" title="NIP-05 verified">✓</span>'
          : v === 'mismatch' ? ' <span class="sp-friends-verify is-bad" title="NIP-05 mismatch">!</span>'
          :                    '';
          const pictureHTML = prof?.picture
            ? `<img class="sp-friends-pic sp-friends-pic-sm" src="${escapeHTML(prof.picture)}" alt="" loading="lazy" referrerpolicy="no-referrer" decoding="async" onerror="this.style.display='none'" />`
            : '';
          const card = document.createElement('article');
          card.className = 'sp-friends-card';
          const header = document.createElement('header');
          header.className = 'sp-friends-card-head';
          header.innerHTML = `
            <span class="sp-friends-card-name">
              ${pictureHTML}
              ${displayName ? `<strong>${escapeHTML(displayName)}</strong>${verifyGlyph} · ` : ''}
              <code title="${friend.pubkey}">${shortPk(friend.pubkey)}</code>
            </span>
            <span class="sp-friends-card-meta">
              ${savedIds.length} saved
              ${updatedAt ? ` · updated ${escapeHTML(String(updatedAt).slice(0, 10))}` : ''}
            </span>
          `;
          card.appendChild(header);

          const list = document.createElement('ul');
          list.className = 'sp-friends-blocks';
          const rendered = savedIds.slice(0, 24);
          for (const id of rendered) {
            const meta = lookup[id];
            const li = document.createElement('li');
            if (meta) {
              const channelName = channelNameByCode[meta.channel] || meta.channel;
              li.innerHTML = `
                <a href="/sparrow/b/${meta.id}" class="sp-friends-block-link">
                  <span class="sp-friends-block-id">№ ${meta.id}</span>
                  <span class="sp-friends-block-title">${escapeHTML(meta.title || '—')}</span>
                  <span class="sp-friends-block-chip">${escapeHTML(channelName)}</span>
                </a>
              `;
            } else {
              li.innerHTML = `
                <a href="/sparrow/b/${id}" class="sp-friends-block-link is-unknown">
                  <span class="sp-friends-block-id">№ ${id}</span>
                  <span class="sp-friends-block-title"><em>unknown block · not in this Sparrow build</em></span>
                </a>
              `;
            }
            list.appendChild(li);
          }
          card.appendChild(list);

          if (savedIds.length > rendered.length) {
            const more = document.createElement('p');
            more.className = 'sp-friends-more';
            more.textContent = `+ ${savedIds.length - rendered.length} more`;
            card.appendChild(more);
          }
          feedBody.appendChild(card);
        }
      }

      // ─── v0.23 · NIP-01 kind-0 profile lookup ─────────────────────
      // Best-effort metadata hydration. Cache is a flat map
      //   { [hex]: { name?, display_name?, picture?, nip05?, fetched_at } }
      // in sparrow:profiles. TTL 24h so repeat visits avoid the relay
      // round-trip. Profiles never mutate our outbound events — they
      // are purely for the friends UI (name autofill, display tweaks).
      const readProfiles = () => {
        try {
          const raw = JSON.parse(localStorage.getItem(KEY_PROFILES) || '{}');
          return (raw && typeof raw === 'object' && !Array.isArray(raw)) ? raw : {};
        } catch { return {}; }
      };
      const writeProfiles = (map) => {
        try { localStorage.setItem(KEY_PROFILES, JSON.stringify(map)); } catch {}
      };

      function profileFor(pubkey) {
        const map = readProfiles();
        const p = map[pubkey];
        if (!p || typeof p !== 'object') return null;
        return p;
      }

      function profileName(pubkey) {
        const p = profileFor(pubkey);
        if (!p) return null;
        return (typeof p.display_name === 'string' && p.display_name.trim())
          || (typeof p.name === 'string' && p.name.trim())
          || null;
      }

      // Fresh if fetched within TTL; we still re-fetch on page load to
      // pick up name changes, but only show the "loading" state on
      // truly cold entries so the UI doesn't flicker.
      function profileIsFresh(pubkey) {
        const p = profileFor(pubkey);
        return !!(p && p.fetched_at && Date.now() - p.fetched_at < PROFILE_TTL_MS);
      }

      function refreshProfiles() {
        const friends = readFriends();
        if (!friends.length) return;
        const relays = getRelays();
        const subId  = `sp-pr-${Math.random().toString(36).slice(2, 10)}`;
        const authors = friends.map((f) => f.pubkey);
        const filter = { kinds: [PROFILE_KIND], authors, limit: authors.length };

        // Track newest kind-0 per author (relays return a few older
        // copies; we want the freshest metadata).
        const newestByAuthor = new Map();

        for (const url of relays) {
          try {
            const ws = new WebSocket(url);
            openSockets.push(ws);
            ws.addEventListener('open', () => {
              try { ws.send(JSON.stringify(['REQ', subId, filter])); } catch {}
            });
            ws.addEventListener('message', (msg) => {
              let frame;
              try { frame = JSON.parse(msg.data); } catch { return; }
              if (!Array.isArray(frame)) return;
              if (frame[0] === 'EVENT' && frame[1] === subId && frame[2]) {
                const ev = frame[2];
                if (typeof ev.content !== 'string' || typeof ev.pubkey !== 'string') return;
                if (typeof ev.created_at !== 'number') return;
                const prior = newestByAuthor.get(ev.pubkey);
                if (!prior || ev.created_at > prior.created_at) {
                  newestByAuthor.set(ev.pubkey, ev);
                }
              } else if (frame[0] === 'EOSE' && frame[1] === subId) {
                try { ws.send(JSON.stringify(['CLOSE', subId])); } catch {}
                try { ws.close(); } catch {}
                commitProfiles(newestByAuthor);
              }
            });
            setTimeout(() => { try { if (ws.readyState <= 1) ws.close(); } catch {} }, 6000);
          } catch {}
        }
        // Safety repaint if no EOSE lands within 3s.
        setTimeout(() => commitProfiles(newestByAuthor), 3000);
      }

      function commitProfiles(newestByAuthor) {
        if (!newestByAuthor || !newestByAuthor.size) return;
        const map = readProfiles();
        let changed = false;
        const needVerify = [];
        for (const [pubkey, ev] of newestByAuthor) {
          let content;
          try { content = JSON.parse(ev.content); } catch { continue; }
          if (!content || typeof content !== 'object') continue;
          // Preserve existing nip05_verified state when the nip05
          // string hasn't changed — no reason to re-check twice.
          const prior = map[pubkey] || {};
          const nextNip05 = typeof content.nip05 === 'string' ? content.nip05.slice(0, 120) : undefined;
          const nip05Changed = (prior.nip05 || '') !== (nextNip05 || '');
          const next = {
            name:         typeof content.name === 'string' ? content.name.slice(0, 80) : undefined,
            display_name: typeof content.display_name === 'string' ? content.display_name.slice(0, 80) : undefined,
            picture:      typeof content.picture === 'string' && /^https?:\/\//i.test(content.picture) ? content.picture.slice(0, 400) : undefined,
            nip05:        nextNip05,
            nip05_verified:  nip05Changed ? undefined : prior.nip05_verified,
            nip05_verified_at: nip05Changed ? undefined : prior.nip05_verified_at,
            fetched_at:   Date.now(),
          };
          map[pubkey] = next;
          changed = true;
          if (next.nip05 && (nip05Changed || !verifiedStateFreshByProfile(next))) {
            needVerify.push({ pubkey, nip05: next.nip05 });
          }
        }
        if (changed) {
          writeProfiles(map);
          paintFriendsList();
          repaintFeed();
          paintState();
        }
        // Kick off NIP-05 verifications for anyone with a nip05 that's
        // new or stale. Runs parallel, each independent.
        for (const { pubkey, nip05 } of needVerify) {
          verifyNip05(pubkey, nip05).catch(() => {});
        }
      }

      // ─── v0.24 · NIP-05 verification ──────────────────────────────
      // Resolve `<user>@<domain>` via `https://<domain>/.well-known/nostr.json?name=<user>`
      // and confirm that the claimed nip05 points back at this pubkey.
      // Result ("ok" | "mismatch" | "pending" | "unchecked") is cached
      // on the profile record with a 7-day TTL. `fetch` is same-origin
      // cache-friendly (GET, no credentials); non-2xx / parse errors /
      // CORS failures all land as "mismatch" so an unreachable verifier
      // doesn't masquerade as verified.
      const NIP05_VERIFY_TTL_MS = 7 * 24 * 60 * 60 * 1000;

      function verifiedStateFreshByProfile(prof) {
        return !!(prof && prof.nip05_verified_at && Date.now() - prof.nip05_verified_at < NIP05_VERIFY_TTL_MS);
      }

      function verifiedStateFor(pubkey) {
        const prof = profileFor(pubkey);
        if (!prof || !prof.nip05) return 'unchecked';
        if (typeof prof.nip05_verified === 'boolean' && verifiedStateFreshByProfile(prof)) {
          return prof.nip05_verified ? 'ok' : 'mismatch';
        }
        if (prof.nip05_verify_in_flight) return 'pending';
        return 'unchecked';
      }

      async function verifyNip05(pubkey, nip05) {
        // nip05 shape: "<localpart>@<domain>" (or bare "domain" → "_@domain")
        const m = /^([^@]+)@([^@]+)$/.exec(nip05)
          || (/^[^@]+$/.test(nip05) ? [null, '_', nip05] : null);
        if (!m) {
          markVerify(pubkey, false);
          return;
        }
        const [, user, domain] = m;
        if (!/^[a-z0-9._-]+$/i.test(user) || !/^[a-z0-9.-]+\.[a-z]{2,}$/i.test(domain)) {
          markVerify(pubkey, false);
          return;
        }
        markVerifyPending(pubkey);
        const url = `https://${domain}/.well-known/nostr.json?name=${encodeURIComponent(user)}`;
        try {
          const r = await fetch(url, { method: 'GET', cache: 'force-cache' });
          if (!r.ok) { markVerify(pubkey, false); return; }
          const body = await r.json();
          const names = body && typeof body === 'object' ? body.names : null;
          const reported = names && typeof names === 'object' ? names[user] : null;
          const ok = typeof reported === 'string' && reported.toLowerCase() === pubkey.toLowerCase();
          markVerify(pubkey, ok);
        } catch {
          markVerify(pubkey, false);
        }
      }

      function markVerifyPending(pubkey) {
        const map = readProfiles();
        const prof = map[pubkey] || {};
        prof.nip05_verify_in_flight = true;
        map[pubkey] = prof;
        writeProfiles(map);
        paintFriendsList();
        repaintFeed();
      }

      function markVerify(pubkey, ok) {
        const map = readProfiles();
        const prof = map[pubkey] || {};
        prof.nip05_verified = !!ok;
        prof.nip05_verified_at = Date.now();
        delete prof.nip05_verify_in_flight;
        map[pubkey] = prof;
        writeProfiles(map);
        paintFriendsList();
        repaintFeed();
      }

      // ─── v0.31 · PARTICIPATION ONRAMPS ───────────────────────────
      // Getting-started checklist, invite share-link, starter seeds,
      // OPML round-trip, ?follow= deep link. All client-side — no
      // new server endpoint. The federation layer becomes joinable
      // by any visitor who has a Nostr signer, with zero docs in
      // between.
      const STARTERS = [
        // Scaffold only. Real curation is an editorial task —
        // these are examples of famous Nostr pubkeys (jack, fiatjaf)
        // so the page never looks empty to a first-time visitor.
        { hex: '82341f882b6eabcd2ba7f1ef90aad961cf074af15b9ef44a09f9d2a8fbfbe6a2', alias: 'jack' },
        { hex: '3bf0c63fcb93463407af97a5e5ee64fa883d107ef9e558472c4eb9aaaefa459d', alias: 'fiatjaf' },
      ];

      function paintGettingStarted() {
        const gsList = document.querySelector('[data-sp-gs-list]');
        const gsMeta = document.querySelector('[data-sp-gs-meta]');
        if (!gsList) return;
        const selfPk = (localStorage.getItem(KEY_SELF_PUBKEY) || '').toLowerCase();
        const publicOn = localStorage.getItem(KEY_PUBLIC_SAVED) === '1';
        const friendCount = readFriends().length;
        const ambientOn = localStorage.getItem('sparrow:ambient-enabled') === '1';
        const steps = {
          signer:  !!selfPk,
          public:  publicOn,
          follow:  friendCount >= 1,
          ambient: ambientOn,
        };
        let done = 0;
        for (const [key, ok] of Object.entries(steps)) {
          const li = gsList.querySelector(`[data-sp-gs-step="${key}"]`);
          if (!li) continue;
          const tick = li.querySelector('.sp-friends-gs-tick');
          if (tick) tick.textContent = ok ? '✓' : '○';
          li.classList.toggle('is-done', ok);
          if (ok) done += 1;
        }
        if (gsMeta) gsMeta.textContent = `${done} of 4 steps done${done === 4 ? ' · you\'re set' : ''}`;
      }

      function paintInviteKit() {
        const box = document.querySelector('[data-sp-invite]');
        const urlEl = document.querySelector('[data-sp-invite-url]');
        if (!box) return;
        const selfPk = (localStorage.getItem(KEY_SELF_PUBKEY) || '').toLowerCase();
        if (!selfPk) { box.hidden = true; return; }
        box.hidden = false;
        const npub = hexToNpub(selfPk) || selfPk;
        const url = `${location.origin}/sparrow/friends?follow=${encodeURIComponent(npub)}`;
        if (urlEl) urlEl.value = url;
      }

      document.querySelector('[data-sp-invite-copy]')?.addEventListener('click', async () => {
        const urlEl = document.querySelector('[data-sp-invite-url]');
        if (!urlEl) return;
        urlEl.select();
        try { await navigator.clipboard.writeText(urlEl.value); }
        catch { document.execCommand('copy'); }
        const btn = document.querySelector('[data-sp-invite-copy]');
        if (btn) {
          btn.textContent = '✓ copied';
          setTimeout(() => { btn.textContent = 'copy'; }, 1600);
        }
      });

      function paintStarters() {
        const ul = document.querySelector('[data-sp-starters-list]');
        if (!ul) return;
        const followed = new Set(readFriends().map((f) => f.pubkey));
        ul.innerHTML = '';
        for (const s of STARTERS) {
          if (followed.has(s.hex)) continue; // already following — don't nag
          const li = document.createElement('li');
          li.className = 'sp-friends-starters-row';
          li.innerHTML = `
            <span class="sp-friends-starters-name">${escapeHTML(s.alias)}</span>
            <code>${shortPk(s.hex)}</code>
            <button type="button" class="sp-friends-starters-btn" data-starter-follow="${s.hex}" data-starter-alias="${escapeHTML(s.alias)}">+ follow</button>
          `;
          ul.appendChild(li);
        }
        // Hide the whole card if there's nothing to suggest.
        const starterBox = document.querySelector('[data-sp-starters]');
        if (starterBox) starterBox.hidden = ul.children.length === 0;
      }

      document.querySelector('[data-sp-starters-list]')?.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-starter-follow]');
        if (!btn) return;
        const pubkey = btn.getAttribute('data-starter-follow');
        const alias  = btn.getAttribute('data-starter-alias') || '';
        if (!pubkey) return;
        const friendsList = readFriends();
        if (!friendsList.some((f) => f.pubkey === pubkey)) {
          friendsList.unshift({ pubkey, alias, muted: false });
          writeFriends(friendsList);
        }
        paintFriendsList();
        paintState();
        paintStarters();
        paintGettingStarted();
        subscribeToFriends();
        refreshProfiles();
      });

      // v0.31: ?follow=<npub|hex> deep link. Pre-fills the add-form
      // and — if valid — offers the user a one-click submit by
      // focusing the follow button.
      function applyFollowDeepLink() {
        const params = new URLSearchParams(location.search);
        const raw = params.get('follow');
        if (!raw) return;
        const hex = parsePubkey(raw);
        if (!hex || !form) return;
        const pkInput = form.querySelector('input[name="pubkey"]');
        const already = readFriends().some((f) => f.pubkey === hex);
        if (pkInput && !already) {
          pkInput.value = hex;
          pkInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
          pkInput.focus();
          // Soft hint that their action is one click away.
          const submit = form.querySelector('button[type="submit"]');
          if (submit) {
            submit.classList.add('sp-friends-submit-hint');
            submit.textContent = `follow ${shortPk(hex)} →`;
          }
        }
      }

      // v0.31: OPML round-trip for friends. Export bundles the
      // current sparrow:friends list as OPML 2.0; import parses
      // any <outline> with nostr:… xmlUrl or htmlUrl + pubkey
      // attribute and unions with the existing list.
      function buildFriendsOPML() {
        const friendsList = readFriends();
        const profileMap = readProfiles();
        const when = new Date().toISOString();
        const outlines = friendsList.map((f) => {
          const prof = profileMap[f.pubkey] || {};
          const name = f.alias || prof.display_name || prof.name || `friend:${f.pubkey.slice(0, 8)}`;
          const npub = hexToNpub(f.pubkey) || f.pubkey;
          const muted = f.muted ? ' x-sparrow-muted="true"' : '';
          return `      <outline type="nostr" text="${escapeHTML(name)}" title="${escapeHTML(name)}" xmlUrl="nostr:${npub}" htmlUrl="${location.origin}/sparrow/friends?follow=${encodeURIComponent(npub)}" x-sparrow-pubkey="${f.pubkey}"${muted} />`;
        }).join('\n');
        return `<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>Sparrow friends · federation list</title>
    <dateCreated>${when}</dateCreated>
    <ownerName>sparrow</ownerName>
    <docs>https://pointcast.xyz/sparrow.json</docs>
  </head>
  <body>
    <outline text="Sparrow friends" title="Sparrow friends">
${outlines}
    </outline>
  </body>
</opml>
`;
      }

      document.querySelector('[data-sp-opml-friends-export]')?.addEventListener('click', () => {
        const xml = buildFriendsOPML();
        const blob = new Blob([xml], { type: 'text/x-opml; charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `sparrow-friends-${new Date().toISOString().slice(0, 10)}.opml`;
        document.body.appendChild(a); a.click(); a.remove();
        setTimeout(() => { try { URL.revokeObjectURL(url); } catch {} }, 2000);
        const status = document.querySelector('[data-sp-opml-friends-status]');
        if (status) {
          status.textContent = `exported · ${readFriends().length} friends`;
          setTimeout(() => { status.textContent = ''; }, 2600);
        }
      });

      document.querySelector('[data-sp-opml-friends-import]')?.addEventListener('change', async (e) => {
        const input = e.target;
        const file = input.files?.[0];
        if (!file) return;
        const status = document.querySelector('[data-sp-opml-friends-status]');
        try {
          const text = await file.text();
          const doc = new DOMParser().parseFromString(text, 'application/xml');
          const outlines = doc.querySelectorAll('outline');
          const existing = readFriends();
          const existingSet = new Set(existing.map((f) => f.pubkey));
          let added = 0;
          for (const o of outlines) {
            // Prefer the explicit sparrow pubkey attribute, fall back
            // to extracting from nostr:npub1… xmlUrl.
            let hex = o.getAttribute('x-sparrow-pubkey');
            if (!hex) {
              const xmlUrl = o.getAttribute('xmlUrl') || '';
              const m = /^nostr:(npub1\w+)$/i.exec(xmlUrl.trim());
              if (m) hex = npubToHex(m[1]);
            }
            if (!hex || !/^[0-9a-f]{64}$/i.test(hex)) continue;
            hex = hex.toLowerCase();
            if (existingSet.has(hex)) continue;
            existing.unshift({
              pubkey: hex,
              alias:  (o.getAttribute('text') || o.getAttribute('title') || '').slice(0, 40),
              muted:  o.getAttribute('x-sparrow-muted') === 'true',
            });
            existingSet.add(hex);
            added += 1;
          }
          writeFriends(existing);
          paintFriendsList();
          paintState();
          paintStarters();
          paintGettingStarted();
          subscribeToFriends();
          refreshProfiles();
          if (status) {
            status.textContent = added ? `imported · +${added}` : 'nothing new to import';
            setTimeout(() => { status.textContent = ''; }, 2800);
          }
        } catch (err) {
          if (status) status.textContent = `error · ${String(err).slice(0, 60)}`;
        } finally {
          input.value = '';
        }
      });

      // Re-paint participation surfaces whenever friends or profiles
      // change. Cheap — small DOM.
      const originalPaintFriendsList = paintFriendsList;
      paintFriendsList = function () {
        originalPaintFriendsList();
        paintStarters();
        paintGettingStarted();
      };
      const originalPaintState = paintState;
      paintState = function () {
        originalPaintState();
        paintInviteKit();
        paintGettingStarted();
      };

      // Hook public-saved toggle to refresh the checklist.
      pubToggle?.addEventListener('change', paintGettingStarted);

      // Hook signer-connect (fires in the HUD) to refresh checklist.
      window.addEventListener('storage', (ev) => {
        if (!ev.key) return;
        if (ev.key === KEY_SELF_PUBKEY || ev.key === KEY_PUBLIC_SAVED || ev.key === 'sparrow:ambient-enabled' || ev.key === KEY_FRIENDS) {
          paintGettingStarted();
          paintInviteKit();
          paintStarters();
        }
      });

      // ─── Boot ─────────────────────────────────────────────────────
      paintState();
      paintFriendsList();
      subscribeToFriends();
      refreshProfiles();
      paintGettingStarted();
      paintInviteKit();
      paintStarters();
      applyFollowDeepLink();

      // v0.24: kick NIP-05 verification for any cached friend whose
      // nip05 hasn't been verified yet (or whose verify cache is
      // stale). New profiles arriving via refreshProfiles() have their
      // own verification hook in commitProfiles().
      for (const f of readFriends()) {
        const prof = profileFor(f.pubkey);
        if (prof?.nip05 && !verifiedStateFreshByProfile(prof)) {
          verifyNip05(f.pubkey, prof.nip05).catch(() => {});
        }
      }

      // Re-paint if the signer injects late (NIP-07 extensions often do).
      setTimeout(paintState, 800);
      setTimeout(paintState, 2400);

      window.addEventListener('beforeunload', () => {
        for (const ws of openSockets) { try { ws.close(); } catch {} }
      });
    })();
  </script>

