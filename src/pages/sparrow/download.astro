---
/**
 * /sparrow/download — Sparrow.app download page (v0.40).
 * Native macOS reader. WKWebView pinned to /sparrow/ scope at the
 * navigation-policy level — no Chrome PWA session-restore bug.
 */
import SparrowLayout from '../../layouts/SparrowLayout.astro';

export const prerender = true;

const RELEASE = {
  version: '0.40',
  zipPath: '/sparrow/downloads/Sparrow-0.40.zip',
  zipBytes: 121346,
  zipSha256: '0dfc6abbdcbf6e0b623b8b4099e14d190a4c73e68e994d647cb61da9f408e934',
  releaseDate: '2026-04-29',
  minMacOS: '13.0',
};
const sizeLabel = `${(RELEASE.zipBytes / 1024).toFixed(0)} KB`;
---

<SparrowLayout
  title="Download"
  description="Download Sparrow.app — the standalone macOS reader for PointCast."
  canonicalPath="/sparrow/download"
>
  <section class="sp-download">
    <header class="sp-download__head">
      <p class="sp-download__kicker">SPARROW.APP · MACOS · STANDALONE</p>
      <h1 class="sp-download__title"><em>A real application,</em> not a browser tab.</h1>
      <p class="sp-download__lede">
        Sparrow.app is a native macOS reader for PointCast. Same blue-hour reader, in its own window — dock icon,
        cmd-tab entry, no Chrome required. Drag to <code>Applications</code> and launch.
      </p>
    </header>

    <section class="sp-download__cta">
      <a class="sp-download__primary" href={RELEASE.zipPath} download>
        <span class="sp-download__primary-glyph" aria-hidden="true">↓</span>
        <span class="sp-download__primary-label">
          <span class="sp-download__primary-line">Sparrow.app · v{RELEASE.version}</span>
          <span class="sp-download__primary-sub">{sizeLabel} · macOS {RELEASE.minMacOS}+ · ad-hoc signed</span>
        </span>
      </a>
      <dl class="sp-download__meta">
        <div class="sp-download__meta-row"><dt>release</dt><dd>{RELEASE.releaseDate}</dd></div>
        <div class="sp-download__meta-row"><dt>format</dt><dd><code>.zip</code> with <code>Sparrow.app</code> inside</dd></div>
        <div class="sp-download__meta-row"><dt>sha-256</dt><dd><code class="sp-download__sha">{RELEASE.zipSha256}</code></dd></div>
        <div class="sp-download__meta-row"><dt>source</dt><dd><a href="https://github.com/mhoydich/sparrow-app" rel="noreferrer">github.com/mhoydich/sparrow-app</a> · MIT</dd></div>
      </dl>
    </section>

    <section class="sp-download__steps">
      <h2 class="sp-download__steps-head">After the download</h2>
      <ol class="sp-download__step-list">
        <li><strong>Unzip</strong> — double-click. Expands to <code>Sparrow.app</code>.</li>
        <li><strong>Move to Applications</strong> — drag into <code>/Applications</code>.</li>
        <li><strong>First launch — right-click → Open</strong>. Ad-hoc signed; Gatekeeper warns once.</li>
        <li><strong>That's it.</strong> Reader opens at <code>/sparrow</code> in its own window.</li>
      </ol>
    </section>

    <section class="sp-download__features">
      <h2 class="sp-download__features-head">What you get</h2>
      <ul class="sp-download__feature-list">
        <li>
          <span class="sp-download__feature-kicker">SCOPE GUARD</span>
          <p>Reader pinned to <code>/sparrow/</code>; out-of-scope clicks open in default browser. No PWA session-restore bug.</p>
        </li>
        <li>
          <span class="sp-download__feature-kicker">FEDERATION</span>
          <p>kind-30078 saved-list mirroring, kind-20078 ambient presence, NIP-44 sync, profile lookups — same localStorage as web reader.</p>
        </li>
        <li>
          <span class="sp-download__feature-kicker">PEER NODE</span>
          <p>Loopback HTTP server on port 38474 advertised via Bonjour as <code>_sparrow._tcp</code>.</p>
        </li>
        <li>
          <span class="sp-download__feature-kicker">PRIVATE</span>
          <p>One URL, no telemetry. Talks to <code>pointcast.xyz</code> + your Nostr relays only.</p>
        </li>
      </ul>
    </section>
  </section>

  <style is:global>
    .sp-download { max-width: 880px; margin: 0 auto; padding: 48px 24px 96px; }
    .sp-download__head { margin-bottom: 48px; }
    .sp-download__kicker { font-family: var(--sp-mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sp-ember); margin: 0 0 14px; }
    .sp-download__title { font-family: var(--sp-display); font-weight: 400; font-size: clamp(38px, 6vw, 64px); line-height: 1.04; letter-spacing: -0.018em; margin: 0 0 18px; }
    .sp-download__title em { font-style: italic; color: var(--sp-ember); }
    .sp-download__lede { font-family: 'Inter Tight', system-ui, sans-serif; font-size: 17px; line-height: 1.55; max-width: 64ch; color: var(--sp-ash); margin: 0; }
    .sp-download code { font-family: var(--sp-mono); font-size: 0.85em; padding: 1px 6px; border: 1px solid var(--sp-rule); border-radius: 3px; color: var(--sp-bone); }
    .sp-download__cta { display: grid; gap: 24px; margin-bottom: 56px; padding: 28px; border: 1px solid var(--sp-rule); border-radius: 4px; background: color-mix(in oklch, var(--sp-blue-hour) 92%, var(--sp-ember)); }
    .sp-download__primary { display: inline-flex; align-items: center; gap: 18px; padding: 22px 26px; border: 2px solid var(--sp-ember); border-radius: 4px; background: color-mix(in oklch, var(--sp-ember) 16%, var(--sp-blue-hour)); color: var(--sp-bone); text-decoration: none; align-self: start; }
    .sp-download__primary:hover { background: color-mix(in oklch, var(--sp-ember) 28%, var(--sp-blue-hour)); text-decoration: none; }
    .sp-download__primary-glyph { font-family: var(--sp-display); font-size: 38px; color: var(--sp-ember); line-height: 1; }
    .sp-download__primary-label { display: flex; flex-direction: column; gap: 4px; }
    .sp-download__primary-line { font-family: var(--sp-display); font-size: 24px; color: var(--sp-bone); }
    .sp-download__primary-sub { font-family: var(--sp-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sp-mute); }
    .sp-download__meta { display: grid; gap: 8px; margin: 0; font-family: var(--sp-mono); font-size: 12px; color: var(--sp-ash); }
    .sp-download__meta-row { display: grid; grid-template-columns: 120px 1fr; gap: 12px; align-items: baseline; }
    .sp-download__meta-row dt { letter-spacing: 0.18em; text-transform: uppercase; color: var(--sp-mute); }
    .sp-download__meta-row dd { margin: 0; color: var(--sp-bone); }
    .sp-download__meta-row a { color: var(--sp-ember); }
    .sp-download__sha { font-family: var(--sp-mono); font-size: 11px; color: var(--sp-mute); word-break: break-all; }
    .sp-download__steps, .sp-download__features { margin-bottom: 56px; }
    .sp-download__steps-head, .sp-download__features-head { font-family: var(--sp-display); font-weight: 400; font-size: 28px; letter-spacing: -0.012em; margin: 0 0 22px; color: var(--sp-bone); }
    .sp-download__step-list { list-style: decimal; padding-left: 24px; margin: 0; font-family: 'Inter Tight', system-ui, sans-serif; font-size: 16px; line-height: 1.65; color: var(--sp-ash); }
    .sp-download__step-list li { margin-bottom: 14px; }
    .sp-download__step-list strong { color: var(--sp-bone); }
    .sp-download__feature-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 22px; }
    .sp-download__feature-list > li { padding: 18px 20px; border: 1px solid var(--sp-rule); border-radius: 4px; background: color-mix(in oklch, var(--sp-blue-hour) 95%, transparent); }
    .sp-download__feature-kicker { font-family: var(--sp-mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sp-ember); display: block; margin-bottom: 8px; }
    .sp-download__feature-list p { margin: 0; font-family: 'Inter Tight', system-ui, sans-serif; font-size: 15px; line-height: 1.55; color: var(--sp-ash); }
  </style>
</SparrowLayout>
