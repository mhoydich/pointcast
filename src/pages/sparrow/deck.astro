      <!-- ─── APPENDIX A ─────────────────────────────────────────── -->
      <section class="sec" id="appa" aria-labelledby="appa-h">
        <h2 class="sec-head" id="appa-h"><span class="sec-num">A.</span> Appendix — Manifest Surface</h2>
        <p>
