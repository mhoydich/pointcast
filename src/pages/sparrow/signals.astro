---
/**
 * /sparrow/signals — v0.28
 *
 * Federation recap. Pulls each followed (non-muted) friend's latest
 * public saved-list event (kind 30078, d-tag sparrow-public-saved-v1)
 * from the relay pool, then aggregates client-side into three
 * windows that answer three distinct questions:
 *
 *  1. Most co-saved — "which blocks keep showing up across my circle?"
 *     A block saved by 3 of my 5 friends matters differently than one
 *     only one person saved.
 *  2. Recently added — "what did my circle pick up in the last 7 days?"
 *     Uses event created_at as the arrival proxy; won't catch
 *     individual saves that aren't in a friend's latest snapshot.
 *  3. Channel distribution — "what is my circle listening to right now?"
 *     Summed saves per channel across all friends, rendered as a
 *     proportional bar so the dominant channel reads at a glance.
 *
 * Entirely client-rendered. Server ships the block lookup so ids
 * resolve to title + channel without per-block round-trips. Reuses
 * sparrow:profiles for avatars / display names — same one-pass
 * hydration as the rest of the federation surface.
 */
import SparrowLayout from '../../layouts/SparrowLayout.astro';
import { getCollection } from 'astro:content';
import { CHANNEL_LIST } from '../../lib/channels';

const all = (await getCollection('blocks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

const lookup: Record<string, { title: string; channel: string; channelName: string }> =
  Object.fromEntries(
    all.map((b) => {
      const ch = CHANNEL_LIST.find((c) => c.code === b.data.channel);
      return [
        b.data.id,
        {
          title: b.data.title,
          channel: b.data.channel,
          channelName: ch?.name ?? b.data.channel,
        },
      ];
    }),
  );

const channelList = CHANNEL_LIST.map((c) => ({
  code: c.code,
  slug: c.slug,
  name: c.name,
  purpose: c.purpose,
}));
---

<SparrowLayout
  title="Signals — federation recap"
  description="What your followed Sparrow readers have been saving — most co-saved blocks, recent adds, channel distribution."
  canonicalPath="/sparrow/signals"
  homeHref="/sparrow"
>
  <section class="sp-reel" aria-label="federation signals">
    <header class="sp-reel-head">
      <span class="sp-kicker">✦ signals · what your circle is listening to</span>
      <span class="sp-aside-mono" style="margin-left: auto;">
        <span data-sp-sig-meta>…</span>
      </span>
    </header>

    <p class="sp-about-dek" style="margin: 4px 0 18px;">
      Aggregates every followed (non-muted) signer's latest public saved
      list into three readings. Empty when nobody you follow has
      published, or when you haven't followed anyone yet.
    </p>

    <nav class="sp-sig-nav">
      <a href="/sparrow/friends" class="sp-sig-nav-link">← /sparrow/friends</a>
      <a href="/sparrow/friends/activity" class="sp-sig-nav-link">activity timeline →</a>
      <button
        type="button"
        class="sp-sig-export-btn"
        data-sp-sig-export
        aria-label="download signals recap as JSON"
        title="download this recap as sparrow-signals-<date>.json"
      >⤓ export JSON</button>
    </nav>

    <section class="sp-sig-panel" aria-label="most co-saved">
      <header class="sp-sig-panel-head">
        <span class="sp-friends-kicker">✦ most co-saved</span>
        <span class="sp-sig-panel-meta" data-sp-sig-top-meta>—</span>
      </header>
      <ol class="sp-sig-top" data-sp-sig-top></ol>
      <p class="sp-sig-empty" data-sp-sig-top-empty>
        Nothing overlaps yet. Co-saved means two or more followed
        signers independently saved the same block.
      </p>
    </section>

    <section class="sp-sig-panel" aria-label="recent adds">
      <header class="sp-sig-panel-head">
        <span class="sp-friends-kicker">✦ added in the last 7 days</span>
        <span class="sp-sig-panel-meta" data-sp-sig-recent-meta>—</span>
      </header>
      <ol class="sp-sig-recent" data-sp-sig-recent></ol>
      <p class="sp-sig-empty" data-sp-sig-recent-empty>
        Nobody's published a fresh saved list this week. Signal is
        based on event created_at — bulk historical lists don't
        count as "new."
      </p>
    </section>

    <section class="sp-sig-panel" aria-label="channel distribution">
      <header class="sp-sig-panel-head">
        <span class="sp-friends-kicker">✦ channel distribution</span>
        <span class="sp-sig-panel-meta" data-sp-sig-dist-meta>—</span>
      </header>
      <ul class="sp-sig-dist" data-sp-sig-dist></ul>
      <p class="sp-sig-empty" data-sp-sig-dist-empty>
        No saves tallied yet.
      </p>
    </section>

    <section class="sp-sig-panel sp-sig-digest" aria-label="weekly digest">
      <header class="sp-sig-panel-head">
        <span class="sp-friends-kicker">✦ weekly digest · experimental</span>
        <span class="sp-sig-panel-meta">v0.30 · worker pending</span>
      </header>
      <p class="sp-sig-dek">
        Opt in to a weekly HTML email of this recap. The sidecar
        worker isn't live yet — your subscription intent is stored
        locally in <code>sparrow:digest-subscription</code> and sent
        when <code>/api/sparrow/digest-subscribe</code> comes up. Worker
        will never hold secret material: only signed-payload pointers
        (relays + npub + preferences).
      </p>
      <form class="sp-sig-digest-form" data-sp-digest-form>
        <label>
          <span>email</span>
          <input
            type="email"
            name="email"
            autocomplete="email"
            placeholder="you@example.com"
            required
          />
        </label>
        <label>
          <span>frequency</span>
          <select name="frequency">
            <option value="weekly">weekly (Mondays)</option>
            <option value="biweekly">biweekly</option>
            <option value="monthly">monthly (1st)</option>
          </select>
        </label>
        <button type="submit">note my intent →</button>
      </form>
      <p class="sp-sig-digest-status" data-sp-digest-status></p>
      <p class="sp-sig-dek sp-sig-dek-small">
        Schema documented at <a class="sp-link" href="/sparrow.json">/sparrow.json</a> under
        <code>nostr.federated_lists.digest_sidecar</code>. Unsubscribe is a
        local clear + future worker DELETE.
      </p>
    </section>
  </section>

  <script
    id="sp-sig-data"
    type="application/json"
    set:html={JSON.stringify({ lookup, channels: channelList })}
  />

  <script is:inline>
    (function () {
      const KEY_FRIENDS   = 'sparrow:friends';
      const KEY_PROFILES  = 'sparrow:profiles';
      const KEY_RELAYS    = 'sparrow:nostr-relays';
      const D_TAG         = 'sparrow-public-saved-v1';
      const SYNC_KIND     = 30078;
      const RECENT_WINDOW_S = 7 * 24 * 60 * 60;  // 7 days
      const TOP_N          = 12;
      const DEFAULT_RELAYS = [
        'wss://relay.damus.io',
        'wss://relay.primal.net',
        'wss://nos.lol',
      ];

      const blob = document.getElementById('sp-sig-data');
      const state = blob ? (() => { try { return JSON.parse(blob.textContent || '{}'); } catch { return {}; } })() : {};
      const lookup = state.lookup || {};
      const channels = Array.isArray(state.channels) ? state.channels : [];
      const channelByCode = Object.fromEntries(channels.map((c) => [c.code, c]));

      const metaEl        = document.querySelector('[data-sp-sig-meta]');
      const topEl         = document.querySelector('[data-sp-sig-top]');
      const topMetaEl     = document.querySelector('[data-sp-sig-top-meta]');
      const topEmptyEl    = document.querySelector('[data-sp-sig-top-empty]');
      const recentEl      = document.querySelector('[data-sp-sig-recent]');
      const recentMetaEl  = document.querySelector('[data-sp-sig-recent-meta]');
      const recentEmptyEl = document.querySelector('[data-sp-sig-recent-empty]');
      const distEl        = document.querySelector('[data-sp-sig-dist]');
      const distMetaEl    = document.querySelector('[data-sp-sig-dist-meta]');
      const distEmptyEl   = document.querySelector('[data-sp-sig-dist-empty]');

      const readFriends = () => {
        try {
          const raw = JSON.parse(localStorage.getItem(KEY_FRIENDS) || '[]');
          if (!Array.isArray(raw)) return [];
          return raw
            .map((f) => (typeof f === 'string'
              ? { pubkey: f, alias: '', muted: false }
              : (f && typeof f === 'object' && typeof f.pubkey === 'string')
                ? {
                    pubkey: f.pubkey.toLowerCase(),
                    alias:  (f.alias || '').slice(0, 40),
                    muted:  !!f.muted,
                  }
                : null))
            .filter((f) => f && /^[0-9a-f]{64}$/.test(f.pubkey) && !f.muted);
        } catch { return []; }
      };
      const readProfiles = () => {
        try {
          const raw = JSON.parse(localStorage.getItem(KEY_PROFILES) || '{}');
          return (raw && typeof raw === 'object' && !Array.isArray(raw)) ? raw : {};
        } catch { return {}; }
      };
      const getRelays = () => {
        try {
          const raw = localStorage.getItem(KEY_RELAYS);
          const list = raw ? JSON.parse(raw) : null;
          if (Array.isArray(list) && list.length) return list.filter((u) => typeof u === 'string' && u.startsWith('ws'));
        } catch {}
        return DEFAULT_RELAYS;
      };
      function escapeHTML(s) {
        return (s || '').replace(/[&<>"']/g, (c) => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
        }[c]));
      }
      const shortPk = (pk) => (pk ? `${pk.slice(0, 8)}…${pk.slice(-4)}` : '—');
      function nameFor(pubkey, friend) {
        const prof = readProfiles()[pubkey];
        return friend?.alias
          || (prof && (prof.display_name || prof.name))
          || shortPk(pubkey);
      }
      function pictureFor(pubkey) {
        const prof = readProfiles()[pubkey];
        return prof?.picture || '';
      }

      const friends = readFriends();
      const relays  = getRelays();
      if (metaEl) {
        metaEl.textContent = friends.length
          ? `${friends.length} following · ${relays.length} relays`
          : 'nobody followed · add someone on /sparrow/friends';
      }
      if (!friends.length) {
        [topEmptyEl, recentEmptyEl, distEmptyEl].forEach((el) => {
          if (!el) return;
          el.hidden = false;
          el.innerHTML = 'You haven\'t followed anyone yet. <a class="sp-link" href="/sparrow/friends">Open /sparrow/friends →</a>.';
        });
        return;
      }

      // Newest kind-30078 per author.
      const newestByAuthor = new Map();
      const openSockets = [];
      const authors = friends.map((f) => f.pubkey);
      const subId = `sp-sig-${Math.random().toString(36).slice(2, 10)}`;
      const filter = {
        kinds: [SYNC_KIND],
        authors,
        '#d': [D_TAG],
        limit: authors.length * 2,
      };

      function ingestEvent(ev) {
        if (!ev || ev.kind !== SYNC_KIND || typeof ev.content !== 'string') return;
        if (typeof ev.pubkey !== 'string' || typeof ev.created_at !== 'number') return;
        const isOurs = Array.isArray(ev.tags) && ev.tags.some(
          (t) => Array.isArray(t) && t[0] === 'd' && t[1] === D_TAG,
        );
        if (!isOurs) return;
        let body;
        try { body = JSON.parse(ev.content); } catch { return; }
        const saved = Array.isArray(body?.saved?.value) ? body.saved.value : [];
        const prior = newestByAuthor.get(ev.pubkey);
        if (!prior || ev.created_at > prior.created_at) {
          newestByAuthor.set(ev.pubkey, {
            created_at: ev.created_at,
            saved,
          });
        }
      }

      function repaint() {
        const friendsLive = readFriends();
        const keepSet = new Set(friendsLive.map((f) => f.pubkey));
        // Prune muted/unfollowed mid-session.
        for (const pk of Array.from(newestByAuthor.keys())) {
          if (!keepSet.has(pk)) newestByAuthor.delete(pk);
        }

        // ── 1. Most co-saved ─────────────────────────────────────────
        // v0.29: also track first-picker per block — the friend with
        // the earliest created_at among those who currently have the
        // block in their saved list. Caveat: this is the timestamp of
        // that friend's LATEST published list, so it's a proxy for
        // "when I most recently saw this friend saving it" — not a
        // historical save-order record. Still useful: across a group
        // re-publishing regularly, the pattern stabilizes to "who
        // put this on my radar first." Rendered as a small ⭐ chip.
        const counts = new Map(); // blockId → { count, savers: Set<pubkey>, firstPicker: pubkey, firstAt: created_at }
        for (const [pubkey, entry] of newestByAuthor) {
          const seenInThisList = new Set();
          for (const id of entry.saved) {
            if (typeof id !== 'string' || seenInThisList.has(id)) continue;
            seenInThisList.add(id);
            const slot = counts.get(id) || {
              count: 0,
              savers: new Set(),
              firstPicker: pubkey,
              firstAt: entry.created_at,
            };
            slot.count += 1;
            slot.savers.add(pubkey);
            if (entry.created_at < slot.firstAt) {
              slot.firstPicker = pubkey;
              slot.firstAt = entry.created_at;
            }
            counts.set(id, slot);
          }
        }
        const top = Array.from(counts.entries())
          .filter(([, v]) => v.count >= 2)
          .sort((a, b) => b[1].count - a[1].count || a[0].localeCompare(b[0]))
          .slice(0, TOP_N);

        if (topMetaEl) topMetaEl.textContent = top.length ? `${top.length} block${top.length === 1 ? '' : 's'} overlap` : '0 overlaps';
        if (topEmptyEl) topEmptyEl.hidden = top.length > 0;
        if (topEl) {
          topEl.innerHTML = '';
          for (const [id, info] of top) {
            const meta = lookup[id];
            const names = Array.from(info.savers).map((pk) => {
              const friend = friendsLive.find((f) => f.pubkey === pk);
              return nameFor(pk, friend);
            });
            const saversHTML = names.slice(0, 4).map((n) => `<span class="sp-sig-saver">${escapeHTML(n)}</span>`).join('');
            const more = names.length > 4 ? `<span class="sp-sig-saver-more">+${names.length - 4}</span>` : '';
            const channelName = meta?.channelName || meta?.channel || '—';
            const channelCode = meta?.channel ? meta.channel.toLowerCase() : '';
            // v0.29: first-picker chip. Earliest created_at among the
            // current savers wins. Only shown when count >= 2 (which
            // is always true at this point) and the picker isn't the
            // same as a single solo saver — which can't happen since
            // filtering requires count >= 2.
            const pickerFriend = friendsLive.find((f) => f.pubkey === info.firstPicker);
            const pickerName = pickerFriend ? nameFor(info.firstPicker, pickerFriend) : shortPk(info.firstPicker);
            const li = document.createElement('li');
            li.className = 'sp-sig-top-row';
            if (channelCode) li.style.setProperty('--ch', `var(--ch-${channelCode})`);
            li.innerHTML = `
              <a href="/sparrow/b/${escapeHTML(id)}" class="sp-sig-top-link">
                <span class="sp-sig-badge">×${info.count}</span>
                <span class="sp-sig-top-id">№ ${escapeHTML(id)}</span>
                <span class="sp-sig-top-title">${escapeHTML(meta?.title || 'unknown block')}</span>
                <span class="sp-sig-top-chip">${escapeHTML(channelName)}</span>
              </a>
              <div class="sp-sig-savers">
                <span class="sp-sig-picker" title="earliest published by ${escapeHTML(pickerName)}">⭐ ${escapeHTML(pickerName)}</span>
                ${saversHTML}${more}
              </div>
            `;
            topEl.appendChild(li);
          }
        }

        // ── 2. Added in the last 7 days ──────────────────────────────
        const now = Math.floor(Date.now() / 1000);
        const recentCutoff = now - RECENT_WINDOW_S;
        const recentRows = [];
        for (const [pubkey, entry] of newestByAuthor) {
          if (entry.created_at < recentCutoff) continue;
          const friend = friendsLive.find((f) => f.pubkey === pubkey);
          const firstId = entry.saved.find((id) => typeof id === 'string');
          if (!firstId) continue;
          recentRows.push({
            pubkey,
            friend,
            blockId: firstId,
            created_at: entry.created_at,
            savedCount: entry.saved.length,
          });
        }
        recentRows.sort((a, b) => b.created_at - a.created_at);
        if (recentMetaEl) recentMetaEl.textContent = recentRows.length ? `${recentRows.length} friend${recentRows.length === 1 ? '' : 's'} active` : '0 updates this week';
        if (recentEmptyEl) recentEmptyEl.hidden = recentRows.length > 0;
        if (recentEl) {
          recentEl.innerHTML = '';
          for (const r of recentRows) {
            const meta = lookup[r.blockId];
            const name = nameFor(r.pubkey, r.friend);
            const pic  = pictureFor(r.pubkey);
            const rel  = (() => {
              const diff = now - r.created_at;
              if (diff < 3600) return `${Math.max(1, Math.floor(diff / 60))}m ago`;
              if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
              return `${Math.floor(diff / 86400)}d ago`;
            })();
            const li = document.createElement('li');
            li.className = 'sp-sig-recent-row';
            li.innerHTML = `
              ${pic
                ? `<img class="sp-sig-avatar" src="${escapeHTML(pic)}" alt="" loading="lazy" referrerpolicy="no-referrer" decoding="async" onerror="this.style.display='none'" />`
                : `<span class="sp-sig-avatar sp-sig-avatar-placeholder" aria-hidden="true">✦</span>`}
              <span class="sp-sig-recent-name">${escapeHTML(name)}</span>
              <span class="sp-sig-recent-action">published ${r.savedCount} · ${rel}</span>
              <a href="/sparrow/b/${escapeHTML(r.blockId)}" class="sp-sig-recent-link">
                <span class="sp-sig-top-id">№ ${escapeHTML(r.blockId)}</span>
                ${meta ? `<span class="sp-sig-top-title">${escapeHTML(meta.title || '—')}</span>` : '<span class="sp-sig-top-title"><em>unknown block</em></span>'}
              </a>
            `;
            recentEl.appendChild(li);
          }
        }

        // ── 3. Channel distribution ──────────────────────────────────
        const dist = new Map(); // channelCode → count
        let totalSaves = 0;
        for (const [, entry] of newestByAuthor) {
          const seen = new Set();
          for (const id of entry.saved) {
            if (typeof id !== 'string' || seen.has(id)) continue;
            seen.add(id);
            const meta = lookup[id];
            const ch = meta?.channel || '—';
            dist.set(ch, (dist.get(ch) || 0) + 1);
            totalSaves += 1;
          }
        }
        const distRows = Array.from(dist.entries()).sort((a, b) => b[1] - a[1]);
        if (distMetaEl) distMetaEl.textContent = totalSaves ? `${totalSaves} saves across ${distRows.length} channels` : '0 saves';
        if (distEmptyEl) distEmptyEl.hidden = distRows.length > 0;
        if (distEl) {
          distEl.innerHTML = '';
          for (const [code, count] of distRows) {
            const info = channelByCode[code];
            const name = info?.name || code;
            const pct = totalSaves ? (count / totalSaves) * 100 : 0;
            const li = document.createElement('li');
            li.className = 'sp-sig-dist-row';
            if (info) li.style.setProperty('--ch', `var(--ch-${code.toLowerCase()})`);
            li.innerHTML = `
              <a class="sp-sig-dist-link" href="${info ? `/sparrow/ch/${escapeHTML(info.slug)}` : '#'}">
                <span class="sp-sig-dist-code">${escapeHTML(code)}</span>
                <span class="sp-sig-dist-name">${escapeHTML(name)}</span>
                <span class="sp-sig-dist-bar"><span style="width:${pct.toFixed(1)}%"></span></span>
                <span class="sp-sig-dist-count">${count}</span>
              </a>
            `;
            distEl.appendChild(li);
          }
        }
      }

      for (const url of relays) {
        try {
          const ws = new WebSocket(url);
          openSockets.push(ws);
          ws.addEventListener('open', () => {
            try { ws.send(JSON.stringify(['REQ', subId, filter])); } catch {}
          });
          ws.addEventListener('message', (msg) => {
            let frame;
            try { frame = JSON.parse(msg.data); } catch { return; }
            if (!Array.isArray(frame)) return;
            if (frame[0] === 'EVENT' && frame[1] === subId && frame[2]) {
              ingestEvent(frame[2]);
            } else if (frame[0] === 'EOSE' && frame[1] === subId) {
              try { ws.send(JSON.stringify(['CLOSE', subId])); } catch {}
              try { ws.close(); } catch {}
              repaint();
            }
          });
          setTimeout(() => { try { if (ws.readyState <= 1) ws.close(); } catch {} }, 8000);
        } catch {}
      }
      setTimeout(repaint, 2500);

      // v0.29: export the current signals recap as a JSON bundle.
      // Client-side only — Blob download, no server round-trip.
      // Schema is namespaced + versioned so future shape changes can
      // be handled by consumers (including the user's own future self).
      document.querySelector('[data-sp-sig-export]')?.addEventListener('click', () => {
        const friendsLive = readFriends();
        const profileMap = readProfiles();
        const keepSet = new Set(friendsLive.map((f) => f.pubkey));
        for (const pk of Array.from(newestByAuthor.keys())) {
          if (!keepSet.has(pk)) newestByAuthor.delete(pk);
        }

        // Recompute a compact snapshot — no DOM reads, no truncation.
        const exportCounts = new Map();
        for (const [pubkey, entry] of newestByAuthor) {
          const seen = new Set();
          for (const id of entry.saved) {
            if (typeof id !== 'string' || seen.has(id)) continue;
            seen.add(id);
            const slot = exportCounts.get(id) || {
              count: 0, savers: [], first_picker: pubkey, first_at: entry.created_at,
            };
            slot.count += 1;
            slot.savers.push(pubkey);
            if (entry.created_at < slot.first_at) {
              slot.first_picker = pubkey;
              slot.first_at = entry.created_at;
            }
            exportCounts.set(id, slot);
          }
        }
        const top = Array.from(exportCounts.entries())
          .filter(([, v]) => v.count >= 2)
          .sort((a, b) => b[1].count - a[1].count || a[0].localeCompare(b[0]));

        const bundle = {
          schema: 'sparrow-signals-v1',
          generated_at: new Date().toISOString(),
          boot_origin: location.origin,
          friends: friendsLive.map((f) => ({
            pubkey: f.pubkey,
            alias: f.alias || undefined,
            display_name: profileMap[f.pubkey]?.display_name || profileMap[f.pubkey]?.name || undefined,
            nip05: profileMap[f.pubkey]?.nip05 || undefined,
            has_published: newestByAuthor.has(f.pubkey),
          })),
          relays: getRelays(),
          newest_events: Array.from(newestByAuthor.entries()).map(([pubkey, entry]) => ({
            pubkey,
            created_at: entry.created_at,
            saved_count: entry.saved.length,
          })),
          top_co_saved: top.map(([id, v]) => {
            const meta = lookup[id];
            return {
              id,
              title: meta?.title ?? null,
              channel: meta?.channel ?? null,
              count: v.count,
              savers: v.savers,
              first_picker: v.first_picker,
              first_picker_at: v.first_at,
            };
          }),
          notes: {
            first_picker: 'Earliest created_at among current savers. Proxy — kind-30078 is replaceable, so this reflects when each friend most recently republished, not the true first-save moment.',
            scope: 'Top co-saved includes blocks saved by ≥ 2 followed signers. Visited state, reactions, and private sync state are NOT included.',
          },
        };

        const blob = new Blob([JSON.stringify(bundle, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        const stamp = new Date().toISOString().slice(0, 10);
        a.href = url;
        a.download = `sparrow-signals-${stamp}.json`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(() => { try { URL.revokeObjectURL(url); } catch {} }, 2000);
      });

      // v0.30: digest subscription intent. No worker yet — we store
      // the shape locally and attempt the POST, accepting 404 / 501
      // as "worker not live, intent recorded." When the sidecar ships,
      // a Service Worker or on-load sync pass will push queued
      // subscriptions to /api/sparrow/digest-subscribe.
      const digestForm = document.querySelector('[data-sp-digest-form]');
      const digestStatus = document.querySelector('[data-sp-digest-status]');
      const KEY_DIGEST = 'sparrow:digest-subscription';
      // Hydrate the form from stored intent.
      try {
        const stored = JSON.parse(localStorage.getItem(KEY_DIGEST) || 'null');
        if (stored && typeof stored === 'object' && digestForm) {
          const emailInput = digestForm.querySelector('input[name="email"]');
          const freqInput  = digestForm.querySelector('select[name="frequency"]');
          if (emailInput && typeof stored.email === 'string') emailInput.value = stored.email;
          if (freqInput && typeof stored.frequency === 'string') freqInput.value = stored.frequency;
          if (digestStatus) digestStatus.textContent = `intent stored locally · ${stored.email} · ${stored.frequency}`;
        }
      } catch {}

      digestForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const fd = new FormData(digestForm);
        const email = String(fd.get('email') || '').trim().toLowerCase();
        const frequency = String(fd.get('frequency') || 'weekly');
        const selfPk = (localStorage.getItem('sparrow:nostr-pubkey') || '').toLowerCase();
        if (!/^\S+@\S+\.\S+$/.test(email)) return;
        const intent = {
          schema: 'sparrow-digest-subscription-v1',
          email,
          frequency,
          npub: selfPk || null,
          relays: getRelays(),
          created_at: new Date().toISOString(),
        };
        try { localStorage.setItem(KEY_DIGEST, JSON.stringify(intent)); } catch {}
        if (digestStatus) digestStatus.textContent = 'saved locally · attempting /api/sparrow/digest-subscribe…';
        try {
          const r = await fetch('/api/sparrow/digest-subscribe', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(intent),
          });
          if (r.ok) {
            if (digestStatus) digestStatus.textContent = 'subscribed — check your inbox for a confirmation.';
          } else if (r.status === 501 || r.status === 404) {
            if (digestStatus) digestStatus.textContent = 'worker not live yet · intent saved locally · will retry on future visits.';
          } else {
            if (digestStatus) digestStatus.textContent = `intent saved · endpoint returned ${r.status}.`;
          }
        } catch {
          if (digestStatus) digestStatus.textContent = 'intent saved · offline — will retry on future visits.';
        }
      });

      window.addEventListener('beforeunload', () => {
        for (const ws of openSockets) { try { ws.close(); } catch {} }
      });
    })();
  </script>

