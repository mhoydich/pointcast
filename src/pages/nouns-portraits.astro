---
import BlockLayout from '../layouts/BlockLayout.astro';
import NounsPortraitStrip from '../components/NounsPortraitStrip.astro';
import contracts from '../data/contracts.json';

const KT1 = (contracts as any).visit_nouns?.mainnet ?? '';
const description = 'Five PointCast Visit Nouns portraits, mintable on Tezos mainnet through the Visit Nouns FA2.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://pointcast.xyz/nouns-portraits',
  name: 'PointCast Nouns Portraits',
  description,
  url: 'https://pointcast.xyz/nouns-portraits',
  isPartOf: {
    '@type': 'WebSite',
    name: 'PointCast',
    url: 'https://pointcast.xyz/',
  },
  about: {
    '@type': 'CreativeWork',
    name: 'Visit Nouns FA2',
    identifier: KT1,
    url: `https://tzkt.io/${KT1}`,
  },
};
---

<BlockLayout title="Nouns Portraits" description={description} jsonLd={jsonLd}>
  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>Nouns Portraits</span>
    </nav>

    <header class="hero">
      <p class="hero__kicker">PointCast collection surface</p>
      <h1>Nouns portraits, ready to mint.</h1>
      <p>
        A tight set of five CC0 Nouns seeds for the PointCast front door.
        Each one routes through the live Visit Nouns FA2 on Tezos mainnet.
      </p>
    </header>

    <NounsPortraitStrip context="page" />

    <aside class="note">
      <p>
        Contract: <code>{KT1}</code>.
        Minted tokens appear on <a href="/collection/visit-nouns">/collection/visit-nouns</a> and objkt after indexing.
      </p>
    </aside>
  </main>
</BlockLayout>

<style>
  .page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 20px 20px 80px;
  }

  .crumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-ink-soft, #5f5e5a);
  }

  .crumb a {
    color: var(--pc-accent, #185fa5);
  }

  .hero {
    padding: 18px 0 4px;
    border-top: 1.5px solid var(--pc-ink, #12110e);
  }

  .hero__kicker {
    margin: 0 0 8px;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pc-accent, #185fa5);
  }

  .hero h1 {
    max-width: 760px;
    margin: 0 0 10px;
    font-family: var(--pc-font-sans, system-ui, sans-serif);
    font-size: clamp(40px, 7vw, 84px);
    line-height: 0.94;
    font-weight: 540;
    color: var(--pc-ink, #12110e);
  }

  .hero p:not(.hero__kicker) {
    max-width: 66ch;
    margin: 0;
    color: var(--pc-ink-soft, #5f5e5a);
    font-size: 16px;
    line-height: 1.5;
  }

  .note {
    margin-top: 16px;
    padding: 12px 14px;
    border: 1px solid var(--pc-rule, #d6d4cd);
    background: var(--pc-paper, #fffaf0);
    color: var(--pc-ink-soft, #5f5e5a);
    font-size: 13px;
    line-height: 1.45;
  }

  .note p {
    margin: 0;
  }

  .note code {
    color: var(--pc-ink, #12110e);
    word-break: break-all;
  }

  .note a {
    color: var(--pc-accent, #185fa5);
  }
</style>
