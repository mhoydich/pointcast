---
/**
 * /here — full-page congregation view.
 *
 * Brief #7. "How this is a place to congregate, a schelling point."
 * A dark/amber page-scale counterpart to the VisitorHereStrip on the
 * home page. Renders HereGrid — up to ~64 currently-connected visitors
 * as noun avatars — in the shipped /tv visual language. Client-hydrated
 * from /api/presence/snapshot + the live WS.
 *
 * No block collection reads, no daily drop, no constellation. Just:
 * who's here, right now. If no other visitors are connected, shows a
 * small "waiting for peoples" line instead of hiding the page.
 *
 * Author: cc. Source: docs/briefs/2026-04-19-codex-here-congregation.md.
 * Codex shipped the backend (snapshot endpoint + DO refactor); cc
 * shipped the UI (HereGrid component + this page shell).
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import HereGrid from '../components/HereGrid.astro';
import HerePoll from '../components/HerePoll.astro';
import HereBeat from '../components/HereBeat.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: 'PointCast · here now',
  description: 'Live congregation view of visitors currently connected to pointcast.xyz.',
  url: 'https://pointcast.xyz/here',
  eventAttendanceMode: 'https://schema.org/OnlineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  startDate: new Date().toISOString(),
  location: {
    '@type': 'VirtualLocation',
    url: 'https://pointcast.xyz/here',
  },
  organizer: {
    '@type': 'Organization',
    name: 'PointCast',
    url: 'https://pointcast.xyz',
  },
};
---

<BlockLayout title="Here now" description="Live congregation — visitors currently connected to PointCast, as noun avatars." jsonLd={jsonLd}>
  <div class="here-shell">
    <header class="here-topbar">
      <a class="here-brand mono" href="/" aria-label="PointCast home">
        <span class="here-brand__mark">PC</span>
        <span>PointCast</span>
      </a>
      <nav class="here-nav mono" aria-label="Here navigation">
        <a href="/">Home</a>
        <a href="/tv">TV</a>
        <a href="/workbench">Workbench</a>
        <a href="/for-agents">Agents</a>
      </nav>
    </header>

    <section class="here-room" aria-labelledby="here-title">
      <div class="here-room__intro">
        <p class="here-room__kicker mono">
          <span class="here-room__live" aria-hidden="true"></span>
          HERE NOW · LIVE ROOM
        </p>
        <h1 id="here-title">The peoples, right now.</h1>
        <p>
          Humans, wallets, agents, and bots arrive as noun avatars. Keep
          the page open and the room updates around you without refresh.
        </p>
        <div class="here-room__actions mono" aria-label="Quick links">
          <a href="/api/presence/snapshot">Snapshot</a>
          <a href="/api/presence">Live WS</a>
          <a href="/for-nodes">Broadcast</a>
        </div>
      </div>

      <div class="here-room__stage" aria-label="Live congregation">
        <HereGrid cap={64} />
      </div>
    </section>

    <section class="here-tools" aria-label="Live room tools">
      <div class="here-tools__primary">
        <HerePoll />
      </div>
      <div class="here-tools__secondary">
        <HereBeat />
      </div>
    </section>

    <aside class="here-agent-strip">
      <p class="here-agent-strip__label mono">MACHINE-READABLE SURFACES</p>
      <ul>
        <li><a href="/api/presence/snapshot">/api/presence/snapshot</a><span>current state, cached 5s</span></li>
        <li><a href="/api/presence">/api/presence</a><span>live WebSocket, identify + updates</span></li>
        <li><a href="/for-agents">/for-agents</a><span>full manifest</span></li>
        <li><a href="/for-nodes">/for-nodes</a><span>how outside nodes broadcast here</span></li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<style is:global>
  body:has(.here-shell) {
    background: #08090c;
    color: #f7f0e3;
  }
  body:has(.here-shell) .skip-link:focus {
    background: #f7f0e3;
    color: #101014;
  }
</style>

<style>
  .here-shell {
    min-height: 100vh;
    padding: 16px clamp(14px, 3vw, 28px) 86px;
    color: #f7f0e3;
    background:
      linear-gradient(180deg, rgba(17, 21, 30, 0.92) 0%, rgba(8, 9, 12, 0.98) 58%, #08090c 100%),
      radial-gradient(circle at 18% 16%, rgba(58, 121, 186, 0.26), transparent 28%),
      radial-gradient(circle at 82% 8%, rgba(221, 174, 71, 0.22), transparent 30%),
      linear-gradient(135deg, #0e1621 0%, #08090c 52%, #15110b 100%);
    font-family: var(--pc-font-sans, Inter, system-ui, sans-serif);
    overflow: hidden;
  }
  .here-shell::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.028) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.55), transparent 78%);
  }
  .here-topbar,
  .here-room,
  .here-tools,
  .here-agent-strip {
    position: relative;
    z-index: 1;
    width: min(100%, 1240px);
    margin-inline: auto;
  }
  .here-topbar {
    min-height: 44px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
    margin-bottom: clamp(18px, 3vw, 34px);
  }
  .here-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #f7f0e3;
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .here-brand__mark {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border: 1px solid rgba(247, 240, 227, 0.22);
    background: #f7f0e3;
    color: #101014;
    font-weight: 800;
  }
  .here-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 6px;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .here-nav a {
    color: #bfc7d4;
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    padding: 0 10px;
    border: 1px solid rgba(191, 199, 212, 0.16);
    background: rgba(8, 9, 12, 0.36);
    text-decoration: none;
  }
  .here-nav a:hover {
    border-color: rgba(221, 174, 71, 0.55);
    color: #f0c66a;
  }
  .here-room {
    display: grid;
    grid-template-columns: minmax(280px, 0.55fr) minmax(0, 1fr);
    gap: clamp(18px, 4vw, 42px);
    align-items: stretch;
    min-height: min(720px, calc(100vh - 122px));
  }
  .here-room__intro {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(20px, 4vw, 46px) 0;
  }
  .here-room__kicker {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 16px;
    color: #f0c66a;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .here-room__live {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #50d890;
    box-shadow: 0 0 0 0 rgba(80, 216, 144, 0.55);
    animation: hereLivePulse 1.8s ease-out infinite;
  }
  .here-room h1 {
    max-width: 9ch;
    margin: 0 0 18px;
    color: #fffaf0;
    font-family: var(--pc-font-sans, Inter, system-ui, sans-serif);
    font-size: clamp(48px, 8vw, 104px);
    line-height: 0.9;
    letter-spacing: 0;
  }
  .here-room__intro p:not(.here-room__kicker) {
    max-width: 560px;
    margin: 0;
    color: #cad2de;
    font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.55;
  }
  .here-room__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 28px;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .here-room__actions a {
    color: #101014;
    background: #f0c66a;
    border: 1px solid #f0c66a;
    min-height: 36px;
    display: inline-flex;
    align-items: center;
    padding: 0 12px;
    text-decoration: none;
  }
  .here-room__actions a:nth-child(2) {
    color: #f7f0e3;
    background: rgba(45, 93, 143, 0.38);
    border-color: rgba(114, 169, 217, 0.42);
  }
  .here-room__actions a:nth-child(3) {
    color: #f7f0e3;
    background: rgba(80, 216, 144, 0.12);
    border-color: rgba(80, 216, 144, 0.36);
  }
  .here-room__stage {
    min-width: 0;
    min-height: 420px;
    display: flex;
    align-items: stretch;
    border: 1px solid rgba(247, 240, 227, 0.16);
    background:
      linear-gradient(180deg, rgba(247, 240, 227, 0.08), rgba(247, 240, 227, 0.025)),
      rgba(8, 9, 12, 0.58);
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.38);
    backdrop-filter: blur(18px);
  }
  .here-tools {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: 18px;
    margin-top: 22px;
  }
  .here-agent-strip {
    margin-top: 18px;
    padding: 16px;
    border: 1px solid rgba(247, 240, 227, 0.14);
    background: rgba(8, 9, 12, 0.46);
  }
  .here-agent-strip__label {
    font-size: 11px;
    letter-spacing: 0.14em;
    color: #8fc6ff;
    margin: 0 0 12px;
  }
  .here-agent-strip ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    font-family: var(--pc-font-mono, 'JetBrains Mono Variable', monospace);
    font-size: 12px;
    color: #bfc7d4;
  }
  .here-agent-strip li {
    min-height: 82px;
    display: grid;
    align-content: start;
    gap: 7px;
    padding: 12px;
    border: 1px solid rgba(247, 240, 227, 0.1);
    background: rgba(247, 240, 227, 0.035);
  }
  .here-agent-strip a {
    color: #f0c66a;
    text-decoration: none;
    overflow-wrap: anywhere;
  }
  .here-agent-strip span {
    color: #9da8b6;
    line-height: 1.35;
  }
  .mono { font-family: var(--pc-font-mono, 'JetBrains Mono Variable', monospace); }
  @keyframes hereLivePulse {
    0% { box-shadow: 0 0 0 0 rgba(80, 216, 144, 0.55); }
    70% { box-shadow: 0 0 0 10px rgba(80, 216, 144, 0); }
    100% { box-shadow: 0 0 0 0 rgba(80, 216, 144, 0); }
  }
  @media (max-width: 980px) {
    .here-room,
    .here-tools {
      grid-template-columns: 1fr;
    }
    .here-room {
      min-height: 0;
    }
    .here-room__intro {
      padding: 18px 0 0;
    }
    .here-room h1 {
      max-width: 10ch;
    }
    .here-agent-strip ul {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 640px) {
    .here-shell {
      padding-inline: 12px;
    }
    .here-topbar {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
    }
    .here-nav {
      justify-content: flex-start;
    }
    .here-nav a {
      padding-inline: 8px;
      font-size: 11px;
    }
    .here-room h1 {
      font-size: 50px;
    }
    .here-room__stage {
      min-height: 360px;
    }
    .here-agent-strip ul {
      grid-template-columns: 1fr;
    }
  }
</style>

<style is:global>
  body:has(.here-shell) .here-grid,
  body:has(.here-shell) .here-poll,
  body:has(.here-shell) .here-beat {
    width: 100%;
    max-width: none;
    margin: 0;
    color: #f7f0e3;
    font-family: var(--pc-font-sans, Inter, system-ui, sans-serif);
  }
  body:has(.here-shell) .here-grid {
    min-height: 100%;
    padding: clamp(16px, 2.4vw, 24px);
    display: flex;
    flex-direction: column;
  }
  body:has(.here-shell) .here-grid__head {
    border-bottom-color: rgba(247, 240, 227, 0.14);
    margin-bottom: 16px;
  }
  body:has(.here-shell) .here-grid__kicker,
  body:has(.here-shell) .here-poll__live,
  body:has(.here-shell) .here-beat__kicker,
  body:has(.here-shell) .here-cell--you .here-cell__label {
    color: #f0c66a;
  }
  body:has(.here-shell) .here-grid__time,
  body:has(.here-shell) .here-poll__kicker,
  body:has(.here-shell) .here-beat__foot,
  body:has(.here-shell) .here-cell__label {
    color: #9da8b6;
  }
  body:has(.here-shell) .here-grid__cells {
    grid-template-columns: repeat(auto-fill, minmax(108px, 1fr));
    gap: 10px;
    align-content: start;
  }
  body:has(.here-shell) .here-cell {
    min-height: 132px;
    border-radius: 0;
    border-color: rgba(247, 240, 227, 0.12);
    background: rgba(247, 240, 227, 0.055);
  }
  body:has(.here-shell) .here-cell--you {
    border-color: rgba(240, 198, 106, 0.7);
    background: linear-gradient(180deg, rgba(240, 198, 106, 0.18), rgba(247, 240, 227, 0.045));
  }
  body:has(.here-shell) .here-cell__noun {
    background: #f7f0e3;
  }
  body:has(.here-shell) .here-cell__chip {
    border-radius: 0;
    background: rgba(143, 198, 255, 0.13);
    color: #dbe7f4;
  }
  body:has(.here-shell) .here-cell__chip--mood {
    background: #50d890;
    color: #07130c;
  }
  body:has(.here-shell) .here-poll,
  body:has(.here-shell) .here-beat {
    min-height: 100%;
    padding: clamp(16px, 2vw, 22px);
    border-radius: 0;
    border-color: rgba(247, 240, 227, 0.14);
    background:
      linear-gradient(180deg, rgba(247, 240, 227, 0.07), rgba(247, 240, 227, 0.025)),
      rgba(8, 9, 12, 0.58);
    backdrop-filter: blur(18px);
  }
  body:has(.here-shell) .here-poll__q {
    color: #fffaf0;
    font-family: var(--pc-font-sans, Inter, system-ui, sans-serif);
    font-size: clamp(20px, 2vw, 28px);
    letter-spacing: 0;
  }
  body:has(.here-shell) .here-poll__dek,
  body:has(.here-shell) .here-beat__dek {
    color: #cad2de;
    font-family: var(--pc-font-sans, Inter, system-ui, sans-serif);
  }
  body:has(.here-shell) .here-poll__slug,
  body:has(.here-shell) .here-poll__opt-pct,
  body:has(.here-shell) .here-poll__followup-kicker,
  body:has(.here-shell) .here-poll__followup-link {
    color: #f0c66a;
  }
  body:has(.here-shell) .here-poll__opt {
    min-height: 46px;
    border-radius: 0;
    border-color: rgba(247, 240, 227, 0.13);
    background: rgba(247, 240, 227, 0.045);
    color: #f7f0e3;
    font-family: var(--pc-font-sans, Inter, system-ui, sans-serif);
  }
  body:has(.here-shell) .here-poll__opt:hover {
    border-color: rgba(143, 198, 255, 0.5);
    background: rgba(45, 93, 143, 0.22);
  }
  body:has(.here-shell) .here-poll__opt-bar {
    background: linear-gradient(90deg, rgba(80, 216, 144, 0.18), rgba(143, 198, 255, 0.22));
  }
  body:has(.here-shell) .here-poll__opt--voted {
    border-color: #50d890;
  }
  body:has(.here-shell) .here-poll__opt--voted .here-poll__opt-label::before {
    color: #50d890;
  }
  body:has(.here-shell) .here-poll__followup {
    border-radius: 0;
    border-color: rgba(240, 198, 106, 0.28);
    border-left-color: #50d890;
    background: rgba(240, 198, 106, 0.08);
  }
  body:has(.here-shell) .here-beat__pads {
    gap: 8px;
  }
  body:has(.here-shell) .here-beat__pad {
    min-height: 72px;
    border-radius: 0;
    border-color: rgba(247, 240, 227, 0.13);
    background: rgba(247, 240, 227, 0.05);
  }
  body:has(.here-shell) .here-beat__pad:hover {
    border-color: rgba(80, 216, 144, 0.5);
    background: rgba(80, 216, 144, 0.08);
  }
  @media (max-width: 640px) {
    body:has(.here-shell) .here-grid__cells {
      grid-template-columns: repeat(auto-fill, minmax(96px, 1fr));
    }
    body:has(.here-shell) .here-cell {
      min-height: 122px;
    }
    body:has(.here-shell) .here-cell__noun {
      width: 64px;
      height: 64px;
    }
  }
</style>
