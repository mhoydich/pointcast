---
/**
 * /here — full-page congregation view.
 *
 * Brief #7. "How this is a place to congregate, a schelling point."
 * A dark/amber page-scale counterpart to the VisitorHereStrip on the
 * home page. Renders HereGrid — up to ~64 currently-connected visitors
 * as noun avatars — in the shipped /tv visual language. Client-hydrated
 * from /api/presence/snapshot + the live WS.
 *
 * No block collection reads, no daily drop, no constellation. Just:
 * who's here, right now. If no other visitors are connected, shows a
 * small "waiting for peoples" line instead of hiding the page.
 *
 * Author: cc. Source: docs/briefs/2026-04-19-codex-here-congregation.md.
 * Codex shipped the backend (snapshot endpoint + DO refactor); cc
 * shipped the UI (HereGrid component + this page shell).
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import HereGrid from '../components/HereGrid.astro';
import HerePoll from '../components/HerePoll.astro';
import HereBeat from '../components/HereBeat.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: 'PointCast · here now',
  description: 'Live congregation view of visitors currently connected to pointcast.xyz.',
  url: 'https://pointcast.xyz/here',
  eventAttendanceMode: 'https://schema.org/OnlineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  startDate: new Date().toISOString(),
  location: {
    '@type': 'VirtualLocation',
    url: 'https://pointcast.xyz/here',
  },
  organizer: {
    '@type': 'Organization',
    name: 'PointCast',
    url: 'https://pointcast.xyz',
  },
};
---

<BlockLayout title="Here now" description="Live congregation — visitors currently connected to PointCast, as noun avatars." jsonLd={jsonLd}>
  <div class="here-shell">
    <nav class="here-crumb mono">
      <a href="/">← Home</a>
      <span aria-hidden="true">·</span>
      <a href="/tv">TV</a>
      <span aria-hidden="true">·</span>
      <a href="/for-agents">For agents</a>
    </nav>

    <header class="here-masthead">
      <p class="here-masthead__kicker mono">PC · HERE NOW · LIVE</p>
      <h1 class="here-masthead__title">The peoples, right now.</h1>
      <p class="here-masthead__intro">
        Every visitor — human, wallet, agent, bot — gets a noun avatar.
        This page shows everyone currently connected. Refresh-free; it
        updates as people arrive and leave.
      </p>
    </header>

    <HereGrid cap={64} />

    <HerePoll />

    <HereBeat />

    <aside class="here-agent-strip">
      <p class="here-agent-strip__label mono">MACHINE-READABLE</p>
      <ul>
        <li><a href="/api/presence/snapshot">/api/presence/snapshot</a> — current state, cached 5s</li>
        <li><a href="/api/presence">/api/presence</a> — live WS, identify + updates</li>
        <li><a href="/for-agents">/for-agents</a> — full manifest</li>
        <li><a href="/for-nodes">/for-nodes</a> — how to broadcast here</li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<style is:global>
  body:has(.here-shell) {
    background: #0b0b0b;
    color: #f3e6d8;
  }
</style>

<style>
  .here-shell {
    min-height: 100vh;
    padding: 24px 16px 80px;
    color: #f3e6d8;
    background: #0b0b0b;
    font-family: Georgia, 'Times New Roman', serif;
  }
  .here-crumb {
    max-width: 1100px;
    margin: 0 auto 20px;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9a8571;
  }
  .here-crumb a {
    color: #e89a2d;
    text-decoration: none;
    margin: 0 4px;
  }
  .here-crumb a:first-child { margin-left: 0; }
  .here-crumb span { opacity: 0.55; }
  .here-masthead {
    max-width: 1100px;
    margin: 0 auto 36px;
    padding: 0 4px;
  }
  .here-masthead__kicker {
    font-size: 12px;
    letter-spacing: 0.14em;
    color: #e89a2d;
    margin: 0 0 8px;
  }
  .here-masthead__title {
    font-family: Georgia, serif;
    font-size: 40px;
    line-height: 1.05;
    margin: 0 0 14px;
    font-weight: 700;
    color: #f3e6d8;
  }
  .here-masthead__intro {
    font-size: 16px;
    line-height: 1.55;
    max-width: 620px;
    color: #d4c2ad;
    margin: 0;
  }
  .here-agent-strip {
    max-width: 1100px;
    margin: 40px auto 0;
    padding: 16px 18px;
    background: rgba(243, 230, 216, 0.04);
    border: 1px solid rgba(232, 154, 45, 0.18);
    border-radius: 6px;
  }
  .here-agent-strip__label {
    font-size: 11px;
    letter-spacing: 0.14em;
    color: #e89a2d;
    margin: 0 0 8px;
  }
  .here-agent-strip ul {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 12px;
    color: #d4c2ad;
  }
  .here-agent-strip li { margin: 4px 0; }
  .here-agent-strip a { color: #e89a2d; text-decoration: none; }
  .mono { font-family: 'Monaco', 'Menlo', monospace; }
  @media (max-width: 720px) {
    .here-masthead__title { font-size: 30px; }
  }
</style>
