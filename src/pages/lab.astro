---
/**
 * /lab — Codex workspace-synced prototypes.
 *
 * Built 2026-04-21 during Sprint #92 follow-up after cc audited Codex's
 * app on Mike's Mac and discovered four substantive single-file HTML
 * prototypes sitting in `~/Documents/join us yee/pointcast-collabs-map-prototype/`
 * with no path to the live site. Sync script (scripts/sync-codex-workspace.mjs)
 * now pulls them to public/lab/ on demand; this page is the index that
 * makes them legible + linkable.
 *
 * Attribution: every prototype below was authored by Codex (GPT-5.4, Extra
 * High reasoning, full access) in the Codex desktop app between 2026-04-16
 * and 2026-04-21. cc's role is pipeline + editorial — the prototypes are
 * Codex's.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

interface Prototype {
  slug: string;
  name: string;
  tagline: string;
  description: string;
  builtBy: string;
  builtAt: string;
  lineCount?: number;
}

const PROTOTYPES: Prototype[] = [
  {
    slug: 'map',
    name: 'MAP',
    tagline: 'El Segundo collab constellation — see who\'s building what, where',
    description: 'A single-file HTML canvas that plots PointCast\'s collaborators as points on a map. Uses the live /collabs.json feed + per-collab position data. Hover a point, read their last ship. 756 lines, zero framework, no build step.',
    builtBy: 'Codex (GPT-5.4 Extra High)',
    builtAt: '~4 days ago',
    lineCount: 756,
  },
  {
    slug: 'arena',
    name: 'ARENA',
    tagline: 'Prompt-tournament playground for agent-on-agent drilling',
    description: 'Arena-style matchmaking experiment. Two agents (cc / codex / manus / chatgpt) are pitted against a shared prompt; visitors compare outputs side-by-side and vote. Pulls live presence + PointCast endpoints to show who\'s online. 3,557 lines — substantial single-file build.',
    builtBy: 'Codex (GPT-5.4 Extra High)',
    builtAt: '~3 hours ago',
    lineCount: 3557,
  },
  {
    slug: 'relay',
    name: 'RELAY',
    tagline: 'Live multi-agent relay — watch messages bounce between agents',
    description: 'A relay visualizer. Messages (from /api/ping or local input) pass through a chain of agents, each transforming the payload. Renders the relay graph live. Loads /agents.json + /api/presence for endpoint discovery. 2,771 lines.',
    builtBy: 'Codex (GPT-5.4 Extra High)',
    builtAt: '~3 hours ago',
    lineCount: 2771,
  },
  {
    slug: 'framecast',
    name: 'FRAMECAST',
    tagline: 'PointCast × GitHub repo signals → prompt/payload generator',
    description: 'Blends PointCast\'s editorial feed with signals from mhoydich/pointcast on GitHub (commit velocity, open PRs, language mix) and produces a prompt/payload fit for posting to other networks (Warpcast frames, Farcaster, etc.). Most speculative of the four. 1,962 lines.',
    builtBy: 'Codex (GPT-5.4 Extra High)',
    builtAt: '~3 hours ago',
    lineCount: 1962,
  },
];

const totalLines = PROTOTYPES.reduce((s, p) => s + (p.lineCount || 0), 0);

const title = '/lab — Codex-authored prototype surface';
const description = 'Four single-file HTML prototypes authored by Codex in its personal workspace, synced to the main repo via scripts/sync-codex-workspace.mjs. Arena + Relay + Map + Framecast — each zero-framework, zero-build, ready to run.';
---

<BlockLayout title={title} description={description}>
  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>lab</span>
    </nav>

    <header class="head">
      <p class="kicker mono">LAB · CODEX WORKSPACE → MAIN REPO</p>
      <h1 class="title">Four prototypes Codex built, now legible on the live site.</h1>
      <p class="dek">
        Until today, Codex's experimental prototypes lived in its personal workspace
        at <code class="mono">~/Documents/join us yee/pointcast-collabs-map-prototype/</code> and never
        reached pointcast.xyz. A remote-audit run (via cc + computer-use on Mike's Mac)
        surfaced the gap. A one-file sync script — <a href="https://github.com/mhoydich/pointcast/blob/main/scripts/sync-codex-workspace.mjs"><code class="mono">scripts/sync-codex-workspace.mjs</code></a> —
        now pulls them in under <code class="mono">/public/lab/*</code>, dry-run by default,
        newest-mtime wins, attribution preserved.
      </p>
      <p class="dek">
        Run <code class="mono">npm run sync:codex</code> to preview; <code class="mono">npm run sync:codex:apply</code> to write.
        Every synced batch emits a manifest to <code class="mono">docs/notes/codex-sync-manifest.json</code>
        which the compute ledger reads for attribution. Details in block 0377.
      </p>
      <ul class="stats">
        <li><span class="stats__num">{PROTOTYPES.length}</span><span class="stats__lbl mono">PROTOTYPES</span></li>
        <li><span class="stats__num">{totalLines.toLocaleString()}</span><span class="stats__lbl mono">LINES</span></li>
        <li><span class="stats__num">0</span><span class="stats__lbl mono">FRAMEWORKS</span></li>
        <li><span class="stats__num">0</span><span class="stats__lbl mono">BUILD STEP</span></li>
      </ul>
    </header>

    <section class="proto-grid" aria-label="Prototypes">
      {PROTOTYPES.map((p) => (
        <article class={`proto proto--${p.slug}`}>
          <header class="proto__head">
            <p class="proto__kicker mono">{p.name}</p>
            <p class="proto__meta mono">{p.builtBy} · {p.builtAt} · {p.lineCount?.toLocaleString()} lines</p>
          </header>
          <h2 class="proto__title">{p.tagline}</h2>
          <p class="proto__desc">{p.description}</p>
          <div class="proto__links">
            <a class="proto__open" href={`/lab/${p.slug}/`}>Open {p.name} →</a>
          </div>
        </article>
      ))}
    </section>

    <footer class="page__foot">
      <p class="foot__line mono">
        Codex workspace → main repo pipeline · shipped Sprint #92 follow-up ·
        <a href="/b/0377">block 0377</a> · <a href="/compute">/compute</a> shows full Codex attribution
      </p>
    </footer>
  </main>
</BlockLayout>

<style>
  .page { max-width: 960px; margin: 0 auto; padding: 20px 18px 60px; font-family: var(--pc-font-sans); }
  .crumb { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--pc-ink-muted); margin-bottom: 16px; }
  .crumb a { color: inherit; text-decoration: none; border-bottom: 1px solid var(--pc-rule); }
  .crumb a:hover { color: var(--pc-accent); }

  .head { margin-bottom: 28px; padding-bottom: 18px; border-bottom: 2px solid var(--pc-ink); }
  .kicker { font-size: 10px; letter-spacing: 0.22em; color: #8a2432; margin: 0 0 4px; font-weight: 700; }
  .title { font-family: 'DM Serif Display', 'Lora', Georgia, serif; font-size: 32px; line-height: 1.15; margin: 0 0 12px; color: var(--pc-ink); }
  .dek { font-family: Georgia, serif; font-size: 15px; line-height: 1.55; color: #38373A; margin: 0 0 10px; max-width: 720px; }
  .dek code { background: rgba(18, 17, 14, 0.06); padding: 1px 5px; border-radius: 2px; font-size: 12.5px; }
  .dek a { color: #8a2432; }

  .stats { list-style: none; padding: 0; margin: 18px 0 0; display: flex; gap: 22px; flex-wrap: wrap; }
  .stats li { display: flex; flex-direction: column; }
  .stats__num { font-family: var(--pc-font-mono); font-size: 24px; font-weight: 700; color: var(--pc-accent); line-height: 1; }
  .stats__lbl { font-size: 9.5px; letter-spacing: 0.14em; color: var(--pc-ink-muted); margin-top: 3px; }

  .proto-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 0 0 36px;
  }
  @media (max-width: 680px) { .proto-grid { grid-template-columns: 1fr; } }

  .proto {
    border: 1px solid var(--pc-rule);
    border-top: 4px solid var(--pc-ink);
    border-radius: 2px;
    padding: 14px 16px 16px;
    background: #fffdfa;
    display: flex;
    flex-direction: column;
  }
  .proto--map       { border-top-color: #2f8f5f; }
  .proto--arena     { border-top-color: #8a2432; }
  .proto--relay     { border-top-color: #185FA5; }
  .proto--framecast { border-top-color: #F59F00; }

  .proto__head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; padding-bottom: 6px; border-bottom: 1px dashed var(--pc-rule-soft); flex-wrap: wrap; gap: 6px; }
  .proto__kicker { font-size: 11px; letter-spacing: 0.22em; color: var(--pc-ink); font-weight: 700; margin: 0; }
  .proto__meta { font-size: 9.5px; letter-spacing: 0.08em; color: var(--pc-ink-muted); margin: 0; }
  .proto__title { font-family: 'DM Serif Display', 'Lora', Georgia, serif; font-size: 19px; line-height: 1.25; margin: 0 0 8px; color: var(--pc-ink); }
  .proto__desc { font-family: Georgia, serif; font-size: 13.5px; line-height: 1.45; color: #38373A; margin: 0 0 14px; flex: 1; }
  .proto__links { margin-top: auto; }
  .proto__open {
    display: inline-block;
    padding: 7px 12px;
    background: var(--pc-ink);
    color: #fef5e7;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.14s ease;
  }
  .proto__open:hover { background: var(--pc-accent); }

  .page__foot { margin-top: 24px; padding-top: 14px; border-top: 1px dotted var(--pc-rule); }
  .foot__line { font-size: 10px; letter-spacing: 0.08em; color: var(--pc-ink-muted); margin: 0; }
  .foot__line a { color: #8a2432; text-decoration: underline; }
</style>
