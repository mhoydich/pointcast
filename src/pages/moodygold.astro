---
import BlockLayout from '../layouts/BlockLayout.astro';
import { getPointcastApp } from '../lib/pointcast-apps';

const app = getPointcastApp('moodygold')!;
const title = app.name;
const description = app.description;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': 'https://pointcast.xyz/moodygold',
  name: app.name,
  description,
  url: 'https://pointcast.xyz/moodygold',
  sameAs: [app.url, app.repo],
};
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="app-page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/apps">apps</a>
      <span aria-hidden="true">/</span>
      <span>moodygold</span>
    </nav>
    <header class="bar">
      <div>
        <p>{app.channel} · {app.kicker}</p>
        <h1>{app.name}</h1>
      </div>
      <div class="actions">
        <a href={app.url} target="_blank" rel="noopener">Open direct</a>
        <a href={app.repo} target="_blank" rel="noopener">Repo</a>
      </div>
    </header>
    <iframe title="MoodyGold app" src={app.url} loading="eager" referrerpolicy="no-referrer-when-downgrade"></iframe>
  </main>
</BlockLayout>

<style>
  .app-page { min-height: calc(100vh - 60px); display: grid; grid-template-rows: auto auto 1fr; padding: 12px; gap: 10px; }
  .crumb, .bar p, .actions a { font-family: var(--pc-font-mono); letter-spacing: 0.1em; text-transform: uppercase; }
  .crumb { display: flex; gap: 8px; font-size: 10px; color: var(--pc-ink-muted); }
  .bar { display: flex; justify-content: space-between; gap: 14px; align-items: end; border: 1px solid var(--pc-rule-soft); padding: 10px 12px; }
  .bar p { margin: 0 0 4px; font-size: 10px; color: #8A2432; }
  h1 { margin: 0; font-size: clamp(28px, 5vw, 52px); line-height: 0.95; font-weight: 500; }
  .actions { display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
  .actions a { border: 1px solid var(--pc-ink); color: var(--pc-ink); padding: 8px 10px; font-size: 10px; }
  .actions a:hover { background: var(--pc-ink); color: #fff; text-decoration: none; }
  iframe { width: 100%; height: 100%; min-height: 72vh; border: 1px solid var(--pc-ink); background: #111; }
  @media (max-width: 720px) {
    .bar { align-items: start; flex-direction: column; }
    .actions { justify-content: start; }
    iframe { min-height: 78vh; }
  }
</style>
