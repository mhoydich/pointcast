---
/**
 * /room — the listening room. A companion for a PointCast mix.
 *
 * Sibling to /tonight (which is a single-song vibe). /room is where
 * the playlist plays — the whole hour-long mix. Mike 2026-04-24:
 * "companion for https://open.spotify.com/playlist/70fhAntBCL9jp5VxH8BK5L"
 *
 * The playlist is ✨🙌✨ — 10 tracks, 1h 11m: Blinded By Your Grace
 * (Katherine Jenkins), Pachelbel's Canon, Donna McKevitt, Thompson
 * Twins "Hold Me Now", Sun Ra "Door of the Cosmos", and more. A
 * reverent + eclectic listening room.
 *
 * Clock-tinted background like /tonight. Cozy copy. Tracklist
 * intentionally spare — Spotify does the track display itself.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const PLAYLIST_ID = '70fhAntBCL9jp5VxH8BK5L';
const title = '/room — a listening room for the mix';
const description =
  'Press play. 10 tracks, 1h 11m. Katherine Jenkins, Pachelbel, Donna McKevitt, Thompson Twins, Sun Ra, and the spaces between. A reverent, eclectic room-mix curated by Mike.';
---

<BlockLayout title={title} description={description}>
  <main class="room" id="room-main">
    <div class="room__frame">
      <header class="room__head">
        <p class="room__kicker mono">ROOM · ✨🙌✨ · MIX · EL SEGUNDO</p>
        <h1 class="room__title">Press play. Stay a while.</h1>
        <p class="room__dek">
          Ten tracks. An hour and eleven minutes. Starts at
          <em>Blinded By Your Grace</em> with Katherine Jenkins,
          passes through Pachelbel's canon and Donna McKevitt,
          lands on Thompson Twins, ends somewhere near Sun Ra's
          door of the cosmos. Put it on. Walk around. Fix something.
        </p>
      </header>

      <section class="room__player" aria-label="The mix">
        <iframe
          src={`https://open.spotify.com/embed/playlist/${PLAYLIST_ID}?utm_source=pointcast`}
          width="100%"
          height="420"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
          title="PointCast room — mhoydich's ✨🙌✨ mix"
        />
        <p class="room__credit mono">
          10 TRACKS · 1H 11M · CURATED BY MHOYDICH
        </p>
      </section>

      <section class="room__texture">
        <p>
          Rooms have moods, not setlists. This one is the mix for when
          the marine layer holds past noon and the afternoon softens.
          The Pachelbel is the hinge. The Thompson Twins is the kindness.
          Sun Ra is the door you leave through, not the door you arrive at.
        </p>
        <p>
          <em>Blinded by your grace</em> — the line lands like a benediction
          two minutes in. If the room feels right, stay another lap. If it
          doesn't, the mix doesn't mind. Pass through.
        </p>
      </section>

      <nav class="room__links" aria-label="Other rooms">
        <a class="room__link room__link--primary" href="/tonight">
          <span class="room__link-label mono">/TONIGHT</span>
          <span class="room__link-desc">the single-song room · Kid Francescoli · marine layer</span>
        </a>
        <a class="room__link" href="/meditate">
          <span class="room__link-label mono">/MEDITATE</span>
          <span class="room__link-desc">the ocean room · timed breathing</span>
        </a>
        <a class="room__link" href="/gandalf">
          <span class="room__link-label mono">/GANDALF</span>
          <span class="room__link-desc">the hearth room · companion + keepsake</span>
        </a>
        <a class="room__link" href="/bath">
          <span class="room__link-label mono">/BATH</span>
          <span class="room__link-desc">the color-wave room · four moods, four fields</span>
        </a>
        <a class="room__link" href="/">
          <span class="room__link-label mono">/</span>
          <span class="room__link-desc">back to the broadcast</span>
        </a>
      </nav>

      <footer class="room__foot mono">
        <span>on air · el segundo · fm 96.1 · cc0</span>
        <span class="room__time" id="room-clock">—</span>
      </footer>
    </div>
  </main>
</BlockLayout>

<script is:inline>
  (function () {
    'use strict';
    // Tint the room by clock hour, sibling behavior to /tonight.
    function paint() {
      var now = new Date();
      var h = now.getHours() + now.getMinutes() / 60;
      var root = document.getElementById('room-main');
      if (!root) return;
      var hue, sat, light;
      if (h < 6)           { hue = 240; sat = 22; light = 14; }
      else if (h < 10)     { hue = 38;  sat = 52; light = 80; }
      else if (h < 14)     { hue = 48;  sat = 40; light = 84; }
      else if (h < 17)     { hue = 34;  sat = 52; light = 74; }
      else if (h < 19)     { hue = 22;  sat = 58; light = 66; }
      else if (h < 21)     { hue = 260; sat = 34; light = 30; }
      else                 { hue = 240; sat = 30; light = 18; }
      var bg1 = 'hsl(' + hue + ',' + sat + '%,' + light + '%)';
      var bg2 = 'hsl(' + (hue + 24) + ',' + (sat - 10) + '%,' + Math.max(6, light - 12) + '%)';
      root.style.background = 'linear-gradient(180deg,' + bg1 + ' 0%,' + bg2 + ' 100%)';
      root.classList.toggle('room--dark', light < 50);

      var clock = document.getElementById('room-clock');
      if (clock) {
        var hh = String(now.getHours()).padStart(2, '0');
        var mm = String(now.getMinutes()).padStart(2, '0');
        clock.textContent = hh + ':' + mm + ' PT';
      }
    }
    paint();
    setInterval(paint, 60 * 1000);
  })();
</script>

<style>
  .room {
    min-height: calc(100vh - 60px);
    padding: 40px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, #f4ecd6 0%, #d9b97a 100%);
    color: #1a140e;
    transition: background 2s ease, color 1s ease;
  }
  .room--dark { color: #fdf2d6; }

  .room__frame {
    max-width: 680px;
    width: 100%;
    padding: 36px 32px;
    background: rgba(255, 253, 250, 0.08);
    border: 1px solid rgba(18, 17, 14, 0.08);
    border-radius: 2px;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .room--dark .room__frame {
    background: rgba(18, 17, 14, 0.28);
    border-color: rgba(254, 245, 231, 0.14);
  }

  .room__head { margin-bottom: 24px; }
  .room__kicker {
    font-size: 10px;
    letter-spacing: 0.26em;
    font-weight: 700;
    margin: 0 0 10px;
    opacity: 0.78;
  }
  .room__title {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: clamp(30px, 4.5vw, 44px);
    line-height: 1.08;
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }
  .room__dek {
    font-family: Georgia, serif;
    font-size: 16px;
    line-height: 1.55;
    margin: 0;
    opacity: 0.92;
  }
  .room__dek em { font-style: italic; }

  .room__player { margin: 28px 0 20px; }
  .room__player iframe {
    display: block;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.25);
    width: 100%;
  }
  .room__credit {
    font-size: 10px;
    letter-spacing: 0.18em;
    margin: 10px 0 0;
    opacity: 0.72;
  }

  .room__texture { margin: 24px 0 28px; font-family: Georgia, serif; font-size: 15px; line-height: 1.6; }
  .room__texture p { margin: 0 0 14px; opacity: 0.92; }
  .room__texture p:last-child { margin-bottom: 0; }
  .room__texture em { font-style: italic; }

  .room__links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 10px;
    margin: 0 0 24px;
  }
  .room__link {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 10px 12px;
    background: rgba(255, 253, 250, 0.5);
    border: 1px solid rgba(18, 17, 14, 0.14);
    border-radius: 2px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .room--dark .room__link {
    background: rgba(18, 17, 14, 0.35);
    border-color: rgba(254, 245, 231, 0.14);
  }
  .room__link:hover { transform: translateY(-1px); border-color: rgba(245, 159, 0, 0.8); }
  .room__link--primary { border-color: rgba(245, 159, 0, 0.55); }
  .room__link-label { font-size: 11px; letter-spacing: 0.14em; font-weight: 700; }
  .room__link-desc { font-size: 11.5px; font-family: Georgia, serif; opacity: 0.85; line-height: 1.4; }

  .room__foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 10px;
    letter-spacing: 0.18em;
    padding-top: 16px;
    border-top: 1px dashed rgba(18, 17, 14, 0.16);
    opacity: 0.78;
  }
  .room--dark .room__foot { border-top-color: rgba(254, 245, 231, 0.14); }

  @media (max-width: 520px) {
    .room { padding: 24px 14px; }
    .room__frame { padding: 24px 18px; }
    .room__title { font-size: 28px; }
  }
</style>
