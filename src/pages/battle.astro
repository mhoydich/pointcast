---
/**
 * /battle — Nouns Battler arena.
 *
 * Single-page interactive battler. Two fighters (Card of the Day vs.
 * Challenger), full best-of-3 resolver, all client-side + deterministic.
 *
 * Phase 2 (this file): choose-your-challenger via seed input, run a match,
 * persist/export the result locally, see the log. Phase 3 adds the
 * commemorative mint on Visit Nouns FA2.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import { CHANNELS } from '../lib/channels';
import { pickCardOfTheDay } from '../lib/battler/card-of-the-day';

const ch = CHANNELS.BTL;

// Card of the Day — rotates deterministically by UTC date via the
// curated roster in src/lib/battler/card-of-the-day.ts. Same day → same
// card, across humans and agents. Phase 2 swap from hardcoded Noun 137.
const card = pickCardOfTheDay();
const CARD_OF_THE_DAY = card.id;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Nouns Battler',
  description: 'Deterministic turn-based battler where every Nouns seed is a fighter.',
  applicationCategory: 'GameApplication',
  operatingSystem: 'Any (browser)',
  url: 'https://pointcast.xyz/battle',
};
---

<BlockLayout title="Nouns Battler" description="Deterministic Nouns duels. Every match is a block." image="/images/og/battle.png" jsonLd={jsonLd}>
  <div class="page" style={`--ch-600: ${ch.color600}; --ch-800: ${ch.color800}; --ch-50: ${ch.color50};`}>
    <nav class="crumb">
      <a href="/">← Home</a>
      <span aria-hidden="true">/</span>
      <a href={`/c/${ch.slug}`} style={`color: ${ch.color800}`}>CH.{ch.code} · Battler</a>
    </nav>

    <header class="head">
      <p class="kicker">CH.BTL · NOUNS BATTLER · v1 PHASE 2</p>
      <h1>Every Nouns seed is a fighter.</h1>
      <p class="dek">
        Stats derive from the five trait slots. Two types per Noun — head picks
        primary, glasses pick secondary. <strong>No RNG.</strong> Same seed →
        same stats forever. Same match inputs → same outcome forever.
      </p>
      <div class="card-banner">
        <div class="card-banner__img">
          <img src={`https://noun.pics/${card.id}.svg`} alt={`Card of the Day — Noun ${card.id}`} />
        </div>
        <div class="card-banner__meta">
          <p class="card-banner__kicker">CARD OF THE DAY · {card.dateLabel.toUpperCase()}</p>
          <p class="card-banner__id">Noun #{card.id}</p>
          <p class="card-banner__note">{card.note}</p>
          <p class="card-banner__rotation mono">
            DAY {card.rosterIndex + 1} OF 21 · ROTATION DETERMINISTIC · <a href="/battle.json">/battle.json</a>
          </p>
        </div>
      </div>
    </header>

    <main class="match" id="match">
      <div class="match__header mono">
        <span class="match__code">CH.BTL · 0000-<span id="match-id">—</span></span>
        <span class="match__meta" id="match-round">ROUND 0 / 3</span>
      </div>

      <section class="arena">
        <article class="fighter" id="fighter-a">
          <div class="port"><img id="port-a" src={`https://noun.pics/${CARD_OF_THE_DAY}.svg`} alt="Card of the Day Noun" /></div>
          <h2>Card of the Day · Noun #<span data-field="id">{CARD_OF_THE_DAY}</span></h2>
          <div class="types" data-field="types"></div>
          <div class="hp"><span class="hp__label">HP</span><div class="hp__bar"><span data-field="hp-bar" style="width:100%"></span></div><span data-field="hp">—</span></div>
          <div class="stats">
            <div class="stat"><span class="k">ATK</span><span class="v" data-field="atk">—</span><span class="stat__bar"><span data-field="atk-bar" style="width:0%"></span></span></div>
            <div class="stat"><span class="k">DEF</span><span class="v" data-field="def">—</span><span class="stat__bar"><span data-field="def-bar" style="width:0%"></span></span></div>
            <div class="stat"><span class="k">SPD</span><span class="v" data-field="spd">—</span><span class="stat__bar"><span data-field="spd-bar" style="width:0%"></span></span></div>
            <div class="stat"><span class="k">FOC</span><span class="v" data-field="foc">—</span><span class="stat__bar"><span data-field="foc-bar" style="width:0%"></span></span></div>
          </div>
        </article>

        <article class="fighter" id="fighter-b">
          <div class="port"><img id="port-b" src={`https://noun.pics/420.svg`} alt="Challenger Noun" /></div>
          <h2>
            Challenger · Noun #<span data-field="id">420</span>
            <button type="button" class="roll" id="btn-roll" title="Roll a random challenger">↻</button>
          </h2>
          <div class="types" data-field="types"></div>
          <div class="hp"><span class="hp__label">HP</span><div class="hp__bar"><span data-field="hp-bar" style="width:100%"></span></div><span data-field="hp">—</span></div>
          <div class="stats">
            <div class="stat"><span class="k">ATK</span><span class="v" data-field="atk">—</span><span class="stat__bar"><span data-field="atk-bar" style="width:0%"></span></span></div>
            <div class="stat"><span class="k">DEF</span><span class="v" data-field="def">—</span><span class="stat__bar"><span data-field="def-bar" style="width:0%"></span></span></div>
            <div class="stat"><span class="k">SPD</span><span class="v" data-field="spd">—</span><span class="stat__bar"><span data-field="spd-bar" style="width:0%"></span></span></div>
            <div class="stat"><span class="k">FOC</span><span class="v" data-field="foc">—</span><span class="stat__bar"><span data-field="foc-bar" style="width:0%"></span></span></div>
          </div>
          <label class="seed-select mono">
            Challenger seed <input id="seed-input" type="number" min="0" max="9999" value="420" />
          </label>
        </article>
      </section>

      <section class="result-banner" id="result-banner" hidden>
        <div class="result-banner__flourish mono" id="result-flourish">+++ GLORY +++</div>
        <h2 id="result-headline">Noun #137 Wins</h2>
        <p class="result-banner__score" id="result-score">Noun #137 wins 2-1</p>
        <p class="result-banner__sub" id="result-sub">Hard read. Clean finish.</p>
        <div class="result-banner__actions">
          <button class="btn btn--arcade" id="btn-rematch" type="button">REMATCH</button>
          <button class="btn btn--arcade" id="btn-new" type="button">NEW CHALLENGER</button>
          <button class="btn btn--arcade btn--arcade-alt" id="btn-share" type="button">SHARE</button>
        </div>
      </section>

      <section class="log" id="log">
        <div class="log__head mono">LOG</div>
        <div class="log__body" id="log-body">
          <div class="log__line">Pick a stance to start round 1.</div>
        </div>
      </section>

      <div class="actions">
        <div class="actions__buttons">
          <button class="btn" data-stance="STRIKE">STRIKE</button>
          <button class="btn" data-stance="GUARD">GUARD</button>
          <button class="btn" data-stance="FOCUS">FOCUS</button>
        </div>
        <div class="actions__tools">
          <button class="btn btn--ghost btn--small" id="btn-record" hidden>RECORD THIS MATCH</button>
          <button class="btn btn--ghost" id="btn-reset">RESET</button>
        </div>
      </div>

      <div class="archive">
        <div class="archive__head mono">
          <span>LOCAL MATCH LOG · LAST 50</span>
          <a href="/battle-log">open full log →</a>
        </div>
        <div class="archive__body" id="match-archive">
          <div class="archive__empty">No completed matches recorded yet.</div>
        </div>
      </div>

      <div class="match__footer mono">
        <span>NOUNS BATTLER · PHASE 2 · NO RNG · NO HIDDEN STATE</span>
        <span>CH.BTL · CODEX DESIGN · CC BUILD</span>
      </div>
    </main>

    <aside class="agent-strip">
      <p class="agent-strip__label">MACHINE-READABLE</p>
      <ul>
        <li><a href={`/c/${ch.slug}`}>/c/{ch.slug}</a></li>
        <li><a href={`/c/${ch.slug}.json`}>/c/{ch.slug}.json</a></li>
        <li><a href={`/c/${ch.slug}.rss`}>/c/{ch.slug}.rss</a></li>
        <li><a href="/battle.json">/battle.json</a></li>
        <li><a href="/for-agents">/for-agents</a></li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<script>
  import { seedToStats, type FighterStats } from '../lib/battler/stat-derivation';
  import { resolveMatch, type Stance } from '../lib/battler/resolve';

  const CARD_OF_THE_DAY = 137;
  const MATCH_LOG_KEY = 'pc:battler-matches';

  const TYPE_COLOR: Record<string, string> = {
    WATER: '#1d8cb8', BEAM: '#b3278e', ARMOR: '#4a4e54', WILD: '#2e7a2e', FEAST: '#b67b10',
  };

  interface State {
    cardOfDay: FighterStats;
    challenger: FighterStats;
    rounds: { a: Stance | null; b: Stance | null }[];
    round: number;       // next round index (0, 1, 2)
    done: boolean;
  }

  type MatchWinner = 'A' | 'B' | 'DRAW';
  type MatchRoundExport = [Stance, Stance, number, number];

  interface MatchRecord {
    matchId: string;
    cardOfDayId: number;
    challengerId: number;
    rounds: MatchRoundExport[];
    winner: MatchWinner;
    timestamp: string;
  }

  let state: State;
  let completedMatch: MatchRecord | null = null;
  let activeCardId = CARD_OF_THE_DAY;
  let activeChallengerId = 420;

  function clampSeed(value: number, fallback: number) {
    if (!Number.isFinite(value)) return fallback;
    return Math.max(0, Math.min(9999, Math.floor(value)));
  }

  function initMatch(cardId: number, challengerId: number) {
    activeCardId = clampSeed(cardId, CARD_OF_THE_DAY);
    activeChallengerId = clampSeed(challengerId, 420);
    state = {
      cardOfDay: seedToStats(activeCardId),
      challenger: seedToStats(activeChallengerId),
      rounds: [],
      round: 0,
      done: false,
    };
    completedMatch = null;
    const resultBanner = document.getElementById('result-banner')!;
    resultBanner.hidden = true;
    render();
    renderArchive();
    setRecordButton();
    document.getElementById('match-id')!.textContent = `${String(activeCardId).padStart(4, '0')}v${String(activeChallengerId).padStart(4, '0')}`;
    const body = document.getElementById('log-body')!;
    body.innerHTML = '<div class="log__line">Pick a stance to start round 1.</div>';
    (document.getElementById('seed-input') as HTMLInputElement).value = String(activeChallengerId);
    (document.getElementById('port-a') as HTMLImageElement).src = `https://noun.pics/${activeCardId}.svg`;
    (document.getElementById('port-b') as HTMLImageElement).src = `https://noun.pics/${activeChallengerId}.svg`;
    setRound();
  }

  function render() {
    fill('fighter-a', state.cardOfDay, state.cardOfDay.HP, state.cardOfDay.HP);
    fill('fighter-b', state.challenger, state.challenger.HP, state.challenger.HP);
  }

  function renderTypeChart(type: string) {
    return `
      <span class="type-pill" style="background-color:${TYPE_COLOR[type] || '#888'}">${type}</span>
      <button class="type-help" type="button" aria-label="Type advantage chart">?</button>
      <span class="type-chart" role="tooltip">
        <strong>${type}</strong>
        <span>STRIKE beats FOCUS</span>
        <span>GUARD beats STRIKE</span>
        <span>FOCUS beats GUARD</span>
      </span>
    `;
  }

  function setStatBar(root: HTMLElement, key: 'atk' | 'def' | 'spd' | 'foc', value: number) {
    const bar = root.querySelector(`[data-field="${key}-bar"]`) as HTMLElement;
    bar.style.width = `${(value / Math.max(value, 100)) * 100}%`;
  }

  function flashDamage(root: HTMLElement, previousHp: number, currentHp: number) {
    if (currentHp >= previousHp) return;
    root.classList.remove('fighter--hit');
    window.requestAnimationFrame(() => root.classList.add('fighter--hit'));
  }

  function fill(rootId: string, f: FighterStats, currentHp: number, previousHp: number) {
    const root = document.getElementById(rootId)!;
    root.querySelector('[data-field="id"]')!.textContent = String(f.id);
    root.querySelector('[data-field="atk"]')!.textContent = String(f.ATK);
    root.querySelector('[data-field="def"]')!.textContent = String(f.DEF);
    root.querySelector('[data-field="spd"]')!.textContent = String(f.SPD);
    root.querySelector('[data-field="foc"]')!.textContent = String(f.FOC);
    setStatBar(root, 'atk', f.ATK);
    setStatBar(root, 'def', f.DEF);
    setStatBar(root, 'spd', f.SPD);
    setStatBar(root, 'foc', f.FOC);
    const typeHost = root.querySelector('[data-field="types"]') as HTMLElement;
    typeHost.innerHTML = '';
    f.types.forEach((t) => {
      const chip = document.createElement('span');
      chip.className = 'type-chip';
      chip.innerHTML = renderTypeChart(t);
      typeHost.appendChild(chip);
    });
    const hpText = root.querySelector('[data-field="hp"]') as HTMLElement;
    hpText.textContent = `${currentHp} / ${f.HP}`;
    const bar = root.querySelector('[data-field="hp-bar"]') as HTMLElement;
    bar.style.width = Math.max(0, (currentHp / f.HP) * 100) + '%';
    flashDamage(root, previousHp, currentHp);
  }

  function setRound() {
    document.getElementById('match-round')!.textContent = `ROUND ${Math.min(state.round + 1, 3)} / 3` + (state.done ? ' · DONE' : '');
  }

  function log(line: string, cls: string = '') {
    const body = document.getElementById('log-body')!;
    const el = document.createElement('div');
    el.className = 'log__line' + (cls ? ' log__line--' + cls : '');
    el.textContent = line;
    body.appendChild(el);
    body.scrollTop = body.scrollHeight;
  }

  function getOutcomeLabel(round: NonNullable<ReturnType<typeof resolveMatch>['rounds'][number]>) {
    if (round.damageA >= Math.max(24, round.damageB + 12)) return 'CRIT';
    if (round.damageA <= 1 && round.damageB <= 1) return 'MISS';
    if (round.damageA <= 2 && round.damageB > round.damageA) return 'BLOCKED';
    if (round.damageB >= Math.max(12, round.damageA + 4)) return 'COUNTER';
    if (round.damageA > round.damageB) return 'CLEAN HIT';
    return 'MISS';
  }

  function logRound(round: NonNullable<ReturnType<typeof resolveMatch>['rounds'][number]>) {
    const body = document.getElementById('log-body')!;
    const wrap = document.createElement('div');
    wrap.className = 'log__round';

    const call = document.createElement('div');
    call.className = 'log__call mono';
    call.textContent = getOutcomeLabel(round);

    const detail = document.createElement('div');
    detail.className = 'log__line';
    detail.textContent = round.log;

    wrap.append(call, detail);
    body.appendChild(wrap);
    body.scrollTop = body.scrollHeight;
  }

  function readMatchLog(): MatchRecord[] {
    try {
      const raw = localStorage.getItem(MATCH_LOG_KEY);
      if (!raw) return [];
      const parsed = JSON.parse(raw);
      return Array.isArray(parsed) ? parsed : [];
    } catch {
      return [];
    }
  }

  function renderArchive() {
    const host = document.getElementById('match-archive')!;
    const matches = readMatchLog();
    host.innerHTML = '';

    if (matches.length === 0) {
      host.innerHTML = '<div class="archive__empty">No completed matches recorded yet.</div>';
      return;
    }

    matches.forEach((match) => {
      const item = document.createElement('article');
      item.className = 'archive__item';

      const head = document.createElement('div');
      head.className = 'archive__item-head mono';
      head.textContent = `${match.matchId} · ${match.winner} · ${new Date(match.timestamp).toLocaleString()}`;

      const meta = document.createElement('div');
      meta.className = 'archive__item-meta';
      meta.textContent = `#${match.cardOfDayId} vs #${match.challengerId} · ${match.rounds.length} rounds`;

      item.append(head, meta);
      host.appendChild(item);
    });
  }

  function setRecordButton() {
    const btn = document.getElementById('btn-record') as HTMLButtonElement;
    btn.hidden = !completedMatch;
    btn.disabled = !completedMatch;
  }

  function makeMatchRecord(result: ReturnType<typeof resolveMatch>): MatchRecord {
    const timestamp = new Date().toISOString();
    const stamp = timestamp.replace(/[:.]/g, '-');
    const winner: MatchWinner = result.winner === 'a' ? 'A' : result.winner === 'b' ? 'B' : 'DRAW';

    return {
      matchId: `${String(result.a.id).padStart(4, '0')}v${String(result.b.id).padStart(4, '0')}-${stamp}`,
      cardOfDayId: result.a.id,
      challengerId: result.b.id,
      rounds: result.rounds.map((round) => [round.stanceA, round.stanceB, round.damageA, round.damageB]),
      winner,
      timestamp,
    };
  }

  function scoreMatch(result: ReturnType<typeof resolveMatch>) {
    return result.rounds.reduce((acc, round) => {
      if (round.winner === 'a') acc.a += 1;
      else if (round.winner === 'b') acc.b += 1;
      else acc.draws += 1;
      return acc;
    }, { a: 0, b: 0, draws: 0 });
  }

  function renderResultBanner(result: ReturnType<typeof resolveMatch>) {
    const banner = document.getElementById('result-banner')!;
    const flourish = document.getElementById('result-flourish')!;
    const headline = document.getElementById('result-headline')!;
    const score = document.getElementById('result-score')!;
    const sub = document.getElementById('result-sub')!;
    const tally = scoreMatch(result);

    if (result.winner === 'draw') {
      flourish.textContent = '+++ DEAD EVEN +++';
      headline.textContent = `DRAW · ${tally.a}-${tally.b}-${tally.draws}`;
      score.textContent = `Final HP ${result.finalHpA}-${result.finalHpB}`;
      sub.textContent = 'Both stood their ground.';
    } else {
      const winner = result.winner === 'a' ? result.a : result.b;
      const loserRounds = result.winner === 'a' ? tally.b : tally.a;
      const winnerRounds = result.winner === 'a' ? tally.a : tally.b;
      flourish.textContent = '+++ GLORY TO THE WINNER +++';
      headline.textContent = `Noun #${winner.id} WINS`;
      score.textContent = `Noun #${winner.id} wins ${winnerRounds}-${loserRounds}${tally.draws ? `-${tally.draws}` : ''}`;
      sub.textContent = `Final HP ${result.finalHpA}-${result.finalHpB}. Cabinet stays hot.`;
    }

    banner.hidden = false;
  }

  async function shareCurrentMatch() {
    const url = `${window.location.origin}/battle?card=${activeCardId}&challenger=${activeChallengerId}`;
    const btn = document.getElementById('btn-share') as HTMLButtonElement;
    try {
      await navigator.clipboard.writeText(url);
      btn.textContent = 'COPIED';
      window.setTimeout(() => { btn.textContent = 'SHARE'; }, 1200);
    } catch {
      btn.textContent = 'COPY FAIL';
      window.setTimeout(() => { btn.textContent = 'SHARE'; }, 1200);
    }
  }

  function playRound(stance: Stance) {
    if (state.done) return;
    // Challenger stance derives from CHARACTER (stats), not modular id rotation.
    // Pick the stance matching the challenger's highest stat — ATK→STRIKE,
    // DEF→GUARD, FOC→FOCUS — and rotate to second-best on round 2, third on 3.
    // Still fully deterministic (same fighter → same sequence), but the read
    // is "challenger is ATK-heavy so they'll STRIKE first" — which is
    // strategic information the player has from the stat pane, not a
    // solve-in-two-replays pattern.
    // (Per Codex review 2026-04-17-battler-phase-1-review.md spec dev #2.)
    const stanceForStat: Record<'ATK' | 'DEF' | 'FOC', Stance> = {
      ATK: 'STRIKE',
      DEF: 'GUARD',
      FOC: 'FOCUS',
    };
    const statRanking = (['ATK', 'DEF', 'FOC'] as const)
      .map((k) => ({ k, v: state.challenger[k] }))
      .sort((a, b) => b.v - a.v);
    const bStance: Stance = stanceForStat[statRanking[state.round % 3].k];

    state.rounds.push({ a: stance, b: bStance });
    state.round += 1;

    const picks = state.rounds.filter(r => r.a && r.b).map(r => ({ a: r.a as Stance, b: r.b as Stance }));
    // Pad with strikes so resolveMatch runs against whatever's been played so far.
    while (picks.length < state.round) picks.push({ a: 'STRIKE', b: 'STRIKE' });
    const result = resolveMatch(state.cardOfDay, state.challenger, picks);

    // Render fresh HP bars with the outcome at this cumulative round.
    const roundResult = result.rounds[state.round - 1];
    if (roundResult) {
      const prevHpA = state.round > 1 ? result.rounds[state.round - 2].hpA : state.cardOfDay.HP;
      const prevHpB = state.round > 1 ? result.rounds[state.round - 2].hpB : state.challenger.HP;
      fill('fighter-a', state.cardOfDay, roundResult.hpA, prevHpA);
      fill('fighter-b', state.challenger, roundResult.hpB, prevHpB);
      logRound(roundResult);
      if (roundResult.hpA === 0 || roundResult.hpB === 0 || state.round >= 3) {
        state.done = true;
        const winner = result.winner === 'a' ? `Card of the Day (#${state.cardOfDay.id})`
          : result.winner === 'b' ? `Challenger (#${state.challenger.id})`
          : 'DRAW';
        log(`— MATCH END — winner: ${winner}`, 'win');
        renderResultBanner(result);
        completedMatch = makeMatchRecord(result);
        persistMatch(completedMatch);
        renderArchive();
        setRecordButton();
      }
    }
    setRound();
  }

  /**
   * Persist the finished match to localStorage under `pc:battler-matches`.
   * Keeps only the most recent 50 so local state stays bounded.
   */
  function persistMatch(record: MatchRecord) {
    try {
      const arr = readMatchLog();
      arr.unshift(record);
      localStorage.setItem(MATCH_LOG_KEY, JSON.stringify(arr.slice(0, 50)));
    } catch {}
  }

  function exportMatch(record: MatchRecord) {
    const blob = new Blob([JSON.stringify(record, null, 2)], {
      type: 'application/json;charset=utf-8',
    });
    const url = URL.createObjectURL(blob);
    const anchor = document.createElement('a');
    anchor.href = url;
    anchor.download = `${record.matchId}.json`;
    anchor.click();
    setTimeout(() => URL.revokeObjectURL(url), 0);
  }

  function wire() {
    document.querySelectorAll<HTMLButtonElement>('.btn[data-stance]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const s = btn.dataset.stance as Stance;
        playRound(s);
      });
    });
    document.getElementById('btn-reset')!.addEventListener('click', () => {
      const seed = Number((document.getElementById('seed-input') as HTMLInputElement).value || 420);
      initMatch(activeCardId, seed);
    });
    document.getElementById('btn-roll')!.addEventListener('click', () => {
      initMatch(activeCardId, Math.floor(Math.random() * 2000));
    });
    document.getElementById('btn-record')!.addEventListener('click', () => {
      if (completedMatch) exportMatch(completedMatch);
    });
    document.getElementById('btn-rematch')!.addEventListener('click', () => {
      initMatch(activeCardId, activeChallengerId);
    });
    document.getElementById('btn-new')!.addEventListener('click', () => {
      initMatch(activeCardId, Math.floor(Math.random() * 2000));
    });
    document.getElementById('btn-share')!.addEventListener('click', () => {
      shareCurrentMatch();
    });
    (document.getElementById('seed-input') as HTMLInputElement).addEventListener('change', (e) => {
      initMatch(activeCardId, Number((e.target as HTMLInputElement).value || 0));
    });
    document.querySelectorAll<HTMLElement>('.fighter').forEach((fighter) => {
      fighter.addEventListener('animationend', () => fighter.classList.remove('fighter--hit'));
    });
  }

  const params = new URLSearchParams(window.location.search);
  initMatch(
    clampSeed(Number(params.get('card') ?? CARD_OF_THE_DAY), CARD_OF_THE_DAY),
    clampSeed(Number(params.get('challenger') ?? 420), 420),
  );
  wire();
</script>

