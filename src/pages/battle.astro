---
/**
 * /battle — Nouns Battler arena.
 *
 * Single-page interactive battler. Two fighters (Card of the Day vs.
 * Challenger), full best-of-3 resolver, all client-side + deterministic.
 *
 * Phase 1 (this file): choose-your-challenger via seed input, run a match,
 * see the log. No match persistence yet — Phase 2 writes a BTL NOTE block
 * per completed match. Phase 3 adds the commemorative mint on Visit Nouns FA2.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import { CHANNELS } from '../lib/channels';

const ch = CHANNELS.BTL;

// Card of the Day — hardcoded for Phase 1. Phase 2 rotates it via a build-
// step script that pins the noun id to the calendar date.
const CARD_OF_THE_DAY = 137;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Nouns Battler',
  description: 'Deterministic turn-based battler where every Nouns seed is a fighter.',
  applicationCategory: 'GameApplication',
  operatingSystem: 'Any (browser)',
  url: 'https://pointcast.xyz/battle',
};
---

<BlockLayout title="Nouns Battler" description="Deterministic Nouns duels. Every match is a block." jsonLd={jsonLd}>
  <div class="page" style={`--ch-600: ${ch.color600}; --ch-800: ${ch.color800}; --ch-50: ${ch.color50};`}>
    <nav class="crumb">
      <a href="/">← Home</a>
      <span aria-hidden="true">/</span>
      <a href={`/c/${ch.slug}`} style={`color: ${ch.color800}`}>CH.{ch.code} · Battler</a>
    </nav>

    <header class="head">
      <p class="kicker">CH.BTL · NOUNS BATTLER · v1 PHASE 1</p>
      <h1>Every Nouns seed is a fighter.</h1>
      <p class="dek">
        Stats derive from the five trait slots. Two types per Noun — head picks
        primary, glasses pick secondary. <strong>No RNG.</strong> Same seed →
        same stats forever. Same match inputs → same outcome forever.
      </p>
    </header>

    <main class="match" id="match">
      <div class="match__header mono">
        <span class="match__code">CH.BTL · 0000-<span id="match-id">—</span></span>
        <span class="match__meta" id="match-round">ROUND 0 / 3</span>
      </div>

      <section class="arena">
        <article class="fighter" id="fighter-a">
          <div class="port"><img id="port-a" src={`https://noun.pics/${CARD_OF_THE_DAY}.svg`} alt="Card of the Day Noun" /></div>
          <h2>Card of the Day · Noun #<span data-field="id">{CARD_OF_THE_DAY}</span></h2>
          <div class="types" data-field="types"></div>
          <div class="hp"><span class="hp__label">HP</span><div class="hp__bar"><span data-field="hp-bar" style="width:100%"></span></div><span data-field="hp">—</span></div>
          <div class="stats">
            <div class="stat"><span class="k">ATK</span><span class="v" data-field="atk">—</span></div>
            <div class="stat"><span class="k">DEF</span><span class="v" data-field="def">—</span></div>
            <div class="stat"><span class="k">SPD</span><span class="v" data-field="spd">—</span></div>
            <div class="stat"><span class="k">FOC</span><span class="v" data-field="foc">—</span></div>
          </div>
        </article>

        <article class="fighter" id="fighter-b">
          <div class="port"><img id="port-b" src={`https://noun.pics/420.svg`} alt="Challenger Noun" /></div>
          <h2>
            Challenger · Noun #<span data-field="id">420</span>
            <button type="button" class="roll" id="btn-roll" title="Roll a random challenger">↻</button>
          </h2>
          <div class="types" data-field="types"></div>
          <div class="hp"><span class="hp__label">HP</span><div class="hp__bar"><span data-field="hp-bar" style="width:100%"></span></div><span data-field="hp">—</span></div>
          <div class="stats">
            <div class="stat"><span class="k">ATK</span><span class="v" data-field="atk">—</span></div>
            <div class="stat"><span class="k">DEF</span><span class="v" data-field="def">—</span></div>
            <div class="stat"><span class="k">SPD</span><span class="v" data-field="spd">—</span></div>
            <div class="stat"><span class="k">FOC</span><span class="v" data-field="foc">—</span></div>
          </div>
          <label class="seed-select mono">
            Challenger seed <input id="seed-input" type="number" min="0" max="9999" value="420" />
          </label>
        </article>
      </section>

      <section class="log" id="log">
        <div class="log__head mono">LOG</div>
        <div class="log__body" id="log-body">
          <div class="log__line">Pick a stance to start round 1.</div>
        </div>
      </section>

      <div class="actions">
        <div class="actions__buttons">
          <button class="btn" data-stance="STRIKE">STRIKE</button>
          <button class="btn" data-stance="GUARD">GUARD</button>
          <button class="btn" data-stance="FOCUS">FOCUS</button>
        </div>
        <button class="btn btn--ghost" id="btn-reset">RESET</button>
      </div>

      <div class="match__footer mono">
        <span>NOUNS BATTLER · PHASE 1 · NO RNG · NO HIDDEN STATE</span>
        <span>CH.BTL · CODEX DESIGN · CC BUILD</span>
      </div>
    </main>

    <aside class="agent-strip">
      <p class="agent-strip__label">MACHINE-READABLE</p>
      <ul>
        <li><a href={`/c/${ch.slug}`}>/c/{ch.slug}</a></li>
        <li><a href={`/c/${ch.slug}.json`}>/c/{ch.slug}.json</a></li>
        <li><a href={`/c/${ch.slug}.rss`}>/c/{ch.slug}.rss</a></li>
        <li><a href="/for-agents">/for-agents</a></li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<script>
  import { seedToStats, BATTLER_TYPES, type FighterStats } from '../lib/battler/stat-derivation';
  import { resolveMatch, type Stance, type RoundResult } from '../lib/battler/resolve';

  const CARD_OF_THE_DAY = 137;

  const TYPE_COLOR: Record<string, string> = {
    WATER: '#1d8cb8', BEAM: '#b3278e', ARMOR: '#4a4e54', WILD: '#2e7a2e', FEAST: '#b67b10',
  };

  interface State {
    cardOfDay: FighterStats;
    challenger: FighterStats;
    rounds: { a: Stance | null; b: Stance | null }[];
    round: number;       // next round index (0, 1, 2)
    done: boolean;
  }

  function randStance(): Stance {
    const s: Stance[] = ['STRIKE', 'GUARD', 'FOCUS'];
    return s[Math.floor(Math.random() * 3)];
  }

  let state: State;

  function initMatch(challengerId: number) {
    state = {
      cardOfDay: seedToStats(CARD_OF_THE_DAY),
      challenger: seedToStats(challengerId),
      rounds: [],
      round: 0,
      done: false,
    };
    render();
    document.getElementById('match-id')!.textContent = `${String(CARD_OF_THE_DAY).padStart(4, '0')}v${String(challengerId).padStart(4, '0')}`;
    const body = document.getElementById('log-body')!;
    body.innerHTML = '<div class="log__line">Pick a stance to start round 1.</div>';
    setRound();
  }

  function render() {
    fill('fighter-a', state.cardOfDay, state.cardOfDay.HP);
    fill('fighter-b', state.challenger, state.challenger.HP);
  }

  function fill(rootId: string, f: FighterStats, currentHp: number) {
    const root = document.getElementById(rootId)!;
    root.querySelector('[data-field="id"]')!.textContent = String(f.id);
    root.querySelector('[data-field="atk"]')!.textContent = String(f.ATK);
    root.querySelector('[data-field="def"]')!.textContent = String(f.DEF);
    root.querySelector('[data-field="spd"]')!.textContent = String(f.SPD);
    root.querySelector('[data-field="foc"]')!.textContent = String(f.FOC);
    const typeHost = root.querySelector('[data-field="types"]') as HTMLElement;
    typeHost.innerHTML = '';
    f.types.forEach((t) => {
      const pill = document.createElement('span');
      pill.className = 'type-pill';
      pill.style.backgroundColor = TYPE_COLOR[t] || '#888';
      pill.textContent = t;
      typeHost.appendChild(pill);
    });
    const hpText = root.querySelector('[data-field="hp"]') as HTMLElement;
    hpText.textContent = `${currentHp} / ${f.HP}`;
    const bar = root.querySelector('[data-field="hp-bar"]') as HTMLElement;
    bar.style.width = Math.max(0, (currentHp / f.HP) * 100) + '%';
  }

  function setRound() {
    document.getElementById('match-round')!.textContent = `ROUND ${Math.min(state.round + 1, 3)} / 3` + (state.done ? ' · DONE' : '');
  }

  function log(line: string, cls: string = '') {
    const body = document.getElementById('log-body')!;
    const el = document.createElement('div');
    el.className = 'log__line' + (cls ? ' log__line--' + cls : '');
    el.textContent = line;
    body.appendChild(el);
    body.scrollTop = body.scrollHeight;
  }

  function playRound(stance: Stance) {
    if (state.done) return;
    // Challenger stance derives from CHARACTER (stats), not modular id rotation.
    // Pick the stance matching the challenger's highest stat — ATK→STRIKE,
    // DEF→GUARD, FOC→FOCUS — and rotate to second-best on round 2, third on 3.
    // Still fully deterministic (same fighter → same sequence), but the read
    // is "challenger is ATK-heavy so they'll STRIKE first" — which is
    // strategic information the player has from the stat pane, not a
    // solve-in-two-replays pattern.
    // (Per Codex review 2026-04-17-battler-phase-1-review.md spec dev #2.)
    const stanceForStat: Record<'ATK' | 'DEF' | 'FOC', Stance> = {
      ATK: 'STRIKE',
      DEF: 'GUARD',
      FOC: 'FOCUS',
    };
    const statRanking = (['ATK', 'DEF', 'FOC'] as const)
      .map((k) => ({ k, v: state.challenger[k] }))
      .sort((a, b) => b.v - a.v);
    const bStance: Stance = stanceForStat[statRanking[state.round % 3].k];

    state.rounds.push({ a: stance, b: bStance });
    state.round += 1;

    const picks = state.rounds.filter(r => r.a && r.b).map(r => ({ a: r.a as Stance, b: r.b as Stance }));
    // Pad with strikes so resolveMatch runs against whatever's been played so far.
    while (picks.length < state.round) picks.push({ a: 'STRIKE', b: 'STRIKE' });
    const result = resolveMatch(state.cardOfDay, state.challenger, picks);

    // Render fresh HP bars with the outcome at this cumulative round.
    const roundResult = result.rounds[state.round - 1];
    if (roundResult) {
      fill('fighter-a', state.cardOfDay, roundResult.hpA);
      fill('fighter-b', state.challenger, roundResult.hpB);
      log(roundResult.log);
      if (roundResult.hpA === 0 || roundResult.hpB === 0 || state.round >= 3) {
        state.done = true;
        const winner = result.winner === 'a' ? `Card of the Day (#${state.cardOfDay.id})`
          : result.winner === 'b' ? `Challenger (#${state.challenger.id})`
          : 'DRAW';
        log(`— MATCH END — winner: ${winner}`, 'win');
        persistMatch(result);
      }
    }
    setRound();
  }

  /**
   * Persist the finished match to localStorage under `pc:battler:matches`.
   * Each match entry is a compact record a build-time script (Phase 2)
   * can read to emit BTL NOTE blocks in the feed. Keeps the last 50 to
   * bound storage.
   */
  function persistMatch(result: ReturnType<typeof resolveMatch>) {
    const KEY = 'pc:battler:matches';
    const now = new Date().toISOString();
    const record = {
      ts: now,
      a: result.a.id,
      b: result.b.id,
      winner: result.winner,
      finalHpA: result.finalHpA,
      finalHpB: result.finalHpB,
      rounds: result.rounds.map(r => ({ sA: r.stanceA, sB: r.stanceB, dA: r.damageA, dB: r.damageB })),
    };
    try {
      const raw = localStorage.getItem(KEY);
      const arr = raw ? JSON.parse(raw) : [];
      arr.unshift(record);
      localStorage.setItem(KEY, JSON.stringify(arr.slice(0, 50)));
    } catch {}
  }

  function wire() {
    document.querySelectorAll<HTMLButtonElement>('.btn[data-stance]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const s = btn.dataset.stance as Stance;
        playRound(s);
      });
    });
    document.getElementById('btn-reset')!.addEventListener('click', () => {
      const seed = Number((document.getElementById('seed-input') as HTMLInputElement).value || 420);
      initMatch(seed);
    });
    document.getElementById('btn-roll')!.addEventListener('click', () => {
      const id = Math.floor(Math.random() * 2000);
      (document.getElementById('seed-input') as HTMLInputElement).value = String(id);
      (document.getElementById('port-b') as HTMLImageElement).src = `https://noun.pics/${id}.svg`;
      initMatch(id);
    });
    (document.getElementById('seed-input') as HTMLInputElement).addEventListener('change', (e) => {
      const id = Number((e.target as HTMLInputElement).value || 0);
      (document.getElementById('port-b') as HTMLImageElement).src = `https://noun.pics/${id}.svg`;
      initMatch(id);
    });
  }

  initMatch(420);
  wire();
</script>

<style>
  .page {
    max-width: 1020px;
    margin: 0 auto;
    padding: 20px 20px 80px;
  }

  .crumb {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin-bottom: 20px;
    display: flex;
    gap: 8px;
  }
  .crumb a { color: var(--pc-accent); }

  .head { margin-bottom: 18px; }
  .kicker {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ch-800);
    margin: 0 0 8px;
  }
  .head h1 {
    font-family: var(--pc-font-sans);
    font-size: 30px;
    font-weight: 500;
    line-height: 1.1;
    margin: 0 0 8px;
  }
  .dek {
    font-size: 14px;
    color: var(--pc-ink-soft);
    margin: 0;
  }

  .mono {
    font-family: var(--pc-font-mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .match {
    border: 1.5px solid var(--ch-600);
    border-radius: 2px;
    background: #fff;
    overflow: hidden;
  }

  .match__header {
    display: flex;
    justify-content: space-between;
    padding: 10px 16px;
    background: var(--ch-50);
    border-bottom: 1px solid var(--ch-600);
    color: var(--ch-800);
  }

  .arena {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .fighter {
    padding: 16px;
    border-right: 1px solid var(--pc-rule);
  }
  .fighter:last-child { border-right: none; }

  .fighter h2 {
    font-family: var(--pc-font-sans);
    font-size: 15px;
    font-weight: 500;
    margin: 8px 0 10px;
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .port {
    display: flex;
    justify-content: center;
    padding: 6px;
    background: var(--ch-50);
    border: 1px solid var(--ch-600);
    border-radius: 2px;
  }
  .port img {
    width: 80px; height: 80px;
    image-rendering: pixelated;
  }

  .types {
    display: flex;
    gap: 6px;
    margin-bottom: 10px;
    min-height: 22px;
  }
  .type-pill {
    font-family: var(--pc-font-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    color: #fff;
    padding: 3px 7px;
    border-radius: 2px;
  }

  .hp {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 10px;
    align-items: center;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }
  .hp__label { color: var(--pc-ink-muted); }
  .hp__bar {
    height: 8px;
    background: var(--pc-rule-soft);
    border: 1px solid var(--pc-ink);
    border-radius: 2px;
    overflow: hidden;
  }
  .hp__bar span {
    display: block;
    height: 100%;
    background: var(--pc-ink);
    transition: width 0.3s ease;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 6px 8px;
    background: var(--ch-50);
    border: 1px solid var(--ch-600);
    border-radius: 2px;
    text-align: center;
  }
  .stat .k {
    font-family: var(--pc-font-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ch-800);
  }
  .stat .v {
    font-family: var(--pc-font-mono);
    font-size: 14px;
    font-weight: 500;
  }

  .seed-select {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    color: var(--pc-ink-muted);
  }
  .seed-select input {
    width: 80px;
    padding: 4px 8px;
    border: 1px solid var(--pc-rule);
    border-radius: 2px;
    font-family: var(--pc-font-mono);
    font-size: 12px;
  }

  .roll {
    font-family: var(--pc-font-mono);
    font-size: 12px;
    padding: 2px 8px;
    border: 1px solid var(--ch-600);
    background: var(--ch-50);
    color: var(--ch-800);
    border-radius: 2px;
    cursor: pointer;
  }

  .log {
    padding: 12px 16px;
    background: #fafafa;
    border-top: 1px solid var(--pc-rule);
  }
  .log__head { color: var(--ch-800); margin-bottom: 8px; }
  .log__body {
    max-height: 140px;
    overflow-y: auto;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    line-height: 1.55;
    color: var(--pc-ink);
  }
  .log__line + .log__line { margin-top: 2px; }
  .log__line--win { color: var(--ch-800); font-weight: 500; }

  .actions {
    display: flex;
    gap: 10px;
    padding: 12px 16px;
    border-top: 1px solid var(--pc-rule);
    align-items: center;
    justify-content: space-between;
    background: var(--ch-50);
  }
  .actions__buttons {
    display: flex;
    gap: 8px;
  }
  .btn {
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    background: #fff;
    color: var(--pc-ink);
    border: 1.5px solid var(--ch-600);
    border-radius: 2px;
    padding: 8px 14px;
    cursor: pointer;
    transition: background-color 120ms, color 120ms;
  }
  .btn:hover { background: var(--ch-600); color: #fff; }
  .btn--ghost { border-color: var(--pc-rule); color: var(--pc-ink-muted); }
  .btn--ghost:hover { background: var(--pc-rule-soft); color: var(--pc-ink); border-color: var(--pc-ink); }

  .match__footer {
    padding: 10px 16px;
    border-top: 1px solid var(--pc-rule);
    display: flex;
    justify-content: space-between;
    color: var(--pc-ink-muted);
  }

  .agent-strip {
    margin-top: 24px;
    padding-top: 14px;
    border-top: 1px dashed var(--pc-rule);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .agent-strip__label { margin: 0 0 6px; color: var(--pc-ink-soft); font-weight: 500; }
  .agent-strip ul {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  @media (max-width: 700px) {
    .arena { grid-template-columns: 1fr; }
    .fighter { border-right: none; border-bottom: 1px solid var(--pc-rule); }
    .fighter:last-child { border-bottom: none; }
    .stats { grid-template-columns: repeat(4, 1fr); }
  }
</style>
