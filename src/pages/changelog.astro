---
/**
 * /changelog — human + agent-readable version history for PointCast.
 *
 * Not generated from git log — hand-curated so the story stays readable.
 * Each release gets:
 *   - Version tag (v1, v2, v2.1, etc.)
 *   - Date
 *   - Short title (what the release was about)
 *   - Bullet highlights
 *   - Optional links to relevant commits/PRs/docs
 *
 * The raw commit firehose is at
 * github.com/MikeHoydich/pointcast/commits/main. This page is the
 * curated narrative.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

interface Release {
  version: string;
  date: string;
  title: string;
  summary: string;
  highlights: string[];
  links?: Array<{ label: string; href: string }>;
}

