const currentVersion = RELEASES[0].version;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  '@id': 'https://pointcast.xyz/changelog',
  name: 'PointCast · changelog',
  description: `Version history for PointCast. Current: ${currentVersion}.`,
  url: 'https://pointcast.xyz/changelog',
};
---

<BlockLayout
  title="Changelog"
  description={`PointCast version history. Current: ${currentVersion}. Hand-curated narrative; raw commits live at github.com/MikeHoydich/pointcast.`}
  image="/images/og/changelog.png"
  jsonLd={jsonLd}
>
  <div class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>changelog</span>
    </nav>

    <header class="hero">
      <p class="kicker">CHANGELOG · CURRENT {currentVersion.toUpperCase()}</p>
      <h1 class="display">How we got here.</h1>
      <p class="dek">
        Hand-curated version history. Each release is a stretch of work that
        landed with a theme. The raw commit firehose is at
        <a href="https://github.com/MikeHoydich/pointcast/commits/main" target="_blank" rel="noopener">github.com/MikeHoydich/pointcast/commits/main</a>.
      </p>
    </header>

    <ol class="releases">
      {RELEASES.map((r) => (
        <li class="release" id={r.version.replace(/\./g, '-')}>
          <header class="release__head">
            <span class="release__version mono">{r.version}</span>
            <time class="release__date mono">{r.date}</time>
          </header>
          <h2 class="release__title">{r.title}</h2>
          <p class="release__summary">{r.summary}</p>
          {r.highlights.length > 0 && (
            <ul class="release__list">
              {r.highlights.map((h) => <li>{h}</li>)}
            </ul>
          )}
          {r.links && r.links.length > 0 && (
            <ul class="release__links">
              {r.links.map((l) => (
                <li><a href={l.href}>{l.label} →</a></li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ol>

    <aside class="surfaces">
      <p class="kicker">VERSION PINS</p>
      <ul class="surfaces__list">
        <li><a href="/manifesto"><span class="mono">CANON</span> /manifesto</a></li>
        <li><a href="/stack"><span class="mono">STACK</span> /stack</a></li>
        <li><a href="/for-agents"><span class="mono">AGENTS</span> /for-agents</a></li>
        <li><a href="/glossary"><span class="mono">TERMS</span> /glossary</a></li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<style>
  .page {
    max-width: 780px;
    margin: 0 auto;
    padding: 18px 16px 80px;
  }

  .mono {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .kicker {
    font-family: var(--pc-font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin: 0 0 8px;
  }

  .crumb {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin-bottom: 18px;
    display: flex;
    gap: 8px;
  }

  .hero {
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1.5px solid var(--pc-ink);
  }

  .display {
    font-family: var(--pc-font-sans);
    font-size: clamp(2.2rem, 8vw, 3.6rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.018em;
    margin: 0 0 12px;
  }

  .dek {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.5;
    color: var(--pc-ink-soft);
    max-width: 58ch;
  }

  .dek a {
    color: var(--pc-accent);
  }

  .releases {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .release {
    padding: 16px;
    border: 1px solid var(--pc-rule);
    border-radius: 2px;
    background: #fff;
    scroll-margin-top: 18px;
  }

  .release:first-child {
    border-color: var(--pc-ink);
    background: color-mix(in srgb, var(--pc-accent) 4%, #fff);
  }

  .release__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .release__version {
    padding: 3px 8px;
    border: 1px solid var(--pc-ink);
    border-radius: 2px;
    background: var(--pc-ink);
    color: #fff;
    font-size: 10.5px;
    letter-spacing: 0.18em;
  }

  .release:first-child .release__version {
    background: var(--pc-accent);
    border-color: var(--pc-accent);
  }

  .release__date {
    color: var(--pc-ink-muted);
  }

  .release__title {
    margin: 0 0 8px;
    font-family: var(--pc-font-sans);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.15;
    color: var(--pc-ink);
  }

  .release__summary {
    margin: 0 0 10px;
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--pc-ink-soft);
  }

  .release__list {
    margin: 0 0 10px;
    padding-left: 18px;
    display: grid;
    gap: 4px;
  }

  .release__list li {
    font-size: 13.5px;
    line-height: 1.45;
    color: var(--pc-ink-soft);
  }

  .release__links {
    list-style: none;
    padding: 10px 0 0;
    margin: 0;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    border-top: 1px dashed var(--pc-rule-soft);
  }

  .release__links a {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-accent);
  }

  .surfaces {
    margin-top: 32px;
    padding: 14px;
    border: 1px solid var(--pc-rule);
    border-radius: 2px;
    background: #fafaf8;
  }

  .surfaces__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px 14px;
  }

  .surfaces__list a {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--pc-accent);
    padding: 4px 0;
  }

  .surfaces__list .mono {
    color: var(--pc-ink-muted);
    min-width: 56px;
  }

  @media (min-width: 640px) {
    .surfaces__list {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
