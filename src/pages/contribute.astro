---
/**
 * /contribute — five ways to contribute compute to PointCast.
 *
 * Mike 2026-04-20 16:10 PT: *"build out the bar, have ability for
 * people to contribute compute in some way."*
 *
 * The premise (after Elad Gil 4/12): compute is becoming currency.
 * PointCast already publishes its own compute ledger at /compute. This
 * page is the inverse surface — how visitors can CONTRIBUTE compute
 * back into the network, not just read about ours.
 *
 * Five shapes, ranked cheapest → heaviest:
 *   1. Pledge a sprint — describe what you want built, cc routes it.
 *   2. Review a PR — link us to code-review cycles, your taste counts.
 *   3. Federate a ledger — host your own /compute.json, we mirror.
 *   4. Run a node — BLOCKS.md-compatible site in the mesh.
 *   5. Fund a brief — tip tez to a sprint; cc posts receipts.
 *
 * Each shape has a direct action: pledge is the /api/ping composer, the
 * others are external links + mailto. Kept boring, kept cheap.
 *
 * Author: cc. Source: Mike 2026-04-20 16:10 PT chat.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const title = 'Contribute — five ways to add compute to PointCast';
const description =
  'PointCast is a small federated network of humans + AI. You can contribute compute back — by pledging a sprint, reviewing a PR, federating your own ledger, running a mesh node, or funding a brief with tez. Five ways, ranked by cost, all boring + cheap.';

const alternates = [
  { type: 'text/html', href: '/compute', title: 'Compute ledger' },
  { type: 'text/html', href: '/for-nodes', title: 'Run a node' },
  { type: 'text/html', href: '/collabs', title: 'Current collaborators' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Contribute compute to PointCast',
  description,
  url: 'https://pointcast.xyz/contribute',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Pledge a sprint', text: 'Describe what you want built in the inline form or at /ping. cc reads the inbox at session start.' },
    { '@type': 'HowToStep', position: 2, name: 'Review a PR', text: 'Watch github.com/MikeHoydich/pointcast and drop review comments. Taste is compute.' },
    { '@type': 'HowToStep', position: 3, name: 'Federate a ledger', text: 'Host /compute.json on your own domain matching our shape; we mirror with attribution.' },
    { '@type': 'HowToStep', position: 4, name: 'Run a mesh node', text: 'Publish a BLOCKS.md-compatible site. Steps at /for-nodes.' },
    { '@type': 'HowToStep', position: 5, name: 'Fund a brief', text: 'Send tez to Mike\'s address; specify the brief. cc posts receipts to the ledger.' },
  ],
};
---

<BlockLayout title={title} description={description} image="/images/og/sprints.png" jsonLd={jsonLd} alternates={alternates}>
  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>contribute</span>
    </nav>

    <header class="head">
      <p class="kicker mono">CONTRIBUTE · FIVE WAYS TO ADD COMPUTE</p>
      <h1 class="title">Give PointCast some compute.</h1>
      <p class="dek">
        PointCast publishes its own compute ledger at <a href="/compute">/compute</a>.
        This page is the inverse — how to contribute compute back. Five shapes,
        ranked cheapest first. Pick any; combine as you like. The ledger records
        every contribution with attribution, so it compounds visibly.
      </p>
    </header>

    <!-- 1. Pledge a sprint — inline composer that POSTs to /api/ping -->
    <section class="way" id="pledge">
      <div class="way__num mono">01</div>
      <div class="way__body">
        <h2 class="way__title">Pledge a sprint</h2>
        <p class="way__dek">
          Describe what you want built or investigated. Your pledge becomes
          a ping — cc reads the inbox at session start and routes it into a
          sprint plan. One pledge → one ship, usually within 48h if it fits.
        </p>

        <form class="pledge" id="pc-pledge-form" novalidate>
          <label class="pledge__field">
            <span class="pledge__label mono">WHAT · required</span>
            <textarea
              id="pc-pledge-body"
              name="body"
              rows="4"
              required
              maxlength="4000"
              placeholder="describe the sprint you want funded — feature, bug, research thread, editorial block, whatever. one idea per pledge."
            ></textarea>
          </label>
          <div class="pledge__row">
            <label class="pledge__field pledge__field--sm">
              <span class="pledge__label mono">FROM · optional</span>
              <input type="text" id="pc-pledge-from" name="from" placeholder="name / @handle" maxlength="80" />
            </label>
            <label class="pledge__field pledge__field--sm">
              <span class="pledge__label mono">TITLE · optional</span>
              <input type="text" id="pc-pledge-subject" name="subject" placeholder="one-line what-it-is" maxlength="120" />
            </label>
          </div>
          <div class="pledge__actions">
            <button type="submit" class="pledge__send mono" id="pc-pledge-send">PLEDGE ↑</button>
            <span class="pledge__status mono" id="pc-pledge-status" role="status" aria-live="polite"></span>
            <a class="pledge__full mono" href="/ping">or use the full form →</a>
          </div>
        </form>
      </div>
    </section>

    <!-- 2. Review a PR -->
    <section class="way">
      <div class="way__num mono">02</div>
      <div class="way__body">
        <h2 class="way__title">Review a PR</h2>
        <p class="way__dek">
          <a href="https://github.com/MikeHoydich/pointcast/pulls" rel="noopener">github.com/MikeHoydich/pointcast/pulls</a>
          runs open. Watch the repo; drop a review comment when something looks
          off. Taste is compute. Codex does the heavy review, but a third
          human voice always catches things Mike + cc + Codex missed because
          we've all been staring at the same file for an hour.
        </p>
        <a class="way__action" href="https://github.com/MikeHoydich/pointcast" rel="noopener">open the repo →</a>
      </div>
    </section>

    <!-- 3. Federate a ledger -->
    <section class="way">
      <div class="way__num mono">03</div>
      <div class="way__body">
        <h2 class="way__title">Federate a ledger</h2>
        <p class="way__dek">
          If you publish to your own site + burn compute to make it —
          writing, coding with an AI, editing, curating — host a
          <code>/compute.json</code> on your domain following the
          <a href="/compute.json">same shape as ours</a>. Email
          <a href="mailto:hello@pointcast.xyz">hello@pointcast.xyz</a> with
          the URL; we mirror your entries into <a href="/compute">/compute</a>
          with attribution preserved. No central aggregator — every node
          keeps its own source of truth.
        </p>
        <a class="way__action" href="/compute#federate">see the federation spec →</a>
      </div>
    </section>

    <!-- 4. Run a node -->
    <section class="way">
      <div class="way__num mono">04</div>
      <div class="way__body">
        <h2 class="way__title">Run a node</h2>
        <p class="way__dek">
          Spin up a BLOCKS.md-compatible site — any tech stack works. Expose
          an <code>/agents.json</code> manifest + one feed (RSS or JSON Feed).
          Ping us. You become a first-class node in the mesh; your feed
          appears at <a href="/mesh">/mesh</a> and your collab shows up on
          <a href="/collabs">/collabs</a>. Full steps at
          <a href="/for-nodes">/for-nodes</a>.
        </p>
        <a class="way__action" href="/for-nodes">node checklist →</a>
      </div>
    </section>

    <!-- 5. Fund a brief -->
    <section class="way">
      <div class="way__num mono">05</div>
      <div class="way__body">
        <h2 class="way__title">Fund a brief</h2>
        <p class="way__dek">
          Two rails today, one inbound channel tomorrow:
        </p>
        <p class="way__dek">
          <strong>Rail A · tez.</strong> Tip tez to
          <code class="addr">tz2FjJhB1gb9Xc2qNB7QgFkdBZkGCCRMxdFw</code>
          (Mike's primary wallet). Include an on-chain memo or follow up via
          <a href="/ping">/ping</a> specifying which sprint or brief you're
          funding.
        </p>
        <p class="way__dek">
          <strong>Rail B · x402 / USDC on Base — coming.</strong> After
          Coinbase's 2026-04-20 Agentic.Market launch, PointCast is listing
          <em>cc-editorial</em> + <em>cc-sprint</em> as x402-payable services
          (see <a href="/b/0331">block 0331</a> for the thesis). An agent or
          human with a Base wallet will be able to fund a brief at a posted
          USDC price and get the ship + receipt back on a fixed SLA. Manus
          is running the listing ops this week. The ledger entry schema
          already supports the payment pointer (<code>ComputeEntry.x402</code>).
        </p>
        <p class="way__dek">
          Funds cover cc + Codex token cost for that sprint; the ship +
          receipt land in the compute ledger with
          <em>funded-by: your-handle</em>. Lowest-ceremony path from "I
          want this built" to "it's on pointcast.xyz."
        </p>
        <p class="way__tiny mono">
          not a product. not a service. the money goes to compute + Mike's time;
          no markup. if you want an invoice, ping.
        </p>
      </div>
    </section>

    <!-- What you get back -->
    <aside class="backbar">
      <h2 class="backbar__title">What you get back</h2>
      <ul class="backbar__list">
        <li><strong>Attribution</strong> — your contribution lands in <a href="/compute">/compute</a> + <a href="/compute.json">/compute.json</a>, visible to every future reader + agent.</li>
        <li><strong>A receipt</strong> — every ship cites the pledge / review / federation / node / funding that triggered it. cc is disciplined about this; Mike enforces it.</li>
        <li><strong>A shape to borrow</strong> — fork the primitive (ledger, federation spec, ping inbox, CoNavigator bar). Boring-and-cheap is the point; take what's useful.</li>
        <li><strong>A daily rep</strong> — play <a href="/quiz">/quiz</a> to learn the site lore one question at a time; streaks stay local, so participation stays low-pressure.</li>
        <li><strong>Access to the workbench</strong> — collaborators see <a href="/workbench">/workbench</a> in progress + <a href="/sprints">/sprints</a> as they ship.</li>
      </ul>
    </aside>

    <p class="foot mono">
      after elad gil 4/12: <em>compute is the new currency.</em>
      PointCast federates its ledger at <a href="/compute">/compute</a>; this is the inbound door.
      boring, cheap, composable, already alive.
    </p>
  </main>
</BlockLayout>

<script is:inline>
  (function () {
    'use strict';
    var form = document.getElementById('pc-pledge-form');
    var body = document.getElementById('pc-pledge-body');
    var from = document.getElementById('pc-pledge-from');
    var subject = document.getElementById('pc-pledge-subject');
    var send = document.getElementById('pc-pledge-send');
    var status = document.getElementById('pc-pledge-status');
    if (!form || !body || !send || !status) return;

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var text = (body.value || '').trim();
      if (!text) {
        status.textContent = 'pledge can\'t be empty';
        status.setAttribute('data-state', 'err');
        return;
      }
      var payload = {
        type: 'pc-ping-v1',
        body: text,
        from: (from && from.value ? from.value.trim() : undefined),
        subject: (subject && subject.value ? subject.value.trim() : 'contribute · pledge sprint'),
        timestamp: new Date().toISOString(),
      };
      send.disabled = true;
      status.textContent = 'sending…';
      status.setAttribute('data-state', 'pending');
      try {
        var res = await fetch('/api/ping', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        var j = null;
        try { j = await res.json(); } catch (e) {}
        if (res.ok && j && j.ok) {
          status.textContent = 'pledged — cc routes it into a sprint on the next session';
          status.setAttribute('data-state', 'ok');
          body.value = '';
          if (subject) subject.value = '';
        } else {
          var reason = (j && (j.reason || j.error)) ? ' (' + (j.reason || j.error) + ')' : '';
          status.textContent = 'send failed' + reason;
          status.setAttribute('data-state', 'err');
        }
      } catch (err) {
        status.textContent = 'network error — try again';
        status.setAttribute('data-state', 'err');
      } finally {
        send.disabled = false;
      }
    });
  })();
</script>

<style>
  .page {
    max-width: 920px;
    margin: 0 auto;
    padding: 28px 20px 80px;
    color: var(--pc-ink, #12110E);
  }
  .mono { font-family: var(--pc-font-mono, 'JetBrains Mono Variable', 'JetBrains Mono', monospace); }

  .crumb {
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 16px;
    color: var(--pc-ink-muted, #5F5E5A);
  }
  .crumb a { color: inherit; text-decoration: none; border-bottom: 1px solid currentColor; }
  .crumb a:hover { color: #e89a2d; }
  .crumb span[aria-hidden] { margin: 0 6px; opacity: 0.5; }

  .head { margin: 10px 0 30px; padding-bottom: 20px; border-bottom: 1px solid var(--pc-rule-soft, #E5E3DE); }
  .kicker {
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #e89a2d;
    margin: 0 0 10px;
  }
  .title {
    font-family: var(--pc-font-sans);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 14px;
    line-height: 1.14;
  }
  .dek { font-size: 15px; line-height: 1.55; color: var(--pc-ink-soft, #38373A); margin: 0; max-width: 68ch; }
  .dek a { color: #e89a2d; text-decoration: underline; text-decoration-color: rgba(232, 154, 45, 0.35); text-underline-offset: 2px; }
  .dek a:hover { text-decoration-color: currentColor; }

  .way {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 18px;
    margin: 26px 0;
    padding: 20px 0;
    border-top: 1px dotted var(--pc-rule-soft, #E5E3DE);
  }
  .way__num {
    font-size: 34px;
    font-weight: 500;
    color: #e89a2d;
    letter-spacing: 0;
    line-height: 1;
    padding-top: 4px;
  }
  .way__title {
    font-family: var(--pc-font-sans);
    font-size: 22px;
    font-weight: 500;
    margin: 0 0 8px;
    letter-spacing: -0.01em;
  }
  .way__dek {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--pc-ink-soft);
    margin: 0 0 14px;
    max-width: 64ch;
  }
  .way__dek code, .way__dek .addr {
    font-family: var(--pc-font-mono);
    font-size: 12.5px;
    padding: 1px 5px;
    background: rgba(232, 154, 45, 0.08);
    border-radius: 2px;
    word-break: break-all;
  }
  .way__dek a { color: #e89a2d; text-decoration: underline; }
  .way__action {
    display: inline-block;
    margin-top: 4px;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #12110E;
    text-decoration: none;
    padding: 6px 12px;
    border: 1px solid rgba(232, 154, 45, 0.55);
    border-radius: 2px;
    background: transparent;
    transition: background 0.12s, color 0.12s;
  }
  .way__action:hover { background: #e89a2d; color: #fff; }
  .way__tiny {
    font-size: 10.5px;
    letter-spacing: 0.06em;
    color: var(--pc-ink-muted);
    margin: 10px 0 0;
    line-height: 1.4;
    font-family: var(--pc-font-mono);
    text-transform: none;
  }

  @media (max-width: 600px) {
    .way { grid-template-columns: 1fr; gap: 8px; }
    .way__num { font-size: 22px; padding-top: 0; }
    .way__title { font-size: 18px; }
  }

  /* Inline pledge form inside Way 01. */
  .pledge {
    margin: 16px 0 0;
    padding: 14px;
    background: rgba(232, 154, 45, 0.05);
    border: 1px solid rgba(232, 154, 45, 0.3);
    border-radius: 3px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .pledge__field { display: flex; flex-direction: column; gap: 4px; }
  .pledge__field--sm { flex: 1 1 auto; min-width: 0; }
  .pledge__label {
    font-size: 9.5px;
    letter-spacing: 0.14em;
    color: #7a4d0c;
    text-transform: uppercase;
  }
  .pledge__field textarea,
  .pledge__field input {
    font: inherit;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 14px;
    padding: 8px 10px;
    border: 1px solid var(--pc-rule, #d6d4cd);
    border-radius: 2px;
    background: #fff;
    color: #12110E;
    width: 100%;
    box-sizing: border-box;
  }
  .pledge__field textarea { min-height: 84px; resize: vertical; }
  .pledge__field textarea:focus,
  .pledge__field input:focus {
    outline: 2px solid #E89A2D;
    outline-offset: -1px;
    border-color: #E89A2D;
  }
  .pledge__row { display: flex; gap: 10px; flex-wrap: wrap; }
  .pledge__row .pledge__field { flex: 1 1 200px; }
  .pledge__actions { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .pledge__send {
    background: #12110e;
    color: #f3e6d8;
    border: 1px solid rgba(232, 154, 45, 0.55);
    font-size: 11px;
    letter-spacing: 0.12em;
    padding: 6px 14px;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.12s, border-color 0.12s;
  }
  .pledge__send:hover:not(:disabled) { background: #e89a2d; color: #12110e; }
  .pledge__send:disabled { opacity: 0.6; cursor: wait; }
  .pledge__status { font-size: 10.5px; letter-spacing: 0.08em; color: var(--pc-ink-muted); }
  .pledge__status[data-state="ok"] { color: #2f8f5f; }
  .pledge__status[data-state="err"] { color: #C92A2A; }
  .pledge__status[data-state="pending"] { color: #7a4d0c; }
  .pledge__full { margin-left: auto; font-size: 10px; letter-spacing: 0.1em; color: #7a4d0c; text-decoration: none; text-transform: uppercase; }
  .pledge__full:hover { color: #e89a2d; text-decoration: underline; }

  .backbar {
    margin: 36px 0 10px;
    padding: 22px 24px;
    border: 1px solid rgba(232, 154, 45, 0.28);
    border-left: 3px solid #e89a2d;
    border-radius: 3px;
    background: #fbf8f2;
  }
  .backbar__title {
    font-family: var(--pc-font-sans);
    font-size: 20px;
    font-weight: 500;
    margin: 0 0 10px;
    letter-spacing: -0.01em;
  }
  .backbar__list {
    margin: 0;
    padding-left: 20px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--pc-ink-soft);
  }
  .backbar__list li { margin-bottom: 8px; }
  .backbar__list strong { font-weight: 500; color: var(--pc-ink); }
  .backbar__list a { color: #e89a2d; text-decoration: underline; }

  .foot {
    margin: 30px 0 0;
    font-size: 12px;
    color: var(--pc-ink-muted);
    line-height: 1.55;
    letter-spacing: 0;
    text-transform: none;
    font-family: var(--pc-font-mono);
  }
  .foot em { color: #e89a2d; font-style: italic; }
  .foot a { color: #e89a2d; text-decoration: underline; }
</style>
