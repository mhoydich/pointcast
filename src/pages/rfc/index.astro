---
/**
 * /rfc — index of every PointCast RFC.
 *
 * Mirrors the /decks/ and /sprints/ patterns. Newest filedAt first.
 * Each card links to /rfc/{slug}. Agent manifest at /rfc.json.
 */
import BlockLayout from '../../layouts/BlockLayout.astro';
import { listRfcs } from '../../lib/rfcs';

const rfcs = listRfcs();

const title = 'RFCs — PointCast protocol specifications';
const description =
  'Every formal spec PointCast publishes. CC0 spec text + MIT reference implementation. Comments invited at hello@pointcast.xyz or by GitHub issue. Agent manifest at /rfc.json.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'PointCast RFCs',
  description,
  url: 'https://pointcast.xyz/rfc',
  hasPart: rfcs.map((r) => ({
    '@type': 'TechArticle',
    name: r.title,
    datePublished: r.filedAt,
    url: `https://pointcast.xyz/rfc/${r.slug}`,
  })),
};

function fmtDate(raw: string): string {
  const m = raw.match(/\d{4}-\d{2}-\d{2}/);
  if (!m) return raw;
  try {
    return new Intl.DateTimeFormat('en-US', {
      year: 'numeric',
      month: 'short',
      day: '2-digit',
      timeZone: 'America/Los_Angeles',
    }).format(new Date(m[0]));
  } catch {
    return raw;
  }
}
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>rfc</span>
    </nav>

    <header class="head">
      <p class="kicker mono">RFCS · PROTOCOL SPECS</p>
      <h1 class="title">What PointCast is offering to codify.</h1>
      <p class="dek">
        Each RFC is a formal specification written at PointCast,
        published CC0, with an MIT reference implementation. v0 versions
        are explicitly drafts — comments invited. Agent manifest at
        <a href="/rfc.json"><code>/rfc.json</code></a>.
      </p>
      <ul class="stats">
        <li><span class="stats__num">{rfcs.length}</span><span class="stats__lbl mono">RFCS</span></li>
        <li><span class="stats__num">{rfcs.reduce((a, r) => a + r.wordCount, 0).toLocaleString()}</span><span class="stats__lbl mono">WORDS TOTAL</span></li>
      </ul>
    </header>

    {rfcs.length === 0 ? (
      <section class="empty">
        <p>No RFCs yet. First one when one lands.</p>
      </section>
    ) : (
      <ol class="list">
        {rfcs.map((r) => (
          <li class="item">
            <div class="item__meta mono">
              <span class="item__ver">{r.version || 'draft'}</span>
              <span class="item__status">{r.status || 'working draft'}</span>
              {r.filedAt && <span class="item__date">{fmtDate(r.filedAt)}</span>}
              <span class="item__words">{r.wordCount.toLocaleString()} words</span>
            </div>
            <h2 class="item__title"><a href={`/rfc/${r.slug}`}>{r.title}</a></h2>
            {r.abstract && <p class="item__abs">{r.abstract.split('\n')[0].slice(0, 320)}</p>}
            <p class="item__links mono">
              <a href={`/rfc/${r.slug}`}>read →</a>
              <span aria-hidden="true"> · </span>
              <a href={`https://github.com/mhoydich/pointcast/blob/main/docs/rfc/${r.slug}.md`}>source</a>
            </p>
          </li>
        ))}
      </ol>
    )}

    <footer class="foot mono">
      <p>
        SCHEMA <code>src/lib/rfcs.ts</code> · DOCS
        <code>docs/rfc/{`{slug}.md`}</code> · RENDERER
        <code>src/lib/rfc-render.ts</code>
      </p>
    </footer>
  </main>
</BlockLayout>

<style>
  .page { max-width: 820px; margin: 0 auto; padding: 3rem 1.5rem 6rem; }
  .crumb { font-family: ui-monospace, 'JetBrains Mono', monospace; font-size: 0.82rem; opacity: 0.6; margin-bottom: 1.5rem; }
  .crumb a { color: inherit; text-decoration: none; }
  .crumb a:hover { text-decoration: underline; }

  .head { border-bottom: 2px solid currentColor; padding-bottom: 2rem; margin-bottom: 3rem; }
  .kicker { font-size: 0.8rem; letter-spacing: 0.28em; text-transform: uppercase; opacity: 0.7; margin-bottom: 1rem; }
  .mono { font-family: ui-monospace, 'JetBrains Mono', monospace; }
  .title { font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(2.2rem, 4.8vw, 3.8rem); line-height: 1; letter-spacing: -0.02em; margin-bottom: 1rem; }
  .dek { font-size: 1.05rem; line-height: 1.5; max-width: 60ch; opacity: 0.88; }
  .dek a, .dek code { color: inherit; }
  .dek code { font-family: ui-monospace, 'JetBrains Mono', monospace; font-size: 0.92em; padding: 0 0.3em; }

  .stats { list-style: none; display: flex; gap: 2rem; margin-top: 1.4rem; padding: 0; flex-wrap: wrap; }
  .stats li { display: flex; flex-direction: column; gap: 0.2rem; }
  .stats__num { font-family: 'DM Serif Display', Georgia, serif; font-size: 2rem; line-height: 1; }
  .stats__lbl { font-size: 0.68rem; letter-spacing: 0.22em; opacity: 0.6; }

  .list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 2.2rem; }
  .item__meta { display: flex; gap: 0.9rem; font-size: 0.74rem; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.65; flex-wrap: wrap; margin-bottom: 0.4rem; }
  .item__ver { color: var(--dusk, #F0B94A); }
  .item__title { font-family: 'DM Serif Display', Georgia, serif; font-size: 1.7rem; line-height: 1.1; letter-spacing: -0.01em; margin-bottom: 0.5rem; }
  .item__title a { color: inherit; text-decoration: none; background-image: linear-gradient(currentColor, currentColor); background-size: 0 1px; background-repeat: no-repeat; background-position: 0 100%; transition: background-size 0.25s ease; }
  .item__title a:hover { background-size: 100% 1px; }
  .item__abs { font-size: 0.98rem; line-height: 1.5; opacity: 0.85; margin-bottom: 0.5rem; }
  .item__links { font-size: 0.78rem; }
  .item__links a { color: inherit; }

  .foot { border-top: 1px dashed currentColor; margin-top: 4rem; padding-top: 1.5rem; opacity: 0.55; font-size: 0.78rem; letter-spacing: 0.1em; }
  .foot code { padding: 0 0.3em; opacity: 0.85; }

  .empty { padding: 3rem 0; text-align: center; opacity: 0.6; }
</style>
