---
/**
 * /rfc/[slug] — render a single RFC from docs/rfc/*.md.
 *
 * Reads the markdown file via the build-time glob in src/lib/rfcs.ts,
 * renders the body with the minimal in-repo Markdown renderer at
 * src/lib/rfc-render.ts, and wraps it in BlockLayout chrome. Adds the
 * og:image poster from public/posters/rfc-{slug}.png when present; the
 * build-deck-poster.mjs pattern can be extended there later.
 *
 * Source of truth: docs/rfc/{slug}.md.
 */
import BlockLayout from '../../layouts/BlockLayout.astro';
import { listRfcs, getRfc } from '../../lib/rfcs';
import { renderMarkdown } from '../../lib/rfc-render';

export function getStaticPaths() {
  return listRfcs().map((r) => ({ params: { slug: r.slug } }));
}

const { slug } = Astro.params;
const rfc = getRfc(slug!);
if (!rfc) {
  return Astro.redirect('/rfc');
}

const html = renderMarkdown(rfc.body);

const title = `${rfc.title} — PointCast RFC`;
const description = rfc.abstract.split('\n').slice(0, 2).join(' ').slice(0, 300);
const canonicalUrl = `https://pointcast.xyz/rfc/${rfc.slug}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: rfc.title,
  datePublished: rfc.filedAt,
  author: {
    '@type': 'Organization',
    name: 'PointCast',
    url: 'https://pointcast.xyz',
  },
  inLanguage: 'en',
  url: canonicalUrl,
  license: 'https://creativecommons.org/publicdomain/zero/1.0/',
  description,
};

function fmtFiled(raw: string): string {
  const m = raw.match(/\d{4}-\d{2}-\d{2}/);
  if (!m) return raw;
  try {
    return new Intl.DateTimeFormat('en-US', {
      year: 'numeric',
      month: 'short',
      day: '2-digit',
      timeZone: 'America/Los_Angeles',
    }).format(new Date(m[0]));
  } catch {
    return raw;
  }
}
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="rfc">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <a href="/rfc">rfc</a>
      <span aria-hidden="true">›</span>
      <span>{rfc.slug}</span>
    </nav>

    <header class="rfc__head">
      <p class="kicker mono">RFC · {rfc.version || 'draft'} · {rfc.status || 'working draft'}</p>
      <h1 class="rfc__title">{rfc.title}</h1>
      <dl class="rfc__meta mono">
        {rfc.filedAt && (
          <><dt>Filed</dt><dd>{fmtFiled(rfc.filedAt)}</dd></>
        )}
        {rfc.editors && (
          <><dt>Editors</dt><dd>{rfc.editors}</dd></>
        )}
        {rfc.license && (
          <><dt>License</dt><dd>{rfc.license}</dd></>
        )}
        {rfc.contact && (
          <><dt>Contact</dt><dd>{rfc.contact}</dd></>
        )}
        <dt>Words</dt><dd>{rfc.wordCount.toLocaleString()}</dd>
        <dt>Canonical</dt><dd><a href={canonicalUrl}>{canonicalUrl.replace(/^https?:\/\//, '')}</a></dd>
      </dl>
    </header>

    <article class="rfc__body" set:html={html}></article>

    <footer class="rfc__foot mono">
      <p>
        Source: <a href={`https://github.com/mhoydich/pointcast/blob/main/docs/rfc/${rfc.slug}.md`}>docs/rfc/{rfc.slug}.md</a> ·
        Index: <a href="/rfc">/rfc</a> ·
        Agent: <a href="/rfc.json">/rfc.json</a> ·
        Comments: <a href="mailto:hello@pointcast.xyz">hello@pointcast.xyz</a>
      </p>
    </footer>
  </main>
</BlockLayout>

<style>
  .rfc { max-width: 780px; margin: 0 auto; padding: 3rem 1.5rem 6rem; }
  .crumb { font-family: ui-monospace, 'JetBrains Mono', monospace; font-size: 0.82rem; opacity: 0.6; margin-bottom: 1.5rem; }
  .crumb a { color: inherit; text-decoration: none; }
  .crumb a:hover { text-decoration: underline; }

  .rfc__head { border-bottom: 2px solid currentColor; padding-bottom: 2rem; margin-bottom: 3rem; }
  .kicker { font-size: 0.8rem; letter-spacing: 0.28em; text-transform: uppercase; opacity: 0.7; margin-bottom: 1rem; }
  .mono { font-family: ui-monospace, 'JetBrains Mono', monospace; }
  .rfc__title { font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(2rem, 4.5vw, 3.6rem); line-height: 1; letter-spacing: -0.02em; margin-bottom: 1.6rem; }
  .rfc__meta { display: grid; grid-template-columns: auto 1fr; gap: 0.4rem 1.2rem; font-size: 0.82rem; }
  .rfc__meta dt { opacity: 0.55; letter-spacing: 0.1em; text-transform: uppercase; }
  .rfc__meta dd { margin: 0; opacity: 0.92; }
  .rfc__meta dd a { color: inherit; }

  .rfc__body { line-height: 1.65; font-size: 1.04rem; }
  .rfc__body :global(h1) { display: none; }
  .rfc__body :global(h2) { font-family: 'DM Serif Display', Georgia, serif; font-size: 1.8rem; line-height: 1.1; letter-spacing: -0.01em; margin: 2.8rem 0 1rem; border-top: 1px solid currentColor; padding-top: 2rem; }
  .rfc__body :global(h3) { font-family: 'DM Serif Display', Georgia, serif; font-size: 1.3rem; line-height: 1.2; margin: 2rem 0 0.6rem; opacity: 0.92; }
  .rfc__body :global(h4) { font-family: 'DM Serif Display', Georgia, serif; font-size: 1.1rem; margin: 1.6rem 0 0.5rem; }
  .rfc__body :global(p) { margin: 0 0 1.1rem; }
  .rfc__body :global(ul),
  .rfc__body :global(ol) { margin: 0 0 1.2rem 1.4rem; }
  .rfc__body :global(li) { margin-bottom: 0.3rem; }
  .rfc__body :global(strong) { font-weight: 600; }
  .rfc__body :global(em) { font-style: italic; }
  .rfc__body :global(a) { color: inherit; background-image: linear-gradient(currentColor, currentColor); background-size: 100% 1px; background-repeat: no-repeat; background-position: 0 100%; opacity: 0.9; }
  .rfc__body :global(a:hover) { opacity: 1; }
  .rfc__body :global(code) { font-family: ui-monospace, 'JetBrains Mono', monospace; font-size: 0.9em; background: rgba(0,0,0,0.06); padding: 0.1em 0.35em; border-radius: 2px; }
  .rfc__body :global(pre.rfc-code) { background: #0B0B10; color: #F4ECDC; padding: 1.1rem 1.3rem; border-radius: 4px; overflow-x: auto; font-size: 0.88rem; margin: 1.2rem 0; line-height: 1.55; }
  .rfc__body :global(pre.rfc-code code) { background: transparent; padding: 0; color: inherit; }
  .rfc__body :global(table.rfc-table) { border-collapse: collapse; width: 100%; margin: 1.2rem 0; font-size: 0.92rem; }
  .rfc__body :global(table.rfc-table th),
  .rfc__body :global(table.rfc-table td) { border-bottom: 1px solid currentColor; padding: 0.55rem 0.7rem; text-align: left; vertical-align: top; }
  .rfc__body :global(table.rfc-table th) { opacity: 0.7; letter-spacing: 0.05em; font-weight: 600; }
  .rfc__body :global(hr) { border: none; border-top: 1px dashed currentColor; opacity: 0.35; margin: 2rem 0; }
  .rfc__body :global(blockquote) { border-left: 3px solid currentColor; padding-left: 1rem; margin: 1.2rem 0; opacity: 0.78; font-style: italic; }

  .rfc__foot { margin-top: 4rem; padding-top: 1.5rem; border-top: 1px solid currentColor; font-size: 0.78rem; opacity: 0.65; }
  .rfc__foot a { color: inherit; }

  @media (max-width: 640px) {
    .rfc__meta { grid-template-columns: 1fr; gap: 0.1rem 0; }
    .rfc__meta dt { margin-top: 0.6rem; }
  }
</style>
