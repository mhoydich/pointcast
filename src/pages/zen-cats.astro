---
import BlockLayout from '../layouts/BlockLayout.astro';
import contracts from '../data/contracts.json';
import {
  ZEN_CAT_GENESIS_COLLECTIBLES,
  ZEN_CAT_WORLD_COLLECTIBLES,
} from '../data/zen-cat-collectibles';
import {
  ZEN_CAT_CAPITAL_PATHWAY,
  ZEN_CAT_CAPITAL_STORAGE_KEYS,
  ZEN_CAT_JOURNEY_SERIES,
  ZEN_CAT_REFERRAL_MILESTONES,
  ZEN_CAT_RITUALS,
  ZEN_CATS_STORAGE_KEYS,
  ZEN_CATS_SYMBOL,
  buildZenCatsManifest,
  recentZenCats,
  todayZenCat,
} from '../lib/zen-cats';

const today = todayZenCat();
const recent = recentZenCats(9);
const genesisCollectibles = ZEN_CAT_GENESIS_COLLECTIBLES;
const worldCollectibles = ZEN_CAT_WORLD_COLLECTIBLES;
const worldGemOptions = Array.from(new Set(worldCollectibles.map((item) => item.gem))).sort((a, b) =>
  a.localeCompare(b),
);
const worldGemLedger = worldGemOptions.map((gem) => ({
  gem,
  count: worldCollectibles.filter((item) => item.gem === gem).length,
}));
const spotlightWorld = Array.from({ length: 4 }, (_, index) => {
  const cursor = (today.seed + index * 7) % worldCollectibles.length;
  return worldCollectibles[cursor];
});
const cat = today.cat;
const palette = cat.palette;
const zenCatsMainnet = ((contracts as any).zen_cats?.mainnet ?? '').trim();
const mintLive = zenCatsMainnet.startsWith('KT1');
const metadataBase =
  ((contracts as any).zen_cats?.metadataBaseUrl ?? 'https://pointcast.xyz/api/zen-cat-metadata').trim();
const manifest = buildZenCatsManifest();

const clientData = {
  today,
  rituals: ZEN_CAT_RITUALS,
  contract: {
    network: 'mainnet',
    address: zenCatsMainnet,
    live: mintLive,
    metadataBase,
  },
  storageKeys: ZEN_CATS_STORAGE_KEYS,
  passportStamp: 'zen-cat',
  capital: {
    storageKeys: ZEN_CAT_CAPITAL_STORAGE_KEYS,
    pathway: ZEN_CAT_CAPITAL_PATHWAY,
    referralMilestones: ZEN_CAT_REFERRAL_MILESTONES,
    journeySeries: ZEN_CAT_JOURNEY_SERIES,
  },
  genesis: genesisCollectibles.map((item) => ({
    id: item.id,
    title: item.title,
    cat: item.cat,
    gem: item.gem,
    rarity: item.rarity,
    imageUrl: item.imageUrl,
  })),
  world: worldCollectibles.map((item) => ({
    id: item.id,
    number: item.number,
    title: item.title,
    city: item.city,
    country: item.country,
    landmark: item.landmark,
    cat: item.cat,
    gem: item.gem,
    mood: item.mood,
    rarity: item.rarity,
    palette: item.palette,
    prompt: item.prompt,
  })),
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Game',
  '@id': 'https://pointcast.xyz/zen-cats#game',
  name: 'Zen Cat Garden',
  description:
    'A daily PointCast collection game with local zen cat care and Tezos-ready PCCAT metadata.',
  url: 'https://pointcast.xyz/zen-cats',
  gamePlatform: ['Web', 'Tezos'],
  genre: ['collection game', 'daily ritual'],
  inLanguage: 'en-US',
  potentialAction: {
    '@type': 'PlayAction',
    target: 'https://pointcast.xyz/zen-cats',
  },
};
---

<BlockLayout
  title="Zen Cat Garden"
  description="A daily PointCast collection game: care for one calm cat, collect it locally, and mint PCCAT on Tezos once the dedicated contract is deployed."
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/zen-cats.json', title: 'Zen Cat Garden manifest' }]}
  frame={{
    image: 'https://pointcast.xyz/images/og/og-home-v2.png',
    buttons: [
      { label: 'Open Zen Cats', action: 'link', target: 'https://pointcast.xyz/zen-cats' },
      { label: 'Cat JSON', action: 'link', target: 'https://pointcast.xyz/zen-cats.json' },
      { label: 'Play Layer', action: 'link', target: 'https://pointcast.xyz/play' },
    ],
  }}
>
  <main class="zen-cat-game" data-zen-cat-game data-token-id={today.tokenId}>
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/play">play</a>
      <span aria-hidden="true">/</span>
      <span>zen-cats</span>
    </nav>

    <header class="cat-hero">
      <div class="cat-hero__copy">
        <p class="kicker">ZEN CAT GARDEN · {today.date} · {ZEN_CATS_SYMBOL}</p>
        <h1>{cat.name} is today's calm little collectible.</h1>
        <p>
          {cat.coat}, {cat.posture}. Room weather: {today.weather}. Mantra:
          <strong>{cat.mantra}</strong>
        </p>
        <div class="cat-actions" aria-label="Primary Zen Cat routes">
          <a href="/zen-cats.json">JSON</a>
          <a href={today.metadataUrl}>Metadata</a>
          <a href={today.imageUrl}>SVG</a>
          <a href="/play">Play Layer</a>
        </div>
      </div>

      <aside class="cat-card" aria-label={`Daily cat ${cat.name}`}>
        <div class="cat-stage" style={`--ground:${palette.ground};--paper:${palette.paper};--fur:${palette.fur};--fur-alt:${palette.furAlt};--accent:${palette.accent};--ink:${palette.ink};`}>
          <svg viewBox="0 0 360 360" role="img" aria-labelledby="cat-svg-title cat-svg-desc">
            <title id="cat-svg-title">{cat.name}, the daily zen cat</title>
            <desc id="cat-svg-desc">{cat.coat}, {cat.posture}, carrying a {cat.charm}.</desc>
            <rect width="360" height="360" rx="18" fill="var(--ground)" />
            <path d="M42 290h276" stroke="var(--ink)" stroke-width="4" stroke-linecap="round" opacity="0.22" />
            <path d="M75 244c32 20 178 20 210 0v42c-38 22-172 22-210 0z" fill="var(--paper)" stroke="var(--ink)" stroke-width="5" />
            <path d="M104 171c0-56 38-97 82-97s82 41 82 97v51c0 46-34 77-82 77s-82-31-82-77z" fill="var(--fur)" stroke="var(--ink)" stroke-width="6" />
            <path d="M122 91l-3-50 38 35" fill="var(--fur)" stroke="var(--ink)" stroke-width="6" stroke-linejoin="round" />
            <path d="M250 91l3-50-38 35" fill="var(--fur)" stroke="var(--ink)" stroke-width="6" stroke-linejoin="round" />
            <path d="M141 106c27-16 65-18 94 0v42c-32-18-65-17-94 0z" fill="var(--fur-alt)" opacity="0.42" />
            <path d="M154 176c10 9 22 9 32 0" fill="none" stroke="var(--paper)" stroke-width="6" stroke-linecap="round" />
            <path d="M206 176c10 9 22 9 32 0" fill="none" stroke="var(--paper)" stroke-width="6" stroke-linecap="round" />
            <path d="M190 194l-9 9h18z" fill="var(--accent)" stroke="var(--ink)" stroke-width="4" stroke-linejoin="round" />
            <path d="M171 219c9 10 21 13 34 0" fill="none" stroke="var(--paper)" stroke-width="5" stroke-linecap="round" />
            <path d="M113 207c-24-10-44-11-63-3M115 225c-25 1-45 9-61 21M257 207c24-10 44-11 63-3M255 225c25 1 45 9 61 21" stroke="var(--ink)" stroke-width="4" stroke-linecap="round" opacity="0.58" />
            <circle cx="186" cy="258" r="16" fill="var(--accent)" stroke="var(--ink)" stroke-width="5" />
            <path d="M186 274v21" stroke="var(--ink)" stroke-width="4" stroke-linecap="round" />
            <text x="180" y="330" text-anchor="middle" fill="var(--ink)" font-family="monospace" font-size="14">#{today.tokenId}</text>
          </svg>
        </div>
        <dl class="cat-facts">
          <div><dt>Room</dt><dd>{today.room}</dd></div>
          <div><dt>Mood</dt><dd>{cat.mood}</dd></div>
          <div><dt>Charm</dt><dd>{cat.charm}</dd></div>
          <div><dt>Rarity</dt><dd>{today.rarity}</dd></div>
        </dl>
      </aside>
    </header>

    <section class="garden-dashboard" aria-label="Zen Cat collection progress">
      <article>
        <p class="kicker">TODAY</p>
        <strong data-dashboard-total>0</strong>
        <span>cats, stamps, and cards held locally</span>
      </article>
      <article>
        <p class="kicker">GENESIS</p>
        <strong><span data-dashboard-genesis>0</span> / {genesisCollectibles.length}</strong>
        <span>founding art cards on the shelf</span>
        <meter min="0" max={genesisCollectibles.length} value="0" data-genesis-meter></meter>
      </article>
      <article>
        <p class="kicker">PASSPORT</p>
        <strong><span data-dashboard-world>0</span> / {worldCollectibles.length}</strong>
        <span>World Atelier places stamped</span>
        <meter min="0" max={worldCollectibles.length} value="0" data-world-meter></meter>
      </article>
      <article>
        <p class="kicker">NEXT</p>
        <strong data-dashboard-next>ritual</strong>
        <span data-dashboard-next-detail>Start with the daily care ritual.</span>
      </article>
    </section>

    <section class="ritual-panel" aria-labelledby="ritual-title">
      <div class="panel-head">
        <p class="kicker">DAILY RITUAL</p>
        <h2 id="ritual-title">Care, collect, mint when ready.</h2>
        <p data-ritual-status>0 / {ZEN_CAT_RITUALS.length} care actions complete.</p>
      </div>
      <div class="ritual-grid">
        {ZEN_CAT_RITUALS.map((ritual) => (
          <button class="ritual-button" type="button" data-ritual-id={ritual.id}>
            <span>{ritual.label}</span>
            <small>{ritual.detail}</small>
          </button>
        ))}
      </div>
      <div class="mint-console">
        <div>
          <span class="console-label">Daily token</span>
          <strong>#{today.tokenId}</strong>
          <p data-collection-status>Complete the ritual to collect today's cat.</p>
        </div>
        <button class="collect-button" type="button" data-collect-cat disabled>Collect locally</button>
        <button class="mint-button" type="button" data-mint-cat disabled>
          {mintLive ? 'Mint on Tezos' : 'Tezos mint pending'}
        </button>
      </div>
      <p class="mint-note" data-mint-status>
        {mintLive
          ? `PCCAT contract: ${zenCatsMainnet}`
          : 'PCCAT needs a dedicated FA2 contract. Visit Nouns is live, but it stays Noun-shaped.'}
      </p>
    </section>

    <section class="quest-panel" aria-labelledby="quest-title">
      <div class="panel-head">
        <p class="kicker">TODAY'S GARDEN QUEST</p>
        <h2 id="quest-title">Make the day feel owned.</h2>
        <p>
          A small local quest chain ties the daily cat, Genesis shelf, and World passport together.
        </p>
      </div>
      <ol class="quest-list">
        <li data-quest-step="ritual">
          <span>01</span>
          <strong>Complete the care ritual</strong>
          <small data-quest-status="ritual">Waiting for three calm actions.</small>
        </li>
        <li data-quest-step="daily">
          <span>02</span>
          <strong>Collect today's cat</strong>
          <small data-quest-status="daily">Ready after the ritual.</small>
        </li>
        <li data-quest-step="genesis">
          <span>03</span>
          <strong>Add a Genesis card</strong>
          <small data-quest-status="genesis">Choose one founding collectible.</small>
        </li>
        <li data-quest-step="world">
          <span>04</span>
          <strong>Stamp a World Atelier place</strong>
          <small data-quest-status="world">Pick a city or gem below.</small>
        </li>
      </ol>
    </section>

    <section class="capital-pathway" id="capital-pathway" aria-labelledby="capital-title">
      <div class="panel-head">
        <p class="kicker">CAPITAL PATHWAY · GARDEN TO BITCOIN</p>
        <h2 id="capital-title">Grow the circle first. Let capital follow proof.</h2>
        <p>
          A referral path for Zen Cats: one direct layer, no pay-to-join rewards, no guaranteed
          yield, and no custody. The game can measure audience, sales readiness, and earned-surplus
          planning before any Bitcoin step is even considered.
        </p>
      </div>
      <div class="capital-console">
        <article class="referral-console" aria-label="Referral console">
          <p class="kicker">REFERRAL CODE</p>
          <strong data-referral-code>creating</strong>
          <p data-referral-status>Generating a browser-local invite link.</p>
          <label>
            <span>Invite link</span>
            <input readonly data-referral-link value="https://pointcast.xyz/zen-cats" />
          </label>
          <div class="capital-actions">
            <button type="button" data-copy-referral>Copy invite</button>
            <button type="button" data-log-referral>Log real invite</button>
          </div>
        </article>
        <article class="capital-scoreboard" aria-label="Capital pathway scoreboard">
          <div>
            <p class="kicker">CAPITAL SCORE</p>
            <strong data-capital-score>0</strong>
          </div>
          <dl>
            <div><dt>Stage</dt><dd data-capital-stage>Seed Signal</dd></div>
            <div><dt>Direct referrals</dt><dd data-referral-count>0</dd></div>
            <div><dt>Next unlock</dt><dd data-capital-milestone>First Signal</dd></div>
            <div><dt>Bitcoin readiness</dt><dd data-btc-readiness>education only</dd></div>
          </dl>
        </article>
        <article class="allocation-simulator" aria-label="Earned surplus simulator">
          <p class="kicker">EARNED SURPLUS SIMULATOR</p>
          <div class="allocation-controls">
            <label>
              <span>Monthly surplus</span>
              <input type="number" data-capital-monthly min="0" step="25" value="250" inputmode="decimal" />
            </label>
            <label>
              <span>Bitcoin reserve</span>
              <input type="range" data-capital-btc-share min="0" max="80" value="25" />
            </label>
          </div>
          <dl>
            <div><dt>Yearly surplus</dt><dd data-capital-yearly>$3,000</dd></div>
            <div><dt>BTC reserve</dt><dd data-capital-btc>$750</dd></div>
            <div><dt>Studio / runway</dt><dd data-capital-creative>$2,250</dd></div>
          </dl>
          <p>
            Simulation only. This does not predict appreciation, income, tax outcome, or investment return.
          </p>
        </article>
      </div>
      <ol class="capital-steps" aria-label="Garden to Bitcoin stages">
        {ZEN_CAT_CAPITAL_PATHWAY.map((stage) => (
          <li data-capital-stage-card={stage.id} data-capital-stage-points={stage.points}>
            <span>{stage.rung}</span>
            <h3>{stage.label}</h3>
            <dl>
              <div><dt>Trigger</dt><dd>{stage.trigger}</dd></div>
              <div><dt>Unlock</dt><dd>{stage.unlock}</dd></div>
              <div><dt>Capital action</dt><dd>{stage.capitalAction}</dd></div>
              <div><dt>Bitcoin step</dt><dd>{stage.bitcoinStep}</dd></div>
            </dl>
          </li>
        ))}
      </ol>
      <div class="journey-head">
        <div>
          <p class="kicker">JOURNEY PRINTS · COLLECTIBLE SERIES</p>
          <h3>Eight art cards for the path from attention to reserve.</h3>
        </div>
        <p>
          <span data-journey-count>0</span> / {ZEN_CAT_JOURNEY_SERIES.length} prints collected.
          Each unlocks from progress in the garden; the final cards stay gated behind safety.
        </p>
      </div>
      <ol class="journey-grid" aria-label="Journey Prints collectible art series">
        {ZEN_CAT_JOURNEY_SERIES.map((print) => (
          <li
            data-journey-card={print.id}
            data-journey-points={print.pointsRequired}
            style={`--journey-ground:${print.palette.ground};--journey-accent:${print.palette.accent};--journey-secondary:${print.palette.secondary};--journey-ink:${print.palette.ink};`}
          >
            <div class="journey-art" aria-hidden="true">
              <span class="journey-art__sun"></span>
              <span class="journey-art__path"></span>
              <span class="journey-art__cat"></span>
            </div>
            <div class="journey-body">
              <p>#{String(print.number).padStart(2, '0')} · {print.rarity}</p>
              <h4>{print.title}</h4>
              <dl>
                <div><dt>Motif</dt><dd>{print.motif}</dd></div>
                <div><dt>Lesson</dt><dd>{print.lesson}</dd></div>
                <div><dt>Medium</dt><dd>{print.medium}</dd></div>
              </dl>
              <button type="button" data-journey-id={print.id}>Locked</button>
            </div>
          </li>
        ))}
      </ol>
      <div class="capital-guardrails">
        <strong>Referral covenant</strong>
        <p>
          Rewards stay single-level and tied to genuine product activity. No guaranteed returns,
          pooled treasury, leverage, custody, or multi-level payout tree ships from this page.
        </p>
      </div>
    </section>

    <section class="shelf-panel" aria-labelledby="shelf-title">
      <div class="panel-head">
        <p class="kicker">COLLECTION SHELF</p>
        <h2 id="shelf-title">Nine recent cats, one per Pacific day.</h2>
        <p>
          <span data-collection-count>0</span> daily cats and
          <span data-genesis-count>0</span> Genesis cats collected in this browser.
          Passport stamps: <span data-world-count>0</span>.
        </p>
      </div>
      <ol class="cat-shelf">
        {recent.map((entry) => (
          <li data-shelf-date={entry.date} data-shelf-token={entry.tokenId}>
            <span class="mini-cat" style={`--mini-fur:${entry.cat.palette.fur};--mini-accent:${entry.cat.palette.accent};--mini-ink:${entry.cat.palette.ink};`} aria-hidden="true">
              <span></span>
            </span>
            <strong>{entry.cat.name}</strong>
            <small>{entry.date}</small>
          </li>
        ))}
      </ol>
    </section>

    <section class="genesis-panel" aria-labelledby="genesis-title">
      <div class="panel-head">
        <p class="kicker">GENESIS GARDEN · EARLY COLLECTIBLES</p>
        <h2 id="genesis-title">The first 16 cats are now inside the garden.</h2>
        <p>
          These are the founding art cards: textile texture, quiet luxury, blue-coral rooms,
          and gem-linked traits before the PCCAT contract goes live.
        </p>
      </div>
      <div class="genesis-grid">
        {genesisCollectibles.map((item) => (
          <article
            class="genesis-card"
            data-genesis-card={item.id}
            style={`--genesis-ground:${item.palette.ground};--genesis-accent:${item.palette.accent};--genesis-ink:${item.palette.ink};`}
          >
            <a href={item.imageUrl} aria-label={`Open ${item.title}`}>
              <img src={item.imageUrl} alt={`${item.title}, ${item.cat}`} width="1024" height="768" loading="lazy" decoding="async" />
            </a>
            <div class="genesis-card__body">
              <p>#{String(item.number).padStart(3, '0')} · {item.rarity}</p>
              <h3>{item.title}</h3>
              <dl>
                <div><dt>Gem</dt><dd>{item.gem}</dd></div>
                <div><dt>Cat</dt><dd>{item.cat}</dd></div>
                <div><dt>Mood</dt><dd>{item.mood}</dd></div>
              </dl>
              <button type="button" data-genesis-id={item.id}>Add to shelf</button>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="world-panel" aria-labelledby="world-title">
      <div class="panel-head">
        <p class="kicker">WORLD ATELIER · 50 PASSPORT CATS</p>
        <h2 id="world-title">Luxury, landmark, gemstone, calm.</h2>
        <p>
          The next collection is mapped as 50 global art prompts: each cat gets a place,
          a landmark cue, a gemstone color story, and a quiet high-end mood.
        </p>
      </div>
      <div class="passport-desk">
        <div class="passport-desk__copy">
          <p class="kicker">PASSPORT DESK</p>
          <h3>Four places are calling today.</h3>
          <ol>
            {spotlightWorld.map((item) => (
              <li>
                <button type="button" data-world-focus={item.id}>
                  <strong>{item.title}</strong>
                  <span>{item.city}, {item.country} · {item.gem}</span>
                </button>
              </li>
            ))}
          </ol>
        </div>
        <div class="gem-ledger" aria-label="World Atelier gem ledger">
          <p class="kicker">GEM LEDGER</p>
          <div>
            {worldGemLedger.map((item) => (
              <button type="button" data-gem-focus={item.gem}>
                <span>{item.gem}</span>
                <strong>{item.count}</strong>
              </button>
            ))}
          </div>
        </div>
      </div>
      <div class="world-tools" aria-label="World Atelier filters">
        <label>
          <span>Search</span>
          <input type="search" data-world-search placeholder="city, gem, landmark" />
        </label>
        <label>
          <span>Gem</span>
          <select data-world-gem>
            <option value="">All gems</option>
            {worldGemOptions.map((gem) => <option value={gem}>{gem}</option>)}
          </select>
        </label>
        <button type="button" data-world-random>Unvisited</button>
        <p data-world-visible>Showing {worldCollectibles.length} passport cats.</p>
      </div>
      <ol class="world-grid">
        {worldCollectibles.map((item) => (
          <li
            data-world-card={item.id}
            data-world-title={item.title}
            data-world-city={item.city}
            data-world-country={item.country}
            data-world-gem={item.gem}
            data-world-landmark={item.landmark}
            data-world-mood={item.mood}
            data-world-rarity={item.rarity}
            tabindex="0"
            aria-label={`Open passport detail for ${item.title}`}
            style={`--world-ground:${item.palette.ground};--world-accent:${item.palette.accent};--world-ink:${item.palette.ink};`}
          >
            <span class="world-grid__number">{String(item.number).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.city}, {item.country}</p>
            <dl>
              <div><dt>Landmark</dt><dd>{item.landmark}</dd></div>
              <div><dt>Gem</dt><dd>{item.gem}</dd></div>
              <div><dt>Cat</dt><dd>{item.cat}</dd></div>
            </dl>
            <div class="world-grid__actions">
              <button type="button" data-world-open={item.id}>Open card</button>
              <button type="button" data-world-id={item.id}>Stamp passport</button>
            </div>
          </li>
        ))}
      </ol>
      <dialog class="passport-drawer" data-world-drawer aria-labelledby="passport-drawer-title">
        <div class="passport-drawer__shell">
          <div class="passport-drawer__art" data-world-drawer-art>
            <span class="passport-drawer__number" data-drawer-number>00</span>
            <svg viewBox="0 0 420 360" aria-hidden="true">
              <path class="drawer-landmark" d="M44 250c42-36 80-70 118-102 38 31 76 65 118 102M86 250V126h152v124M122 126c8-42 22-64 40-64s32 22 40 64M276 250c10-72 36-116 76-132 22 38 22 82 0 132" />
              <path class="drawer-cat-body" d="M126 263c0-58 44-98 100-98s100 40 100 98v22c0 32-34 52-100 52s-100-20-100-52z" />
              <path class="drawer-cat-ear" d="M156 177l-8-60 52 42" />
              <path class="drawer-cat-ear" d="M296 177l8-60-52 42" />
              <path class="drawer-cat-face" d="M194 234c10 8 22 8 32 0M248 234c10 8 22 8 32 0M240 254l-12 12h24zM219 282c12 12 28 12 42 0" />
              <path class="drawer-whisker" d="M188 263c-42-17-76-15-108 4M190 280c-43 4-76 18-102 40M288 263c42-17 76-15 108 4M286 280c43 4 76 18 102 40" />
            </svg>
            <div class="passport-stamp-mark" data-drawer-stamp-mark>
              <span data-drawer-stamp-code>OPEN</span>
              <strong>STAMPED</strong>
              <small data-drawer-stamp-date>UNVISITED</small>
            </div>
          </div>
          <div class="passport-drawer__body">
            <button class="passport-drawer__close" type="button" data-world-drawer-close aria-label="Close passport detail">Close</button>
            <p class="kicker" data-drawer-kicker>WORLD ATELIER PASSPORT</p>
            <h3 id="passport-drawer-title" data-drawer-title>Passport cat</h3>
            <p class="passport-drawer__place" data-drawer-place>City, country</p>
            <dl class="passport-drawer__facts">
              <div><dt>Landmark</dt><dd data-drawer-landmark></dd></div>
              <div><dt>Gem</dt><dd data-drawer-gem></dd></div>
              <div><dt>Cat</dt><dd data-drawer-cat></dd></div>
              <div><dt>Mood</dt><dd data-drawer-mood></dd></div>
              <div><dt>Rarity</dt><dd data-drawer-rarity></dd></div>
              <div><dt>Status</dt><dd data-drawer-status></dd></div>
            </dl>
            <p class="passport-drawer__note" data-drawer-note></p>
            <div class="passport-drawer__tezos">
              <span>Tezos slot</span>
              <strong data-drawer-tezos>{mintLive ? 'Ready after PCCAT mint action' : 'Reserved for PCCAT FA2'}</strong>
            </div>
            <div class="passport-drawer__actions">
              <button type="button" data-world-drawer-stamp>Stamp passport</button>
              <button type="button" data-world-drawer-locate>Find in grid</button>
            </div>
          </div>
        </div>
      </dialog>
      <div class="stamp-toast" data-stamp-toast hidden>
        <span>Passport stamped</span>
        <strong data-stamp-toast-title></strong>
        <small data-stamp-toast-code></small>
      </div>
    </section>

    <section class="agent-note" aria-labelledby="agent-note-title">
      <p class="kicker">AGENT HOOK</p>
      <h2 id="agent-note-title">The cat surface is machine-readable.</h2>
      <p>
        Agents can read <a href="/zen-cats.json">/zen-cats.json</a> for today's cat, localStorage keys,
        Genesis collectibles, the 50-cat world series, Tezos contract status, metadata base, and mint readiness.
      </p>
      <pre>{JSON.stringify({
        today: manifest.today,
        genesis: { count: manifest.genesis.count, storageKey: manifest.genesis.storageKey },
        worldAtelier: { count: manifest.worldAtelier.count, storageKey: manifest.worldAtelier.storageKey },
        capitalPathway: {
          stages: manifest.capitalPathway.stages.length,
          referralStorageKey: manifest.capitalPathway.storageKeys.referrals,
          journeyPrints: manifest.capitalPathway.journeySeries.count,
        },
        tezos: manifest.tezos,
      }, null, 2)}</pre>
    </section>
  </main>

  <script type="application/json" id="zen-cat-data" set:html={JSON.stringify(clientData)}></script>

  <script>
    import { mintZenCat } from '../lib/mint';

    const root = document.querySelector('[data-zen-cat-game]');
    const dataEl = document.getElementById('zen-cat-data');

    if (root && dataEl) {
      const DATA = JSON.parse(dataEl.textContent || '{}');
      const collectionKey = DATA.storageKeys.collection;
      const genesisKey = DATA.storageKeys.genesisCollection;
      const worldKey = DATA.storageKeys.worldCollection;
      const capitalProfileKey = DATA.capital?.storageKeys?.profile || 'pc:zen-cats:capital-profile';
      const capitalReferralKey = DATA.capital?.storageKeys?.referrals || 'pc:zen-cats:capital-referrals';
      const inboundReferralKey = DATA.capital?.storageKeys?.inboundReferral || 'pc:zen-cats:capital-inbound-referral';
      const journeyKey = DATA.capital?.storageKeys?.journeyCollection || 'pc:zen-cats:journey';
      const ritualKey = DATA.storageKeys.ritualPrefix + DATA.today.date;
      const ritualButtons = Array.from(root.querySelectorAll('[data-ritual-id]'));
      const genesisButtons = Array.from(root.querySelectorAll('[data-genesis-id]'));
      const worldButtons = Array.from(root.querySelectorAll('[data-world-id]'));
      const journeyButtons = Array.from(root.querySelectorAll('[data-journey-id]'));
      const journeyCards = Array.from(root.querySelectorAll('[data-journey-card]'));
      const worldOpenButtons = Array.from(root.querySelectorAll('[data-world-open]'));
      const worldCards = Array.from(root.querySelectorAll('[data-world-card]'));
      const worldFocusButtons = Array.from(root.querySelectorAll('[data-world-focus]'));
      const gemFocusButtons = Array.from(root.querySelectorAll('[data-gem-focus]'));
      const collectButton = root.querySelector('[data-collect-cat]');
      const mintButton = root.querySelector('[data-mint-cat]');
      const ritualStatus = root.querySelector('[data-ritual-status]');
      const collectionStatus = root.querySelector('[data-collection-status]');
      const collectionCount = root.querySelector('[data-collection-count]');
      const genesisCount = root.querySelector('[data-genesis-count]');
      const worldCount = root.querySelector('[data-world-count]');
      const dashboardTotal = root.querySelector('[data-dashboard-total]');
      const dashboardGenesis = root.querySelector('[data-dashboard-genesis]');
      const dashboardWorld = root.querySelector('[data-dashboard-world]');
      const dashboardNext = root.querySelector('[data-dashboard-next]');
      const dashboardNextDetail = root.querySelector('[data-dashboard-next-detail]');
      const genesisMeter = root.querySelector('[data-genesis-meter]');
      const worldMeter = root.querySelector('[data-world-meter]');
      const worldSearch = root.querySelector('[data-world-search]');
      const worldGemFilter = root.querySelector('[data-world-gem]');
      const worldVisible = root.querySelector('[data-world-visible]');
      const worldRandom = root.querySelector('[data-world-random]');
      const worldDrawer = root.querySelector('[data-world-drawer]');
      const drawerArt = root.querySelector('[data-world-drawer-art]');
      const drawerClose = root.querySelector('[data-world-drawer-close]');
      const drawerStamp = root.querySelector('[data-world-drawer-stamp]');
      const drawerLocate = root.querySelector('[data-world-drawer-locate]');
      const stampToast = root.querySelector('[data-stamp-toast]');
      const stampToastTitle = root.querySelector('[data-stamp-toast-title]');
      const stampToastCode = root.querySelector('[data-stamp-toast-code]');
      const referralCode = root.querySelector('[data-referral-code]');
      const referralStatus = root.querySelector('[data-referral-status]');
      const referralLink = root.querySelector('[data-referral-link]');
      const referralCount = root.querySelector('[data-referral-count]');
      const copyReferral = root.querySelector('[data-copy-referral]');
      const logReferral = root.querySelector('[data-log-referral]');
      const capitalScore = root.querySelector('[data-capital-score]');
      const capitalStage = root.querySelector('[data-capital-stage]');
      const capitalMilestone = root.querySelector('[data-capital-milestone]');
      const btcReadiness = root.querySelector('[data-btc-readiness]');
      const capitalStageCards = Array.from(root.querySelectorAll('[data-capital-stage-card]'));
      const capitalMonthly = root.querySelector('[data-capital-monthly]');
      const capitalBtcShare = root.querySelector('[data-capital-btc-share]');
      const capitalYearly = root.querySelector('[data-capital-yearly]');
      const capitalBtc = root.querySelector('[data-capital-btc]');
      const capitalCreative = root.querySelector('[data-capital-creative]');
      const journeyCount = root.querySelector('[data-journey-count]');
      const mintStatus = root.querySelector('[data-mint-status]');
      const shelves = Array.from(root.querySelectorAll('[data-shelf-date]'));
      let activeWorldId = DATA.world?.[0]?.id || null;
      let stampToastTimer;
      const questStatuses = {
        ritual: root.querySelector('[data-quest-status="ritual"]'),
        daily: root.querySelector('[data-quest-status="daily"]'),
        genesis: root.querySelector('[data-quest-status="genesis"]'),
        world: root.querySelector('[data-quest-status="world"]'),
      };
      const questSteps = {
        ritual: root.querySelector('[data-quest-step="ritual"]'),
        daily: root.querySelector('[data-quest-step="daily"]'),
        genesis: root.querySelector('[data-quest-step="genesis"]'),
        world: root.querySelector('[data-quest-step="world"]'),
      };

      function readJson(key, fallback) {
        try {
          const raw = localStorage.getItem(key);
          if (!raw) return fallback;
          const parsed = JSON.parse(raw);
          return parsed ?? fallback;
        } catch {
          return fallback;
        }
      }

      function writeJson(key, value) {
        try {
          localStorage.setItem(key, JSON.stringify(value));
        } catch {}
      }

      function collection() {
        const items = readJson(collectionKey, []);
        return Array.isArray(items) ? items : [];
      }

      function genesisCollection() {
        const items = readJson(genesisKey, []);
        return Array.isArray(items) ? items : [];
      }

      function worldCollection() {
        const items = readJson(worldKey, []);
        return Array.isArray(items) ? items : [];
      }

      function journeyCollection() {
        const items = readJson(journeyKey, []);
        return Array.isArray(items) ? items : [];
      }

      function capitalProfile() {
        const profile = readJson(capitalProfileKey, null);
        if (profile?.code) return profile;
        const seed = Math.random().toString(36).slice(2, 6).toUpperCase();
        const dateTail = String(DATA.today.tokenId).slice(-4);
        const next = {
          code: `ZC-${seed}-${dateTail}`,
          createdAt: new Date().toISOString(),
          source: 'zen-cats',
        };
        writeJson(capitalProfileKey, next);
        return next;
      }

      function inboundReferral() {
        const profile = capitalProfile();
        const params = new URLSearchParams(window.location.search);
        const ref = String(params.get('ref') || '').trim().toUpperCase();
        if (/^[A-Z0-9-]{4,32}$/.test(ref) && ref !== profile.code) {
          const entry = {
            code: ref,
            capturedAt: new Date().toISOString(),
            source: 'url',
          };
          writeJson(inboundReferralKey, entry);
          return entry;
        }
        return readJson(inboundReferralKey, null);
      }

      function referralEntries() {
        const items = readJson(capitalReferralKey, []);
        return Array.isArray(items) ? items : [];
      }

      function addReferralEntry() {
        const items = referralEntries();
        const nextNumber = items.length + 1;
        items.unshift({
          code: `DIRECT-${String(nextNumber).padStart(2, '0')}`,
          capturedAt: new Date().toISOString(),
          source: 'manual',
        });
        writeJson(capitalReferralKey, items.slice(0, 64));
        render();
      }

      function referralUrl(code) {
        const url = new URL(window.location.href);
        url.pathname = '/zen-cats';
        url.searchParams.set('ref', code);
        url.hash = 'capital-pathway';
        return url.toString();
      }

      function formatUsd(value) {
        try {
          return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 0,
          }).format(value);
        } catch {
          return `$${Math.round(value).toLocaleString('en-US')}`;
        }
      }

      function syncAllocationSimulator() {
        const monthly = Math.max(0, Number(capitalMonthly?.value || 0));
        const btcShare = Math.max(0, Math.min(80, Number(capitalBtcShare?.value || 0)));
        const yearly = monthly * 12;
        const btcReserve = yearly * (btcShare / 100);
        const studioReserve = yearly - btcReserve;

        if (capitalYearly) capitalYearly.textContent = formatUsd(yearly);
        if (capitalBtc) capitalBtc.textContent = `${formatUsd(btcReserve)} · ${btcShare}%`;
        if (capitalCreative) capitalCreative.textContent = formatUsd(studioReserve);
      }

      function capitalStageForScore(score) {
        const stages = DATA.capital?.pathway || [];
        return stages.reduce((active, stage) => (score >= stage.points ? stage : active), stages[0]);
      }

      function nextReferralMilestone(count) {
        const milestones = DATA.capital?.referralMilestones || [];
        return milestones.find((item) => count < item.count) || milestones[milestones.length - 1];
      }

      function capitalScoreFor(done, items, genesisItems, worldItems, referralItems, journeyItems) {
        return (
          done +
          items.length * 2 +
          genesisItems.length * 3 +
          worldItems.length * 2 +
          referralItems.length * 5 +
          journeyItems.length * 4
        );
      }

      function ritualState() {
        const state = readJson(ritualKey, {});
        return state && typeof state === 'object' ? state : {};
      }

      function isCollectedToday() {
        return collection().some((item) => item.date === DATA.today.date);
      }

      function passportStamp() {
        const key = 'pc:passport:stamps';
        const current = readJson(key, {});
        if (!current || typeof current !== 'object') return;
        current[DATA.passportStamp] = current[DATA.passportStamp] || {
          id: DATA.passportStamp,
          at: new Date().toISOString(),
          via: 'zen-cats',
        };
        writeJson(key, current);
      }

      function worldById(id) {
        return DATA.world.find((item) => item.id === id);
      }

      function worldStampEntry(id) {
        return worldCollection().find((item) => item.id === id);
      }

      function stampCode(item) {
        const city = String(item?.city || 'cat').replace(/[^a-z0-9]/gi, '').slice(0, 3).toUpperCase() || 'CAT';
        return `${city}-${String(item?.number || 0).padStart(3, '0')}`;
      }

      function stampDate(value) {
        if (!value) return 'UNVISITED';
        return String(value).slice(0, 10);
      }

      function stampNote(item) {
        const gem = String(item.gem || 'gemstone');
        const gemName = gem.charAt(0).toUpperCase() + gem.slice(1);
        return `${item.cat} keeps ${item.mood} watch near ${item.landmark}. ${gemName} sets the color story.`;
      }

      function setText(selector, value) {
        const node = root.querySelector(selector);
        if (node) node.textContent = value;
      }

      function syncWorldDrawer(animate = false) {
        if (!activeWorldId || !worldDrawer) return;
        const item = worldById(activeWorldId);
        if (!item) return;
        const entry = worldStampEntry(item.id);
        const stamped = !!entry;
        const code = entry?.stampCode || stampCode(item);

        if (drawerArt && item.palette) {
          drawerArt.style.setProperty('--world-ground', item.palette.ground);
          drawerArt.style.setProperty('--world-accent', item.palette.accent);
          drawerArt.style.setProperty('--world-ink', item.palette.ink);
        }

        setText('[data-drawer-number]', String(item.number).padStart(2, '0'));
        setText('[data-drawer-kicker]', `${code} · WORLD ATELIER PASSPORT`);
        setText('[data-drawer-title]', item.title);
        setText('[data-drawer-place]', `${item.city}, ${item.country}`);
        setText('[data-drawer-landmark]', item.landmark);
        setText('[data-drawer-gem]', item.gem);
        setText('[data-drawer-cat]', item.cat);
        setText('[data-drawer-mood]', item.mood);
        setText('[data-drawer-rarity]', item.rarity);
        setText('[data-drawer-status]', stamped ? `Stamped ${stampDate(entry.stampedAt)}` : 'Unvisited');
        setText('[data-drawer-note]', stampNote(item));
        setText('[data-drawer-stamp-code]', code);
        setText('[data-drawer-stamp-date]', stampDate(entry?.stampedAt));

        worldDrawer.classList.toggle('is-stamped', stamped);
        if (drawerStamp) {
          drawerStamp.disabled = stamped;
          drawerStamp.textContent = stamped ? 'Stamped' : 'Stamp passport';
        }

        if (animate) {
          worldDrawer.classList.remove('is-stamping');
          void worldDrawer.offsetWidth;
          worldDrawer.classList.add('is-stamping');
          window.setTimeout(() => worldDrawer.classList.remove('is-stamping'), 760);
        }
      }

      function openWorldDetail(id, options = {}) {
        const item = worldById(id);
        if (!item || !worldDrawer) return;
        activeWorldId = id;
        syncWorldDrawer(!!options.animate);
        if (typeof worldDrawer.showModal === 'function') {
          if (!worldDrawer.open) worldDrawer.showModal();
        } else {
          worldDrawer.removeAttribute('hidden');
        }
      }

      function closeWorldDetail() {
        if (!worldDrawer) return;
        if (typeof worldDrawer.close === 'function' && worldDrawer.open) {
          worldDrawer.close();
        } else {
          worldDrawer.setAttribute('hidden', '');
        }
      }

      function showStampMoment(item, stampedAt) {
        const card = root.querySelector(`[data-world-card="${item.id}"]`);
        card?.classList.remove('is-just-stamped');
        if (card) {
          void card.offsetWidth;
          card.classList.add('is-just-stamped');
          window.setTimeout(() => card.classList.remove('is-just-stamped'), 900);
        }

        if (stampToast && stampToastTitle && stampToastCode) {
          stampToast.hidden = false;
          stampToastTitle.textContent = item.title;
          stampToastCode.textContent = `${stampCode(item)} · ${stampDate(stampedAt)}`;
          stampToast.classList.remove('is-visible');
          void stampToast.offsetWidth;
          stampToast.classList.add('is-visible');
          window.clearTimeout(stampToastTimer);
          stampToastTimer = window.setTimeout(() => {
            stampToast.classList.remove('is-visible');
            stampToast.hidden = true;
          }, 2200);
        }

        openWorldDetail(item.id, { animate: true });
      }

      function collectToday() {
        const items = collection().filter((item) => item.date !== DATA.today.date);
        const state = ritualState();
        items.unshift({
          date: DATA.today.date,
          tokenId: DATA.today.tokenId,
          cat: DATA.today.cat.name,
          rarity: DATA.today.rarity,
          rituals: DATA.rituals.filter((ritual) => state[ritual.id]).map((ritual) => ritual.id),
          collectedAt: new Date().toISOString(),
        });
        writeJson(collectionKey, items.slice(0, 64));
        passportStamp();
        render();
      }

      function collectGenesis(id) {
        const collectible = DATA.genesis.find((item) => item.id === id);
        if (!collectible) return;
        const items = genesisCollection().filter((item) => item.id !== id);
        items.unshift({
          id: collectible.id,
          title: collectible.title,
          cat: collectible.cat,
          gem: collectible.gem,
          rarity: collectible.rarity,
          imageUrl: collectible.imageUrl,
          source: 'genesis',
          collectedAt: new Date().toISOString(),
        });
        writeJson(genesisKey, items.slice(0, 64));
        passportStamp();
        render();
      }

      function collectWorld(id) {
        const collectible = worldById(id);
        if (!collectible) return;
        if (worldStampEntry(id)) {
          openWorldDetail(id);
          return;
        }
        const stampedAt = new Date().toISOString();
        const items = worldCollection().filter((item) => item.id !== id);
        items.unshift({
          id: collectible.id,
          number: collectible.number,
          title: collectible.title,
          city: collectible.city,
          country: collectible.country,
          landmark: collectible.landmark,
          cat: collectible.cat,
          gem: collectible.gem,
          mood: collectible.mood,
          rarity: collectible.rarity,
          stampCode: stampCode(collectible),
          source: 'world-atelier',
          stampedAt,
        });
        writeJson(worldKey, items.slice(0, 128));
        passportStamp();
        render();
        showStampMoment(collectible, stampedAt);
      }

      function collectJourney(id) {
        const collectible = DATA.capital?.journeySeries?.find((item) => item.id === id);
        if (!collectible) return;
        const state = ritualState();
        const done = DATA.rituals.filter((ritual) => state[ritual.id]).length;
        const items = collection();
        const genesisItems = genesisCollection();
        const worldItems = worldCollection();
        const referralItems = referralEntries();
        const journeyItems = journeyCollection();
        const score = capitalScoreFor(done, items, genesisItems, worldItems, referralItems, journeyItems);
        if (score < collectible.pointsRequired || journeyItems.some((item) => item.id === id)) return;
        const next = journeyItems.filter((item) => item.id !== id);
        next.unshift({
          id: collectible.id,
          number: collectible.number,
          title: collectible.title,
          stageId: collectible.stageId,
          motif: collectible.motif,
          lesson: collectible.lesson,
          rarity: collectible.rarity,
          pointsRequired: collectible.pointsRequired,
          source: 'journey-print',
          collectedAt: new Date().toISOString(),
        });
        writeJson(journeyKey, next.slice(0, 32));
        passportStamp();
        render();
      }

      function normalize(value) {
        return String(value || '').trim().toLowerCase();
      }

      function applyWorldFilters() {
        const query = normalize(worldSearch?.value);
        const gem = normalize(worldGemFilter?.value);
        let visible = 0;

        worldCards.forEach((card) => {
          const haystack = [
            card.getAttribute('data-world-title'),
            card.getAttribute('data-world-city'),
            card.getAttribute('data-world-country'),
            card.getAttribute('data-world-gem'),
            card.getAttribute('data-world-landmark'),
          ].map(normalize).join(' ');
          const cardGem = normalize(card.getAttribute('data-world-gem'));
          const matchesQuery = !query || haystack.includes(query);
          const matchesGem = !gem || cardGem === gem;
          const show = matchesQuery && matchesGem;
          card.hidden = !show;
          if (show) visible += 1;
        });

        if (worldVisible) {
          const suffix = gem ? ` · ${worldGemFilter.value}` : '';
          worldVisible.textContent = `Showing ${visible} of ${DATA.world.length} passport cats${suffix}.`;
        }
      }

      function focusWorld(id) {
        const collectible = DATA.world.find((item) => item.id === id);
        if (!collectible) return;
        if (worldSearch) worldSearch.value = collectible.title;
        if (worldGemFilter) worldGemFilter.value = '';
        applyWorldFilters();
        root.querySelector(`[data-world-card="${id}"]`)?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }

      function focusUnvisitedWorld() {
        const stamped = new Set(worldCollection().map((item) => item.id));
        const candidates = DATA.world.filter((item) => !stamped.has(item.id));
        const pool = candidates.length ? candidates : DATA.world;
        const next = pool[Math.floor(Math.random() * pool.length)];
        if (next) focusWorld(next.id);
      }

      function render() {
        const state = ritualState();
        const done = DATA.rituals.filter((ritual) => state[ritual.id]).length;
        const complete = done >= DATA.rituals.length;
        const collected = isCollectedToday();
        const items = collection();
        const genesisItems = genesisCollection();
        const worldItems = worldCollection();
        const referralItems = referralEntries();
        const journeyItems = journeyCollection();
        const profile = capitalProfile();
        const inbound = inboundReferral();
        const score = capitalScoreFor(done, items, genesisItems, worldItems, referralItems, journeyItems);
        const activeCapitalStage = capitalStageForScore(score);
        const milestone = nextReferralMilestone(referralItems.length);
        const genesisIds = new Set(genesisItems.map((item) => item.id));
        const worldIds = new Set(worldItems.map((item) => item.id));
        const journeyIds = new Set(journeyItems.map((item) => item.id));

        ritualButtons.forEach((button) => {
          const id = button.getAttribute('data-ritual-id');
          const active = !!state[id];
          button.classList.toggle('is-done', active);
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
        });

        if (ritualStatus) {
          ritualStatus.textContent = `${done} / ${DATA.rituals.length} care actions complete.`;
        }
        if (collectionStatus) {
          collectionStatus.textContent = collected
            ? `${DATA.today.cat.name} is on your shelf.`
            : complete
              ? `${DATA.today.cat.name} is ready for the shelf.`
              : 'Complete the ritual to collect today\'s cat.';
        }
        if (collectionCount) collectionCount.textContent = String(items.length);
        if (genesisCount) genesisCount.textContent = String(genesisItems.length);
        if (worldCount) worldCount.textContent = String(worldItems.length);
        if (dashboardTotal) dashboardTotal.textContent = String(items.length + genesisItems.length + worldItems.length);
        if (dashboardGenesis) dashboardGenesis.textContent = String(genesisItems.length);
        if (dashboardWorld) dashboardWorld.textContent = String(worldItems.length);
        if (genesisMeter) genesisMeter.setAttribute('value', String(genesisItems.length));
        if (worldMeter) worldMeter.setAttribute('value', String(worldItems.length));
        if (referralCode) referralCode.textContent = profile.code;
        if (referralLink) referralLink.value = referralUrl(profile.code);
        if (referralCount) referralCount.textContent = String(referralItems.length);
        if (capitalScore) capitalScore.textContent = String(score);
        if (journeyCount) journeyCount.textContent = String(journeyItems.length);
        if (capitalStage && activeCapitalStage) capitalStage.textContent = activeCapitalStage.label;
        if (capitalMilestone && milestone) {
          capitalMilestone.textContent =
            referralItems.length >= milestone.count
              ? `${milestone.label} unlocked`
              : `${milestone.count - referralItems.length} to ${milestone.label}`;
        }
        if (btcReadiness && activeCapitalStage) {
          btcReadiness.textContent =
            activeCapitalStage.id === 'bitcoin'
              ? 'external review'
              : activeCapitalStage.id === 'market'
                ? 'simulate only'
                : 'education only';
        }
        if (referralStatus) {
          referralStatus.textContent = inbound?.code
            ? `Arrived through ${inbound.code}. Your own invite link is ready.`
            : 'Share one direct link. Access/reputation only until legal and tax review.';
        }
        capitalStageCards.forEach((card) => {
          const points = Number(card.getAttribute('data-capital-stage-points') || 0);
          const id = card.getAttribute('data-capital-stage-card');
          card.classList.toggle('is-complete', score >= points);
          card.classList.toggle('is-active', activeCapitalStage?.id === id);
        });
        journeyCards.forEach((card) => {
          const id = card.getAttribute('data-journey-card');
          const required = Number(card.getAttribute('data-journey-points') || 0);
          const collectedPrint = id ? journeyIds.has(id) : false;
          const unlocked = score >= required;
          card.classList.toggle('is-unlocked', unlocked);
          card.classList.toggle('is-collected', collectedPrint);
        });
        syncAllocationSimulator();
        if (dashboardNext && dashboardNextDetail) {
          if (!complete) {
            dashboardNext.textContent = 'ritual';
            dashboardNextDetail.textContent = 'Complete the three care actions.';
          } else if (!collected) {
            dashboardNext.textContent = 'daily cat';
            dashboardNextDetail.textContent = `${DATA.today.cat.name} is ready for the shelf.`;
          } else if (!genesisItems.length) {
            dashboardNext.textContent = 'genesis';
            dashboardNextDetail.textContent = 'Add one founding art card.';
          } else if (!worldItems.length) {
            dashboardNext.textContent = 'passport';
            dashboardNextDetail.textContent = 'Stamp one World Atelier city.';
          } else {
            dashboardNext.textContent = 'polish';
            dashboardNextDetail.textContent = 'Keep collecting gems and places.';
          }
        }
        if (questStatuses.ritual) questStatuses.ritual.textContent = complete ? 'Complete.' : `${done} of ${DATA.rituals.length} actions done.`;
        if (questStatuses.daily) questStatuses.daily.textContent = collected ? `${DATA.today.cat.name} collected.` : complete ? 'Ready to collect.' : 'Waiting on care ritual.';
        if (questStatuses.genesis) questStatuses.genesis.textContent = genesisItems.length ? `${genesisItems.length} Genesis cards held.` : 'Choose one founding collectible.';
        if (questStatuses.world) questStatuses.world.textContent = worldItems.length ? `${worldItems.length} places stamped.` : 'Pick a city or gem below.';
        questSteps.ritual?.classList.toggle('is-complete', complete);
        questSteps.daily?.classList.toggle('is-complete', collected);
        questSteps.genesis?.classList.toggle('is-complete', genesisItems.length > 0);
        questSteps.world?.classList.toggle('is-complete', worldItems.length > 0);
        if (collectButton) {
          collectButton.disabled = !complete || collected;
          collectButton.textContent = collected ? 'Collected' : 'Collect locally';
        }
        if (mintButton) {
          mintButton.disabled = !DATA.contract.live || !collected;
          mintButton.textContent = DATA.contract.live ? 'Mint on Tezos' : 'Tezos mint pending';
        }
        shelves.forEach((item) => {
          const date = item.getAttribute('data-shelf-date');
          item.classList.toggle('is-collected', items.some((entry) => entry.date === date));
        });
        genesisButtons.forEach((button) => {
          const id = button.getAttribute('data-genesis-id');
          const isCollected = genesisIds.has(id);
          const card = id ? root.querySelector(`[data-genesis-card="${id}"]`) : null;
          button.textContent = isCollected ? 'Collected' : 'Add to shelf';
          button.disabled = isCollected;
          card?.classList.toggle('is-collected', isCollected);
        });
        worldButtons.forEach((button) => {
          const id = button.getAttribute('data-world-id');
          const isCollected = worldIds.has(id);
          const card = id ? root.querySelector(`[data-world-card="${id}"]`) : null;
          button.textContent = isCollected ? 'Stamped' : 'Stamp passport';
          button.disabled = isCollected;
          card?.classList.toggle('is-stamped', isCollected);
        });
        journeyButtons.forEach((button) => {
          const id = button.getAttribute('data-journey-id');
          const collectible = DATA.capital?.journeySeries?.find((item) => item.id === id);
          const isCollected = id ? journeyIds.has(id) : false;
          const unlocked = collectible ? score >= collectible.pointsRequired : false;
          button.textContent = isCollected ? 'Collected' : unlocked ? 'Collect print' : `${collectible?.pointsRequired || 0} pts`;
          button.disabled = isCollected || !unlocked;
        });
        syncWorldDrawer();
        applyWorldFilters();
      }

      ritualButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const id = button.getAttribute('data-ritual-id');
          const state = ritualState();
          state[id] = state[id] || new Date().toISOString();
          writeJson(ritualKey, state);
          render();
        });
      });

      collectButton?.addEventListener('click', collectToday);

      copyReferral?.addEventListener('click', async () => {
        const profile = capitalProfile();
        const url = referralUrl(profile.code);
        if (referralLink) referralLink.value = url;
        try {
          await navigator.clipboard.writeText(url);
          if (referralStatus) referralStatus.textContent = 'Invite link copied. Keep referrals disclosed and one-level.';
        } catch {
          if (referralStatus) referralStatus.textContent = url;
        }
      });

      logReferral?.addEventListener('click', addReferralEntry);
      capitalMonthly?.addEventListener('input', syncAllocationSimulator);
      capitalBtcShare?.addEventListener('input', syncAllocationSimulator);

      genesisButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const id = button.getAttribute('data-genesis-id');
          if (id) collectGenesis(id);
        });
      });

      journeyButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const id = button.getAttribute('data-journey-id');
          if (id) collectJourney(id);
        });
      });

      worldButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const id = button.getAttribute('data-world-id');
          if (id) collectWorld(id);
        });
      });

      worldOpenButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const id = button.getAttribute('data-world-open');
          if (id) openWorldDetail(id);
        });
      });

      worldCards.forEach((card) => {
        card.addEventListener('click', (event) => {
          if (event.target?.closest?.('button, a, input, select, textarea')) return;
          const id = card.getAttribute('data-world-card');
          if (id) openWorldDetail(id);
        });
        card.addEventListener('keydown', (event) => {
          if (event.key !== 'Enter' && event.key !== ' ') return;
          if (event.target !== card) return;
          event.preventDefault();
          const id = card.getAttribute('data-world-card');
          if (id) openWorldDetail(id);
        });
      });

      worldFocusButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const id = button.getAttribute('data-world-focus');
          if (id) focusWorld(id);
        });
      });

      gemFocusButtons.forEach((button) => {
        button.addEventListener('click', () => {
          if (worldSearch) worldSearch.value = '';
          if (worldGemFilter) worldGemFilter.value = button.getAttribute('data-gem-focus') || '';
          applyWorldFilters();
          root.querySelector('[data-world-card]:not([hidden])')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
      });

      worldSearch?.addEventListener('input', applyWorldFilters);
      worldGemFilter?.addEventListener('change', applyWorldFilters);
      worldRandom?.addEventListener('click', focusUnvisitedWorld);
      drawerClose?.addEventListener('click', closeWorldDetail);
      drawerStamp?.addEventListener('click', () => {
        if (activeWorldId) collectWorld(activeWorldId);
      });
      drawerLocate?.addEventListener('click', () => {
        if (!activeWorldId) return;
        closeWorldDetail();
        focusWorld(activeWorldId);
      });
      worldDrawer?.addEventListener('click', (event) => {
        if (event.target === worldDrawer) closeWorldDetail();
      });

      mintButton?.addEventListener('click', async () => {
        if (!DATA.contract.live || !isCollectedToday()) return;
        try {
          mintButton.disabled = true;
          if (mintStatus) mintStatus.textContent = 'Opening wallet...';
          const result = await mintZenCat(DATA.today.tokenId, 'mainnet', {
            source: 'zen-cats',
            capturedAt: new Date().toISOString(),
            cat: DATA.today.cat.name,
            date: DATA.today.date,
          });
          if (result.ok) {
            if (mintStatus) {
              mintStatus.innerHTML = `Mint submitted: <a href="${result.tzktUrl}" target="_blank" rel="noopener">${result.opHash}</a>`;
            }
          } else if (mintStatus) {
            mintStatus.textContent = `Mint unavailable: ${result.reason || 'unknown error'}`;
          }
        } catch (error) {
          if (mintStatus) {
            mintStatus.textContent = `Mint unavailable: ${error instanceof Error ? error.message : String(error)}`;
          }
        } finally {
          render();
        }
      });

      render();
    }
  </script>
</BlockLayout>

