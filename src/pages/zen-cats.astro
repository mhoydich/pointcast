---
import BlockLayout from '../layouts/BlockLayout.astro';
import contracts from '../data/contracts.json';
import {
  ZEN_CAT_GENESIS_COLLECTIBLES,
  ZEN_CAT_WORLD_COLLECTIBLES,
} from '../data/zen-cat-collectibles';
import {
  ZEN_CAT_RITUALS,
  ZEN_CATS_STORAGE_KEYS,
  ZEN_CATS_SYMBOL,
  buildZenCatsManifest,
  recentZenCats,
  todayZenCat,
} from '../lib/zen-cats';

const today = todayZenCat();
const recent = recentZenCats(9);
const genesisCollectibles = ZEN_CAT_GENESIS_COLLECTIBLES;
const worldCollectibles = ZEN_CAT_WORLD_COLLECTIBLES;
const worldProofImage = '/images/zen-cats/world/world-atelier-proof.webp';
const cat = today.cat;
const palette = cat.palette;
const zenCatsMainnet = ((contracts as any).zen_cats?.mainnet ?? '').trim();
const mintLive = zenCatsMainnet.startsWith('KT1');
const metadataBase =
  ((contracts as any).zen_cats?.metadataBaseUrl ?? 'https://pointcast.xyz/api/zen-cat-metadata').trim();
const manifest = buildZenCatsManifest();

const clientData = {
  today,
  rituals: ZEN_CAT_RITUALS,
  contract: {
    network: 'mainnet',
    address: zenCatsMainnet,
    live: mintLive,
    metadataBase,
  },
  storageKeys: ZEN_CATS_STORAGE_KEYS,
  passportStamp: 'zen-cat',
  genesis: genesisCollectibles.map((item) => ({
    id: item.id,
    title: item.title,
    cat: item.cat,
    gem: item.gem,
    rarity: item.rarity,
    imageUrl: item.imageUrl,
  })),
  worldAtelier: {
    count: worldCollectibles.length,
    proofImageUrl: worldProofImage,
  },
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Game',
  '@id': 'https://pointcast.xyz/zen-cats#game',
  name: 'Zen Cat Garden',
  description:
    'A daily PointCast collection game with local zen cat care and Tezos-ready PCCAT metadata.',
  url: 'https://pointcast.xyz/zen-cats',
  gamePlatform: ['Web', 'Tezos'],
  genre: ['collection game', 'daily ritual'],
  inLanguage: 'en-US',
  potentialAction: {
    '@type': 'PlayAction',
    target: 'https://pointcast.xyz/zen-cats',
  },
};
---

<BlockLayout
  title="Zen Cat Garden"
  description="A daily PointCast collection game: care for one calm cat, collect it locally, and mint PCCAT on Tezos once the dedicated contract is deployed."
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/zen-cats.json', title: 'Zen Cat Garden manifest' }]}
  frame={{
    image: 'https://pointcast.xyz/images/og/og-home-v2.png',
    buttons: [
      { label: 'Open Zen Cats', action: 'link', target: 'https://pointcast.xyz/zen-cats' },
      { label: 'Cat JSON', action: 'link', target: 'https://pointcast.xyz/zen-cats.json' },
      { label: 'Play Layer', action: 'link', target: 'https://pointcast.xyz/play' },
    ],
  }}
>
  <main class="zen-cat-game" data-zen-cat-game data-token-id={today.tokenId}>
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/play">play</a>
      <span aria-hidden="true">/</span>
      <span>zen-cats</span>
    </nav>

    <header class="cat-hero">
      <div class="cat-hero__copy">
        <p class="kicker">ZEN CAT GARDEN · {today.date} · {ZEN_CATS_SYMBOL}</p>
        <h1>{cat.name} is today's calm little collectible.</h1>
        <p>
          {cat.coat}, {cat.posture}. Room weather: {today.weather}. Mantra:
          <strong>{cat.mantra}</strong>
        </p>
        <div class="cat-actions" aria-label="Primary Zen Cat routes">
          <a href="/zen-cats.json">JSON</a>
          <a href={today.metadataUrl}>Metadata</a>
          <a href={today.imageUrl}>SVG</a>
          <a href="/play">Play Layer</a>
        </div>
      </div>

      <aside class="cat-card" aria-label={`Daily cat ${cat.name}`}>
        <div class="cat-stage" style={`--ground:${palette.ground};--paper:${palette.paper};--fur:${palette.fur};--fur-alt:${palette.furAlt};--accent:${palette.accent};--ink:${palette.ink};`}>
          <svg viewBox="0 0 360 360" role="img" aria-labelledby="cat-svg-title cat-svg-desc">
            <title id="cat-svg-title">{cat.name}, the daily zen cat</title>
            <desc id="cat-svg-desc">{cat.coat}, {cat.posture}, carrying a {cat.charm}.</desc>
            <rect width="360" height="360" rx="18" fill="var(--ground)" />
            <path d="M42 290h276" stroke="var(--ink)" stroke-width="4" stroke-linecap="round" opacity="0.22" />
            <path d="M75 244c32 20 178 20 210 0v42c-38 22-172 22-210 0z" fill="var(--paper)" stroke="var(--ink)" stroke-width="5" />
            <path d="M104 171c0-56 38-97 82-97s82 41 82 97v51c0 46-34 77-82 77s-82-31-82-77z" fill="var(--fur)" stroke="var(--ink)" stroke-width="6" />
            <path d="M122 91l-3-50 38 35" fill="var(--fur)" stroke="var(--ink)" stroke-width="6" stroke-linejoin="round" />
            <path d="M250 91l3-50-38 35" fill="var(--fur)" stroke="var(--ink)" stroke-width="6" stroke-linejoin="round" />
            <path d="M141 106c27-16 65-18 94 0v42c-32-18-65-17-94 0z" fill="var(--fur-alt)" opacity="0.42" />
            <path d="M154 176c10 9 22 9 32 0" fill="none" stroke="var(--paper)" stroke-width="6" stroke-linecap="round" />
            <path d="M206 176c10 9 22 9 32 0" fill="none" stroke="var(--paper)" stroke-width="6" stroke-linecap="round" />
            <path d="M190 194l-9 9h18z" fill="var(--accent)" stroke="var(--ink)" stroke-width="4" stroke-linejoin="round" />
            <path d="M171 219c9 10 21 13 34 0" fill="none" stroke="var(--paper)" stroke-width="5" stroke-linecap="round" />
            <path d="M113 207c-24-10-44-11-63-3M115 225c-25 1-45 9-61 21M257 207c24-10 44-11 63-3M255 225c25 1 45 9 61 21" stroke="var(--ink)" stroke-width="4" stroke-linecap="round" opacity="0.58" />
            <circle cx="186" cy="258" r="16" fill="var(--accent)" stroke="var(--ink)" stroke-width="5" />
            <path d="M186 274v21" stroke="var(--ink)" stroke-width="4" stroke-linecap="round" />
            <text x="180" y="330" text-anchor="middle" fill="var(--ink)" font-family="monospace" font-size="14">#{today.tokenId}</text>
          </svg>
        </div>
        <dl class="cat-facts">
          <div><dt>Room</dt><dd>{today.room}</dd></div>
          <div><dt>Mood</dt><dd>{cat.mood}</dd></div>
          <div><dt>Charm</dt><dd>{cat.charm}</dd></div>
          <div><dt>Rarity</dt><dd>{today.rarity}</dd></div>
        </dl>
      </aside>
    </header>

    <section class="ritual-panel" aria-labelledby="ritual-title">
      <div class="panel-head">
        <p class="kicker">DAILY RITUAL</p>
        <h2 id="ritual-title">Care, collect, mint when ready.</h2>
        <p data-ritual-status>0 / {ZEN_CAT_RITUALS.length} care actions complete.</p>
      </div>
      <div class="ritual-grid">
        {ZEN_CAT_RITUALS.map((ritual) => (
          <button class="ritual-button" type="button" data-ritual-id={ritual.id}>
            <span>{ritual.label}</span>
            <small>{ritual.detail}</small>
          </button>
        ))}
      </div>
      <div class="mint-console">
        <div>
          <span class="console-label">Daily token</span>
          <strong>#{today.tokenId}</strong>
          <p data-collection-status>Complete the ritual to collect today's cat.</p>
        </div>
        <button class="collect-button" type="button" data-collect-cat disabled>Collect locally</button>
        <button class="mint-button" type="button" data-mint-cat disabled>
          {mintLive ? 'Mint on Tezos' : 'Tezos mint pending'}
        </button>
      </div>
      <p class="mint-note" data-mint-status>
        {mintLive
          ? `PCCAT contract: ${zenCatsMainnet}`
          : 'PCCAT needs a dedicated FA2 contract. Visit Nouns is live, but it stays Noun-shaped.'}
      </p>
    </section>

    <section class="shelf-panel" aria-labelledby="shelf-title">
      <div class="panel-head">
        <p class="kicker">COLLECTION SHELF</p>
        <h2 id="shelf-title">Nine recent cats, one per Pacific day.</h2>
        <p>
          <span data-collection-count>0</span> daily cats and
          <span data-genesis-count>0</span> Genesis cats collected in this browser.
        </p>
      </div>
      <ol class="cat-shelf">
        {recent.map((entry) => (
          <li data-shelf-date={entry.date} data-shelf-token={entry.tokenId}>
            <span class="mini-cat" style={`--mini-fur:${entry.cat.palette.fur};--mini-accent:${entry.cat.palette.accent};--mini-ink:${entry.cat.palette.ink};`} aria-hidden="true">
              <span></span>
            </span>
            <strong>{entry.cat.name}</strong>
            <small>{entry.date}</small>
          </li>
        ))}
      </ol>
    </section>

    <section class="genesis-panel" aria-labelledby="genesis-title">
      <div class="panel-head">
        <p class="kicker">GENESIS GARDEN · EARLY COLLECTIBLES</p>
        <h2 id="genesis-title">The first 16 cats are now inside the garden.</h2>
        <p>
          These are the founding art cards: textile texture, quiet luxury, blue-coral rooms,
          and gem-linked traits before the PCCAT contract goes live.
        </p>
      </div>
      <div class="genesis-grid">
        {genesisCollectibles.map((item) => (
          <article
            class="genesis-card"
            data-genesis-card={item.id}
            style={`--genesis-ground:${item.palette.ground};--genesis-accent:${item.palette.accent};--genesis-ink:${item.palette.ink};`}
          >
            <a href={item.imageUrl} aria-label={`Open ${item.title}`}>
              <img src={item.imageUrl} alt={`${item.title}, ${item.cat}`} width="1024" height="768" loading="lazy" decoding="async" />
            </a>
            <div class="genesis-card__body">
              <p>#{String(item.number).padStart(3, '0')} · {item.rarity}</p>
              <h3>{item.title}</h3>
              <dl>
                <div><dt>Gem</dt><dd>{item.gem}</dd></div>
                <div><dt>Cat</dt><dd>{item.cat}</dd></div>
                <div><dt>Mood</dt><dd>{item.mood}</dd></div>
              </dl>
              <button type="button" data-genesis-id={item.id}>Add to shelf</button>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="world-panel" aria-labelledby="world-title">
      <div class="panel-head">
        <p class="kicker">WORLD ATELIER · 50 PASSPORT CATS</p>
        <h2 id="world-title">Luxury, landmark, gemstone, calm.</h2>
        <p>
          The next collection is mapped as 50 global art prompts: each cat gets a place,
          a landmark cue, a gemstone color story, and a quiet high-end mood.
        </p>
      </div>
      <figure class="world-proof">
        <a href={worldProofImage} aria-label="Open the World Atelier proof sheet">
          <img
            src={worldProofImage}
            alt="World Atelier proof sheet with 50 luxury zen cat collectible studies"
            width="887"
            height="1774"
            loading="lazy"
            decoding="async"
          />
        </a>
      </figure>
      <ol class="world-grid">
        {worldCollectibles.map((item) => (
          <li style={`--world-ground:${item.palette.ground};--world-accent:${item.palette.accent};--world-ink:${item.palette.ink};`}>
            <span class="world-grid__number">{String(item.number).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.city}, {item.country}</p>
            <dl>
              <div><dt>Landmark</dt><dd>{item.landmark}</dd></div>
              <div><dt>Gem</dt><dd>{item.gem}</dd></div>
              <div><dt>Cat</dt><dd>{item.cat}</dd></div>
            </dl>
          </li>
        ))}
      </ol>
    </section>

    <section class="agent-note" aria-labelledby="agent-note-title">
      <p class="kicker">AGENT HOOK</p>
      <h2 id="agent-note-title">The cat surface is machine-readable.</h2>
      <p>
        Agents can read <a href="/zen-cats.json">/zen-cats.json</a> for today's cat, localStorage keys,
        Genesis collectibles, the 50-cat world series, Tezos contract status, metadata base, and mint readiness.
      </p>
      <pre>{JSON.stringify({
        today: manifest.today,
        genesis: { count: manifest.genesis.count, storageKey: manifest.genesis.storageKey },
        worldAtelier: { count: manifest.worldAtelier.count },
        tezos: manifest.tezos,
      }, null, 2)}</pre>
    </section>
  </main>

  <script type="application/json" id="zen-cat-data" set:html={JSON.stringify(clientData)}></script>

  <script>
    import { mintZenCat } from '../lib/mint';

    const root = document.querySelector('[data-zen-cat-game]');
    const dataEl = document.getElementById('zen-cat-data');

    if (root && dataEl) {
      const DATA = JSON.parse(dataEl.textContent || '{}');
      const collectionKey = DATA.storageKeys.collection;
      const genesisKey = DATA.storageKeys.genesisCollection;
      const ritualKey = DATA.storageKeys.ritualPrefix + DATA.today.date;
      const ritualButtons = Array.from(root.querySelectorAll('[data-ritual-id]'));
      const genesisButtons = Array.from(root.querySelectorAll('[data-genesis-id]'));
      const collectButton = root.querySelector('[data-collect-cat]');
      const mintButton = root.querySelector('[data-mint-cat]');
      const ritualStatus = root.querySelector('[data-ritual-status]');
      const collectionStatus = root.querySelector('[data-collection-status]');
      const collectionCount = root.querySelector('[data-collection-count]');
      const genesisCount = root.querySelector('[data-genesis-count]');
      const mintStatus = root.querySelector('[data-mint-status]');
      const shelves = Array.from(root.querySelectorAll('[data-shelf-date]'));

      function readJson(key, fallback) {
        try {
          const raw = localStorage.getItem(key);
          if (!raw) return fallback;
          const parsed = JSON.parse(raw);
          return parsed ?? fallback;
        } catch {
          return fallback;
        }
      }

      function writeJson(key, value) {
        try {
          localStorage.setItem(key, JSON.stringify(value));
        } catch {}
      }

      function collection() {
        const items = readJson(collectionKey, []);
        return Array.isArray(items) ? items : [];
      }

      function genesisCollection() {
        const items = readJson(genesisKey, []);
        return Array.isArray(items) ? items : [];
      }

      function ritualState() {
        const state = readJson(ritualKey, {});
        return state && typeof state === 'object' ? state : {};
      }

      function isCollectedToday() {
        return collection().some((item) => item.date === DATA.today.date);
      }

      function passportStamp() {
        const key = 'pc:passport:stamps';
        const current = readJson(key, {});
        if (!current || typeof current !== 'object') return;
        current[DATA.passportStamp] = current[DATA.passportStamp] || {
          id: DATA.passportStamp,
          at: new Date().toISOString(),
          via: 'zen-cats',
        };
        writeJson(key, current);
      }

      function collectToday() {
        const items = collection().filter((item) => item.date !== DATA.today.date);
        const state = ritualState();
        items.unshift({
          date: DATA.today.date,
          tokenId: DATA.today.tokenId,
          cat: DATA.today.cat.name,
          rarity: DATA.today.rarity,
          rituals: DATA.rituals.filter((ritual) => state[ritual.id]).map((ritual) => ritual.id),
          collectedAt: new Date().toISOString(),
        });
        writeJson(collectionKey, items.slice(0, 64));
        passportStamp();
        render();
      }

      function collectGenesis(id) {
        const collectible = DATA.genesis.find((item) => item.id === id);
        if (!collectible) return;
        const items = genesisCollection().filter((item) => item.id !== id);
        items.unshift({
          id: collectible.id,
          title: collectible.title,
          cat: collectible.cat,
          gem: collectible.gem,
          rarity: collectible.rarity,
          imageUrl: collectible.imageUrl,
          source: 'genesis',
          collectedAt: new Date().toISOString(),
        });
        writeJson(genesisKey, items.slice(0, 64));
        passportStamp();
        render();
      }

      function render() {
        const state = ritualState();
        const done = DATA.rituals.filter((ritual) => state[ritual.id]).length;
        const complete = done >= DATA.rituals.length;
        const collected = isCollectedToday();
        const items = collection();
        const genesisItems = genesisCollection();
        const genesisIds = new Set(genesisItems.map((item) => item.id));

        ritualButtons.forEach((button) => {
          const id = button.getAttribute('data-ritual-id');
          const active = !!state[id];
          button.classList.toggle('is-done', active);
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
        });

        if (ritualStatus) {
          ritualStatus.textContent = `${done} / ${DATA.rituals.length} care actions complete.`;
        }
        if (collectionStatus) {
          collectionStatus.textContent = collected
            ? `${DATA.today.cat.name} is on your shelf.`
            : complete
              ? `${DATA.today.cat.name} is ready for the shelf.`
              : 'Complete the ritual to collect today\'s cat.';
        }
        if (collectionCount) collectionCount.textContent = String(items.length);
        if (genesisCount) genesisCount.textContent = String(genesisItems.length);
        if (collectButton) {
          collectButton.disabled = !complete || collected;
          collectButton.textContent = collected ? 'Collected' : 'Collect locally';
        }
        if (mintButton) {
          mintButton.disabled = !DATA.contract.live || !collected;
          mintButton.textContent = DATA.contract.live ? 'Mint on Tezos' : 'Tezos mint pending';
        }
        shelves.forEach((item) => {
          const date = item.getAttribute('data-shelf-date');
          item.classList.toggle('is-collected', items.some((entry) => entry.date === date));
        });
        genesisButtons.forEach((button) => {
          const id = button.getAttribute('data-genesis-id');
          const isCollected = genesisIds.has(id);
          const card = id ? root.querySelector(`[data-genesis-card="${id}"]`) : null;
          button.textContent = isCollected ? 'Collected' : 'Add to shelf';
          button.disabled = isCollected;
          card?.classList.toggle('is-collected', isCollected);
        });
      }

      ritualButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const id = button.getAttribute('data-ritual-id');
          const state = ritualState();
          state[id] = state[id] || new Date().toISOString();
          writeJson(ritualKey, state);
          render();
        });
      });

      collectButton?.addEventListener('click', collectToday);

      genesisButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const id = button.getAttribute('data-genesis-id');
          if (id) collectGenesis(id);
        });
      });

      mintButton?.addEventListener('click', async () => {
        if (!DATA.contract.live || !isCollectedToday()) return;
        try {
          mintButton.disabled = true;
          if (mintStatus) mintStatus.textContent = 'Opening wallet...';
          const result = await mintZenCat(DATA.today.tokenId, 'mainnet', {
            source: 'zen-cats',
            capturedAt: new Date().toISOString(),
            cat: DATA.today.cat.name,
            date: DATA.today.date,
          });
          if (result.ok) {
            if (mintStatus) {
              mintStatus.innerHTML = `Mint submitted: <a href="${result.tzktUrl}" target="_blank" rel="noopener">${result.opHash}</a>`;
            }
          } else if (mintStatus) {
            mintStatus.textContent = `Mint unavailable: ${result.reason || 'unknown error'}`;
          }
        } catch (error) {
          if (mintStatus) {
            mintStatus.textContent = `Mint unavailable: ${error instanceof Error ? error.message : String(error)}`;
          }
        } finally {
          render();
        }
      });

      render();
    }
  </script>
</BlockLayout>

<style>
  .zen-cat-game {
    display: grid;
    gap: 16px;
    color: var(--pc-ink);
  }

  .crumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    font-family: var(--pc-font-mono);
    font-size: 12px;
  }

  .kicker {
    margin: 0 0 8px;
    color: #185fa5;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .cat-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(280px, 0.58fr);
    gap: 16px;
    align-items: stretch;
  }

  .cat-hero__copy,
  .cat-card,
  .ritual-panel,
  .shelf-panel,
  .genesis-panel,
  .world-panel,
  .agent-note {
    border: 1.5px solid var(--pc-ink);
    background: #fffef8;
  }

  .cat-hero__copy {
    display: grid;
    align-content: center;
    min-height: 440px;
    padding: clamp(18px, 4vw, 44px);
    background:
      repeating-linear-gradient(90deg, rgba(24, 95, 165, 0.08), rgba(24, 95, 165, 0.08) 1px, transparent 1px, transparent 22px),
      #fffef8;
  }

  .cat-hero h1 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(42px, 7vw, 88px);
    line-height: 0.95;
    letter-spacing: 0;
    font-weight: 560;
  }

  .cat-hero p {
    max-width: 680px;
    margin: 18px 0 0;
    color: var(--pc-ink-soft);
    font-size: 18px;
    line-height: 1.45;
  }

  .cat-hero strong {
    color: var(--pc-ink);
    font-weight: 600;
  }

  .cat-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 24px;
  }

  .cat-actions a,
  .collect-button,
  .mint-button,
  .ritual-button {
    border: 1.5px solid var(--pc-ink);
    background: #fff;
    color: var(--pc-ink);
    cursor: pointer;
  }

  .cat-actions a {
    padding: 10px 12px;
    font-family: var(--pc-font-mono);
    font-size: 12px;
    text-decoration: none;
    text-transform: uppercase;
  }

  .cat-actions a:hover,
  .collect-button:not(:disabled):hover,
  .mint-button:not(:disabled):hover,
  .ritual-button:hover {
    background: #eef4fa;
    text-decoration: none;
  }

  .cat-card {
    display: grid;
    gap: 12px;
    padding: 12px;
  }

  .cat-stage {
    aspect-ratio: 1;
    border: 1px solid var(--pc-rule);
    background: var(--paper);
  }

  .cat-stage svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .cat-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    margin: 0;
  }

  .cat-facts div {
    min-width: 0;
    padding: 10px;
    border: 1px solid var(--pc-rule);
    background: #fff;
  }

  .cat-facts dt,
  .console-label {
    color: #185fa5;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    text-transform: uppercase;
  }

  .cat-facts dd {
    margin: 4px 0 0;
    overflow-wrap: anywhere;
    font-size: 14px;
  }

  .ritual-panel,
  .shelf-panel,
  .genesis-panel,
  .world-panel,
  .agent-note {
    display: grid;
    gap: 14px;
    padding: 16px;
