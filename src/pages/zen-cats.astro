    height: 64px;
    border-top: 2px solid color-mix(in oklab, #fffef8 72%, var(--journey-secondary));
    background:
      repeating-linear-gradient(135deg, color-mix(in oklab, var(--journey-accent) 52%, transparent), color-mix(in oklab, var(--journey-accent) 52%, transparent) 4px, transparent 4px, transparent 18px),
      color-mix(in oklab, var(--journey-ink) 18%, transparent);
    transform: rotate(-4deg);
  }

  .journey-art__cat {
    left: 26px;
    bottom: 38px;
    width: 112px;
    height: 88px;
    border: 4px solid var(--journey-ink);
    border-radius: 54px 54px 34px 34px;
    background: color-mix(in oklab, var(--journey-accent) 46%, #fffef8);
  }

  .journey-art__cat::before,
  .journey-art__cat::after {
    content: "";
    position: absolute;
    top: -24px;
    width: 34px;
    height: 34px;
    border: 4px solid var(--journey-ink);
    background: color-mix(in oklab, var(--journey-accent) 52%, #fffef8);
    transform: rotate(45deg);
  }

  .journey-art__cat::before {
    left: 18px;
  }

  .journey-art__cat::after {
    right: 18px;
  }

  .journey-body {
    display: grid;
    gap: 8px;
    padding: 11px;
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--journey-ink) 10%, transparent), transparent),
      color-mix(in oklab, var(--journey-ground) 86%, #000);
  }

  .journey-body p,
  .journey-body h4,
  .journey-body dl {
    margin: 0;
  }

  .journey-body p {
    color: color-mix(in oklab, var(--journey-secondary) 82%, #fff);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    text-transform: uppercase;
  }

  .journey-body h4 {
    min-height: 2.1em;
    font-size: 20px;
    line-height: 1.04;
    letter-spacing: 0;
  }

  .journey-body dl {
    display: grid;
    gap: 6px;
  }

  .journey-body dt {
    color: color-mix(in oklab, var(--journey-secondary) 76%, #fff);
    font-family: var(--pc-font-mono);
    font-size: 9px;
    text-transform: uppercase;
  }

  .journey-body dd {
    margin: 2px 0 0;
    overflow-wrap: anywhere;
    font-size: 12px;
    line-height: 1.26;
  }

  .journey-body button {
    min-height: 40px;
    border: 1px solid color-mix(in oklab, var(--journey-secondary) 72%, #fff);
    background: #fffef8;
    color: var(--journey-ink);
    cursor: pointer;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    text-transform: uppercase;
  }

  .journey-body button:disabled {
    cursor: default;
    opacity: 0.68;
  }

  .capital-guardrails {
    display: grid;
    gap: 4px;
    background: #fff;
  }

  .capital-guardrails strong {
    font-size: 18px;
  }

  .mint-console {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    gap: 10px;
    align-items: center;
    padding: 12px;
    border: 1px solid var(--pc-rule);
    background: #f8fbff;
  }

  .mint-console strong {
    display: block;
    margin-top: 3px;
    font-family: var(--pc-font-mono);
    font-size: 22px;
  }

  .mint-console p {
    margin: 4px 0 0;
    color: var(--pc-ink-soft);
    font-size: 13px;
  }

  .collect-button,
  .mint-button {
    min-height: 46px;
    padding: 0 14px;
    font-weight: 650;
  }

  .collect-button:disabled,
  .mint-button:disabled {
    cursor: not-allowed;
    opacity: 0.58;
  }

  .cat-shelf {
    display: grid;
    grid-template-columns: repeat(9, minmax(0, 1fr));
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .cat-shelf li {
    display: grid;
    gap: 6px;
    min-width: 0;
    min-height: 138px;
    padding: 10px;
    border: 1px solid var(--pc-rule);
    background: #fff;
    opacity: 0.68;
  }

  .cat-shelf li.is-collected {
    opacity: 1;
    box-shadow: inset 0 0 0 2px #d6b14a;
  }

  .mini-cat {
    position: relative;
    display: block;
    width: 48px;
    height: 42px;
    align-self: end;
  }

  .mini-cat::before,
  .mini-cat::after {
    content: "";
    position: absolute;
    top: 0;
    width: 18px;
    height: 18px;
    background: var(--mini-fur);
    border: 2px solid var(--mini-ink);
    transform: rotate(45deg);
  }

  .mini-cat::before {
    left: 4px;
  }

  .mini-cat::after {
    right: 4px;
  }

  .mini-cat span {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 32px;
    border: 2px solid var(--mini-ink);
    border-radius: 22px 22px 16px 16px;
    background: var(--mini-fur);
  }

  .mini-cat span::after {
    content: "";
    position: absolute;
    left: 19px;
    top: 17px;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--mini-accent);
  }

  .cat-shelf strong,
  .cat-shelf small {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .cat-shelf strong {
    font-size: 13px;
  }

  .cat-shelf small {
    color: var(--pc-ink-soft);
    font-family: var(--pc-font-mono);
    font-size: 10px;
  }

  .genesis-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
  }

  .genesis-card {
    display: grid;
    min-width: 0;
    border: 1px solid color-mix(in oklab, var(--genesis-ink) 72%, var(--pc-rule));
    background: var(--genesis-ground);
    color: #fffef8;
  }

  .genesis-card.is-collected {
    box-shadow: inset 0 0 0 3px var(--genesis-accent);
  }

  .genesis-card a {
    display: block;
    overflow: hidden;
    background: #f6efe4;
  }

  .genesis-card img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .genesis-card__body {
    display: grid;
    gap: 8px;
    padding: 10px;
  }

  .genesis-card__body p,
  .genesis-card__body h3,
  .genesis-card__body dl {
    margin: 0;
  }

  .genesis-card__body p,
  .world-grid__number {
    color: color-mix(in oklab, var(--genesis-accent, var(--world-accent)) 84%, #fff);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    text-transform: uppercase;
  }

  .genesis-card h3 {
    min-height: 2.4em;
    font-size: 18px;
    line-height: 1.12;
    letter-spacing: 0;
  }

  .genesis-card dl,
  .world-grid dl {
    display: grid;
    gap: 5px;
  }

  .genesis-card dt,
  .world-grid dt {
    color: color-mix(in oklab, var(--genesis-accent, var(--world-accent)) 76%, #fff);
    font-family: var(--pc-font-mono);
    font-size: 9px;
    text-transform: uppercase;
  }

  .genesis-card dd,
  .world-grid dd {
    margin: 1px 0 0;
    overflow-wrap: anywhere;
    font-size: 12px;
    line-height: 1.25;
  }

  .genesis-card button {
    min-height: 38px;
    border: 1px solid color-mix(in oklab, var(--genesis-accent) 72%, #fff);
    background: #fffef8;
    color: var(--genesis-ink);
    cursor: pointer;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    text-transform: uppercase;
  }

  .genesis-card button:disabled {
    cursor: default;
    opacity: 0.72;
  }

  .passport-desk {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(260px, 0.7fr);
    gap: 10px;
  }

  .passport-desk__copy,
  .gem-ledger {
    min-width: 0;
    padding: 12px;
    border: 1px solid var(--pc-rule);
    background: #f8fbff;
  }

  .passport-desk h3 {
    margin: 0 0 10px;
    font-size: 24px;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .passport-desk ol,
  .gem-ledger div {
    display: grid;
    gap: 6px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .passport-desk button,
  .gem-ledger button,
  .world-tools button,
  .world-grid button {
    min-width: 0;
    border: 1px solid var(--pc-ink);
    background: #fffef8;
    color: var(--pc-ink);
    cursor: pointer;
  }

  .passport-desk button {
    display: grid;
    gap: 3px;
    width: 100%;
    padding: 10px;
    text-align: left;
  }

  .passport-desk button span {
    color: var(--pc-ink-soft);
    font-size: 12px;
    line-height: 1.25;
  }

  .gem-ledger div {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .gem-ledger button {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    min-height: 38px;
    padding: 7px 9px;
    font-size: 12px;
  }

  .gem-ledger button span {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .world-tools {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(180px, 0.6fr) auto minmax(220px, 0.8fr);
    gap: 8px;
    align-items: end;
  }

  .world-tools label {
    display: grid;
    gap: 4px;
    min-width: 0;
    color: #185fa5;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    text-transform: uppercase;
  }

  .world-tools input,
  .world-tools select {
    min-height: 42px;
    min-width: 0;
    border: 1px solid var(--pc-ink);
    background: #fff;
    color: var(--pc-ink);
    font: inherit;
    text-transform: none;
  }

  .world-tools button {
    min-height: 42px;
    padding: 0 12px;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    text-transform: uppercase;
  }

  .world-tools p {
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 13px;
    line-height: 1.3;
  }

  .world-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .world-grid li {
    position: relative;
    display: grid;
    gap: 7px;
    min-height: 250px;
    min-width: 0;
    padding: 10px;
    border: 1px solid color-mix(in oklab, var(--world-ink) 66%, var(--pc-rule));
    background:
      linear-gradient(135deg, color-mix(in oklab, var(--world-accent) 18%, transparent), transparent 52%),
      var(--world-ground);
    color: #fffef8;
    cursor: zoom-in;
    overflow: hidden;
  }

  .world-grid li[hidden] {
    display: none;
  }

  .world-grid li:focus-visible {
    outline: 3px solid color-mix(in oklab, var(--world-accent) 76%, #fff);
    outline-offset: 2px;
  }

  .world-grid li.is-stamped {
    box-shadow: inset 0 0 0 3px var(--world-accent);
  }

  .world-grid li.is-just-stamped::after {
    content: "STAMPED";
    position: absolute;
    right: 12px;
    bottom: 54px;
    display: grid;
    place-items: center;
    width: 96px;
    height: 96px;
    border: 2px solid color-mix(in oklab, var(--world-accent) 76%, #fff);
    border-radius: 999px;
    color: color-mix(in oklab, var(--world-accent) 76%, #fff);
    font-family: var(--pc-font-mono);
    font-size: 11px;
    font-weight: 800;
    transform: rotate(-10deg);
    animation: stamp-pop 720ms cubic-bezier(0.2, 0.92, 0.22, 1);
    pointer-events: none;
  }

  .world-grid h3,
  .world-grid p {
    margin: 0;
  }

  .world-grid h3 {
    min-height: 3em;
    font-size: 18px;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .world-grid p {
    color: color-mix(in oklab, #fffef8 82%, var(--world-accent));
    font-size: 12px;
    line-height: 1.25;
  }

  .world-grid__actions {
    display: grid;
    grid-template-columns: 1fr;
    gap: 6px;
    align-self: end;
  }

  .world-grid button {
    align-self: end;
    min-height: 38px;
    border-color: color-mix(in oklab, var(--world-accent) 72%, #fff);
    color: var(--world-ink);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    text-transform: uppercase;
  }

  .world-grid button[data-world-open] {
    background: color-mix(in oklab, var(--world-ink) 74%, var(--world-ground));
    color: #fffef8;
  }

  .world-grid button:disabled {
    cursor: default;
    opacity: 0.72;
  }

  .passport-drawer {
    width: min(980px, calc(100vw - 32px));
    max-height: calc(100vh - 32px);
    margin: auto;
    padding: 0;
    border: 1.5px solid var(--pc-ink);
    background: #fffef8;
    color: var(--pc-ink);
    overflow: auto;
  }

  .passport-drawer::backdrop {
    background: rgba(16, 20, 24, 0.62);
  }

  .passport-drawer[open] {
    animation: drawer-rise 180ms ease-out;
  }

  .passport-drawer__shell {
    display: grid;
    grid-template-columns: minmax(300px, 0.9fr) minmax(0, 1fr);
    min-height: min(720px, calc(100vh - 36px));
  }

  .passport-drawer__art {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 480px;
    overflow: hidden;
    background:
      repeating-linear-gradient(90deg, rgba(255, 254, 248, 0.14), rgba(255, 254, 248, 0.14) 1px, transparent 1px, transparent 18px),
      radial-gradient(circle at 20% 12%, color-mix(in oklab, var(--world-accent) 42%, transparent), transparent 28%),
      linear-gradient(150deg, color-mix(in oklab, var(--world-ground) 82%, #fff), var(--world-ground));
    color: #fffef8;
  }

  .passport-drawer__art::before {
    content: "";
    position: absolute;
    inset: 18px;
    border: 1px solid rgba(255, 254, 248, 0.42);
    pointer-events: none;
  }

  .passport-drawer__number {
    position: absolute;
    left: 24px;
    top: 22px;
    color: color-mix(in oklab, var(--world-accent) 72%, #fff);
    font-family: var(--pc-font-mono);
    font-size: 42px;
    line-height: 1;
  }

  .passport-drawer__art svg {
    position: relative;
    z-index: 1;
    width: min(92%, 460px);
    height: auto;
    filter: drop-shadow(0 18px 34px rgba(0, 0, 0, 0.18));
  }

  .drawer-landmark,
  .drawer-cat-body,
  .drawer-cat-ear,
  .drawer-cat-face,
  .drawer-whisker {
    fill: none;
    stroke: color-mix(in oklab, #fffef8 86%, var(--world-accent));
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .drawer-landmark {
    stroke-width: 5;
    opacity: 0.46;
  }

  .drawer-cat-body,
  .drawer-cat-ear {
    fill: color-mix(in oklab, var(--world-accent) 42%, #fffef8);
    stroke: var(--world-ink);
    stroke-width: 7;
  }

  .drawer-cat-face {
    stroke: var(--world-ink);
    stroke-width: 6;
  }

  .drawer-whisker {
    stroke: color-mix(in oklab, #fffef8 80%, var(--world-accent));
    stroke-width: 4;
  }

  .passport-stamp-mark {
    position: absolute;
    right: 28px;
    bottom: 28px;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 142px;
    height: 142px;
    border: 3px double var(--world-ink);
    border-radius: 999px;
    background: color-mix(in oklab, #fffef8 70%, transparent);
    color: var(--world-ink);
    font-family: var(--pc-font-mono);
    text-align: center;
    text-transform: uppercase;
    transform: rotate(-9deg) scale(0.92);
    opacity: 0.2;
  }

  .passport-stamp-mark span,
  .passport-stamp-mark small {
    font-size: 10px;
    letter-spacing: 0.08em;
  }

  .passport-stamp-mark strong {
    font-size: 18px;
    line-height: 1;
  }

  .passport-drawer.is-stamped .passport-stamp-mark {
    opacity: 0.86;
  }

  .passport-drawer.is-stamping .passport-stamp-mark {
    animation: stamp-drop 680ms cubic-bezier(0.18, 0.9, 0.22, 1);
  }

  .passport-drawer__body {
    position: relative;
    display: grid;
    align-content: start;
    gap: 14px;
    padding: 24px;
  }

  .passport-drawer__close {
    justify-self: end;
    min-height: 34px;
    border: 1px solid var(--pc-ink);
    background: #fff;
    color: var(--pc-ink);
    cursor: pointer;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    text-transform: uppercase;
  }

  .passport-drawer h3 {
    margin: 0;
    font-size: clamp(32px, 5vw, 58px);
    line-height: 0.96;
    letter-spacing: 0;
  }

  .passport-drawer__place,
  .passport-drawer__note {
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 16px;
    line-height: 1.45;
  }

  .passport-drawer__facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    margin: 0;
  }

  .passport-drawer__facts div,
  .passport-drawer__tezos {
    min-width: 0;
    padding: 10px;
    border: 1px solid var(--pc-rule);
    background: #fbf8ee;
  }

  .passport-drawer__facts dt,
  .passport-drawer__tezos span {
    color: #185fa5;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    text-transform: uppercase;
  }

  .passport-drawer__facts dd {
    margin: 4px 0 0;
    overflow-wrap: anywhere;
    font-size: 13px;
    line-height: 1.28;
  }

  .passport-drawer__tezos {
    display: grid;
    gap: 4px;
  }

  .passport-drawer__tezos strong {
    font-size: 16px;
  }

  .passport-drawer__actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }

  .passport-drawer__actions button {
    min-height: 46px;
    border: 1.5px solid var(--pc-ink);
    background: #fffef8;
    color: var(--pc-ink);
    cursor: pointer;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    text-transform: uppercase;
  }

  .passport-drawer__actions button:first-child {
    background: var(--pc-ink);
    color: #fffef8;
  }

  .passport-drawer__actions button:disabled {
    cursor: default;
    opacity: 0.62;
  }

  .stamp-toast {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 20;
    display: grid;
    gap: 4px;
    min-width: min(320px, calc(100vw - 36px));
    padding: 14px;
    border: 1.5px solid var(--pc-ink);
    background: #fffef8;
    box-shadow: 0 18px 48px rgba(16, 20, 24, 0.22);
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
  }

  .stamp-toast.is-visible {
    animation: toast-in 2200ms ease both;
  }

  .stamp-toast span,
  .stamp-toast small {
    color: #185fa5;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    text-transform: uppercase;
  }

  .stamp-toast strong {
    font-size: 18px;
    line-height: 1.1;
  }

  @keyframes drawer-rise {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes stamp-drop {
    0% {
      opacity: 0;
      transform: rotate(-9deg) scale(1.7);
    }
    48% {
      opacity: 0.95;
      transform: rotate(-9deg) scale(0.86);
    }
    68% {
      transform: rotate(-9deg) scale(1.02);
    }
    100% {
      opacity: 0.86;
      transform: rotate(-9deg) scale(0.92);
    }
  }

  @keyframes stamp-pop {
    0% {
      opacity: 0;
      transform: rotate(-10deg) scale(1.8);
    }
    42% {
      opacity: 1;
      transform: rotate(-10deg) scale(0.88);
    }
    100% {
      opacity: 0;
      transform: rotate(-10deg) scale(1.08);
    }
  }

  @keyframes toast-in {
    0% {
      opacity: 0;
      transform: translateY(12px);
    }
    12%,
    82% {
      opacity: 1;
      transform: translateY(0);
    }
    100% {
      opacity: 0;
      transform: translateY(12px);
    }
  }

  .agent-note pre {
    max-height: 320px;
    margin: 0;
    overflow: auto;
    padding: 12px;
    border: 1px solid var(--pc-rule);
    background: #101418;
    color: #e8f4e9;
    font-size: 12px;
    line-height: 1.45;
  }

  @media (max-width: 1080px) {
    .cat-hero,
    .capital-console,
    .journey-head,
    .mint-console,
    .passport-desk,
    .passport-drawer__shell,
    .world-tools {
      grid-template-columns: 1fr;
    }

    .garden-dashboard,
    .capital-steps,
    .journey-grid,
    .quest-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

