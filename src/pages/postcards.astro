---
/**
 * /postcards — PointCast Postcards · El Segundo Set 1.
 *
 * Per Mike 2026-04-27: "1 and 4 and 6" — #6 was a new mintable, painted
 * El Segundo scenes. Shipped seven postcards as token_ids 0..6, free
 * open-edition, 100 each, 7.5% royalty.
 *
 * Until contracts.json's `postcards.mainnet` is populated, this page
 * renders a preview-only surface with mint buttons disabled and an
 * "originating soon" label. Once the KT1 lands, the same page becomes
 * the live mint without a code change. Mirrors /snapshots pattern.
 *
 * Companion mintables: /coffee · /snapshots · /visit-nouns · /market
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import contracts from '../data/contracts.json';

const pc = ((contracts as any).postcards ?? {}) as Record<string, any>;
const pcKt1 = ((pc.mainnet ?? '') as string).trim();
const pcLive = pcKt1.startsWith('KT1');

const TOKENS = [
  { id: 0, slug: 'marine-layer-main-street', name: 'Marine Layer · Main Street', file: '/images/postcards/0-marine-layer-main-street.svg', note: 'Foggy mid-morning on Main Street. Power lines, palms, a sun trying to burn through.', edition: 100 },
  { id: 1, slug: 'el-porto-pier',            name: 'El Porto Pier',              file: '/images/postcards/1-el-porto-pier.svg',            note: 'The pier at El Porto, north end of the strand. Surfers paddling out, gulls overhead.', edition: 100 },
  { id: 2, slug: 'dunes-at-sunset',          name: 'Dunes at Sunset',            file: '/images/postcards/2-dunes-at-sunset.svg',          note: 'The El Segundo Dunes — only intact coastal dune ecosystem in LA County. Ice plant in flower.', edition: 100 },
  { id: 3, slug: 'ralphs-at-3pm',            name: 'Ralphs · 3pm Tuesday',       file: '/images/postcards/3-ralphs-at-3pm.svg',            note: 'Sepulveda and Mariposa, 3pm Tuesday. Five cars in the lot. The neon sign you don\'t notice unless you live here.', edition: 100 },
  { id: 4, slug: 'refinery-night',           name: 'Refinery · Eleven PM',       file: '/images/postcards/4-refinery-night.svg',           note: 'The Chevron refinery, eleven pm. Flare on the stack. The town that runs all night.', edition: 100 },
  { id: 5, slug: 'manhattan-pier',           name: 'Manhattan Pier · Golden Hour', file: '/images/postcards/5-manhattan-pier.svg',         note: 'Manhattan Beach Pier from the south. Roundhouse glowing, sun on the water.', edition: 100 },
  { id: 6, slug: 'marine-layer-thinning',    name: 'Marine Layer · Thinning',    file: '/images/postcards/6-marine-layer-thinning.svg',    note: 'Mid-morning, fog drifting away, sun cutting through. The moment the town wakes up.', edition: 100 },
];

const title = '/postcards — PointCast Postcards · El Segundo Set 1';
const description =
  'Seven painted postcards from El Segundo as FA2 NFTs. Free open-edition mint, 100 editions each. Marine layer, the pier, the dunes, Ralphs at 3pm, the refinery at eleven pm, Manhattan pier at golden hour, and the moment the fog thins.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://pointcast.xyz/postcards',
  name: 'PointCast Postcards',
  description,
  url: 'https://pointcast.xyz/postcards',
  hasPart: TOKENS.map((t) => ({
    '@type': 'VisualArtwork',
    name: t.name,
    image: 'https://pointcast.xyz' + t.file,
    description: t.note,
  })),
};
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="pc" id="pc-main">

    <header class="pc__head">
      <p class="pc__kicker mono">CH.ESC · POINTCAST POSTCARDS · EL SEGUNDO · SET 1</p>
      <h1 class="pc__title"><em>Seven postcards from a small beach town.</em></h1>
      <p class="pc__dek">
        Painted scenes of El Segundo as FA2 NFTs. Free open-edition mint when the contract lands. Until then a preview — same page, mint button asleep.
      </p>
      <p class="pc__status mono" data-state={pcLive ? 'live' : 'pending'}>
        <span class="pc__status-dot" aria-hidden="true"></span>
        {pcLive
          ? <>contract live · <code>{pcKt1.slice(0, 12)}…{pcKt1.slice(-6)}</code> · free mint, gas only</>
          : <>contract not yet originated · preview only · check back after the SmartPy IDE drive</>
        }
      </p>
    </header>

    <section class="pc__grid" aria-label="Seven postcards">
      {TOKENS.map((t) => (
        <article class="pc__card" data-token-id={t.id} data-slug={t.slug}>
          <div class="pc__art">
            <img src={t.file} alt={`${t.name} — Postcard №${t.id}`} loading="lazy" />
            <span class="pc__art-tag mono">№{t.id} · {t.edition} ED</span>
          </div>
          <div class="pc__caption">
            <h2 class="pc__name">{t.name}</h2>
            <p class="pc__note">{t.note}</p>
            <button
              type="button"
              class="pc__claim mono"
              data-token-id={t.id}
              data-slug={t.slug}
              disabled={!pcLive}
              aria-label={`${pcLive ? 'Mint' : 'Mint (soon)'} — ${t.name}`}
            >
              {pcLive ? 'MINT · 0 ꜩ' : 'ORIGINATING SOON'}
            </button>
          </div>
        </article>
      ))}
    </section>

    <section class="pc__texture">
      <p>
        Postcards is the third mintable on PointCast after Coffee Mugs and Window Snapshots. Same FA2 pattern — multi-token, on-chain edition caps, public free mint gated only by gas. 7.5% royalty on secondary sales routes through the marketplace.
      </p>
      <p>
        Seven scenes is the first set. If El Segundo keeps showing up, a Set 2 follows: dawn at the strand, the airport at midnight, the wind farm in the hills, the quiet Saturday at Smoky Hollow.
      </p>
    </section>

    <nav class="pc__links" aria-label="Other rooms">
      <a class="pc__link" href="/snapshots"><span class="pc__link-label mono">/SNAPSHOTS</span><span class="pc__link-desc">three painted interiors</span></a>
      <a class="pc__link" href="/coffee"><span class="pc__link-label mono">/COFFEE</span><span class="pc__link-desc">five mugs · pour to unlock</span></a>
      <a class="pc__link" href="/visit-nouns"><span class="pc__link-label mono">/VISIT-NOUNS</span><span class="pc__link-desc">noun-by-noun · one per visit</span></a>
      <a class="pc__link" href="/market"><span class="pc__link-label mono">/MARKET</span><span class="pc__link-desc">trade every PointCast FA2</span></a>
      <a class="pc__link" href="/town"><span class="pc__link-label mono">/TOWN</span><span class="pc__link-desc">the iso town map</span></a>
      <a class="pc__link" href="/"><span class="pc__link-label mono">/</span><span class="pc__link-desc">back to the broadcast</span></a>
    </nav>

    <footer class="pc__foot mono">
      <span>on air · el segundo · fm 96.1 · cc0</span>
      <span id="pc-clock">—</span>
    </footer>

  </main>
</BlockLayout>

<script is:inline>
  (function () {
    'use strict';
    function tick() {
      var el = document.getElementById('pc-clock');
      if (!el) return;
      var n = new Date();
      el.textContent = String(n.getHours()).padStart(2, '0') + ':' +
        String(n.getMinutes()).padStart(2, '0') + ' PT';
    }
    tick();
    setInterval(tick, 60 * 1000);

    // Mint flow lights up only when contracts.postcards.mainnet is populated.
    document.querySelectorAll('.pc__claim:not([disabled])').forEach(function (btn) {
      btn.addEventListener('click', async function () {
        var tokenId = parseInt(btn.getAttribute('data-token-id') || '0', 10);
        var origLabel = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'AWAITING KUKAI…';
        try {
          var taquito = await import('@taquito/taquito');
          var beacon = await import('@taquito/beacon-wallet');
          var tezos = new taquito.TezosToolkit('https://mainnet.api.tez.ie');
          var bw = new beacon.BeaconWallet({ name: 'PointCast Postcards', network: { type: 'mainnet' } });
          tezos.setWalletProvider(bw);
          var active = await bw.client.getActiveAccount();
          if (!active) await bw.client.requestPermissions();
          var kt1 = window.__pcPcKt1 || '';
          if (!kt1) throw new Error('contract not yet originated');
          var contract = await tezos.wallet.at(kt1);
          var op = await contract.methodsObject.mint_postcard(tokenId).send();
          btn.textContent = 'BROADCAST · ' + (op.opHash || '').slice(0, 8) + '…';
          await op.confirmation();
          btn.textContent = 'MINTED ✓';
        } catch (err) {
          var msg = (err && err.message) ? err.message : String(err);
          btn.textContent = /reject|cancel|abort/i.test(msg) ? 'CANCELLED' : 'ERROR · TRY AGAIN';
          setTimeout(function () { btn.disabled = false; btn.textContent = origLabel; }, 2400);
        }
      });
    });
  })();
</script>

<script is:inline define:vars={{ pcKt1 }}>
  window.__pcPcKt1 = pcKt1 || '';
</script>

<style>
  .pc {
    min-height: calc(100vh - 60px);
    max-width: 1280px;
    margin: 0 auto;
    padding: 32px 16px 60px;
    background: #fffaf0;
    color: #12110e;
    font-family: 'Inter Variable', system-ui, sans-serif;
  }

  .mono { font-family: 'JetBrains Mono Variable', ui-monospace, monospace; letter-spacing: 0.06em; }

  .pc__head {
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 2px dashed #12110e;
  }

  .pc__kicker {
    margin: 0 0 8px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #b8431a;
    font-weight: 700;
  }

  .pc__title {
    margin: 0 0 8px;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(28px, 4.4vw, 56px);
    line-height: 1.05;
    font-weight: 400;
  }

  .pc__title em { font-style: italic; }

  .pc__dek {
    margin: 0 0 14px;
    font-size: 16px;
    line-height: 1.5;
    max-width: 70ch;
    color: #5f5e5a;
  }

  .pc__status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0;
    padding: 5px 12px;
    border: 1.5px solid #12110e;
    background: #fff;
    box-shadow: 2px 2px 0 0 #12110e;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .pc__status-dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: #b8431a;
  }

  .pc__status[data-state='live'] .pc__status-dot { background: #3b6e3b; }

  .pc__status code {
    background: #ffd400;
    padding: 1px 6px;
    color: #12110e;
    font-size: 11px;
  }

  .pc__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 16px;
    margin-bottom: 32px;
  }

  .pc__card {
    background: #fff;
    border: 2px solid #12110e;
    box-shadow: 4px 4px 0 0 #12110e;
    overflow: hidden;
    transition: transform 140ms, box-shadow 140ms;
  }

  .pc__card:hover {
    transform: translate(-1px, -1px);
    box-shadow: 5px 5px 0 0 #12110e;
  }

  .pc__art {
    position: relative;
    border-bottom: 2px solid #12110e;
    background: #f2f2f2;
  }

  .pc__art img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 8 / 5;
    object-fit: cover;
  }

  .pc__art-tag {
    position: absolute;
    bottom: 8px;
    left: 8px;
    padding: 3px 8px;
    background: #12110e;
    color: #fffaf0;
    font-size: 10px;
    letter-spacing: 0.16em;
  }

  .pc__caption {
    padding: 14px 16px 16px;
  }

  .pc__name {
    margin: 0 0 6px;
    font-family: Georgia, serif;
    font-size: 20px;
    font-weight: 500;
  }

  .pc__note {
    margin: 0 0 14px;
    font-size: 13px;
    line-height: 1.45;
    color: #5f5e5a;
    min-height: 44px;
  }

  .pc__claim {
    display: inline-block;
    padding: 8px 16px;
    border: 1.5px solid #12110e;
    background: #ffd400;
    color: #12110e;
    cursor: pointer;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    box-shadow: 2px 2px 0 0 #12110e;
    transition: transform 100ms;
  }

  .pc__claim:hover:not(:disabled) {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 0 #12110e;
  }

  .pc__claim:disabled {
    background: #e5e3de;
    color: #5f5e5a;
    cursor: default;
    box-shadow: 2px 2px 0 0 #5f5e5a;
  }

  .pc__texture {
    margin: 24px 0;
    padding: 18px 20px;
    background: #f7f3e6;
    border: 1.5px solid #12110e;
    box-shadow: 3px 3px 0 0 #12110e;
  }

  .pc__texture p {
    margin: 0 0 10px;
    font-size: 14px;
    line-height: 1.55;
    max-width: 70ch;
  }

  .pc__texture p:last-child { margin-bottom: 0; }

  .pc__links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 8px;
    margin-bottom: 24px;
  }

  .pc__link {
    display: block;
    padding: 12px 14px;
    border: 1.5px solid #12110e;
    background: #fff;
    text-decoration: none;
    color: #12110e;
    transition: background 120ms;
  }

  .pc__link:hover { background: #ffd400; }

  .pc__link-label { display: block; font-size: 11px; font-weight: 700; letter-spacing: 0.18em; }
  .pc__link-desc { display: block; font-size: 12px; color: #5f5e5a; margin-top: 4px; }

  .pc__foot {
    display: flex;
    justify-content: space-between;
    padding: 12px 0 0;
    border-top: 1px dashed #12110e;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #5f5e5a;
  }
</style>
