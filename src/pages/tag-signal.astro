---
/**
 * /tag-signal - embeddable browser tag game + tracking prototype.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Tag Signal',
  description: 'An embeddable browser tag game with local play tracking and optional analytics endpoint forwarding.',
  url: 'https://pointcast.xyz/tag-signal',
  gamePlatform: 'Web browser',
  genre: 'Tag',
  inLanguage: 'en-US',
};
---

<BlockLayout
  title="Tag Signal"
  description="An embeddable tag game for other sites, with local play tracking, postMessage events, and optional analytics endpoint forwarding."
  image="/images/og/b/0388.png"
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/tag-signal.json', title: 'Tag Signal manifest (JSON)' }]}
  frame={{
    image: 'https://pointcast.xyz/images/og/b/0388.png',
    buttons: [
      { label: 'Play', action: 'link', target: 'https://pointcast.xyz/tag-signal' },
      { label: 'Full screen', action: 'link', target: 'https://pointcast.xyz/games/tag-signal/' },
      { label: 'Manifest', action: 'link', target: 'https://pointcast.xyz/tag-signal.json' },
      { label: 'Home feed', action: 'link', target: 'https://pointcast.xyz/' },
    ],
  }}
>
  <main class="tag-page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/c/btl">CH.BTL</a>
      <span aria-hidden="true">/</span>
      <span>Tag Signal</span>
    </nav>

    <section class="intro">
      <p class="kicker">CH.BTL / EMBEDDABLE SITE GAME</p>
      <h1>Tag Signal</h1>
      <p>
        A drop-in tag game for other sites. It can run as a full page, mount from one script tag,
        store recent events locally, and forward play events to a future endpoint.
      </p>
      <div class="manifest-row">
        <a href="/games/tag-signal/" target="_blank" rel="noreferrer">Open full screen</a>
        <a href="/games/tag-signal/embed-demo.html" target="_blank" rel="noreferrer">Embed demo</a>
        <a href="/tag-signal.json">Manifest JSON</a>
      </div>
    </section>

    <section class="game-frame" aria-label="Tag Signal playable frame">
      <iframe src="/games/tag-signal/" title="Tag Signal game" loading="eager"></iframe>
    </section>
  </main>
</BlockLayout>

<style>
  .tag-page {
    display: grid;
    gap: 18px;
  }

  .crumb,
  .manifest-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .crumb {
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--muted, #6c6254);
  }

  .intro {
    max-width: 900px;
  }

  .kicker {
    margin: 0 0 8px;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 8px;
    font-size: clamp(2.8rem, 8vw, 6rem);
    line-height: 0.9;
    letter-spacing: 0;
  }

  .intro p {
    margin: 0;
    max-width: 800px;
    font-size: clamp(1rem, 2vw, 1.28rem);
    line-height: 1.45;
  }

  .manifest-row {
    margin-top: 16px;
  }

  .manifest-row a {
    border: 2px solid currentColor;
    padding: 8px 10px;
    font-weight: 900;
    text-decoration: none;
  }

  .game-frame {
    min-height: 820px;
    border: 3px solid currentColor;
    background: #f7f4ef;
  }

  .game-frame iframe {
    display: block;
    width: 100%;
    height: min(920px, 94vh);
    min-height: 820px;
    border: 0;
  }

  @media (max-width: 760px) {
    .game-frame,
    .game-frame iframe {
      min-height: 920px;
    }
  }
</style>
