---
/**
 * /dao — PointCast DAO v1.
 *
 * Lightweight no-moderation governance surface:
 *   - Proposals are author-curated (Mike drafts, no free-text from
 *     visitors) — the page has zero user-submitted content to moderate
 *   - Voting is Beacon-wallet signed (Kukai, Temple, Umami). One signature
 *     per proposal per wallet. Sign message is a plain-text JSON string
 *     with proposal id, choice, timestamp.
 *   - Tally backend is env-guarded: if PC_DAO_KV is bound, the /api/dao
 *     function accepts signed votes and aggregates. Until then, votes
 *     persist to localStorage and show your own vote status.
 *   - Zero free-text anywhere in the UI. Vote is FOR / AGAINST / ABSTAIN.
 *
 * Mike 2026-04-18: "continue to think how community can use, in short
 * term where we don't have to moderate content." The design answer:
 * predefined proposals + signed binary votes + no comments.
 *
 * v1 ships the proposals and the signing flow. Tally aggregation lands
 * when Manus binds the KV namespace.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import WalletChip from '../components/WalletChip.astro';
import contracts from '../data/contracts.json';

const visitNounsKt1 = ((contracts as any).visit_nouns?.mainnet ?? '').trim();

interface Proposal {
  id: string;
  kind: 'cotd' | 'schema' | 'treasury' | 'parameters';
  title: string;
  summary: string;
  body: string[];
  opensAt: string;
  closesAt: string;
  minEligibility: string;
  /** For v1 — manually-authored "this is the decision space" text */
  options: Array<{ code: 'FOR' | 'AGAINST' | 'ABSTAIN'; label: string; consequence: string }>;
}

