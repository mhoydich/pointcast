---
/**
 * /bath — the color-wave room. Four moods, four fields.
 *
 * No music. No player. Just color.
 * Four animated blob fields — WARM / COOL / ELECTRIC / EARTH —
 * each morphing through border-radius keyframes with slow floating.
 * Clicking a mood panel swaps the CSS-var palette; the blobs
 * re-color with a 2s ease transition. Clock sets the opening mood.
 *
 * The module: lava-lamp blobs. Different from /anytime's vinyl.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const title = 'Bath — color-wave room · PointCast';
const description =
  'Four moods, four fields. A PointCast color bath — ambient, warm, enveloping. WARM · COOL · ELECTRIC · EARTH.';
---

<BlockLayout title={title} description={description}>
  <main class="bath" id="bath-main" data-mood="warm">

    <!-- The four blob fields -->
    <div class="bath__blobs" aria-hidden="true">
      <div class="bath__blob bath__blob--a"></div>
      <div class="bath__blob bath__blob--b"></div>
      <div class="bath__blob bath__blob--c"></div>
      <div class="bath__blob bath__blob--d"></div>
    </div>

    <div class="bath__frame">

      <header class="bath__head">
        <p class="bath__kicker">ROOM · BATH · EL SEGUNDO</p>
        <h1 class="bath__title">The Bath</h1>
        <p class="bath__dek">Step in. The color fills from below.</p>
      </header>

      <!-- Mood note — swaps with JS -->
      <p class="bath__note" id="bath-note" aria-live="polite">
        amber · coral · gold · the warm side of morning
      </p>

      <!-- Four mood panels -->
      <nav class="bath__moods" aria-label="Color moods">
        <button class="bath__mood" data-m="warm"   aria-pressed="true">
          <span class="bath__mood-swatch"></span>
          <span class="bath__mood-name">WARM</span>
          <span class="bath__mood-sub">amber · coral · gold</span>
        </button>
        <button class="bath__mood" data-m="cool"   aria-pressed="false">
          <span class="bath__mood-swatch"></span>
          <span class="bath__mood-name">COOL</span>
          <span class="bath__mood-sub">teal · sapphire · mist</span>
        </button>
        <button class="bath__mood" data-m="electric" aria-pressed="false">
          <span class="bath__mood-swatch"></span>
          <span class="bath__mood-name">ELECTRIC</span>
          <span class="bath__mood-sub">magenta · cyan · arc</span>
        </button>
        <button class="bath__mood" data-m="earth"  aria-pressed="false">
          <span class="bath__mood-swatch"></span>
          <span class="bath__mood-name">EARTH</span>
          <span class="bath__mood-sub">sage · ochre · loam</span>
        </button>
      </nav>

      <nav class="bath__links" aria-label="Other rooms">
        <a class="bath__link" href="/anytime">
          <span class="bath__link-label">/ANYTIME</span>
          <span class="bath__link-desc">I'd Have You Anytime · George Harrison</span>
        </a>
        <a class="bath__link" href="/room">
          <span class="bath__link-label">/ROOM</span>
          <span class="bath__link-desc">the mix room · 10 tracks</span>
        </a>
        <a class="bath__link" href="/meditate">
          <span class="bath__link-label">/MEDITATE</span>
          <span class="bath__link-desc">the ocean room · breathing</span>
        </a>
        <a class="bath__link" href="/">
          <span class="bath__link-label">/</span>
          <span class="bath__link-desc">back to the broadcast</span>
        </a>
      </nav>

      <footer class="bath__foot">
        <span>on air · el segundo · fm 96.1 · cc0</span>
        <span id="bath-clock">—</span>
      </footer>

    </div>
  </main>
</BlockLayout>

<script is:inline>
  (function () {
    'use strict';

    var NOTES = {
      warm:     'amber · coral · gold · the warm side of morning',
      cool:     'teal · sapphire · mist · the clear side of afternoon',
      electric: 'magenta · cyan · arc · the lit side of midnight',
      earth:    'sage · ochre · loam · the slow side of dusk',
    };

    // Clock → opening mood
    function clockMood() {
      var h = new Date().getHours();
      if (h < 6)  return 'electric';
      if (h < 11) return 'warm';
      if (h < 16) return 'cool';
      if (h < 20) return 'earth';
      return 'electric';
    }

    function setMood(m) {
      var main = document.getElementById('bath-main');
      if (!main) return;
      main.dataset.mood = m;
      var note = document.getElementById('bath-note');
      if (note) note.textContent = NOTES[m] || '';
      document.querySelectorAll('.bath__mood').forEach(function (btn) {
        var active = btn.dataset.m === m;
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
        btn.classList.toggle('bath__mood--active', active);
      });
    }

    function tick() {
      var el = document.getElementById('bath-clock');
      if (!el) return;
      var now = new Date();
      el.textContent =
        String(now.getHours()).padStart(2, '0') + ':' +
        String(now.getMinutes()).padStart(2, '0') + ' PT';
    }

    // Wire mood buttons
    document.querySelectorAll('.bath__mood').forEach(function (btn) {
      btn.addEventListener('click', function () { setMood(btn.dataset.m); });
    });

    setMood(clockMood());
    tick();
    setInterval(tick, 60 * 1000);
  })();
</script>

<style>
  /* ── palette vars by mood ── */
  .bath                        { --bg: #100c18; --a: #F5A623; --b: #E84D6A; --c: #F7C325; --d: #FF7F50; --ink: #fdf2d6; --sw: #F5A623; }
  .bath[data-mood="warm"]      { --bg: #120a06; --a: #F5A623; --b: #E84D6A; --c: #F7C325; --d: #FF7F50; --ink: #fdf2d6; --sw: #F5A623; }
  .bath[data-mood="cool"]      { --bg: #060e18; --a: #2CC5A0; --b: #4A9EFF; --c: #7B68EE; --d: #00C9FF; --ink: #d8f0ff; --sw: #4A9EFF; }
  .bath[data-mood="electric"]  { --bg: #080612; --a: #FF00AA; --b: #00FFCC; --c: #9B4DCA; --d: #FF6B6B; --ink: #f4e8ff; --sw: #FF00AA; }
  .bath[data-mood="earth"]     { --bg: #090e06; --a: #7B9E5E; --b: #C4821A; --c: #8B5E3C; --d: #5C8A5C; --ink: #f0ead8; --sw: #7B9E5E; }

  /* ── base ── */
  .bath {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 20px 56px;
    position: relative;
    overflow: hidden;
    background: var(--bg);
    color: var(--ink);
    transition: background 2s ease, color 1.5s ease;
    font-family: 'JetBrains Mono Variable', 'Courier New', monospace;
  }

  /* ── blobs ── */
  .bath__blobs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bath__blob {
    position: absolute;
    border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;
    filter: blur(90px);
    opacity: 0.62;
    transition: background 2s ease;
    will-change: border-radius, transform;
  }

  .bath__blob--a {
    width: 60vmax;
    height: 60vmax;
    top: -20%;
    left: -15%;
    background: var(--a);
    animation: morph-a 22s ease-in-out infinite, drift-a 28s ease-in-out infinite;
  }
  .bath__blob--b {
    width: 45vmax;
    height: 45vmax;
    top: -10%;
    right: -12%;
    background: var(--b);
    animation: morph-b 17s ease-in-out infinite, drift-b 32s ease-in-out infinite;
    opacity: 0.55;
  }
  .bath__blob--c {
    width: 55vmax;
    height: 55vmax;
    bottom: -22%;
    left: 15%;
    background: var(--c);
    animation: morph-c 25s ease-in-out infinite, drift-c 36s ease-in-out infinite;
    opacity: 0.50;
  }
  .bath__blob--d {
    width: 35vmax;
    height: 35vmax;
    top: 35%;
    right: 5%;
    background: var(--d);
    animation: morph-d 14s ease-in-out infinite, drift-d 24s ease-in-out infinite;
    opacity: 0.45;
  }

  @keyframes morph-a {
    0%   { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; }
    33%  { border-radius: 70% 30% 50% 50% / 30% 30% 70% 70%; }
    66%  { border-radius: 30% 70% 40% 60% / 50% 60% 40% 50%; }
    100% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; }
  }
  @keyframes morph-b {
    0%   { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
    33%  { border-radius: 30% 70% 70% 30% / 30% 50% 50% 70%; }
    66%  { border-radius: 50% 50% 60% 40% / 40% 60% 40% 60%; }
    100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
  }
  @keyframes morph-c {
    0%   { border-radius: 50% 50% 40% 60% / 60% 40% 60% 40%; }
    33%  { border-radius: 40% 60% 60% 40% / 40% 70% 30% 60%; }
    66%  { border-radius: 70% 30% 50% 50% / 50% 40% 60% 50%; }
    100% { border-radius: 50% 50% 40% 60% / 60% 40% 60% 40%; }
  }
  @keyframes morph-d {
    0%   { border-radius: 30% 70% 50% 50% / 50% 30% 70% 50%; }
    50%  { border-radius: 60% 40% 70% 30% / 30% 60% 40% 70%; }
    100% { border-radius: 30% 70% 50% 50% / 50% 30% 70% 50%; }
  }

  @keyframes drift-a {
    0%   { transform: translate(0, 0); }
    50%  { transform: translate(3vw, 4vh); }
    100% { transform: translate(0, 0); }
  }
  @keyframes drift-b {
    0%   { transform: translate(0, 0); }
    50%  { transform: translate(-4vw, 3vh); }
    100% { transform: translate(0, 0); }
  }
  @keyframes drift-c {
    0%   { transform: translate(0, 0); }
    50%  { transform: translate(2vw, -3vh); }
    100% { transform: translate(0, 0); }
  }
  @keyframes drift-d {
    0%   { transform: translate(0, 0); }
    50%  { transform: translate(-3vw, -4vh); }
    100% { transform: translate(0, 0); }
  }

  /* ── frame ── */
  .bath__frame {
    position: relative;
    z-index: 1;
    max-width: 600px;
    width: 100%;
    padding: 32px 28px 28px;
    background: rgba(0, 0, 0, 0.30);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 2px;
    backdrop-filter: blur(18px) saturate(1.4);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
  }

  /* ── header ── */
  .bath__head { text-align: center; margin-bottom: 18px; }

  .bath__kicker {
    font-size: 10px;
    letter-spacing: 0.28em;
    font-weight: 700;
    margin: 0 0 16px;
    opacity: 0.60;
  }

  .bath__title {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.05;
    margin: 0 0 8px;
  }

  .bath__dek {
    font-family: Georgia, serif;
    font-size: 15px;
    margin: 0;
    opacity: 0.78;
    letter-spacing: 0.01em;
  }

  /* ── mood note ── */
  .bath__note {
    text-align: center;
    font-size: 10px;
    letter-spacing: 0.20em;
    margin: 0 0 22px;
    opacity: 0.56;
    min-height: 1.4em;
    transition: opacity 0.4s ease;
  }

  /* ── mood buttons ── */
  .bath__moods {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    margin: 0 0 24px;
  }

  .bath__mood {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    padding: 12px 6px 10px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 2px;
    color: inherit;
    cursor: pointer;
    font-family: 'JetBrains Mono Variable', monospace;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
    text-align: center;
  }
  .bath__mood:hover {
    background: rgba(255, 255, 255, 0.12);
    transform: translateY(-2px);
  }
  .bath__mood--active,
  .bath__mood[aria-pressed="true"] {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.30);
  }

  .bath__mood-swatch {
    display: block;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--sw);
    transition: background 2s ease;
    box-shadow: 0 0 12px var(--sw);
  }
  /* swatch color per button */
  .bath__mood[data-m="warm"]     .bath__mood-swatch { background: #F5A623; box-shadow: 0 0 10px #F5A623; }
  .bath__mood[data-m="cool"]     .bath__mood-swatch { background: #4A9EFF; box-shadow: 0 0 10px #4A9EFF; }
  .bath__mood[data-m="electric"] .bath__mood-swatch { background: #FF00AA; box-shadow: 0 0 10px #FF00AA; }
  .bath__mood[data-m="earth"]    .bath__mood-swatch { background: #7B9E5E; box-shadow: 0 0 10px #7B9E5E; }

  .bath__mood-name {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
    opacity: 0.88;
  }
  .bath__mood-sub {
    font-size: 8px;
    opacity: 0.48;
    letter-spacing: 0.06em;
    line-height: 1.3;
  }

  /* ── room links ── */
  .bath__links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 7px;
    margin: 0 0 20px;
  }
  .bath__link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 8px 11px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 2px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s ease, transform 0.15s ease;
  }
  .bath__link:hover {
    background: rgba(255, 255, 255, 0.12);
    transform: translateY(-1px);
  }
  .bath__link-label {
    font-size: 10px;
    letter-spacing: 0.16em;
    font-weight: 700;
  }
  .bath__link-desc {
    font-size: 11px;
    font-family: Georgia, serif;
    opacity: 0.65;
    line-height: 1.3;
  }

  /* ── footer ── */
  .bath__foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 10px;
    letter-spacing: 0.18em;
    padding-top: 14px;
    border-top: 1px dashed rgba(255, 255, 255, 0.12);
    opacity: 0.55;
  }

  /* ── responsive ── */
  @media (max-width: 500px) {
    .bath { padding: 32px 12px 44px; }
    .bath__frame { padding: 22px 14px 20px; }
    .bath__moods { grid-template-columns: repeat(2, 1fr); }
    .bath__mood-sub { display: none; }
    .bath__title { font-size: 30px; }
  }
</style>
