---
import BlockLayout from '../layouts/BlockLayout.astro';
import {
  PROTOCOL_AGENT_RECEIPTS,
  PROTOCOL_CANONICAL_JSON_RULES,
  PROTOCOL_COMPATIBILITY_NOTES,
  PROTOCOL_DISCOVERY,
  PROTOCOL_LAYERS,
  PROTOCOL_NAME,
  PROTOCOL_PACKET_MEDIA_TYPE,
  PROTOCOL_PACKET_EXAMPLE,
  PROTOCOL_RECEIPT_TYPES,
  PROTOCOL_PRINCIPLES,
  PROTOCOL_ROADMAP,
  PROTOCOL_SHORT_NAME,
  PROTOCOL_STORAGE_KEYS,
  PROTOCOL_UPDATED_AT,
  PROTOCOL_VALIDATION_RULES,
  PROTOCOL_V2_CHAIN_MESSENGER,
  PROTOCOL_VERSION,
  PROTOCOL_V2_SIMPLE_FRIENDS,
} from '../lib/protocol';

const description =
  'PointCast Peer Message Protocol v1: signed Block packets, replaceable relays, local-first logs, and human plus agent peers for 2026 and 2027.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  '@id': 'https://pointcast.xyz/protocol',
  name: `${PROTOCOL_NAME} v1`,
  headline: `${PROTOCOL_NAME} v1`,
  description,
  datePublished: PROTOCOL_UPDATED_AT,
  dateModified: PROTOCOL_UPDATED_AT,
  author: { '@type': 'Person', name: 'Mike Hoydich' },
  publisher: { '@type': 'Organization', name: 'PointCast', url: 'https://pointcast.xyz' },
  mainEntityOfPage: 'https://pointcast.xyz/protocol',
};

const packetJson = JSON.stringify(PROTOCOL_PACKET_EXAMPLE, null, 2);
---

<BlockLayout
  title="Protocol"
  description={description}
  jsonLd={jsonLd}
  alternates={[
    { type: 'application/json', href: '/protocol.json', title: 'PointCast Peer Message Protocol JSON' },
    { type: 'application/json', href: '/.well-known/pointcast-peer.json', title: 'PointCast peer discovery' },
  ]}
>
  <div class="protocol-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/for-agents">for-agents</a>
      <span>/</span>
      <strong>protocol</strong>
    </nav>

    <header class="hero">
      <p class="kicker">{PROTOCOL_SHORT_NAME} · {PROTOCOL_VERSION} · 2026/2027</p>
      <h1>{PROTOCOL_NAME}</h1>
      <p class="lede">
        A peer-to-peer messaging protocol for the next two years of PointCast:
        signed Block packets, replaceable relays, local-first logs, and humans
        plus agents speaking in the same thread without pretending they are the
        same kind of peer.
      </p>
      <div class="hero-actions" aria-label="Protocol links">
        <a href="/messages">Open client</a>
        <a href="/messages/demo">Friend demo</a>
        <a href="/messages/chain">Chain messenger</a>
        <a href="/protocol.json">JSON manifest</a>
        <a href="/.well-known/pointcast-peer.json">Peer discovery</a>
        <a href="/b/0378">Block 0378</a>
      </div>
    </header>

    <section class="thesis" aria-labelledby="thesis-title">
      <p class="kicker">THESIS</p>
      <h2 id="thesis-title">Messaging becomes a signed mesh of Blocks.</h2>
      <p>
        The old feed pushed updates down from a platform. The next feed is a
        mesh: people, agents, rooms, devices, and sites pass small signed
        packets to one another. Some packets are private messages. Some become
        public Blocks. Some are receipts, invites, presence pings, or citations.
        The packet is portable. The relay is replaceable. The peer keeps the log.
      </p>
    </section>

    <section class="principles" aria-labelledby="principles-title">
      <p class="kicker">DESIGN PRINCIPLES</p>
      <h2 id="principles-title">Five rules for v1.</h2>
      <ol>
        {PROTOCOL_PRINCIPLES.map((principle) => (
          <li>
            <h3>{principle.title}</h3>
            <p>{principle.body}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="layers" aria-labelledby="layers-title">
      <p class="kicker">STACK</p>
      <h2 id="layers-title">The protocol has five layers.</h2>
      <div class="layer-grid">
        {PROTOCOL_LAYERS.map((layer) => (
          <article>
            <span>{layer.id}</span>
            <h3>{layer.label}</h3>
            <p>{layer.summary}</p>
            <ul>
              {layer.must.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="client" aria-labelledby="client-title">
      <div>
        <p class="kicker">WORKING CLIENT</p>
        <h2 id="client-title">The packet now has a browser workbench.</h2>
        <p>
          <a href="/messages">/messages</a> is the v1.1 local-first proof:
          generate a browser-local Ed25519 peer, compose a Block Packet, sign it,
          store it in outbox, import JSONL into inbox, and copy any selected
          packet as a draft public Block. <a href="/messages/demo">/messages/demo</a>
          shows the v2 friend-card flow in one browser, and <a href="/messages/chain">/messages/chain</a>
          adds wallet registration plus chain-ready message envelopes.
        </p>
      </div>
      <dl>
        {Object.entries(PROTOCOL_STORAGE_KEYS).map(([label, key]) => (
          <div><dt>{label}</dt><dd><code>{key}</code></dd></div>
        ))}
      </dl>
    </section>

    <section class="v2-chain" aria-labelledby="v2-chain-title">
      <p class="kicker">CHAIN MESSENGER</p>
      <h2 id="v2-chain-title">Register, message, anchor the proof.</h2>
      <div class="roadmap-grid">
        <article>
          <p>{PROTOCOL_V2_CHAIN_MESSENGER.status}</p>
          <h3>Registration</h3>
          <ul>
            <li>{PROTOCOL_V2_CHAIN_MESSENGER.registration.mediaType}</li>
            <li>{PROTOCOL_V2_CHAIN_MESSENGER.registration.stores.join(', ')}</li>
          </ul>
        </article>
        <article>
          <p>{PROTOCOL_V2_CHAIN_MESSENGER.chain}</p>
          <h3>Envelope</h3>
          <ul>
            <li>{PROTOCOL_V2_CHAIN_MESSENGER.envelope.mediaType}</li>
            <li>{PROTOCOL_V2_CHAIN_MESSENGER.envelope.modes.join(' · ')}</li>
          </ul>
        </article>
        <article>
          <p>{PROTOCOL_V2_CHAIN_MESSENGER.handoff.prefix}</p>
          <h3>Handoff</h3>
          <ul>
            <li>{PROTOCOL_V2_CHAIN_MESSENGER.handoff.mediaType}</li>
            <li>{PROTOCOL_V2_CHAIN_MESSENGER.handoff.includes.join(' · ')}</li>
          </ul>
        </article>
        <article>
          <p>demo</p>
          <h3>Try it</h3>
          <ul>
            <li><a href={PROTOCOL_V2_CHAIN_MESSENGER.demo}>{PROTOCOL_V2_CHAIN_MESSENGER.demo}</a></li>
            <li>{PROTOCOL_V2_CHAIN_MESSENGER.caveat}</li>
          </ul>
        </article>
      </div>
    </section>

    <section class="v2-friends" aria-labelledby="v2-friends-title">
      <p class="kicker">PCP/2 DRAFT</p>
      <h2 id="v2-friends-title">Friend messaging starts with a card.</h2>
      <div class="roadmap-grid">
        <article>
          <p>{PROTOCOL_V2_SIMPLE_FRIENDS.status}</p>
          <h3>Friend card</h3>
          <ul>
            <li>{PROTOCOL_V2_SIMPLE_FRIENDS.friendCard.mediaType}</li>
            <li>{PROTOCOL_V2_SIMPLE_FRIENDS.friendCard.fields.join(', ')}</li>
          </ul>
        </article>
        <article>
          <p>human flow</p>
          <h3>Three moves</h3>
          <ul>
            {PROTOCOL_V2_SIMPLE_FRIENDS.humanFlow.slice(0, 3).map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article>
          <p>demo</p>
          <h3>Try it</h3>
          <ul>
            <li><a href={PROTOCOL_V2_SIMPLE_FRIENDS.demo}>{PROTOCOL_V2_SIMPLE_FRIENDS.demo}</a></li>
            <li>{PROTOCOL_V2_SIMPLE_FRIENDS.relayRule}</li>
          </ul>
        </article>
      </div>
    </section>

    <section class="hardening" aria-labelledby="hardening-title">
      <p class="kicker">V1.0.1 HARDENING</p>
      <h2 id="hardening-title">Canonical JSON, validation, receipts, bridges.</h2>
      <div class="hardening-grid">
        <article>
          <h3>Packet media type</h3>
          <p><code>{PROTOCOL_PACKET_MEDIA_TYPE}</code></p>
        </article>
        <article>
          <h3>Canonical rules</h3>
          <ul>{PROTOCOL_CANONICAL_JSON_RULES.map((item) => <li>{item}</li>)}</ul>
        </article>
        <article>
          <h3>Validation rules</h3>
          <ul>{PROTOCOL_VALIDATION_RULES.map((item) => <li>{item}</li>)}</ul>
        </article>
        <article>
          <h3>Receipts</h3>
          <p>{PROTOCOL_RECEIPT_TYPES.join(' · ')}</p>
        </article>
      </div>
    </section>

    <section class="packet" aria-labelledby="packet-title">
      <div>
        <p class="kicker">PACKET SHAPE</p>
        <h2 id="packet-title">A message is a Block Packet.</h2>
        <p>
          The packet is intentionally boring JSON. It can move over WebRTC,
          WebSocket relay, WebTransport, QR bundle, Bluetooth, file export, or
          a future native client without changing the message itself.
        </p>
      </div>
      <pre><code>{packetJson}</code></pre>
    </section>

    <section class="flow" aria-labelledby="flow-title">
      <p class="kicker">SEND FLOW</p>
      <h2 id="flow-title">How a peer sends one message.</h2>
      <ol>
        <li>Compose a Block Packet locally.</li>
        <li>Canonicalize the JSON and derive the content id.</li>
        <li>Encrypt the body when the packet is private.</li>
        <li>Sign the packet with the peer key.</li>
        <li>Try direct WebRTC delivery.</li>
        <li>Fall back to a relay, QR bundle, LAN, Bluetooth, or JSONL export.</li>
        <li>Append receipts without rewriting the original packet.</li>
      </ol>
    </section>

    <section class="agent-use" aria-labelledby="agent-use-title">
      <p class="kicker">AGENT PEERS</p>
      <h2 id="agent-use-title">Agents send receipts, not vibes.</h2>
      <div class="roadmap-grid">
        {PROTOCOL_AGENT_RECEIPTS.map((receipt) => (
          <article>
            <p>{receipt.type}</p>
            <h3>{receipt.type}</h3>
            <ul><li>{receipt.use}</li></ul>
          </article>
        ))}
      </div>
    </section>

    <section class="compat" aria-labelledby="compat-title">
      <p class="kicker">BRIDGES</p>
      <h2 id="compat-title">Compatibility notes.</h2>
      <ul>
        {PROTOCOL_COMPATIBILITY_NOTES.map((note) => <li>{note}</li>)}
      </ul>
    </section>

    <section class="roadmap" aria-labelledby="roadmap-title">
      <p class="kicker">ROADMAP</p>
      <h2 id="roadmap-title">2026 proves the packet. 2027 proves the mesh.</h2>
      <div class="roadmap-grid">
        {PROTOCOL_ROADMAP.map((phase) => (
          <article>
            <p>{phase.year}</p>
            <h3>{phase.phase}</h3>
            <ul>
              {phase.ships.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <aside class="discovery" aria-labelledby="discovery-title">
      <p class="kicker">DISCOVERY</p>
      <h2 id="discovery-title">Canonical surfaces</h2>
      <dl>
        <div><dt>Human spec</dt><dd><a href={PROTOCOL_DISCOVERY.route}>{PROTOCOL_DISCOVERY.route}</a></dd></div>
        <div><dt>Local client</dt><dd><a href={PROTOCOL_DISCOVERY.client}>{PROTOCOL_DISCOVERY.client}</a></dd></div>
        <div><dt>Friend demo</dt><dd><a href={PROTOCOL_DISCOVERY.friendDemo}>{PROTOCOL_DISCOVERY.friendDemo}</a></dd></div>
        <div><dt>Chain messenger</dt><dd><a href={PROTOCOL_DISCOVERY.chainMessenger}>{PROTOCOL_DISCOVERY.chainMessenger}</a></dd></div>
        <div><dt>JSON manifest</dt><dd><a href={PROTOCOL_DISCOVERY.json}>{PROTOCOL_DISCOVERY.json}</a></dd></div>
        <div><dt>Well-known</dt><dd><a href={PROTOCOL_DISCOVERY.wellKnown}>{PROTOCOL_DISCOVERY.wellKnown}</a></dd></div>
        <div><dt>Encrypted relay</dt><dd><a href={PROTOCOL_DISCOVERY.relay}>{PROTOCOL_DISCOVERY.relay}</a></dd></div>
        <div><dt>Announcement block</dt><dd><a href={PROTOCOL_DISCOVERY.block}>{PROTOCOL_DISCOVERY.block}</a></dd></div>
      </dl>
    </aside>
  </div>
</BlockLayout>

<style>
  .protocol-page {
    width: min(1120px, calc(100vw - 32px));
    margin: 0 auto;
    padding: 28px 0 96px;
    color: var(--pc-ink);
  }

  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin-bottom: 28px;
    font-family: var(--pc-font-mono);
    font-size: 12px;
    text-transform: uppercase;
  }

  .breadcrumb a,
  .breadcrumb strong {
    color: var(--pc-ink);
  }

  .kicker {
    margin: 0 0 10px;
    color: var(--pc-accent);
    font-family: var(--pc-font-mono);
    font-size: 12px;
    text-transform: uppercase;
  }

  .hero {
    display: grid;
    gap: 22px;
    min-height: 72vh;
    align-content: center;
    border-top: 2px solid var(--pc-ink);
    border-bottom: 1px solid var(--pc-rule);
    padding: 56px 0;
  }

  .hero h1 {
    max-width: 960px;
    margin: 0;
    font-size: clamp(54px, 8vw, 116px);
    line-height: 0.92;
    letter-spacing: 0;
    font-weight: 500;
  }

  .lede {
    max-width: 760px;
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 22px;
    line-height: 1.35;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-actions a {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    border: 1px solid var(--pc-ink);
    padding: 0 14px;
    color: var(--pc-ink);
    font-family: var(--pc-font-mono);
    font-size: 12px;
    text-transform: uppercase;
  }

  .hero-actions a:first-child {
    background: var(--pc-ink);
    color: #fff;
  }

  section,
  .discovery {
    padding: 44px 0;
    border-bottom: 1px solid var(--pc-rule-soft);
  }

  h2 {
    max-width: 800px;
    margin: 0 0 16px;
    font-size: clamp(30px, 4vw, 54px);
    line-height: 1;
    letter-spacing: 0;
    font-weight: 500;
  }

  .thesis p {
    max-width: 860px;
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 22px;
    line-height: 1.45;
  }

  .principles ol,
  .flow ol {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 10px;
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .principles li,
  .flow li,
  .layers article,
  .roadmap article {
    min-width: 0;
    border: 1px solid var(--pc-rule);
    padding: 16px;
    background: #fff;
  }

  .principles h3,
  .layers h3,
  .roadmap h3 {
    margin: 0 0 8px;
    font-size: 21px;
    line-height: 1.08;
    letter-spacing: 0;
    font-weight: 500;
  }

  .principles p,
  .layers p,
  .roadmap li,
  .flow li {
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 14px;
    line-height: 1.45;
  }

  .layer-grid,
  .roadmap-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin-top: 24px;
  }

  .layers article span,
  .roadmap article p {
    display: block;
    margin: 0 0 18px;
    color: var(--pc-accent);
    font-family: var(--pc-font-mono);
    font-size: 11px;
    text-transform: uppercase;
  }

  .layers ul,
  .roadmap ul {
    display: grid;
    gap: 8px;
    margin: 14px 0 0;
    padding-left: 18px;
  }

  .packet {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1fr);
    gap: 24px;
    align-items: start;
  }

  .client {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1fr);
    gap: 24px;
    align-items: start;
  }

  .client p {
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 18px;
    line-height: 1.45;
  }

  .client dl,
  .hardening-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin: 0;
  }

  .client div,
  .hardening article {
    min-width: 0;
  }

  .client dl div,
  .hardening article {
    border: 1px solid var(--pc-rule);
    padding: 14px;
  }

  .client dt {
    color: var(--pc-accent);
    font-family: var(--pc-font-mono);
    font-size: 11px;
    text-transform: uppercase;
  }

  .client dd {
    margin: 6px 0 0;
    overflow-wrap: anywhere;
    font-family: var(--pc-font-mono);
    font-size: 12px;
  }

  .hardening h3 {
    margin: 0 0 10px;
    font-size: 20px;
    line-height: 1.1;
    font-weight: 500;
  }

  .hardening p,
  .hardening li,
  .compat li {
    color: var(--pc-ink-soft);
    font-size: 14px;
    line-height: 1.45;
  }

  .hardening ul,
  .compat ul {
    display: grid;
    gap: 8px;
    margin: 0;
    padding-left: 18px;
  }

  .packet p {
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 18px;
    line-height: 1.45;
  }

  pre {
    min-width: 0;
    max-height: 620px;
    overflow: auto;
    margin: 0;
    border: 1px solid var(--pc-ink);
    background: #111;
    color: #f7f7f2;
    padding: 18px;
    font-family: var(--pc-font-mono);
    font-size: 12px;
    line-height: 1.5;
  }

  .flow ol {
    grid-template-columns: repeat(7, minmax(0, 1fr));
    counter-reset: flow;
  }

  .flow li {
    display: grid;
    gap: 14px;
  }

  .flow li::before {
    counter-increment: flow;
    content: counter(flow, decimal-leading-zero);
    color: var(--pc-accent);
    font-family: var(--pc-font-mono);
    font-size: 12px;
  }

  .discovery dl {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin: 22px 0 0;
  }

  .discovery div {
    min-width: 0;
    border: 1px solid var(--pc-rule);
    padding: 14px;
  }

  .discovery dt {
    color: var(--pc-accent);
    font-family: var(--pc-font-mono);
    font-size: 11px;
    text-transform: uppercase;
  }

  .discovery dd {
    margin: 6px 0 0;
    overflow-wrap: anywhere;
    font-size: 15px;
  }

  @media (max-width: 980px) {
    .principles ol,
    .flow ol,
    .layer-grid,
    .roadmap-grid,
    .packet,
    .client,
    .client dl,
    .hardening-grid,
    .discovery dl {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .protocol-page {
      width: min(100% - 24px, 1120px);
      padding-top: 18px;
    }

    .hero {
      min-height: 64vh;
      padding: 36px 0;
    }

    .hero h1 {
      font-size: 52px;
    }

    .lede,
    .thesis p {
      font-size: 18px;
    }

    .principles ol,
    .flow ol,
    .layer-grid,
    .roadmap-grid,
    .packet,
    .client,
    .client dl,
    .hardening-grid,
    .discovery dl {
      grid-template-columns: 1fr;
    }
  }
</style>
