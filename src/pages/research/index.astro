---
/**
 * /research — index of every PointCast research memo.
 *
 * Mirrors the /rfc index. Newest filedDate first.
 */
import BlockLayout from '../../layouts/BlockLayout.astro';
import { listMemos } from '../../lib/research';

const memos = listMemos();

const title = 'Research — PointCast memos';
const description =
  "Research passes filed at PointCast — frontier scans, thesis checks, game-design explorations. Each memo is a cc-curated note with live web sources. Agent manifest at /research.json.";

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'PointCast Research',
  description,
  url: 'https://pointcast.xyz/research',
  hasPart: memos.map((m) => ({
    '@type': 'ScholarlyArticle',
    name: m.title,
    datePublished: m.filedDate,
    url: `https://pointcast.xyz/research/${m.slug}`,
    about: m.purpose,
  })),
};

function fmtDate(raw: string): string {
  if (!raw) return '';
  try {
    return new Intl.DateTimeFormat('en-US', {
      year: 'numeric',
      month: 'short',
      day: '2-digit',
      timeZone: 'America/Los_Angeles',
    }).format(new Date(raw));
  } catch {
    return raw;
  }
}
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>research</span>
    </nav>

    <header class="head">
      <p class="kicker mono">RESEARCH · MEMOS</p>
      <h1 class="title">Scans from the edge of the table.</h1>
      <p class="dek">
        Research passes run at PointCast — live-web scans, thesis
        checks, game-design explorations. Each memo is a cc-curated
        note with cited sources and honest uncertainty flags. Agent
        manifest at <a href="/research.json"><code>/research.json</code></a>.
      </p>
      <ul class="stats">
        <li><span class="stats__num">{memos.length}</span><span class="stats__lbl mono">MEMOS</span></li>
        <li><span class="stats__num">{memos.reduce((a, m) => a + m.wordCount, 0).toLocaleString()}</span><span class="stats__lbl mono">WORDS TOTAL</span></li>
      </ul>
    </header>

    {memos.length === 0 ? (
      <section class="empty"><p>No memos yet. First one when one lands.</p></section>
    ) : (
      <ol class="list">
        {memos.map((m) => (
          <li class="item">
            <div class="item__meta mono">
              {m.filedDate && <span class="item__date">{fmtDate(m.filedDate)}</span>}
              <span class="item__words">{m.wordCount.toLocaleString()} words</span>
            </div>
            <h2 class="item__title"><a href={`/research/${m.slug}`}>{m.title}</a></h2>
            {m.purpose && <p class="item__purp">{m.purpose}</p>}
            {m.summary && <p class="item__sum">{m.summary}</p>}
            <p class="item__links mono">
              <a href={`/research/${m.slug}`}>read →</a>
              <span aria-hidden="true"> · </span>
              <a href={`https://github.com/mhoydich/pointcast/blob/main/docs/research/${m.slug}.md`}>source</a>
            </p>
          </li>
        ))}
      </ol>
    )}

    <footer class="foot mono">
      <p>SCHEMA <code>src/lib/research.ts</code> · DOCS <code>docs/research/{`{slug}.md`}</code></p>
    </footer>
  </main>
</BlockLayout>

<style>
  .page { max-width: 820px; margin: 0 auto; padding: 3rem 1.5rem 6rem; }
  .crumb { font-family: ui-monospace, 'JetBrains Mono', monospace; font-size: 0.82rem; opacity: 0.6; margin-bottom: 1.5rem; }
  .crumb a { color: inherit; text-decoration: none; }
  .crumb a:hover { text-decoration: underline; }

  .head { border-bottom: 2px solid currentColor; padding-bottom: 2rem; margin-bottom: 3rem; }
  .kicker { font-size: 0.8rem; letter-spacing: 0.28em; text-transform: uppercase; opacity: 0.7; margin-bottom: 1rem; }
  .mono { font-family: ui-monospace, 'JetBrains Mono', monospace; }
  .title { font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(2.2rem, 4.8vw, 3.8rem); line-height: 1; letter-spacing: -0.02em; margin-bottom: 1rem; }
  .dek { font-size: 1.05rem; line-height: 1.5; max-width: 60ch; opacity: 0.88; }
  .dek a, .dek code { color: inherit; }
  .dek code { font-family: ui-monospace, 'JetBrains Mono', monospace; font-size: 0.92em; padding: 0 0.3em; }

  .stats { list-style: none; display: flex; gap: 2rem; margin-top: 1.4rem; padding: 0; flex-wrap: wrap; }
  .stats li { display: flex; flex-direction: column; gap: 0.2rem; }
  .stats__num { font-family: 'DM Serif Display', Georgia, serif; font-size: 2rem; line-height: 1; }
  .stats__lbl { font-size: 0.68rem; letter-spacing: 0.22em; opacity: 0.6; }

  .list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 2.2rem; }
  .item__meta { display: flex; gap: 1rem; font-size: 0.74rem; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.65; flex-wrap: wrap; margin-bottom: 0.4rem; }
  .item__date { color: var(--dusk, #F0B94A); }
  .item__title { font-family: 'DM Serif Display', Georgia, serif; font-size: 1.7rem; line-height: 1.1; letter-spacing: -0.01em; margin-bottom: 0.5rem; }
  .item__title a { color: inherit; text-decoration: none; background-image: linear-gradient(currentColor, currentColor); background-size: 0 1px; background-repeat: no-repeat; background-position: 0 100%; transition: background-size 0.25s ease; }
  .item__title a:hover { background-size: 100% 1px; }
  .item__purp { font-size: 0.92rem; line-height: 1.45; opacity: 0.75; font-style: italic; margin-bottom: 0.5rem; }
  .item__sum { font-size: 0.98rem; line-height: 1.5; opacity: 0.88; margin-bottom: 0.5rem; }
  .item__links { font-size: 0.78rem; }
  .item__links a { color: inherit; }

  .foot { border-top: 1px dashed currentColor; margin-top: 4rem; padding-top: 1.5rem; opacity: 0.55; font-size: 0.78rem; letter-spacing: 0.1em; }
  .foot code { padding: 0 0.3em; opacity: 0.85; }

  .empty { padding: 3rem 0; text-align: center; opacity: 0.6; }
</style>
