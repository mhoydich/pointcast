---
/**
 * /drum-v2 — PointCast Drum Room v2
 *
 * More Nouns. More collaborative. More celebratory. DRUM token front and center.
 * An orbiting crew of friend nouns, party mode when the room fills up, and
 * a Tezos DRUM token accumulator that makes every tap feel like it matters.
 *
 * Signed: Michael Hoydich · Claude Sonnet 4.6 High · 2026-04-26
 */
import DrumLayout from '../layouts/DrumLayout.astro';
import DrumNav from '../components/DrumNav.astro';

const DRUMS = [
  { id:  20, label: 'Low',    pitch:  70, kind: 'thump',  unlockAt:   0 },
  { id:  42, label: 'Mid',    pitch: 110, kind: 'thump',  unlockAt:   0 },
  { id: 101, label: 'High',   pitch: 170, kind: 'thump',  unlockAt:   0 },
  { id: 333, label: 'Bell',   pitch: 440, kind: 'bell',   unlockAt:  10 },
  { id: 555, label: 'Shaker', pitch:   0, kind: 'shaker', unlockAt: 100 },
] as const;
---

<DrumLayout
  title="Drum Room v2"
  description="Collaborative multiplayer drum room v2 on pointcast.xyz. Earn DRUM tokens on Tezos. Tap rhythms, build combos, celebrate together."
  image="/images/og-drum.png"
>

<div class="v2-root">

  <DrumNav current="v2" />

  <!-- ══ HERO COUNTER ══ -->
  <div class="v2-hero" id="v2-hero">
    <div class="v2-hero-eyebrow">total drums</div>
    <div class="v2-hero-number" id="v2-global">—</div>
    <div class="v2-hero-sub">
      <span class="v2-live-pulse"></span>
      <span id="v2-active-label">live · warming up</span>
    </div>
  </div>

  <!-- ══ PARTY BANNER (hidden until 3+ jammers) ══ -->
  <div class="v2-party-banner" id="v2-party-banner" aria-live="polite" hidden>
    <span>⌐◨-◨</span>
    <span class="v2-party-text">JAM SESSION</span>
    <span id="v2-party-sub">3 live</span>
    <span>⌐◨-◨</span>
  </div>

  <!-- ══ MAIN STAGE ══ -->
  <div class="v2-stage" id="v2-stage">

    <!-- Friend nouns orbit — populated by JS -->
    <div class="v2-orbit" id="v2-orbit" aria-hidden="true"></div>

    <!-- Main drum -->
    <button
      id="v2-drum-btn"
      type="button"
      class="v2-main-drum"
      aria-label="Tap to drum"
      style="touch-action: manipulation;"
    >
      <div class="v2-drum-frame" id="v2-drum-frame">
        <div class="v2-drum-corner v2-drum-corner-tl" aria-hidden="true"></div>
        <div class="v2-drum-corner v2-drum-corner-tr" aria-hidden="true"></div>
        <div class="v2-drum-corner v2-drum-corner-bl" aria-hidden="true"></div>
        <div class="v2-drum-corner v2-drum-corner-br" aria-hidden="true"></div>
        <img
          id="v2-drum-img"
          src="https://noun.pics/42.svg"
          alt="Drum Noun"
          width="220"
          height="220"
          class="v2-drum-img"
          style="image-rendering: pixelated;"
          draggable="false"
        />
      </div>
      <div class="v2-drum-tap-label" id="v2-drum-label">TAP</div>
    </button>

    <!-- Floating layers -->
    <div class="v2-ripples" id="v2-ripples" aria-hidden="true"></div>
    <div class="v2-confetti" id="v2-confetti" aria-hidden="true"></div>
  </div>

  <!-- ══ VOICE CHIP — your assigned pentatonic note ══ -->
  <div class="v2-voice-strip" aria-live="polite">
    <span class="v2-voice-glyph">⌐◨-◨</span>
    <span class="v2-voice-prefix">your voice</span>
    <span class="v2-voice-note" id="v2-voice-note">—</span>
    <span class="v2-voice-reg" id="v2-voice-reg">·  pentatonic · everyone harmonizes</span>
  </div>

  <!-- ══ WALLET STRIP — appears when Beacon-connected. Surfaces the
       active Tezos wallet so leaderboard / DRUM claim feel grounded.
       Hidden until pc:wallet-change fires with a wallet. ══ -->
  <div class="v2-wallet-strip" id="v2-wallet-strip" hidden>
    <span class="v2-wallet-tez">ꜩ</span>
    <span class="v2-wallet-prefix">wallet</span>
    <span class="v2-wallet-addr" id="v2-wallet-addr">—</span>
    <span class="v2-wallet-prov" id="v2-wallet-prov">—</span>
    <button type="button" class="v2-wallet-disc" id="v2-wallet-disc-btn">switch ↓</button>
  </div>

  <!-- ══ STAT HUD ══ -->
  <div class="v2-hud">
    <div class="v2-hud-card">
      <div class="v2-hud-label">Your Drums</div>
      <div class="v2-hud-val" id="v2-your">0</div>
    </div>
    <div class="v2-hud-card v2-hud-combo" id="v2-combo-card">
      <div class="v2-hud-label">Combo</div>
      <div class="v2-hud-val" id="v2-combo">×1</div>
    </div>
    <div class="v2-hud-card">
      <div class="v2-hud-label">BPM</div>
      <div class="v2-hud-val" id="v2-bpm">—</div>
    </div>
    <div class="v2-hud-card v2-hud-jammers">
      <div class="v2-hud-label">Jammers</div>
      <div class="v2-hud-val" id="v2-jammers">1</div>
    </div>
  </div>

  <!-- ══ DRUM TOKEN SECTION ══ -->
  <div class="v2-token">
    <div class="v2-token-header">
      <span class="v2-token-tez">ꜩ</span>
      <span class="v2-token-name">DRUM Token · Tezos FA1.2</span>
      <span class="v2-token-chip">SOON</span>
    </div>
    <div class="v2-token-eq-row">
      <div class="v2-token-stat">
        <div class="v2-token-stat-label">Your drums</div>
        <div class="v2-token-stat-val" id="v2-tok-drums">0</div>
      </div>
      <div class="v2-token-arrow">→</div>
      <div class="v2-token-stat">
        <div class="v2-token-stat-label">DRUM tokens</div>
        <div class="v2-token-stat-val v2-token-warm" id="v2-tok-amount">0.00</div>
      </div>
      <div class="v2-token-stat">
        <div class="v2-token-stat-label">Next token</div>
        <div class="v2-tok-progress-wrap">
          <div class="v2-tok-bar">
            <div class="v2-tok-fill" id="v2-tok-fill" style="width:0%"></div>
          </div>
          <div class="v2-token-stat-val v2-token-sm" id="v2-tok-next">100 to go</div>
        </div>
      </div>
    </div>
    <button id="v2-claim-btn" disabled class="v2-claim-btn" aria-label="Claim DRUM tokens on Tezos (coming soon)">
      Claim DRUM on Tezos
      <span class="v2-claim-pill" id="v2-claim-pill">Phase C</span>
    </button>
    <p class="v2-token-hint">
      100 drums = 1 DRUM · connect a Tezos wallet to earn on-chain · powered by
      <span class="v2-token-tez-inline">ꜩ</span> Tezos
    </p>
  </div>

  <!-- ══ DRUM RACK ══ -->
  <div class="v2-rack">
    <div class="v2-rack-header">
      <span class="v2-rack-title">DRUM RACK</span>
      <span class="v2-rack-hint">tap a drum to switch · unlock more as you level up</span>
    </div>
    <div class="v2-rack-row" id="v2-rack-row">
      {DRUMS.map((d, i) => (
        <button
          type="button"
          class={`v2-rack-btn${i === 1 ? ' v2-rack-active' : ''}`}
          data-drum-index={String(i)}
          data-noun-id={String(d.id)}
          data-pitch={String(d.pitch)}
          data-drum-kind={d.kind}
          data-unlock-at={String(d.unlockAt)}
          aria-label={`${d.label} drum`}
          aria-pressed={i === 1 ? 'true' : 'false'}
          style="touch-action: manipulation;"
        >
          <div class="v2-rack-inner">
            <img
              class="v2-rack-img"
              src={`https://noun.pics/${d.id}.svg`}
              alt={d.label}
              width="80"
              height="80"
              style="image-rendering: pixelated;"
              draggable="false"
            />
            {d.unlockAt > 0 && (
              <div class="v2-rack-lock" aria-hidden="true">
                <span>🔒</span>
                <span>at {d.unlockAt}</span>
              </div>
            )}
          </div>
          <div class="v2-rack-name">{d.label}</div>
        </button>
      ))}
    </div>
  </div>

  <!-- ══ MILESTONE + BADGES ══ -->
  <div class="v2-milestone">
    <div class="v2-milestone-row">
      <span class="v2-milestone-label" id="v2-tier-label">Newcomer</span>
      <span class="v2-milestone-progress" id="v2-tier-progress">0 / 10</span>
    </div>
    <div class="v2-milestone-bar">
      <div class="v2-milestone-fill" id="v2-tier-fill" style="width:0%"></div>
    </div>
  </div>

  <div class="v2-badges" id="v2-badges" aria-label="Drum achievements">
    <span class="v2-badge locked" data-badge="first"       title="First tap">🥁</span>
    <span class="v2-badge locked" data-badge="novice"      title="Novice · 10 drums">🎯</span>
    <span class="v2-badge locked" data-badge="combo-3"     title="Combo ×3 · on fire">🔥</span>
    <span class="v2-badge locked" data-badge="pace-120"    title="Pace ≥ 120 BPM">⚡</span>
    <span class="v2-badge locked" data-badge="combo-5"     title="Combo ×5 · flow">✨</span>
    <span class="v2-badge locked" data-badge="journeyman"  title="Journeyman · 100 drums">🥋</span>
    <span class="v2-badge locked" data-badge="pace-240"    title="Pace ≥ 240 BPM">🚀</span>
    <span class="v2-badge locked" data-badge="master"      title="Master · 1,000 drums">👑</span>
    <span class="v2-badge locked" data-badge="social"      title="Drum with 3+ friends">⌐◨-◨</span>
  </div>

  <!-- ══ LEADERBOARD — top 10 drummers by all-time count.
       Backed by /api/drum/top (KV-cached). Refreshes every 15s.
       Highlights "you" if your hash is in the top 10; appends a
       "your rank" row below if you're not in. Wallet-aware: a
       connected wallet wins display priority over noun-id label. ══ -->
  <section class="v2-leaderboard" aria-label="Top drummers leaderboard">
    <div class="v2-lb-header">
      <span class="v2-lb-glyph">⌐◨-◨</span>
      <span class="v2-lb-title">Top Drummers</span>
      <span class="v2-lb-period">all-time · top 10</span>
      <span class="v2-lb-live" id="v2-lb-live">refreshing…</span>
    </div>
    <ol id="v2-lb-list" class="v2-lb-list">
      <li class="v2-lb-empty">loading leaderboard…</li>
    </ol>
    <div id="v2-lb-self" class="v2-lb-self" hidden>
      <span class="v2-lb-self-label">your rank</span>
      <span class="v2-lb-self-rank" id="v2-lb-self-rank">—</span>
      <span class="v2-lb-self-count" id="v2-lb-self-count">0</span>
    </div>
  </section>

  <!-- ══ BOTTOM: ACTIVITY + PRESENCE ══ -->
  <div class="v2-bottom">
    <div class="v2-panel">
      <div class="v2-panel-head">
        <span class="v2-panel-title">Live Activity</span>
        <span class="v2-live-dot-sm"></span>
        <span id="v2-activity-rate">—</span>/min
      </div>
      <ul id="v2-activity-feed" class="v2-activity-list">
        <li class="v2-activity-empty">waiting for taps…</li>
      </ul>
    </div>
    <div class="v2-panel">
      <div class="v2-panel-head">
        <span class="v2-panel-title">In the Room</span>
        <span id="v2-room-count">—</span>
      </div>
      <div id="v2-present-strip" class="v2-presence-strip"></div>
      <div class="v2-name-row">
        <label for="v2-name-input" class="v2-name-label">you're</label>
        <input
          id="v2-name-input"
          type="text"
          maxlength="16"
          placeholder="name yourself (optional)"
          class="v2-name-input"
        />
        <span class="v2-name-noun" id="v2-name-noun">#—</span>
      </div>
    </div>
  </div>

  <!-- ══ SHARE ══ -->
  <div class="v2-share-row">
    <button id="v2-share-btn" type="button" class="v2-share-btn">
      ↗ Invite friends to jam
    </button>
    <span class="v2-share-hint" id="v2-share-hint">share the drum room</span>
  </div>

  <!-- ══ TOAST ══ -->
  <div id="v2-toast" class="v2-toast" hidden aria-live="assertive">
    <div class="v2-toast-label" id="v2-toast-label">unlocked</div>
    <div class="v2-toast-title" id="v2-toast-title">—</div>
  </div>

  <!-- ══ FOOTER SIGNATURE ══ -->
  <footer class="v2-footer">
    <span>⌐◨-◨ PointCast · Drum Room</span>
    <span>Signed: Michael Hoydich · Claude Sonnet 4.6 High · 2026</span>
    <a href="/drum" class="v2-footer-v1">← v1 classic</a>
  </footer>

</div>

</DrumLayout>

<style is:global>
/* ══════════════════════════════════════════════════════════════════
   DRUM v2 — self-contained styles. Uses DrumLayout CSS vars.
   `is:global` so dynamically-injected leaderboard rows (which lack
   Astro's scoped data-astro-cid attribute) still pick up styles.
   All selectors are v2-* prefixed to avoid leaking elsewhere.
   All classes prefixed v2- to avoid collisions with global.css.
   ══════════════════════════════════════════════════════════════════ */

.v2-root {
  max-width: 680px;
  margin: 0 auto;
  padding: 0 16px 60px;
  font-family: var(--pc-font-mono);
}

/* ── Version switcher ─────────────────────────────── */
.v2-ver-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 0 14px;
}
.v2-ver-pill {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  border-radius: 999px;
  border: 1.5px solid var(--pc-ink);
  font-size: 9px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--pc-ink-muted);
  transition: background 120ms, color 120ms;
  cursor: pointer;
}
.v2-ver-pill:hover { background: var(--pc-rule-soft); color: var(--pc-ink); text-decoration: none; }
.v2-ver-active {
  background: var(--pc-ink);
  color: #fff;
  cursor: default;
}

/* ── Hero counter ──────────────────────────────────── */
.v2-hero {
  text-align: center;
  padding: 20px 0 10px;
  border-bottom: 1.5px solid var(--pc-rule);
  margin-bottom: 16px;
}
.v2-hero-eyebrow {
  font-size: 9px;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--pc-ink-muted);
  margin-bottom: 6px;
}
.v2-hero-number {
  font-size: clamp(2.4rem, 8vw, 4rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1;
  color: var(--pc-ink);
  font-variant-numeric: tabular-nums;
  transition: color 200ms;
}
.v2-hero-sub {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 8px;
  font-size: 9px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--pc-ink-muted);
}
.v2-live-pulse {
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #c26a4a;
  animation: v2-pulse 1.8s ease-in-out infinite;
}
@keyframes v2-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.45; transform: scale(0.7); }
}

/* ── Party banner ──────────────────────────────────── */
.v2-party-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 10px 16px;
  border-radius: 8px;
  border: 2px solid #c26a4a;
  background: linear-gradient(90deg, rgba(194,106,74,0.08) 0%, rgba(194,106,74,0.15) 50%, rgba(194,106,74,0.08) 100%);
  background-size: 200% 100%;
  animation: v2-party-slide 2s linear infinite;
  margin-bottom: 14px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #c26a4a;
}
.v2-party-text { font-size: 13px; }
@keyframes v2-party-slide {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ── Main stage ────────────────────────────────────── */
.v2-stage {
  position: relative;
  width: 340px;
  height: 340px;
  max-width: 100%;
  margin: 0 auto 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Orbit ring */
.v2-orbit {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}
.v2-orbit-friend {
  position: absolute;
  width: 52px;
  height: 52px;
  border-radius: 6px;
  border: 2px solid var(--pc-ink);
  background: #fff;
  padding: 3px;
  transform: translate(-50%, -50%);
  box-shadow: 0 2px 6px rgba(0,0,0,0.12);
  animation: v2-orbit-float 3s ease-in-out infinite;
}
.v2-orbit-friend img {
  width: 100%;
  height: 100%;
  display: block;
  image-rendering: pixelated;
}
.v2-orbit-friend:nth-child(2) { animation-delay: -1s; }
.v2-orbit-friend:nth-child(3) { animation-delay: -2s; }
.v2-orbit-friend:nth-child(4) { animation-delay: -0.5s; }
.v2-orbit-friend:nth-child(5) { animation-delay: -1.5s; }
.v2-orbit-friend:nth-child(6) { animation-delay: -2.5s; }
@keyframes v2-orbit-float {
  0%, 100% { transform: translate(-50%, -50%) scale(1); }
  50%       { transform: translate(-50%, calc(-50% - 5px)) scale(1.04); }
}

/* Main drum button */
.v2-main-drum {
  position: relative;
  z-index: 2;
  background: transparent;
  border: none;
  padding: 0;
  cursor: pointer;
  outline: none;
  -webkit-tap-highlight-color: transparent;
}
.v2-drum-frame {
  position: relative;
  border: 3px solid var(--pc-ink);
  background: #fff;
  padding: 10px;
  transition: box-shadow 120ms ease, transform 80ms ease;
}
.v2-main-drum:active .v2-drum-frame,
.v2-drum-frame.tapped {
  transform: scale(0.93);
  box-shadow: 0 0 0 4px rgba(194,106,74,0.35);
}
.v2-drum-frame.released { transform: scale(1.05); }
.v2-drum-frame.on-fire {
  box-shadow: 0 0 0 4px rgba(194,106,74,0.55), 0 0 20px rgba(194,106,74,0.3);
  border-color: #c26a4a;
}

/* Nouns-style corner blocks */
.v2-drum-corner {
  position: absolute;
  width: 10px;
  height: 10px;
}
.v2-drum-corner-tl { top: -2px; left: -2px; background: #c26a4a; }
.v2-drum-corner-tr { top: -2px; right: -2px; background: var(--pc-ink); }
.v2-drum-corner-bl { bottom: -2px; left: -2px; background: var(--pc-ink); }
.v2-drum-corner-br { bottom: -2px; right: -2px; background: #c26a4a; }

.v2-drum-img {
  width: 200px;
  height: 200px;
  display: block;
  image-rendering: pixelated;
  transition: transform 80ms ease-out, opacity 180ms ease-out;
}
@media (max-width: 400px) {
  .v2-drum-img { width: 160px; height: 160px; }
  .v2-stage { width: 280px; height: 280px; }
}

.v2-drum-tap-label {
  margin-top: 8px;
  font-size: 8px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--pc-ink-muted);
  text-align: center;
  transition: color 120ms;
}
.v2-drum-tap-label.hot { color: #c26a4a; font-weight: 700; }

/* Ripples */
.v2-ripples {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 10;
  overflow: visible;
}

/* Confetti */
.v2-confetti {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 50;
  overflow: hidden;
}
@keyframes v2-ripple {
  0%   { opacity: 1;   transform: translate(-50%, -50%) scale(1);   }
  100% { opacity: 0;   transform: translate(-50%, -280%) scale(1.6); }
}
@keyframes confetti-fly {
  0%   { opacity: 1; transform: translate(0, 0) rotate(0deg) scale(1); }
  100% { opacity: 0; transform: translate(var(--tx), var(--ty)) rotate(var(--rot)) scale(0.4); }
}
@keyframes v2-spin-fast {
  0%   { transform: rotate(0deg) scale(1); }
  50%  { transform: rotate(180deg) scale(1.15); }
  100% { transform: rotate(360deg) scale(1); }
}

/* ── Voice strip ───────────────────────────────────── */
.v2-voice-strip {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  margin-bottom: 12px;
  border: 1.5px solid var(--pc-rule);
  border-radius: 999px;
  background: #fafaf9;
  font-size: 9px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--pc-ink-muted);
  flex-wrap: wrap;
}
.v2-voice-glyph { color: var(--pc-ink); font-size: 11px; letter-spacing: 0; }
.v2-voice-prefix { color: var(--pc-ink-muted); }
.v2-voice-note {
  font-family: var(--pc-font-mono);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.05em;
  color: var(--pc-ink);
  padding: 2px 10px;
  border-radius: 999px;
  background: #fff;
  border: 1.5px solid var(--pc-ink);
  min-width: 32px;
  text-align: center;
  transition: background 200ms, color 200ms, transform 200ms;
}
.v2-voice-note.note-C { background: #fef3c7; border-color: #f59e0b; }
