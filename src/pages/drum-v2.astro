<script>
  // ══════════════════════════════════════════════════════════════════
  // Drum Room v2 — full client
  // Shared localStorage keys with v1 so progress carries over.
  // ══════════════════════════════════════════════════════════════════

  // ── Session ID ───────────────────────────────────────────────────
  const SESSION_KEY = 'pc:reactSessionId';
  function getSessionId(): string {
    try {
      let id = localStorage.getItem(SESSION_KEY);
      if (!id) {
        id = (crypto as any).randomUUID?.() ??
             `s-${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
        localStorage.setItem(SESSION_KEY, id);
      }
      return id;
    } catch {
      return `s-${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
    }
  }
  const sessionId = getSessionId();

  // ── Element refs ─────────────────────────────────────────────────
  const drumBtn     = document.getElementById('v2-drum-btn') as HTMLButtonElement | null;
  const drumImg     = document.getElementById('v2-drum-img') as HTMLImageElement | null;
  const drumFrame   = document.getElementById('v2-drum-frame');
  const drumLabel   = document.getElementById('v2-drum-label');
  const ripplesEl   = document.getElementById('v2-ripples');
  const confettiEl  = document.getElementById('v2-confetti');
  const globalEl    = document.getElementById('v2-global');
  const activeLbl   = document.getElementById('v2-active-label');
  const yourEl      = document.getElementById('v2-your');
  const comboEl     = document.getElementById('v2-combo');
  const comboCard   = document.getElementById('v2-combo-card');
  const bpmEl       = document.getElementById('v2-bpm');
  const jammersEl   = document.getElementById('v2-jammers');
  const tierLabel   = document.getElementById('v2-tier-label');
  const tierProg    = document.getElementById('v2-tier-progress');
  const tierFill    = document.getElementById('v2-tier-fill') as HTMLElement | null;
  const partyBanner = document.getElementById('v2-party-banner');
  const partySub    = document.getElementById('v2-party-sub');
  const toastEl     = document.getElementById('v2-toast');
  const toastLabel  = document.getElementById('v2-toast-label');
  const toastTitle  = document.getElementById('v2-toast-title');
  const tokDrums    = document.getElementById('v2-tok-drums');
  const tokAmount   = document.getElementById('v2-tok-amount');
  const tokFill     = document.getElementById('v2-tok-fill') as HTMLElement | null;
  const tokNext     = document.getElementById('v2-tok-next');
  const orbitEl     = document.getElementById('v2-orbit');
  const actFeed     = document.getElementById('v2-activity-feed');
  const actRate     = document.getElementById('v2-activity-rate');
  const presentStrip = document.getElementById('v2-present-strip');
  const roomCount   = document.getElementById('v2-room-count');
  const nameInput   = document.getElementById('v2-name-input') as HTMLInputElement | null;
  const nameNoun    = document.getElementById('v2-name-noun');
  const shareBtn    = document.getElementById('v2-share-btn');
  const shareHint   = document.getElementById('v2-share-hint');

  // ── Local state ──────────────────────────────────────────────────
  const LOCAL_KEY   = 'pc:drumLocalCount';
  const UNLOCKS_KEY = 'pc:drumUnlocks';
  const BADGES_KEY  = 'pc:drumBadgesV1';
  const NAME_KEY    = 'pc:drumName';

  function loadLocal(): number { try { return Number(localStorage.getItem(LOCAL_KEY)) || 0; } catch { return 0; } }
  function saveLocal(n: number) { try { localStorage.setItem(LOCAL_KEY, String(n)); } catch {} }
  let localCount = loadLocal();

  // ── Tiers (shared with v1) ───────────────────────────────────────
  const TIERS = [
    { at: 10,     label: 'Novice',       next: 100,     noun:  42 },
    { at: 100,    label: 'Journeyman',   next: 1000,    noun: 201 },
    { at: 1000,   label: 'Master',       next: 10000,   noun: 444 },
    { at: 10000,  label: 'Grand Master', next: 100000,  noun: 777 },
    { at: 100000, label: 'Mythic',       next: 1000000, noun: 999 },
  ];

  function tierForCount(n: number) {
    let current = { at: 0, label: 'Newcomer', next: 10, noun: 42 };
    for (const t of TIERS) {
      if (n >= t.at) current = { at: t.at, label: t.label, next: t.next, noun: t.noun };
    }
    return current;
  }

  function renderTier(n: number) {
    const t = tierForCount(n);
    if (tierLabel)  tierLabel.textContent = t.label;
    const displayNext = TIERS.find(x => x.at > n)?.at ?? t.next;
    if (tierProg)  tierProg.textContent = `${Math.min(n, displayNext).toLocaleString()} / ${displayNext.toLocaleString()}`;
    if (tierFill)  tierFill.style.width = `${Math.min(100, (n / displayNext) * 100)}%`;
  }

  let lastDrumNoun = tierForCount(localCount).noun;
  function updateDrumNoun(n: number) {
    const wanted = tierForCount(n).noun;
    if (wanted === lastDrumNoun || !drumImg) return;
    lastDrumNoun = wanted;
    drumImg.style.transition = 'opacity 180ms ease-out, transform 180ms ease-out';
    drumImg.style.opacity = '0';
    drumImg.style.transform = 'scale(0.85)';
    setTimeout(() => {
      drumImg.src = `https://noun.pics/${wanted}.svg`;
      drumImg.style.opacity = '1';
      drumImg.style.transform = 'scale(1.1)';
      setTimeout(() => { drumImg.style.transform = ''; drumImg.style.transition = ''; }, 160);
    }, 180);
  }

  // ── DRUM Token display ───────────────────────────────────────────
  const DRUMS_PER_TOKEN = 100;
  function updateToken(n: number) {
    const tokens = n / DRUMS_PER_TOKEN;
    const whole  = Math.floor(tokens);
    const frac   = tokens - whole;
    if (tokDrums)  tokDrums.textContent  = n.toLocaleString();
    if (tokAmount) tokAmount.textContent  = tokens.toFixed(2);
    if (tokFill)   tokFill.style.width   = `${frac * 100}%`;
    if (tokNext) {
      const remaining = DRUMS_PER_TOKEN - (n % DRUMS_PER_TOKEN);
      tokNext.textContent = remaining === DRUMS_PER_TOKEN ? '100 to go' : `${remaining} to go`;
    }
  }

  // ══════════════════════════════════════════════════════════════
  // AUDIO — pentatonic collaborative synth.
  // Each session is hashed to a pentatonic step (C/D/E/G/A in C
  // major). Any combination of these notes is harmonically valid,
  // so when two players overlap, they always sound musical even
  // with poll-induced lag. Combos layer chord tones on top of the
  // root: x2 adds the 5th, x3 adds the 3rd, x5 adds octave + 12th.
  // ══════════════════════════════════════════════════════════════
  const PENTA_NAMES  = ['C', 'D', 'E', 'G', 'A'] as const;
  const PENTA_RATIOS = [1, 9/8, 5/4, 3/2, 5/3];      // just-intonation ratios in C
  const REGISTER_BASE: Record<string, number> = {
    bass: 130.81,  // C3
    mid:  261.63,  // C4
    high: 523.25,  // C5
  };

  function simpleHash(s: string): number {
    let h = 0;
    for (let i = 0; i < s.length; i++) {
      h = ((h << 5) - h) + s.charCodeAt(i);
      h = h | 0;
    }
    return Math.abs(h);
  }
  function voiceStepFor(idLike: string): number {
    if (!idLike) return 0;
    return simpleHash(idLike) % 5;
  }
  const myVoiceStep = voiceStepFor(sessionId);
  const myVoiceName = PENTA_NAMES[myVoiceStep];

  let audioCtx: AudioContext | null = null;
  function getCtx(): AudioContext | null {
    if (audioCtx) return audioCtx;
    try {
      const Ctx = (window.AudioContext || (window as any).webkitAudioContext);
      if (!Ctx) return null;
      audioCtx = new Ctx({ latencyHint: 'interactive' });
    } catch { audioCtx = null; }
    return audioCtx;
  }
  const primeAudio = () => { const c = getCtx(); if (c?.state === 'suspended') c.resume().catch(() => {}); };
  ['pointerdown','keydown','touchstart','scroll'].forEach(e => document.addEventListener(e as any, primeAudio, { once: true, passive: true, capture: true }));

  // Single-note mallet voice — sine fundamental + soft octave for warmth.
  function playNote(freq: number, gain: number, decay: number, type: OscillatorType = 'sine', whenOffset = 0) {
    const ctx = getCtx();
    if (!ctx) return;
    if (ctx.state === 'suspended') ctx.resume().catch(() => {});
    const now = ctx.currentTime + whenOffset;
    const out = ctx.createGain();
    out.connect(ctx.destination);
    out.gain.setValueAtTime(0, now);
    out.gain.linearRampToValueAtTime(gain, now + 0.005);
    out.gain.exponentialRampToValueAtTime(0.001, now + decay);
    const osc = ctx.createOscillator();
    osc.type = type;
    osc.frequency.setValueAtTime(freq, now);
    osc.connect(out);
    osc.start(now); osc.stop(now + decay + 0.05);
    // Octave overtone for warmth (subtle)
    const o2 = ctx.createOscillator();
    o2.type = 'triangle';
    o2.frequency.setValueAtTime(freq * 2, now);
    const g2 = ctx.createGain();
    g2.gain.setValueAtTime(0, now);
    g2.gain.linearRampToValueAtTime(gain * 0.18, now + 0.01);
    g2.gain.exponentialRampToValueAtTime(0.001, now + decay * 0.5);
    o2.connect(g2); g2.connect(out);
    o2.start(now); o2.stop(now + decay * 0.6);
  }

  function playShaker(gain: number) {
    const ctx = getCtx();
    if (!ctx) return;
    if (ctx.state === 'suspended') ctx.resume().catch(() => {});
    const now = ctx.currentTime;
    const out = ctx.createGain();
    out.connect(ctx.destination);
    out.gain.setValueAtTime(0, now);
    out.gain.linearRampToValueAtTime(gain * 0.7, now + 0.005);
    out.gain.exponentialRampToValueAtTime(0.001, now + 0.15);
    const bufSz = Math.floor(ctx.sampleRate * 0.12);
    const buf = ctx.createBuffer(1, bufSz, ctx.sampleRate);
    const data = buf.getChannelData(0);
    for (let i = 0; i < bufSz; i++) data[i] = (Math.random() * 2 - 1) * (1 - i / bufSz);
    const src = ctx.createBufferSource(); src.buffer = buf;
    const bpf = ctx.createBiquadFilter(); bpf.type = 'bandpass'; bpf.frequency.value = 8000; bpf.Q.value = 0.7;
    src.connect(bpf); bpf.connect(out); src.start(now);
  }

  // Top-level voice playback — register × kind × pentatonic step × combo.
  // Skill rewards: comboMult 2 adds 5th, 3 adds 3rd, 5 adds octave + 12th.
  function playVoice(register: string, kind: string, voiceStep: number, comboMult = 1, gain = 0.4) {
    if (kind === 'shaker') {
      playShaker(gain);
      if (comboMult >= 3) setTimeout(() => playShaker(gain * 0.55), 75);
      if (comboMult >= 5) setTimeout(() => playShaker(gain * 0.45), 140);
      return;
    }
    const base = REGISTER_BASE[register] ?? REGISTER_BASE.mid;
    const root = base * PENTA_RATIOS[voiceStep];

    if (kind === 'bell') {
      playNote(root, gain * 0.55, 1.4, 'triangle');
      // Inharmonic overtone for bell shimmer
      playNote(root * 2.76, gain * 0.22, 0.9, 'sine');
    } else {
      // thump — mallet
      playNote(root, gain, 0.5, 'sine');
    }

    // Chord layers — staggered slightly so they read as a roll, not a stab.
    if (comboMult >= 2) playNote(root * 1.5,  gain * 0.42, 0.4, 'sine', 0.025); // perfect 5th
    if (comboMult >= 3) playNote(root * 1.25, gain * 0.36, 0.4, 'sine', 0.05);  // major 3rd
    if (comboMult >= 5) {
      playNote(root * 2,   gain * 0.32, 0.55, 'sine', 0.08);   // octave
      playNote(root * 3,   gain * 0.22, 0.55, 'sine', 0.12);   // 12th
    }
  }

  // Set voice chip UI
  const voiceNoteEl = document.getElementById('v2-voice-note');
  const voiceRegEl  = document.getElementById('v2-voice-reg');
  if (voiceNoteEl) {
    voiceNoteEl.textContent = myVoiceName;
    voiceNoteEl.classList.add(`note-${myVoiceName}`);
  }
  function flashVoiceChip() {
    if (!voiceNoteEl) return;
    voiceNoteEl.classList.add('tapping');
    setTimeout(() => voiceNoteEl.classList.remove('tapping'), 140);
  }

  // ── Ripples ──────────────────────────────────────────────────────
  function spawnRipple(x: number, y: number, label = '+1', color = '#c26a4a') {
    if (!ripplesEl) return;
    const rect = ripplesEl.getBoundingClientRect();
    const el = document.createElement('div');
    el.style.cssText = `
      position:absolute;
      left:${x - rect.left}px;
      top:${y - rect.top}px;
      transform:translate(-50%,-50%);
      color:${color};
      font-family:var(--pc-font-mono),monospace;
      font-weight:700;
      font-size:16px;
      pointer-events:none;
      animation:v2-ripple 900ms cubic-bezier(.2,.8,.3,1) forwards;
    `;
    el.textContent = label;
    ripplesEl.appendChild(el);
    setTimeout(() => el.isConnected && el.remove(), 1000);
  }

  // ── Confetti ─────────────────────────────────────────────────────
  function spawnConfetti(cx: number, cy: number, count = 22) {
    if (!confettiEl) return;
    const pool = ['⌐◨-◨', '⌐◨-◨', '🥁', '⚡', '✨', '🎉', '⌐◨-◨'];
    for (let i = 0; i < count; i++) {
      const el = document.createElement('span');
      const angle = (i / count) * 360 + (Math.random() - 0.5) * 30;
      const dist  = 100 + Math.random() * 140;
      const tx    = Math.cos(angle * Math.PI / 180) * dist;
      const ty    = Math.sin(angle * Math.PI / 180) * dist - 60;
      const rot   = (Math.random() - 0.5) * 900;
      const dur   = 700 + Math.random() * 700;
      el.textContent = pool[Math.floor(Math.random() * pool.length)];
      el.style.cssText = `
        position:fixed;
        left:${cx}px;
        top:${cy}px;
        font-size:${9 + Math.random() * 9}px;
        pointer-events:none;
        --tx:${tx}px;
        --ty:${ty}px;
        --rot:${rot}deg;
        animation:confetti-fly ${dur}ms cubic-bezier(.2,.8,.3,1) forwards;
        z-index:51;
      `;
      confettiEl.appendChild(el);
      setTimeout(() => el.isConnected && el.remove(), dur + 50);
    }
  }

  // ── Rack (drum selector) ─────────────────────────────────────────
  // Each rack entry sets a register (which octave plays your note) and
  // a timbre kind (thump / bell / shaker). Your voice's pentatonic note
  // stays constant — the rack just shifts it up/down or changes color.
  const RACK_DRUMS = [
    { id: 20,  label: 'Low',    register: 'bass', kind: 'thump',  unlockAt: 0 },
    { id: 42,  label: 'Mid',    register: 'mid',  kind: 'thump',  unlockAt: 0 },
    { id: 101, label: 'High',   register: 'high', kind: 'thump',  unlockAt: 0 },
    { id: 333, label: 'Bell',   register: 'high', kind: 'bell',   unlockAt: 10 },
    { id: 555, label: 'Shaker', register: 'mid',  kind: 'shaker', unlockAt: 100 },
  ];
  let activeRackIdx = 1; // start on Mid

  function updateRackLocks(count: number) {
    document.querySelectorAll<HTMLElement>('.v2-rack-btn').forEach((btn) => {
      const unlockAt = Number(btn.dataset.unlockAt ?? 0);
      const lock = btn.querySelector<HTMLElement>('.v2-rack-lock');
      if (unlockAt === 0 || count >= unlockAt) {
        btn.style.opacity = '';
        btn.disabled = false;
        if (lock) lock.style.display = 'none';
      } else {
        btn.style.opacity = '0.45';
        btn.disabled = true;
        if (lock) lock.style.display = '';
      }
    });
  }

  document.querySelectorAll<HTMLElement>('.v2-rack-btn').forEach((btn) => {
    btn.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      const idx = Number(btn.dataset.drumIndex ?? 1);
      if (isNaN(idx) || RACK_DRUMS[idx].unlockAt > localCount) return;
      activeRackIdx = idx;
      document.querySelectorAll('.v2-rack-btn').forEach((b) => {
        b.classList.remove('v2-rack-active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('v2-rack-active');
      btn.setAttribute('aria-pressed', 'true');
      // Preview sound — your note in the new rack's register
      const d = RACK_DRUMS[idx];
      playVoice(d.register, d.kind, myVoiceStep, 1, 0.32);
      flashVoiceChip();
    });
  });

  updateRackLocks(localCount);

  // ── Combo state ──────────────────────────────────────────────────
  const COMBO_WINDOW = 380;
  const COMBO_MULTS  = [1, 2, 3, 5];
  let comboIdx  = 0;
  let lastTapAt = 0;
  const tapTimes: number[] = [];

  function renderCombo() {
    const m = COMBO_MULTS[comboIdx];
    if (comboEl)  comboEl.textContent = `×${m}`;
    if (comboCard) {
      if (m >= 3) {
        comboCard.classList.add('hot');
        if (drumFrame) drumFrame.classList.add('on-fire');
      } else {
        comboCard.classList.remove('hot');
        if (drumFrame) drumFrame.classList.remove('on-fire');
      }
    }
    if (drumLabel) {
      if (m >= 5) { drumLabel.textContent = 'ON FIRE ×5'; drumLabel.classList.add('hot'); }
      else if (m >= 3) { drumLabel.textContent = `COMBO ×${m}!`; drumLabel.classList.add('hot'); }
      else { drumLabel.textContent = m > 1 ? `COMBO ×${m}` : 'TAP'; drumLabel.classList.remove('hot'); }
    }
  }

  function calcBPM(): number {
    if (tapTimes.length < 2) return 0;
    const window = tapTimes.slice(-8);
    const diff = window[window.length - 1] - window[0];
    if (diff <= 0) return 0;
    return Math.round(((window.length - 1) * 60_000) / diff);
  }

  // Idle combo reset
  setInterval(() => {
    if (comboIdx > 0 && Date.now() - lastTapAt > 800) {
      comboIdx = 0;
      renderCombo();
    }
  }, 300);

  // ── Badges ───────────────────────────────────────────────────────
  const earnedBadges = new Set<string>();
  try {
    const raw = localStorage.getItem(BADGES_KEY);
    if (raw) JSON.parse(raw).forEach((k: string) => earnedBadges.add(k));
  } catch {}

  function persistBadges() { try { localStorage.setItem(BADGES_KEY, JSON.stringify([...earnedBadges])); } catch {} }

  function paintBadges() {
    document.querySelectorAll<HTMLElement>('.v2-badge').forEach((el) => {
      const key = el.dataset.badge;
      if (!key) return;
      if (earnedBadges.has(key)) { el.classList.remove('locked'); el.classList.add('earned'); }
    });
  }

  let toastTimer: number | null = null;
  function showToast(label: string, title: string) {
    if (!toastEl) return;
    if (toastLabel) toastLabel.textContent = label;
    if (toastTitle) toastTitle.textContent = title;
    toastEl.hidden = false;
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => { toastEl.hidden = true; }, 3000);
  }

  function awardBadge(key: string, toast: string) {
    if (earnedBadges.has(key)) return;
    earnedBadges.add(key);
    persistBadges();
    paintBadges();
    const el = document.querySelector<HTMLElement>(`.v2-badge[data-badge="${key}"]`);
    if (el) { el.classList.add('just-earned'); setTimeout(() => el.classList.remove('just-earned'), 700); }
    showToast('unlocked', toast);
    try { navigator.vibrate?.(20); } catch {}
  }

  function checkCountBadges(n: number) {
    if (n >= 1)    awardBadge('first',      'First tap 🥁');
    if (n >= 10)   awardBadge('novice',     'Novice · 10 drums 🎯');
    if (n >= 100)  awardBadge('journeyman', 'Journeyman · 100 drums 🥋');
    if (n >= 1000) awardBadge('master',     'Master · 1,000 drums 👑');
  }
  function checkComboBadges(m: number) {
    if (m >= 3) awardBadge('combo-3', 'Combo ×3 · on fire 🔥');
    if (m >= 5) awardBadge('combo-5', 'Combo ×5 · flow state ✨');
  }
  function checkPaceBadges(bpm: number) {
    if (bpm >= 120) awardBadge('pace-120', 'Pace ≥ 120 BPM ⚡');
    if (bpm >= 240) awardBadge('pace-240', 'Pace ≥ 240 BPM 🚀');
  }

  paintBadges();
  checkCountBadges(localCount);

  // ── Milestones (shared with v1) ───────────────────────────────────
  const unlocked = new Set<string>();
  try {
    const raw = localStorage.getItem(UNLOCKS_KEY);
    if (raw) JSON.parse(raw).forEach((k: string) => unlocked.add(k));
  } catch {}
  function saveUnlocks() { try { localStorage.setItem(UNLOCKS_KEY, JSON.stringify([...unlocked])); } catch {} }

  function checkMilestones(n: number) {
    const milestone_thresholds = [10, 100, 1000, 10000, 100000];
    for (const at of milestone_thresholds) {
      const key = `personal-${at}`;
      if (n >= at && !unlocked.has(key)) {
        unlocked.add(key);
        saveUnlocks();
        // Confetti burst from drum center
        if (drumBtn) {
          const r = drumBtn.getBoundingClientRect();
          spawnConfetti(r.left + r.width / 2, r.top + r.height / 2, 28);
        }
        // Big spin on the drum
        if (drumImg) {
          drumImg.style.transition = 'transform 600ms cubic-bezier(.4,0,.2,1)';
          drumImg.style.transform = 'rotate(360deg) scale(1.15)';
          setTimeout(() => { if (drumImg) { drumImg.style.transform = ''; drumImg.style.transition = ''; } }, 620);
        }
      }
    }
  }

  renderTier(localCount);
  updateToken(localCount);
  if (drumImg && localCount > 0) {
    const n = tierForCount(localCount).noun;
    if (n !== 42) { drumImg.src = `https://noun.pics/${n}.svg`; lastDrumNoun = n; }
  }

  // ── Server sync ──────────────────────────────────────────────────
  let pendingDelta = 0;
  let flushTimer: number | null = null;

  async function flushDelta() {
    if (pendingDelta <= 0) return;
    const delta = pendingDelta;
    pendingDelta = 0;
    if (flushTimer) { clearTimeout(flushTimer); flushTimer = null; }
    try {
      const res = await fetch('/api/drum', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ delta, sessionId }),
        keepalive: true,
      });
      if (!res.ok) throw new Error(String(res.status));
      const data = await res.json();
      if (globalEl && typeof data.globalTotal === 'number') {
        globalEl.textContent = Number(data.globalTotal).toLocaleString();
      }
      if (typeof data.yourTotal === 'number' && data.yourTotal > localCount) {
        localCount = data.yourTotal;
        saveLocal(localCount);
        renderYour();
        renderTier(localCount);
        updateToken(localCount);
      }
    } catch { pendingDelta += delta; }
  }

  function scheduleFlush() {
    if (flushTimer) clearTimeout(flushTimer);
    flushTimer = window.setTimeout(flushDelta, 2500);
  }

  async function refreshGlobal() {
    try {
      const r = await fetch(`/api/drum?sessionId=${encodeURIComponent(sessionId)}`);
      if (!r.ok) return;
      const data = await r.json();
      if (globalEl && typeof data.globalTotal === 'number') {
        globalEl.textContent = Number(data.globalTotal).toLocaleString();
      }
      if (typeof data.yourTotal === 'number' && data.yourTotal > localCount) {
        localCount = data.yourTotal;
        saveLocal(localCount);
        renderYour();
        renderTier(localCount);
        updateToken(localCount);
      }
    } catch {}
  }

  function renderYour() {
    if (yourEl) yourEl.textContent = localCount.toLocaleString();
  }
  renderYour();
  refreshGlobal();
  setInterval(() => { if (document.visibilityState === 'visible') refreshGlobal(); }, 4000);

  // ── Active drummer tracking + party mode ─────────────────────────
  const remoteActive = new Map<string, number>(); // pid → lastSeen

  function activeCount(): number {
    const now = Date.now();
    for (const [pid, t] of remoteActive) if (now - t > 10_000) remoteActive.delete(pid);
    return remoteActive.size + (Date.now() - lastTapAt < 10_000 ? 1 : 0);
  }

  let partyMode = false;
  let friendsSeen = 0;

  function renderActive() {
    const count = activeCount();
    if (jammersEl) jammersEl.textContent = String(count);
    if (activeLbl) activeLbl.textContent = count <= 1 ? 'live · just you' : `live · ${count} jammers`;
    // Party mode
    if (count >= 3 && !partyMode) {
      partyMode = true;
      if (partyBanner) { partyBanner.hidden = false; if (partySub) partySub.textContent = `${count} drummers live`; }
    } else if (count < 3 && partyMode) {
      partyMode = false;
      if (partyBanner) partyBanner.hidden = true;
    }
    // Social badge
    if (friendsSeen >= 3) awardBadge('social', '5+ friends drummed with you ⌐◨-◨');
  }

  setInterval(() => { if (document.visibilityState === 'visible') renderActive(); }, 2000);

  // ── Orbit (friend nouns around the drum) ─────────────────────────
  let orbitNouns: Array<{ nounId: number; pid: string }> = [];

  function updateOrbit() {
    if (!orbitEl) return;
    orbitEl.innerHTML = '';
    const friends = orbitNouns.slice(0, 6);
    if (friends.length === 0) return;
    const stage = document.getElementById('v2-stage');
    const stageW = stage ? stage.offsetWidth : 340;
    const cx = stageW / 2;
    const cy = stageW / 2;
    const r  = Math.min(stageW / 2 - 40, 155);
    friends.forEach((f, i) => {
      const angle = (i / friends.length) * 2 * Math.PI - Math.PI / 2;
      const x = cx + Math.cos(angle) * r;
      const y = cy + Math.sin(angle) * r;
      const el = document.createElement('div');
      el.className = 'v2-orbit-friend';
      el.style.left = `${x}px`;
      el.style.top  = `${y}px`;
      const img = document.createElement('img');
      img.src = `https://noun.pics/${f.nounId}.svg`;
      img.alt = '';
      img.width = 44;
      img.height = 44;
      img.style.imageRendering = 'pixelated';
      el.appendChild(img);
      orbitEl.appendChild(el);
    });
  }

  // ── Presence ─────────────────────────────────────────────────────
  function esc(s: string) { return String(s).replace(/"/g, '&quot;').replace(/</g, '&lt;'); }

  async function refreshPresence() {
    try {
      const r = await fetch('/api/visit');
      if (!r.ok) return;
      const data = await r.json();
      const present  = Array.isArray(data.present) ? data.present : [];
      const yourPid  = typeof data.yourPid === 'string' ? data.yourPid : null;
      const humans   = present.filter((p: any) => p.type === 'human');
      const others   = yourPid ? humans.filter((p: any) => p.pid !== yourPid) : humans;
      if (roomCount) roomCount.textContent = String(humans.length || 1);

      // Update orbit with friend nouns
      orbitNouns = others.slice(0, 6).map((p: any) => ({ nounId: Number(p.nounId) || 42, pid: p.pid || '' }));
      updateOrbit();
      friendsSeen = Math.max(friendsSeen, others.length);

      // Presence strip
      if (presentStrip) {
        const shown = others.slice(0, 8);
        if (shown.length === 0) {
          presentStrip.innerHTML = '<span style="font-size:8px;letter-spacing:.14em;text-transform:uppercase;color:var(--pc-ink-muted);">just you right now</span>';
        } else {
          presentStrip.innerHTML = shown.map((p: any) => `
            <img
              src="https://noun.pics/${Number(p.nounId)||42}.svg"
              alt="" aria-hidden="true" width="36" height="36"
              style="image-rendering:pixelated;border-radius:4px;border:1.5px solid var(--pc-rule);"
              loading="lazy"
            />
          `).join('');
        }
      }

      // Name noun
      if (nameNoun) {
        const nounId = yourPid
          ? (humans.find((p: any) => p.pid === yourPid)?.nounId ?? 42)
          : 42;
        nameNoun.textContent = `#${nounId}`;
      }
    } catch {}
  }
  refreshPresence();
  setInterval(() => { if (document.visibilityState === 'visible') refreshPresence(); }, 8000);

  // ── Activity feed ─────────────────────────────────────────────────
  const TAP_HISTORY: number[] = []; // timestamps for rate calc
  function logActivity(label: string, isYou = false) {
    if (!actFeed) return;
    const empty = actFeed.querySelector('.v2-activity-empty');
    if (empty) empty.remove();
    const li = document.createElement('li');
    li.className = 'v2-activity-item';
    li.innerHTML = `
      <span>${new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false })}</span>
      <span class="${isYou ? 'v2-activity-you' : ''}">${label}</span>
    `;
    actFeed.prepend(li);
    // Keep last 20
    const items = actFeed.querySelectorAll('li');
    if (items.length > 20) items[items.length - 1].remove();

    // Rate
    const now = Date.now();
    TAP_HISTORY.push(now);
    const minute_ago = now - 60_000;
    while (TAP_HISTORY[0] < minute_ago) TAP_HISTORY.shift();
    if (actRate) actRate.textContent = String(TAP_HISTORY.length);
  }

  // ── Sound polling (remote drums) ─────────────────────────────────
  let lastSoundT = Date.now();
  let ownPid = '';
  (async () => {
    try {
      const buf = new TextEncoder().encode(sessionId);
      const hash = await crypto.subtle.digest('SHA-256', buf);
      ownPid = Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2,'0')).join('').slice(0,10);
    } catch {}
  })();

  async function pollSounds() {
    try {
      const r = await fetch(`/api/sounds?since=${lastSoundT}`);
      if (!r.ok) return;
      const data = await r.json();
      if (typeof data.now === 'number') lastSoundT = data.now;
      const events = Array.isArray(data.events) ? data.events : [];
      for (const ev of events) {
        if (ev.pid === ownPid || ev.type !== 'drum') continue;
        if (ev.pid) remoteActive.set(ev.pid, Date.now());
        if (!drumBtn) continue;
        const rect = drumBtn.getBoundingClientRect();
        const angle = Math.random() * Math.PI * 2;
        const rad   = 90 + Math.random() * 40;
        const x = rect.left + rect.width / 2 + Math.cos(angle) * rad;
        const y = rect.top + rect.height / 2 + Math.sin(angle) * rad;
        spawnRipple(x, y, '+1', '#8c7a5e');

        // Remote player's pentatonic step — derived from their pid so
        // the same person always plays the same note. Combo (seed) drives
        // chord layers. Played in mid register at lower gain so it sits
        // under your own voice.
        const theirStep = voiceStepFor(ev.pid || '');
        const theirMult = Number(ev.seed) || 1;
        const theirNote = PENTA_NAMES[theirStep];
        playVoice('mid', 'thump', theirStep, theirMult, 0.22);
        logActivity(`⌐◨-◨ ${theirNote}${theirMult > 1 ? ' ×' + theirMult : ''}`, false);
      }
      renderActive();
    } catch {}
  }
  // Tighter 300ms poll — 5× faster than v1, brings remote echo from
  // ~800ms-1.6s down to ~300-600ms. Pentatonic voicing makes any latency
  // sound musical instead of cluttered.
  setInterval(() => { if (document.visibilityState === 'visible') pollSounds(); }, 300);

  // ── The tap ───────────────────────────────────────────────────────
  function performTap(x: number, y: number) {
    const now = Date.now();
    if (now - lastTapAt < COMBO_WINDOW && lastTapAt > 0) {
      comboIdx = Math.min(COMBO_MULTS.length - 1, comboIdx + 1);
    }
    lastTapAt = now;
    tapTimes.push(now);
    if (tapTimes.length > 32) tapTimes.shift();
    const mult = COMBO_MULTS[comboIdx];

    localCount += mult;
    saveLocal(localCount);
    renderYour();
    renderTier(localCount);
    updateToken(localCount);
    updateDrumNoun(localCount);
    updateRackLocks(localCount);
    renderCombo();
    checkMilestones(localCount);
    checkCountBadges(localCount);
    checkComboBadges(mult);
    const bpm = calcBPM();
    if (bpmEl) bpmEl.textContent = bpm > 0 ? String(bpm) : '—';
    if (bpm > 0) checkPaceBadges(bpm);

    // Sound — your pentatonic voice + chord layers from combo
    const d = RACK_DRUMS[activeRackIdx];
    playVoice(d.register, d.kind, myVoiceStep, mult, 0.42);
    flashVoiceChip();

    // Haptic
    try { navigator.vibrate?.(mult >= 3 ? 20 : 10); } catch {}

    // Visual bounce
    if (drumFrame) {
      drumFrame.classList.add('tapped');
      setTimeout(() => {
        drumFrame?.classList.remove('tapped');
        drumFrame?.classList.add('released');
        setTimeout(() => drumFrame?.classList.remove('released'), 70);
      }, 55);
    }

    // Combo x5 spin
    if (mult >= 5 && drumImg) {
      drumImg.style.animation = 'v2-spin-fast 500ms cubic-bezier(.4,0,.2,1)';
      setTimeout(() => { if (drumImg) drumImg.style.animation = ''; }, 520);
    }

    // +N ripple
    spawnRipple(x, y, `+${mult}`, mult >= 3 ? '#ef6c3d' : '#c26a4a');

    // Activity
    logActivity(mult > 1 ? `you · ×${mult} combo` : 'you tapped', true);

    // Broadcast
    fetch('/api/sounds', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type: 'drum', seed: mult, sessionId }),
      keepalive: true,
    }).catch(() => {});

    pendingDelta += mult;
    if (pendingDelta >= 10) flushDelta();
    else scheduleFlush();
  }

  if (drumBtn) {
    drumBtn.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      const rect = drumBtn.getBoundingClientRect();
      performTap(e.clientX || rect.left + rect.width / 2, e.clientY || rect.top + rect.height / 2);
    });
  }

  document.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement;
    if (target?.tagName === 'INPUT' || target?.tagName === 'TEXTAREA' || target?.isContentEditable) return;
    if (e.code !== 'Space' && e.code !== 'Enter') return;
    if (!drumBtn) return;
    const rect = drumBtn.getBoundingClientRect();
    if (rect.bottom < 0 || rect.top > window.innerHeight) return;
    e.preventDefault();
    performTap(rect.left + rect.width / 2, rect.top + rect.height / 2);
  });

  // ── Name input ────────────────────────────────────────────────────
  if (nameInput) {
    try { nameInput.value = localStorage.getItem(NAME_KEY) || ''; } catch {}
    nameInput.addEventListener('input', () => {
      try { localStorage.setItem(NAME_KEY, nameInput.value.trim()); } catch {}
    });
  }

  // ── Share ─────────────────────────────────────────────────────────
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const url = window.location.href;
      try {
        await navigator.share({ title: 'PointCast Drum Room', url });
      } catch {
        try { await navigator.clipboard.writeText(url); if (shareHint) shareHint.textContent = 'link copied!'; setTimeout(() => { if (shareHint) shareHint.textContent = 'share the drum room'; }, 2500); } catch {}
      }
    });
  }

  // ══════════════════════════════════════════════════════════════════
  // WALLET — read pc:wallet-active from localStorage and listen for
  // pc:wallet-change events fired by WalletChip. Keeps the wallet
  // strip synced. Also flips the DRUM claim button copy when wallet
  // is connected (hint: "Phase C will airdrop here").
  // ══════════════════════════════════════════════════════════════════
  type Wallet = { chain: string; address: string; provider: string };
  function loadActiveWallet(): Wallet | null {
    try {
      const raw = localStorage.getItem('pc:wallets');
      const list: Wallet[] = raw ? JSON.parse(raw) : [];
      if (!Array.isArray(list) || list.length === 0) return null;
      const active = localStorage.getItem('pc:wallet-active');
      return list.find(w => w.address === active) || list[list.length - 1] || null;
    } catch { return null; }
  }

  const walletStripEl = document.getElementById('v2-wallet-strip');
  const walletAddrEl  = document.getElementById('v2-wallet-addr');
  const walletProvEl  = document.getElementById('v2-wallet-prov');
  const walletDiscBtn = document.getElementById('v2-wallet-disc-btn');
  const claimBtn      = document.getElementById('v2-claim-btn');
  const claimPill     = document.getElementById('v2-claim-pill');

  function shortAddr(a: string) {
    return a && a.length > 12 ? `${a.slice(0, 6)}…${a.slice(-4)}` : a;
  }

  function renderWallet() {
    const w = loadActiveWallet();
    if (!walletStripEl) return;
    if (w) {
      walletStripEl.hidden = false;
      if (walletAddrEl) walletAddrEl.textContent = shortAddr(w.address);
      if (walletProvEl) walletProvEl.textContent = w.provider;
      if (claimPill) claimPill.textContent = 'PHASE C → YOU';
    } else {
      walletStripEl.hidden = true;
      if (claimPill) claimPill.textContent = 'Phase C';
    }
  }
  renderWallet();
  window.addEventListener('pc:wallet-change', () => { renderWallet(); maybeBindWallet(); });
  window.addEventListener('storage', (e) => {
    if (e.key === 'pc:wallets' || e.key === 'pc:wallet-active') renderWallet();
  });

  // Auto-bind the wallet to this drum session via /api/drum/identify so
  // the leaderboard + Phase C claim can find it server-side. Idempotent
  // — sends only when address changes. Runs in 'soft' mode (no Beacon
  // signature today; the endpoint accepts that and stores mode='soft'),
  // upgrade path documented in the endpoint header.
  let lastBoundAddress = '';
  async function maybeBindWallet() {
    const w = loadActiveWallet();
    if (!w || w.address === lastBoundAddress) return;
    const timestamp = Math.floor(Date.now() / 1000);
    const payload = `drum:bind:${sessionId}:${timestamp}`;
    try {
      const r = await fetch('/api/drum/identify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          sessionId,
          address: w.address,
          timestamp,
          signature: '', // soft bind — endpoint accepts empty signature
          payload,
        }),
        keepalive: true,
      });
      if (r.ok) lastBoundAddress = w.address;
    } catch { /* non-fatal — leaderboard still reads from localStorage */ }
  }
  // Bind on first paint if wallet was already connected from a prior session
  maybeBindWallet();

  if (walletDiscBtn) {
    walletDiscBtn.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('pc:open-wallet-menu'));
    });
  }

  // ══════════════════════════════════════════════════════════════════
  // LEADERBOARD — /api/drum/top returns top 10 by all-time count.
  // Self-rank ribbon shows when you're not in the top 10.
  // ══════════════════════════════════════════════════════════════════
  const lbList     = document.getElementById('v2-lb-list');
  const lbLive     = document.getElementById('v2-lb-live');
  const lbSelf     = document.getElementById('v2-lb-self');
  const lbSelfRank = document.getElementById('v2-lb-self-rank');
  const lbSelfCnt  = document.getElementById('v2-lb-self-count');

  async function refreshLeaderboard() {
    if (!lbList) return;
    try {
      const r = await fetch('/api/drum/top');
      if (!r.ok) return;
      const data = await r.json();
      const entries: Array<{ rank: number; hash: string; nounId: number; count: number }> =
        Array.isArray(data?.entries) ? data.entries : [];

      const myShortHash = ownPid ? ownPid.slice(0, 8) : '';
      const wallet = loadActiveWallet();

      if (entries.length === 0) {
        lbList.innerHTML = '<li class="v2-lb-empty">be first → tap to enter the leaderboard</li>';
        if (lbSelf) lbSelf.hidden = true;
      } else {
        lbList.innerHTML = entries.map((e) => {
          const isMe = !!myShortHash && e.hash === myShortHash;
          const rankCls = e.rank <= 3 ? ` rank-${e.rank}` : '';
          const selfCls = isMe ? ' is-self' : '';
          const name = isMe
            ? (wallet ? `you · ${shortAddr(wallet.address)}` : `you · noun #${e.nounId}`)
            : `noun #${e.nounId}`;
          const nameCls = isMe && wallet ? 'v2-lb-name-wallet' : '';
          return `
            <li class="v2-lb-row${rankCls}${selfCls}">
              <span class="v2-lb-rank">#${e.rank}</span>
              <img class="v2-lb-noun" src="https://noun.pics/${e.nounId}.svg" alt="" loading="lazy" />
              <span class="v2-lb-name ${nameCls}">${name}</span>
              <span class="v2-lb-count">${e.count.toLocaleString()}</span>
            </li>
          `;
        }).join('');

        // Self-rank ribbon — only when you're not in the top 10 AND you have drums
        const inTop = !!myShortHash && entries.some((e) => e.hash === myShortHash);
        if (lbSelf) {
          if (!inTop && localCount > 0) {
            lbSelf.hidden = false;
            const minTopCount = entries[entries.length - 1]?.count ?? 0;
            if (lbSelfRank) lbSelfRank.textContent = localCount >= minTopCount ? '· qualifying soon' : '· keep drumming';
            if (lbSelfCnt)  lbSelfCnt.textContent  = localCount.toLocaleString();
          } else {
            lbSelf.hidden = true;
          }
        }
      }
      if (lbLive) lbLive.textContent = 'live';
    } catch {
      if (lbLive) lbLive.textContent = 'offline';
    }
  }
  // Wait briefly for ownPid hash to compute, then fetch.
  setTimeout(refreshLeaderboard, 500);
  setInterval(() => {
    if (document.visibilityState === 'visible') refreshLeaderboard();
  }, 15_000);
</script>

</DrumLayout>
