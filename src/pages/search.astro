---
/**
 * /search — client-side search over every PointCast Block.
 *
 * Ships an index of blocks (id, channel, type, title, dek, timestamp) as
 * JSON baked into the page at build time. The script filters in-place as
 * the visitor types — no network, no fallback, no rate limit.
 *
 * The server also exposes /blocks.json + /archive.json for agents that
 * want to do their own filtering. This page is the human-oriented affordance.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import { getCollection } from 'astro:content';
import { CHANNELS } from '../lib/channels';

const blocks = (await getCollection('blocks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

const polls = (await getCollection('polls', ({ data }) => !data.draft))
  .sort((a, b) => b.data.openedAt.getTime() - a.data.openedAt.getTime());

const products = (await getCollection('products', ({ data }) => !data.draft))
  .sort((a, b) => b.data.addedAt.getTime() - a.data.addedAt.getTime());

// Index shape consumed by the client-side filter. Lightweight — strings
// only, no body. Three document kinds share one result stream so you can
// type "el segundo" and find the block, the poll, and any products that
// match with one query.
type IndexRow = {
  kind: 'BLOCK' | 'POLL' | 'PRODUCT';
  id: string;
  url: string;
  label: string;        // short type/kind chip (channel code, POLL, PROD)
  labelBg: string;
  labelFg: string;
  type: string;         // BLOCK type, POLL purpose, PRODUCT category
  title: string;
  dek: string;
  timestamp: string;
  haystack: string;
};

const blockRows: IndexRow[] = blocks.map((b) => {
  const ch = CHANNELS[b.data.channel];
  return {
    kind: 'BLOCK',
    id: b.data.id,
    url: `/b/${b.data.id}`,
    label: `CH.${ch.code}`,
    labelBg: ch.color50,
    labelFg: ch.color800,
    type: b.data.type,
    title: b.data.title,
    dek: b.data.dek ?? '',
    timestamp: b.data.timestamp.toISOString(),
    haystack: [
      b.data.id,
      b.data.title,
      b.data.dek ?? '',
      b.data.body ?? '',
      ch.code,
      ch.name,
      ch.slug,
      b.data.type,
      b.data.mood ?? '',
      b.data.author,
    ].join(' ').toLowerCase(),
  };
});

const pollRows: IndexRow[] = polls.map((p) => {
  const zeitgeist = p.data.zeitgeist ? 'ZEITGEIST' : '';
  return {
    kind: 'POLL',
    id: p.data.slug,
    url: `/poll/${p.data.slug}`,
    label: 'POLL',
    labelBg: '#f5f0ff',
    labelFg: '#5F3DC4',
    type: (p.data.purpose || 'coordination').toUpperCase(),
    title: p.data.question,
    dek: p.data.dek ?? '',
    timestamp: p.data.openedAt.toISOString(),
    haystack: [
      p.data.slug,
      p.data.question,
      p.data.dek ?? '',
      p.data.purpose,
      zeitgeist,
      p.data.options.map((o) => `${o.label} ${o.hint ?? ''}`).join(' '),
    ].join(' ').toLowerCase(),
  };
});

const productRows: IndexRow[] = products.map((pr) => ({
  kind: 'PRODUCT',
  id: pr.data.slug,
  url: `/products/${pr.data.slug}`,
  label: 'PROD',
  labelBg: '#e6f5ee',
  labelFg: '#0F6E56',
  type: (pr.data.category || 'product').toUpperCase(),
  title: pr.data.name,
  dek: pr.data.dek ?? pr.data.description.slice(0, 140),
  timestamp: pr.data.addedAt.toISOString(),
  haystack: [
    pr.data.slug,
    pr.data.name,
    pr.data.description,
    pr.data.dek ?? '',
    pr.data.category ?? '',
    pr.data.brand,
    (pr.data.effects ?? []).join(' '),
    (pr.data.ingredients ?? []).join(' '),
  ].join(' ').toLowerCase(),
}));

const INDEX: IndexRow[] = [...blockRows, ...pollRows, ...productRows];
const TOTAL_COUNT = INDEX.length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://pointcast.xyz/search',
  name: 'PointCast · search',
  url: 'https://pointcast.xyz/search',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://pointcast.xyz/search?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};
---

<BlockLayout
  title="Search"
  description={`Search every PointCast block, poll, and product by title, channel, option, or id. ${TOTAL_COUNT} items indexed across 3 kinds, fully client-side.`}
  image="/images/og/search.png"
  jsonLd={jsonLd}
>
  <div class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>search</span>
    </nav>

    <header class="hero">
      <p class="kicker">SEARCH · {blocks.length} BLOCKS · {polls.length} POLLS · {products.length} PRODUCTS</p>
      <h1 class="display">Find any block, poll, or product.</h1>
      <p class="dek">
        Client-side search across every title, dek, body, channel code, poll
        option, and product effect. Starts filtering the moment you type.
        Hit enter to open the top result. No network, no rate limit.
      </p>
    </header>

    <form class="form" role="search" id="search-form" autocomplete="off">
      <label class="form__field">
        <span class="sr-only">Search query</span>
        <input
          type="search"
          id="q"
          name="q"
          placeholder="el segundo, zeitgeist, mallorca, CH.FD, POLL, PROD…"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          aria-describedby="count"
        />
      </label>
      <div class="form__filters mono" role="group" aria-label="Filter by kind">
        <button type="button" class="kind-filter kind-filter--active" data-kind="ALL">ALL</button>
        <button type="button" class="kind-filter" data-kind="BLOCK">BLOCKS</button>
        <button type="button" class="kind-filter" data-kind="POLL">POLLS</button>
        <button type="button" class="kind-filter" data-kind="PRODUCT">PRODUCTS</button>
      </div>
      <p class="form__meta mono">
        <span id="count">— of {TOTAL_COUNT}</span>
        <span class="sep" aria-hidden="true">·</span>
        <span>TRY · <button type="button" class="q-hint" data-q="el segundo">el segundo</button>, <button type="button" class="q-hint" data-q="zeitgeist">zeitgeist</button>, <button type="button" class="q-hint" data-q="CH.FD">CH.FD</button></span>
      </p>
    </form>

    <section class="results" id="results" aria-live="polite" aria-label="Search results">
      {/* rendered by the script below */}
    </section>

    <aside class="surfaces">
      <p class="kicker">AGENT SURFACES</p>
      <ul class="surfaces__list">
        <li><a href="/blocks.json"><span class="mono">GET</span> /blocks.json</a></li>
        <li><a href="/api/blocks.jsonl"><span class="mono">GET</span> /api/blocks.jsonl</a></li>
        <li><a href="/api/soundtracks.jsonl"><span class="mono">GET</span> /api/soundtracks.jsonl</a></li>
        <li><a href="/api/clock/0324.json"><span class="mono">GET</span> /api/clock/0324.json</a></li>
        <li><a href="/archive.json"><span class="mono">GET</span> /archive.json</a></li>
        <li><a href="/for-agents"><span class="mono">SEE</span> /for-agents</a></li>
      </ul>
    </aside>
  </div>

  <script is:inline define:vars={{ INDEX }}>
    (function () {
      const input = document.getElementById('q');
      const countEl = document.getElementById('count');
      const out = document.getElementById('results');
      const form = document.getElementById('search-form');
      const kindButtons = Array.from(document.querySelectorAll('.kind-filter'));

      let activeKind = 'ALL';

      function idLabel(row) {
        if (row.kind === 'BLOCK') return '№' + row.id;
        if (row.kind === 'POLL') return '/' + row.id;
        if (row.kind === 'PRODUCT') return '/' + row.id;
        return row.id;
      }

      function render(list) {
        if (list.length === 0) {
          out.innerHTML = '<p class="empty">No matches. Try a looser query, a channel code like <code>CH.FD</code>, a kind like <code>POLL</code>, or a term like <code>zeitgeist</code>.</p>';
          return;
        }
        out.innerHTML = list.slice(0, 80).map(function (row) {
          const dateShort = new Date(row.timestamp).toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: '2-digit' }).toUpperCase();
          const dekSafe = row.dek ? row.dek.replace(/</g, '&lt;').replace(/>/g, '&gt;') : '';
          const titleSafe = row.title.replace(/</g, '&lt;').replace(/>/g, '&gt;');
          return (
            '<a class="hit hit--' + row.kind.toLowerCase() + '" href="' + row.url + '"'
              + ' style="--row-c50: ' + row.labelBg + '; --row-c8: ' + row.labelFg + '">'
              + '<span class="hit__ch" style="background:' + row.labelBg + '; color:' + row.labelFg + '; border-color:' + row.labelFg + '">' + row.label + '</span>'
              + '<span class="hit__id mono">' + idLabel(row) + '</span>'
              + '<span class="hit__type mono">' + row.type + '</span>'
              + '<span class="hit__date mono">' + dateShort + '</span>'
              + '<span class="hit__title">' + titleSafe + '</span>'
              + (dekSafe ? '<span class="hit__dek">' + dekSafe + '</span>' : '')
            + '</a>'
          );
        }).join('');
      }

      function runQuery(q) {
        const needle = q.trim().toLowerCase();
        const byKind = activeKind === 'ALL' ? INDEX : INDEX.filter(function (r) { return r.kind === activeKind; });
        if (!needle) {
          const top = byKind.slice(0, 24);
          countEl.textContent = 'Showing latest ' + Math.min(24, byKind.length) + ' of ' + byKind.length + (activeKind !== 'ALL' ? ' ' + activeKind.toLowerCase() + 's' : '');
          render(top);
          return;
        }
        const hits = byKind.filter(function (r) {
          return r.haystack.indexOf(needle) !== -1;
        });
        countEl.textContent = hits.length + ' of ' + byKind.length + (activeKind !== 'ALL' ? ' ' + activeKind.toLowerCase() + 's' : '');
        render(hits);
      }

      // Kind filter toggle
      kindButtons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          activeKind = btn.getAttribute('data-kind') || 'ALL';
          kindButtons.forEach(function (b) { b.classList.toggle('kind-filter--active', b === btn); });
          runQuery(input.value || '');
        });
      });

      // Initial state (honor ?q= and ?kind= on load)
      const params = new URLSearchParams(window.location.search);
      const initial = params.get('q') || '';
      const kindParam = (params.get('kind') || 'ALL').toUpperCase();
      if (['ALL','BLOCK','POLL','PRODUCT'].indexOf(kindParam) !== -1) {
        activeKind = kindParam;
        kindButtons.forEach(function (b) { b.classList.toggle('kind-filter--active', (b.getAttribute('data-kind') || 'ALL') === activeKind); });
      }
      if (initial) input.value = initial;
      runQuery(initial);

      input.addEventListener('input', function () {
        runQuery(input.value || '');
      });

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        const first = out.querySelector('.hit');
        if (first) window.location.href = first.getAttribute('href');
      });

      document.querySelectorAll('.q-hint').forEach(function (btn) {
        btn.addEventListener('click', function () {
          input.value = btn.getAttribute('data-q') || '';
          runQuery(input.value);
          input.focus();
        });
      });

      if (window.matchMedia && window.matchMedia('(min-width: 720px)').matches) {
        input.focus();
      }
    })();
  </script>
</BlockLayout>

<style>
  .page {
    max-width: 1040px;
    margin: 0 auto;
    padding: 18px 16px 80px;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .mono {
    font-family: var(--pc-font-mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .kicker {
    font-family: var(--pc-font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin: 0 0 8px;
  }

  .crumb {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
    margin-bottom: 18px;
    display: flex;
    gap: 8px;
  }

  .hero {
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1.5px solid var(--pc-ink);
  }

  .display {
    font-family: var(--pc-font-sans);
    font-size: clamp(2rem, 8vw, 3.2rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.018em;
    margin: 0 0 10px;
    color: var(--pc-ink);
  }

  .dek {
    margin: 0;
    font-size: 15px;
    line-height: 1.5;
    color: var(--pc-ink-soft);
    max-width: 58ch;
  }

  /* ══════ FORM ══════ */
  .form {
    margin-bottom: 20px;
  }

  .form__field input {
    width: 100%;
    padding: 14px 16px;
    font-family: var(--pc-font-sans);
    font-size: 18px;
    border: 1.5px solid var(--pc-ink);
    border-radius: 2px;
    background: #fff;
    color: var(--pc-ink);
  }

  .form__field input:focus {
    outline: 2px solid rgba(24, 95, 165, 0.18);
    border-color: var(--pc-accent);
  }

  .form__filters {
    display: flex;
    gap: 6px;
    margin: 10px 2px 0;
    flex-wrap: wrap;
  }
  .kind-filter {
    appearance: none;
    border: 1px solid var(--pc-rule, #d6d4cd);
    background: transparent;
    color: var(--pc-ink-muted, #5F5E5A);
    padding: 4px 10px;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .kind-filter:hover { color: var(--pc-ink, #12110E); border-color: var(--pc-ink, #12110E); }
  .kind-filter--active {
    background: #12110E;
    color: #FBB040;
    border-color: #12110E;
  }

  .form__meta {
    margin: 8px 2px 0;
    display: flex;
    gap: 10px;
    align-items: center;
    color: var(--pc-ink-muted);
    font-size: 10px;
    flex-wrap: wrap;
  }

  .form__meta .sep {
    color: var(--pc-rule);
  }

  .q-hint {
    border: 0;
    background: none;
    padding: 2px 6px;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-accent);
    cursor: pointer;
    border-bottom: 1px dashed var(--pc-accent);
  }

  .q-hint:hover {
    color: var(--pc-ink);
    border-bottom-color: var(--pc-ink);
  }

  /* ══════ RESULTS ══════ */
  .results {
    display: flex;
    flex-direction: column;
  }

  .empty {
    padding: 32px 20px;
    text-align: center;
    color: var(--pc-ink-muted);
    border: 1px dashed var(--pc-rule);
    border-radius: 2px;
    background: #fafaf8;
    font-size: 15px;
  }

  .empty code {
    font-family: var(--pc-font-mono);
    font-size: 12px;
    padding: 1px 5px;
    background: var(--pc-rule-soft);
    border-radius: 2px;
    color: var(--pc-ink);
  }

  /* .hit rows are injected via innerHTML from the script, so they don't
     carry Astro's scoping attribute. Mark them :global so the styles apply. */
  :global(.hit) {
    display: grid;
    grid-template-columns: auto 56px 54px 64px 1fr;
    grid-template-areas: "ch id type date title";
    gap: 6px 12px;
    padding: 10px 4px;
    border-bottom: 1px dashed var(--pc-rule-soft, #E5E3DE);
    color: var(--pc-ink, #12110E);
    text-decoration: none;
    align-items: center;
    transition: background-color 0.12s, padding-left 0.12s;
  }

  :global(.hit:hover) {
    background: var(--row-c50, #fafaf8);
    padding-left: 8px;
    text-decoration: none;
  }

  :global(.hit__ch) {
    grid-area: ch;
    display: inline-flex;
    padding: 2px 6px;
    border: 1px solid;
    border-radius: 2px;
    font-family: var(--pc-font-mono);
    font-size: 9.5px;
    letter-spacing: 0.14em;
    min-width: 54px;
    justify-content: center;
  }

  :global(.hit__id) { grid-area: id; color: var(--pc-ink-muted, #5F5E5A); font-family: var(--pc-font-mono); font-size: 10.5px; letter-spacing: 0.1em; }
  :global(.hit__type) { grid-area: type; color: var(--pc-ink-muted, #5F5E5A); font-family: var(--pc-font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; }
  :global(.hit__date) { grid-area: date; color: var(--pc-ink-muted, #5F5E5A); font-family: var(--pc-font-mono); font-size: 9.5px; letter-spacing: 0.08em; }

  :global(.hit__title) {
    grid-area: title;
    font-family: var(--pc-font-sans);
    font-size: 15px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--pc-ink, #12110E);
  }

  :global(.hit:hover .hit__title) {
    color: var(--row-c8, var(--pc-accent));
  }

  :global(.hit__dek) {
    display: none;
  }

  @media (max-width: 620px) {
    :global(.hit) {
      grid-template-columns: auto 1fr auto;
      grid-template-areas:
        "ch title id"
        "ch dek dek";
      row-gap: 2px;
    }
    :global(.hit__id) { text-align: right; }
    :global(.hit__type), :global(.hit__date) { display: none; }
    :global(.hit__dek) {
      grid-area: dek;
      display: block;
      font-size: 13px;
      color: var(--pc-ink-soft, #5F5E5A);
      line-height: 1.35;
    }
    :global(.hit__title) { font-size: 14.5px; }
  }

  /* ══════ SURFACES ══════ */
  .surfaces {
    margin-top: 32px;
    padding: 14px;
    border: 1px solid var(--pc-rule);
    border-radius: 2px;
    background: #fafaf8;
  }

  .surfaces__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px 14px;
  }

  .surfaces__list a {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--pc-accent);
    padding: 4px 0;
  }

  .surfaces__list .mono {
    color: var(--pc-ink-muted);
    min-width: 38px;
  }

  /* ══════ RESPONSIVE (surfaces only; .hit responsive lives up top with the :global rules) ══════ */
  @media (min-width: 720px) {
    .surfaces__list {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
