---
/**
 * /resources - a hand-curated field kit for modern computing.
 *
 * Companion to /ai-stack and /stack. This page is broader: converters,
 * open-source utilities, data tools, creative software, and instructionals
 * that help humans and agents work with files instead of fighting them.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import {
  RESOURCE_GROUPS,
  RESOURCE_LAST_CHECKED,
  RESOURCE_PRINCIPLES,
  RESOURCE_RECIPES,
  getAllResources,
} from '../lib/resources';

const allResources = getAllResources();
const featured = allResources.filter((resource) => resource.featured);
const resourceCount = allResources.length;
const groupCount = RESOURCE_GROUPS.length;
const siteBase = Astro.site || new URL('https://pointcast.xyz');

const absoluteUrl = (url: string) => new URL(url, siteBase).href;
const isExternal = (url: string) => /^https?:\/\//.test(url);
const labelize = (value: string) => value.replace(/-/g, ' ');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://pointcast.xyz/resources',
  name: 'PointCast resources',
  description: `A hand-curated resource page for modern computing: ${resourceCount} tools, references, and instructionals across ${groupCount} groups.`,
  url: 'https://pointcast.xyz/resources',
  dateModified: RESOURCE_LAST_CHECKED,
  hasPart: allResources.map((resource) => ({
    '@type': resource.kind === 'course' ? 'LearningResource' : 'SoftwareApplication',
    name: resource.name,
    url: absoluteUrl(resource.url),
    description: resource.oneLiner,
    keywords: resource.tags.join(', '),
  })),
};
---

<BlockLayout
  title="Resources"
  description={`A hand-curated PointCast resource page for modern computing: converters, open-source utilities, instructionals, and references. ${resourceCount} resources across ${groupCount} groups.`}
  jsonLd={jsonLd}
  alternates={[{ type: 'application/json', href: '/resources.json', title: 'Resources (JSON)' }]}
>
  <div class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>resources</span>
    </nav>

    <header class="hero">
      <p class="kicker">RESOURCES · FIELD KIT · CHECKED {RESOURCE_LAST_CHECKED}</p>
      <h1 class="display">Useful things for modern computing.</h1>
      <p class="dek">
        A PointCast working shelf: converters, open-source tools, local-first
        utilities, references, and instructionals that make computers feel
        more like instruments and less like chores.
      </p>
    </header>

    <section class="quick" aria-labelledby="quick-title">
      <header class="section-head">
        <p class="kicker">START HERE</p>
        <h2 id="quick-title">Four fast wins.</h2>
      </header>
      <div class="quick__grid">
        {featured.map((resource) => (
          <article class="quick-card">
            <p class="quick-card__meta mono">{labelize(resource.kind)} · {resource.tags[0]}</p>
            <h3><a href={resource.url} target={isExternal(resource.url) ? '_blank' : undefined} rel={isExternal(resource.url) ? 'noopener' : undefined}>{resource.name}</a></h3>
            <p>{resource.oneLiner}</p>
          </article>
        ))}
      </div>
    </section>

    <nav class="group-nav" aria-label="Resource groups">
      {RESOURCE_GROUPS.map((group) => (
        <a href={`#${group.id}`}>
          <span class="mono">{group.code}</span>
          <span>{group.name}</span>
        </a>
      ))}
    </nav>

    {RESOURCE_GROUPS.map((group) => (
      <section class="group" id={group.id}>
        <header class="group__head">
          <div class="group__titleline">
            <span class="group__code mono">{group.code}</span>
            <h2>{group.name}</h2>
          </div>
          <p>{group.note}</p>
        </header>

        <div class="resource-grid">
          {group.resources.map((resource) => (
            <article class="resource-card">
              <header class="resource-card__head">
                <p class="resource-card__type mono">{labelize(resource.kind)} · {labelize(resource.mode)}</p>
                <h3>
                  <a href={resource.url} target={isExternal(resource.url) ? '_blank' : undefined} rel={isExternal(resource.url) ? 'noopener' : undefined}>
                    {resource.name}
                  </a>
                </h3>
              </header>

              <p class="resource-card__summary">{resource.oneLiner}</p>

              <dl class="resource-card__facts">
                <div>
                  <dt class="mono">USE WHEN</dt>
                  <dd>{resource.useWhen}</dd>
                </div>
                {resource.quickStart && (
                  <div>
                    <dt class="mono">FIRST MOVE</dt>
                    <dd><code>{resource.quickStart}</code></dd>
                  </div>
                )}
                {resource.caution && (
                  <div>
                    <dt class="mono">NOTE</dt>
                    <dd>{resource.caution}</dd>
                  </div>
                )}
              </dl>

              <footer class="resource-card__footer">
                <ul class="tag-list" aria-label={`${resource.name} tags`}>
                  {resource.tags.slice(0, 4).map((tag) => <li>{tag}</li>)}
                </ul>
                <div class="resource-card__links">
                  <a href={resource.url} target={isExternal(resource.url) ? '_blank' : undefined} rel={isExternal(resource.url) ? 'noopener' : undefined}>Open</a>
                  {resource.links?.slice(0, 2).map((link) => (
                    <a href={link.url} target={isExternal(link.url) ? '_blank' : undefined} rel={isExternal(link.url) ? 'noopener' : undefined}>{link.label}</a>
                  ))}
                </div>
              </footer>
            </article>
          ))}
        </div>
      </section>
    ))}

    <section class="recipes" aria-labelledby="recipes-title">
      <header class="section-head">
        <p class="kicker">RECIPES</p>
        <h2 id="recipes-title">Tiny commands worth keeping close.</h2>
      </header>
      <ol class="recipe-list">
        {RESOURCE_RECIPES.map((recipe) => (
          <li>
            <div class="recipe__head">
              <h3>{recipe.title}</h3>
              <span class="mono">{recipe.tool}</span>
            </div>
            <code>{recipe.command}</code>
            <p>{recipe.note}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="principles" aria-labelledby="principles-title">
      <header class="section-head">
        <p class="kicker">PRINCIPLES</p>
        <h2 id="principles-title">How this shelf is picked.</h2>
      </header>
      <ol>
        {RESOURCE_PRINCIPLES.map((principle) => <li>{principle}</li>)}
      </ol>
    </section>

    <aside class="surfaces">
      <p class="kicker">RELATED</p>
      <ul class="surfaces__list">
        <li><a href="/resources.json"><span class="mono">JSON</span> /resources.json</a></li>
        <li><a href="/ai-stack"><span class="mono">AI</span> /ai-stack</a></li>
        <li><a href="/stack"><span class="mono">TECH</span> /stack</a></li>
        <li><a href="/for-agents"><span class="mono">AGENTS</span> /for-agents</a></li>
      </ul>
    </aside>
  </div>
</BlockLayout>

<style>
  .page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 18px 16px 80px;
  }

  .mono {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .kicker {
    margin: 0 0 8px;
    color: var(--pc-ink-muted);
    font-family: var(--pc-font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .crumb {
    display: flex;
    gap: 8px;
    margin-bottom: 18px;
    color: var(--pc-ink-muted);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero {
    margin-bottom: 24px;
    padding-bottom: 18px;
    border-bottom: 1.5px solid var(--pc-ink);
  }

  .display {
    max-width: 850px;
    margin: 0 0 12px;
    color: var(--pc-ink);
    font-family: var(--pc-font-sans);
    font-size: clamp(2.2rem, 8vw, 4.6rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 0.98;
  }

  .dek {
    max-width: 68ch;
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 15.5px;
    line-height: 1.52;
  }

  .section-head {
    margin-bottom: 12px;
  }

  .section-head h2,
  .group__head h2 {
    margin: 0;
    color: var(--pc-ink);
    font-family: var(--pc-font-sans);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0;
  }

  .quick {
    margin-bottom: 20px;
  }

  .quick__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 10px;
  }

  .quick-card {
    min-height: 156px;
    padding: 14px;
    border: 1px solid var(--pc-rule);
    border-left: 3px solid var(--pc-accent);
    background: #fff;
  }

  .quick-card__meta {
    margin: 0 0 10px;
    color: var(--pc-ink-muted);
    font-size: 9.5px;
  }

  .quick-card h3 {
    margin: 0 0 8px;
    font-size: 17px;
    font-weight: 500;
  }

  .quick-card h3 a {
    color: var(--pc-ink);
  }

  .quick-card h3 a:hover {
    color: var(--pc-accent);
    text-decoration: none;
  }

  .quick-card p {
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 13.5px;
    line-height: 1.48;
  }

  .group-nav {
    position: sticky;
    top: 0;
    z-index: 4;
    display: flex;
    gap: 6px;
    margin: 0 0 28px;
    padding: 10px 0;
    overflow-x: auto;
    border-top: 1px solid var(--pc-rule);
    border-bottom: 1px solid var(--pc-rule);
    background: var(--pc-bg);
    scrollbar-width: none;
  }

  .group-nav::-webkit-scrollbar {
    display: none;
  }

  .group-nav a {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 8px;
    min-height: 34px;
    padding: 6px 10px;
    border: 1px solid var(--pc-rule);
    background: #fff;
    color: var(--pc-ink);
    font-size: 12.5px;
  }

  .group-nav a:hover {
    border-color: var(--pc-accent);
    color: var(--pc-accent);
    text-decoration: none;
  }

  .group-nav .mono {
    color: var(--pc-ink-muted);
    font-size: 9.5px;
  }

  .group {
    scroll-margin-top: 70px;
    margin-bottom: 34px;
  }

  .group__head {
    display: grid;
    gap: 6px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1.5px solid var(--pc-ink);
  }

  .group__titleline {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .group__code {
    padding: 2px 7px;
    border: 1px solid var(--pc-accent);
    color: var(--pc-accent);
    font-size: 10px;
  }

  .group__head p {
    max-width: 72ch;
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 14px;
    line-height: 1.48;
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 10px;
  }

  .resource-card {
    display: flex;
    min-height: 300px;
    flex-direction: column;
    padding: 14px;
    border: 1px solid var(--pc-rule);
    background: #fff;
  }

  .resource-card__head {
    margin-bottom: 9px;
  }

  .resource-card__type {
    margin: 0 0 7px;
    color: var(--pc-ink-muted);
    font-size: 9.5px;
  }

  .resource-card h3 {
    margin: 0;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0;
  }

  .resource-card h3 a {
    color: var(--pc-ink);
    overflow-wrap: anywhere;
  }

  .resource-card h3 a:hover {
    color: var(--pc-accent);
    text-decoration: none;
  }

  .resource-card__summary {
    margin: 0 0 12px;
    color: var(--pc-ink);
    font-size: 14px;
    line-height: 1.5;
  }

  .resource-card__facts {
    display: grid;
    gap: 9px;
    margin: 0 0 14px;
  }

  .resource-card__facts div {
    display: grid;
    gap: 3px;
  }

  .resource-card__facts dt {
    color: var(--pc-ink-muted);
    font-size: 9.5px;
  }

  .resource-card__facts dd {
    margin: 0;
    color: var(--pc-ink-soft);
    font-size: 13px;
    line-height: 1.46;
  }

  code {
    padding: 1px 5px;
    border: 1px solid var(--pc-rule-soft);
    background: #f6f5f1;
    color: var(--pc-ink);
    font-family: var(--pc-font-mono);
    font-size: 12px;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }

  .resource-card__footer {
    display: grid;
    gap: 10px;
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px dashed var(--pc-rule-soft);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tag-list li {
    padding: 2px 6px;
    border: 1px solid var(--pc-rule-soft);
    color: var(--pc-ink-muted);
    font-family: var(--pc-font-mono);
    font-size: 9.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .resource-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    font-size: 13px;
  }

  .resource-card__links a {
    color: var(--pc-accent);
  }

  .recipes,
  .principles,
  .surfaces {
    margin-top: 28px;
    padding: 14px;
    border: 1px solid var(--pc-rule);
    background: #fafaf8;
  }

  .recipe-list,
  .principles ol {
    display: grid;
    gap: 10px;
    margin: 0;
    padding-left: 20px;
  }

  .recipe-list li,
  .principles li {
    color: var(--pc-ink-soft);
    font-size: 14px;
    line-height: 1.5;
  }

  .recipe__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 5px;
  }

  .recipe__head h3 {
    margin: 0;
    color: var(--pc-ink);
    font-size: 15px;
    font-weight: 500;
  }

  .recipe__head .mono {
    color: var(--pc-ink-muted);
    font-size: 9.5px;
  }

  .recipe-list code {
    display: block;
    margin: 4px 0;
    padding: 8px 10px;
  }

  .recipe-list p {
    margin: 4px 0 0;
  }

  .principles li::marker,
  .recipe-list li::marker {
    color: var(--pc-accent);
  }

  .surfaces__list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px 14px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .surfaces__list a {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 0;
    color: var(--pc-accent);
    font-size: 14px;
  }

  .surfaces__list .mono {
    min-width: 48px;
    color: var(--pc-ink-muted);
  }

  @media (min-width: 760px) {
    .surfaces__list {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 620px) {
    .page {
      padding-inline: 12px;
    }

    .quick__grid,
    .resource-grid {
      grid-template-columns: 1fr;
    }

    .resource-card {
      min-height: auto;
    }

    .recipe__head {
      display: grid;
      gap: 2px;
    }

    .surfaces__list {
      grid-template-columns: 1fr;
    }
  }
</style>
