---
/**
 * /drops — index of PointCast editorial drops.
 *
 * First drop (001) staged 2026-04-24. Future drops land as they're
 * named. Reads directory structure / a manifest later.
 */
import BlockLayout from '../../layouts/BlockLayout.astro';

const DROPS = [
  {
    id: '001',
    title: 'Four Fields',
    date: '2026-04-24',
    status: 'staged',
    kicker: 'DROP 001',
    dek: 'Four editorial pieces staged for Tezos mint via Visit Nouns FA2. El Segundo print · Jacaranda post · Sparrow in the margin · Garden of the future.',
    href: '/drops/001',
  },
];

const title = 'Drops — PointCast editorial editions';
const description = 'Curated drops of editorial editions on Tezos. Each drop is a small named set; mints go to the Visit Nouns FA2.';
---

<BlockLayout title={title} description={description}>
  <main class="drops">
    <nav class="drops__crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>drops</span>
    </nav>

    <header class="drops__hero">
      <p class="drops__kicker mono">DROPS · POINTCAST EDITORIAL EDITIONS</p>
      <h1 class="drops__title">Named sets. Free mints. Small editions.</h1>
      <p class="drops__dek">
        Drops are curated editorial packs — a named set of pieces that
        ship together, mint to the Visit Nouns FA2, and stay listed on
        <a href="/editions">/editions</a> once live.
      </p>
    </header>

    <section class="drops__list">
      {DROPS.map((d) => (
        <a class={`drop-card drop-card--${d.status}`} href={d.href}>
          <p class="drop-card__kicker mono">{d.kicker} · {d.date} · {d.status.toUpperCase()}</p>
          <h2 class="drop-card__title">{d.title}</h2>
          <p class="drop-card__dek">{d.dek}</p>
          <p class="drop-card__cta mono">open →</p>
        </a>
      ))}
    </section>

    <footer class="drops__foot mono">
      <span>DROPS INDEX · EL SEGUNDO</span>
    </footer>
  </main>
</BlockLayout>

<style>
  .drops {
    max-width: 760px;
    margin: 0 auto;
    padding: 24px 20px 72px;
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    color: #121116;
  }
  .mono { font-family: 'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, monospace; }
  .drops__crumb { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: #5f5e5a; margin-bottom: 22px; }
  .drops__crumb a { color: inherit; text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 1px; }
  .drops__crumb span { margin: 0 6px; }
  .drops__hero { padding-bottom: 22px; border-bottom: 2px solid #1a1a22; margin-bottom: 28px; }
  .drops__kicker { font-size: 10.5px; letter-spacing: 0.24em; font-weight: 700; color: #8a2432; margin: 0 0 10px; }
  .drops__title { font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(26px, 4.5vw, 36px); line-height: 1.1; margin: 0 0 10px; font-weight: 400; }
  .drops__dek { font-family: Georgia, serif; font-size: 15.5px; line-height: 1.55; margin: 0; max-width: 62ch; color: #38373a; }
  .drops__dek a { color: #8a2432; }
  .drops__list { display: flex; flex-direction: column; gap: 12px; margin-bottom: 28px; }
  .drop-card {
    display: block;
    padding: 16px 18px;
    background: #fffdf8;
    border: 1px solid #e5dfce;
    border-left: 4px solid #8a2432;
    border-radius: 3px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .drop-card:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(18,17,22,0.08); }
  .drop-card__kicker { font-size: 10px; letter-spacing: 0.18em; font-weight: 700; color: #8a2432; margin: 0 0 4px; }
  .drop-card--staged { border-left-color: #f59f00; }
  .drop-card--staged .drop-card__kicker { color: #8a6000; }
  .drop-card__title { font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; font-weight: 400; margin: 0 0 6px; }
  .drop-card__dek { font-family: Georgia, serif; font-size: 14px; line-height: 1.5; margin: 0 0 8px; color: #38373a; }
  .drop-card__cta { font-size: 10.5px; letter-spacing: 0.18em; font-weight: 700; color: #8a2432; margin: 0; }
  .drops__foot { font-size: 10px; letter-spacing: 0.2em; color: #5f5e5a; text-align: center; }
</style>
