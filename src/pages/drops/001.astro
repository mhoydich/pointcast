---
/**
 * /drops/001 — Drop 001 · Four Fields
 *
 * Mike 2026-04-24 ~02:20 PT: "publish as nfts ... we'll work on the
 * contract tomorrow yah." Staged tonight, minted tomorrow on the
 * Visit Nouns FA2 (mainnet KT1LP1oTBuudRubAYQDErH7i7mSwazVdohxh).
 *
 * Four editorial pieces — "El Segundo Print", "Jacaranda Post",
 * "Sparrow in the Margin", "Garden of the Future". Images live at
 * /images/editions/drop-001/*.png once Mike drops them in; until
 * then the cards show a dashed placeholder.
 *
 * The mint runbook is at docs/plans/2026-04-24-drop-001-mint-runbook.md.
 */
import BlockLayout from '../../layouts/BlockLayout.astro';

interface Piece {
  idx: string;
  slug: string;
  title: string;
  dek: string;
  blockId: string;
  imagePath: string;
  medium: string;
  proposedEdition: number;
}

const PIECES: Piece[] = [
  {
    idx: '01',
    slug: 'el-segundo-print',
    title: 'El Segundo Print',
    dek: 'A two-color screen print. Royal blue skyline over green wall with potted plant and lemon water.',
    blockId: '0340',
    imagePath: '/images/editions/drop-001/drop-001-01-el-segundo-print.png',
    medium: 'two-color screen print (riso-ready)',
    proposedEdition: 20,
  },
  {
    idx: '02',
    slug: 'jacaranda-post',
    title: 'Jacaranda Post',
    dek: 'Single-story ES building, red-tile roof, jacaranda in full bloom, palm behind. Classic SoCal vernacular.',
    blockId: '0341',
    imagePath: '/images/editions/drop-001/drop-001-02-jacaranda-post.png',
    medium: 'painted digital photograph',
    proposedEdition: 20,
  },
  {
    idx: '03',
    slug: 'sparrow-in-the-margin',
    title: 'Sparrow in the Margin',
    dek: 'Canvas-textured sparrow on deep indigo, jade ink foliage. The portrait of the reader.',
    blockId: '0342',
    imagePath: '/images/editions/drop-001/drop-001-03-sparrow-in-the-margin.png',
    medium: 'canvas-textured print',
    proposedEdition: 15,
  },
  {
    idx: '04',
    slug: 'garden-of-the-future',
    title: 'Garden of the Future',
    dek: 'Retrofuturist garden terrace with planet rising, grid overlay, reference thumbnails. The manifesto poster.',
    blockId: '0343',
    imagePath: '/images/editions/drop-001/drop-001-04-garden-of-the-future.png',
    medium: 'collage / retrofuturist poster',
    proposedEdition: 12,
  },
];

const totalEditions = PIECES.reduce((s, p) => s + p.proposedEdition, 0);

const title = 'Drop 001 — Four Fields (staged)';
const description = 'Four editorial pieces staged for Tezos mint via Visit Nouns FA2. El Segundo Print · Jacaranda Post · Sparrow in the Margin · Garden of the Future. Minting tomorrow.';
const canonical = 'https://pointcast.xyz/drops/001';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': canonical,
  name: title,
  description,
  url: canonical,
  inLanguage: 'en-US',
  hasPart: PIECES.map((p) => ({
    '@type': 'VisualArtwork',
    name: p.title,
    description: p.dek,
    artMedium: p.medium,
    url: `https://pointcast.xyz/b/${p.blockId}`,
    image: `https://pointcast.xyz${p.imagePath}`,
  })),
  about: ['drop', 'nft', 'tezos', 'editorial', 'el-segundo', 'pointcast'],
};
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="drop">
    <nav class="drop__crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <a href="/drops">drops</a>
      <span aria-hidden="true">›</span>
      <span>001</span>
    </nav>

    <header class="drop__hero">
      <p class="drop__kicker mono">DROP 001 · FOUR FIELDS · STAGED · 2026-04-24</p>
      <h1 class="drop__title">Four pieces. One drop. Minting tomorrow.</h1>
      <p class="drop__dek">
        A small editorial set staged tonight for a Tezos mint via the
        Visit Nouns FA2 (<code class="mono">KT1LP1oTBuudRubAYQDErH7i7mSwazVdohxh</code>).
        {totalEditions} total editions across four pieces. Free mint,
        one per wallet per piece — the full mint mechanics get nailed
        down alongside the origination run. Staging captures the
        intent; tomorrow lights it up.
      </p>
      <ul class="drop__stats mono">
        <li><span class="num">{PIECES.length}</span><span class="lbl">PIECES</span></li>
        <li><span class="num">{totalEditions}</span><span class="lbl">EDITIONS</span></li>
        <li><span class="num">0</span><span class="lbl">TEZ</span></li>
        <li><span class="num">PENDING</span><span class="lbl">STATUS</span></li>
      </ul>
    </header>

    <section class="drop__grid" aria-label="Drop 001 pieces">
      {PIECES.map((p) => (
        <article class={`piece piece--${p.slug}`}>
          <figure class="piece__fig">
            <img class="piece__img" src={p.imagePath} alt={p.title} loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
            <div class="piece__ph" aria-hidden="true">
              <span class="mono">IMAGE COMING</span>
              <span class="mono">{p.idx}/04</span>
            </div>
          </figure>
          <header class="piece__head">
            <p class="piece__idx mono">DROP 001 · {p.idx}/04</p>
            <h2 class="piece__title">{p.title}</h2>
          </header>
          <p class="piece__dek">{p.dek}</p>
          <dl class="piece__meta mono">
            <dt>Medium</dt><dd>{p.medium}</dd>
            <dt>Edition</dt><dd>{p.proposedEdition} (proposed)</dd>
            <dt>Price</dt><dd>free · gas only</dd>
            <dt>Block</dt><dd><a href={`/b/${p.blockId}`}>b/{p.blockId}</a></dd>
          </dl>
        </article>
      ))}
    </section>

    <section class="drop__how">
      <h2 class="drop__h2">How the mint runs</h2>
      <ol class="drop__steps">
        <li><strong>Tonight (staged):</strong> 4 blocks (0340–0343) describe each piece · this page lists them · mint runbook written at <code class="mono">docs/plans/2026-04-24-drop-001-mint-runbook.md</code></li>
        <li><strong>Tomorrow:</strong> Mike drops image files into <code class="mono">public/images/editions/drop-001/</code> · cards render with real imagery</li>
        <li><strong>Origination pass:</strong> transfer Visit Nouns admin off the throwaway signer to Mike's wallet (`set_administrator`)</li>
        <li><strong>Metadata:</strong> upload TZIP-21 JSONs for each piece to IPFS (or Cloudflare Pages via <code class="mono">/api/tezos-metadata/[tokenId]</code>)</li>
        <li><strong>Mint:</strong> run <code class="mono">scripts/mint-drop-001.mjs</code> · allocates 4 token IDs, mints each to a holding wallet, optionally distributes editions</li>
        <li><strong>Surface:</strong> <code class="mono">/editions</code> auto-picks up new tokens via the live TzKT fetch · <code class="mono">/drops/001</code> converts the cards to MINT-type with contract + tokenId populated</li>
      </ol>
    </section>

    <section class="drop__runbook">
      <h2 class="drop__h2">Tomorrow's runbook</h2>
      <p class="drop__p">
        Full step-by-step at
        <a href="https://github.com/mhoydich/pointcast/blob/main/docs/plans/2026-04-24-drop-001-mint-runbook.md"><code class="mono">docs/plans/2026-04-24-drop-001-mint-runbook.md</code></a>
        — covers image upload, metadata prep, origination handover, and
        the mint script. Safe to run against shadownet first.
      </p>
    </section>

    <footer class="drop__foot mono">
      <span>DROP 001 · STAGED · EL SEGUNDO · 2026-04-24</span>
    </footer>
  </main>
</BlockLayout>

<style>
  .drop {
    max-width: 860px;
    margin: 0 auto;
    padding: 24px 20px 72px;
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    color: #121116;
  }
  .mono { font-family: 'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, monospace; }

  .drop__crumb {
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    color: #5f5e5a; margin-bottom: 22px;
  }
  .drop__crumb a { color: inherit; text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 1px; }
  .drop__crumb span { margin: 0 6px; }

  .drop__hero { padding-bottom: 22px; border-bottom: 2px solid #1a1a22; margin-bottom: 28px; }
  .drop__kicker { font-size: 10.5px; letter-spacing: 0.24em; font-weight: 700; color: #8a2432; margin: 0 0 10px; }
  .drop__title { font-family: 'DM Serif Display', 'Lora', Georgia, serif; font-size: clamp(28px, 4.5vw, 40px); line-height: 1.12; margin: 0 0 14px; font-weight: 400; }
  .drop__dek { font-family: Georgia, serif; font-size: 16px; line-height: 1.55; margin: 0 0 18px; max-width: 64ch; color: #38373a; }
  .drop__dek code { font-size: 12px; background: rgba(18,17,22,0.07); padding: 1px 5px; border-radius: 2px; }
  .drop__stats { list-style: none; padding: 0; margin: 0; display: flex; gap: 28px; flex-wrap: wrap; }
  .drop__stats li { display: flex; flex-direction: column; }
  .drop__stats .num { font-size: 20px; font-weight: 700; color: #8a2432; line-height: 1; }
  .drop__stats .lbl { font-size: 9.5px; letter-spacing: 0.16em; color: #5f5e5a; margin-top: 3px; }

  .drop__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin: 0 0 36px;
  }
  @media (max-width: 680px) { .drop__grid { grid-template-columns: 1fr; } }

  .piece {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 12px;
    background: #fffdf8;
    border: 1px solid #e5dfce;
    border-top: 4px solid #8a2432;
    border-radius: 3px;
  }
  .piece__fig {
    margin: 0;
    aspect-ratio: 1;
    background: #1a120a;
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }
  .piece__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .piece__ph {
    position: absolute; inset: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: repeating-linear-gradient(45deg, #2a2015, #2a2015 10px, #1f170e 10px, #1f170e 20px);
    color: #f5e6c3;
    font-size: 10px;
    letter-spacing: 0.2em;
    font-weight: 700;
    opacity: 0.85;
  }
  .piece__img[src=""] + .piece__ph,
  .piece__img:not([src]) + .piece__ph { display: flex; }

  .piece__head { margin-top: 6px; }
  .piece__idx { font-size: 10px; letter-spacing: 0.18em; color: #8a2432; margin: 0 0 3px; font-weight: 700; }
  .piece__title { font-family: 'DM Serif Display', 'Lora', Georgia, serif; font-size: 18px; font-weight: 400; line-height: 1.18; margin: 0; color: #1a120a; }
  .piece__dek { font-family: Georgia, serif; font-size: 13px; line-height: 1.5; margin: 2px 0 8px; color: #38373a; }
  .piece__meta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 4px 10px;
    font-size: 10.5px;
    letter-spacing: 0.1em;
    color: #5f5e5a;
    margin: 0;
    padding-top: 8px;
    border-top: 1px dashed #e5dfce;
  }
  .piece__meta dt { font-weight: 700; }
  .piece__meta dd { margin: 0; color: #1a120a; }
  .piece__meta a { color: #8a2432; }

  .drop__h2 { font-family: 'DM Serif Display', 'Lora', Georgia, serif; font-size: 22px; font-weight: 400; margin: 0 0 12px; color: #1a120a; }
  .drop__how, .drop__runbook { margin: 0 0 28px; padding-bottom: 22px; border-bottom: 1px solid #e5dfce; }
  .drop__steps { padding-left: 20px; margin: 0; font-family: Georgia, serif; font-size: 14px; line-height: 1.6; }
  .drop__steps li { margin-bottom: 6px; }
  .drop__steps code { font-size: 12.5px; background: rgba(26, 32, 21, 0.08); padding: 1px 5px; border-radius: 2px; }
  .drop__p { font-family: Georgia, serif; font-size: 14px; line-height: 1.6; margin: 0; color: #38373a; }
  .drop__p a { color: #8a2432; }

  .drop__foot { font-size: 10.5px; letter-spacing: 0.2em; color: #5f5e5a; text-align: center; }
</style>
