---
/**
 * /nouns-nation - standalone PointCast area for the Nouns Nation league,
 * broadcast surfaces, blocks, and federation path.
 */
import { getCollection } from 'astro:content';
import BlockLayout from '../../layouts/BlockLayout.astro';
import { CHANNELS } from '../../lib/channels';

const ch = CHANNELS.BTL;

const latestBattlerBlocks = (await getCollection('blocks', ({ data }) => !data.draft && data.channel === 'BTL'))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime())
  .slice(0, 4);

const surfaces = [
  {
    eyebrow: 'Live Desk',
    title: 'Battle Desk V2',
    href: '/nouns-nation-battler-v2/',
    note: 'GameCast-style control room with pressure, table, leaders, controls, and embedded match feed.',
    cta: 'Open V2',
  },
  {
    eyebrow: 'Original Desk',
    title: 'Battle Desk',
    href: '/nouns-nation-battler/',
    note: 'The canonical sports desk for the automated 30 vs 30 league and agent bench links.',
    cta: 'Open desk',
  },
  {
    eyebrow: 'Living Room',
    title: 'TV Cast',
    href: '/nouns-nation-battler-tv/',
    note: 'No-chrome broadcast mode for big screens, parties, QR handoffs, and keyboard hosting.',
    cta: 'Cast it',
  },
  {
    eyebrow: 'Archive',
    title: 'Desk Wall',
    href: '/nouns-nation-battler-desk/',
    note: 'Snapshot-backed report cards, scoreboards, story desk, and agent scorebook frames.',
    cta: 'Open wall',
  },
  {
    eyebrow: 'Assets',
    title: 'Poster Wall',
    href: '/nouns-nation-battler-posters/',
    note: 'Twenty type-heavy Nouns posters for the league world and shareable match energy.',
    cta: 'See posters',
  },
  {
    eyebrow: 'Machines',
    title: 'Nation JSON',
    href: '/nouns-nation.json',
    note: 'A machine-readable map of the hub, federation posture, intake schema, and live links.',
    cta: 'Read JSON',
  },
];

const federationCards = [
  {
    step: '01',
    title: 'Bring a nation',
    body: 'A person, crew, DAO, school, shop, fandom, art collective, or local league can show up with a name, colors, roster, rules, and a feed.',
  },
  {
    step: '02',
    title: 'Declare the kit',
    body: 'Each nation gets portable identity: short code, marks, colors, home link, contact path, and public manifest.',
  },
  {
    step: '03',
    title: 'Run local matches',
    body: 'PointCast can host or mirror automated slates while the nation keeps its own culture, teams, and weird house rules.',
  },
  {
    step: '04',
    title: 'Join federation events',
    body: 'Opt-in bowls, cups, rivalry nights, and cross-nation leaderboards become possible once manifests speak the same shape.',
  },
];

const quickLinks = [
  { href: '/nouns-nation/federation/', label: 'Federation strategy' },
  { href: '/nouns-nation/join/', label: 'Bring a nation' },
  { href: '/nouns-nation-battler-agents/', label: 'Agent bench' },
  { href: '/c/battler/', label: 'CH.BTL blocks' },
  { href: '/nouns-nation-battler.json', label: 'Battler JSON' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Nouns Nation',
  description:
    'A standalone PointCast area for Nouns Nation Battler, live battle desks, TV cast, desk wall, agent bench, blocks, and federation strategy for people bringing their own nations, teams, gangs, or leagues.',
  url: 'https://pointcast.xyz/nouns-nation/',
  hasPart: surfaces.map((surface) => ({
    '@type': 'WebPage',
    name: surface.title,
    url: `https://pointcast.xyz${surface.href}`,
  })),
};
---

<BlockLayout
  title="Nouns Nation"
  description="The standalone PointCast area for Nouns Nation: Battle Desk V2, TV cast, Desk Wall, Agent Bench, fresh Battler blocks, and the federation strategy for bringing your own nation, team, gang, or league."
  image="/images/og/battle.png"
  jsonLd={jsonLd}
  alternates={[
    { type: 'application/json', href: '/nouns-nation.json', title: 'Nouns Nation federation manifest' },
    { type: 'application/json', href: '/nouns-nation-battler.json', title: 'Nouns Nation Battler manifest' },
  ]}
  frame={{
    image: 'https://pointcast.xyz/images/og/battle.png',
    buttons: [
      { label: 'Nouns Nation', action: 'link', target: 'https://pointcast.xyz/nouns-nation/' },
      { label: 'Battle Desk V2', action: 'link', target: 'https://pointcast.xyz/nouns-nation-battler-v2/' },
      { label: 'Bring a nation', action: 'link', target: 'https://pointcast.xyz/nouns-nation/join/' },
      { label: 'Nation JSON', action: 'link', target: 'https://pointcast.xyz/nouns-nation.json' },
    ],
  }}
>
  <main
    class="nation"
    style={`--btl: ${ch.color600}; --btl-dark: ${ch.color800}; --btl-soft: ${ch.color50};`}
  >
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/c/battler/">CH.BTL</a>
      <span aria-hidden="true">/</span>
      <span>Nouns Nation</span>
    </nav>

    <section class="hero" aria-labelledby="nation-title">
      <div class="hero__copy">
        <p class="kicker">POINTCAST BTL NETWORK / STANDALONE AREA</p>
        <h1 id="nation-title">Nouns Nation is the league room.</h1>
        <p>
          One area for the automated Nouns sport: Battle Desk V2, TV cast, Desk Wall, agent handoffs,
          poster archive, machine manifests, and the early federation plan for people who want to bring
          their own nations, teams, gangs, clubs, crews, and local leagues.
        </p>
        <nav class="hero__actions" aria-label="Nouns Nation primary paths">
          <a class="primary" href="/nouns-nation-battler-v2/">Open Battle Desk V2</a>
          <a href="/nouns-nation/federation/">Federation strategy</a>
          <a href="/nouns-nation/join/">Bring a nation</a>
        </nav>
      </div>
      <div class="hero__field" aria-label="Nouns Nation signal board">
        <div class="scoreline">
          <span>NATION</span>
          <strong>BTL</strong>
          <span>FEDERATION</span>
        </div>
        <div class="noun-grid" aria-hidden="true">
          {[12, 19, 27, 34, 41, 52, 7, 58, 3].map((noun) => (
            <img src={`/games/nouns-nation-battler/assets/noun-${noun}.svg`} alt="" loading="eager" />
          ))}
        </div>
        <div class="field-readout">
          <span>30 vs 30</span>
          <span>8 gangs live</span>
          <span>Open federation</span>
        </div>
      </div>
    </section>

    <section class="ticker" aria-label="Nouns Nation ticker">
      <span>LIVE</span>
      <div>
        <p>Battle Desk V2 is live.</p>
        <p>Federation manifest published.</p>
        <p>Intake path open for nations, teams, gangs, and clubs.</p>
        <p>Blocks 0406-0408 carry the receipts.</p>
      </div>
    </section>

    <section class="surface-grid" aria-labelledby="surface-title">
      <div class="section-head">
        <p class="kicker">Broadcast surfaces</p>
        <h2 id="surface-title">Everything in the room has a job.</h2>
      </div>
      <div class="surfaces">
        {surfaces.map((surface) => (
          <a class="surface" href={surface.href}>
            <span>{surface.eyebrow}</span>
            <strong>{surface.title}</strong>
            <p>{surface.note}</p>
            <em>{surface.cta}</em>
          </a>
        ))}
      </div>
    </section>

    <section class="federation" aria-labelledby="federation-title">
      <div class="federation__copy">
        <p class="kicker">Federation posture</p>
        <h2 id="federation-title">Let people bring their own side without flattening the culture.</h2>
        <p>
          The PointCast job is not to own every nation. It is to publish a clean enough game surface,
          manifest shape, and event calendar that outside groups can bring identity and stakes with
          minimal ceremony. Nations stay theirs. Federation events make them legible together.
        </p>
        <nav class="link-row" aria-label="Federation paths">
          {quickLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        </nav>
      </div>
      <div class="federation__steps">
        {federationCards.map((card) => (
          <article>
            <span>{card.step}</span>
            <strong>{card.title}</strong>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="blocks" aria-labelledby="blocks-title">
      <div class="section-head">
        <p class="kicker">Fresh CH.BTL blocks</p>
        <h2 id="blocks-title">The public receipts for the arena.</h2>
      </div>
      <div class="block-list">
        {latestBattlerBlocks.map((block) => (
          <a href={`/b/${block.data.id}`}>
            <span>#{block.data.id} / {block.data.type}</span>
            <strong>{block.data.title}</strong>
            <p>{block.data.dek}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="agent-strip" aria-label="Machine-readable Nouns Nation links">
      <p>Machine-readable</p>
      <a href="/nouns-nation.json">/nouns-nation.json</a>
      <a href="/nouns-nation-battler.json">/nouns-nation-battler.json</a>
      <a href="/nouns-nation-battler-agents.json">/nouns-nation-battler-agents.json</a>
      <a href="/api/mcp-v2">/api/mcp-v2</a>
    </section>
  </main>
</BlockLayout>

<style>
  .nation {
    width: min(1180px, calc(100vw - 32px));
    margin: 0 auto;
    padding: 28px 0 64px;
    color: #12110e;
  }

  .crumb,
  .kicker,
  .agent-strip,
  .ticker,
  .surface span,
  .surface em,
  .block-list span {
    font-family: var(--pc-font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 12px;
  }

  .crumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    color: #5f5e5a;
    margin-bottom: 18px;
  }

  .crumb a {
    color: var(--btl-dark);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);
    gap: 24px;
    align-items: stretch;
    min-height: 520px;
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(28px, 5vw, 70px) 0;
  }

  .kicker {
    color: var(--btl-dark);
    margin: 0 0 12px;
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(44px, 8vw, 96px);
    line-height: 0.92;
    max-width: 760px;
    margin-bottom: 22px;
    letter-spacing: 0;
  }

  .hero__copy p:not(.kicker) {
    max-width: 710px;
    color: #38373a;
    font-size: clamp(18px, 2.1vw, 24px);
    line-height: 1.35;
  }

  .hero__actions,
  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .hero__actions a,
  .link-row a,
  .agent-strip a {
    border: 1px solid #c4c2bc;
    color: #12110e;
    padding: 12px 14px;
    border-radius: 8px;
    background: #fff;
  }

  .hero__actions a.primary {
    background: #12110e;
    color: #fff;
    border-color: #12110e;
  }

  .hero__field {
    border: 1px solid #12110e;
    background:
      linear-gradient(90deg, rgba(228, 87, 69, 0.12), rgba(54, 119, 224, 0.12)),
      #f8f7f2;
    min-height: 520px;
    display: grid;
    grid-template-rows: auto 1fr auto;
    overflow: hidden;
  }

  .scoreline,
  .field-readout {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px;
    font-family: var(--pc-font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 12px;
    background: #12110e;
    color: #fff;
  }

  .scoreline strong {
    font-size: 34px;
    letter-spacing: 0;
  }

  .noun-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    place-items: stretch;
  }

  .noun-grid img {
    width: 100%;
    height: 100%;
    min-height: 128px;
    object-fit: contain;
    padding: 18px;
    border-right: 1px solid rgba(18, 17, 14, 0.14);
    border-bottom: 1px solid rgba(18, 17, 14, 0.14);
  }

  .ticker {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 18px;
    align-items: center;
    border-top: 2px solid #12110e;
    border-bottom: 1px solid #12110e;
    margin: 28px 0;
    padding: 12px 0;
  }

  .ticker > span {
    background: var(--btl);
    color: #fff;
    padding: 8px 10px;
    border-radius: 999px;
  }

  .ticker div {
    display: flex;
    gap: 24px;
    overflow: hidden;
    white-space: nowrap;
  }

  .ticker p {
    margin: 0;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: end;
    margin: 48px 0 16px;
  }

  .section-head h2,
  .federation h2 {
    font-size: clamp(28px, 4vw, 52px);
    line-height: 0.98;
    margin-bottom: 0;
  }

  .surfaces,
  .block-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .surface,
  .block-list a,
  .federation__steps article {
    border: 1px solid #c4c2bc;
    border-radius: 8px;
    padding: 18px;
    color: #12110e;
    background: #fff;
  }

  .surface strong,
  .block-list strong,
  .federation__steps strong {
    display: block;
    font-size: 24px;
    line-height: 1.05;
    margin: 10px 0;
  }

  .surface p,
  .block-list p,
  .federation p {
    color: #5f5e5a;
    line-height: 1.45;
  }

  .surface em {
    display: inline-flex;
    font-style: normal;
    color: var(--btl-dark);
  }

  .federation {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 22px;
    align-items: start;
    margin-top: 56px;
    padding: 30px 0;
    border-top: 1px solid #12110e;
    border-bottom: 1px solid #12110e;
  }

  .federation__steps {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .federation__steps span {
    display: inline-flex;
    width: 38px;
    height: 38px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--btl-soft);
    color: var(--btl-dark);
    font-family: var(--pc-font-mono);
  }

  .agent-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-top: 42px;
    padding-top: 18px;
    border-top: 1px solid #c4c2bc;
  }

  .agent-strip p {
    margin: 0 6px 0 0;
    color: #5f5e5a;
  }

  @media (max-width: 860px) {
    .nation {
      width: min(100% - 20px, 1180px);
      padding-top: 18px;
    }

    .hero,
    .federation {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .hero__copy {
      padding: 24px 0 0;
    }

    .hero__field {
      min-height: 0;
    }

    .surfaces,
    .block-list,
    .federation__steps {
      grid-template-columns: 1fr;
    }

    .ticker {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .ticker div {
      white-space: normal;
      display: grid;
      gap: 8px;
    }
  }
</style>
