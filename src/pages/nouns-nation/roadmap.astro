---
/**
 * /nouns-nation/roadmap - V2 investor roadmap for the Nouns Nation Builder.
 */
import BlockLayout from '../../layouts/BlockLayout.astro';
import {
  NOUNS_NATION_ROADMAP,
  aiToolingCurve,
  capitalGatesV2,
  ninetyDayMoves,
  roadmapGithubSignals,
  roadmapSources,
  threeYearRoadmap,
  venueLadder,
} from '../../lib/nouns-nation-roadmap';

const title = 'Nouns Nation Builder Roadmap V2';
const description =
  'A three-year roadmap for taking Nouns Nation from web-native arena to agent-operated broadcast, TV-ready league, partner venues, and a live final format.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  '@id': 'https://pointcast.xyz/nouns-nation/roadmap#roadmap',
  name: title,
  description,
  datePublished: '2026-04-29',
  dateModified: '2026-04-29',
  url: NOUNS_NATION_ROADMAP.url,
  inLanguage: 'en-US',
  author: { '@id': 'https://pointcast.xyz/#person' },
  publisher: { '@id': 'https://pointcast.xyz/#org' },
  image: 'https://pointcast.xyz/images/og/battle.png',
  associatedMedia: {
    '@type': 'MediaObject',
    name: 'Nouns Nation Builder Roadmap V2 deck',
    contentUrl: NOUNS_NATION_ROADMAP.deck,
    encodingFormat: 'application/vnd.openxmlformats-officedocument.presentationml.presentation',
  },
};
---

<BlockLayout
  title={title}
  description={description}
  image="/images/og/battle.png"
  jsonLd={jsonLd}
  alternates={[
    { type: 'application/json', href: '/nouns-nation/roadmap.json', title: 'Nouns Nation Builder Roadmap V2 JSON' },
    { type: 'application/vnd.openxmlformats-officedocument.presentationml.presentation', href: '/decks/nouns-nation-builder-roadmap-v2.pptx', title: 'Nouns Nation Builder Roadmap V2 deck' },
  ]}
  frame={{
    image: 'https://pointcast.xyz/images/og/battle.png',
    buttons: [
      { label: 'Roadmap V2', action: 'link', target: 'https://pointcast.xyz/nouns-nation/roadmap' },
      { label: 'Roadmap JSON', action: 'link', target: 'https://pointcast.xyz/nouns-nation/roadmap.json' },
      { label: 'Pitch deck', action: 'link', target: NOUNS_NATION_ROADMAP.deck },
      { label: 'Nation hub', action: 'link', target: 'https://pointcast.xyz/nouns-nation/' },
    ],
  }}
>
  <main class="roadmap">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/nouns-nation/">Nouns Nation</a>
      <span aria-hidden="true">/</span>
      <span>Roadmap V2</span>
    </nav>

    <section class="hero" aria-labelledby="roadmap-title">
      <div class="hero__copy">
        <p class="kicker">Roadmap V2 / {NOUNS_NATION_ROADMAP.date}</p>
        <h1 id="roadmap-title">From browser room to stadium board.</h1>
        <p>{NOUNS_NATION_ROADMAP.thesis}</p>
        <nav class="actions" aria-label="Roadmap actions">
          <a class="primary" href={NOUNS_NATION_ROADMAP.deck}>Pitch deck</a>
          <a href="/nouns-nation/roadmap.json">Roadmap JSON</a>
          <a href="/investment-thesis">Investment thesis</a>
          <a href="/nouns-nation/">Nation hub</a>
        </nav>
      </div>
      <figure class="hero__asset">
        <img src="/images/og/battle.png" alt="Nouns Nation battle broadcast graphic" width="1200" height="630" loading="eager" />
        <figcaption>
          {NOUNS_NATION_ROADMAP.position}
        </figcaption>
      </figure>
    </section>

    <section class="ticker" aria-label="Roadmap ticker">
      <span>V2</span>
      <p>AI tools compress production cost.</p>
      <p>Agents run the desk, not the whole culture.</p>
      <p>TV is the next surface.</p>
      <p>Venues are the first real-world wedge.</p>
    </section>

    <section class="section" id="ai-tools" aria-labelledby="ai-tools-title">
      <p class="eyebrow">AI Tool Curve</p>
      <h2 id="ai-tools-title">The tooling curve now favors tiny media studios.</h2>
      <div class="tool-curve">
        {aiToolingCurve.map((item) => (
          <article>
            <span>{item.period}</span>
            <h3>{item.title}</h3>
            <p>{item.signal}</p>
            <strong>{item.implication}</strong>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="roadmap" aria-labelledby="three-year-title">
      <p class="eyebrow">Three Year Roadmap</p>
      <h2 id="three-year-title">A staged path from ritual to broadcast asset.</h2>
      <div class="year-stack">
        {threeYearRoadmap.map((year) => (
          <article>
            <div class="year-mark">
              <span>{year.year}</span>
              <strong>{year.calendar}</strong>
            </div>
            <div>
              <h3>{year.title}</h3>
              <p>{year.headline}</p>
              <div class="roadmap-cols">
                <div>
                  <span>Public surfaces</span>
                  <ul>
                    {year.publicSurfaces.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
                <div>
                  <span>Build</span>
                  <ul>
                    {year.build.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
                <div>
                  <span>Gates</span>
                  <ul>
                    {year.gates.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section ladder" id="venues" aria-labelledby="venue-title">
      <div>
        <p class="eyebrow">Venue Ladder</p>
        <h2 id="venue-title">The product should climb screens before it climbs cap tables.</h2>
        <p>
          The browser proves repeat behavior. TV proves social viewing.
          Partner venues prove local demand. Stadiums only matter after the
          runbook survives without founder-only magic.
        </p>
      </div>
      <div class="ladder__steps">
        {venueLadder.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.stage}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section split" id="capital" aria-labelledby="capital-title">
      <div>
        <p class="eyebrow">Capital Gates</p>
        <h2 id="capital-title">Tranche the money to proof, not vibes.</h2>
        <p>
          The capital plan stays milestone-gated. Fund the operating surface,
          then expand only when the audience, agents, and sponsor loop show
          they can repeat.
        </p>
      </div>
      <div class="gate-list">
        {capitalGatesV2.map((gate) => (
          <article>
            <span>{gate.gate}</span>
            <strong>{gate.amount}</strong>
            <p>{gate.unlock}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="ninety" aria-labelledby="ninety-title">
      <p class="eyebrow">Next 90 Days</p>
      <h2 id="ninety-title">The first proof window is simple and public.</h2>
      <div class="move-grid">
        {ninetyDayMoves.map((move) => (
          <article>
            <span>{move.window}</span>
            <p>{move.move}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="github" aria-labelledby="github-title">
      <p class="eyebrow">GitHub Receipts</p>
      <h2 id="github-title">Latest main was checked before V2.</h2>
      <div class="github-grid">
        {roadmapGithubSignals.map((signal) => (
          <article>
            <span>{signal.label}</span>
            <h3>{signal.title}</h3>
            <p>{signal.body}</p>
            <a href={signal.url}>Open commit</a>
          </article>
        ))}
      </div>
    </section>

    <section class="section sources" id="sources" aria-labelledby="sources-title">
      <p class="eyebrow">Sources</p>
      <h2 id="sources-title">Roadmap assumptions.</h2>
      <div class="source-grid">
        {roadmapSources.map((source) => (
          <a href={source.url}>
            <strong>{source.label}</strong>
            <span>{source.note}</span>
          </a>
        ))}
      </div>
      <p class="disclaimer">
        Strategic roadmap only. Not personalized financial advice, a public
        securities offering, or legal advice. Token, DAO, revenue-share, and
        collectible mechanics need counsel before launch.
      </p>
    </section>
  </main>
</BlockLayout>

<style>
  .roadmap {
    width: min(1180px, calc(100vw - 32px));
    margin: 0 auto;
    padding: 24px 0 96px;
    color: #12110e;
  }

  .crumb,
  .kicker,
  .eyebrow,
  .ticker,
  .tool-curve span,
  .roadmap-cols span,
  .year-mark span,
  .gate-list span,
  .move-grid span,
  .github-grid span,
  .github-grid a {
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .crumb,
  .actions,
  .ticker,
  .source-grid a {
    display: flex;
    align-items: center;
  }

  .crumb {
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
    color: #5f5e5a;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(330px, 0.72fr);
    gap: 22px;
    align-items: stretch;
    padding: 24px;
    border: 2px solid currentColor;
    background:
      linear-gradient(135deg, rgba(216, 51, 63, 0.09), rgba(49, 111, 221, 0.09)),
      #fbf7e9;
    box-shadow: 10px 10px 0 #15130f;
  }

  .hero__copy {
    display: grid;
    align-content: center;
  }

  .kicker,
  .eyebrow {
    margin: 0 0 10px;
    color: #4e19a8;
  }

  h1 {
    max-width: 820px;
    margin-bottom: 18px;
    font-size: clamp(3rem, 8.4vw, 7rem);
    line-height: 0.86;
    letter-spacing: 0;
  }

  h2 {
    margin-bottom: 12px;
    font-size: clamp(2rem, 4.4vw, 4.1rem);
    line-height: 0.94;
    letter-spacing: 0;
  }

  h3 {
    margin-bottom: 8px;
    font-size: 1.28rem;
    line-height: 1.04;
    letter-spacing: 0;
  }

  .hero__copy p:not(.kicker),
  .ladder > div > p,
  .split > div > p {
    max-width: 780px;
    color: #38373a;
    font-size: 1.12rem;
    line-height: 1.52;
  }

  .actions {
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .actions a,
  .github-grid a {
    padding: 10px 12px;
    border: 1.5px solid currentColor;
    color: #12110e;
    background: #fffdf6;
    text-decoration: none;
  }

  .actions a.primary {
    color: #fff8df;
    background: #15130f;
  }

  .hero__asset {
    display: grid;
    grid-template-rows: 1fr auto;
    margin: 0;
    min-height: 420px;
    border: 1.5px solid currentColor;
    overflow: hidden;
    background: #050310;
  }

  .hero__asset img {
    width: 100%;
    height: 100%;
    min-height: 330px;
    object-fit: cover;
  }

  .hero__asset figcaption {
    margin: 0;
    padding: 12px;
    color: #d7ff3f;
    background: #050310;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .ticker {
    flex-wrap: wrap;
    gap: 10px;
    margin: 24px 0;
    padding: 12px 0;
    border-top: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
  }

  .ticker span {
    padding: 7px 10px;
    color: #fff8df;
    background: #15130f;
  }

  .ticker p {
    margin: 0;
  }

  .section {
    margin: 0 0 26px;
    padding-top: 28px;
    border-top: 2px solid currentColor;
  }

  .tool-curve,
  .github-grid,
  .source-grid,
  .move-grid {
    display: grid;
    gap: 12px;
  }

  .tool-curve {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .tool-curve article,
  .year-stack > article,
  .ladder__steps article,
  .gate-list article,
  .move-grid article,
  .github-grid article {
    min-width: 0;
    border: 1.5px solid currentColor;
    background: #fffdf6;
  }

  .tool-curve article,
  .ladder__steps article,
  .gate-list article,
  .move-grid article,
  .github-grid article {
    padding: 16px;
  }

  .tool-curve span,
  .github-grid span,
  .gate-list span,
  .move-grid span,
  .roadmap-cols span {
    display: inline-block;
    width: fit-content;
    margin-bottom: 10px;
    padding: 4px 7px;
    border: 1.5px solid currentColor;
    background: #d7ff3f;
  }

  .tool-curve strong {
    display: block;
    margin-top: 12px;
    color: #15130f;
    line-height: 1.35;
  }

  .tool-curve p,
  .roadmap-cols li,
  .ladder__steps p,
  .gate-list p,
  .move-grid p,
  .github-grid p {
    color: #5f5e5a;
    line-height: 1.46;
  }

  .year-stack {
    display: grid;
    gap: 12px;
  }

  .year-stack > article {
    display: grid;
    grid-template-columns: 210px minmax(0, 1fr);
    gap: 18px;
    padding: 18px;
  }

  .year-mark {
    display: grid;
    align-content: start;
    gap: 12px;
    padding: 14px;
    color: #fff8df;
    background: #15130f;
  }

  .year-mark strong {
    font-size: clamp(3.4rem, 8vw, 7rem);
    line-height: 0.78;
  }

  .roadmap-cols {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .roadmap-cols ul {
    margin: 0;
    padding-left: 18px;
  }

  .roadmap-cols li + li {
    margin-top: 6px;
  }

  .ladder,
  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
    gap: 22px;
    align-items: start;
  }

  .ladder__steps,
  .gate-list {
    display: grid;
    gap: 10px;
  }

  .ladder__steps article {
    display: grid;
    grid-template-columns: 50px minmax(0, 0.42fr) minmax(0, 1fr);
    gap: 12px;
    align-items: start;
  }

  .ladder__steps article > span {
    display: inline-grid;
    width: 42px;
    height: 42px;
    place-items: center;
    color: #fff8df;
    background: #d8333f;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
  }

  .ladder__steps h3,
  .ladder__steps p,
  .move-grid p {
    margin-bottom: 0;
  }

  .gate-list strong {
    display: block;
    margin-bottom: 8px;
    font-size: 1.8rem;
    line-height: 1;
  }

  .move-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .github-grid {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .source-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .source-grid a {
    min-width: 0;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    padding: 12px;
    border: 1.5px solid currentColor;
    color: inherit;
    background: #fffdf6;
    text-decoration: none;
  }

  .source-grid span {
    color: #5f5e5a;
    line-height: 1.35;
    text-align: right;
  }

  .disclaimer {
    margin: 14px 0 0;
    padding: 12px;
    color: #fff8df;
    background: #15130f;
    font-family: var(--pc-font-mono, ui-monospace, monospace);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  @media (max-width: 980px) {
    .hero,
    .ladder,
    .split,
    .year-stack > article {
      grid-template-columns: 1fr;
    }

    .tool-curve,
    .github-grid,
    .source-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .roadmap-cols,
    .move-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .roadmap {
      width: min(100% - 20px, 1180px);
      padding-top: 18px;
    }

    .hero {
      padding: 16px;
      box-shadow: 6px 6px 0 #15130f;
    }

    .tool-curve,
    .github-grid,
    .source-grid,
    .ladder__steps article {
      grid-template-columns: 1fr;
    }

    .source-grid a {
      display: grid;
    }

    .source-grid span {
      text-align: left;
    }
  }
</style>
