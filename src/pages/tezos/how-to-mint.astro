---
/**
 * /tezos/how-to-mint — step-by-step guide to minting on Tezos via PointCast.
 *
 * HowTo schema for step-carousel rich-result eligibility. Target keywords:
 * "how to mint on tezos", "tezos nft mint guide", "beacon wallet mint",
 * "kukai mint tutorial", "visit nouns mint".
 */
import BlockLayout from '../../layouts/BlockLayout.astro';
import { TEZOS_WALLETS, liveContracts } from '../../lib/tezos-ecosystem';

const live = liveContracts();

const steps = [
  {
    name: 'Install a Tezos wallet',
    text: 'Pick a Beacon-compatible wallet. Kukai (kukai.app) is browser-based and needs no install — social-login recovery for first-timers. Temple Wallet (templewallet.com) is a Chrome/Firefox extension with mobile apps. Umami (umamiwallet.com) is desktop-native with ledger support. Altme (altme.io) is mobile-first.',
  },
  {
    name: 'Fund your wallet with a little tez',
    text: 'Buy XTZ on Coinbase, Kraken, Bitfinex, or Binance — all support Tezos. Send to your new wallet\'s tz1/tz2/tz3 address. ~1 ꜩ total covers 100+ mints; network fees per mint are ~0.003 ꜩ.',
  },
  {
    name: 'Visit pointcast.xyz/collection/visit-nouns',
    text: 'The mint gallery. Shows every Nouns seed 0-1199, current mint status, and a preview from noun.pics. Pick a seed you like. The contract is open-supply, so any unclaimed seed is available.',
    url: 'https://pointcast.xyz/collection/visit-nouns',
  },
  {
    name: 'Connect your wallet via Beacon',
    text: 'Click "Connect Wallet". A Beacon popup shows every compatible wallet. Pick yours and approve. PointCast requests only signature rights — no read access to full balance, no recurring approvals.',
  },
  {
    name: 'Pick the Noun seed you want to mint',
    text: 'Click the seed tile. Mint modal shows the Nouns preview, the tokenId (matches the seed), and the estimated ~0.003 ꜩ fee. Click "Mint".',
  },
  {
    name: 'Sign the transaction in your wallet',
    text: 'Your wallet shows contract KT1LP1oTBuudRubAYQDErH7i7mSwazVdohxh, entrypoint mint, fee ~0.003 ꜩ. Approve. Tezos confirms in ~15 seconds; finalizes in ~30.',
  },
  {
    name: 'Verify the mint',
    text: 'Within 30 seconds the page updates. Verify on TzKT at tzkt.io/KT1LP1oTBuudRubAYQDErH7i7mSwazVdohxh — your address is in the holders list. Your Noun also appears at objkt.com/profile/{your-address}.',
  },
];

const faqs = [
  { q: 'How long does a Tezos mint take?', a: 'About 15-30 seconds end to end. Block time is ~15s; finalization at ~30s.' },
  { q: 'What if the mint fails?', a: 'Failed operations revert cleanly on Tezos. Common causes: wallet locked, insufficient tez, Beacon pairing dropped. Reconnect and retry.' },
  { q: 'Do I pay PointCast to mint?', a: 'No. Visit Nouns is free-to-claim. You pay only the Tezos network fee (~0.003 ꜩ).' },
  { q: 'Is my Visit Noun the same as an Ethereum Noun?', a: 'Same CC0 art (rendered via noun.pics). Different on-chain asset — Visit Nouns is FA2 on Tezos; Ethereum Nouns is ERC-721. Complementary proliferation projects.' },
  { q: 'Can I mint on mobile?', a: 'Yes. Temple Wallet, Altme, and Kukai mobile-web all work. Same flow.' },
  { q: 'Where do I go if something breaks?', a: 'Email hello@pointcast.xyz or DM @mhoydich on X / Farcaster.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'HowTo',
      '@id': 'https://pointcast.xyz/tezos/how-to-mint',
      name: 'How to mint a Tezos FA2 NFT on PointCast',
      description: 'Seven-step guide to minting a Visit Nouns FA2 token on Tezos mainnet. Covers wallet choice (Kukai / Temple / Umami / Altme), funding (~0.003 ꜩ per mint), Beacon connection, seed selection, transaction signing, and on-chain verification. End-to-end in under 10 minutes.',
      url: 'https://pointcast.xyz/tezos/how-to-mint',
      image: 'https://pointcast.xyz/images/og-home-v3.png',
      totalTime: 'PT10M',
      estimatedCost: { '@type': 'MonetaryAmount', currency: 'XTZ', value: '0.003' },
      supply: [
        { '@type': 'HowToSupply', name: 'A Tezos wallet (Kukai, Temple, Umami, or Altme) — free' },
        { '@type': 'HowToSupply', name: 'A small amount of XTZ (~1 ꜩ covers 100+ mints)' },
      ],
      tool: [
        { '@type': 'HowToTool', name: 'A web browser with JavaScript enabled' },
        { '@type': 'HowToTool', name: 'Internet connection' },
      ],
      step: steps.map((s, i) => ({
        '@type': 'HowToStep',
        position: i + 1,
        name: s.name,
        text: s.text,
        ...(s.url ? { url: s.url } : {}),
      })),
      author: { '@type': 'Person', '@id': 'https://pointcast.xyz/#person', name: 'Mike Hoydich' },
      publisher: { '@type': 'Organization', '@id': 'https://pointcast.xyz/#org', name: 'PointCast' },
      datePublished: '2026-04-21',
      inLanguage: 'en-US',
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://pointcast.xyz/tezos/how-to-mint#faq',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://pointcast.xyz/tezos/how-to-mint#breadcrumb',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://pointcast.xyz/' },
        { '@type': 'ListItem', position: 2, name: 'Tezos', item: 'https://pointcast.xyz/tezos' },
        { '@type': 'ListItem', position: 3, name: 'How to mint', item: 'https://pointcast.xyz/tezos/how-to-mint' },
      ],
    },
  ],
};
---

<BlockLayout
  title="How to mint on Tezos"
  description="Seven-step guide to minting a Visit Nouns FA2 token on Tezos mainnet via PointCast. Wallet (Kukai / Temple / Umami / Altme), funding (~0.003 ꜩ per mint), Beacon connect, sign, verify. ~10 minutes."
  image="/images/og-home-v3.png"
  jsonLd={jsonLd}
>
  <article class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <a href="/tezos">Tezos</a>
      <span aria-hidden="true">›</span>
      <span>How to mint</span>
    </nav>

    <header class="hero">
      <p class="kicker">TEZOS · HOW TO MINT · ~10 MIN</p>
      <h1 class="display">How to mint on Tezos.</h1>
      <p class="dek">
        Seven steps. Install a Beacon-compatible wallet, fund it with a
        little tez, visit <a href="/collection/visit-nouns">/collection/visit-nouns</a>,
        pick a Nouns seed 0-1199, sign the transaction, verify on-chain.
        End to end in under 10 minutes. Network fees total ~0.003 ꜩ.
      </p>
    </header>

    <section class="steps">
      <h2 id="steps">The seven steps</h2>
      <ol class="step-list">
        {steps.map((s, i) => (
          <li class="step" id={`step-${i + 1}`}>
            <header class="step__head">
              <span class="step__num mono">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="step__title">{s.name}</h3>
            </header>
            <p class="step__text">{s.text}</p>
            {s.url && (
              <p class="step__cta mono">→ <a href={s.url}>{s.url}</a></p>
            )}
          </li>
        ))}
      </ol>
    </section>

    <section class="wallets">
      <h2 id="wallets">Wallet compatibility</h2>
      <ul class="wallet-list">
        {TEZOS_WALLETS.map((w) => (
          <li class="wallet">
            <h3 class="wallet__name"><a href={w.url} target="_blank" rel="noopener">{w.name} ↗</a></h3>
            <p class="wallet__platforms mono">{w.platforms.join(' · ')}</p>
            <p class="wallet__note">{w.note}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="faq-section">
      <h2 id="faq">FAQ</h2>
      <dl class="faq">
        {faqs.map((f) => (
          <>
            <dt>{f.q}</dt>
            <dd>{f.a}</dd>
          </>
        ))}
      </dl>
    </section>

    <footer class="related">
      <p class="related__label">RELATED</p>
      <ul>
        <li><a href="/tezos">/tezos — hub</a></li>
        <li><a href="/tezos.json">/tezos.json — machine manifest</a></li>
        <li><a href="/nouns">/nouns — Nouns-on-Tezos pillar</a></li>
        <li><a href="/collection/visit-nouns">/collection/visit-nouns — live mint UI</a></li>
      </ul>
    </footer>
  </article>
</BlockLayout>

<style>
  .page { max-width: 780px; margin: 0 auto; padding: 18px 18px 80px; }
  .mono { font-family: var(--pc-font-mono); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; }
  .crumb { font-family: var(--pc-font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--pc-ink-muted); margin-bottom: 18px; }
  .crumb a { color: var(--pc-accent); }

  .hero { margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1.5px solid var(--pc-ink); }
  .kicker { font-family: var(--pc-font-mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--pc-accent); margin: 0 0 10px; }
  .display { font-family: var(--pc-font-sans); font-size: 36px; font-weight: 500; line-height: 1.1; margin: 0 0 12px; }
  @media (max-width: 600px) { .display { font-size: 26px; } }
  .dek { font-size: 16px; line-height: 1.55; color: var(--pc-ink-soft); margin: 0; max-width: 60ch; }
  .dek a { color: var(--pc-accent); }

  .steps, .wallets, .faq-section { margin: 28px 0; }
  .steps h2, .wallets h2, .faq-section h2 { font-family: var(--pc-font-sans); font-size: 22px; font-weight: 500; margin: 0 0 14px; }

  .step-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 12px; }
  .step { padding: 14px 16px; border: 1px solid var(--pc-rule); border-left: 3px solid var(--pc-accent); border-radius: 2px; background: #fff; }
  .step__head { display: flex; align-items: baseline; gap: 12px; margin-bottom: 8px; }
  .step__num { color: var(--pc-accent); font-weight: 500; font-size: 12px; letter-spacing: 0.18em; }
  .step__title { margin: 0; font-family: var(--pc-font-sans); font-size: 17px; font-weight: 500; }
  .step__text { font-size: 14.5px; line-height: 1.55; color: var(--pc-ink); margin: 0 0 6px; max-width: 64ch; }
  .step__cta { margin: 0; font-size: 11px; color: var(--pc-ink-muted); }
  .step__cta a { color: var(--pc-accent); word-break: break-all; }

  .wallet-list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 10px; }
  .wallet { padding: 10px 12px; border: 1px solid var(--pc-rule); border-radius: 2px; background: #fafaf8; }
  .wallet__name { margin: 0 0 4px; font-family: var(--pc-font-sans); font-size: 15px; font-weight: 500; }
  .wallet__name a { color: var(--pc-ink); text-decoration: none; }
  .wallet__name a:hover { color: var(--pc-accent); }
  .wallet__platforms { margin: 0 0 6px; color: var(--pc-ink-muted); font-size: 9.5px; }
  .wallet__note { margin: 0; font-size: 13px; line-height: 1.5; color: var(--pc-ink-soft); }

  .faq { margin: 0; display: grid; gap: 14px; }
  .faq dt { font-family: var(--pc-font-sans); font-size: 16px; font-weight: 500; }
  .faq dd { margin: 0; font-size: 14px; line-height: 1.55; color: var(--pc-ink-soft); max-width: 64ch; }

  .related { margin-top: 40px; padding-top: 16px; border-top: 1.5px solid var(--pc-ink); font-family: var(--pc-font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; }
  .related__label { margin: 0 0 8px; color: var(--pc-ink-soft); }
  .related ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
  .related a { color: var(--pc-accent); }
</style>
