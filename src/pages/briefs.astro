---
/**
 * /briefs — Codex + Manus + cc collaboration surface.
 *
 * Mike 2026-04-18 chat: "get codex working, figure it out, and yah manus".
 * cc can't wire another agent's API, but cc CAN make the handoff legible.
 * This page reads every brief in docs/briefs/, groups by assignee, surfaces
 * status, and gives both agents a clear picking-up-work surface.
 *
 * Codex reads /briefs → picks an atomic task → opens a PR → Mike reviews.
 * Manus reads /briefs → picks an ops task → runs the dashboard/browser
 * work → posts a screenshot in the recap.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import { readAllBriefs, briefsSummary } from '../lib/briefs';

const briefs = readAllBriefs();
const stats = briefsSummary(briefs);

const codexBriefs = briefs.filter((b) => b.assignee === 'codex' || b.assignee === 'mixed');
const manusBriefs = briefs.filter((b) => b.assignee === 'manus' || b.assignee === 'mixed');
const ccBriefs    = briefs.filter((b) => b.assignee === 'cc');

// Today's shelf — briefs dated today (PT-adjusted). Makes the fresh
// handoffs visible without requiring agents to scan the whole list.
// Using a PT-day derivation so the shelf matches the site's sense of
// "today" (Front Door race day, etc.).
const ptNow = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/Los_Angeles' }));
const ptToday = `${ptNow.getFullYear()}-${String(ptNow.getMonth() + 1).padStart(2, '0')}-${String(ptNow.getDate()).padStart(2, '0')}`;
const todayBriefs = briefs.filter((b) => b.date === ptToday && !b.complete);

const title = 'Briefs — collaboration queue for Codex + Manus';
const description = 'Every brief cc has handed off to Codex or Manus, plus cc-internal planning notes. Read, pick a task, open a PR or post a screenshot.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'PointCast Briefs',
  description,
  url: 'https://pointcast.xyz/briefs',
};

function ghRawUrl(fileSlug: string) {
  return `https://github.com/MikeHoydich/pointcast/blob/main/docs/briefs/${fileSlug}.md`;
}
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>briefs</span>
    </nav>

    <header class="head">
      <p class="kicker mono">BRIEFS · COLLABORATION QUEUE</p>
      <h1 class="title">Codex, Manus, and cc — work to pick up.</h1>
      <p class="dek">
        Every handoff cc has written for another agent or itself. If you're
        Codex, read the <a href="#codex">Codex section</a> + pick an atomic
        task + open a PR. If you're Manus, read the <a href="#manus">Manus
        section</a> + run the dashboard/browser work + post a screenshot.
        If you're Mike, this is the transparent record of who's assigned
        what.
      </p>
      <ul class="stats">
        <li><span class="stats__num mono">{stats.total}</span><span class="stats__lbl mono">BRIEFS</span></li>
        <li><span class="stats__num mono">{stats.totalTasks}</span><span class="stats__lbl mono">TASKS</span></li>
        <li><span class="stats__num mono">{stats.byAssignee.codex + stats.byAssignee.mixed}</span><span class="stats__lbl mono">FOR CODEX</span></li>
        <li><span class="stats__num mono">{stats.byAssignee.manus + stats.byAssignee.mixed}</span><span class="stats__lbl mono">FOR MANUS</span></li>
      </ul>
    </header>

    {todayBriefs.length > 0 && (
      <section class="section today-shelf" aria-label="Today's open briefs">
        <div class="today-shelf__head">
          <p class="kicker mono today-shelf__kicker">Today's shelf · {ptToday} · {todayBriefs.length} open</p>
          <p class="today-shelf__dek">Fresh briefs from today. Pick one up — acceptance criteria at the top of each file.</p>
        </div>
        <ul class="brief-list">
          {todayBriefs.map((b) => (
            <li class={`brief-card brief-card--${b.assignee === 'mixed' ? 'codex' : b.assignee} today-shelf__card`}>
              <a href={ghRawUrl(b.fileSlug)} target="_blank" rel="noopener" class="brief-card__link">
                <div class="brief-card__head">
                  <span class="brief-card__date mono">{b.date || '—'}</span>
                  <span class={`brief-card__status mono today-shelf__chip today-shelf__chip--${b.assignee === 'mixed' ? 'codex' : b.assignee}`}>
                    {b.assignee === 'manus' ? 'FOR MANUS' : b.assignee === 'codex' ? 'FOR CODEX' : b.assignee === 'mixed' ? 'FOR CODEX+MANUS' : 'FOR CC'}
                  </span>
                  {b.taskCount > 0 && <span class="brief-card__task-count mono">{b.taskCount} TASK{b.taskCount === 1 ? '' : 'S'}</span>}
                </div>
                <h2 class="brief-card__title">{b.title}</h2>
                {b.lede && <p class="brief-card__lede">{b.lede}</p>}
                <p class="brief-card__path mono">{b.path} ↗</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {codexBriefs.length > 0 && (
      <section class="section" id="codex">
        <div class="section__head">
          <p class="kicker mono section__kicker section__kicker--codex">CODEX · OPENAI · REVIEWER</p>
          <p class="section__role">Picks atomic review tasks. Opens PRs. Tags Mike. No merge without approval.</p>
        </div>
        <ul class="brief-list">
          {codexBriefs.map((b) => (
            <li class="brief-card brief-card--codex">
              <a href={ghRawUrl(b.fileSlug)} target="_blank" rel="noopener" class="brief-card__link">
                <div class="brief-card__head">
                  <span class="brief-card__date mono">{b.date || '—'}</span>
                  {b.complete && <span class="brief-card__status mono status--done">COMPLETE</span>}
                  <span class="brief-card__task-count mono">{b.taskCount} TASK{b.taskCount === 1 ? '' : 'S'}</span>
                </div>
                <h2 class="brief-card__title">{b.title}</h2>
                {b.lede && <p class="brief-card__lede">{b.lede}</p>}
                <p class="brief-card__path mono">{b.path} ↗</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {manusBriefs.length > 0 && (
      <section class="section" id="manus">
        <div class="section__head">
          <p class="kicker mono section__kicker section__kicker--manus">MANUS · OPERATIONS · COMPUTER-USE</p>
          <p class="section__role">Cloudflare dashboard, DNS, GSC, IndexNow, objkt curation, social posts. Anything behind a login.</p>
        </div>
        <ul class="brief-list">
          {manusBriefs.map((b) => (
            <li class="brief-card brief-card--manus">
              <a href={ghRawUrl(b.fileSlug)} target="_blank" rel="noopener" class="brief-card__link">
                <div class="brief-card__head">
                  <span class="brief-card__date mono">{b.date || '—'}</span>
                  {b.complete && <span class="brief-card__status mono status--done">COMPLETE</span>}
                  <span class="brief-card__task-count mono">{b.taskCount} TASK{b.taskCount === 1 ? '' : 'S'}</span>
                </div>
                <h2 class="brief-card__title">{b.title}</h2>
                {b.lede && <p class="brief-card__lede">{b.lede}</p>}
                <p class="brief-card__path mono">{b.path} ↗</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {ccBriefs.length > 0 && (
      <section class="section" id="cc">
        <div class="section__head">
          <p class="kicker mono section__kicker section__kicker--cc">CC · INTERNAL PLANNING</p>
          <p class="section__role">cc-authored planning + strategy docs. Not handoffs, just the record.</p>
        </div>
        <ul class="brief-list">
          {ccBriefs.map((b) => (
            <li class="brief-card brief-card--cc">
              <a href={ghRawUrl(b.fileSlug)} target="_blank" rel="noopener" class="brief-card__link">
                <div class="brief-card__head">
                  <span class="brief-card__date mono">{b.date || '—'}</span>
                  {b.complete && <span class="brief-card__status mono status--done">COMPLETE</span>}
                  {b.taskCount > 0 && <span class="brief-card__task-count mono">{b.taskCount} TASK{b.taskCount === 1 ? '' : 'S'}</span>}
                </div>
                <h2 class="brief-card__title">{b.title}</h2>
                {b.lede && <p class="brief-card__lede">{b.lede}</p>}
                <p class="brief-card__path mono">{b.path} ↗</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="how">
      <p class="kicker mono">HOW THE HANDOFF WORKS</p>
      <ol class="how__steps">
        <li><strong>cc writes a brief</strong> in docs/briefs/{'{date}'}-{'{agent}'}-{'{slug}'}.md with atomic tasks (R4-1, R4-2, M-3-1, etc.), expected deliverables, and submission format.</li>
        <li><strong>The agent reads /briefs</strong> (this page) and picks up any task — one PR per task for Codex, one screenshot-backed ops report for Manus.</li>
        <li><strong>Status signal:</strong> drop a line `status: complete` in the brief body when done. cc picks it up on the next build and the card gets a COMPLETE chip.</li>
        <li><strong>Mike reviews</strong> PRs / ops reports + merges / posts approvals.</li>
      </ol>
    </section>

    <section class="agent-strip">
      <p class="agent-strip__label mono">MACHINE-READABLE</p>
      <ul>
        <li><a href="/collabs">/collabs · the team registry</a></li>
        <li><a href="/sprints">/sprints · what cc has shipped</a></li>
        <li><a href="/agents.json">/agents.json</a></li>
        <li><a href="https://github.com/MikeHoydich/pointcast/tree/main/docs/briefs" target="_blank" rel="noopener">docs/briefs/ on GitHub ↗</a></li>
      </ul>
    </section>
  </main>

  <style>
    .page { max-width: 820px; margin: 0 auto; padding: 24px 18px 80px; }
    .mono { font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); text-transform: uppercase; letter-spacing: 0.12em; }
    .crumb { display: flex; gap: 8px; margin-bottom: 14px; font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: #7a7a72; }
    .crumb a { color: #a02c2c; text-decoration: none; }

    .head { margin-bottom: 22px; }
    .kicker { font-size: 10px; margin: 0 0 10px; letter-spacing: 0.18em; color: #5F3DC4; }
    .title { font-family: var(--pc-font-sans, 'Inter Variable', system-ui, sans-serif); font-size: clamp(26px, 5vw, 36px); font-weight: 700; line-height: 1.1; margin: 0 0 12px; }
    .dek { margin: 0 0 14px; color: #38373A; font-size: 15px; line-height: 1.55; }
    .dek a { color: #a02c2c; text-decoration: none; font-weight: 500; }

    .stats { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 8px; }
    .stats li { padding: 10px 12px; border: 1px dashed #d6d4cd; border-radius: 2px; background: #faf9f5; display: flex; flex-direction: column; gap: 4px; }
    .stats__num { font-size: 22px; font-weight: 700; color: #12110E; }
    .stats__lbl { font-size: 9.5px; color: #5F5E5A; }

    .section { margin-bottom: 24px; }
    .section__head { margin-bottom: 10px; }

    .today-shelf {
      padding: 14px 14px 16px;
      margin-bottom: 26px;
      border: 1px solid #d4b55a;
      border-left: 4px solid #c4952e;
      border-radius: 2px;
      background: linear-gradient(180deg, #fdf7e6 0%, #fbf3dd 100%);
      position: relative;
    }
    .today-shelf::before {
      content: '';
      position: absolute;
      top: 10px;
      right: 12px;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #c4952e;
      box-shadow: 0 0 0 0 rgba(196, 149, 46, 0.55);
      animation: today-shelf-pulse 2.6s ease-out infinite;
    }
    @keyframes today-shelf-pulse {
      0%   { box-shadow: 0 0 0 0 rgba(196, 149, 46, 0.55); }
      70%  { box-shadow: 0 0 0 8px rgba(196, 149, 46, 0); }
      100% { box-shadow: 0 0 0 0 rgba(196, 149, 46, 0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .today-shelf::before { animation: none; }
    }
    .today-shelf__head { margin-bottom: 10px; }
    .today-shelf__kicker { color: #a07722; font-size: 10.5px; }
    .today-shelf__dek { margin: 0; color: #5F5E5A; font-size: 13.5px; line-height: 1.5; }
    .today-shelf__chip { margin-left: auto; }
    .today-shelf__chip--codex { background: #185FA5; color: #fff; }
    .today-shelf__chip--manus { background: #C95019; color: #fff; }
    .today-shelf__chip--cc    { background: #5F3DC4; color: #fff; }
    .today-shelf__card .brief-card__link {
      background: #fff;
    }

    .section__kicker { font-size: 10px; }
    .section__kicker--codex { color: #185FA5; }
    .section__kicker--manus { color: #C95019; }
    .section__kicker--cc    { color: #5F3DC4; }
    .section__role { margin: 0 0 10px; color: #5F5E5A; font-size: 13px; line-height: 1.5; }

    .brief-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 8px; }
    .brief-card__link { display: block; padding: 12px 14px; border: 1px solid #d6d4cd; border-left: 4px solid #185FA5; border-radius: 2px; background: #fff; color: #12110E; text-decoration: none; transition: background 0.12s; }
    .brief-card__link:hover { background: #f5f6fa; }
    .brief-card--manus .brief-card__link { border-left-color: #C95019; }
    .brief-card--manus .brief-card__link:hover { background: #fdf4ee; }
    .brief-card--cc .brief-card__link { border-left-color: #5F3DC4; }
    .brief-card--cc .brief-card__link:hover { background: #fbf9ff; }

    .brief-card__head { display: flex; gap: 8px; align-items: baseline; margin-bottom: 4px; flex-wrap: wrap; }
    .brief-card__date { font-size: 9.5px; color: #5F5E5A; letter-spacing: 0.14em; }
    .brief-card__task-count { font-size: 9.5px; color: #5F5E5A; margin-left: auto; font-weight: 700; }
    .brief-card__status { padding: 1px 6px; border-radius: 2px; font-size: 9px; font-weight: 700; letter-spacing: 0.14em; }
    .status--done { background: #1E7C2F; color: #fff; }

    .brief-card__title { font-family: var(--pc-font-sans, 'Inter Variable', system-ui, sans-serif); font-size: 16px; font-weight: 600; margin: 4px 0 4px; line-height: 1.3; }
    .brief-card__lede { margin: 0 0 6px; color: #38373A; font-size: 13.5px; line-height: 1.5; }
    .brief-card__path { margin: 6px 0 0; color: #5F5E5A; font-size: 9.5px; letter-spacing: 0.06em; text-transform: lowercase; font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); }

    .how { margin-top: 22px; padding: 14px 16px; border: 1px dashed #d6d4cd; border-radius: 2px; background: #fbfaf5; }
    .how__steps { list-style: none; counter-reset: how; margin: 6px 0 0; padding: 0; display: grid; gap: 8px; }
    .how__steps li { position: relative; padding-left: 22px; font-size: 13.5px; line-height: 1.5; color: #38373A; }
    .how__steps li::before { counter-increment: how; content: counter(how) '.'; position: absolute; left: 0; font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); color: #5F3DC4; font-weight: 700; }
    .how__steps strong { color: #12110E; font-weight: 600; }
    .how__steps code { font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); background: #f0eee6; padding: 1px 5px; border-radius: 2px; font-size: 0.9em; }

    .agent-strip { margin-top: 24px; padding-top: 12px; border-top: 1px dashed #d6d4cd; font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; }
    .agent-strip__label { margin: 0 0 6px; color: #5F5E5A; font-weight: 500; }
    .agent-strip ul { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 12px; }
    .agent-strip a { color: #a02c2c; text-decoration: none; text-transform: lowercase; letter-spacing: 0; }
    .agent-strip a:hover { text-decoration: underline; }
  </style>
</BlockLayout>
