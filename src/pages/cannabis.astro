      box-shadow: inset 0 0 0 1px rgba(22, 19, 15, 0.16), 0 20px 55px rgba(35, 26, 15, 0.12);
    }

    .wheel::after {
      content: '';
      position: absolute;
      inset: 11%;
      border-radius: 50%;
      border: 1px solid rgba(255, 253, 247, 0.72);
      pointer-events: none;
    }

    .wheel__spoke {
      --angle: calc((360deg / 6) * var(--i) - 90deg);
      position: absolute;
      left: 50%;
      top: 50%;
      width: 116px;
      min-height: 40px;
      transform: translate(-50%, -50%) rotate(var(--angle)) translateY(-180px) rotate(calc(var(--angle) * -1));
      border: 1px solid rgba(22, 19, 15, 0.2);
      border-radius: 999px;
      background: rgba(255, 253, 247, 0.92);
      color: #17120b;
      cursor: pointer;
      font-family: var(--pc-font-mono, ui-monospace, monospace);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .wheel__spoke:hover,
    .wheel__spoke[aria-pressed='true'] {
      background: var(--tone);
      color: #fff;
      text-decoration: none;
