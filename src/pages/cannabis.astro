    .wheel__center {
      position: absolute;
      inset: 32%;
      display: grid;
      place-items: center;
      align-content: center;
      gap: 3px;
      border-radius: 50%;
      background: #fffdf7;
      border: 1px solid rgba(22, 19, 15, 0.22);
