---
import BlockLayout from '../../layouts/BlockLayout.astro';
import {
  TV_ASSET_GROUPS,
  TV_PRIMARY_NAV,
  TV_SOURCE_RUNS,
  TV_STATION_NAV,
  TV_SURFACE_NAV,
  getTvAssetInventory,
} from '../../lib/tv-assets';

const inventory = getTvAssetInventory();
const assetByPath = new Map(inventory.assets.map((asset) => [asset.publicPath, asset]));
const spotlightPaths = [
  'images/og-home-v3.png',
  'images/listening-room/pointcast-listening-room-space.png',
  'collabs/arena/graphics/19-control-room.webp',
  'collabs/arena/graphics/32-hero-background.webp',
  'images/relay-super-map.png',
  'images/nouns-cola/nouns-cola-pack.png',
  'images/nouns-cola-crush/super-graphics.png',
  'sitting-with-gandalf/assets/wizard-study.png',
  'images/houseplants/houseplant-lab.svg',
  'images/og/b/0389.png',
];
const spotlightAssets = spotlightPaths.map((path) => assetByPath.get(path)).filter(Boolean);
const groups = TV_ASSET_GROUPS.map((group) => ({
  ...group,
  assets: inventory.assets.filter((asset) => asset.group === group.id),
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://pointcast.xyz/tv/assets',
  name: 'PointCast TV Assets',
  description: 'Central PointCast TV control room with broadcast links, station presets, games, and published assets.',
  url: 'https://pointcast.xyz/tv/assets',
  hasPart: inventory.assets.slice(0, 80).map((asset) => ({
    '@type': asset.previewable ? 'ImageObject' : 'DigitalDocument',
    name: asset.title,
    url: `https://pointcast.xyz${asset.href}`,
    encodingFormat: asset.extension,
  })),
};
---

<BlockLayout
  title="TV Assets"
  description="PointCast TV control room: broadcast links, station presets, games, source runs, and the published asset library."
  image="/images/og-home-v3.png"
  jsonLd={jsonLd}
  alternates={[
    { type: 'application/json', href: '/tv/assets.json', title: 'PointCast TV assets manifest' },
  ]}
>
  <div class="tv-library">
    <header class="library-head">
      <nav class="crumb" aria-label="Breadcrumb">
        <a href="/">PointCast</a>
        <span>/</span>
        <a href="/tv">TV</a>
        <span>/</span>
        <span>assets</span>
      </nav>

      <div class="mast">
        <div class="mast__copy">
          <p class="kicker">POINTCAST TV</p>
          <h1>Control room and asset library</h1>
          <p class="lede">
            One place for the live broadcast, station presets, playable surfaces,
            published graphics, and source design runs.
          </p>
        </div>

        <a class="onair" href="/tv" aria-label="Open PointCast TV broadcast">
          <span class="onair__label">ON AIR</span>
          <span class="onair__title">/tv</span>
          <span class="onair__meta">{inventory.totals.stations} stations / {inventory.totals.all} public files</span>
        </a>
      </div>

      <nav class="hub-nav" aria-label="TV asset navigation">
        <a href="#broadcast">Broadcast</a>
        <a href="#stations">Stations</a>
        <a href="#surfaces">Surfaces</a>
        <a href="#assets">Assets</a>
        <a href="#source">Source Runs</a>
        <a href="/tv/assets.json">JSON</a>
      </nav>
    </header>

    <section class="section-band" id="broadcast" aria-labelledby="broadcast-title">
      <div class="section-head">
        <p class="kicker">BROADCAST</p>
        <h2 id="broadcast-title">Primary TV surfaces</h2>
      </div>

      <div class="nav-grid">
        {TV_PRIMARY_NAV.map((item) => (
          <a class="nav-card" href={item.href} style={`--accent: ${item.accent};`}>
            <span class="nav-card__eyebrow">{item.eyebrow}</span>
            <span class="nav-card__title">{item.label}</span>
            <span class="nav-card__body">{item.body}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section-band" id="stations" aria-labelledby="stations-title">
      <div class="section-head section-head--inline">
        <div>
          <p class="kicker">STATIONS</p>
          <h2 id="stations-title">Presets in range</h2>
        </div>
        <a class="text-link" href="/local">Local layer</a>
      </div>

      <div class="station-grid">
        {TV_STATION_NAV.map((station) => (
          <a class="station-chip" href={station.href} style={`--accent: ${station.accent};`}>
            <span class="station-chip__key">{station.eyebrow}</span>
            <span class="station-chip__name">{station.label}</span>
            <span class="station-chip__body">{station.body}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section-band" id="surfaces" aria-labelledby="surfaces-title">
      <div class="section-head">
        <p class="kicker">SURFACES</p>
        <h2 id="surfaces-title">Playable and ambient builds</h2>
      </div>

      <div class="surface-grid">
        {TV_SURFACE_NAV.map((item) => (
          <a class="surface-card" href={item.href} style={`--accent: ${item.accent};`}>
            <span class="surface-card__eyebrow">{item.eyebrow}</span>
            <span class="surface-card__title">{item.label}</span>
            <span class="surface-card__body">{item.body}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section-band" aria-labelledby="spotlights-title">
      <div class="section-head">
        <p class="kicker">SPOTLIGHTS</p>
        <h2 id="spotlights-title">Broadcast-ready visuals</h2>
      </div>

      <div class="spotlight-grid">
        {spotlightAssets.map((asset) => (
          <a class="spotlight-card" href={asset.href}>
            <img src={asset.href} alt={asset.title} loading="lazy" />
            <span>{asset.title}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section-band" id="assets" aria-labelledby="assets-title">
      <div class="section-head section-head--inline">
        <div>
          <p class="kicker">PUBLIC ASSETS</p>
          <h2 id="assets-title">Published inventory</h2>
        </div>
        <div class="asset-tools">
          <label>
            <span class="sr-only">Filter assets</span>
            <input id="asset-filter" type="search" placeholder="filter" autocomplete="off" />
          </label>
          <span id="asset-count">{inventory.totals.all} files</span>
        </div>
      </div>

      <div class="group-stats" aria-label="Asset group counts">
        {inventory.groups.map((group) => (
          <a href={`#asset-${group.id}`} style={`--accent: ${group.accent};`}>
            <span>{group.label}</span>
            <strong>{group.count}</strong>
          </a>
        ))}
      </div>

      {groups.map((group) => (
        <section class="asset-section" id={`asset-${group.id}`} data-asset-section>
          <div class="asset-section__head" style={`--accent: ${group.accent};`}>
            <div>
              <p class="kicker">{group.eyebrow}</p>
              <h3>{group.label}</h3>
            </div>
            <p>{group.short}</p>
          </div>

          <div class="asset-grid">
            {group.assets.map((asset) => (
              <a
                class={`asset-card asset-card--${asset.previewable ? 'media' : 'file'}`}
                href={asset.href}
                data-asset-card
                data-search={`${asset.title} ${asset.publicPath} ${asset.kind} ${group.label}`.toLowerCase()}
              >
                {asset.previewable ? (
                  <span class="asset-card__thumb">
                    <img src={asset.href} alt={asset.title} loading="lazy" />
                  </span>
                ) : (
                  <span class="asset-card__file">{asset.extension}</span>
                )}
                <span class="asset-card__name">{asset.title}</span>
                <span class="asset-card__path">/{asset.publicPath}</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </section>

    <section class="section-band" id="source" aria-labelledby="source-title">
      <div class="section-head">
        <p class="kicker">SOURCE RUNS</p>
        <h2 id="source-title">Design folders behind the public library</h2>
      </div>

      <div class="source-grid">
        {TV_SOURCE_RUNS.map((run) => (
          <article class="source-card" style={`--accent: ${run.accent};`}>
            <span class="source-card__count">{run.count}</span>
            <h3>{run.label}</h3>
            <p>{run.body}</p>
            <code>{run.sourcePath}</code>
          </article>
        ))}
      </div>
    </section>
  </div>
</BlockLayout>

<script is:inline>
  (() => {
    const input = document.getElementById('asset-filter');
    const count = document.getElementById('asset-count');
    const cards = Array.from(document.querySelectorAll('[data-asset-card]'));
    const sections = Array.from(document.querySelectorAll('[data-asset-section]'));

    function applyFilter() {
      const query = (input?.value || '').trim().toLowerCase();
      let visible = 0;

      cards.forEach((card) => {
        const haystack = card.getAttribute('data-search') || '';
        const show = query === '' || haystack.includes(query);
        card.hidden = !show;
        if (show) visible += 1;
      });

      sections.forEach((section) => {
        const hasVisibleCard = !!section.querySelector('[data-asset-card]:not([hidden])');
        section.hidden = !hasVisibleCard;
      });

      if (count) count.textContent = query ? `${visible} / ${cards.length} files` : `${cards.length} files`;
    }

    input?.addEventListener('input', applyFilter);
  })();
</script>

<style>
  .tv-library {
    --ink: #111827;
    --muted: #5f6368;
    --rule: #d8dde3;
    --paper: #ffffff;
    --soft: #f5f7f8;
    max-width: 1440px;
    margin: 0 auto;
    padding: 18px 20px 88px;
    color: var(--ink);
  }

  .library-head {
    border-bottom: 2px solid var(--ink);
    padding-bottom: 18px;
  }

  .crumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 26px;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .crumb a {
    color: var(--ink);
  }

  .mast {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 340px);
    gap: 28px;
    align-items: stretch;
  }

  .kicker {
    margin: 0 0 9px;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 900px;
    margin: 0;
    font-size: clamp(42px, 7vw, 104px);
    line-height: 0.92;
    letter-spacing: 0;
    font-weight: 800;
  }

  h2 {
    margin: 0;
    font-size: clamp(28px, 4vw, 54px);
    line-height: 0.98;
    letter-spacing: 0;
    font-weight: 800;
  }

  h3 {
    margin: 0;
    font-size: 19px;
    line-height: 1.05;
    letter-spacing: 0;
    font-weight: 800;
  }

  .lede {
    max-width: 720px;
    margin: 18px 0 0;
    font-size: 18px;
    line-height: 1.45;
    color: var(--muted);
  }

  .onair {
    display: grid;
    min-height: 220px;
    padding: 22px;
    border: 2px solid var(--ink);
    background:
      linear-gradient(135deg, rgba(245, 159, 0, 0.16), transparent 52%),
      #080808;
    color: #fff;
    text-decoration: none;
    align-content: space-between;
  }

  .onair:hover {
    text-decoration: none;
  }

  .onair__label {
    width: fit-content;
    padding: 6px 9px;
    border: 1px solid rgba(255, 255, 255, 0.38);
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #f59f00;
  }

  .onair__title {
    font-family: var(--pc-font-mono);
    font-size: clamp(38px, 5vw, 66px);
    line-height: 0.9;
    font-weight: 800;
  }

  .onair__meta {
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #d8dde3;
  }

  .hub-nav {
    position: sticky;
    top: 0;
    z-index: 4;
    display: flex;
    gap: 1px;
    margin-top: 22px;
    overflow-x: auto;
    background: var(--ink);
    border: 1px solid var(--ink);
  }

  .hub-nav a {
    flex: 1 0 max-content;
    min-width: 112px;
    padding: 12px 14px;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
  }

  .hub-nav a:hover {
    background: var(--ink);
    color: #fff;
  }

  .section-band {
    padding: 42px 0 8px;
    border-bottom: 1px solid var(--rule);
  }

  .section-head {
    margin-bottom: 18px;
  }

  .section-head--inline {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 20px;
  }

  .text-link {
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .nav-grid,
  .surface-grid,
  .source-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 10px;
  }

  .nav-card,
  .surface-card,
  .source-card {
    display: grid;
    gap: 12px;
    min-height: 180px;
    padding: 18px;
    border: 1px solid var(--rule);
    border-top: 6px solid var(--accent);
    background: var(--paper);
    color: var(--ink);
    text-decoration: none;
  }

  .nav-card:hover,
  .surface-card:hover {
    border-color: var(--ink);
    text-decoration: none;
  }

  .nav-card__eyebrow,
  .surface-card__eyebrow {
    width: fit-content;
    padding: 4px 7px;
    background: color-mix(in srgb, var(--accent), white 86%);
    color: var(--accent);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .nav-card__title,
  .surface-card__title {
    font-size: 25px;
    line-height: 1.02;
    font-weight: 800;
  }

  .nav-card__body,
  .surface-card__body {
    align-self: end;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.35;
  }

  .station-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 8px;
  }

  .station-chip {
    display: grid;
    gap: 8px;
    min-height: 142px;
    padding: 14px;
    border: 1px solid var(--rule);
    background: linear-gradient(180deg, color-mix(in srgb, var(--accent), white 92%), #fff 60%);
    color: var(--ink);
    text-decoration: none;
  }

  .station-chip:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .station-chip__key {
    color: var(--accent);
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
  }

  .station-chip__name {
    font-size: 20px;
    line-height: 1;
    font-weight: 800;
  }

  .station-chip__body {
    color: var(--muted);
    font-size: 12px;
    line-height: 1.35;
  }

  .spotlight-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 10px;
  }

  .spotlight-card {
    display: grid;
    gap: 10px;
    padding: 10px;
    border: 1px solid var(--rule);
    background: var(--paper);
    color: var(--ink);
    text-decoration: none;
  }

  .spotlight-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    background: var(--soft);
    border: 1px solid var(--rule);
  }

  .spotlight-card span {
    min-height: 34px;
    font-size: 13px;
    line-height: 1.25;
    font-weight: 800;
  }

  .asset-tools {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .asset-tools input {
    width: min(320px, 58vw);
    min-height: 40px;
    border: 1px solid var(--ink);
    padding: 10px 12px;
    font: 12px var(--pc-font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink);
    background: #fff;
  }

  .asset-tools span {
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .group-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(148px, 1fr));
    gap: 1px;
    margin: 18px 0 28px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }

  .group-stats a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    min-height: 54px;
    padding: 12px;
    background: var(--paper);
    color: var(--ink);
    text-decoration: none;
  }

  .group-stats span {
    color: var(--accent);
    font-family: var(--pc-font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .group-stats strong {
    font-size: 24px;
    line-height: 1;
  }

  .asset-section {
    padding: 28px 0 10px;
  }

  .asset-section__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 12px;
    border-left: 8px solid var(--accent);
    padding-left: 14px;
  }

  .asset-section__head p:last-child {
    max-width: 540px;
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.35;
    text-align: right;
  }

  .asset-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(178px, 1fr));
    gap: 8px;
  }

  .asset-card {
    display: grid;
    grid-template-rows: auto minmax(34px, auto) auto;
    gap: 8px;
    min-height: 172px;
    padding: 8px;
    border: 1px solid var(--rule);
    background: #fff;
    color: var(--ink);
    text-decoration: none;
  }

  .asset-card:hover {
    border-color: var(--ink);
    text-decoration: none;
  }

  .asset-card[hidden],
  .asset-section[hidden] {
    display: none;
  }

  .asset-card__thumb {
    display: grid;
    place-items: center;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border: 1px solid var(--rule);
    background:
      linear-gradient(45deg, #f4f4f5 25%, transparent 25%),
      linear-gradient(-45deg, #f4f4f5 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #f4f4f5 75%),
      linear-gradient(-45deg, transparent 75%, #f4f4f5 75%);
    background-position: 0 0, 0 8px, 8px -8px, -8px 0;
    background-size: 16px 16px;
  }

  .asset-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .asset-card__file {
    display: grid;
    place-items: center;
    width: 100%;
    aspect-ratio: 16 / 10;
    border: 1px solid var(--rule);
    background: var(--soft);
    color: var(--muted);
    font-family: var(--pc-font-mono);
    font-size: 18px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .asset-card__name {
    font-size: 13px;
    line-height: 1.2;
    font-weight: 800;
  }

  .asset-card__path {
    color: var(--muted);
    font-family: var(--pc-font-mono);
    font-size: 9px;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }

  .source-card {
    min-height: 210px;
  }

  .source-card__count {
    width: fit-content;
    padding: 5px 8px;
    background: color-mix(in srgb, var(--accent), white 88%);
    color: var(--accent);
    font-family: var(--pc-font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
  }

  .source-card p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.4;
  }

  .source-card code {
    align-self: end;
    padding-top: 10px;
    border-top: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--pc-font-mono);
    font-size: 11px;
    overflow-wrap: anywhere;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 860px) {
    .tv-library {
      padding: 14px 12px 78px;
    }

    .mast {
      grid-template-columns: 1fr;
    }

    .onair {
      min-height: 172px;
    }

    .section-head--inline,
    .asset-section__head {
      align-items: start;
      flex-direction: column;
    }

    .asset-section__head p:last-child {
      text-align: left;
    }
  }
</style>
