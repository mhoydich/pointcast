---
import { STATIONS } from '../../lib/local';

export async function getStaticPaths() {
  return STATIONS.map((station) => ({
    params: { station: station.slug },
  }));
}

const station = Astro.params.station ?? '';
const target = `/tv?station=${encodeURIComponent(station)}`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content={`0;url=${target}`} />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>PointCast · TV Station</title>
</head>
<body>
  <script is:inline define:vars={{ target }}>
    window.location.replace(target);
  </script>
</body>
</html>
