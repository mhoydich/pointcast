---
/**
 * /tv/shows/commercials — fullscreen TV show that auto-cycles three
 * commercial videos end-to-end on loop.
 *
 * Same auto-fullscreen pattern as the other shows. Mute toggle, prev/
 * next, current-title display in the bottom bar. Loops forever.
 */

const COMMERCIALS = [
  { slug: 'pointcast-1967', title: 'PointCast — Tokyo broadcast', brand: 'POINTCAST', era: '1967 (anachronistic)', src: '/videos/pointcast-japanese-1967.mp4' },
  { slug: 'magpie',         title: 'Magpie — corner-store ad',     brand: 'MAGPIE',     era: '1970s–80s',           src: '/videos/magpie-commercial.mp4' },
  { slug: 'magpie-lego',    title: 'Magpie × Lego — block by block', brand: 'MAGPIE × LEGO', era: '1980s–90s',         src: '/videos/magpie-lego-commercial.mp4' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#000" />
  <meta name="description" content="Commercial break — three commercial videos auto-cycling fullscreen on loop. Pure broadcast mode." />
  <title>PointCast TV · Commercials</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:wght@500&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #000;
      --ink: #fef5e7;
      --ink-soft: #c4c2bc;
      --accent: #F59F00;
      --warm: #8a2432;
      --serif: 'Lora', Georgia, serif;
      --mono: 'JetBrains Mono', ui-monospace, monospace;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; height: 100vh; width: 100vw; overflow: hidden; background: var(--bg); color: var(--ink); font-family: var(--serif); }

    .top {
      position: fixed; top: 0; left: 0; right: 0; height: 56px;
      display: flex; align-items: center; gap: 16px; padding: 16px 30px; z-index: 30;
      font-family: var(--mono);
      background: linear-gradient(180deg, rgba(0,0,0,0.85) 0%, transparent 100%);
      transition: opacity 1s ease;
    }
    .top--idle { opacity: 0.15; }
    .top__brand { font-size: 15px; letter-spacing: 0.28em; font-weight: 700; }
    .top__brand em { font-style: normal; color: var(--accent); font-weight: 400; }
    .top__show { font-size: 10px; letter-spacing: 0.28em; color: var(--ink-soft); text-transform: uppercase; font-weight: 600; }
    .top__counter { font-size: 11px; letter-spacing: 0.16em; color: var(--accent); margin-left: auto; font-weight: 700; font-variant-numeric: tabular-nums; }
    .top__fs { appearance: none; cursor: pointer; background: rgba(245, 159, 0, 0.1); border: 1px solid rgba(245, 159, 0, 0.4); color: var(--accent); font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em; font-weight: 700; padding: 5px 10px; border-radius: 2px; }
    .top__fs:hover { background: rgba(245, 159, 0, 0.22); color: var(--ink); }
    .top__back { color: var(--ink-soft); font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em; text-decoration: none; }
    .top__back:hover { color: var(--accent); }
    .top__nav { appearance: none; cursor: pointer; background: rgba(254, 245, 231, 0.08); border: 1px solid rgba(254, 245, 231, 0.25); color: var(--ink-soft); font-family: var(--mono); font-size: 10px; letter-spacing: 0.16em; font-weight: 700; padding: 5px 10px; border-radius: 2px; }
    .top__nav:hover { color: var(--accent); border-color: var(--accent); }

    .stage {
      position: fixed; inset: 0;
      display: flex; align-items: center; justify-content: center;
      background: #000;
    }
    .player {
      max-width: 100%;
      max-height: 100%;
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .bot {
      position: fixed; left: 0; right: 0; bottom: 0;
      padding: 20px 30px;
      z-index: 30;
      background: linear-gradient(0deg, rgba(0,0,0,0.85) 0%, transparent 100%);
      display: flex; align-items: baseline; gap: 16px;
      font-family: var(--mono);
      transition: opacity 1s ease;
    }
    .bot--idle { opacity: 0.15; }
    .bot__brand-tag { font-size: 11px; letter-spacing: 0.22em; color: var(--accent); font-weight: 700; text-transform: uppercase; }
    .bot__title { font-family: var(--serif); font-size: clamp(15px, 1.6vw, 20px); color: var(--ink); margin: 0; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-style: italic; }
    .bot__era { font-size: 10px; letter-spacing: 0.12em; color: var(--ink-soft); text-transform: uppercase; font-weight: 600; }
    .bot__progress { width: 120px; height: 3px; background: rgba(254, 245, 231, 0.12); border-radius: 2px; overflow: hidden; }
    .bot__progress-fill { height: 100%; background: var(--accent); width: 0%; transition: width 0.2s linear; }
  </style>
</head>
<body>
  <header class="top" id="top">
    <div class="top__brand">POINT<em>CAST</em></div>
    <div class="top__show">SHOWS / COMMERCIALS</div>
    <button type="button" class="top__nav" id="prev-btn" aria-label="Previous">← PREV</button>
    <button type="button" class="top__nav" id="next-btn" aria-label="Next">NEXT →</button>
    <button type="button" class="top__nav" id="mute-btn" aria-pressed="false">♪ ON</button>
    <button type="button" class="top__fs" id="fs-btn"><span aria-hidden="true">⛶</span> FS</button>
    <a class="top__back" href="/tv/shows/">← SHOWS</a>
    <div class="top__counter"><span id="now-num">1</span> / {COMMERCIALS.length}</div>
  </header>

  <main class="stage">
    <video class="player" id="player" autoplay muted playsinline preload="auto"></video>
  </main>

  <footer class="bot" id="bot">
    <span class="bot__brand-tag" id="bot-brand">—</span>
    <p class="bot__title" id="bot-title">—</p>
    <span class="bot__era" id="bot-era">—</span>
    <div class="bot__progress"><div class="bot__progress-fill" id="bot-fill"></div></div>
  </footer>

  <script is:inline define:vars={{ COMMERCIALS }}>
    (function () {
      var idx = 0;
      var player = document.getElementById('player');
      var nowNum = document.getElementById('now-num');
      var brand = document.getElementById('bot-brand');
      var title = document.getElementById('bot-title');
      var era = document.getElementById('bot-era');
      var fill = document.getElementById('bot-fill');
      var top = document.getElementById('top');
      var bot = document.getElementById('bot');
      var muteBtn = document.getElementById('mute-btn');

      function load(i) {
        idx = (i + COMMERCIALS.length) % COMMERCIALS.length;
        var c = COMMERCIALS[idx];
        player.src = c.src;
        player.currentTime = 0;
        var p = player.play();
        if (p && p.then) p.catch(function () {});
        nowNum.textContent = idx + 1;
        brand.textContent = c.brand;
        title.textContent = c.title;
        era.textContent = c.era;
      }

      player.addEventListener('ended', function () { load(idx + 1); });
      player.addEventListener('timeupdate', function () {
        var pct = (player.duration > 0) ? (player.currentTime / player.duration) * 100 : 0;
        fill.style.width = pct + '%';
      });
      document.getElementById('prev-btn').addEventListener('click', function (e) { e.stopPropagation(); load(idx - 1); });
      document.getElementById('next-btn').addEventListener('click', function (e) { e.stopPropagation(); load(idx + 1); });
      muteBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        player.muted = !player.muted;
        muteBtn.textContent = player.muted ? '♪ MUTE' : '♪ ON';
        muteBtn.setAttribute('aria-pressed', player.muted ? 'true' : 'false');
      });

      load(0);

      // Idle chrome — fade top + bot bars after 4s of no mouse movement
      var idleTimer = null;
      function showChrome() {
        top.classList.remove('top--idle');
        bot.classList.remove('bot--idle');
        clearTimeout(idleTimer);
        idleTimer = setTimeout(function () {
          top.classList.add('top--idle');
          bot.classList.add('bot--idle');
        }, 4000);
      }
      window.addEventListener('mousemove', showChrome);
      window.addEventListener('touchstart', showChrome);
      showChrome();

      // Fullscreen wiring
      var fsBtn = document.getElementById('fs-btn');
      var armed = true;
      function inFs() { return !!(document.fullscreenElement || document.webkitFullscreenElement); }
      function enter() { var el = document.documentElement; var r = el.requestFullscreen || el.webkitRequestFullscreen; if (r) try { var p = r.call(el); if (p && p.then) p.catch(function(){}); } catch(e){} }
      function exit() { var e = document.exitFullscreen || document.webkitExitFullscreen; if (e) try { var p = e.call(document); if (p && p.then) p.catch(function(){}); } catch(e){} }
      if (fsBtn) fsBtn.addEventListener('click', function (ev) { ev.stopPropagation(); inFs() ? exit() : enter(); });
      function autoOnce(ev) {
        if (ev && ev.target && (ev.target.tagName === 'A' || ev.target.tagName === 'BUTTON' || (ev.target.closest && ev.target.closest('a,button,video')))) return;
        if (!armed) return; armed = false;
        window.removeEventListener('click', autoOnce);
        window.removeEventListener('touchend', autoOnce);
        enter();
        // Also unmute on first interaction since autoplay required muted
        if (player.muted) { player.muted = false; muteBtn.textContent = '♪ ON'; }
      }
      window.addEventListener('click', autoOnce);
      window.addEventListener('touchend', autoOnce);
      window.addEventListener('keydown', function (ev) {
        if (ev.key === 'f' || ev.key === 'F') { inFs() ? exit() : enter(); }
        if (ev.key === 'ArrowRight') { load(idx + 1); }
        if (ev.key === 'ArrowLeft')  { load(idx - 1); }
        if (ev.key === ' ' || ev.code === 'Space') { ev.preventDefault(); player.paused ? player.play() : player.pause(); }
      });
    })();
  </script>
</body>
</html>
