---
/**
 * /tv/shows/nouns — drifting mosaic of every Noun attached to a PointCast
 * block. Renders noun.pics SVGs in a full-viewport CSS grid with slow
 * organic drift on every tile. Reads beautiful on a 4K panel; at scale
 * the pattern feels like a swarm.
 *
 * Auto-fullscreen on first tap.
 */
import { getCollection } from 'astro:content';

const blocks = (await getCollection('blocks', ({ data }) => !data.draft && typeof data.noun === 'number'))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

// Up to 240 nouns on the mosaic (enough to fill any viewport densely).
// Beyond 240 the grid starts visually clipping and there's no benefit.
const tiles = blocks.slice(0, 240).map((b) => ({
  id: b.data.id,
  title: b.data.title,
  noun: b.data.noun,
}));
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#050404" />
  <meta name="description" content="Nouns mosaic — every Noun attached to a PointCast block, drifting in slow organic motion. Full viewport, 240 tiles." />
  <title>PointCast TV · Nouns mosaic</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://noun.pics" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #060504;
      --ink: #fef5e7;
      --ink-soft: #c4c2bc;
      --ink-dim: #5F5E5A;
      --accent: #F59F00;
      --warm: #8a2432;
      --mono: 'JetBrains Mono', ui-monospace, monospace;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; height: 100vh; width: 100vw; overflow: hidden; background: radial-gradient(ellipse at 50% 40%, #1a0d1a 0%, var(--bg) 70%); color: var(--ink); font-family: var(--mono); }

    .top {
      position: fixed; top: 0; left: 0; right: 0;
      height: 56px;
      display: flex; align-items: center; gap: 16px;
      padding: 16px 30px;
      z-index: 10;
      background: linear-gradient(180deg, rgba(6, 5, 4, 0.9) 0%, transparent 100%);
    }
    .top__brand { font-size: 15px; letter-spacing: 0.28em; font-weight: 700; color: var(--ink); }
    .top__brand em { font-style: normal; color: var(--accent); font-weight: 400; }
    .top__show { font-size: 10px; letter-spacing: 0.28em; color: var(--ink-soft); text-transform: uppercase; font-weight: 600; }
    .top__count { font-size: 10px; letter-spacing: 0.14em; color: var(--ink-dim); margin-left: auto; font-weight: 600; }
    .top__fs { appearance: none; cursor: pointer; background: rgba(245, 159, 0, 0.1); border: 1px solid rgba(245, 159, 0, 0.4); color: var(--accent); font-size: 10px; letter-spacing: 0.18em; font-weight: 700; padding: 5px 10px; border-radius: 2px; font-family: inherit; }
    .top__fs:hover { background: rgba(245, 159, 0, 0.22); color: var(--ink); }
    .top__back { color: var(--ink-soft); font-size: 10px; letter-spacing: 0.18em; text-decoration: none; }
    .top__back:hover { color: var(--accent); }

    .mosaic {
      position: fixed;
      inset: 60px 0 48px 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(90px, 1fr));
      grid-auto-rows: 1fr;
      gap: 4px;
      padding: 8px;
      overflow: hidden;
      container-type: inline-size;
    }

    .tile {
      position: relative;
      aspect-ratio: 1;
      overflow: hidden;
      border-radius: 4px;
      background: rgba(255, 255, 255, 0.02);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      animation: tile-drift var(--dur, 24s) var(--ease, ease-in-out) infinite alternate;
      animation-delay: var(--delay, 0s);
      will-change: transform;
    }
    .tile__img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(0.9) brightness(0.95);
      transition: filter 0.3s ease;
    }
    .tile__id {
      position: absolute;
      right: 3px; bottom: 3px;
      font-size: 8px;
      letter-spacing: 0.06em;
      color: rgba(255, 255, 255, 0.4);
      font-weight: 700;
      background: rgba(0, 0, 0, 0.55);
      padding: 1px 4px;
      border-radius: 2px;
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .tile:hover .tile__id { opacity: 1; }
    .tile:hover { transform: scale(1.06) !important; box-shadow: 0 4px 24px rgba(245, 159, 0, 0.4); z-index: 2; }
    .tile:hover .tile__img { filter: saturate(1.1) brightness(1.05); }

    @keyframes tile-drift {
      0%   { transform: translate(0, 0) scale(1); }
      50%  { transform: translate(var(--x-mid, 0px), var(--y-mid, 0px)) scale(1.02); }
      100% { transform: translate(var(--x-end, 0px), var(--y-end, 0px)) scale(1); }
    }

    .bot {
      position: fixed; left: 0; right: 0; bottom: 0; height: 44px;
      display: flex; align-items: center; gap: 20px; padding: 12px 30px;
      background: linear-gradient(0deg, rgba(6, 5, 4, 0.85) 0%, transparent 100%);
      z-index: 10;
      font-size: 10px; letter-spacing: 0.14em; color: var(--ink-dim);
    }
    .bot__kicker { color: var(--accent); font-weight: 700; }

    @media (prefers-reduced-motion: reduce) {
      .tile { animation: none !important; transform: none !important; }
    }
    @media (max-width: 720px) {
      .mosaic { grid-template-columns: repeat(auto-fit, minmax(64px, 1fr)); gap: 2px; padding: 4px; }
    }
  </style>
</head>
<body>
  <header class="top">
    <div class="top__brand">POINT<em>CAST</em></div>
    <div class="top__show">SHOWS / NOUNS MOSAIC</div>
    <button type="button" class="top__fs" id="fs-btn"><span aria-hidden="true">⛶</span> FS</button>
    <a class="top__back" href="/tv/shows/">← SHOWS</a>
    <div class="top__count">{tiles.length} NOUNS</div>
  </header>

  <main class="mosaic" aria-label="Nouns from every PointCast block">
    {tiles.map((t, i) => {
      // Pseudo-random-but-deterministic drift params per tile.
      const dur = 22 + ((i * 37) % 24);  // 22-45s
      const delay = -((i * 13) % 20);     // negative so they start mid-cycle
      const xMid = ((i * 23) % 16) - 8;
      const yMid = ((i * 29) % 16) - 8;
      const xEnd = ((i * 31) % 18) - 9;
      const yEnd = ((i * 41) % 14) - 7;
      return (
        <div
          class="tile"
          style={`--dur: ${dur}s; --delay: ${delay}s; --x-mid: ${xMid}px; --y-mid: ${yMid}px; --x-end: ${xEnd}px; --y-end: ${yEnd}px;`}
        >
          <img
            class="tile__img"
            src={`https://noun.pics/${t.noun}.svg`}
            alt={`Noun ${t.noun}`}
            loading="lazy"
            onerror="this.style.background='#2a1a2a';this.removeAttribute('src')"
          />
          <span class="tile__id">{t.id}</span>
        </div>
      );
    })}
  </main>

  <footer class="bot">
    <span class="bot__kicker">MOSAIC</span>
    <span>one noun per block, drifting · hover for block id · {tiles.length} currently attached</span>
  </footer>

  <script is:inline>
    (function () {
      var fsBtn = document.getElementById('fs-btn');
      var armed = true;
      function inFs() { return !!(document.fullscreenElement || document.webkitFullscreenElement); }
      function enter() { var el = document.documentElement; var r = el.requestFullscreen || el.webkitRequestFullscreen; if (r) try { var p = r.call(el); if (p && p.then) p.catch(function(){}); } catch(e){} }
      function exit() { var e = document.exitFullscreen || document.webkitExitFullscreen; if (e) try { var p = e.call(document); if (p && p.then) p.catch(function(){}); } catch(e){} }
      if (fsBtn) fsBtn.addEventListener('click', function (ev) { ev.stopPropagation(); inFs() ? exit() : enter(); });
      function autoOnce(ev) {
        if (ev && ev.target && (ev.target.tagName === 'A' || ev.target.tagName === 'BUTTON' || (ev.target.closest && ev.target.closest('a,button')))) return;
        if (!armed) return; armed = false;
        window.removeEventListener('click', autoOnce);
        window.removeEventListener('touchend', autoOnce);
        enter();
      }
      window.addEventListener('click', autoOnce);
      window.addEventListener('touchend', autoOnce);
      window.addEventListener('keydown', function (ev) { if (ev.key === 'f' || ev.key === 'F') inFs() ? exit() : enter(); });
    })();
  </script>
</body>
</html>
