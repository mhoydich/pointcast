---
/**
 * /tv/shows — index of viewable PointCast shows for broadcast mode.
 *
 * Mike 2026-04-20 ~23:30 PT: *"tv is so cool, when go to url can we auto
 * full screen, start to create some content from our history that'd be
 * interesting in that format, try some viewables."*
 *
 * This is the hub. Four shows on opening night (4/20 still):
 *   - /tv/shows/ticker  — scrolling compute ledger (stock-ticker style)
 *   - /tv/shows/archive — slow crawl of every block title in PointCast history
 *   - /tv/shows/loop    — animated conversation → editorial → feature loop
 *   - /tv/shows/quotes  — Mike's directives as fullscreen serif
 *
 * Each show auto-enters fullscreen on first tap (browsers require gesture).
 * Each respects prefers-reduced-motion.
 */
import BlockLayout from '../../../layouts/BlockLayout.astro';

const SHOWS = [
  {
    slug: 'ticker',
    title: 'Compute ticker',
    dek: 'Every ledger entry scrolling sideways like a stock ticker. Signature-colored, auto-advancing. Best on a 4K panel; reads fine on a phone.',
    kicker: 'DATA / LIVE',
    href: '/tv/shows/ticker',
    palette: 'warm',
  },
  {
    slug: 'archive',
    title: 'The archive crawl',
    dek: 'Every block title in PointCast history, oldest to newest, one at a time, set in big serif. About 4 minutes end-to-end at a reading pace.',
    kicker: 'ARCHIVE / MEDITATIVE',
    href: '/tv/shows/archive',
    palette: 'paper',
  },
  {
    slug: 'loop',
    title: 'The loop',
    dek: 'Animated diagram of the PointCast loop from block 0336: ping → editorial → feature → back. Real pings, real block titles, real features cycling through.',
    kicker: 'EXPLAINER / ANIMATED',
    href: '/tv/shows/loop',
    palette: 'dark',
  },
  {
    slug: 'quotes',
    title: 'Mike\'s directives',
    dek: 'Every Mike-quote that shaped a block, set in full-viewport serif. Source attribution below in mono. Crossfades every eleven seconds.',
    kicker: 'EDITORIAL / QUOTES',
    href: '/tv/shows/quotes',
    palette: 'paper',
  },
  {
    slug: 'nouns',
    title: 'Nouns mosaic',
    dek: 'Up to 240 Nouns — one per block — drifting in slow organic motion across a CSS grid. Hover any tile for the block ID. Best at 4K; the swarm appears.',
    kicker: 'VISUAL / SWARM',
    href: '/tv/shows/nouns',
    palette: 'dark',
  },
  {
    slug: 'clock',
    title: 'World clock',
    dek: 'El Segundo time as broadcast origin, with nine broadcast-relevant zones ringing it: cloud/UTC, NYC, London, Berlin, Tokyo, Hong Kong, Sydney, Reykjavík, Casablanca. Live ticking.',
    kicker: 'LIVE / TIME',
    href: '/tv/shows/clock',
    palette: 'warm',
  },
  {
    slug: 'polls',
    title: 'Polls cycle',
    dek: 'Every active PointCast poll with its current vote distribution as colored bars, cycling one at a time. Tallies fetched from /api/poll on each rotation.',
    kicker: 'COORDINATION / LIVE',
    href: '/tv/shows/polls',
    palette: 'paper',
  },
  {
    slug: 'here',
    title: 'Here bubbles',
    dek: 'Every visitor connected to PointCast right now, rendered as a floating Noun. Live snapshot from the presence Durable Object, refreshed every 3 seconds. Empty state included.',
    kicker: 'LIVE / PRESENCE',
    href: '/tv/shows/here',
    palette: 'dark',
  },
  {
    slug: 'sprint-retro',
    title: 'Sprint retro crawl',
    dek: 'Every sprint markdown in /docs/sprints/, oldest to newest, scrolling slowly. The shipping discipline made readable — title + first paragraph + date.',
    kicker: 'PROCESS / ARCHIVE',
    href: '/tv/shows/sprint-retro',
    palette: 'paper',
  },
  {
    slug: 'drum-vis',
    title: 'Drum visualizer',
    dek: 'Self-playing rhythm machine cycling 5 tempo modes (heartbeat → walk → train → run → sprint) on an 18-second loop each. Ring pulses radiate from a center drum head; tap to add a green ring of your own.',
    kicker: 'AUDIO / GENERATIVE',
    href: '/tv/shows/drum-vis',
    palette: 'dark',
  },
  {
    slug: 'commercials',
    title: 'Commercials',
    dek: 'Three commercial videos auto-cycling fullscreen on loop: a 1967 anachronistic Japanese PointCast spot, a Magpie commercial, and a Magpie × Lego crossover. Idle chrome fade. Tap to enter fullscreen + unmute.',
    kicker: 'BROADCAST / VIDEO',
    href: '/tv/shows/commercials',
    palette: 'dark',
  },
  {
    slug: 'federation',
    title: 'Federation map',
    dek: 'Animated network graph of PointCast plus imagined federated peer nodes. Pulsing connection lines, traveling ping events, live pings-per-minute counter. v0 has placeholders; real peers register at /for-nodes.',
    kicker: 'NETWORK / SKETCH',
    href: '/tv/shows/federation',
    palette: 'dark',
  },
  {
    slug: 'agarchat',
    title: 'AgarChat',
    dek: 'Instant messenger meets agar.io — eat, chat, dominate. Playable game with 12 AI bots, power-ups, viruses, combo kills, achievements, and floating chat bubbles. Gamepad and phone companion controller supported.',
    kicker: 'GAME / INTERACTIVE',
    href: '/tv/shows/agarchat',
    palette: 'dark',
  },
];

const title = 'PointCast TV — shows';
const description = 'Seven viewables built from PointCast\'s own history: compute ticker, archive crawl, the loop, Mike\'s directives, Nouns mosaic, world clock, polls cycle. Each auto-fullscreens on tap; cast to any TV.';
---

<BlockLayout title={title} description={description}>
  <main class="shows-page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <a href="/tv">TV</a>
      <span aria-hidden="true">›</span>
      <span>Shows</span>
    </nav>

    <header class="head">
      <p class="kicker mono">TV / SHOWS · FROM OUR HISTORY</p>
      <h1 class="title">Four viewables, built from the record.</h1>
      <p class="dek">
        Each show is a full-viewport visual pulled from PointCast's actual archive — the compute ledger,
        the block collection, the ping inbox, Mike's directives. Tap a tile; auto-fullscreen on first
        tap; cast or AirPlay to a TV from there. These replay indefinitely.
      </p>
    </header>

    <ul class="shows-grid">
      {SHOWS.map((s) => (
        <li class={`show-tile show-tile--${s.palette}`}>
          <a href={s.href} class="show-tile__link">
            <span class="show-tile__kicker mono">{s.kicker}</span>
            <h2 class="show-tile__title">{s.title}</h2>
            <p class="show-tile__dek">{s.dek}</p>
            <span class="show-tile__cta mono">WATCH →</span>
          </a>
        </li>
      ))}
    </ul>

    <footer class="foot">
      <p class="mono foot__kicker">ALSO</p>
      <ul class="foot__list">
        <li><a href="/tv">/tv — the main broadcast slideshow</a></li>
        <li><a href="/compute">/compute — the federated ledger these shows read</a></li>
        <li><a href="/b/0344">Block 0344 — on building viewables from history</a></li>
        <li><a href="/">Back to the front page</a></li>
      </ul>
    </footer>
  </main>
</BlockLayout>

<style>
  .shows-page { max-width: 980px; margin: 0 auto; padding: 24px 18px 80px; color: var(--pc-ink, #12110E); }
  .mono { font-family: var(--pc-font-mono, 'JetBrains Mono Variable', monospace); }

  .crumb { font-family: var(--pc-font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; color: var(--pc-ink-muted, #5F5E5A); }
  .crumb a { color: inherit; text-decoration: none; border-bottom: 1px solid currentColor; }
  .crumb a:hover { color: #E89A2D; }
  .crumb span[aria-hidden] { margin: 0 6px; opacity: 0.5; }

  .head { margin: 10px 0 30px; padding-bottom: 20px; border-bottom: 1px solid var(--pc-rule-soft, #E5E3DE); }
  .kicker { font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: #8A2432; margin: 0 0 10px; font-weight: 600; }
  .title { font-family: var(--pc-font-sans, 'Inter Variable', system-ui); font-size: clamp(28px, 4.5vw, 44px); font-weight: 500; margin: 0 0 14px; letter-spacing: -0.01em; line-height: 1.12; }
  .dek { font-size: 15px; line-height: 1.55; color: var(--pc-ink-soft, #38373A); margin: 0; max-width: 68ch; }

  .shows-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; }
  .show-tile { border-radius: 3px; overflow: hidden; border: 1px solid var(--pc-rule, #d6d4cd); transition: transform 0.14s, box-shadow 0.14s, border-color 0.14s; }
  .show-tile:hover { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(12, 11, 8, 0.14); border-color: var(--pc-ink); }
  .show-tile--warm { background: linear-gradient(140deg, #fff3d8 0%, #f5cf8d 100%); }
  .show-tile--paper { background: linear-gradient(140deg, #fffaf1 0%, #ece3c9 100%); }
  .show-tile--dark { background: linear-gradient(140deg, #12110e 0%, #2a1a2a 100%); color: #fef5e7; }
  .show-tile__link { display: flex; flex-direction: column; gap: 8px; padding: 18px 20px 18px; text-decoration: none; color: inherit; min-height: 220px; }
  .show-tile__kicker { font-size: 9.5px; letter-spacing: 0.16em; text-transform: uppercase; opacity: 0.75; font-weight: 600; }
  .show-tile__title { font-family: var(--pc-font-sans, 'Inter Variable', system-ui); font-size: 22px; font-weight: 500; margin: 0 0 4px; line-height: 1.15; }
  .show-tile__dek { font-size: 13.5px; line-height: 1.5; font-family: Georgia, 'Times New Roman', serif; margin: 0; flex-grow: 1; }
  .show-tile__cta { font-size: 10px; letter-spacing: 0.22em; font-weight: 700; margin-top: auto; padding-top: 10px; }
  .show-tile--dark .show-tile__cta { color: #F59F00; }
  .show-tile--warm .show-tile__cta { color: #7A1414; }
  .show-tile--paper .show-tile__cta { color: #5F2A1E; }

  .foot { margin-top: 40px; padding-top: 20px; border-top: 1px solid var(--pc-rule-soft, #E5E3DE); }
  .foot__kicker { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--pc-ink-muted); margin: 0 0 8px; }
  .foot__list { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .foot__list a { color: var(--pc-ink); text-decoration: underline; text-decoration-color: rgba(0,0,0,0.18); font-size: 14.5px; }
  .foot__list a:hover { color: #8A2432; text-decoration-color: currentColor; }
</style>
