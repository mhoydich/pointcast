---
/**
 * /tonight — Tuesday night in El Segundo, with a song on.
 *
 * Built 2026-04-21 ~21:55 PT after Mike: "fun times el segundo, and yah
 * tuesday night energy, figure out how to bring it to the site, this song
 * kinda vibe" — Kid Francescoli, "Moon (And It Went Like)," 2017.
 *
 * This page is intentionally small + soft. A background color that drifts
 * toward the current wall-clock hour. The Spotify player. A short prose
 * texture about being in the city tonight. Links into /bath for the full
 * color-wave mode over the same track.
 *
 * Refreshes per-visit (no cron, no cache). The tonight-copy stays editorial
 * until swapped; the background gradient is derived from the clock hour
 * client-side so the same page feels different at 8pm vs 11pm vs 2am.
 */
import BlockLayout from '../layouts/BlockLayout.astro';

const title = '/tonight — El Segundo, marine layer, a song on';
const description = 'Tuesday night, Kid Francescoli on loop, the beach is cold but the city has the right light. Tonight\'s soundtrack: Moon (And It Went Like). Open it, let it run, drift with it or open /bath for the full color-wave.';
---

<BlockLayout title={title} description={description}>
  <main class="tn" id="tonight-main">
    <div class="tn__frame">
      <header class="tn__head">
        <p class="tn__kicker mono">TONIGHT · 2026-04-21 · EL SEGUNDO</p>
        <h1 class="tn__title">Analog heart, night air.</h1>
        <p class="tn__dek">
          Tuesday. Marine layer came in at dusk. The late-April cool feels
          like the city exhaling. Kid Francescoli on loop. <em>Moon (And It
          Went Like)</em> — six minutes and thirty seconds, on the second
          or third time through by now.
        </p>
      </header>

      <section class="tn__player" aria-label="Tonight's song">
        <iframe
          src="https://open.spotify.com/embed/track/20HCH8XT2EK1QYe1loAJ8E?utm_source=pointcast"
          width="100%"
          height="152"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
          title="Kid Francescoli — Moon (And It Went Like)"
        />
        <p class="tn__player-credit mono">
          KID FRANCESCOLI × JULIA MINKIN · PLAY ME AGAIN · 2017
        </p>
      </section>

      <section class="tn__texture">
        <p>
          The Strand is empty past the lifeguard tower. The jets out of LAX
          are louder at night because the air is quieter. Someone's porch
          smells like a jasmine vine that shouldn't be blooming yet. The
          310 is a different city after 9pm — you can hear the boulevards.
        </p>
        <p>
          <em>And it went like…</em> — the line lands twice in the chorus.
          Both times feel like the song is asking permission to keep going.
          Press play. Put it on loop. Let the bath take it.
        </p>
      </section>

      <nav class="tn__links" aria-label="Go deeper">
        <a class="tn__link tn__link--primary" href="/bath">
          <span class="tn__link-label mono">/BATH</span>
          <span class="tn__link-desc">color-wave mode over this track · four moods, four fields</span>
        </a>
        <a class="tn__link" href="/clock">
          <span class="tn__link-label mono">/CLOCK</span>
          <span class="tn__link-desc">sky over El Segundo right now · 14 rituals, 12 zones</span>
        </a>
        <a class="tn__link" href="/drum/click">
          <span class="tn__link-label mono">/DRUM</span>
          <span class="tn__link-desc">tap along · web audio, mobile-first</span>
        </a>
        <a class="tn__link" href="/play/tank">
          <span class="tn__link-label mono">/PLAY/TANK</span>
          <span class="tn__link-desc">the shared aquarium · fish drift to the beat</span>
        </a>
        <a class="tn__link" href="/b/0339">
          <span class="tn__link-label mono">/B/0339</span>
          <span class="tn__link-desc">the bath atlas · eleven tracks across four moods</span>
        </a>
        <a class="tn__link" href="/">
          <span class="tn__link-label mono">/</span>
          <span class="tn__link-desc">back to the broadcast</span>
        </a>
      </nav>

      <footer class="tn__foot mono">
        <span>on air · el segundo · fm 96.1 · cc0</span>
        <span class="tn__time" id="tonight-clock">—</span>
      </footer>
    </div>
  </main>
</BlockLayout>

<script is:inline>
  (function () {
    'use strict';
    // Tint the page toward the clock hour. At 8pm the gradient leans warm
    // golden; at 11pm it drifts indigo; past 1am it goes toward slate.
    function paint() {
      var now = new Date();
      var h = now.getHours() + now.getMinutes() / 60;
      var root = document.getElementById('tonight-main');
      if (!root) return;
      // Evening → night → late-night color curve.
      var hue, sat, light;
      if (h < 19)          { hue = 32;  sat = 64; light = 86; } // pre-dusk amber
      else if (h < 20.5)   { hue = 22;  sat = 58; light = 78; } // dusk
      else if (h < 22)     { hue = 260; sat = 34; light = 30; } // indigo evening
      else if (h < 23.5)   { hue = 245; sat = 38; light = 22; } // deep evening
      else if (h < 1)      { hue = 230; sat = 30; light = 16; } // late night
      else if (h < 3.5)    { hue = 220; sat = 18; light = 12; } // small hours
      else if (h < 6)      { hue = 210; sat = 12; light = 14; } // pre-dawn slate
      else                 { hue = 200; sat = 40; light = 80; } // fallback daytime
      var bg1 = 'hsl(' + hue + ',' + sat + '%,' + light + '%)';
      var bg2 = 'hsl(' + (hue + 24) + ',' + (sat - 10) + '%,' + Math.max(6, light - 12) + '%)';
      root.style.background = 'linear-gradient(180deg,' + bg1 + ' 0%,' + bg2 + ' 100%)';
      // Flip text color when the background gets dark.
      root.classList.toggle('tn--dark', light < 50);

      var clock = document.getElementById('tonight-clock');
      if (clock) {
        var hh = String(now.getHours()).padStart(2, '0');
        var mm = String(now.getMinutes()).padStart(2, '0');
        clock.textContent = hh + ':' + mm + ' PT';
      }
    }
    paint();
    setInterval(paint, 60 * 1000);
  })();
</script>

<style>
  .tn {
    min-height: calc(100vh - 60px);
    padding: 40px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, #f3e7c9 0%, #ddb97e 100%);
    color: #12110e;
    transition: background 2s ease, color 1s ease;
  }
  .tn--dark { color: #fef5e7; }

  .tn__frame {
    max-width: 620px;
    width: 100%;
    padding: 36px 32px;
    background: rgba(255, 253, 250, 0.08);
    border: 1px solid rgba(18, 17, 14, 0.08);
    border-radius: 2px;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .tn--dark .tn__frame {
    background: rgba(18, 17, 14, 0.28);
    border-color: rgba(254, 245, 231, 0.14);
  }

  .tn__head { margin-bottom: 24px; }
  .tn__kicker {
    font-size: 10px;
    letter-spacing: 0.26em;
    font-weight: 700;
    margin: 0 0 10px;
    opacity: 0.75;
  }
  .tn__title {
    font-family: 'DM Serif Display', 'Lora', Georgia, serif;
    font-size: 40px;
    line-height: 1.08;
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }
  .tn__dek {
    font-family: Georgia, serif;
    font-size: 16px;
    line-height: 1.55;
    margin: 0;
    opacity: 0.92;
  }
  .tn__dek em { font-style: italic; }

  .tn__player { margin: 28px 0 20px; }
  .tn__player iframe {
    display: block;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.25);
  }
  .tn__player-credit {
    font-size: 10px;
    letter-spacing: 0.18em;
    margin: 8px 0 0;
    opacity: 0.72;
  }

  .tn__texture { margin: 24px 0 28px; font-family: Georgia, serif; font-size: 15px; line-height: 1.6; }
  .tn__texture p { margin: 0 0 14px; opacity: 0.9; }
  .tn__texture p:last-child { margin-bottom: 0; }

  .tn__links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 10px;
    margin: 0 0 24px;
  }
  .tn__link {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 10px 12px;
    background: rgba(255, 253, 250, 0.6);
    border: 1px solid rgba(18, 17, 14, 0.12);
    border-radius: 2px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .tn--dark .tn__link {
    background: rgba(18, 17, 14, 0.35);
    border-color: rgba(254, 245, 231, 0.14);
  }
  .tn__link:hover { transform: translateY(-1px); border-color: rgba(245, 159, 0, 0.8); }
  .tn__link--primary { border-color: rgba(245, 159, 0, 0.55); }
  .tn__link-label { font-size: 11px; letter-spacing: 0.14em; font-weight: 700; }
  .tn__link-desc { font-size: 11.5px; font-family: Georgia, serif; opacity: 0.85; line-height: 1.4; }

  .tn__foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 10px;
    letter-spacing: 0.18em;
    padding-top: 16px;
    border-top: 1px dashed rgba(18, 17, 14, 0.16);
    opacity: 0.75;
  }
  .tn--dark .tn__foot { border-top-color: rgba(254, 245, 231, 0.14); }

  @media (max-width: 520px) {
    .tn { padding: 24px 14px; }
    .tn__frame { padding: 24px 18px; }
    .tn__title { font-size: 30px; }
  }
</style>
