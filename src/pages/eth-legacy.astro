---
/**
 * /eth-legacy — retrospective of Mike's ~43 ETH/Polygon token deployments.
 *
 * Mike 2026-04-18 shared ~/Downloads/eth info.xlsx containing 45+ custom
 * ERC-20 token entries (2018-2021 era). cc extracted PUBLIC columns only
 * (name, ticker, deployer, contract, network, notes) — private keys +
 * mnemonics explicitly NOT stored. This page renders the retrospective.
 *
 * Each card → Etherscan / Polygonscan link for the contract (when
 * present) so anyone can verify on-chain state independently.
 */
import { getCollection } from 'astro:content';
import BlockLayout from '../layouts/BlockLayout.astro';

const tokens = (await getCollection('ethLegacy', ({ data }) => !data.draft))
  .sort((a, b) => {
    // Prefer mainnet-with-contract first, then other networks, then by name
    const aScore = (a.data.network === 'mainnet' ? 0 : 10) + (a.data.contract ? 0 : 1);
    const bScore = (b.data.network === 'mainnet' ? 0 : 10) + (b.data.contract ? 0 : 1);
    if (aScore !== bScore) return aScore - bScore;
    return (a.data.name || '').localeCompare(b.data.name || '');
  });

// Network-aware scan URL
function scanUrl(network: string, address: string): string | null {
  if (!address) return null;
  if (network === 'mainnet') return `https://etherscan.io/address/${address}`;
  if (network === 'polygon') return `https://polygonscan.com/address/${address}`;
  if (network === 'ropsten' || network === 'goerli' || network === 'sepolia') return null; // testnet scanners unreliable / deprecated
  return null;
}

// Distribution
const byNetwork: Record<string, number> = {};
const withContract = tokens.filter((t) => t.data.contract).length;
for (const t of tokens) byNetwork[t.data.network] = (byNetwork[t.data.network] || 0) + 1;

const title = 'ETH Legacy — the token-deployment retrospective';
const description = 'Mike deployed ~43 custom ERC-20 tokens on Ethereum, Ropsten, and Polygon between 2018 and 2021. This is the retrospective gallery. Public data only — private keys + mnemonics never stored here.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'PointCast ETH Legacy',
  description,
  url: 'https://pointcast.xyz/eth-legacy',
};
---

<BlockLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>eth-legacy</span>
    </nav>

    <header class="head">
      <p class="kicker mono">ETH LEGACY · DEPLOYMENT RETROSPECTIVE</p>
      <h1 class="title">Forty-five tokens. One hand.</h1>
      <p class="dek">
        Between 2018 and 2021 Mike deployed roughly forty-five custom ERC-20
        tokens on Ethereum, Ropsten, and Polygon. Some had live contracts
        and real holders. Most were zero-revenue experiments — tokens as
        poems, as jokes, as one-line bets on an idea that might mean
        something later. This is the retrospective.
      </p>
      <p class="dek dek--sub">
        <strong>Security note:</strong> the source file held private keys
        and recovery phrases. cc extracted <em>only</em> the public columns
        (name · ticker · deployer · contract · network · public notes) and
        explicitly skipped every row of the private-key and mnemonic columns.
        The source file is stored in Mike's password manager; nothing
        sensitive is in this repo. Public addresses are on-chain and
        already world-readable via Etherscan.
      </p>
      <ul class="stats">
        <li><span class="stats__num mono">{tokens.length}</span><span class="stats__lbl mono">TOKENS</span></li>
        <li><span class="stats__num mono">{byNetwork.mainnet || 0}</span><span class="stats__lbl mono">MAINNET</span></li>
        <li><span class="stats__num mono">{(byNetwork.ropsten || 0) + (byNetwork.goerli || 0) + (byNetwork.sepolia || 0)}</span><span class="stats__lbl mono">TESTNET</span></li>
        <li><span class="stats__num mono">{byNetwork.polygon || 0}</span><span class="stats__lbl mono">POLYGON</span></li>
        <li><span class="stats__num mono">{withContract}</span><span class="stats__lbl mono">WITH CONTRACT</span></li>
      </ul>
    </header>

    <section class="legend">
      <p class="kicker mono">HOW TO READ</p>
      <p>
        Each card shows the token name, ticker, network, and a direct link
        to the contract on the appropriate block explorer when one exists.
        Testnet tokens (Ropsten, Goerli, Sepolia) mostly don't have live
        explorers anymore — they render as dormant markers. Mainnet cards
        are clickable → live state. Polygon → PolygonScan.
      </p>
    </section>

    <ul class="tokens">
      {tokens.map((t) => {
        const url = t.data.contract ? scanUrl(t.data.network, t.data.contract) : null;
        const netColor = t.data.network === 'mainnet' ? '#185FA5'
          : t.data.network === 'polygon' ? '#5F3DC4'
          : t.data.network === 'unknown' ? '#5F5E5A'
          : '#C95019';  // testnets
        return (
          <li class="token" data-network={t.data.network} data-has-contract={t.data.contract ? '1' : '0'}>
            <div class="token__head">
              <span class="token__ticker mono">{t.data.ticker || '—'}</span>
              <span class="token__net mono" style={`background: ${netColor}`}>{t.data.network.toUpperCase()}</span>
            </div>
            <h2 class="token__name">{t.data.name}</h2>
            {t.data.notes && <p class="token__notes">{t.data.notes}</p>}
            <dl class="token__facts mono">
              {t.data.deployer && (
                <div><dt>DEPLOYER</dt><dd>{t.data.deployer.slice(0, 6)}…{t.data.deployer.slice(-4)}</dd></div>
              )}
              {t.data.contract && (
                <div><dt>CONTRACT</dt><dd>{t.data.contract.slice(0, 6)}…{t.data.contract.slice(-4)}</dd></div>
              )}
            </dl>
            {url ? (
              <a class="token__cta mono" href={url} target="_blank" rel="noopener">→ view on {t.data.network === 'polygon' ? 'polygonscan' : 'etherscan'}</a>
            ) : t.data.contract ? (
              <span class="token__cta token__cta--dormant mono">dormant · {t.data.network} scanner deprecated</span>
            ) : (
              <span class="token__cta token__cta--dormant mono">no contract address in archive</span>
            )}
          </li>
        );
      })}
    </ul>

    <section class="future">
      <p class="kicker mono">WHAT HAPPENS NEXT</p>
      <p>
        <a href="/poll/eth-legacy-story-next">/poll/eth-legacy-story-next</a>
        asks which of these tokens should get a dedicated PointCast block
        with the story behind it. Leader wins a cc-written editorial
        (author: mh+cc, sourced to Mike's recollection + the archive entry).
        Voters literally route which bits of the retrospective get written
        out first.
      </p>
    </section>

    <section class="agent-strip">
      <p class="agent-strip__label mono">MACHINE-READABLE</p>
      <ul>
        <li><a href="/eth-legacy.json">/eth-legacy.json</a></li>
        <li><a href="/poll/eth-legacy-story-next">/poll/eth-legacy-story-next</a></li>
        <li><a href="/b/0278">/b/0278 · the announcement</a></li>
        <li><a href="/for-agents">/for-agents</a></li>
      </ul>
    </section>
  </main>

  <style>
    .page { max-width: 1080px; margin: 0 auto; padding: 24px 18px 80px; }
    .mono { font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); text-transform: uppercase; letter-spacing: 0.12em; }
    .crumb { display: flex; gap: 8px; margin-bottom: 14px; font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: #7a7a72; }
    .crumb a { color: #a02c2c; text-decoration: none; }

    .head { margin-bottom: 22px; }
    .kicker { font-size: 10px; margin: 0 0 8px; letter-spacing: 0.18em; color: #185FA5; }
    .title { font-family: var(--pc-font-sans, 'Inter Variable', system-ui, sans-serif); font-size: clamp(28px, 5vw, 40px); font-weight: 700; line-height: 1.1; margin: 0 0 12px; }
    .dek { margin: 0 0 10px; color: #38373A; font-size: 15px; line-height: 1.6; }
    .dek--sub { font-size: 13.5px; color: #5F5E5A; border-left: 3px solid #C95019; padding: 8px 12px; background: #fdf4ee; border-radius: 2px; }
    .dek--sub strong { color: #6A3E05; }
    .dek--sub em { font-style: italic; }
    .dek a { color: #a02c2c; text-decoration: none; }

    .stats { list-style: none; margin: 14px 0 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 6px; }
    .stats li { padding: 8px 10px; border: 1px dashed #d6d4cd; border-radius: 2px; background: #faf9f5; display: flex; flex-direction: column; gap: 2px; }
    .stats__num { font-size: 20px; font-weight: 700; color: #12110E; }
    .stats__lbl { font-size: 9px; color: #5F5E5A; }

    .legend { margin-bottom: 18px; padding: 12px 14px; border: 1px dashed #d6d4cd; border-radius: 2px; background: #fbfaf5; }
    .legend p { margin: 0; font-size: 13px; line-height: 1.5; color: #5F5E5A; }

    .tokens { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 8px; }
    .token {
      padding: 12px 14px;
      border: 1px solid #d6d4cd;
      border-radius: 2px;
      background: #fff;
      display: flex;
      flex-direction: column;
      gap: 6px;
      min-height: 160px;
    }
    .token[data-network="mainnet"] { border-left: 4px solid #185FA5; }
    .token[data-network="polygon"] { border-left: 4px solid #5F3DC4; }
    .token[data-network="ropsten"], .token[data-network="goerli"], .token[data-network="sepolia"] { border-left: 4px solid #C95019; background: #fbf9f5; }
    .token[data-network="unknown"] { border-left: 4px solid #5F5E5A; background: #f7f7f4; }
    .token[data-has-contract="0"] { opacity: 0.72; }

    .token__head { display: flex; justify-content: space-between; align-items: center; gap: 6px; }
    .token__ticker { font-size: 10px; letter-spacing: 0.14em; color: #5F5E5A; font-weight: 700; }
    .token__net { font-size: 9px; color: #fff; padding: 2px 6px; border-radius: 2px; font-weight: 700; letter-spacing: 0.14em; }

    .token__name { font-family: var(--pc-font-sans, 'Inter Variable', system-ui, sans-serif); font-size: 15px; font-weight: 600; line-height: 1.3; margin: 0; color: #12110E; }
    .token__notes { font-size: 12px; color: #5F5E5A; margin: 0; line-height: 1.4; font-style: italic; }

    .token__facts { margin: auto 0 0; font-size: 9.5px; display: grid; gap: 2px; }
    .token__facts div { display: grid; grid-template-columns: 80px 1fr; gap: 6px; align-items: baseline; }
    .token__facts dt { color: #8a8878; margin: 0; letter-spacing: 0.14em; }
    .token__facts dd { color: #12110E; margin: 0; letter-spacing: 0; text-transform: none; font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); font-size: 10px; }

    .token__cta {
      margin-top: 4px;
      font-size: 9.5px;
      color: #a02c2c;
      text-decoration: none;
      letter-spacing: 0.06em;
      text-transform: lowercase;
      font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace);
    }
    .token__cta:hover { text-decoration: underline; }
    .token__cta--dormant { color: #8a8878; cursor: default; }
    .token__cta--dormant:hover { text-decoration: none; }

    .future { margin-top: 22px; padding: 14px 16px; border: 1px dashed #d6d4cd; border-radius: 2px; background: #fbfaf5; }
    .future p { margin: 0; font-size: 14px; line-height: 1.55; color: #38373A; }
    .future a { color: #a02c2c; text-decoration: none; font-weight: 500; }

    .agent-strip { margin-top: 22px; padding-top: 12px; border-top: 1px dashed #d6d4cd; font-family: var(--pc-font-mono, 'JetBrains Mono Variable', ui-monospace, monospace); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; }
    .agent-strip__label { margin: 0 0 6px; color: #5F5E5A; font-weight: 500; }
    .agent-strip ul { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 12px; }
    .agent-strip a { color: #a02c2c; text-decoration: none; text-transform: lowercase; letter-spacing: 0; }
    .agent-strip a:hover { text-decoration: underline; }
  </style>
</BlockLayout>
