---
/**
 * 404 — Block not found.
 *
 * Astro on Cloudflare Pages: the `_routes.json` / Pages convention is to
 * serve `404.html` for unmatched routes with a 404 status. Adding this
 * page + the _redirects rule (which our build emits) gets us there.
 *
 * BLOCKS.md dictates the aesthetic — mono metadata, hard corners, channel
 * accent (picked VST gray as the "nothing there" color).
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import { CHANNELS } from '../lib/channels';
const ch = CHANNELS.VST;
---

<BlockLayout title="Block not found" description="The block at this URL does not exist. Block IDs are monotonic and immutable — retired blocks stay retired.">
  <div class="page" style={`--ch-600: ${ch.color600}; --ch-800: ${ch.color800}; --ch-50: ${ch.color50};`}>
    <header class="head">
      <p class="code">CH.404 · BLOCK NOT FOUND</p>
      <h1>No block at this address.</h1>
      <p class="dek">
        Block IDs are monotonic and immutable per
        <a href="/BLOCKS.md"><code>BLOCKS.md</code></a> — if a block is retired,
        the ID does not get handed to something else.
      </p>
    </header>
    <section class="doors">
      <a class="door" href="/">← All blocks</a>
      <a class="door" href="/for-agents">/for-agents</a>
      <a class="door" href="/blocks.json">/blocks.json</a>
      <a class="door" href="/status">/status</a>
    </section>
  </div>
</BlockLayout>

<style>
  .page { max-width: 640px; margin: 0 auto; padding: 80px 20px; }
  .code {
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ch-800);
    margin: 0 0 10px;
  }
  .head h1 {
    font-family: var(--pc-font-sans);
    font-size: 36px;
    font-weight: 500;
    line-height: 1.1;
    margin: 0 0 14px;
  }
  .dek { font-size: 15px; color: var(--pc-ink-soft); margin: 0 0 36px; line-height: 1.5; }
  .dek code { font-family: var(--pc-font-mono); font-size: 13px; padding: 1px 4px; background: var(--ch-50); border-radius: 2px; }
  .doors { display: flex; flex-wrap: wrap; gap: 10px; }
  .door {
    padding: 8px 14px;
    border: 1.5px solid var(--ch-600);
    color: var(--ch-800);
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background-color 0.12s;
  }
  .door:hover { background: var(--ch-50); text-decoration: none; }
</style>
