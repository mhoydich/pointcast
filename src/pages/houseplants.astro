---
/**
 * /houseplants - canonical learning-module route for Block 0402.
 *
 * The block remains the immutable source of truth at /b/0402; this page is
 * the human-readable topic route people expect when the homepage hero says
 * "houseplants." It also links to the correct public GitHub repo branch
 * instead of assuming the block has landed on main.
 */
import { getCollection } from 'astro:content';
import BlockLayout from '../layouts/BlockLayout.astro';
import BlockCard from '../components/BlockCard.astro';

const block = (await getCollection('blocks', ({ data }) => !data.draft))
  .find((entry) => entry.data.id === '0402');

if (!block) {
  throw new Error('Houseplants route expected block 0402.');
}

const title = 'Houseplant Field School';
const description = block.data.dek ?? 'A PointCast Garden learning module for understanding houseplants through the El Segundo indoor-climate lens.';
const canonical = 'https://pointcast.xyz/houseplants';
const blockUrl = 'https://pointcast.xyz/b/0402';
const sourceUrl = 'https://github.com/mhoydich/pointcast/blob/cc/sprints-1-6-publish/src/content/blocks/0402.json';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LearningResource',
      '@id': canonical,
      name: title,
      headline: block.data.title,
      description,
      url: canonical,
      image: 'https://pointcast.xyz/images/og/b/0402.png',
      inLanguage: 'en-US',
      datePublished: block.data.timestamp.toISOString(),
      learningResourceType: 'Field guide',
      educationalLevel: 'Beginner to intermediate',
      teaches: [
        'Houseplant light diagnosis',
        'Watering by pot weight and root oxygen',
        'Indoor soil structure',
        'Common houseplant pest literacy',
        'El Segundo coastal indoor plant care',
      ],
      about: [
        'houseplants',
        'indoor gardening',
        'El Segundo',
        'coastal Southern California',
      ],
      isPartOf: {
        '@type': 'CollectionPage',
        name: 'Garden',
        url: 'https://pointcast.xyz/c/garden',
      },
      mainEntity: { '@id': blockUrl },
      codeRepository: 'https://github.com/mhoydich/pointcast',
      citation: `PointCast · CH.GDN · No. 0402 - "${block.data.title}" · 2026-04-22`,
    },
    {
      '@type': 'CreativeWork',
      '@id': blockUrl,
      name: block.data.title,
      url: blockUrl,
      sameAs: sourceUrl,
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonical}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://pointcast.xyz/' },
        { '@type': 'ListItem', position: 2, name: 'Garden', item: 'https://pointcast.xyz/c/garden' },
        { '@type': 'ListItem', position: 3, name: 'Houseplants', item: canonical },
      ],
    },
  ],
};
---

<BlockLayout
  title={title}
  description={description}
  image="/images/og/b/0402.png"
  jsonLd={jsonLd}
  alternates={[
    { type: 'application/json', href: '/b/0402.json', title: 'Houseplant Field School block JSON' },
    { type: 'application/rss+xml', href: '/c/garden.rss', title: 'Garden channel RSS' },
  ]}
  frame={{
    image: 'https://pointcast.xyz/images/og/b/0402.png',
    buttons: [
      { label: 'Open module', action: 'link', target: canonical },
      { label: 'Block 0402', action: 'link', target: blockUrl },
    ],
  }}
>
  <article class="module">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/c/garden">Garden</a>
      <span aria-hidden="true">/</span>
      <span>Houseplants</span>
    </nav>

    <header class="hero">
      <p class="kicker">GARDEN MODULE · HOUSEPLANTS · EL SEGUNDO</p>
      <h1>Houseplant Field School</h1>
      <p class="dek">{description}</p>
      <div class="actions" aria-label="Module links">
        <a href="/b/0402">Open block 0402</a>
        <a href={sourceUrl} target="_blank" rel="noopener">Source on GitHub</a>
      </div>
    </header>

    <section class="lesson" aria-label="Houseplant lesson block">
      <BlockCard block={block} detail />
    </section>
  </article>
</BlockLayout>

<style>
  .module {
    width: min(1040px, calc(100% - 32px));
    margin: 0 auto;
    padding: 42px 0 96px;
  }

  .crumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin: 0 0 30px;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pc-ink-muted);
  }

  .crumb a {
    color: #074638;
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  .hero {
    max-width: 820px;
    margin: 0 0 28px;
  }

  .kicker {
    margin: 0 0 12px;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #074638;
  }

  h1 {
    margin: 0 0 14px;
    font-size: 60px;
    line-height: 0.98;
    font-weight: 540;
    letter-spacing: 0;
  }

  .dek {
    margin: 0;
    max-width: 72ch;
    font-size: 18px;
    line-height: 1.55;
    color: var(--pc-ink-soft);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .actions a {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 9px 13px;
    border: 1.5px solid #0f6e56;
    border-radius: 2px;
    color: #074638;
    font-family: var(--pc-font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .actions a:hover {
    background: #e7f4ef;
  }

  .lesson {
    margin-top: 30px;
  }

  @media (max-width: 640px) {
    .module {
      width: min(100% - 24px, 1040px);
      padding-top: 28px;
    }

    .dek {
      font-size: 16px;
    }

    h1 {
      font-size: 38px;
    }

    .actions a {
      width: 100%;
      justify-content: center;
    }
  }
</style>
