---
/**
 * /houseplants - indoor plant learning lab.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import {
  CARE_LIGHT_OPTIONS,
  HOUSEPLANT_DIAGNOSTICS,
  HOUSEPLANT_LESSONS,
  HOUSEPLANT_PROFILES,
  HOUSEPLANT_SOURCES,
} from '../lib/houseplants';

const title = 'Houseplants · Learning lab';
const description =
  'A PointCast learning module for houseplants: light, watering, roots, soil, humidity, feeding, repotting, propagation, symptoms, and common indoor plant profiles.';

const initialProfile = HOUSEPLANT_PROFILES[0];
const initialDiagnostic = HOUSEPLANT_DIAGNOSTICS[0];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LearningResource',
  '@id': 'https://pointcast.xyz/houseplants',
  name: title,
  description,
  url: 'https://pointcast.xyz/houseplants',
  inLanguage: 'en-US',
  learningResourceType: 'interactive module',
  teaches: HOUSEPLANT_LESSONS.map((lesson) => lesson.title),
  about: HOUSEPLANT_PROFILES.map((plant) => ({
    '@type': 'Thing',
    name: plant.name,
    alternateName: plant.scientific,
    url: `https://pointcast.xyz/houseplants#${plant.slug}`,
  })),
  isPartOf: {
    '@type': 'WebSite',
    name: 'PointCast',
    url: 'https://pointcast.xyz',
  },
};
---

<BlockLayout
  title={title}
  description={description}
  image="/images/og/houseplants.png"
  jsonLd={jsonLd}
  alternates={[
    { type: 'application/json', href: '/houseplants.json', title: 'Houseplant learning lab (JSON)' },
    { type: 'application/json', href: '/nature.json', title: 'El Segundo nature field guide (JSON)' },
  ]}
  frame={{
    image: 'https://pointcast.xyz/images/og/houseplants.png',
    buttons: [
      { label: 'Open Houseplants', action: 'link', target: 'https://pointcast.xyz/houseplants' },
      { label: 'Care Desk', action: 'link', target: 'https://pointcast.xyz/houseplants#care-desk' },
      { label: 'Agent JSON', action: 'link', target: 'https://pointcast.xyz/houseplants.json' },
      { label: 'Nature Guide', action: 'link', target: 'https://pointcast.xyz/nature' },
    ],
  }}
>
  <div class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a><span aria-hidden="true">/</span><a href="/nature">nature</a><span aria-hidden="true">/</span><span>houseplants</span>
    </nav>

    <header class="hero">
      <div class="hero__copy">
        <p class="kicker">HOUSEPLANT SCHOOL · INDOOR GARDENING</p>
        <h1>Learn the room before you treat the leaf.</h1>
        <p class="dek">
          A practical learning module for house plants: light, watering,
          roots, soil, humidity, feeding, repotting, propagation, pests, and
          the common plants that teach each skill.
        </p>
      </div>
      <figure class="hero__visual">
        <img src="/images/houseplants/houseplant-lab.svg" alt="Houseplant learning lab with labeled plants and care cards" width="1440" height="1080" />
      </figure>
    </header>

    <section class="stats" aria-label="Module stats">
      <div><span class="mono">LESSONS</span><strong>{HOUSEPLANT_LESSONS.length}</strong></div>
      <div><span class="mono">PROFILES</span><strong>{HOUSEPLANT_PROFILES.length}</strong></div>
      <div><span class="mono">SYMPTOMS</span><strong>{HOUSEPLANT_DIAGNOSTICS.length}</strong></div>
      <div><span class="mono">BLOCK</span><strong>0333</strong></div>
    </section>

    <section class="desk" id="care-desk" data-care-lab aria-label="Houseplant care desk">
      <div class="section-head">
        <p class="kicker">CARE DESK · DIAGNOSE THE SYSTEM</p>
        <h2>Pick a plant, a room, and a symptom.</h2>
        <p>
          This is not a magic answer box. It is a better first move: compare
          the plant's needs against actual light, watering habit, and visible
          symptom before changing anything.
        </p>
      </div>

      <div class="desk__grid">
        <div class="controls">
          <label><span class="mono">Plant</span>
            <select data-profile>
              {HOUSEPLANT_PROFILES.map((plant) => (
                <option value={plant.slug} selected={plant.slug === initialProfile.slug}>{plant.name}</option>
              ))}
            </select>
          </label>
          <label><span class="mono">Light where it sits</span>
            <select data-light>
              {CARE_LIGHT_OPTIONS.map((light) => (
                <option value={light.id} selected={light.id === 'medium'}>{light.label}</option>
              ))}
            </select>
          </label>
          <label><span class="mono">Watering habit</span>
            <select data-water>
              <option value="checks-soil">I check soil / pot weight</option>
              <option value="calendar">I water on a calendar</option>
              <option value="generous">I water whenever I worry</option>
              <option value="forgetful">I forget until it droops</option>
            </select>
          </label>
          <label><span class="mono">Symptom</span>
            <select data-symptom>
              {HOUSEPLANT_DIAGNOSTICS.map((item) => (
                <option value={item.slug} selected={item.slug === initialDiagnostic.slug}>{item.symptom}</option>
              ))}
            </select>
          </label>
        </div>

        <div class="care-card" aria-live="polite">
          <div class="care-card__top">
            <span class="mono" data-out="archetype">{initialProfile.archetype}</span>
            <strong data-out="plant">{initialProfile.name}</strong>
            <span data-out="latin">{initialProfile.scientific}</span>
          </div>
          <dl class="care-card__facts">
            <div><dt>Light</dt><dd data-out="light">{initialProfile.light}</dd></div>
            <div><dt>Water</dt><dd data-out="water">{initialProfile.water}</dd></div>
            <div><dt>Mix</dt><dd data-out="mix">{initialProfile.mix}</dd></div>
            <div><dt>Skill</dt><dd data-out="skill">{initialProfile.skill}</dd></div>
          </dl>
          <div class="diagnosis">
            <span class="mono">FIRST READ</span>
            <p data-out="diagnosis">{initialDiagnostic.nextMove}</p>
            <small data-out="avoid">{initialDiagnostic.avoid}</small>
          </div>
        </div>
      </div>
    </section>

    <section class="section" aria-label="Lessons">
      <div class="section-head">
        <p class="kicker">CURRICULUM · EIGHT MOVES</p>
        <h2>The plant is the teacher.</h2>
      </div>
      <ol class="lesson-grid">
        {HOUSEPLANT_LESSONS.map((lesson) => (
          <li id={`lesson-${lesson.id}`}>
            <span class="lesson-grid__id mono">{lesson.id}</span>
            <h3>{lesson.title}</h3>
            <p>{lesson.focus}</p>
            <strong>{lesson.takeaway}</strong>
            <small>{lesson.practice}</small>
          </li>
        ))}
      </ol>
    </section>

    <section class="section section--light" aria-label="Light ladder">
      <div class="section-head">
        <p class="kicker">LIGHT LADDER · READ THE SHADOW</p>
        <h2>Light is the budget. Water spends it.</h2>
      </div>
      <div class="light-grid">
        {CARE_LIGHT_OPTIONS.map((light) => (
          <article><span class="mono">{light.label}</span><p>{light.read}</p></article>
        ))}
        <article><span class="mono">Rule</span><p>Lower light means slower growth, slower drying, and less fertilizer. Brighter light raises every other need.</p></article>
      </div>
    </section>

    <section class="section" aria-label="Plant profiles">
      <div class="section-head">
        <p class="kicker">PLANT PROFILES · WHAT EACH ONE TEACHES</p>
        <h2>Pick a plant by the skill you want.</h2>
      </div>
      <div class="profile-grid">
        {HOUSEPLANT_PROFILES.map((plant) => (
          <article class={`profile profile--${plant.lightBand}`} id={plant.slug}>
            <div class="profile__top">
              <span class="mono">{plant.archetype}</span>
              <span class="profile__band mono">{plant.lightBand}</span>
            </div>
            <h3>{plant.name}</h3>
            <p class="latin">{plant.scientific}</p>
            <dl>
              <div><dt>Light</dt><dd>{plant.light}</dd></div>
              <div><dt>Water</dt><dd>{plant.water}</dd></div>
              <div><dt>Propagation</dt><dd>{plant.propagation}</dd></div>
            </dl>
            <p class="watch">{plant.watch}</p>
            <small>{plant.petNote}</small>
            <a href={plant.sourceUrl} target="_blank" rel="noopener" class="source mono">{plant.sourceLabel}</a>
          </article>
        ))}
      </div>
    </section>

    <section class="section" aria-label="Symptom decoder">
      <div class="section-head">
        <p class="kicker">SYMPTOM DECODER · EVIDENCE FIRST</p>
        <h2>Old damage is history. New growth is the report.</h2>
      </div>
      <div class="symptom-grid">
        {HOUSEPLANT_DIAGNOSTICS.map((item) => (
          <article id={`symptom-${item.slug}`}>
            <h3>{item.symptom}</h3>
            <p><strong>Likely:</strong> {item.likely.join(', ')}</p>
            <p><strong>Check:</strong> {item.firstChecks.join(', ')}</p>
            <p>{item.nextMove}</p>
            <small>{item.avoid}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="section section--sources" aria-label="Sources">
      <div class="section-head">
        <p class="kicker">SOURCES · EXTENSION BACKBONE</p>
        <h2>Learning beats plant folklore.</h2>
      </div>
      <ul class="source-list">
        {HOUSEPLANT_SOURCES.map((source) => (
          <li><a href={source.url} target="_blank" rel="noopener">{source.label}</a><span>{source.role}</span></li>
        ))}
      </ul>
    </section>

    <aside class="agent-strip">
      <p class="agent-strip__label">MACHINE-READABLE</p>
      <ul>
        <li><a href="/houseplants.json">/houseplants.json</a></li>
        <li><a href="/b/0333.json">/b/0333.json</a></li>
        <li><a href="/nature.json">/nature.json</a></li>
        <li><a href="/for-agents">/for-agents</a></li>
      </ul>
    </aside>
  </div>

  <script type="application/json" id="houseplant-data" set:html={JSON.stringify({
    profiles: HOUSEPLANT_PROFILES,
    diagnostics: HOUSEPLANT_DIAGNOSTICS,
    lightOptions: CARE_LIGHT_OPTIONS,
  })}></script>

  <script is:inline>
    (function () {
      const root = document.querySelector('[data-care-lab]');
      const dataNode = document.getElementById('houseplant-data');
      if (!root || !dataNode) return;
      const data = JSON.parse(dataNode.textContent || '{}');
      const profiles = data.profiles || [];
      const diagnostics = data.diagnostics || [];
      const lightOptions = data.lightOptions || [];
      const profileSelect = root.querySelector('[data-profile]');
      const lightSelect = root.querySelector('[data-light]');
      const waterSelect = root.querySelector('[data-water]');
      const symptomSelect = root.querySelector('[data-symptom]');
      function bySlug(items, slug) {
        return items.find(function (item) { return item.slug === slug || item.id === slug; }) || items[0];
      }
      function setOut(key, value) {
        const el = root.querySelector('[data-out="' + key + '"]');
        if (el) el.textContent = value || '';
      }
      function waterRead(habit) {
        if (habit === 'calendar') return 'Calendar watering is the risk. Switch to soil depth and pot weight.';
        if (habit === 'generous') return 'Generous watering needs brighter light, airy mix, and no standing saucer water.';
        if (habit === 'forgetful') return 'Forgetting favors drought-storing plants or a smaller collection with a weekly check ritual.';
        return 'Good: soil checks beat calendar rules.';
      }
      function lightRead(profile, roomLight) {
        if (profile.lightBand === 'bright' && roomLight !== 'bright') return 'Light mismatch: this plant likely wants a brighter seat.';
        if (profile.lightBand === 'low' && roomLight === 'bright') return 'Bright light is fine only if it is indirect or softened.';
        const picked = lightOptions.find(function (item) { return item.id === roomLight; });
        return picked ? picked.read : '';
      }
      function render() {
        const profile = bySlug(profiles, profileSelect.value);
        const diagnostic = bySlug(diagnostics, symptomSelect.value);
        setOut('archetype', profile.archetype);
        setOut('plant', profile.name);
        setOut('latin', profile.scientific);
        setOut('light', profile.light + ' ' + lightRead(profile, lightSelect.value));
        setOut('water', profile.water + ' ' + waterRead(waterSelect.value));
        setOut('mix', profile.mix);
        setOut('skill', profile.skill);
        setOut('diagnosis', diagnostic.nextMove);
        setOut('avoid', diagnostic.avoid);
      }
      [profileSelect, lightSelect, waterSelect, symptomSelect].forEach(function (select) {
        select.addEventListener('change', render);
      });
      render();
    })();
  </script>
</BlockLayout>

<style>
  .page { max-width: 1180px; margin: 0 auto; padding: 18px 18px 86px; }
  .mono, .kicker, .crumb, .source, .agent-strip__label { font-family: var(--pc-font-mono); letter-spacing: .14em; text-transform: uppercase; }
  .mono { font-size: 10px; color: var(--pc-ink-muted); }
  .kicker { margin: 0 0 8px; font-size: 10px; color: #074638; }
  .crumb { display: flex; gap: 8px; margin-bottom: 16px; color: var(--pc-ink-muted); font-size: 10px; }
  .hero { display: grid; grid-template-columns: minmax(0,.92fr) minmax(360px,1.08fr); gap: clamp(24px,5vw,62px); align-items: center; min-height: min(720px,calc(100vh - 42px)); padding: 18px 0 32px; border-bottom: 1.5px solid var(--pc-ink); }
  .hero h1 { max-width: 10ch; margin: 0 0 16px; font-size: clamp(4rem,11vw,9rem); font-weight: 500; line-height: .9; letter-spacing: 0; }
  .dek { max-width: 58ch; margin: 0; color: var(--pc-ink-soft); font-size: 17px; line-height: 1.58; }
  .hero__visual { margin: 0; border: 1.5px solid var(--pc-ink); border-radius: 2px; background: #fff; }
  .hero__visual img { display: block; width: 100%; height: auto; }
  .stats { display: grid; grid-template-columns: repeat(4,1fr); border-bottom: 1.5px solid var(--pc-ink); }
  .stats div { min-height: 86px; padding: 12px; border-right: 1px solid var(--pc-rule); }
  .stats div:last-child { border-right: 0; }
  .stats strong { display: block; margin-top: 8px; font-size: clamp(22px,4vw,34px); line-height: 1; }
  .desk, .section { padding: 44px 0; border-top: 1.5px solid var(--pc-ink); }
  .section-head { margin-bottom: 22px; }
  .section-head h2 { max-width: 12ch; margin: 0 0 10px; font-size: clamp(2.1rem,6vw,4.7rem); font-weight: 500; line-height: .98; letter-spacing: 0; }
  .section-head p:not(.kicker) { max-width: 70ch; margin: 0; color: var(--pc-ink-soft); font-size: 15.5px; line-height: 1.58; }
  .desk__grid { display: grid; grid-template-columns: minmax(280px,.78fr) minmax(0,1.22fr); gap: 18px; align-items: start; }
  .controls, .care-card, .lesson-grid li, .light-grid article, .profile, .symptom-grid article { border: 1.5px solid var(--pc-rule); border-radius: 2px; background: #fff; }
  .controls { display: grid; gap: 12px; padding: 16px; border-color: var(--pc-ink); }
  .controls label { display: grid; gap: 6px; }
  select { min-height: 42px; width: 100%; border: 1.5px solid var(--pc-rule); border-radius: 2px; background: #fff; color: var(--pc-ink); font: inherit; padding: 0 10px; }
  .care-card { padding: 18px; border-color: #0f6e56; background: #f2faf6; }
  .care-card__top { display: grid; gap: 5px; padding-bottom: 14px; border-bottom: 1px solid var(--pc-rule); }
  .care-card__top strong { font-size: clamp(32px,6vw,58px); line-height: .96; letter-spacing: 0; }
  .care-card__top span:last-child, .latin { color: var(--pc-ink-soft); font-style: italic; }
  .care-card__facts { display: grid; grid-template-columns: repeat(2,1fr); gap: 12px; margin: 16px 0; }
  .care-card__facts div { display: grid; gap: 5px; }
  dt { font-family: var(--pc-font-mono); font-size: 10px; letter-spacing: .14em; text-transform: uppercase; color: var(--pc-ink-muted); }
  dd { margin: 0; color: var(--pc-ink); font-size: 14px; line-height: 1.45; }
  .diagnosis { padding: 14px; border: 1.5px solid #0f6e56; background: #fff; }
  .diagnosis p { margin: 7px 0; font-size: 17px; line-height: 1.45; }
  .diagnosis small, .profile small, .symptom-grid small, .lesson-grid small { color: var(--pc-ink-muted); font-size: 12.5px; line-height: 1.45; }
  .lesson-grid, .profile-grid, .symptom-grid, .light-grid { display: grid; gap: 10px; }
  .lesson-grid { grid-template-columns: repeat(4,1fr); padding: 0; margin: 0; list-style: none; }
  .lesson-grid li { display: grid; gap: 9px; min-height: 270px; padding: 14px; }
  .lesson-grid__id { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border: 1.5px solid var(--pc-ink); color: var(--pc-ink); }
  .lesson-grid h3, .profile h3, .symptom-grid h3 { margin: 0; font-size: 22px; line-height: 1.08; letter-spacing: 0; }
  .lesson-grid p, .light-grid p, .profile p, .symptom-grid p { margin: 0; color: var(--pc-ink-soft); font-size: 14px; line-height: 1.48; }
  .lesson-grid strong { display: block; font-size: 15px; line-height: 1.4; }
  .light-grid { grid-template-columns: repeat(4,1fr); }
  .light-grid article { min-height: 130px; padding: 14px; }
  .light-grid article:nth-child(1) { border-color: #5f5e5a; }
  .light-grid article:nth-child(2) { border-color: #0f6e56; }
  .light-grid article:nth-child(3) { border-color: #ba7517; }
  .light-grid article:nth-child(4) { border-color: #12110e; background: #f7f7f2; }
  .profile-grid { grid-template-columns: repeat(3,1fr); }
  .profile { display: grid; gap: 12px; padding: 14px; }
  .profile--low { border-left: 5px solid #5f5e5a; }
  .profile--medium { border-left: 5px solid #0f6e56; }
  .profile--bright { border-left: 5px solid #ba7517; }
  .profile__top { display: flex; justify-content: space-between; gap: 12px; align-items: baseline; }
  .profile__band { color: var(--pc-ink); }
  .profile dl { display: grid; gap: 8px; margin: 0; }
  .watch { padding-top: 10px; border-top: 1px solid var(--pc-rule); }
  .source { color: var(--pc-accent); font-size: 10px; }
  .symptom-grid { grid-template-columns: repeat(2,1fr); }
  .symptom-grid article { display: grid; gap: 10px; padding: 14px; }
  .source-list, .agent-strip ul { list-style: none; padding: 0; margin: 0; }
  .source-list { display: grid; gap: 8px; }
  .source-list li { display: grid; grid-template-columns: minmax(220px,.35fr) minmax(0,.65fr); gap: 16px; padding: 12px 0; border-top: 1px solid var(--pc-rule); }
  .source-list span { color: var(--pc-ink-soft); font-size: 14px; line-height: 1.45; }
  .agent-strip { margin-top: 28px; padding: 14px; border: 1.5px solid var(--pc-ink); border-radius: 2px; background: #12110e; color: #fff; }
  .agent-strip__label { margin: 0 0 10px; color: #f7c325; font-size: 10px; }
  .agent-strip ul { display: flex; flex-wrap: wrap; gap: 8px 14px; }
  .agent-strip a { color: #fff; }
  @media (max-width: 980px) {
    .hero, .desk__grid { grid-template-columns: 1fr; }
    .hero { min-height: 0; }
    .lesson-grid, .light-grid, .profile-grid { grid-template-columns: repeat(2,1fr); }
  }
  @media (max-width: 640px) {
    .page { padding-inline: 14px; overflow-x: hidden; }
    .hero h1 { font-size: clamp(3.6rem,18vw,5.4rem); }
    .stats, .care-card__facts, .lesson-grid, .light-grid, .profile-grid, .symptom-grid, .source-list { grid-template-columns: 1fr; }
    .stats div { border-right: 0; border-bottom: 1px solid var(--pc-rule); }
    .hero__visual, .desk, .section { max-width: 100%; }
  }
</style>
