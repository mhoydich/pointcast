---
/**
 * /now — refreshed lighter newspaper-feel surface (2026-04-21).
 *
 * Mike directive (in the rest-of-sprint roadmap, docs/plans/2026-04-20-
 * home-phase3-plus-sprint-plan.md, Tier 2 item):
 *   "/now refresh · 45min · cc. Lighter surface, less dashboard, more
 *    newsroom. Reuses agent dots + recent ledger."
 *
 * v1 was a Sivers-style /now meets system status dashboard — useful but
 * dense. This refresh is a single-page newspaper-style snapshot:
 *
 *   - Masthead: PointCast · El Segundo · the date · pulsing live chip
 *   - Headline: a one-line answer to "what's PointCast doing right now"
 *   - Three columns:
 *       1. RECENT SHIPS (last 5 ledger entries with collab + relative time)
 *       2. INBOX (last 5 pings, fetched client-side from /api/ping)
 *       3. WHERE TO 5-MIN (3 chips: a fresh block, a game, a show)
 *   - Footer: links to /compute /cadence /cos /tv/shows /sprints
 *
 * On mobile the columns stack. The dashboard depth from v1 is in
 * /status (system status surface) for anyone who wants it.
 *
 * Author: cc. Source: 2026-04-20 home phase 3 plan + 2026-04-21
 * "lets keep going" double session continuation.
 */
import BlockLayout from '../layouts/BlockLayout.astro';
import { getCollection } from 'astro:content';
import { CHANNELS } from '../lib/channels';
import { COMPUTE_LEDGER } from '../lib/compute-ledger';

const blocks = (await getCollection('blocks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

const latestBlock = blocks[0] ?? null;
const latestThree = blocks.slice(0, 3);

const ledger = [...COMPUTE_LEDGER]
  .sort((a, b) => new Date(b.at).getTime() - new Date(a.at).getTime())
  .slice(0, 5);

// SEO / GEO: agent-activity telemetry. Cheap to compute (derived from
// the ledger + block authorship), high signal for LLM crawlers that
// land on /now looking for "how active is this site". Counts are for
// the 24h trailing window. Agent ships = blocks authored by Claude
// Code (cc), Codex, or Manus. Human ships = MH-authored blocks.
const DAY_MS = 24 * 60 * 60 * 1000;
const now = Date.now();

const agentAuthors = new Set(['cc', 'claude-code', 'claude', 'codex', 'manus']);
const humanAuthors = new Set(['mh', 'mike-hoydich', 'mike']);

const ships24h = blocks.filter((b) => now - b.data.timestamp.getTime() <= DAY_MS);
const agentShips24h = ships24h.filter((b) => {
  const a = (b.data as any).author?.toString().toLowerCase();
  return a && agentAuthors.has(a);
});
const humanShips24h = ships24h.filter((b) => {
  const a = (b.data as any).author?.toString().toLowerCase();
  return a && humanAuthors.has(a);
});
const mixedShips24h = ships24h.length - agentShips24h.length - humanShips24h.length;

// Ledger-derived: how many compute entries in the last 24h, distinct
// agent collaborators active today. Ledger has a richer signal than
// block authorship because not every compute unit ships a block.
const ledger24h = COMPUTE_LEDGER.filter((e) => now - new Date(e.at).getTime() <= DAY_MS);
const activeAgents24h = Array.from(new Set(ledger24h.map((e) => e.collab))).filter((c) => c !== 'mike-hoydich' && c !== 'mh');

// Three "5-minute" chips — a fresh block, a game, a show. Picks rotate
// daily via the same date-seeded pattern HeroBlock uses elsewhere.
const FIVE_MIN_CHIPS = [
  { kicker: 'BLOCK', title: latestBlock ? latestBlock.data.title : '—', href: latestBlock ? `/b/${latestBlock.data.id}` : '/', accent: '#8A2432' },
  { kicker: 'GAME',  title: 'Noundrum — drum to claim land',  href: '/noundrum', accent: '#F59F00' },
  { kicker: 'WATCH', title: 'Three commercials + a tiny game', href: '/commercials', accent: '#5F2A1E' },
  { kicker: 'SHOW',  title: 'TV / 11 viewables',               href: '/tv/shows/', accent: '#185FA5' },
  { kicker: 'BOARD', title: 'Leaderboards across PointCast',   href: '/leaderboards', accent: '#0B3E73' },
  { kicker: 'TEZOS', title: 'Contracts, tip mike, land sketch', href: '/tezos', accent: '#2f8f5f' },
];

const prettyToday = new Intl.DateTimeFormat('en-US', {
  weekday: 'long', month: 'long', day: 'numeric',
  timeZone: 'America/Los_Angeles',
}).format(new Date());

const title = 'Now — what PointCast is doing this minute';
const description = 'A newspaper-style live snapshot of PointCast right this second: the latest five ships from the federated compute ledger, the latest five pings from the inbox, three places to spend five minutes. Refreshed on every visit; minimal chrome.';

const COLLAB_SHORT: Record<string, string> = {
  'claude-code': 'cc',
  'mh+cc': 'mh+cc',
  'mike-hoydich': 'mh',
  'codex': 'codex',
  'manus': 'manus',
  'chatgpt': 'chatgpt',
};
const SIG_COLOR: Record<string, string> = {
  shy: '#8a7e6c',
  modest: '#185FA5',
  healthy: '#E8590C',
  heavy: '#C92A2A',
};
---

<BlockLayout title={title} description={description}>
  <main class="now-page">
    <!-- Masthead -->
    <header class="masthead">
      <div class="masthead__left">
        <a href="/" class="masthead__brand">PointCast</a>
        <span class="masthead__sep" aria-hidden="true">·</span>
        <span class="masthead__loc mono">El Segundo</span>
      </div>
      <div class="masthead__right">
        <span class="live mono"><span class="live__dot" aria-hidden="true"></span>LIVE</span>
        <span class="masthead__date mono"><span id="now-date">{prettyToday}</span> · <time id="now-time">—:—</time> PT</span>
      </div>
    </header>

    <!-- Headline -->
    <section class="headline">
      <p class="headline__kicker mono">RIGHT NOW · A NEWSPAPER OF ONE INSTANT</p>
      <h1 class="headline__h1">
        {ledger.length > 0 ? (
          <>
            Latest ship: <em>{ledger[0].title}</em>
          </>
        ) : (
          <>What PointCast is doing this minute.</>
        )}
      </h1>
      <p class="headline__dek">
        A live snapshot. The five most recent ships, the five most recent pings landing in the inbox,
        and three places to spend five minutes. Built so a visitor can know everything that matters
        in eight seconds and pick their next move.
      </p>
    </section>

    <!-- Three columns -->
    <section class="cols">
      <!-- RECENT SHIPS -->
      <article class="col">
        <header class="col__head">
          <p class="col__kicker mono">RECENT SHIPS · /COMPUTE</p>
        </header>
        <ol class="ships">
          {ledger.map((e) => (
            <li class="ship" style={`--sig: ${SIG_COLOR[e.signature] ?? '#8a7e6c'}`}>
              <p class="ship__title">
                {e.artifact ? (
                  <a href={e.artifact.startsWith('http') ? e.artifact : e.artifact}>{e.title}</a>
                ) : (
                  e.title
                )}
              </p>
              <p class="ship__meta mono">
                <span class="ship__collab">{COLLAB_SHORT[e.collab] ?? e.collab}</span>
                <span aria-hidden="true">·</span>
                <span class="ship__sig">{e.signature}</span>
                <span aria-hidden="true">·</span>
                <time class="ship__when" data-iso={e.at}>—</time>
              </p>
            </li>
          ))}
        </ol>
        <p class="col__foot mono"><a href="/compute">→ all ships at /compute</a></p>
      </article>

      <!-- INBOX -->
      <article class="col">
        <header class="col__head">
          <p class="col__kicker mono">INBOX · /API/PING</p>
        </header>
        <ol class="inbox" id="now-inbox">
          <li class="inbox__loading mono">loading the inbox…</li>
        </ol>
        <p class="col__foot mono"><a href="/cos">→ /cos to send a message</a></p>
      </article>

      <!-- WHERE TO 5 -->
      <article class="col">
        <header class="col__head">
          <p class="col__kicker mono">WHERE TO 5 · GO HERE NEXT</p>
        </header>
        <ol class="chips">
          {FIVE_MIN_CHIPS.map((c) => (
            <li class="chip" style={`--accent: ${c.accent}`}>
              <a href={c.href} class="chip__link">
                <span class="chip__kicker mono">{c.kicker}</span>
                <span class="chip__title">{c.title}</span>
                <span class="chip__cta mono">→</span>
              </a>
            </li>
          ))}
        </ol>
        <p class="col__foot mono"><a href="/play">→ /play hub for everything</a></p>
      </article>
    </section>

    {/* SEO / GEO: agent-activity pulse. Machine-readable-friendly
        telemetry that answers "how active is this site right now".
        Crawlers landing on /now see a fresh number every visit. The
        linked surfaces (/agents.json, /llms.txt, /for-agents) take
        curious agents directly to the structured entry points. */}
    <section class="agent-pulse" aria-labelledby="ap-heading">
      <div class="agent-pulse__head">
        <p class="agent-pulse__kicker mono" id="ap-heading">AGENT PULSE · LAST 24H</p>
        <p class="agent-pulse__meta mono">updated every build · window = 24h trailing</p>
      </div>
      <dl class="agent-pulse__stats">
        <div class="agent-pulse__stat">
          <dt class="mono">AGENT SHIPS</dt>
          <dd class="agent-pulse__num">{agentShips24h.length}</dd>
          <dd class="agent-pulse__label mono">blocks authored by Claude Code / Codex / Manus</dd>
        </div>
        <div class="agent-pulse__stat">
          <dt class="mono">HUMAN SHIPS</dt>
          <dd class="agent-pulse__num">{humanShips24h.length}</dd>
          <dd class="agent-pulse__label mono">blocks authored by Mike Hoydich</dd>
        </div>
        <div class="agent-pulse__stat">
          <dt class="mono">MIXED / OTHER</dt>
          <dd class="agent-pulse__num">{mixedShips24h}</dd>
          <dd class="agent-pulse__label mono">mh × cc pairs, unattributed, or federated contributors</dd>
        </div>
        <div class="agent-pulse__stat">
          <dt class="mono">COMPUTE ENTRIES</dt>
          <dd class="agent-pulse__num">{ledger24h.length}</dd>
          <dd class="agent-pulse__label mono">federated ledger units (ships + in-flight)</dd>
        </div>
        <div class="agent-pulse__stat">
          <dt class="mono">ACTIVE AGENTS</dt>
          <dd class="agent-pulse__num">{activeAgents24h.length}</dd>
          <dd class="agent-pulse__label mono">
            {activeAgents24h.length > 0 ? activeAgents24h.map((a) => COLLAB_SHORT[a] ?? a).join(' · ') : '—'}
          </dd>
        </div>
      </dl>
      <nav class="agent-pulse__links">
        <a href="/agents.json" class="mono">→ /agents.json</a>
        <a href="/llms.txt" class="mono">→ /llms.txt</a>
        <a href="/for-agents" class="mono">→ /for-agents</a>
        <a href="/agent-native" class="mono">→ /agent-native</a>
      </nav>
    </section>

    <!-- Extra stripe — commercial-of-the-moment + leaderboard top-3 (overnight-12) -->
    <section class="extra">
      <article class="extra__cell extra__cell--watch">
        <p class="extra__kicker mono">WATCH NOW · COMMERCIAL OF THE MOMENT</p>
        <p class="extra__title" id="extra-com-title">—</p>
        <p class="extra__sub mono" id="extra-com-sub">—</p>
        <a class="extra__cta mono" href="/tv/shows/commercials">→ /tv/shows/commercials (fullscreen carousel)</a>
      </article>
      <article class="extra__cell extra__cell--board">
        <p class="extra__kicker mono">WHO'S WINNING · YOUR LEADERBOARD POSITION</p>
        <ul class="extra__board-list" id="extra-board-list">
          <li class="extra__board-row mono">loading your scores…</li>
        </ul>
        <a class="extra__cta mono" href="/leaderboards">→ /leaderboards (8 boards)</a>
      </article>
    </section>

    <!-- Footer -->
    <footer class="now-foot">
      <p class="mono">
        <a href="/compute">/compute</a>
        <span aria-hidden="true">·</span>
        <a href="/cadence">/cadence</a>
        <span aria-hidden="true">·</span>
        <a href="/cos">/cos</a>
        <span aria-hidden="true">·</span>
        <a href="/tv">/tv</a>
        <span aria-hidden="true">·</span>
        <a href="/tv/shows">/tv/shows</a>
        <span aria-hidden="true">·</span>
        <a href="/sprints">/sprints</a>
        <span aria-hidden="true">·</span>
        <a href="/status">→ system status dashboard</a>
      </p>
      <p class="now-foot__note mono">
        page refreshed {new Date().toLocaleString('en-US', { timeZone: 'America/Los_Angeles', hour12: false })} PT · ledger has {COMPUTE_LEDGER.length} entries · {blocks.length} blocks live
      </p>
    </footer>
  </main>
</BlockLayout>

<script is:inline>
(function () {
  // ---- Live clock --------------------------------------------------------
  function tickClock() {
    var t = document.getElementById('now-time');
    if (!t) return;
    var d = new Date();
    var s = d.toLocaleString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false, timeZone: 'America/Los_Angeles' });
    t.textContent = s;
  }
  tickClock();
  setInterval(tickClock, 1000);

  // ---- Relative-time labels ---------------------------------------------
  function fmtAgo(ms) {
    if (ms < 60_000) return 'just now';
    if (ms < 3600_000) return Math.round(ms / 60_000) + 'm ago';
    if (ms < 86400_000) return Math.round(ms / 3600_000) + 'h ago';
    if (ms < 7 * 86400_000) return Math.round(ms / 86400_000) + 'd ago';
    return Math.round(ms / (7 * 86400_000)) + 'w ago';
  }
  function paintRelativeTimes() {
    var now = Date.now();
    document.querySelectorAll('time[data-iso]').forEach(function (el) {
      var iso = el.getAttribute('data-iso');
      if (!iso) return;
      var t = new Date(iso).getTime();
      if (isNaN(t)) return;
      el.textContent = fmtAgo(now - t);
    });
  }
  paintRelativeTimes();
  setInterval(paintRelativeTimes, 30_000);

  // ---- Commercial of the moment (rotates by current minute %3) ----------
  var COMMERCIALS = [
    { title: 'PointCast — Tokyo broadcast', sub: '1967 · Showa-era anachronism' },
    { title: 'Magpie — corner-store ad',     sub: '1970s–80s · the era is on the screen' },
    { title: 'Magpie × Lego — block by block', sub: '1980s–90s · imagined crossover' },
  ];
  function paintCommercial() {
    var m = new Date().getMinutes();
    var c = COMMERCIALS[m % COMMERCIALS.length];
    var t = document.getElementById('extra-com-title');
    var s = document.getElementById('extra-com-sub');
    if (t) t.textContent = c.title;
    if (s) s.textContent = c.sub;
  }
  paintCommercial();
  setInterval(paintCommercial, 60_000);

  // ---- Leaderboard top-3 — show your scores across the 3 most-tracked boards
  function readSource(source, field) {
    try {
      var raw = localStorage.getItem(source);
      if (!raw) return 0;
      if (field === 'self') {
        var n = Number(raw);
        if (!isNaN(n)) return n;
        try { var p = JSON.parse(raw); return Number(p) || 0; } catch (e) { return 0; }
      }
      var parsed;
      try { parsed = JSON.parse(raw); } catch (e) { return 0; }
      var parts = field.split('.');
      var v = parsed;
      for (var i = 0; i < parts.length; i++) {
        if (v == null) return 0;
        if (parts[i] === 'length' && Array.isArray(v)) return v.length;
        v = v[parts[i]];
      }
      var num = Number(v);
      if (isNaN(num)) return Array.isArray(v) ? v.length : 0;
      return num;
    } catch (e) { return 0; }
  }
  function paintBoard() {
    var BOARDS = [
      { label: 'drum lifetime',     source: 'pc:drum:state',     field: 'lifetime' },
      { label: 'noundrum tiles',    source: 'pc:noundrum:state', field: 'ownedTiles.length' },
      { label: 'noundrum best',     source: 'pc:noundrum:state', field: 'bestTiles' },
      { label: 'noundrum claims',   source: 'pc:noundrum:state', field: 'lifetimeClaims' },
      { label: 'cards collected',   source: 'pc:cards:deck',     field: 'length' },
      { label: 'commercials guess', source: 'pc:commercials:score', field: 'self' },
    ];
    var top = BOARDS.map(function (b) { return { label: b.label, score: readSource(b.source, b.field) }; })
                   .sort(function (a, b) { return b.score - a.score; })
                   .slice(0, 3);
    var listEl = document.getElementById('extra-board-list');
    if (!listEl) return;
    listEl.innerHTML = '';
    top.forEach(function (b, i) {
      var li = document.createElement('li');
      li.className = 'extra__board-row mono';
      li.innerHTML = '<span class="extra__board-rank">' + (i + 1) + '</span><span class="extra__board-label">' + b.label + '</span><span class="extra__board-score">' + b.score + '</span>';
      listEl.appendChild(li);
    });
  }
  paintBoard();
  setInterval(paintBoard, 30_000);

  // ---- Inbox fetch (client-side, /api/ping?action=list) ------------------
  async function loadInbox() {
    var box = document.getElementById('now-inbox');
    if (!box) return;
    try {
      var res = await fetch('/api/ping?action=list');
      if (!res.ok) { box.innerHTML = '<li class="inbox__loading mono">inbox unreachable · try /cos</li>'; return; }
      var j = await res.json();
      var entries = (j && Array.isArray(j.entries)) ? j.entries.slice(-5).reverse() : [];
      if (!entries.length) { box.innerHTML = '<li class="inbox__loading mono">no pings yet</li>'; return; }
      box.innerHTML = '';
      entries.forEach(function (e) {
        var msg = e.message || {};
        var li = document.createElement('li');
        li.className = 'inbox__row';
        var subj = msg.subject ? '<span class="inbox__subj">' + escapeHtml(msg.subject) + '</span>' : '';
        var from = msg.from ? '<span class="inbox__from">' + escapeHtml(msg.from) + '</span>' : '<span class="inbox__from inbox__from--anon">anon</span>';
        var body = (msg.body || '').toString().slice(0, 160);
        var when = '<time class="inbox__when mono" data-iso="' + escapeAttr(msg.timestamp || '') + '">—</time>';
        li.innerHTML =
          '<p class="inbox__head mono">' + from + (msg.expand ? '<span class="inbox__expand">EXPAND</span>' : '') + ' · ' + when + '</p>' +
          (subj ? '<p class="inbox__subjline">' + subj + '</p>' : '') +
          '<p class="inbox__body">' + escapeHtml(body) + (body.length === 160 ? '…' : '') + '</p>';
        box.appendChild(li);
      });
      paintRelativeTimes();
    } catch (e) {
      box.innerHTML = '<li class="inbox__loading mono">inbox unreachable · try /cos</li>';
    }
  }
  function escapeHtml(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }
  function escapeAttr(s) {
    return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;');
  }
  loadInbox();
})();
</script>

<style>
  .now-page { max-width: 1200px; margin: 0 auto; padding: 22px 18px 60px; color: var(--pc-ink, #12110E); }
  .mono { font-family: var(--pc-font-mono, 'JetBrains Mono Variable', monospace); }

  /* Masthead — single row, newspaper-style */
  .masthead {
    display: flex; align-items: baseline; justify-content: space-between;
    border-bottom: 2px solid var(--pc-ink, #12110E);
    padding-bottom: 10px; margin-bottom: 18px;
    flex-wrap: wrap; gap: 8px;
  }
  .masthead__left { display: flex; align-items: baseline; gap: 8px; }
  .masthead__brand {
    font-family: var(--pc-font-sans, 'Syne', system-ui);
    font-weight: 700;
    font-size: clamp(24px, 3vw, 32px);
    letter-spacing: -0.01em;
    color: var(--pc-ink);
    text-decoration: none;
  }
  .masthead__brand:hover { color: #8A2432; }
  .masthead__sep { color: var(--pc-ink-muted, #5F5E5A); font-size: 18px; }
  .masthead__loc { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--pc-ink-muted); font-weight: 600; }
  .masthead__right { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; }
  .live { display: inline-flex; align-items: center; gap: 6px; font-size: 10px; letter-spacing: 0.22em; font-weight: 700; padding: 3px 8px; border: 1px solid #C92A2A; background: rgba(201, 42, 42, 0.1); color: #8A2432; border-radius: 2px; }
  .live__dot { width: 6px; height: 6px; border-radius: 50%; background: #C92A2A; box-shadow: 0 0 6px rgba(201, 42, 42, 0.6); animation: nw-blink 2s ease-in-out infinite; }
  @keyframes nw-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
  .masthead__date { font-size: 11px; letter-spacing: 0.1em; color: var(--pc-ink-muted); font-weight: 600; font-variant-numeric: tabular-nums; text-transform: uppercase; }

  /* Headline */
  .headline { margin: 0 0 22px; padding-bottom: 16px; border-bottom: 1px solid var(--pc-rule-soft, #E5E3DE); }
  .headline__kicker { font-size: 10.5px; letter-spacing: 0.22em; text-transform: uppercase; color: #8A2432; margin: 0 0 8px; font-weight: 700; }
  .headline__h1 { font-family: var(--pc-font-sans, 'Syne', system-ui); font-size: clamp(22px, 3.4vw, 36px); font-weight: 500; margin: 0 0 10px; line-height: 1.18; letter-spacing: -0.01em; color: var(--pc-ink); }
  .headline__h1 em { font-style: italic; color: #8A2432; }
  .headline__dek { font-family: Georgia, 'Times New Roman', serif; font-size: 14.5px; line-height: 1.55; color: var(--pc-ink-soft, #38373A); margin: 0; max-width: 70ch; }

  /* Three columns */
  .cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin-bottom: 30px;
  }
  .col {
    background: transparent;
    border-top: 3px solid var(--pc-ink);
    padding-top: 12px;
  }
  .col__head { margin-bottom: 12px; }
  .col__kicker { font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: #5F2A1E; margin: 0; font-weight: 700; }
  .col__foot { font-size: 11px; letter-spacing: 0.06em; color: var(--pc-ink-muted); margin: 14px 0 0; padding-top: 10px; border-top: 1px dotted var(--pc-rule-soft, #E5E3DE); }
  .col__foot a { color: #8A2432; text-decoration: underline; text-decoration-color: rgba(138, 36, 50, 0.3); }
  .col__foot a:hover { text-decoration-color: currentColor; }

  /* Ships column */
  .ships { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
  .ship {
    padding-left: 12px;
    border-left: 3px solid var(--sig, #8a7e6c);
  }
  .ship__title { font-family: Georgia, serif; font-size: 14.5px; line-height: 1.35; margin: 0 0 4px; color: var(--pc-ink); font-weight: 500; }
  .ship__title a { color: var(--pc-ink); text-decoration: underline; text-decoration-color: rgba(0,0,0,0.18); }
  .ship__title a:hover { color: #8A2432; text-decoration-color: currentColor; }
  .ship__meta { font-size: 10.5px; letter-spacing: 0.08em; color: var(--pc-ink-muted); display: flex; gap: 8px; align-items: baseline; flex-wrap: wrap; text-transform: uppercase; font-weight: 600; }
  .ship__collab { color: var(--sig, #8a7e6c); font-weight: 700; }
  .ship__sig { color: var(--pc-ink-muted); }

  /* Inbox column */
