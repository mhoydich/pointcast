---
/**
 * AuthMenu.astro
 * Unified sign-in dropdown for PointCast.
 *
 * This component is SEPARATE from WalletConnect.astro:
 *   - WalletConnect.astro: Handles wallet connections for on-chain interactions (Beacon SDK).
 *   - AuthMenu.astro: Handles authentication and identity (who you are).
 *
 * Usage:
 *   <AuthMenu />
 *
 * The component reads the current auth state from /api/auth/me on mount.
 * If authenticated, it shows the user's drum name and a sign-out button.
 * If not, it shows the sign-in dropdown.
 */
---

<div id="auth-menu" class="auth-menu" aria-label="Authentication menu">
  <!-- Loading state -->
  <div id="auth-loading" class="auth-state" aria-hidden="true">
    <span class="auth-loading-indicator">···</span>
  </div>

  <!-- Signed-out state -->
  <div id="auth-signed-out" class="auth-state hidden">
    <button
      id="auth-trigger"
      type="button"
      class="auth-trigger-btn"
      aria-expanded="false"
      aria-haspopup="true"
      aria-controls="auth-dropdown"
    >
      Sign In
      <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
        <path d="M6 8L1 3h10L6 8z"/>
      </svg>
    </button>

    <div
      id="auth-dropdown"
      class="auth-dropdown hidden"
      role="menu"
      aria-labelledby="auth-trigger"
    >
      <!-- Social Providers -->
      <div class="auth-group">
        <p class="auth-group-label">Social</p>

        <button class="auth-option" data-provider="google" role="menuitem">
          <svg class="auth-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Continue with Google
        </button>

        <button class="auth-option" data-provider="apple" role="menuitem">
          <svg class="auth-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Continue with Apple
        </button>
      </div>

      <!-- Tezos Wallets -->
      <div class="auth-group">
        <p class="auth-group-label">Tezos Wallets</p>

        <button class="auth-option" data-provider="kukai" role="menuitem">
          <span class="auth-icon auth-icon-text">KU</span>
          Kukai Wallet
        </button>

        <button class="auth-option" data-provider="temple" role="menuitem">
          <span class="auth-icon auth-icon-text">TE</span>
          Temple Wallet
        </button>

        <button class="auth-option" data-provider="umami" role="menuitem">
          <span class="auth-icon auth-icon-text">UM</span>
          Umami Wallet
        </button>
      </div>

      <!-- Other Chains (Phase 3) — Hidden by default -->
      <div class="auth-group auth-group-hidden" id="auth-other-chains" aria-hidden="true" style="display:none">
        <p class="auth-group-label">Other Chains</p>
        <button class="auth-option" data-provider="metamask" role="menuitem">
          <span class="auth-icon auth-icon-text">MM</span>
          MetaMask
        </button>
        <button class="auth-option" data-provider="phantom" role="menuitem">
          <span class="auth-icon auth-icon-text">PH</span>
          Phantom
        </button>
      </div>
    </div>
  </div>

  <!-- Signed-in state -->
  <div id="auth-signed-in" class="auth-state hidden">
    <button
      id="auth-user-trigger"
      type="button"
      class="auth-trigger-btn auth-trigger-btn--user"
      aria-expanded="false"
      aria-haspopup="true"
      aria-controls="auth-user-dropdown"
    >
      <span id="auth-drum-name" class="auth-drum-name">···</span>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
        <path d="M6 8L1 3h10L6 8z"/>
      </svg>
    </button>

    <div
      id="auth-user-dropdown"
      class="auth-dropdown hidden"
      role="menu"
      aria-labelledby="auth-user-trigger"
    >
      <div class="auth-group">
        <button class="auth-option" id="auth-signout-btn" role="menuitem">
          Sign Out
        </button>
        <button class="auth-option auth-option--danger" id="auth-delete-btn" role="menuitem">
          Delete Account
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  // ---------------------------------------------------------------------------
  // AuthMenu client-side logic
  // ---------------------------------------------------------------------------
  (async () => {
    const loadingEl = document.getElementById('auth-loading')!;
    const signedOutEl = document.getElementById('auth-signed-out')!;
    const signedInEl = document.getElementById('auth-signed-in')!;
    const drumNameEl = document.getElementById('auth-drum-name')!;

    // -------------------------------------------------------------------------
    // 1. Check current auth state
    // -------------------------------------------------------------------------
    async function checkAuth() {
      try {
        const res = await fetch('/api/auth/me', { credentials: 'same-origin' });
        if (res.ok) {
          const data = await res.json() as { authenticated: boolean; user?: { preferences: { drumName?: string } } };
          if (data.authenticated && data.user) {
            drumNameEl.textContent = data.user.preferences.drumName || 'Anonymous';
            loadingEl.classList.add('hidden');
            signedInEl.classList.remove('hidden');
            return;
          }
        }
      } catch (err) {
        console.warn('[AuthMenu] Could not reach /api/auth/me:', err);
      }
      loadingEl.classList.add('hidden');
      signedOutEl.classList.remove('hidden');
    }

    await checkAuth();

    // -------------------------------------------------------------------------
    // 2. Dropdown toggle logic
    // -------------------------------------------------------------------------
    function setupDropdown(triggerId: string, dropdownId: string) {
      const trigger = document.getElementById(triggerId);
      const dropdown = document.getElementById(dropdownId);
      if (!trigger || !dropdown) return;

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        dropdown.classList.toggle('hidden');
      });

      document.addEventListener('click', () => {
        trigger.setAttribute('aria-expanded', 'false');
        dropdown.classList.add('hidden');
      });
    }

    setupDropdown('auth-trigger', 'auth-dropdown');
    setupDropdown('auth-user-trigger', 'auth-user-dropdown');

    // -------------------------------------------------------------------------
    // 3. Provider sign-in handlers
    // -------------------------------------------------------------------------
    const preferences = {
      drumName: localStorage.getItem('pc:drumName') ?? undefined,
      noun: localStorage.getItem('pc:noun') ?? undefined,
    };

    document.querySelectorAll<HTMLButtonElement>('.auth-option[data-provider]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const provider = btn.dataset.provider as string;
        console.log(`[AuthMenu] Initiating sign-in: ${provider}`);

        if (provider === 'google' || provider === 'apple') {
          // OAuth redirect flow
          const params = new URLSearchParams();
          if (preferences.drumName) params.set('drumName', preferences.drumName);
          if (preferences.noun) params.set('noun', preferences.noun);
          window.location.href = `/api/auth/${provider}/login?${params.toString()}`;

        } else if (['kukai', 'temple', 'umami', 'metamask', 'phantom'].includes(provider)) {
          // Web3 challenge-response flow
          await handleWeb3Auth(provider);
        }
      });
    });

    // -------------------------------------------------------------------------
    // 4. Web3 auth flow
    // -------------------------------------------------------------------------
    async function handleWeb3Auth(provider: string) {
      try {
        // Step 1: Get nonce from backend
        const nonceRes = await fetch('/api/auth/web3/nonce', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-PointCast-Request': '1' },
          body: JSON.stringify({ provider }),
        });
        const { nonce } = await nonceRes.json() as { nonce: string };

        let signature = '';
        let message = '';
        let publicKey = '';

        if (['kukai', 'temple', 'umami'].includes(provider)) {
          // Tezos: Use Beacon SDK
          // TODO: Import and use @airgap/beacon-sdk
          // const client = new DAppClient({ name: 'PointCast' });
          // const activeAccount = await client.getActiveAccount();
          // const payload = `Tezos Signed Message: pointcast.app ${new Date().toISOString()} ${nonce}`;
          // const result = await client.requestSignPayload({ signingType: SigningType.MICHELINE, payload });
          // signature = result.signature;
          // message = payload;
          // publicKey = result.signerPublicKey;
          console.warn('[AuthMenu] TODO: Implement Beacon SDK signing for', provider);
          return;

        } else if (provider === 'metamask') {
          // Ethereum: SIWE
          // TODO: Use viem or ethers to format and sign SIWE message
          console.warn('[AuthMenu] TODO: Implement MetaMask SIWE signing');
          return;

        } else if (provider === 'phantom') {
          // Solana: SIWS
          // TODO: Use @solana/wallet-adapter or window.solana
          console.warn('[AuthMenu] TODO: Implement Phantom SIWS signing');
          return;
        }

        // Step 2: Verify signature with backend
        const verifyRes = await fetch('/api/auth/web3/verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-PointCast-Request': '1' },
          body: JSON.stringify({ provider, signature, message, nonce, publicKey, preferences }),
        });

        if (!verifyRes.ok) {
          const err = await verifyRes.json() as { error: string };
          console.error('[AuthMenu] Verification failed:', err.error);
          return;
        }

        // Step 3: Reload to reflect new auth state
        window.location.reload();

      } catch (err) {
        console.error('[AuthMenu] Web3 auth error:', err);
      }
    }

    // -------------------------------------------------------------------------
    // 5. Sign out
    // -------------------------------------------------------------------------
    document.getElementById('auth-signout-btn')?.addEventListener('click', async () => {
      await fetch('/api/auth/me', {
        method: 'DELETE',
        headers: { 'X-PointCast-Request': '1' },
        credentials: 'same-origin',
      });
      window.location.reload();
    });

    // -------------------------------------------------------------------------
    // 6. Delete account
    // -------------------------------------------------------------------------
    document.getElementById('auth-delete-btn')?.addEventListener('click', async () => {
      if (!confirm('Permanently delete your PointCast account? This cannot be undone.')) return;
      // TODO: Call DELETE /api/auth/me/account
      console.warn('[AuthMenu] TODO: Implement full account deletion endpoint');
    });
  })();
</script>

<style>
  .auth-menu {
    position: relative;
    display: inline-block;
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 0.875rem;
  }

  .auth-state { display: inline-block; }
  .auth-state.hidden { display: none; }

  .auth-trigger-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    background: white;
    color: #374151;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background 0.15s;
  }

  .auth-trigger-btn:hover { background: #f9fafb; }
  .auth-trigger-btn--user { font-weight: 600; }

  .auth-dropdown {
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    min-width: 14rem;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    z-index: 100;
    overflow: hidden;
  }

  .auth-dropdown.hidden { display: none; }

  .auth-group {
    padding: 0.5rem 0;
    border-bottom: 1px solid #f3f4f6;
  }

  .auth-group:last-child { border-bottom: none; }

  .auth-group-label {
    padding: 0.25rem 1rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
    margin: 0;
  }

  .auth-option {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    width: 100%;
    padding: 0.5rem 1rem;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    font-size: 0.875rem;
    color: #374151;
    transition: background 0.1s;
  }

  .auth-option:hover { background: #f9fafb; }
  .auth-option--danger { color: #dc2626; }
  .auth-option--danger:hover { background: #fef2f2; }

  .auth-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  .auth-icon-text {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 0.25rem;
    background: #e5e7eb;
    font-size: 0.6rem;
    font-weight: 700;
    color: #6b7280;
    flex-shrink: 0;
  }

  .auth-drum-name {
    max-width: 8rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .auth-loading-indicator {
    color: #9ca3af;
    font-size: 0.875rem;
    letter-spacing: 0.1em;
  }
</style>
