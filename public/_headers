# Cloudflare Pages headers.
#
# HTML: must-revalidate so returning visitors always get the newest copy
# (the pages embed live content like presence, drums, visits that shouldn't
# be served stale from browser cache). Bundled JS/CSS have content-hashed
# filenames so they can be cached forever.
#
# Long-cache the OG image. iMessage's LinkPresentation will occasionally
# fail to show a preview if the image response has ambiguous caching.
# Making it immutable + public means every unfurl consumer can cache the
# same bytes indefinitely; we bust by changing the filename when the
# asset actually changes.

/*
  Cache-Control: public, max-age=0, must-revalidate

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/images/og-home-v3.png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/images/og-home-v3.svg
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Legacy v2 — kept served for any stale shares. Safe to drop after a few weeks.
/images/og-home-v2.png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/images/og-home-v2.svg
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/images/og-drum.png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/images/og-drum.svg
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/images/og-collect.png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/images/og-collect.svg
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/images/og-about.png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/images/og-about.svg
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Keep the legacy default served — existing shared links may reference it.
/images/og-default.png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/images/og-default.svg
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Other static images — self-hosted token art etc. — can be cached for a
# week. Short enough to refresh when we re-run fetch-market.mjs, long
# enough that Cloudflare's edge does the heavy lifting.
/images/tokens/*
  Cache-Control: public, max-age=604800
