# Cloudflare Pages redirects.
#
# Note: same-host redirects only. Cross-host (www ↔ apex) is handled in
# functions/_middleware.ts since Pages' _redirects file cannot rewrite
# the hostname.

# Agent discovery — conventional .well-known path maps to /agents.json
# so agents following the "well-known" discovery pattern find us without
# having to read /for-agents first.
/.well-known/agents.json  /agents.json  200
/.well-known/ai.json      /agents.json  200

# Canonical shorthand for the unified RSS feed — /rss redirects to
# /feed.xml. The legacy /rss.xml still serves the posts-only archive
# for back-compat with existing subscribers. Readers looking for "the
# PointCast RSS feed" expect /rss; this gives them /feed.xml.
/rss  /feed.xml  302

# URL-resolve rewrites — the trailing-slash fix for pretty-URL routes
# (/gamgee, /gandalf, /farm, etc.) is handled in functions/_middleware.ts
# via an internal server-side fetch. CF Pages' _redirects file can't
# catch the literal-path case because static-HTML trailing-slash logic
# runs before _redirects parsing. The middleware approach keeps the
# URL bar clean.
