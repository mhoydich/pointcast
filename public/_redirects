# Cloudflare Pages redirects.
#
# Note: same-host redirects only. Cross-host (www ↔ apex) is handled in
# functions/_middleware.ts since Pages' _redirects file cannot rewrite
# the hostname.

# Agent discovery — conventional .well-known path maps to /agents.json
# so agents following the "well-known" discovery pattern find us without
# having to read /for-agents first.
/.well-known/agents.json  /agents.json  200
/.well-known/ai.json      /agents.json  200

# Canonical shorthand for the unified RSS feed — /rss redirects to
# /feed.xml. The legacy /rss.xml still serves the posts-only archive
# for back-compat with existing subscribers. Readers looking for "the
# PointCast RSS feed" expect /rss; this gives them /feed.xml.
/rss  /feed.xml  302

# URL-resolve rewrites — kill the 308 trailing-slash flash for the
# top-level release + game + companion routes. Without these, typing
# `pointcast.xyz/gamgee` in the URL bar hits a 308 → /gamgee/ before
# the HTML loads. Mike surfaced this 2026-04-23. These 200 rewrites
# serve the index.html directly at the short slug.
/gamgee                /gamgee/index.html                 200
/gandalf               /gandalf/index.html                200
/farm                  /farm/index.html                   200
/race                  /race/index.html                   200
/race/front-door       /race/front-door/index.html        200
/talk                  /talk/index.html                   200
/listen                /listen/index.html                 200
/agent-derby           /agent-derby/index.html            200
/tonight               /tonight/index.html                200
/typing                /typing/index.html                 200
/workbench             /workbench/index.html              200
/sitting-with-gandalf  /sitting-with-gandalf/index.html   200
