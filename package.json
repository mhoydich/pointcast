{
  "name": "pointcast",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/clean-build.mjs && node scripts/generate-og-images.mjs && astro build",
    "build:bare": "astro build",
    "clean:build": "node scripts/clean-build.mjs",
    "preview": "astro preview",
    "test": "npm run test:protocol",
    "test:protocol": "node --test tests/protocol-packet.test.mjs",
    "og": "node scripts/generate-og-images.mjs",
    "audit:agents": "node scripts/audit-agent-surfaces.mjs",
    "audit:publishing": "node scripts/audit-publishing.mjs",
    "manus:list": "node scripts/manus.mjs list",
    "manus:create": "node scripts/manus.mjs create",
    "publish:live": "node scripts/publish-live.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@farcaster/miniapp-sdk": "^0.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@taquito/beacon-wallet": "^24.2.0",
    "@taquito/michel-codec": "^24.3.0",
    "@taquito/signer": "^24.3.0",
    "@taquito/taquito": "^24.2.0",
    "@taquito/utils": "^24.3.0",
    "astro": "^6.1.6",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "vite-plugin-node-polyfills": "^0.26.0"
  }
}
