{
  "name": "pointcast",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/generate-og-images.mjs && node scripts/build-deck-poster.mjs && node scripts/build-passport-posters.mjs && astro build",
    "build:bare": "astro build",
    "preview": "astro preview",
    "og": "node scripts/generate-og-images.mjs",
    "audit:publishing": "node scripts/audit-publishing.mjs",
    "posters": "node scripts/build-deck-poster.mjs && node scripts/build-passport-posters.mjs",
    "passport:posters": "node scripts/build-passport-posters.mjs",
    "hash:skills": "node scripts/hash-agent-skills.mjs",
    "sync:codex": "node scripts/sync-codex-workspace.mjs",
    "sync:codex:apply": "node scripts/sync-codex-workspace.mjs --apply",
    "walk:codex": "node scripts/walk-codex-workspaces.mjs",
    "attribute:git": "node scripts/git-branch-attribution.mjs",
    "install:hooks": "node scripts/install-git-hooks.mjs",
    "push:nightly": "node scripts/nightly-push.mjs",
    "push:nightly:apply": "node scripts/nightly-push.mjs --apply",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@taquito/beacon-wallet": "^24.2.0",
    "@taquito/taquito": "^24.2.0",
    "astro": "^6.1.6",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "vite-plugin-node-polyfills": "^0.26.0"
  }
}
